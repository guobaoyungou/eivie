<view><block wx:if="{{isload}}"><block><view class="container"><block wx:if="{{pics.length>0}}"><swiper class="swiper" indicator-dots="{{pics[1]?true:false}}" autoplay="true" interval="{{5000}}"><block wx:for="{{pics}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><swiper-item class="swiper-item"><image src="{{item}}" mode="widthFix"></image></swiper-item></block></block></swiper></block><view class="datalist"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="collage-product" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block wx:if="{{item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view><view class="p3"><view class="t1">礼包数量<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">立即购买</text></view></view></view></view></block></block></view><block wx:if="{{nomore}}"><nomore vue-id="3e336901-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="3e336901-2" bind:__l="__l"></nodata></block></view><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的套餐</button></block></block><block wx:if="{{loading}}"><loading vue-id="3e336901-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="3e336901-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="3e336901-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>