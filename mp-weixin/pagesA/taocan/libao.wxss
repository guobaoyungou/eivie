:flex-start}.shop-info-view .shop-title{color:#1a1a1a;font-size:24rpx;font-weight:700}.shop-info-view .shop-tisp{color:#aaa;font-size:24rpx;margin-top:20rpx}.addnum{width:auto;position:absolute;right:30rpx;bottom:30rpx;font-size:26rpx;color:#666;display:flex;align-items:center;justify-content:flex-end;padding:0rpx 8rpx}.addnum .plus{width:43rpx;height:43rpx;background:#fd4a46;color:#fff;border-radius:8rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx}.addnum .minus{width:43rpx;height:43rpx;background:#fff;color:#fd4a46;border:1px solid #fd4a46;border-radius:8rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx}.addnum .i{padding:0 20rpx;color:#999;font-size:26rpx}.but-class{width:100%;height:165rpx;background:#fff;position:fixed;bottom:0rpx;padding:20rpx;border-top:1px #ebebeb solid}.but-class .but-content{width:94%;margin:0 auto;height:calc(165rpx - env(safe-area-inset-bottom));display:flex;align-items:center;justify-content:space-between}.but-class .but-content .quedingbut{width:380rpx;height:50%;text-align:center;display:flex;align-items:center;justify-content:center;border-radius:100rpx;font-size:30rpx;font-weight:700;color:#fff;background:#f94b30}.but-class .but-content .quedingbut2{width:380rpx;height:50%;text-align:center;display:flex;align-items:center;justify-content:center;border-radius:100rpx;font-size:30rpx;font-weight:700;color:#fff;background:grey}.but-left-info .info1{display:flex;align-items:flex-end;justify-content:flex-start}.but-left-info .info1 .text1{color:#f94b30;font-size:24rpx}.but-left-info .info1 .text2{color:#f94b30;font-size:36rpx;font-weight:700}.but-left-info .info2{color:rgba(34,34,34,.6);font-size:24rpx}.addnum .input{flex:1;width:120rpx;border:0;text-align:center;color:#2b2b2b;font-size:24rpx}