px;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>添加车辆</view></block></block><block wx:if="{{loading}}"><loading vue-id="232fcc06-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="232fcc06-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="232fcc06-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>