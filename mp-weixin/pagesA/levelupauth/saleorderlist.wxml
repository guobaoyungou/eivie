<view class="container"><block wx:if="{{isload}}"><block><dd-tab vue-id="51c25626-1" itemdata="{{['全部','待付款','已付款']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="order-box" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><block wx:if="{{item.status==0}}"><text class="st0">待付款</text></block><block wx:if="{{item.status==1}}"><text class="st1">{{item.ordertype==1?'已领取':'已付款'}}</text></block><block wx:if="{{item.status==-1}}"><text class="st2">已取消</text></block></view><view class="content"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.title}}</text><text class="t2" style="color:#666;">{{(item.ordertype==1?'赠送':'售卖')+"等级："+item.levelname}}</text></view></view><view class="bottom"><text>{{"金额:￥"+item.totalprice}}</text></view><view class="op"><view class="btn2" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">订单详情</view></view></view></block></block></view><block wx:if="{{nomore}}"><nomore vue-id="51c25626-2" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="51c25626-3" bind:__l="__l"></nodata></block></block></block><block wx:if="{{loading}}"><loading vue-id="51c25626-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="51c25626-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="51c25626-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>