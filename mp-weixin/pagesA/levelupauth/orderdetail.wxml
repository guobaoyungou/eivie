<view class="container"><block wx:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block wx:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待付款</view><block wx:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block wx:if="{{detail.status==1}}"><view class="f1"><view class="t1">已成功付款</view></view></block><block wx:if="{{detail.status==-1}}"><view class="f1"><view class="t1">已取消</view></view></block></view><view class="product"><view class="content"><view><image src="{{detail.pic}}"></image></view><view class="detail"><text class="t1">{{detail.title}}</text><text class="t2" style="color:#666;">{{"等级："+detail.levelname}}</text></view></view></view><view class="orderinfo"><block wx:if="{{type==2}}"><block><view class="item"><text class="t1">{{detail.ordertype==1?'领取人信息':'购买人信息'}}</text><view class="f2"><image src="{{detail.headimg}}"></image><text>{{detail.nickname}}</text></view></view></block></block><block wx:if="{{type==1}}"><block><view class="item"><text class="t1">{{detail.ordertype==1?'赠送人信息':'售卖人信息'}}</text><view class="f2"><image src="{{detail.fromheadimg}}"></image><text>{{detail.fromnickname}}</text></view></view></block></block><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block wx:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block wx:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block wx:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block wx:if="{{detail.status==1}}"><text class="t2">{{detail.ordertype==1?'已领取':'已付款'}}</text></block><block wx:if="{{detail.status==-1}}"><text class="t2">已取消</text></block></view></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block wx:if="{{detail.status==0&&type==1}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" bindtap="__e">取消订单</view><view class="btn1" style="{{'background:'+($root.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block></block></view></block></block><block wx:if="{{loading}}"><loading vue-id="f5e4bcda-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="f5e4bcda-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f5e4bcda-3" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="f5e4bcda-4" bind:__l="__l"></wxxieyi></view>