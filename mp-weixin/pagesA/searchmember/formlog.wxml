<view class="container"><block wx:if="{{isload}}"><block><dd-tab vue-id="480d597f-1" itemdata="{{['全部','待确认','已确认','已驳回','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:90rpx;"></view><view class="content" id="datalist"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="item" data-url="{{'formdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.title}}</text><text class="t2">{{"提交时间："+item.createtime}}</text></view><view class="f2"><block wx:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待确认</text></block><block wx:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block wx:if="{{item.status==1}}"><text class="t1" style="color:green;">已确认</text></block><block wx:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></block></view></block></block><block wx:if="{{nodata}}"><nodata vue-id="480d597f-2" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="480d597f-3" bind:__l="__l"></nomore></block><block wx:if="{{loading}}"><loading vue-id="480d597f-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="480d597f-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="480d597f-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>