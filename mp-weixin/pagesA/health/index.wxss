.container{width:100%}.main{padding:30rpx}.item{display:flex;justify-content:space-between;align-items:center;background:#fff;border-radius:10rpx;margin-bottom:30rpx;padding:20rpx}.item .left{display:flex;align-items:center;justify-content:flex-start}.item .img{width:120rpx;height:120rpx;border-radius:10rpx}.item .img image{max-width:100%;max-height:100%;border-radius:10rpx}.item .info{padding:0 20rpx}.item .info .title{font-size:28rpx;font-weight:700}.item .info .desc{font-size:24rpx;line-height:40rpx;color:#999;max-height:80rpx;overflow:hidden;text-overflow:ellipsis}.item .opt{color:#999;font-size:24rpx;flex-shrink:0}