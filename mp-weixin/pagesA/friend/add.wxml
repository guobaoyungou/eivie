<view class="container"><block wx:if="{{isload}}"><block><view class="top"><view class="top-search"><image class="search-icon" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="input" type="text" placeholder="输入昵称|姓名|手机号添加好友" placeholder-style="font-size:26rpx;color:#999" data-event-opts="{{[['confirm',[['searchMember',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block wx:if="{{datalist.length>0}}"><view class="box"><view class="itembox"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index"><block><view class="item flex-sb"><view class="left"><image class="headimg" src="{{item.$orig.headimg}}"></image><view class="info"><view class="nickname txthide">{{item.$orig.nickname}}</view><view class="desc">{{"等级："+item.$orig.levelname}}</view><view class="desc txthide">{{"地区："+(item.$orig.area?item.$orig.area:'未知')}}</view></view></view><view class="right"><block wx:if="{{item.$orig.add_status==1}}"><button class="btn" style="{{'background:'+(item.m0)+';'+('color:'+('#fff')+';')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['addFriend',['$event']]]]]}}" bindtap="__e">加好友</button></block><block wx:if="{{item.$orig.add_status==2}}"><button class="btn btn1">已添加</button></block></view></view></block></block></view></view></block></block></block><block wx:if="{{loading}}"><loading vue-id="5f19efbc-1" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="5f19efbc-2" data-ref="popmsg" bind:__l="__l"></popmsg></view>