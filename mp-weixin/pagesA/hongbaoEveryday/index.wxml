<view class="container"><block wx:if="{{isload}}"><block><view class="wrap" style="{{'height:100%;'+('background:'+('linear-gradient(-90deg,'+$root.m0+' ,rgba('+$root.m1+',0.8) 100%)')+';')}}"><view class="title" style="{{('background-image:url('+info.banner+');background-size:100% 100%;')}}"></view><view class="content"><view class="f1"><block wx:if="{{!todayRecord}}"><view class="font-big">--</view></block><block wx:if="{{todayRecord}}"><view class="font-big">{{todayRecord.money}}</view></block><view class="font-normal">今日补贴</view><view data-event-opts="{{[['tap',[['changeRule',['$event']]]]]}}" class="rule" style="{{'background:'+('linear-gradient(-90deg,rgba('+$root.m2+',0.2) ,rgba('+$root.m3+',0.2) 100%)')+';'+('color:'+($root.m4)+';')}}" bindtap="__e">活动规则</view></view><view class="flex"><view class="col-3"><view class="font-mid">{{data.total}}</view><view class="font-normal">补贴总额</view></view><view class="col-3"><view class="font-mid">{{data.todayNum}}</view><view class="font-normal">今日数量</view></view><view class="col-3"><view class="font-mid">{{data.todayLeftNum}}</view><view class="font-normal">今日剩余</view></view></view><view class="flex"><view class="card" data-url="eduLog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="font-mid">{{member.hongbao_everyday_edu}}</view><view class="font-normal">我的额度</view></view><view class="card" data-url="log" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="font-mid">{{member.hongbao_count}}</view><view class="font-normal">补贴总数</view></view></view><view><block wx:if="{{!todayRecord}}"><button data-event-opts="{{[['tap',[['getHongbao',['$event']]]]]}}" class="form-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m5+' 0%,rgba('+$root.m6+',0.8) 100%)')+';'}}" bindtap="__e">领今日额度</button></block><block wx:if="{{todayRecord}}"><button class="form-btn" style="{{'background:'+('#aaa')+';'}}">明日再来</button></block></view><view data-url="log" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">补贴记录</view></view><view class="prolist"><dp-product-item vue-id="68f96414-1" data="{{tjdatalist}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]]]}}" bind:addcart="__e" bind:__l="__l"></dp-product-item></view><block wx:if="{{showmaskrule}}"><view id="mask-rule"><block wx:if="{{showBoxhongbao}}"><view class="box-hongbao" style="{{'background:'+('url('+pre_url+'/static/img/hongbao_bg.png'+') no-repeat')+';'+('background-size:'+('contain')+';')}}"><view class="text-center h1">· 恭喜您获得额度 ·</view><view class="font-big"><text style="font-size:34rpx;margin-right:10rpx;">¥</text>{{hongbaoMoney}}</view><view></view><button data-event-opts="{{[['tap',[['hideBox',['$event']]]]]}}" class="box-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m7+' 0%,rgba('+$root.m8+',0.8) 100%)')+';'}}" bindtap="__e">确定</button></view></block><block wx:if="{{showBoxrule}}"><view class="box-rule" style="{{'background:'+('linear-gradient(180deg,'+$root.m9+' 40%,rgba(255,255,255,0.8) 120%)')+';'}}"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changeRule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{info.guize}}</text></view></view></view></block></view></block></view></block></block><block wx:if="{{loading}}"><loading vue-id="68f96414-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="68f96414-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="68f96414-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>