<view class="container"><block wx:if="{{isload}}"><block><block wx:if="{{set.header_text}}"><view><parse vue-id="1d39f3ff-1" content="{{set.header_text}}" bind:__l="__l"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><view class="title">{{queryText}}</view><view class="inputdiv"><input type="text" name="realname" placeholder-style="color:#666;" placeholder="请输入姓名" value="{{realname}}"/></view><block wx:if="{{set&&set.query_type=='id_card'}}"><view class="inputdiv"><input type="text" name="id_card" placeholder-style="color:#666;" placeholder="请输入身份证号" value="{{id_card}}"/></view></block><block wx:if="{{set&&set.query_type=='tel'}}"><view class="inputdiv"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入手机号" value="{{tel}}"/></view></block><button class="btn" form-type="submit">查询</button></form><block wx:if="{{set.footer_text}}"><view><parse vue-id="1d39f3ff-2" content="{{set.footer_text}}" bind:__l="__l"></parse></view></block></block></block><block wx:if="{{loading}}"><loading vue-id="1d39f3ff-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1d39f3ff-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1d39f3ff-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>