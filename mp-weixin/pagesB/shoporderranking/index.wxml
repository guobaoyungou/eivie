<block wx:if="{{isload}}"><view><view><block wx:if="{{set&&set.showpool}}"><view class="poolmoney" style="{{(pic?'background:url('+pic+') no-repeat;background-size:100% 100%;':'background-color:'+$root.m0)}}"><view style="text-align:center;"><view style="font-size:36rpx;">分红池总金额</view><view style="font-size:40rpx;margin-top:20rpx;">{{poolmoney+"元"}}</view></view></view></block><block wx:if="{{set&&(set.showselfranking&&selfranking>0||set.showlast&&lastid>0)}}"><view style="width:720rpx;margin:0 auto;line-height:70rpx;height:70rpx;"><block wx:if="{{set&&set.showselfranking&&selfranking>0}}"><view style="float:left;">{{'当前自己排名：'+selfranking+''}}</view></block><block wx:if="{{set&&set.showlast&&lastid>0}}"><view style="float:right;" data-url="{{'detail?id='+lastid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">上一期</view></block></view></block><view class="dd-tab2"><scroll-view scroll-x="true"><view class="dd-tab2-content"><block wx:for="{{itemdata}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['item',st==itemst[index]?'on':'']}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e"><view>{{item.name}}</view><view class="after" style="{{'background:'+(color1?color1:$root.m1)+';'}}"></view><block wx:if="{{set&&set.showchildpool}}"><view style="{{('text-align: center;line-height: 50rpx;color:'+$root.m2)}}">{{item.childmoney+"元"}}</view></block></view></block></view></scroll-view></view><block wx:if="{{showmoney}}"><view style="font-size:34rpx;text-align:center;">{{'参与该分红池差距消费金额:'+money+'元'}}</view></block><view class="contentbox"><view class="content"><view class="tab"><view class="t1" style="width:80rpx;">排名</view><view class="t1" style="width:280rpx;">姓名</view><view class="t2">消费金额</view><block wx:if="{{display==1}}"><view class="t3" style="width:112rpx;">预估奖金</view></block></view><view class="itembox"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="item"><text class="t1" style="width:80rpx;">{{index+1+''}}</text><view class="t2" style="width:280rpx;"><image src="{{item.headimg}}"></image><view style="width:180rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{''+item.nickname+''}}</view></view><text class="t3">{{''+item.summoney+"元"}}</text><block wx:if="{{display==1}}"><text class="t3" style="width:112rpx;">{{''+item.avgmoney+"元"}}</text></block></view></block></block></view><block wx:if="{{nodata}}"><nodata vue-id="61c0075c-1" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="61c0075c-2" bind:__l="__l"></nomore></block></view></view><block wx:if="{{loading}}"><loading vue-id="61c0075c-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="61c0075c-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="61c0075c-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></view></block>