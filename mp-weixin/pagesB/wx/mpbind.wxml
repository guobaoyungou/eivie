<view><view class="content"><view class="message"><view class="image-container"><block wx:if="{{error==1}}"><image class="img" src="{{pre_url+'/static/img/success_1.png'}}" mode="widthFix"></image></block><block wx:else><image class="img" src="{{pre_url+'/static/img/warning.png'}}" mode="widthFix"></image></block></view><view class="message-text ft30">{{msg}}</view></view><block wx:if="{{mpinfo.nickname&&mpinfo.qrcode}}"><view class="qr-code"><view class="image-container"><image class="img" src="{{mpinfo.qrcode}}" mode="aspectFit" show-menu-by-longpress="{{true}}"></image></view><view class="qr-text ft30">长按识别或者保存二维码</view><view class="qr-text ft30">{{"关注公众号："+mpinfo.nickname}}</view><block wx:if="{{subscribe==1}}"><view class="qr-text c9e">已关注公众号</view></block><block wx:else><view class="qr-text c9e">暂未关注公众号</view></block></view></block><view class="tips"><view class="tip-text c9e">请按返回键重新进入小程序</view></view></view><block wx:if="{{loading}}"><loading vue-id="7e03c44a-1" bind:__l="__l"></loading></block></view>