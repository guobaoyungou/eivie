<view class="container"><block wx:if="{{isload}}"><block><dd-tab vue-id="a3486f9c-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="listrow"><view class="item"><view class="f1"><text class="t1">{{"提现"+$root.m0+"："+item.score}}<text class="money" style="{{'color:'+($root.m1)+';'}}">{{"(￥"+item.money+")"}}</text></text><text class="t2">{{item.showtime}}</text></view><view class="f3"><block wx:if="{{item.status==0}}"><text class="st0">审核中</text></block><block wx:if="{{item.status==1}}"><text class="st1">已审核</text></block><block wx:if="{{item.status==2}}"><text class="st2">已驳回</text></block><block wx:if="{{item.status==3}}"><text class="st3">已打款</text></block></view></view><block wx:if="{{item.status==2&&item.reason}}"><view class="tips">{{item.reason}}</view></block></view></block></view><block wx:if="{{nomore}}"><nomore vue-id="a3486f9c-2" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="a3486f9c-3" bind:__l="__l"></nodata></block></block></block><block wx:if="{{loading}}"><loading vue-id="a3486f9c-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="a3486f9c-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="a3486f9c-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>