<view class="container"><block wx:if="{{isload}}"><block><view class="topfix"></view><block wx:if="{{datalist&&datalist.length>0}}"><block><view class="content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="item"><view class="f1"><text>{{item.ordernum}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.name}}</text><text class="x2">{{item.createtime}}</text><view class="x3"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></view><view class="t2"><block wx:if="{{item.status==1||item.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block wx:if="{{item.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><text class="dior-sp6 ywc">已完成</text><block wx:if="{{item.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block wx:if="{{item.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block></view></block></block></block></block><block wx:if="{{nodata}}"><nodata vue-id="c65a395e-1" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="c65a395e-2" bind:__l="__l"></nomore></block><block wx:if="{{loading}}"><loading vue-id="c65a395e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="c65a395e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c65a395e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>