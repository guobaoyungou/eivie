<view class="container"><block wx:if="{{isload}}"><block><view class="ind_business"><view class="ind_buslist" id="datalist"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view data-id="{{item.id}}" data-event-opts="{{[['tap',[['toBack',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox flex"><view class="flex1"><view class="bus_title flex">{{''+item.name+''}}</view><view class="bus_address flex"><view class="flex1">{{item.address}}</view></view><view class="bus_time flex flex-wp"><text>营业时间：</text><block wx:if="{{item.start_hours}}"><text>{{item.start_hours+" - "+item.end_hours}}</text></block><block wx:if="{{item.start_hours2!='00:00'&&item.start_hours2!='00:00'}}"><text style="margin-left:10rpx;">{{item.end_hours2+" - "+item.end_hours2}}</text></block><block wx:if="{{item.start_hours3!='00:00'&&item.start_hours3!='00:00'}}"><text style="margin-left:10rpx;">{{item.start_hours3+" - "+item.end_hours3}}</text></block></view></view><view class="data flex-xy-center"><view><view class="data_title">去下单</view><view class="data_text">{{"距离"+item.juli}}</view><view class="data_tag flex-xy-center"><view class="flex"><block wx:if="{{item.tel}}"><view class="data_item flex-xy-center" data-tel="{{item.tel}}" data-event-opts="{{[['tap',[['calltel',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/b_tel.png'}}" mode></image></view></block><view class="data_item flex-xy-center" data-name="{{item.name}}" data-address="{{item.address}}" data-longitude="{{item.longitude}}" data-latitude="{{item.latitude}}" data-event-opts="{{[['tap',[['showMap',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/b_addr.png'}}" mode></image></view></view></view></view></view></view></view></block></block><block wx:if="{{nomore}}"><nomore vue-id="2d306e4a-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="2d306e4a-2" bind:__l="__l"></nodata></block></view></view></block></block><block wx:if="{{loading}}"><loading vue-id="2d306e4a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="2d306e4a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="2d306e4a-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="2d306e4a-6" bind:__l="__l"></wxxieyi></view>