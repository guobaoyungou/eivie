<view class="container"><block wx:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{"商家个数（"+count+"）"}}</text></view></view><block wx:if="{{show_search==1}}"><view class="topsearch flex-y-center sx"><view class="f1 flex-y-center"><text class="t1">营业额日期筛选：</text><view data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" class="range-item" style="{{('border-color:'+$root.m0)}}" bindtap="__e">{{choosetime||'选择日期'}}</view></view></view></block><block wx:if="{{show_search==1}}"><view class="topsearch flex-y-center sx"><view class="search-area"><view class="search-header"><view class="search-title">店铺区域筛选</view><view data-event-opts="{{[['tap',[['searchArea',['$event']]]]]}}" class="reset-btn" bindtap="__e">查询</view></view><view class="region-select"><view class="region-item"><picker value="{{provinceIndex}}" range="{{provinceList}}" data-event-opts="{{[['change',[['provinceChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content">{{''+(provinceList[provinceIndex]||'安徽省')+''}}<text class="iconfont icondaoxu"></text></view></picker></view><view class="region-item"><picker value="{{cityIndex}}" range="{{cityList}}" data-event-opts="{{[['change',[['cityChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content">{{cityList[cityIndex]||'市'}}<text class="iconfont icondaoxu"></text></view></picker></view><view class="region-item"><picker value="{{districtIndex}}" range="{{districtList}}" data-event-opts="{{[['change',[['districtChange',['$event']]]]]}}" bindchange="__e"><view class="picker-content">{{districtList[districtIndex]||'区/县'}}<text class="iconfont icondaoxu"></text></view></picker></view></view></view></view></block><view class="ind_business"><view class="ind_buslist" id="datalist"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view data-url="{{'/pagesExt/business/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox flex1 flex-row"><view class="ind_buspic flex0"><image src="{{item.logo}}"></image></view><view class="flex1"><view class="bus_title">{{item.name}}</view><view style="padding-top:10px;">{{"商户ID:"+item.id}}</view><view class="bus_sales">{{"销量："+item.sales}}</view><block wx:if="{{show_order_price}}"><view class="bus_order">{{"营业额："+item.order_price_total}}</view></block></view></view></view></block></block><block wx:if="{{nomore}}"><nomore vue-id="380ace9c-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="380ace9c-2" bind:__l="__l"></nodata></block><block wx:if="{{ischooserange}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><view class="headertab"><view data-event-opts="{{[['tap',[['rangeTypeChange',[1]]]]]}}" class="{{[rangeType==1?'item on':'item']}}" style="{{'color:'+(rangeType==1?$root.m1:'')+';'}}" bindtap="__e">年份选择</view><view data-event-opts="{{[['tap',[['rangeTypeChange',[2]]]]]}}" class="{{[rangeType==2?'item on':'item']}}" style="{{'color:'+(rangeType==2?$root.m2:'')+';'}}" bindtap="__e">月份选择</view><view data-event-opts="{{[['tap',[['rangeTypeChange',[3]]]]]}}" class="{{[rangeType==3?'item on':'item']}}" style="{{'color:'+(rangeType==3?$root.m3:'')+';'}}" bindtap="__e">日期选择</view></view><image class="popup__close" style="width:30rpx;height:30rpx;" src="/static/img/close.png" data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block wx:if="{{rangeType==1}}"><view class="year-tab"><view class="month-label">年份</view><view><picker class="date" mode="date" value="{{year}}" fields="year" end="{{curdate}}" data-field="year" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{year?year:'请选择'}}</view></picker></view></view></block><block wx:if="{{rangeType==2}}"><view class="month-tab"><view class="month-label">月份</view><view><picker class="date" mode="date" value="{{month}}" fields="month" end="{{curdate}}" data-field="month" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{month?month:'请选择'}}</view></picker></view></view></block><block wx:if="{{rangeType==3}}"><view class="time-tab"><view class="month-label">日期</view><view class="time-date"><picker class="date" mode="date" value="{{start_date}}" end="{{curdate}}" data-field="start_date" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{start_date?start_date:'开始时间'}}</view></picker><text class="dt">至</text><picker class="date" mode="date" value="{{end_date}}" end="{{curdate}}" data-field="end_date" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{end_date?end_date:'结束时间'}}</view></picker></view></view></block></view><view class="popup__bottom"><button data-event-opts="{{[['tap',[['resetTimeChoose',['$event']]]]]}}" class="popup_btn btn1" bindtap="__e">重 置</button><button data-event-opts="{{[['tap',[['confirmTimeChoose',['$event']]]]]}}" class="popup_btn" style="{{'background:'+($root.m4)+';'+('color:'+('#fff')+';')}}" bindtap="__e">确 定</button></view></view></view></block></view></view></block></block><block wx:if="{{loading}}"><loading vue-id="380ace9c-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="380ace9c-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="380ace9c-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>