<view><block wx:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" bindsubmit="__e"><view style="height:80rpx;"></view><view class="titlebg-postions"><view class="titlebg-view" style="{{('background:rgba('+$root.m0+')')}}"></view></view><view class="position-view"><view class="order-time-details flex flex-col"><view class="name-info flex flex-y-center flex-bt"><view class="flex flex-col"><view class="name-text">{{product.name}}</view></view></view><block wx:if="{{product.date_price&&product.date_price.length>0&&product.type!=2}}"><view class="calendar-view"><view class="calendar-view-title">选择日期</view><view class="calendar-date-list "><view class="date-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block wx:if="{{product.date_price}}"><view data-event-opts="{{[['tap',[['selectDateItem',['$0',index],[[['product.date_price','',index]]]]]]]}}" class="date-item" style="{{'border-color:'+(index===selectedDateIndex?item.m1:'')+';'+('background-color:'+(index===selectedDateIndex?'rgba('+item.m2+', 0.2)':'')+';')}}" bindtap="__e"><view>{{item.$orig.week+" "+item.$orig.date}}</view><view class="date-price" style="{{'color:'+($root.m3)+';'}}">￥<text>{{item.$orig.sell_price}}</text></view></view></block></block></view></view></view></block><block wx:if="{{product.type==2}}"><view class="calendar-view flex-bt" style="padding:20rpx 0;"><view class="calendar-view-title">选择日期:</view><view>{{visit_date+" （"+daycount+"晚）"}}</view></view></block><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view class="minus"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" bindtap="__e"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{num}}" bindinput="__e"/><view class="plus"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" bindtap="__e"></image></view></view></view><block wx:if="{{product.maximum}}"><view class="gou-tips flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/error.png'}}"></image>{{'最多购买'+product.maximum+'张'}}</view></block></view><view class="order-options-view flex flex-col"><view class="options-title flex flex-bt flex-y-center"><view>游客信息</view></view><block wx:for="{{travellerdata}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="traveller-data"><block wx:if="{{product.is_single!=1}}"><view class="booking-options booking-options-title">{{"游客"+(index+1)}}</view></block><block wx:if="{{product.need_contact_name}}"><view class="booking-options flex flex-y-center flex-bt form-item"><view class="book-title">姓名</view><view class="room-form"><input style="text-align:right;" name="{{'traveller_name'+index}}" placeholder="请填写姓名" data-event-opts="{{[['input',[['__set_model',['$0','traveller_name','$event',[]],['travellerdata.'+index+'']]]]]}}" value="{{travellerdata[index].traveller_name}}" bindinput="__e"/></view></view></block><block wx:if="{{product.need_contact_phone}}"><view class="booking-options flex flex-y-center flex-bt form-item"><view class="book-title">联系方式</view><view class="room-form"><input style="text-align:right;" name="{{'traveller_mobile'+index}}" placeholder="请填写联系方式" data-event-opts="{{[['input',[['__set_model',['$0','traveller_mobile','$event',[]],['travellerdata.'+index+'']]]]]}}" value="{{travellerdata[index].traveller_mobile}}" bindinput="__e"/></view></view></block><block wx:if="{{product.need_contact_email}}"><view class="booking-options flex flex-y-center flex-bt form-item"><view class="book-title">Email</view><view class="room-form"><input style="text-align:right;" name="{{'traveller_email'+index}}" placeholder="请填写邮箱" data-event-opts="{{[['input',[['__set_model',['$0','traveller_email','$event',[]],['travellerdata.'+index+'']]]]]}}" value="{{travellerdata[index].traveller_email}}" bindinput="__e"/></view></view></block><block wx:if="{{product.need_contact_id_card}}"><view class="booking-options flex flex-y-center flex-bt form-item"><view class="book-title">证件号码</view><view class="room-form"><input style="text-align:right;" name="{{'traveller_credentials'+index}}" placeholder="请填写证件号码" data-event-opts="{{[['input',[['__set_model',['$0','traveller_credentials','$event',[]],['travellerdata.'+index+'']]]]]}}" value="{{travellerdata[index].traveller_credentials}}" bindinput="__e"/></view></view></block></view></block></view><block wx:if="{{userinfo.dedamount>0}}"><view class="price order-options-view flex flex-col"><checkbox-group data-event-opts="{{[['change',[['moneydk',['$event']]]]]}}" class="flex" style="width:100%;" bindchange="__e"><view class="f1"><view>使用抵扣金抵扣（抵扣金：<text style="color:#e94745;">{{userinfo.dedamount}}</text>）,最多可抵扣（<text style="color:#e94745;">{{maxusemoney}}</text>）</view><view style="font-size:24rpx;color:#999;">1、选择此项提交订单时将直接扣除抵扣金</view></view><view class="f2" style="font-weight:normal;"><checkbox style="margin-left:6px;transform:scale(.8);" value="1" checked="{{usededamount?true:false}}"></checkbox></view></checkbox-group></view></block><view style="height:300rpx;"></view></view><view class="but-view flex flex-col"><view class="yuding-view flex flex-y-center flex-bt"><view class="price-view flex flex-col"><view class="text">共计:</view><block wx:if="{{usededamount}}"><block><view class="price-text" style="{{'color:'+($root.m4)+';'}}">{{"￥"+totalprice+'+'}}<text style="font-size:24rpx;">{{(usededamount?usemoney:0)+"抵扣金"}}</text></view></block></block><block wx:else><block><view class="price-text" style="{{'color:'+($root.m5)+';'}}">{{"￥"+totalprice}}</view></block></block></view><view class="flex flex-row flex-y-center"><button class="but-class1" style="{{('background:rgba('+$root.m6+',0.8);color:#FFF')}}" form-type="submit">购买</button></view></view></view></form></block></block></view>