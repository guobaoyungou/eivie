<view class="container"><block wx:if="{{isload}}"><block><view class="order-content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"活动名称："+item.name}}</view></view><block wx:if="{{item.jump_detail_status}}"><view class="st0 flex-y-center" data-url="{{item.jump_detail_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看详情<image class="arrowright" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">活动时间：<text style="font-size:24rpx;">{{item.starttime+" ~ "+item.endtime}}</text></view></view></view><view style="border-bottom:1px #f4f4f4 solid;"></view><view class="content flex-bt"><view class="option-content flex"><view>我的业绩：</view><view style="color:#ff8758;">{{"￥"+item.yeji}}</view></view><view class="option-content flex"><view><block wx:if="{{item.fafang_fenhong>0}}"><text>已发奖励</text></block><block wx:else><text>预估奖励：</text></block></view><view style="color:#ff8758;"><block wx:if="{{item.fafang_fenhong>0}}"><text>{{"￥"+item.fafang_fenhong}}</text></block><block wx:else><text>{{"￥"+item.fenhong}}</text></block></view></view></view></view></block></block></view><block wx:if="{{nomore}}"><nomore vue-id="0b70c573-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="0b70c573-2" bind:__l="__l"></nodata></block></block></block><block wx:if="{{loading}}"><loading vue-id="0b70c573-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="0b70c573-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="0b70c573-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>