<view class="container"><block wx:if="{{isload}}"><block><view class="coupon-list"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="coupon" data-url="{{'coupondetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="pt_left"><view class="pt_left-content"><image src="{{item.pic}}" mode="widthFix"></image></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.name}}</view><view class="t4">{{'x '+item.limit_count}}</view><block wx:if="{{item.price>0}}"><view class="t4 price"><text class="price_tag">￥</text>{{item.price}}</view></block></view><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-price="{{item.price}}" data-score="{{item.score}}" data-key="{{index}}" data-event-opts="{{[['tap',[['getcoupon',['$event']]]]]}}" catchtap="__e">{{item.price>0?'购买':item.score>0?'兑换':'领取'}}</button></view></view></block></view><block wx:if="{{nodata}}"><nodata vue-id="81802bc0-1" text="{{'暂无可领'+$root.m2}}" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="81802bc0-2" bind:__l="__l"></nomore></block></block></block><block wx:if="{{loading}}"><loading vue-id="81802bc0-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="81802bc0-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="81802bc0-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>