<view class="container"><block wx:if="{{isload}}"><block><dd-tab vue-id="18079bd8-1" itemdata="{{['全部','发放中','已完成']}}" itemst="{{['all','1','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="{{(show_rebate?'height:260rpx;width:100%;':'height:100rpx;width:100%;')}}"></view><view class="order-content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="order-box" data-url="{{'recordlog?butie_member_product_id='+item.id+'&butie_activity_id='+item.butie_activity_id+'&pro_id='+item.pro_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><block wx:if="{{item.pic}}"><image src="{{item.pic}}"></image></block><block wx:else><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image></block><view class="head-title">{{item.name}}</view></view><text class="{{['st','st'+item.status]}}">{{item.status_str}}</text></view><view class="report-box"><view class="report-item"><view class="item-txt">已补贴天数</view><view class="item-num">{{item.back_days_total+"天"}}</view></view><view class="report-item"><view class="item-txt">累计可补贴天数</view><view class="item-num">{{item.back_days+"天"}}</view></view><view class="report-item"><view class="item-txt">推广增加天数</view><view class="item-num">{{item.back_days_add+"天"}}</view></view></view><view class="report-box"><view class="report-item"><view class="item-txt">每日发放金额</view><view class="item-num">{{"￥"+item.back_everyday_money}}</view></view><view class="report-item"><view class="item-txt">推广增加日金额</view><view class="item-num">{{"￥"+item.back_everyday_money_add}}</view></view><view class="report-item"><view class="item-txt">已发放金额</view><view class="item-num">{{"￥"+item.back_money_total}}</view></view></view><view class="report-box"><view class="report-item"><view class="item-txt">已推人数</view><view class="item-num">{{item.tuiguang_num+"人"}}</view></view><view data-event-opts="{{[['tap',[['showmemberstage',['$0'],[[['datalist','',index]]]]]]]}}" class="report-item" catchtap="__e"><view class="item-txt">推广人数</view><view class="item-num">{{item.tuiguang_num_max+"人"}}</view></view></view><view class="weekdays"><block wx:for="{{item.week_day}}" wx:for-item="day" wx:for-index="i" wx:key="i"><view class="weekday">{{day}}</view></block></view></view></block></block></view><uni-popup class="vue-ref" vue-id="18079bd8-2" id="dialogTuiguang" type="dialog" data-ref="dialogTuiguang" bind:__l="__l" vue-slots="{{['default']}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><block wx:for="{{member_stage.tuiguangdata}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="sendexpress-item" style="display:flex;border-bottom:1px solid #f5f5f5;padding:20rpx 0;"><view><block wx:if="{{item.tuiguang}}"><text>{{"推广"+item.tuiguang+"人"}}</text></block><block wx:if="{{item.addday}}"><text>{{"增加"+item.addday}}</text></block><block wx:if="{{item.addmoney}}"><text>{{"天,每日多补贴"+item.addmoney+"元"}}</text></block></view></view></block></view></uni-popup><block wx:if="{{nomore}}"><nomore vue-id="18079bd8-3" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="18079bd8-4" bind:__l="__l"></nodata></block></block></block><block wx:if="{{loading}}"><loading vue-id="18079bd8-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="18079bd8-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="18079bd8-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>