<view class="container"><block wx:if="{{isload}}"><block><view class="topfix"><view class="head-total" style="background-color:#fd2936;color:#feef2f;"><view class="data-search flex-xy-center"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="header-back-but" bindtap="__e"><image src="{{pre_url+'/static/img/hotel/fanhui.png'}}"></image></view><view data-event-opts="{{[['tap',[['changeDateType',['today']]]]]}}" class="{{['data-btn',(datetype==='today')?'selected':'']}}" bindtap="__e">今日</view><view data-event-opts="{{[['tap',[['changeDateType',['week']]]]]}}" class="{{['data-btn',(datetype==='week')?'selected':'']}}" bindtap="__e">近7天</view><view data-event-opts="{{[['tap',[['changeDateType',['month']]]]]}}" class="{{['data-btn',(datetype==='month')?'selected':'']}}" bindtap="__e">本月</view><view data-event-opts="{{[['tap',[['changeDateType',['year']]]]]}}" class="{{['data-btn',(datetype==='year')?'selected':'']}}" bindtap="__e">本年</view></view><block wx:if="{{provincename}}"><view class="area-box"><text>{{provincename}}</text><block wx:if="{{cityname}}"><text>{{"-"+cityname}}</text></block></view></block><view class="tongji flex-y-center"><view class="stat-item"><view>商家数量</view><view class="price">{{count.business_count}}</view></view><view class="divider"></view><view class="stat-item mb0"><view>区域业绩</view><view class="price">{{count.commission_count}}</view></view><view class="divider"></view><view class="stat-item"><view>订单数量</view><view class="price">{{count.order_count}}</view></view></view><view class="pv-box"><view class="pv">{{count.rangli_count}}</view><view class="pv-title" style="{{'background:'+('url('+pre_url+'/static/img/countbj.png) no-repeat')+';'+('background-size:'+('70%')+';')+('background-position:'+('center')+';')+('filter:'+('brightness(1000%) saturate(0%)')+';')}}">业绩统计(PV)</view></view><view style="height:40rpx;"></view></view><block wx:if="{{neworders&&neworders.length>0}}"><view class="neworders"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="{{pre_url+'/static/imgsrc/notice2.png'}}"></image><swiper class="neworders-swiper" autoplay="{{true}}" interval="{{2000}}" vertical="{{true}}" circular="{{true}}"><block wx:for="{{neworders}}" wx:for-item="item" wx:for-index="__i0__"><swiper-item style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{''+item.name+"店 订单"+item.totalprice+'元'}}</swiper-item></block></swiper></view></block><view style="background:#fff;width:720rpx;margin:0 auto;display:flex;align-items:center;line-height:80rpx;"><view>地区业绩概览</view><view style="flex:1;display:flex;margin-left:20rpx;align-items:center;"><block wx:if="{{provinceArray&&provinceArray.length>0}}"><view><picker mode="selector" range="{{provinceArray}}" data-event-opts="{{[['change',[['provincechange',['$event']]]]]}}" bindchange="__e"><view class="picker"><text>{{provincename?provincename:'请选择省份'}}</text><image class="arrowdown" src="{{pre_url+'/static/img/location/down-black.png'}}"></image></view></picker></view></block><block wx:if="{{cityArray&&cityArray.length>0}}"><view><picker mode="selector" range="{{cityArray}}" data-event-opts="{{[['change',[['citychange',['$event']]]]]}}" bindchange="__e"><view class="picker"><text>{{cityname?cityname:'城市'}}</text><image class="arrowdown" src="{{pre_url+'/static/img/location/down-black.png'}}"></image></view></picker></view></block><block wx:if="{{showdistrict&&districtArray&&districtArray.length>0}}"><view><picker mode="selector" range="{{districtArray}}" data-event-opts="{{[['change',[['districtchange',['$event']]]]]}}" bindchange="__e"><view class="picker"><text>{{districtname?districtname:'县区'}}</text><image class="arrowdown" src="{{pre_url+'/static/img/location/down-black.png'}}"></image></view></picker></view></block></view></view></view><view class="ind_business"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-url="{{'/pagesD/commission/areatjbusiness?opttype=member_business_area&provincename='+provincename+'&cityname='+cityname+'&districtname='+item.name}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox"><view style="height:100rpx;line-height:100rpx;background-color:#000;border-radius:20rpx;color:#fff;text-align:center;width:200rpx;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">{{''+item.name+''}}</view><view class="flex" style="flex:1;margin-left:30rpx;"><view class="activecoin flex rl-total"><text class="rl-title">累计让利</text><text class="rl-number">{{item.newscore_total}}</text></view></view></view></view></block><block wx:if="{{nodata}}"><nodata vue-id="d85ad8b4-1" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="d85ad8b4-2" bind:__l="__l"></nomore></block></view></block></block><block wx:if="{{loading}}"><loading vue-id="d85ad8b4-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="d85ad8b4-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d85ad8b4-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>