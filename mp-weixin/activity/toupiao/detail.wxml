image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block></block><block wx:if="{{loading}}"><loading vue-id="8b0b2a36-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="8b0b2a36-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="8b0b2a36-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>