<view class="container"><block wx:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入课程标题搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="order-content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="order-box" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.title}}</text><view class="t4 flex"><view><view class="t3"><text class="x1 flex1">{{item.price==0||item.price==null?'免费':'支付金额：￥'+item.price}}</text></view><view class="t2"><text>{{"共"+item.kccount+"节 已学"+item.count+"节"}}</text></view></view><block wx:if="{{!item.orderlearn}}"><block><block wx:if="{{item.iskaoshi!=1&&item.count>=item.kccount&&item.isdt==1}}"><view class="btn2" data-url="{{'tiku?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去答题</view></block><block wx:if="{{item.iskaoshi!=1&&item.count<item.kccount}}"><view class="btn2" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">继续学习</view></block><block wx:if="{{item.iskaoshi==1}}"><view class="btn2" data-url="{{'recordlog?kcid='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">答题记录</view></block></block></block><block wx:else><block><view><block wx:if="{{item.count<item.kccount}}"><view class="btn2" style="margin-top:10rpx;" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">继续学习</view></block><block wx:if="{{item.iskaoshi==1}}"><view class="btn2" style="margin-top:10rpx;" data-url="{{'recordlog?kcid='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">答题记录</view></block></view></block></block></view></view></view></view></block></block></view><block wx:if="{{nomore}}"><nomore vue-id="098a731c-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="098a731c-2" bind:__l="__l"></nodata></block></block></block><block wx:if="{{loading}}"><loading vue-id="098a731c-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="098a731c-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="098a731c-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>