<view class="container"><block wx:if="{{isload}}"><block><dd-tab vue-id="65fe3cd1-1" itemdata="{{['门店队列','全网队列','我的队列']}}" itemst="{{['business','platform','me']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="tips-text">幸运免单将订单结算之后进入排队，请耐心等待</view><view class="content" id="datalist"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="list-item" data-url="{{'record?acid='+item.$orig.id}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="item-row"><block wx:if="{{item.$orig.business}}"><view><text class="tag" style="{{'background-color:'+(item.m0)+';'}}">{{item.$orig.business+"免单"}}</text></view></block><block wx:else><view><text class="tag" style="{{'background-color:'+(item.m1)+';'}}">平台免单</text></view></block><block wx:if="{{st=='me'&&item.$orig.status==0}}"><view style="font-weight:bold;">已开奖</view></block><block wx:else><view style="font-weight:bold;">{{"达到 "+item.$orig.opennum+"人开奖"}}</view></block></view><progress class="my-progress" percent="{{item.$orig.activity_num_ratio}}" stroke-width="6" border-radius="10" show-info="{{true}}" font-size="{{14}}" activeColor="#fb743b"></progress><view class="item-row">{{"活动名称: "+item.$orig.name}}</view><block wx:if="{{item.$orig.free_money>0}}"><view class="item-row">{{"免单金额: "+item.$orig.free_money}}</view></block><block wx:if="{{item.$orig.status==0}}"><view class="item-row">{{"中奖用户: "+item.$orig.win_nickname}}</view></block><view class="item-row">{{"排队用户: "+item.$orig.activity_num+"人"}}</view><view class="item-row">{{"创建时间: "+item.$orig.createtime}}</view></view></block></view><block wx:if="{{nodata}}"><nodata vue-id="65fe3cd1-2" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="65fe3cd1-3" bind:__l="__l"></nomore></block></block></block><block wx:if="{{loading}}"><loading vue-id="65fe3cd1-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="65fe3cd1-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="65fe3cd1-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>