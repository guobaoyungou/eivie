<block wx:if="{{isload}}"><view><view class="form-view"><view class="form-item"><view class="label">手机号</view><input style="flex:1;" type="text" placeholder="请输入手机号" name="phone" data-field="phone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{phone}}" bindinput="__e"/></view><view class="form-item"><view class="label">验证码</view><input style="max-width:300rpx;" type="text" placeholder="请输入验证码" name="verificationCode" data-field="verificationCode" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{verificationCode}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['sendSmscode',['$event']]]]]}}" class="code" style="{{('color:'+$root.m0)}}" bindtap="__e">{{smsdjs||'获取验证码'}}</view></view></view><view class="but-view"><button data-event-opts="{{[['tap',[['goBandPhone',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" bindtap="__e">确定绑定</button></view></view></block>