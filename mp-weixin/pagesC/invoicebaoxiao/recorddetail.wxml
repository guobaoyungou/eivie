<view class="container"><block wx:if="{{isload}}"><block><view class="recorddetail"><view class="item-pics"><view class="t1">已上传发票截图</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block wx:for="{{invoicepic}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="layui-imgbox"><block wx:if="{{edit&&(detail.status==0||detail.status==2)}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="invoicepic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block wx:if="{{edit&&(detail.status==0||detail.status==2)}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="invoicepic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="invoicepic" maxlength="-1" value="{{$root.g0}}"/></view><view class="item-pics"><view class="t1">已上传现场消费照片</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block wx:for="{{consumepic}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="layui-imgbox"><block wx:if="{{edit&&(detail.status==0||detail.status==2)}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="consumepic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block wx:if="{{edit&&(detail.status==0||detail.status==2)}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="consumepic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="consumepic" maxlength="-1" value="{{$root.g1}}"/></view><view class="item"><text class="t1">提交时间：</text><text class="t2">{{detail.createtime}}</text></view><block wx:if="{{detail.status>0}}"><view class="item"><text class="t1">审核时间：</text><text class="t2">{{detail.operatetime}}</text></view></block><view class="item"><text class="t1">当前状态：</text><block wx:if="{{detail.status==0}}"><text class="t2 red">待审核</text></block><block wx:if="{{detail.status==1&&detail.payment_status==1}}"><text class="t2 green">已通过</text></block><block wx:if="{{detail.status==2}}"><text class="t2 yellow">已驳回</text></block><block wx:if="{{detail.status==1&&detail.payment_status==2}}"><text class="t2 green">已打款</text></block><block wx:if="{{detail.status==3&&detail.payment_status==3}}"><text class="t2">已关闭</text></block></view><view class="item"><text class="t1">记录编号：</text><text class="t2">{{detail.id}}</text></view><view class="item"><text class="t1">{{"扣除"+$root.m0+"："}}</text><text class="t2">{{detail.deduct_score}}</text></view><view class="item"><text class="t1">打款金额：</text><text class="t2">{{detail.money}}</text></view><block wx:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因：</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block><block wx:if="{{edit&&(detail.status==0||detail.status==2)}}"><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">提交</button></block></view></block></block><block wx:if="{{loading}}"><loading vue-id="f4df190e-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="f4df190e-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f4df190e-3" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="f4df190e-4" bind:__l="__l"></wxxieyi></view>