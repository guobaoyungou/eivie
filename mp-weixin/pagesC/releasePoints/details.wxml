<block wx:if="{{isload}}"><view><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{cashback_total.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日新增</view><view class="num-text">{{cashback_total.today_add}}</view></view></view></view><view class="list-title-view">释放日记</view><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index"><block><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark}}</view><view class="time-text">{{item.create_time}}</view></view><view class="price-view">{{item.back_price}}</view></view></block></block><block wx:if="{{nodata}}"><nodata vue-id="becedf2a-1" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="becedf2a-2" bind:__l="__l"></nomore></block><block wx:if="{{loading}}"><loading vue-id="becedf2a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="becedf2a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="becedf2a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>