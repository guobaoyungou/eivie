<view><block wx:if="{{isload}}"><block><view class="container"><view class="datalist"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="collage-product" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;"></text></text><block wx:if="{{item.market_price*1>item.sell_price*1}}"><text class="t2"></text></block></view></view><view class="p3"><view class="t1">商品数量<text style="font-size:28rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">查看详情</text></view></view></view></view></block></block></view><block wx:if="{{nomore}}"><nomore vue-id="694ee7b6-1" bind:__l="__l"></nomore></block><block wx:if="{{nodata}}"><nodata vue-id="694ee7b6-2" bind:__l="__l"></nodata></block></view><button class="covermy" style="{{('background:'+$root.m4)}}" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的订单</button></block></block><block wx:if="{{loading}}"><loading vue-id="694ee7b6-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="694ee7b6-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="694ee7b6-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>