<view class="dp-photo-generation" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('width:'+('calc(100% - '+params.margin_x*2.2*2+'rpx)')+';')}}"><block wx:if="{{params.style=='1'||params.style=='2'||params.style=='3'}}"><dp-product-item vue-id="pg-item-1" showstyle="{{params.style}}" data="{{data}}" saleimg="{{params.saleimg}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" showcart="{{params.showcart}}" cartimg="{{params.cartimg}}" carttext="{{params.carttext}}" idfield="proid" menuindex="{{menuindex}}" probgcolor="{{params.probgcolor}}" params="{{params}}" saleslabel="已用" cover_ratio="{{params.cover_ratio||'1:1'}}" cover_radius="{{params.cover_radius||8}}" card_radius="{{params.card_radius||8}}" btn_position="{{params.btn_position||'bottom-right'}}" card_gap="{{params.card_gap||12}}" info_padding="{{params.info_padding||12}}" detailurl="/pagesZ/generation/create?type=1" bind:__l="__l"></dp-product-item></block><block wx:if="{{params.style=='list'}}"><dp-product-itemlist vue-id="pg-item-2" data="{{data}}" saleimg="{{params.saleimg}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" showcart="{{params.showcart}}" cartimg="{{params.cartimg}}" carttext="{{params.carttext}}" idfield="proid" menuindex="{{menuindex}}" probgcolor="{{params.probgcolor}}" saleslabel="已用" cover_ratio="{{params.cover_ratio||'1:1'}}" cover_radius="{{params.cover_radius||8}}" card_radius="{{params.card_radius||8}}" btn_position="{{params.btn_position||'bottom-right'}}" info_padding="{{params.info_padding||12}}" detailurl="/pagesZ/generation/create?type=1" bind:__l="__l"></dp-product-itemlist></block><block wx:if="{{params.style=='line'}}"><dp-product-itemline vue-id="pg-item-3" data="{{data}}" saleimg="{{params.saleimg}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" showcart="{{params.showcart}}" cartimg="{{params.cartimg}}" carttext="{{params.carttext}}" idfield="proid" menuindex="{{menuindex}}" probgcolor="{{params.probgcolor}}" saleslabel="已用" cover_ratio="{{params.cover_ratio||'1:1'}}" cover_radius="{{params.cover_radius||8}}" card_radius="{{params.card_radius||8}}" btn_position="{{params.btn_position||'bottom-right'}}" info_padding="{{params.info_padding||12}}" detailurl="/pagesZ/generation/create?type=1" bind:__l="__l"></dp-product-itemline></block><block wx:if="{{params.style=='waterfall'}}"><dp-product-waterfall vue-id="pg-item-4" list="{{data}}" saleimg="{{params.saleimg}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" showcart="{{params.showcart}}" cartimg="{{params.cartimg}}" carttext="{{params.carttext}}" idfield="proid" menuindex="{{menuindex}}" probgcolor="{{params.probgcolor}}" saleslabel="已用" cover_ratio="{{params.cover_ratio||'auto'}}" cover_radius="{{params.cover_radius||8}}" card_radius="{{params.card_radius||8}}" btn_position="{{params.btn_position||'bottom-right'}}" card_gap="{{params.card_gap||12}}" info_padding="{{params.info_padding||12}}" detailurl="/pagesZ/generation/create?type=1" bind:__l="__l"></dp-product-waterfall></block><!-- grid7横排7列自适应 --><block wx:if="{{params.style=='grid7'}}"><view class="grid7-container"><view class="grid7-card" wx:for="{{data}}" wx:key="id" style="border-radius:{{params.card_radius||8}}rpx" data-index="{{index}}" bindtap="onMakeSame"><view class="grid7-cover" style="padding-bottom:{{grid7CoverPadding}};border-radius:{{params.card_radius||8}}rpx {{params.card_radius||8}}rpx 0 0"><image class="grid7-cover-img" src="{{item.pic}}" mode="aspectFill" style="border-radius:{{params.card_radius||8}}rpx {{params.card_radius||8}}rpx 0 0"></image></view><view class="grid7-info"><view class="grid7-name">{{item.name}}</view><view class="grid7-price">¥{{item.sell_price||item.price||'0.00'}}</view></view><view class="grid7-hover-btn grid7-hover-show"><text class="grid7-hover-text">制作同款</text></view></view></view></block><!-- 底部任务弹窗遮罩 --><view class="task-popup-mask" wx:if="{{showPopup}}" bindtap="closePopup"></view><!-- 底部任务弹窗 --><view class="task-popup {{showPopup?'task-popup-show':''}} {{isExpanded?'task-popup-expanded':''}}" wx:if="{{showPopup}}"><view class="popup-row popup-header"><text class="popup-type-title">图片生成</text><view class="popup-header-btns"><view class="popup-btn-expand" bindtap="toggleExpand"><text class="popup-btn-icon">{{isExpanded?'⇩':'⇧'}}</text></view><view class="popup-btn-close" bindtap="closePopup"><text class="popup-btn-icon">✕</text></view></view></view><view class="popup-row popup-prompt" wx:if="{{popupPromptVisible}}"><textarea class="popup-prompt-input" value="{{popupPrompt}}" bindinput="onPromptInput" placeholder="请输入图像描述" maxlength="2000" auto-height="{{!isExpanded}}" style="{{isExpanded?'height:200rpx;':''}}"></textarea><text class="popup-prompt-count">{{popupPrompt.length}}/2000</text></view><view class="popup-row popup-upload" wx:if="{{popupNeedRefImage}}"><view class="popup-upload-label">参考图片</view><view class="popup-upload-area"><view class="popup-upload-item" wx:for="{{popupRefImages}}" wx:for-item="img" wx:for-index="imgIdx" wx:key="*this"><image class="popup-upload-thumb" src="{{img}}" mode="aspectFill"></image><view class="popup-upload-del" data-index="{{imgIdx}}" catchtap="removeRefImage">✕</view></view><view class="popup-upload-add" wx:if="{{popupRefImages.length < popupMaxRefImages}}" bindtap="chooseRefImage"><text class="popup-upload-add-icon">+</text></view></view></view><view class="popup-row popup-params"><view class="popup-param-group"><view class="popup-param-item" bindtap="toggleRatioPanel"><text class="popup-param-label">比例</text><text class="popup-param-value">{{popupSelectedRatio}}</text><text class="popup-param-arrow">▼</text></view><view class="popup-param-item" bindtap="toggleQuantityPanel"><text class="popup-param-label">数量</text><text class="popup-param-value">{{popupQuantity}}张</text><text class="popup-param-arrow">▼</text></view></view><view class="popup-generate-btn {{popupSubmitting?'popup-generate-disabled':''}}" bindtap="submitPopupGeneration"><text class="popup-generate-text">{{popupSubmitting?'提交中...':'立即生成'}}</text></view></view><view class="popup-dropdown" wx:if="{{showRatioPanel}}"><view class="popup-dropdown-mask" bindtap="closeRatioPanel"></view><view class="popup-dropdown-content"><view class="popup-dropdown-title">选择比例</view><view class="popup-dropdown-grid"><view class="popup-dropdown-item {{popupSelectedRatio==item?'popup-dropdown-active':''}}" wx:for="{{popupRatioOptions}}" wx:key="*this" data-ratio="{{item}}" bindtap="selectPopupRatio">{{item}}</view></view></view></view><view class="popup-dropdown" wx:if="{{showQuantityPanel}}"><view class="popup-dropdown-mask" bindtap="closeQuantityPanel"></view><view class="popup-dropdown-content"><view class="popup-dropdown-title">选择数量</view><view class="popup-dropdown-grid"><view class="popup-dropdown-item {{popupQuantity==item?'popup-dropdown-active':''}}" wx:for="{{quantityOptions}}" wx:key="*this" data-quantity="{{item}}" bindtap="selectPopupQuantity">{{item}}张</view></view></view></view></view></view>
