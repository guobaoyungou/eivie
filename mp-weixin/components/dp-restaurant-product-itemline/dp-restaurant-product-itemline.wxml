<view style="width:100%;"><view class="dp-product-itemline"><block wx:for="{{data}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="item" data-url="{{showtype=='0'?'/restaurant/takeaway/product?id='+item[idfield]:'/restaurant/shop/product?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block wx:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block wx:if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block wx:if="{{showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block wx:if="{{item.price_show&&item.price_show_text}}"><text style="margin:0 15rpx;font-size:22rpx;font-weight:400;">{{item.price_show_text}}</text></block><block wx:if="{{showprice=='1'&&item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></block></view><block wx:if="{{item.price_show&&item.price_show==1}}"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item.sell_putongprice}}</text></view></block><block wx:if="{{item.priceshows&&item.priceshows.length>0}}"><view><block wx:for="{{item.priceshows}}" wx:for-item="item2" wx:for-index="index2"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item2.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item2.price_show_text}}</text></view></block></view></block><block wx:if="{{showsales=='1'&&item.sales>0}}"><view class="p3">{{"已售"+item.sales+"件"}}</view></block></view></view></block></view><block wx:if="{{buydialogShow}}"><buydialog vue-id="567822c2-1" proid="{{proid}}" menuindex="{{menuindex}}" controller="{{showtype=='0'?'ApiRestaurantTakeaway':'ApiRestaurantShop'}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" bind:addcart="__e" bind:buydialogChange="__e" bind:__l="__l"></buydialog></block></view>