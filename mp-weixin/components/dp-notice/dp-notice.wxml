<view class="dp-notice" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx'+' 0rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block wx:if="{{params.showimg==1}}"><view class="left"><image class="image" src="{{params.img}}" mode="heightFix"></image></view></block><view class="right"><block wx:if="{{params.showicon==1}}"><image class="ico" src="{{params.icon}}"></image></block><block wx:if="{{data&&data.length==1}}"><block><view class="dp-notice-content" style="{{'text-align:'+(textAlign)+';'}}"><view class="dp-content-text" style="{{'font-size:'+(params.fontsize*2.2+'rpx')+';'+('animation-duration:'+(animationDuration)+';')+('animation-play-state:'+(animationPlayState)+';')+('padding-lift:'+(paddingLift)+';')}}" data-url="{{data[0].hrefurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{''+data[0].title+''}}</view></view></block></block><block wx:else><block><swiper class="itemlist" style="position:relative;height:40rpx;" autoplay="true" interval="{{params.scroll*1000}}" vertical="true" circular="{{true}}"><block wx:for="{{data}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><swiper-item class="item" style="{{'font-size:'+(params.fontsize*2.2+'rpx')+';'}}" data-url="{{item.hrefurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{item.title}}</swiper-item></block></swiper></block></block></view></view>