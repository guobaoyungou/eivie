.coupon-list{width:100%;display:flex;flex-direction:column;padding:0 30rpx;box-sizing:border-box}.coupon-list .coupon{width:100%;background:#fff;border-radius:16rpx;display:flex;flex-direction:row;align-items:center;padding:36rpx 24rpx;box-sizing:border-box}.coupon-list .coupon + .coupon{margin-top:20rpx}.coupon-list .coupon .left{width:150rpx;display:flex;flex-direction:column;align-items:center;justify-content:center}.coupon-list .coupon .left .number{font-size:56rpx}.coupon-list .coupon .left .number.complex{display:flex;flex-direction:row;align-items:baseline;justify-content:center}.coupon-list .coupon .left .number.complex .main{font-size:64rpx}.coupon-list .coupon .left .number.complex .minor{font-size:24rpx}.coupon-list .coupon .left .desc{font-size:24rpx}.coupon-list .coupon .right{margin-left:24rpx;flex-grow:1;display:flex;flex-direction:column}.coupon-list .coupon .right .content{width:100%;display:flex;flex-direction:row;align-items:center;justify-content:space-between}.coupon-list .coupon .right .content .info{display:flex;flex-direction:column}.coupon-list .coupon .right .content .info .name{font-size:30rpx;color:#000}.coupon-list .coupon .right .content .info .item{margin-top:22rpx;font-size:24rpx;color:rgba(58,68,99,.5)}.coupon-list .coupon .right .content .info .item.compact{margin-top:0}.coupon-list .coupon .right .content .button{color:#fff;height:60rpx;line-height:60rpx;min-width:140rpx;margin:0;font-size:26rpx;border-radius:60rpx;background:#555}.coupon-list .coupon .right .content .button.disabled{background:#9d9d9d}.coupon-list .coupon .right .rule{margin-top:24rpx;width:100%;font-size:24rpx;color:rgba(58,68,99,.5)}