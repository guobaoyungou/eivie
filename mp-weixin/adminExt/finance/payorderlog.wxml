<view><block wx:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入用户昵称或订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index1" wx:key="index1"><view class="item" data-url="{{'payorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><view class="f2"><view class="t2">{{"支付会员："+(item.nickname||'')}}</view><text class="t2">{{"支付时间："+item.paytime}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><block wx:if="{{item.paynum&&item.paynum!=0}}"><text class="t2" style="white-space:nowrap;">{{"支付单号："+item.paynum}}</text></block></view></view><view class="right"><view><view class="money" style="{{'color:'+($root.m0)+';'}}">{{"￥"+item.money}}</view><block wx:if="{{item.refund_money>0}}"><view class="refund-money">{{"已退:￥"+item.refund_money}}</view></block></view><image class="more" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></view><block wx:if="{{nodata}}"><nodata vue-id="9bf08c68-1" bind:__l="__l"></nodata></block><block wx:if="{{nomore}}"><nomore vue-id="9bf08c68-2" bind:__l="__l"></nomore></block></block></block><block wx:if="{{loading}}"><loading vue-id="9bf08c68-3" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="9bf08c68-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>