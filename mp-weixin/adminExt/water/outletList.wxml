<view class="container"><block wx:if="{{isload}}"><block><view class="coupon-list"><block wx:for="{{datalist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="coupon"><view class="order-box"><view class="content" style="border-bottom:none;"><view class="pt_right"><view class="f1"><view class="t1">{{"出水口编号："+item.outlet_num}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"出水口单价："+item.outlet_price+"元/升"}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"设备编号："+item.deviceId}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"添加时间 "+item.createtime}}</view></view></view></view><view class="op"><view data-event-opts="{{[['tap',[['copyUrl',['$0'],[[['datalist','',index,'qrcode']]]]]]]}}" class="btn2" style="width:240rpx;" bindtap="__e">复制二维码链接</view><view class="btn2" style="width:200rpx;" data-qrcode="{{item.qrcode}}" data-event-opts="{{[['tap',[['showQr',['$event']]]]]}}" bindtap="__e">查看二维码</view><view class="btn2" data-url="{{'outletEdit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">编辑</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除</view></view></view></view></block></view><view class="bottom-but-view notabbarbot"><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',1) 100%)')}}" data-url="{{'outletEdit?water_happyti_device_id='+water_happyti_device_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加出水口</button></view><uni-popup class="vue-ref" vue-id="1d54cef8-1" id="dialogQr" type="dialog" data-ref="dialogQr" bind:__l="__l" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{qrcode}}" data-url="{{qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['closeQr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block wx:if="{{nomore}}"><nomore vue-id="1d54cef8-2" bind:__l="__l"></nomore></block><block wx:if="{{loading}}"><loading vue-id="1d54cef8-3" bind:__l="__l"></loading></block><block wx:if="{{nodata}}"><nodata vue-id="1d54cef8-4" bind:__l="__l"></nodata></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view></block></block></view>