<view><block wx:if="{{isload}}"><block><view class="container"><view class="topbg"><image class="image" src="{{pre_url+'/static/img/collage_teambg.png'}}"></image></view><view class="topbox" data-url="{{'product?id='+product.id+'&teampid='+teamid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><image src="{{product.pic}}"></image></view><view class="right"><view class="f1">{{product.name}}</view><view class="f2"><block wx:if="{{!product.collage_type}}"><view class="t1">{{product.teamnum+"人团"}}</view></block></view><view class="f3"><view class="t1">￥</view><view class="t2">{{product.sell_price}}</view><view class="t3">{{product.sales+"人已拼"}}</view></view></view></view><view class="teambox"><view class="userlist"><block wx:for="{{userlist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="item"><image class="f1" src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image><block wx:if="{{item.tuanzhang==1}}"><text class="f2">团长</text></block><block wx:if="{{item.nickname!=''}}"><text>{{item.nickname}}</text></block><block wx:else><view style="height:40rpx;"></view></block></view></block></view></view></view></block></block><block wx:if="{{loading}}"><loading vue-id="44a3dcae-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="44a3dcae-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="44a3dcae-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>