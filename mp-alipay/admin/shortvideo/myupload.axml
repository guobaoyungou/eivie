<view><dd-search vue-id="589d725d-1" isfixed="{{true}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" onGetdata="__e" onVueInit="__l"></dd-search><view class="container" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="content" style="border-bottom:none;"><view data-url="{{'/activity/shortvideo/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.coverimg}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><view class="t2">{{"播放量 "+item.view_num}}<text style="color:#a88;padding-left:20rpx;">{{"点赞数 "+item.zan_num}}</text></view><block a:if="{{item.status==2}}"><text class="t3">{{"驳回原因："+item.reason}}</text></block></view></view><view class="op"><block a:if="{{item.status==0}}"><text class="flex1" style="color:orange;">待审核</text></block><block a:if="{{item.status==2}}"><text class="flex1" style="color:red;">未通过</text></block><block a:if="{{item.status==1}}"><text class="flex1" style="color:green;">已通过</text></block><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除</view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="589d725d-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="589d725d-3" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view><view class="{{(('btn-add')+' '+(menuindex>-1?'tabbarbot':'notabbarbot3'))}}" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" data-url="uploadvideo" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image style="width:28rpx;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>发布短视频</view><popmsg vue-id="589d725d-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>