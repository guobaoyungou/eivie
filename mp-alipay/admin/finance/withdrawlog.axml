<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="tabcontent"><dd-tab vue-id="5cf40b55-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view class="content"><view class="item" data-url="{{'withdrawdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="t1" src="{{item.$orig.headimg}}"></image><text class="t2">{{item.$orig.nickname}}</text></view><view class="f2"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m1}}</text><text class="t2">{{"提现方式："+item.$orig.paytype}}</text></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block><block a:if="{{item.$orig.status==4}}"><text class="t1">处理中</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="5cf40b55-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="5cf40b55-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="5cf40b55-4" onVueInit="__l"></loading></block><popmsg vue-id="5cf40b55-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>