<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f-row"><view class="f2"><text>{{myscore}}</text></view><view class="score-option"><block a:if="{{businessTransfer}}"><view class="btn-mini" data-url="/pagesA/score/transfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转入/转出</view></block><block a:if="{{scoreWithdraw}}"><view class="btn-mini" data-url="/pagesB/business/scorewithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></block></view></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block a:else><block><text class="t2">{{item.score}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="476d5c7b-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="476d5c7b-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="476d5c7b-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="476d5c7b-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="476d5c7b-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>