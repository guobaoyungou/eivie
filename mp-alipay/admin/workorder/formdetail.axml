<view class="container"><block a:if="{{isload}}"><block><view class="orderinfo"><view class="item"><text class="t1">提交人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view><view class="item"><text class="t1">工单分类</text><view class="t2" data-url="{{'updatecate?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{detail.cname+''}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view><view class="item"><text class="t1">工单名称</text><text class="t2">{{detail.title}}</text></view><block class="item" a:for="{{formcontent}}" a:for-item="fitem" a:for-index="findex"><view class="dp-form-separate" data-index="{{findex}}" data-event-opts="{{[['tap',[['formChange',['$event']]]]]}}" catchTap="__e">{{fitem.name}}<image src="{{pre_url+'/static/img/workorder/'+(currentindex==findex?'down':'up')+'.png'}}"></image></view><view class="parentitem" style="{{(currentindex!=findex?'display:none':'')}}"><view class="item" a:for="{{fitem.list}}" a:for-item="item" a:for-index="idx"><text class="t1">{{item.val1}}</text><block a:if="{{item.key!='upload'&&item.key!='upload_file'&&item.key!='upload_video'}}"><text class="t2">{{detail['form'+idx]}}</text></block><block a:if="{{item.key=='upload'}}"><view class="t2" style="display:flex;justify-content:flex-end;"><view a:for="{{detail['form'+idx]}}" a:for-item="sub" a:for-index="indx" a:key="indx"><image style="width:50px;margin-left:10rpx;" src="{{sub}}" mode="widthFix" data-url="{{sub}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:if="{{item.key=='upload_file'}}"><view class="t2" style="overflow:hidden;white-space:pre-wrap;word-wrap:break-word;color:#4786BC;">{{''+detail['form'+idx]+''}}</view></block><block a:if="{{item.key=='upload_video'}}"><view class="t2"><video style="width:100%;" src="{{detail['form'+idx]}}"></video></view></block></view></view></block><view class="item"><text class="t1">提交时间</text><text class="t2">{{detail.createtime}}</text></view><view class="item"><text class="t1">审核状态</text><block a:if="{{detail.status==0&&(!detail.payorderid||detail.paystatus==1)}}"><text class="t2" style="color:#88e;">待处理</text></block><block a:if="{{detail.status==0&&detail.payorderid&&detail.paystatus==0}}"><text class="t2" style="color:red;">待支付</text></block><block a:if="{{detail.status==1}}"><text class="t2" style="color:green;">处理中</text></block><block a:if="{{detail.status==2}}"><text class="t2" style="color:green;">已完成</text></block><block a:if="{{detail.status==-1}}"><text class="t2" style="color:red;">已驳回</text></block></view><block a:if="{{detail.status==-1}}"><view class="item"><text class="t1">驳回原因</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block><block a:if="{{form.payset==1}}"><block><view class="item"><text class="t1">付款金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype}}</text></view><view class="item"><text class="t1">付款状态</text><block a:if="{{detail.paystatus==1&&detail.isrefund==0}}"><text class="t2" style="color:green;">已付款</text></block><block a:if="{{detail.paystatus==1&&detail.isrefund==1}}"><text class="t2" style="color:red;">已退款</text></block><block a:if="{{detail.paystatus==0}}"><text class="t2" style="color:red;">未付款</text></block></view><block a:if="{{detail.paystatus>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block></block></block><block a:if="{{detail.iscomment==1}}"><block><view class="item"><text class="t1">满意度</text><block a:if="{{detail.comment_status==1}}"><text class="t2" style="color:red;">不满意</text></block><block a:if="{{detail.comment_status==2}}"><text class="t2" style="color:#88e;">一般</text></block><block a:if="{{detail.comment_status==3}}"><text class="t2" style="color:green;">满意</text></block></view></block></block></view><view style="width:100%;height:160rpx;"></view><view class="bottom notabbarbot"><block a:if="{{detail.status>0}}"><view class="btn2" data-url="{{'jindu?id='+detail.id+'&cid='+detail.cid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看进度</view></block><block a:if="{{detail.status==0}}"><view class="btn2" data-st="{{-1}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setst2',['$event']]]]]}}" onTap="__e">驳回</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" onTap="__e">删除</view></view><uni-popup vue-id="7277afa7-1" id="dialogSetst2" type="dialog" ref="__r" data-ref="dialogSetst2" onVueInit="__l"><uni-popup-dialog vue-id="{{('7277afa7-2')+','+('7277afa7-1')}}" mode="input" title="驳回原因" value="{{detail.reason}}" placeholder="请输入驳回原因" data-event-opts="{{[['^confirm',[['setst2confirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{ishowjindu}}"><view class="modaljd"><view class="modal_jindu2"><view data-event-opts="{{[['tap',[['closejd',['$event']]]]]}}" class="close" onTap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view><block a:if="{{jdlist.length>0}}"><block><view class="item " style="display:flex;" a:for="{{jdlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/jindu'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{'时间：'+item.time}}</text><text class="t1">{{item.desc+"("+item.remark+')'}}</text><block a:for="{{item.content_pic}}" a:for-item="pic" a:for-index="ind"><block a:if="{{item.content_pic.length>0}}"><view><view class="layui-imgbox-img"><image src="{{pic}}" data-url="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></block><view a:for="{{item.hflist}}" a:for-item="hf" a:for-index="hfindex" a:key="hfindex"><block a:if="{{hf.hfremark}}"><view class="t3">{{"用户回复："+hf.hfremark+''}}</view></block><block a:if="{{hf.hftime}}"><view class="t4">{{"回复时间："+hf.hftime+''}}</view></block><block a:for="{{hf.hfcontent_pic}}" a:for-item="pic2" a:for-index="ind2"><block a:if="{{hf.hfcontent_pic.length>0}}"><view><view class="layui-imgbox-img"><image src="{{pic2}}" data-url="{{pic2}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></block></view></view></view></block></block><block a:else><block><view style="font-size:14px;color:#f05555;padding:10px;">等待处理</view></block></block></view></view></block><block a:if="{{showstatus}}"><view class="modal"><view class="modal_jindu"><form data-event-opts="{{[['submit',[['formsubmit',['$event']]]]]}}" onSubmit="__e"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="close" onTap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title">选择处理流程</view><view class="uni-list"><radio-group name="liucheng"><label class="uni-list-cell uni-list-cell-pd" a:for="{{lclist}}" a:for-item="item" a:for-index="index" a:key="index"><view><radio style="transform:scale(0.7);" value="{{''+item.id}}"></radio></view><view>{{item.name}}</view></label></radio-group><view class="beizhu flex"><label>备注1:</label><textarea style="height:100rpx;" placeholder="输入内容" name="content" maxlength="-1"></textarea></view></view><button class="btn" form-type="submit">提交</button></form></view></view></block><block a:if="{{loading}}"><loading vue-id="7277afa7-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="7277afa7-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7277afa7-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>