<view class="container"><block a:if="{{isload}}"><block><view class="content-container"><view class="nav_left"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('nav_left_items '+(curIndex==index?'active':''))}}" style="{{'color:'+(curIndex==index?item.m0:'#333')+';'}}" data-index="{{index}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.$orig.name}}</view></block></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="product-itemlist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="idx2" a:key="id"><block a:if="{{iscate==1}}"><view class="item"><view class="product-info"><view class="img" data-id="{{item.id}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/workorder/'+(curIndex2==idx2?'down':'up')+'.png?v1'}}" mode="widthFix"></image></view><view class="p1" data-url="{{'record?cid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{item.name}}</text><block a:if="{{item.count>0}}"><text class="count">{{item.count}}</text></block></view></view><block a:for="{{item.list}}" a:for-item="subitem" a:for-index="subindex"><block a:if="{{curIndex2==idx2}}"><view class="list" data-url="{{'record?cateid='+subitem.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><label>{{''+subitem.name}}</label><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></view></block><block a:else><view class="item"><view class="product-info"><view class="list" style="width:100%;position:relative;" data-url="{{'record?cateid='+subitem.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="subitem" a:for-index="subindex"><label>{{''+subitem.name}}</label><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text><block a:if="{{subitem.count>0}}"><text class="count" style="position:absolute;top:10rpx;right:30rpx;">{{subitem.count}}</text></block></view></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="6b785744-1" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="6b785744-2" text="暂无相关商品" onVueInit="__l"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="6b785744-3" loadstyle="left:62.5%" onVueInit="__l"></loading></block><dp-tabbar vue-id="6b785744-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="6b785744-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>