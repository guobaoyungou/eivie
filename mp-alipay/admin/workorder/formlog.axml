<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="369764ec-1" itemdata="{{['全部','待处理','处理中','已处理','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:90rpx;"></view><view class="content" id="datalist"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><view class="flex" style="justify-content:space-between;"><text class="t1" data-url="{{'myformdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"工单类型："+item.title}}</text><view class="f2"><block a:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待处理</text></block><block a:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block a:if="{{item.status==1}}"><text class="t1" style="color:green;">处理中</text></block><block a:if="{{item.status==2}}"><text class="t1" style="color:red;">已处理</text></block><block a:if="{{item.status==-1}}"><text class="t1" style="color:red;">已驳回</text></block></view></view><view class="flex" style="justify-content:space-between;margin-top:15rpx;"><text class="t2" data-url="{{'myformdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"提交时间："+item.createtime}}</text><block a:if="{{!item.payorderid||item.payorderid&&item.paystatus==1}}"><view class="jindu" data-id="{{item.id}}" data-event-opts="{{[['tap',[['jindu',['$event']]]]]}}" onTap="__e">查看进度</view></block></view></view></view></view></block></block><block a:if="{{ishowjindu}}"><view class="modal"><view class="modal_jindu"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="close" onTap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view><block a:if="{{jdlist.length>0}}"><block><view class="item " a:for="{{jdlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/jindu'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{'时间：'+item.time}}</text><text class="t1">{{item.desc+"("+item.remark+')'}}</text></view></view></block></block><block a:else><block><view style="font-size:14px;color:#f05555;padding:10px;">等待处理</view></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="369764ec-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="369764ec-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="369764ec-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="369764ec-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="369764ec-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>