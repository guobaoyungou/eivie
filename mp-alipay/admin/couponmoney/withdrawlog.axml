<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m0}}</text></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="89f42056-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="89f42056-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="89f42056-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="89f42056-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="89f42056-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>