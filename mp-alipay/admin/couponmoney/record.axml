<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"名称："+item.$orig.couponname}}</text><text class="t2">{{"时间："+item.m0}}</text><view class="t3 flex-y-center">使用人：<image style="width:40rpx;height:40rpx;" src="{{item.$orig.headimg}}"></image>{{item.$orig.nickname}}</view></view><view class="f2"><text class="t1">{{"+"+item.$orig.decmoney}}</text></view></view></view><block a:if="{{nomore}}"><nomore vue-id="4a13d330-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4a13d330-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="4a13d330-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="4a13d330-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4a13d330-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>