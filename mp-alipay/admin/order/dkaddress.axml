<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="content" data-id="{{item.id}}" data-event-opts="{{[['tap',[['setdefault',['$0'],[[['datalist','',index]]]]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{item.tel}}</text><block a:if="{{item.company}}"><text class="t2">{{item.company}}</text></block><text class="flex1"></text></view><view class="f2">{{item.area+" "+item.address}}</view></view><block a:if="{{nodata}}"><nodata vue-id="aac31024-1" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="aac31024-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="aac31024-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="aac31024-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>