<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="9b038b7a-1" itemdata="{{['全部','待付款','待发货','待收货','已完成']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view><block a:if="{{morewifiprintShow}}"><view class="btn2" data-type="2" data-event-opts="{{[['tap',[['wifiprint',['$event']]]]]}}" onTap="__e">批量打印</view></block></view><view class="order-content"><checkbox-group class="radio-group" name="gettj" data-event-opts="{{[['change',[['wifiprintChexbox',['$event']]]]]}}" onChange="__e"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'shoporderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type!=1}}"><text class="st1">待发货</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type==1}}"><text class="st1">待提货</text></block><block a:if="{{item.$orig.status==2}}"><text class="st2">待收货</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><text class="t2">{{item2.$orig.ggname}}</text><block><block a:if="{{item2.$orig.product_type&&item2.$orig.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item2.$orig.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item2.$orig.real_total_weight+"斤"}}</text></view></block><block a:else><view class="t3"><text class="x1 flex1">{{"￥"+item2.$orig.sell_price+''}}<block a:if="{{item2.m0}}"><text>{{"+"+item2.$orig.freezemoney_price+item2.m1}}</text></block></text><text class="x2">{{"×"+item2.$orig.num}}</text></view></block></block><block a:if="{{item2.$orig.has_glassrecord}}"><view class="t2 tgr">{{''+item2.$orig.glassrecord.name+" \r\n\t\t\t\t\t\t\t\t"+(item2.$orig.glassrecord.nickname?item2.$orig.glassrecord.nickname:'')+" \r\n\t\t\t\t\t\t\t\t"+(item2.$orig.glassrecord.check_time?item2.$orig.glassrecord.check_time:'')+"\r\n\t\t\t\t\t\t\t\t"+item2.$orig.glassrecord.typetxt+''}}</view></block></view></view></block><block a:if="{{item.$orig.crk_givenum&&item.$orig.crk_givenum>0}}"><view style="color:#f60;line-height:70rpx;">{{"+随机赠送"+item.$orig.crk_givenum+"件"}}</view></block><block a:if="{{item.$orig.isdygroupbuy&&item.$orig.isdygroupbuy==1}}"><view class="bottom"><text style="color:red;">抖音团购券</text></view></block><view class="bottom"><text>{{"共计"+item.$orig.procount+"件商品 实付:￥"+item.$orig.totalprice}}</text><block a:if="{{item.m2}}"><text>{{"+"+item.$orig.total_freezemoney_price+item.m3}}</text></block><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><block a:if="{{item.m4}}"><view class="bottom"><text>{{"预约提货时间："+item.$orig.exchange_card_take_date}}</text></view></block><block a:if="{{item.$orig.mid>0}}"><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.$orig.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.$orig.member.nickname}}</text>{{"(ID:"+item.$orig.mid+')'}}</view></block><block a:if="{{item.$orig.wx_express_intracity&&item.$orig.wxtc_status_name}}"><view class="bottom" style="color:red;font-size:13px;"><text>{{"配送状态："+item.$orig.wxtc_status_name}}</text></view></block><block a:if="{{item.$orig.wx_express_intracity&&item.$orig.freight_time}}"><view class="bottom" style="color:red;font-size:13px;"><text>{{"配送时间："+item.$orig.freight_time}}</text></view></block><view class="op"><block a:if="{{wifiprintAuth}}"><view style="display:flex;justify-content:flex-end;align-items:center;"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" catchTap="__e"><checkbox value="{{''+item.$orig.id}}" checked="{{item.m5?true:false}}"></checkbox></view><view class="btn2" data-id="{{item.$orig.id}}" data-type="1" data-event-opts="{{[['tap',[['wifiprint',['$event']]]]]}}" catchTap="__e">打印小票</view></view></block><block a:if="{{item.$orig.shoporder_update&&item.$orig.status==0}}"><view class="btn2" data-id="{{item.$orig.id}}" data-url="{{'/adminExt/order/updateOrder?id='+item.$orig.id}}" data-type="1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">订单修改</view></block><block a:if="{{item.$orig.shoporder_shdimg_mobile}}"><view class="btn2" data-id="{{item.$orig.id}}" data-url="{{'/adminExt/order/shdImg?id='+item.$orig.id}}" data-type="1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">送货单</view></block><block a:if="{{shoporder_copy}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['copyOrder',['$event']]]]]}}" catchTap="__e">复制</view></block><block a:if="{{shoporder_update_member&&item.$orig.status==0}}"><view class="btn2" data-id="{{item.$orig.id}}" data-url="{{'../member/index?type=updateOrder&update_oid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">更换ID</view></block></view></view></block></checkbox-group></view><uni-popup vue-id="9b038b7a-2" id="dialogShdimg" type="dialog" ref="__r" data-ref="dialogShdimg" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{shdimg}}" data-url="{{shdimg}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">点击查看图片后，长按保存</view><view data-event-opts="{{[['tap',[['closeShdimg',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="9b038b7a-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="9b038b7a-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="9b038b7a-5" onVueInit="__l"></loading></block><popmsg vue-id="9b038b7a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>