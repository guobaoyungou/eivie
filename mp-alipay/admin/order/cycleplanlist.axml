<view class="data-v-6cda726e"><view class="page data-v-6cda726e"><view class="body data-v-6cda726e"><view class="body_progress data-v-6cda726e"><view class="data-v-6cda726e" a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{index==0}}"><view class="{{(('data-v-6cda726e')+' '+(item.status==2?'progress_active':''))}}"><view class="progress_tag data-v-6cda726e"></view></view></block><block a:if="{{index!=0}}"><view class="{{(('data-v-6cda726e')+' '+(item.status==2?'progress_active':''))}}"><view class="progress_line data-v-6cda726e"></view><view class="progress_tag data-v-6cda726e"></view></view></block></view></view><view class="body_module data-v-6cda726e"><view class="{{((('body_list')+' '+'data-v-6cda726e')+' '+(item.status==2?'list_active':item.status==3?'collect_active':''))}}" a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><view class="body_data data-v-6cda726e"><view class="body_title data-v-6cda726e" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" catchTap="__e">{{item.title}}<image class="body_icon _img data-v-6cda726e" src="{{pre_url+'/static/img/week/week_detail.png'}}" alt></image></view><block a:if="{{detail.freight_type==0||detail.freight_type==2}}"><view class="body_text data-v-6cda726e">{{"配送日: "+item.cycle_date}}</view></block><block a:else><block a:if="{{detail.freight_type==1}}"><view class="body_text data-v-6cda726e">{{"取货日: "+item.cycle_date}}</view></block></block></view><view class="body_state data-v-6cda726e">{{''+(item.status==0?'待支付':item.status==1&&detail.freight_type==2?'待配送':item.status==1&&detail.freight_type==0?'待发货':item.status==2&&detail.freight_type==2?'配送中':item.status==2&&detail.freight_type==0?'已发货':item.status==1&&detail.freight_type==1?'待取货':'已完成')+''}}</view></view></view></view></view></view>