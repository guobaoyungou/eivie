<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="8d709320-1" itemdata="{{['全部','待付款','已付款','寄售','发货']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'seckill2orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.status_s}}</text></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><text class="t2">{{item.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></view></view><view class="bottom"><text>{{"共计"+item.num+"件商品 实付:￥"+item.totalprice}}</text><block a:if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block a:if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block a:if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="8d709320-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="8d709320-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="8d709320-4" onVueInit="__l"></loading></block><popmsg vue-id="8d709320-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>