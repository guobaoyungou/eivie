<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="content"><view class="info-item"><view class="t1">预定时间</view><view data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" class="t2" onTap="__e"><input type="text" placeholder="请选择时间" name="time" value="{{chooseTimeStr}}"/></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}" data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" onTap="__e"></image></view><view class="info-item"><view class="t1">人数</view><view class="t2"><picker value="{{nindex}}" range="{{numArr}}" name="renshu" data-event-opts="{{[['change',[['numChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{numArr[nindex]}}</view></picker></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="info-item"><view class="t1">餐桌</view><view class="t2" data-url="{{'bookingTableList?bid='+opt.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><input type="text" placeholder="请选择" value="{{tableName}}"/></view><image class="t3" data-url="{{'bookingTableList?bid='+opt.bid}}" src="{{pre_url+'/static/img/arrowright.png'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image></view></view><view class="content"><view class="info-item"><view class="t1">顾客姓名</view><view class="t2"><input type="text" data-name="linkman" name="linkman" placeholder="请输入姓名" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view></view><view class="info-item"><view class="t1">手机号</view><view class="t2"><input type="number" data-name="tel" name="tel" placeholder="请输入手机号" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view></view></view><view class="content"><view class=" remark"><view class="t1">备注</view><view><textarea data-name="message" name="message" placeholder="如您有其他需求请填写" placeholder-style="color:#ABABABFF" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{message}}" onInput="__e"></textarea></view></view></view><view style="padding:30rpx 0;"><button class="set-btn" style="background:#FE5B07;" form-type="submit">添加预定</button></view></form><block a:if="{{pstimeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择时间</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['timeRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{timeArr}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.title}}</view><view class="radio" style="{{('')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="4ddb09b2-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="4ddb09b2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>