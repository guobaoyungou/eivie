<view class="container"><block a:if="{{isload}}"><block><view class="search-container" value="{{keyword}}" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" onConfirm="__e" onInput="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">输入关键词或餐桌号码</view></view></view><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}</view></block></view></view><view class="table-box"><view class="{{(((('table-item')+' '+'bg-green')+' '+((item.status==2)?'bg-orange':''))+' '+((item.status==3)?'bg-blue':''))}}" data-url="{{'tableEdit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{contentList}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="color-fff line40">{{"座位："+item.seat}}</view><block a:if="{{item.status==0}}"><view class="color-fff">空闲</view></block><block a:if="{{item.status==2}}"><view class="color-fff">用餐</view></block><block a:if="{{item.status==3}}"><view class="color-fff">清台</view></block></view></view></view></block></block><view class="bottom-view"><view class="button" data-url="tableEdit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加餐桌</view></view><block a:if="{{loading}}"><loading vue-id="65e81fd2-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="65e81fd2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>