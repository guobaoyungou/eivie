<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form"><view class="form-item"><text class="label">еҜ„еӯҳеҗҚз§°</text><text class="flex1"></text><text>{{info.name}}</text></view><view class="form-item"><text class="label">еҜ„еӯҳж•°йҮҸ</text><text class="flex1"></text><text>{{info.num}}</text></view><view class="form-item"><text class="label">еҜ„еӯҳдәә</text><text class="flex1"></text><text>{{info.linkman}}</text></view><view class="form-item"><text class="label">жүӢжңәеҸ·</text><text class="flex1"></text><text>{{info.tel}}</text></view></view><view class="form"><view class="form-item"><text class="label">еҜ„еӯҳеӨҮжіЁ</text><text class="flex1"></text><text>{{info.message}}</text></view></view><view class="form"><view class="form-item"><text class="label">зҠ¶жҖҒ</text><text class="flex1"></text><text>{{info.statusLabel}}</text></view></view><view class="form"><view class="flex-col"><text class="label" style="height:98rpx;line-height:98rpx;font-size:30rpx;">еҜ„еӯҳжӢҚз…§</text><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox-img"><image src="{{info.pic}}" data-url="{{info.pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view></view><block a:if="{{info.status==1}}"><button class="btn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" data-num="{{info.num}}" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" onTap="__e">еҸ–еҮә</button></block><block a:if="{{info.status==0}}"><button class="btn" style="{{('background:linear-gradient(90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')}}" data-type="access" data-operate="йҖҡиҝҮе®Ўж ё" data-event-opts="{{[['tap',[['check',['$event']]]]]}}" onTap="__e">йҖҡиҝҮе®Ўж ё</button></block><block a:if="{{info.status==0}}"><button class="btn btn2" data-type="refuse" data-operate="й©іеӣһ" data-event-opts="{{[['tap',[['check',['$event']]]]]}}" onTap="__e">й©іеӣһ</button></block></form><block a:if="{{info.log.length>0}}"><view class="expressinfo"><view class="content"><view class="{{('item '+(index==0?'on':''))}}" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/dot'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{item.m4}}</text><text class="t1">{{item.$orig.remark+item.$orig.num+"д»¶"}}</text></view></view></view></view></block><block a:if="{{boxShow}}"><view data-event-opts="{{[['touchMove',[['disabledScroll',['$event']]]]]}}" catchTouchMove="__e"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">иҜ·иҫ“е…ҘеҸ–еҮәж•°йҮҸ</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content takeoutBox"><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="orderinfo"><view class="item"><text class="t1">еҸ–еҮәж•°йҮҸ</text><input class="t2" type="text" placeholder="иҜ·иҫ“е…ҘиҰҒеҸ–еҮәзҡ„ж•°йҮҸ" placeholder-style="font-size:28rpx;color:#BBBBBB" name="numbers" value="{{num}}"/></view></view><button class="btn" style="{{'background:'+($root.m5)+';'}}" form-type="submit">зЎ®е®ҡ</button></form></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="674ec3f2-1" onVueInit="__l"></loading></block></view>