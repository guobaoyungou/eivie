<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block a:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><view class="t2">请尽快接单</view></view></block><block a:if="{{detail.status==12}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block a:if="{{detail.freight_type!=1}}"><view class="t2">请尽快发货</view></block><block a:if="{{detail.freight_type==1}}"><view class="t2">待提货</view></block></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block a:if="{{detail.freight_type!=3&&detail.freight_type!=2}}"><view class="t2">{{"发货信息："+detail.express+" "+detail.express_no}}</view></block></view></block><block a:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block a:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><text class="t1">{{detail.linkman+" "+detail.tel}}</text><block a:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2">{{"地址："+detail.area+detail.address}}</text></block><block a:if="{{detail.freight_type==1}}"><text class="t2" data-address="{{storeinfo.address}}" data-latitude="{{storeinfo.latitude}}" data-longitude="{{storeinfo.longitude}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address}}</text></block></view></view><view class="product"><view class="content" a:for="{{$root.l0}}" a:for-item="item" a:for-index="idx" a:key="idx"><view><image src="{{item.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.ggname+(item.$orig.jltitle?item.$orig.jltitle:'')}}</text><view class="t3"><block a:if="{{item.$orig.jlprice}}"><text class="x1 flex1">{{"￥"+item.g0}}</text></block><block a:else><text class="x1 flex1">{{"￥"+item.$orig.sell_price}}</text></block><block a:if="{{goods_hexiao_status&&(detail.status==1||detail.status==2||detail.status==12)&&detail.freight_type==1&&item.$orig.hexiao_code&&item.$orig.num>0}}"><block><view><block a:if="{{item.$orig.status==3}}"><view style="color:#999;">已核销</view></block><block a:else><view style="color:#f60;">未核销</view></block></view></block></block><text class="x2">{{"×"+item.$orig.num}}</text></view></view></view></view><block a:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view><block a:if="{{detail.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2">{{detail.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block a:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m1+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.jianmoney>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block a:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block a:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block a:if="{{detail.couponmoney>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block a:if="{{detail.scoredk>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><view class="item"><text class="t1">{{(detail.status==0?'应付':'实付')+"款"}}</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block a:if="{{detail.status==2}}"><text class="t2">已发货</text></block><block a:if="{{detail.status==3}}"><text class="t2">已收货</text></block><block a:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason}}</text></view></block><block a:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block><view class="item"><text class="t1">备注</text><text class="t2 red">{{detail.message?detail.message:'无'}}</text></view><block a:if="{{detail.field1}}"><view class="item"><text class="t1">{{detail.field1data[0]}}</text><text class="t2 red">{{detail.field1data[1]}}</text></view></block><block a:if="{{detail.field2}}"><view class="item"><text class="t1">{{detail.field2data[0]}}</text><text class="t2 red">{{detail.field2data[1]}}</text></view></block><block a:if="{{detail.field3}}"><view class="item"><text class="t1">{{detail.field3data[0]}}</text><text class="t2 red">{{detail.field3data[1]}}</text></view></block><block a:if="{{detail.field4}}"><view class="item"><text class="t1">{{detail.field4data[0]}}</text><text class="t2 red">{{detail.field4data[1]}}</text></view></block><block a:if="{{detail.field5}}"><view class="item"><text class="t1">{{detail.field5data[0]}}</text><text class="t2 red">{{detail.field5data[1]}}</text></view></block><block a:if="{{(detail.status==1||detail.status==12||detail.status==2)&&detail.freight_type==1}}"><view class="item flex-col"><text class="t1">核销码</text><view class="flex-x-center"><image style="width:400rpx;height:400rpx;" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></view><view style="width:100%;height:120rpx;"></view><view class="bottom"><block a:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundnopass',['$event']]]]]}}" onTap="__e">退款驳回</view></block><block a:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundpass',['$event']]]]]}}" onTap="__e">退款通过</view></block><block a:if="{{detail.status==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['closeOrder',['$event']]]]]}}" onTap="__e">关闭订单</view></block><block a:if="{{detail.status==0&&detail.bid==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['ispay',['$event']]]]]}}" onTap="__e">改为已支付</view></block><block a:if="{{detail.status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refund',['$event']]]]]}}" onTap="__e">拒单退款</view></block><block a:if="{{detail.status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['jiedan',['$event']]]]]}}" onTap="__e">接单</view></block><block a:if="{{detail.status==12}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['fahuo',['$event']]]]]}}" onTap="__e">发货</view></block><block a:if="{{detail.status==12&&detail.canpeisong}}"><block><block a:if="{{detail.express_wx_status}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisongWx',['$event']]]]]}}" onTap="__e">即时配送</view></block><block a:else><block a:if="{{detail.myt_status}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisongMyt',['$event']]]]]}}" onTap="__e">麦芽田配送</view></block><block a:else><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisong',['$event']]]]]}}" onTap="__e">配送</view></block></block></block></block><block a:if="{{detail.status==2||detail.status==3}}"><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+detail.express_com+'&express_no='+detail.express_no+'&type='+detail.express_type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查物流</view></block><block a:if="{{detail.status==4}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" onTap="__e">删除</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setremark',['$event']]]]]}}" onTap="__e">设置备注</view><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['print',['$event']]]]]}}" onTap="__e">打印小票</view><block a:if="{{shopset.is_refund&&(detail.status==1||detail.status==2||detail.status==3||detail.status==12)}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundinit',['$event']]]]]}}" onTap="__e">退款</view></block></view><uni-popup vue-id="14cc0a16-1" id="dialogSetremark" type="dialog" ref="__r" data-ref="dialogSetremark" onVueInit="__l"><uni-popup-dialog vue-id="{{('14cc0a16-2')+','+('14cc0a16-1')}}" mode="input" title="设置备注" value="{{detail.remark}}" placeholder="请输入备注" data-event-opts="{{[['^confirm',[['setremarkconfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="14cc0a16-3" id="dialogExpress" type="dialog" ref="__r" data-ref="dialogExpress" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">发货</text></view><view class="uni-dialog-content"><view><view 