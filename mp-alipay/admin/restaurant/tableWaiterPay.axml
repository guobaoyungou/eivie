<view class="container"><block a:if="{{isload}}"><block><view class="head-bg"><view class="text-center _h1">{{detail.name}}</view></view><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><block a:if="{{detail.status==2}}"><view class="card-view"><view class="card-wrap"><view class="card-title">餐桌信息</view><view class="info-item"><view class="t1">桌台</view><view class="t2">{{detail.name}}</view></view><view class="info-item"><view class="t1">人数/座位数</view><view class="t2">{{order.renshu+"/"+detail.seat}}</view></view></view><block a:if="{{detail.timing_fee_type&&detail.timing_fee_type>0}}"><view class="card-wrap"><view class="card-title">计时收费</view><block a:for="{{detail.timing_log}}" a:for-item="item" a:for-index="index"><block a:if="{{detail.timing_log.length>0}}"><view class="info-item" style="justify-content:center;"><view class="t1">{{item.start_time+" ~ "+item.end_time}}</view><view class="t2" style="flex:0.3;">{{item.num+" 分钟"}}</view></view></block></block><view class="info-item info-textarea"><view class="t1">{{detail.timing_fee_text}}</view><view class="t2">{{"￥"+detail.timing_money}}</view></view></view></block><block a:if="{{orderGoods.length>0}}"><view class="card-wrap card-goods"><view class="card-title">{{"已点菜品("+orderGoodsSum+")"}}</view><view class="info-item" a:for="{{orderGoods}}" a:for-item="item" a:for-index="index" a:key="index"><view class="t1">{{item.name+"["+item.ggname+"]"}}</view><view class="t2">{{"x"+item.num}}</view><view class="t3">{{"￥"+item.real_totalprice}}</view></view><block a:if="{{order.tea_fee>0}}"><view class="info-item"><view class="t1">餐位费</view><view class="t2">{{order.renshu+"人"}}</view><view class="t3">{{"￥"+order.tea_fee}}</view></view></block><view class="info-item"><view class="t1">合计</view><view class="t2">{{"x"+orderGoodsSum}}</view><view class="t3">{{"￥"+order.totalprice}}</view></view><view class="info-item"><view class="t1">优惠</view><view class="t2" style="text-align:right;"><input type="digit" data-name="discount" name="discount" placeholder="输入优惠金额" data-event-opts="{{[['input',[['__set_model',['','discount','$event',[]]],['input',['$event']]]]]}}" value="{{discount}}" onInput="__e"/></view></view><view class="info-item"><view class="t1">实付</view><view class="t2">{{"￥"+real_totalprice}}</view></view></view></block></view></block><view class="btn-view button-sp-area"><block a:if="{{detail.status==2}}"><button type="primary" form-type="submit">线下收款</button></block></view></form><view class="btn-view button-sp-area mb"><button class="btn-default" type="default" data-url="tableWaiter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">返回餐桌列表</button></view></block></block><block a:if="{{loading}}"><loading vue-id="7ea95df0-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="7ea95df0-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>