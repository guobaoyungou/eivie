<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="853dda90-1" itemdata="{{['全部','待审核','寄存中','已取出','驳回']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入寄存名称、寄存人姓名或手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block><view class="order-box" a:for="{{$root.l0}}" a:for-item="item2" a:for-index="idx" a:key="idx"><block><view class="content"><view class="pic" data-url="{{'depositorderdetail?id='+item2.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{item2.$orig.pic}}"></image></view><view class="detail" data-url="{{'depositorderdetail?id='+item2.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text class="t1">{{item2.$orig.name}}</text><text class="t2">{{"寄存人："+item2.$orig.linkman+" "+item2.$orig.tel}}</text><text class="t2">{{"数量："+item2.$orig.num}}</text><text class="t2">{{"存入时间："+item2.m0}}</text></view><block a:if="{{item2.$orig.status==0}}"><view class="takeout st0" data-orderid="{{item2.$orig.id}}">待审核</view></block><block a:if="{{item2.$orig.status==1}}"><view class="takeout" data-orderid="{{item2.$orig.id}}" data-num="{{item2.$orig.num}}" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/deposit_takeout.png'}}"></image>取出</view></block><block a:if="{{item2.$orig.status==2}}"><view class="takeout st2" data-orderid="{{item2.$orig.id}}">已取走</view></block><block a:if="{{item2.$orig.status==3}}"><view class="takeout st3" data-orderid="{{item2.$orig.id}}">未通过</view></block><block a:if="{{item2.$orig.status==4}}"><view class="takeout st2" data-orderid="{{item2.$orig.id}}">已过期</view></block></view></block></view></block></view><block a:if="{{boxShow}}"><view data-event-opts="{{[['touchMove',[['disabledScroll',['$event']]]]]}}" catchTouchMove="__e"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请输入取出数量</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content takeoutBox"><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="orderinfo"><view class="item"><text class="t1">取出数量</text><input class="t2" type="text" placeholder="请输入要取出的数量" placeholder-style="font-size:28rpx;color:#BBBBBB" name="numbers" value="{{num}}"/></view></view><button class="btn" style="{{'background:'+($root.m1)+';'}}" form-type="submit">确定</button></form></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="853dda90-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="853dda90-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="853dda90-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="853dda90-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>