<view class="container"><block a:if="{{isload}}"><block><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}</view></block></view></view><view class="shop-box"><view class="shop-item" a:for="{{contentList}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><image class="shop-img" src="{{item.pic?item.pic:logo}}" mode="aspectFill"></image><view class="f2 flex-col flex1"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="desc">{{"人数："+item.seat}}</view><view class="desc">{{"预定费："+item.booking_fee+" 最低消费："+item.limit_fee}}</view></view><view class="f3 button" data-url="{{'booking?bid='+opt.bid+'&tableId='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">预定</view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="fb8b5e56-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="fb8b5e56-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>