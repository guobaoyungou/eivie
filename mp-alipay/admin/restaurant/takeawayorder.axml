<view class="container"><block a:if="{{isload}}"><block><block a:if="{{!goods_hexiao_status}}"><dd-tab vue-id="0b9e7607-1" itemdata="{{['全部','待付款','待发货','待收货','已完成','退款']}}" itemst="{{['all','0','1','2','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><block a:else><dd-tab vue-id="0b9e7607-2" itemdata="{{['全部','待付款','待发货','已接单','待收货','已完成','退款']}}" itemst="{{['all','0','1','12','2','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'takeawayorderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type!=1}}"><text class="st1">待发货</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type==1}}"><text class="st1">待提货</text></block><block a:if="{{item.$orig.status==2}}"><text class="st2">待收货</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block><block a:if="{{item.$orig.status==12}}"><text class="st1">已接单</text></block></view><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view data-url="{{'/restaurant/shop/product?id='+item2.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><text class="t2">{{item2.$orig.ggname+(item2.$orig.jltitle?item2.$orig.jltitle:'')}}</text><view class="t3"><block a:if="{{item2.$orig.jlprice}}"><text class="x1 flex1">{{"￥"+item2.g0}}</text></block><block a:else><text class="x1 flex1">{{"￥"+item2.$orig.sell_price}}</text></block><block a:if="{{goods_hexiao_status&&(item.$orig.status==1||item.$orig.status==2||item.$orig.status==12)&&item.$orig.freight_type==1&&item2.$orig.hexiao_code&&item2.$orig.num>0}}"><text style="color:#999;"><block a:if="{{item2.$orig.status==3}}"><block style="color:#999;">已核销</block></block><block a:else><block style="color:#f60;">未核销</block></block></text></block><text class="x2">{{"×"+item2.$orig.num}}</text></view></view></view></block><view class="bottom"><text>{{"共计"+item.$orig.procount+"个菜品 实付:￥"+item.$orig.totalprice}}</text><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.$orig.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.$orig.member.nickname}}</text>{{'(ID:'+item.$orig.mid+')'}}</view><block a:if="{{goods_hexiao_status&&(item.$orig.status==12||item.$orig.status==2)&&item.$orig.tel}}"><view style="width:150rpx;text-align:center;line-height:60rpx;border-radius:8rpx;border:2rpx solid #333;" data-phone="{{item.$orig.tel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchTap="__e">拨打电话</view></block></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0b9e7607-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0b9e7607-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="0b9e7607-5" onVueInit="__l"></loading></block></view>