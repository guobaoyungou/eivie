<view class="container"><dd-tab vue-id="0ba8426e-1" itemdata="{{['全部('+countall+')','已上架('+count1+')','未上架('+count0+')']}}" itemst="{{['all','1','0']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="content" style="border-bottom:none;"><view><image src="{{item.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.name}}</text><view class="t2">{{"剩余："+item.$orig.stock}}<text style="color:#a88;padding-left:20rpx;">{{"已售："+item.$orig.sales}}</text></view><view class="t3"><text class="x1">{{"￥"+item.$orig.sell_price}}</text><text class="x2">{{"￥"+item.$orig.market_price}}</text></view></view></view><view class="op"><block a:if="{{!item.$orig.status||item.$orig.status==0}}"><text class="flex1" style="color:red;">未上架</text></block><block a:else><text class="flex1" style="color:green;">已上架</text></block><block a:if="{{!item.$orig.ischecked}}"><text class="flex1" style="color:orange;">待审核</text></block><block a:if="{{bottomButShow}}"><block><block a:if="{{!item.$orig.status||item.$orig.status==0}}"><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-st="1" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" onTap="__e">上架</view></block><block a:else><view class="btn1" style="{{'background:'+(item.m1)+';'}}" data-st="0" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" onTap="__e">下架</view></block><view class="btn2" data-url="{{'edit?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">编辑</view><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除</view></block></block><block a:else><block><view data-event-opts="{{[['tap',[['couponAddChange',['$0'],[[['datalist','',index]]]]]]]}}" class="btn1" style="{{'background:'+($root.m2)+';'}}" onTap="__e">添加</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0ba8426e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0ba8426e-3" onVueInit="__l"></nodata></block></view>