<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">菜品名称<text style="color:red;">*</text></view><view class="f2"><input type="text" name="name" placeholder="请填写菜品名称" placeholder-style="color:#888" value="{{info.name}}"/></view></view><view class="form-item"><view class="f1">菜品分类<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{cids.length>0}}"><text>{{cnames}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><block a:if="{{show_area_list}}"><view class="form-item"><view class="f1">出餐区域<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeArealistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{area_name}}"><text>{{area_name}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">菜品主图<text style="color:red;">*</text></view><view class="f2"><view class="layui-imgbox" a:for="{{pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view><view class="form-item flex-col"><view class="f1">菜品图片</view><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view></view><view class="form-box"><view class="form-item flex-col"><view class="f1">设置规格</view><view class="flex-col"><view class="ggtitle"><view class="t1">规格分组</view><view class="t2">规格名称</view></view><view class="ggcontent" a:for="{{guigedata}}" a:for-item="gg" a:for-index="index" a:key="index"><view class="t1" data-index="{{index}}" data-title="{{gg.title}}" data-event-opts="{{[['tap',[['delgggroupname',['$event']]]]]}}" onTap="__e">{{gg.title}}<image class="edit" src="{{pre_url+'/static/img/edit2.png'}}"></image></view><view class="t2"><view class="ggname" data-index="{{index}}" data-index2="{{index2}}" data-title="{{ggitem.title}}" data-k="{{ggitem.k}}" data-event-opts="{{[['tap',[['delggname',['$event']]]]]}}" onTap="__e" a:for="{{gg.items}}" a:for-item="ggitem" a:for-index="index2" a:key="index2">{{ggitem.title}}<image class="close" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="ggnameadd" data-index="{{index}}" data-event-opts="{{[['tap',[['addggname',['$event']]]]]}}" onTap="__e">+</view></view></view><view class="ggcontent"><view data-event-opts="{{[['tap',[['addgggroupname',['$event']]]]]}}" class="ggadd" onTap="__e">添加分组</view></view></view></view></view><view class="form-box" a:for="{{gglist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">规格</view><view class="f2" style="font-weight:bold;">{{item.name}}</view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">市场价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="market_price" name="{{'market_price['+index+']'}}" placeholder="请填写市场价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.market_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">成本价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="cost_price" name="{{'cost_price['+index+']'}}" placeholder="请填写成本价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.cost_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">销售价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="sell_price" name="{{'sell_price['+index+']'}}" placeholder="请填写销售价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.sell_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">每日库存</view><view class="f2"><input type="text" data-index="{{index}}" data-field="stock_daily" name="{{'stock_daily['+index+']'}}" placeholder="请填写每日库存" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.stock_daily}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">总库存</view><view class="f2"><input type="text" data-index="{{index}}" data-field="stock" name="{{'stock['+index+']'}}" placeholder="请填写库存" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.stock}}" onInput="__e"/></view></view><view class="form-item"><view class="f1">规格图片</view><view class="f2" style="flex-wrap:wrap;margin-top:20rpx;margin-bottom:20rpx;"><block a:if="{{item.pic!=''}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-event-opts="{{[['tap',[['removeimg2',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item.pic}}" data-url="{{item.pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['uploadimg2',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><view class="form-box"><view class="form-item"><view class="f1">销量</view><view class="f2"><input type="text" name="sales" placeholder="请填写销量" placeholder-style="color:#888" value="{{info.sales}}"/></view><input type="text" hidden="true" name="oldsales" value="{{info.id?info.sales:'0'}}"/></view><view class="form-item"><view class="f1">每人限购</view><view class="f2"><input type="text" name="limit_per" placeholder="0表示不限购" placeholder-style="color:#888" value="{{info.limit_per}}"/></view></view><view class="form-item"><view class="f1">序号</view><view class="f2"><input type="text" name="sort" placeholder="用于排序,越大越靠前" placeholder-style="color:#888" value="{{info.sort}}"/></view></view></view><block a:if="{{product_showset==1}}"><view class="form-box"><view class="form-item flex-col"><view class="f1">显示条件</view><view class="f2" style="line-height:30px;"><checkbox-group class="radio-group" name="showtj"><label><checkbox value="-1" checked="{{$root.m0?true:false}}"></checkbox>所有人</label><label><checkbox value="-2" checked="{{$root.m1?true:false}}"></checkbox>未登录用户</label><label><checkbox value="0" checked="{{$root.m2?true:false}}"></checkbox>关注用户</label><label a:for="{{$root.l0}}" a:for-item="item" a:for-index="__i0__" a:key="id"><checkbox value="{{''+item.$orig.id}}" checked="{{item.m3?true:false}}"></checkbox>{{''+item.$orig.name}}</label></checkbox-group></view></view></view></block><view class="form-box"><view class="form-item"><view>状态<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="status" data-event-opts="{{[['change',[['bindStatusChange',['$event']]]]]}}" onChange="__e"><label><radio value="1" checked="{{info.status==1?true:false}}"></radio>上架</label><label><radio value="0" checked="{{!info||info.status==0?true:false}}"></radio>下架</label><label><radio value="2" checked="{{info.status==2?true:false}}"></radio>上架时间</label><label><radio value="3" checked="{{info.status==3?true:false}}"></radio>上架周期</label></radio-group></view></view><block a:if="{{info.status==2}}"><view class="form-item flex-col"><view class="f1">上架时间</view><view class="f2" style="line-height:30px;"><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time1}}</view></picker><picker mode="time" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" onChange="__e"><view class="picker" style="padding-left:10rpx;">{{start_time2}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">到</view><picker mode="date" value="{{end_time1}}" data-event-opts="{{[['change',[['bindEndTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{end_time1}}</view></picker><picker mode="time" value="{{end_time2}}" data-event-opts="{{[['change',[['bindEndTime2Change',['$event']]]]]}}" onChange="__e"><view class="picker" style="padding-left:10rpx;">{{end_time2}}</view></picker></view></view></block><block a:if="{{info.status==3}}"><view class="form-item flex-col"><view class="f1">上架周期</view><view class="f2" style="line-height:30px;"><picker mode="time" value="{{start_hours}}" data-event-opts="{{[['change',[['bindStartHoursChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_hours}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">到</view><picker mode="time" value="{{end_hours}}" data-event-opts="{{[['change',[['bindEndHoursChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{end_hours}}</view></picker></view></view></block></view><view class="form-box"><view class="form-item flex-col"><text>菜品详情</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" onTap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" onTap="__e">+图片</view></view><view><block a:for="{{pagecontent}}" a:for-item="setData" a:for-index="index" a:key="index"><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" onTap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" onTap="__e">下移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" onTap="__e">删除</view></view><view class="detailbox"><block a:if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'5134e984-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-notice></block></block><block a:if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'5134e984-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-banner></block></block><block a:if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'5134e984-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-search></block></block><block a:if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'5134e984-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-text></block></block><block a:if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'5134e984-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-title></block></block><block a:if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'5134e984-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-dhlist></block></block><block a:if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'5134e984-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-line></block></block><block a:if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'5134e984-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-blank></block></block><block a:if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'5134e984-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-menu></block></block><block a:if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'5134e984-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-map></block></block><block a:if="{{setData.temp=='cube'}}"><bloc