<view class="container"><block a:if="{{isload}}"><block><view class="search-container"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="search-text" placeholder="输入关键词或餐桌号码" placeholder-style="color:#aaa;font-size:24rpx" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}</view></block></view></view><view class="table-box"><view class="{{((((('table-item')+' '+'bg-green')+' '+((item.status==2)?'bg-orange':''))+' '+((item.status==3)?'bg-blue':''))+' '+((item.status==-1)?'bg-gray':''))}}" data-id="{{item.id}}" data-tablename="{{item.name}}" data-event-opts="{{[['tap',[['selectTable',['$event']]]]]}}" onTap="__e" a:for="{{contentList}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="color-fff line40">{{"座位："+item.seat}}</view><block a:if="{{item.status==0}}"><view class="color-fff">空闲</view></block><block a:if="{{item.status==2}}"><view class="color-fff">用餐</view></block><block a:if="{{item.status==3}}"><view class="color-fff">清台</view></block><block a:if="{{item.status==-1}}"><view class="color-fff">禁用</view></block></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="1eaa64e0-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="1eaa64e0-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>