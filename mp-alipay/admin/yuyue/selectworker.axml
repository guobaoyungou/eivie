<view class="container"><block a:if="{{isload}}"><block><view class="content flex" data-id="{{item.$orig.id}}" data-index="{{index}}" data-yystatus="{{item.$orig.yystatus}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="btitle"><view class="radio" style="{{(sindex==index?'background:'+item.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><view class="f1"><view class="headimg"><image src="{{item.$orig.headimg}}"></image></view><view class="text1"><text class="t1">{{item.$orig.realname+''}}</text><block a:if="{{item.$orig.typename}}"><text class="t2">{{item.$orig.typename}}</text></block><view class="tags"><block a:if="{{item.$orig.citys}}"><text class="t3">{{item.$orig.citys}}</text></block><block a:if="{{item.$orig.age}}"><text class="t3">{{''+item.$orig.age+"岁"}}</text></block><text class="t3">{{"评分"+item.$orig.comment_score}}</text></view><view class="f3"><text class="juli">距离<text class="t4">{{item.$orig.juli}}</text>{{item.$orig.juli_unit}}</text><image class="tel" src="{{pre_url+'/static/img/tel2.png'}}" data-url="{{'tel::'+item.$orig.tel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"></image></view></view></view></view><block a:if="{{fwname}}"><view class="bottom"><view data-event-opts="{{[['tap',[['confirm',['$event']]]]]}}" class="btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" onTap="__e">确定指派<block a:if="{{fwname}}"><text>{{fwname}}</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="dadd149c-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="dadd149c-2" onVueInit="__l"></nomore></block><view style="height:140rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="dadd149c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="dadd149c-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="dadd149c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>