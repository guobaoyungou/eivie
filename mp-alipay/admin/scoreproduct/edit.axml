>请选择商品分类</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l3}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m6?'background:'+item.m7+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:for="{{item.l2}}" a:for-item="item2" a:for-index="index2" a:key="id"><view class="clist-item" style="padding-left:80rpx;" data-id="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><block a:if="{{item.$orig.child.length-1==index2}}"><view class="flex1">{{"└ "+item2.$orig.name}}</view></block><block a:else><view class="flex1">{{"├ "+item2.$orig.name}}</view></block><view class="radio" style="{{(item2.m8?'background:'+item2.m9+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:for="{{item2.l1}}" a:for-item="item3" a:for-index="index3" a:key="id"><view class="clist-item" style="padding-left:160rpx;" data-id="{{item3.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><block a:if="{{item2.$orig.child.length-1==index3}}"><view class="flex1">{{"└ "+item3.$orig.name}}</view></block><block a:else><view class="flex1">{{"├ "+item3.$orig.name}}</view></block><view class="radio" style="{{(item3.m10?'background:'+item3.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></block></view></view></view></block><uni-popup vue-id="a1d16c84-31" id="dialogInput" type="dialog" ref="__r" data-ref="dialogInput" onVueI