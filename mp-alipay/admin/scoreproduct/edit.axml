<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">商品名称<text style="color:red;">*</text></view><view class="f2"><input type="text" name="name" placeholder="请填写商品名称" placeholder-style="color:#888" value="{{info.name}}"/></view></view><view class="form-item"><view class="f1">商品分类<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{cids.length>0}}"><text>{{cnames}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">商品主图<text style="color:red;">*</text></view><view class="f2"><view class="layui-imgbox" a:for="{{pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view><view class="form-item flex-col"><view class="f1">商品图片</view><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view></view><view hidden="{{!(scoreshop_guige)}}" class="form-box"><view class="form-item"><text>多规格</text><view><radio-group class="radio-group" name="guigeset" data-event-opts="{{[['change',[['bindguigesetChange',['$event']]]]]}}" onChange="__e"><label><radio value="0" checked="{{!info||info.guigeset==0?true:false}}"></radio>关闭</label><label><radio value="1" checked="{{info.guigeset==1?true:false}}"></radio>开启</label></radio-group></view></view><view hidden="{{!(info.guigeset==1)}}" class="form-item flex-col"><view class="f1">设置规格</view><view class="flex-col"><view class="ggtitle"><view class="t1">规格分组</view><view class="t2">规格名称</view></view><view class="ggcontent" a:for="{{guigedata}}" a:for-item="gg" a:for-index="index" a:key="index"><view class="t1" data-index="{{index}}" data-title="{{gg.title}}" data-event-opts="{{[['tap',[['delgggroupname',['$event']]]]]}}" onTap="__e">{{gg.title}}<image class="edit" src="{{pre_url+'/static/img/edit2.png'}}"></image></view><view class="t2"><view class="ggname" data-index="{{index}}" data-index2="{{index2}}" data-title="{{ggitem.title}}" data-k="{{ggitem.k}}" data-event-opts="{{[['tap',[['delggname',['$event']]]]]}}" onTap="__e" a:for="{{gg.items}}" a:for-item="ggitem" a:for-index="index2" a:key="index2">{{ggitem.title}}<image class="close" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="ggnameadd" data-index="{{index}}" data-event-opts="{{[['tap',[['addggname',['$event']]]]]}}" onTap="__e">+</view></view></view><view class="ggcontent"><view data-event-opts="{{[['tap',[['addgggroupname',['$event']]]]]}}" class="ggadd" onTap="__e">添加分组</view></view></view></view></view><view class="form-box" a:for="{{gglist}}" a:for-item="item" a:for-index="index" a:key="index"><view hidden="{{!(info.guigeset==1)}}" class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">规格</view><view class="f2" style="font-weight:bold;">{{item.name}}</view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">市场价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="market_price" name="{{'market_price['+index+']'}}" placeholder="请填写市场价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.market_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">成本价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="cost_price" name="{{'cost_price['+index+']'}}" placeholder="请填写成本价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.cost_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">所需金额（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="money_price" name="{{'money_price['+index+']'}}" placeholder="请填写所需金额" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.money_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">{{"所需"+$root.m0+"（个）"}}</view><view class="f2"><input type="text" data-index="{{index}}" data-field="score_price" name="{{'score_price['+index+']'}}" placeholder="{{'请填写所需'+$root.m1}}" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.score_price}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">重量（克）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="weight" name="{{'weight['+index+']'}}" placeholder="请填写重量" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.weight}}" onInput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">库存</view><view class="f2"><input type="text" data-index="{{index}}" data-field="stock" name="{{'stock['+index+']'}}" placeholder="请填写库存" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.stock}}" onInput="__e"/></view></view><view hidden="{{!(info.guigeset==1)}}" class="form-item"><view class="f1">规格图片</view><view class="f2" style="flex-wrap:wrap;margin-top:20rpx;margin-bottom:20rpx;"><block a:if="{{item.pic!=''}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-event-opts="{{[['tap',[['removeimg2',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item.pic}}" data-url="{{item.pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['uploadimg2',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><view class="form-box"><view class="form-item"><view class="f1">配送模板</view><view class="f2"><picker value="{{freightindex}}" range="{{freighttypeArr}}" data-event-opts="{{[['change',[['freighttypeChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{freighttypeArr[freightindex]}}</view></picker><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><block a:if="{{freightindex==1}}"><view class="form-item flex-col"><view class="f1">选择模板</view><view class="f2 flex-col"><view class="freightitem" style="width:100%;" data-index="{{index}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeFrieght',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m2?'background:'+item.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></block><block a:if="{{freightindex==2}}"><view class="form-item flex-col"><view class="f1">发货信息</view><view class="f2 flex-col"><textarea style="height:160rpx;min-height:160rpx;font-size:28rpx;" name="freightdata" placeholder="请输入发货信息" placeholder-style="color:#888;font-size:28rpx" maxlength="-1" value="{{info.freightdata}}"></textarea></view></view></block><block a:if="{{freightindex==3}}"><view class="form-item flex-col" style="color:#999;">请在电脑端后台上传卡密信息</view></block></view><view class="form-box"><view class="form-item"><view class="f1">销量</view><view class="f2"><input type="text" name="sales" placeholder="请填写销量" placeholder-style="color:#888" value="{{info.sales}}"/></view><input type="text" hidden="true" name="oldsales" value="{{info.id?info.sales:'0'}}"/></view><view class="form-item"><view class="f1">每人限购</view><view class="f2"><input type="text" name="buymax" placeholder="0表示不限购" placeholder-style="color:#888" value="{{info.buymax}}"/></view></view><view class="form-item"><view class="f1">序号</view><view class="f2"><input type="text" name="sort" placeholder="用于排序,越大越靠前" placeholder-style="color:#888" value="{{info.sort}}"/></view></view></view><view class="form-box"><view class="form-item"><view>状态<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="status" data-event-opts="{{[['change',[['bindStatusChange',['$event']]]]]}}" onChange="__e"><label><radio value="1" checked="{{info.status==1?true:false}}"></radio>上架</label><label><radio value="0" checked="{{!info||info.status==0?true:false}}"></radio>下架</label></radio-group></view></view></view><view class="form-box"><view class="form-item flex-col"><text>商品详情</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" onTap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" onTap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" onTap="__e">+视频</view></view><view><block a:for="{{pagecontent}}" a:for-item="setData" a:for-index="index" a:key="index"><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" onTap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" onTap="__e">下移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" onTap="__e">删除</view></view><view class="detailbox"><block a:if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'a1d16c84-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-notice></block></block><block a:if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'a1d16c84-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-banner></block></block><block a:if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'a1d16c84-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-search></block></block><block a:if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'a1d16c84-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-text></block></block><block a:if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'a1d16c84-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-title></block></block><block a:if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'a1d16c84-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-dhlist></block></block><block a:if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'a1d16c84-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-line></block></block><block a:if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'a1d16c84-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-blank></block></block><block a:if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'a1d16c84-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-menu></block></block><block a:if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'a1d16c84-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-map></block></block><block a:if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'a1d16c84-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cube></block></block><block a:if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'a1d16c84-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-picture></block></block><block a:if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'a1d16c84-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-pictures></block></block><block a:if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'a1d16c84-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-video></block></block><block a:if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'a1d16c84-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}" onVueInit="__l"></dp-shop></block></block><block a:if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'a1d16c84-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-product></block></block><block a:if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'a1d16c84-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-collage></block></block><block a:if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'a1d16c84-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-kanjia></block></block><block a:if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'a1d16c84-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-seckill></block></block><block a:if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'a1d16c84-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-scoreshop></block></block><block a:if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'a1d16c84-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-coupon></block></block><block a:if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'a1d16c84-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-article></block></block><block a:if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'a1d16c84-23-'+index}}" params="{{setData.