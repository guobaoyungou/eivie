<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">ID</view><view class="f2">{{info.id}}</view></view><view class="form-item"><view class="f1">昵称</view><view class="f2">{{info.nickname}}</view></view></view><view class="form-box"><view class="form-item flex-col"><text>详细介绍</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" onTap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" onTap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" onTap="__e">+视频</view></view><view><block a:for="{{pagecontent}}" a:for-item="setData" a:for-index="index" a:key="index"><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" onTap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" onTap="__e">下移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveEdit',['$event']]]]]}}" onTap="__e">编辑</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" onTap="__e">删除</view></view><view class="detailbox"><block a:if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'6752ac7b-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-notice></block></block><block a:if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'6752ac7b-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-banner></block></block><block a:if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'6752ac7b-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-search></block></block><block a:if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'6752ac7b-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" selectable="{{true}}" onVueInit="__l"></dp-text></block></block><block a:if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'6752ac7b-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-title></block></block><block a:if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'6752ac7b-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-dhlist></block></block><block a:if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'6752ac7b-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-line></block></block><block a:if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'6752ac7b-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-blank></block></block><block a:if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'6752ac7b-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-menu></block></block><block a:if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'6752ac7b-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-map></block></block><block a:if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'6752ac7b-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cube></block></block><block a:if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'6752ac7b-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}" preview="{{true}}" onVueInit="__l"></dp-picture></block></block><block a:if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'6752ac7b-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-pictures></block></block><block a:if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'6752ac7b-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-video></block></block><block a:if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'6752ac7b-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}" onVueInit="__l"></dp-shop></block></block><block a:if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'6752ac7b-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-product></block></block><block a:if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'6752ac7b-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-collage></block></block><block a:if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'6752ac7b-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-kanjia></block></block><block a:if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'6752ac7b-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-seckill></block></block><block a:if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'6752ac7b-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-scoreshop></block></block><block a:if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'6752ac7b-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-coupon></block></block><block a:if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'6752ac7b-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-article></block></block><block a:if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'6752ac7b-23-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-business></block></block><block a:if="{{setData.temp=='liveroom'}}"><block><dp-liveroom vue-id="{{'6752ac7b-24-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-liveroom></block></block><block a:if="{{setData.temp=='button'}}"><block><dp-button vue-id="{{'6752ac7b-25-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-button></block></block><block a:if="{{setData.temp=='hotspot'}}"><block><dp-hotspot vue-id="{{'6752ac7b-26-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-hotspot></block></block><block a:if="{{setData.temp=='cover'}}"><block><dp-cover vue-id="{{'6752ac7b-27-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cover></block></block><block a:if="{{setData.temp=='richtext'}}"><block><dp-richtext vue-id="{{'6752ac7b-28-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-richtext></block></block><block a:if="{{setData.temp=='form'}}"><block><dp-form vue-id="{{'6752ac7b-29-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-form></block></block><block a:if="{{setData.temp=='userinfo'}}"><block><dp-userinfo vue-id="{{'6752ac7b-30-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-userinfo></block></block></view></view></block></view></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form><uni-popup vue-id="6752ac7b-31" id="dialogDetailtxt" type="dialog" ref="__r" data-ref="dialogDetailtxt" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请输入文本内容</text></view><view class="uni-dialog-content"><textarea placeholder="请输入文本内容" data-event-opts="{{[['input',[['catcheDetailtxt',['$event']]]]]}}" value="{{edit_index!=-1?pagecontent[edit_index].params.showcontent:''}}" onInput="__e"></textarea></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['dialogDetailtxtConfirm',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-popup-dialog__close" onTap="__e"><label class="uni-popup-dialog__close-icon  _span"></label></view></view></uni-popup></block></block><view style="display:none;">{{test}}</view><block a:if="{{loading}}"><loading vue-id="6752ac7b-32" onVueInit="__l"></loading></block><popmsg vue-id="6752ac7b-33" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="6752ac7b-34" onVueInit="__l"></wxxieyi></view>