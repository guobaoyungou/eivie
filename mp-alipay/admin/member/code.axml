<view class="container"><block a:if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><view class="title">会员消费</view><view class="inputdiv"><input id="code" type="text" name="code" placeholder-style="color:#666;" placeholder="请输入会员码" value="{{code}}"/><block a:if="{{platform!='h5'}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view><button class="btn" form-type="submit">确定</button></form></block></block><popmsg vue-id="1cdfec78-1" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="1cdfec78-2" onVueInit="__l"></loading></block><wxxieyi vue-id="1cdfec78-3" onVueInit="__l"></wxxieyi></view>