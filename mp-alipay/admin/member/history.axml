<view class="container"><block a:if="{{isload}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{(item.$orig.type=='shop'?'/pages/':'/activity/')+item.$orig.type+'/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><block a:if="{{item.$orig.product&&item.$orig.product.pic}}"><image src="{{item.$orig.product.pic}}" mode="widthFix"></image></block></view><block a:if="{{item.$orig.type=='scoreshop'}}"><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+(item.m0)+';'}}">{{item.$orig.product.score_price+item.m1}}</text><text class="t2">{{"市场价￥"+item.$orig.product.sell_price}}</text></view><view class="p3"><block a:if="{{item.$orig.product.sales>0}}"><text class="t1">已兑换<text style="font-size:24rpx;color:#f40;padding:0 2rpx;">{{item.$orig.product.sales}}</text>件</text></block><block a:else><block a:if="{{item.$orig.product.sellpoint}}"><text class="t2">{{item.$orig.product.sellpoint}}</text></block></block></view></view></block><block a:else><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+(item.m2)+';'}}"><text style="font-size:22rpx;">￥</text>{{item.$orig.product.sell_price}}</text><block a:if="{{item.$orig.product.market_price*1>item.$orig.product.sell_price*1}}"><text class="t2">{{"￥"+item.$orig.product.market_price}}</text></block></view><view class="p3"><block a:if="{{item.$orig.product.sales>0}}"><text class="t1">已售<text style="font-size:24rpx;color:#f40;padding:0 2rpx;">{{item.$orig.product.sales}}</text>件</text></block><block a:else><block a:if="{{item.$orig.product.sellpoint}}"><text class="t2">{{item.$orig.product.sellpoint}}</text></block></block></view></view></block></view><view class="foot"><text class="flex1">{{"浏览时间："+item.$orig.createtime}}</text></view></view></block></block><block a:if="{{nomore}}"><nomore vue-id="8d48fee2-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="8d48fee2-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="8d48fee2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="8d48fee2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="8d48fee2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>