<view><block a:if="{{isload}}"><block><view class="orderinfo"><view class="item"><text class="t1">ID</text><text class="t2">{{member.id}}</text></view><view class="item"><text class="t1">头像</text><view class="t2"><image style="width:80rpx;height:80rpx;" src="{{member.headimg}}"></image></view></view><view class="item"><text class="t1">昵称</text><text class="t2">{{member.nickname}}</text></view><view class="item"><text class="t1">地区</text><text class="t2">{{(member.province?member.province:'')+(member.city?member.city:'')}}</text></view><view class="item"><text class="t1">加入时间</text><text class="t2">{{member.createtime}}</text></view><view class="item"><text class="t1">姓名</text><text class="t2">{{member.realname?member.realname:''}}</text></view><view class="item"><text class="t1">电话</text><text class="t2">{{member.tel?member.tel:''}}</text></view><view class="item"><text class="t1">{{$root.m0}}</text><text class="t2">{{member.money}}</text></view><view class="item"><text class="t1">{{$root.m1}}</text><text class="t2">{{member.score}}</text></view><block a:if="{{member.showxianjin}}"><view class="item"><text class="t1">{{$root.m2}}</text><text class="t2">{{member.xianjin}}</text></view></block><view class="item"><text class="t1">等级</text><text class="t2">{{member.levelname}}</text></view><block a:if="{{member.remark}}"><view class="item"><text class="t1">备注</text><text class="t2">{{member.remark}}</text></view></block><block a:if="{{member.mendian_member_levelup_fenhong}}"><view class="item"><text class="t1">门店</text><text class="t2">{{member.mdname?member.mdname:'无'}}</text></view></block><block a:if="{{ordershow}}"><view class="item" style="justify-content:space-between;"><text class="t1" style="color:#007aff;">商城订单</text><view class="flex" data-url="{{'/admin/order/shoporder?mid='+member.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{member.ordercount+''}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;margin-top:2rpx;"></text></view></view></block></view><view style="width:100%;height:120rpx;"></view><block a:if="{{$root.m3}}"><view class="bottom"><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['recharge',['$event']]]]]}}" onTap="__e">充值</view><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['consume',['$event']]]]]}}" onTap="__e">消费</view><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['addscore',['$event']]]]]}}" onTap="__e">{{"加"+$root.m4}}</view><block a:if="{{member.showxianjin}}"><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['xianjinrecharge',['$event']]]]]}}" onTap="__e">{{"充值"+$root.m5}}</view></block><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['changelv',['$event']]]]]}}" onTap="__e">修改等级</view><view class="btn" data-id="{{member.id}}" data-event-opts="{{[['tap',[['remark',['$event']]]]]}}" onTap="__e">备注</view><view class="btn" data-url="{{'/admin/member/history?id='+member.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">足迹</view><block a:if="{{member.showrichinfo}}"><view class="btn" data-url="{{'richinfo?id='+member.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">介绍</view></block></view></block><uni-popup vue-id="531c2454-1" id="rechargeDialog" type="dialog" ref="__r" data-ref="rechargeDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('531c2454-2')+','+('531c2454-1')}}" mode="input" title="充值" value="" placeholder="请输入充值金额" data-event-opts="{{[['^confirm',[['rechargeConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="531c2454-3" id="consumeDialog" type="dialog" ref="__r" data-ref="consumeDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('531c2454-4')+','+('531c2454-3')}}" mode="input" title="消费" value="" placeholder="请输入消费金额" data-event-opts="{{[['^confirm',[['consumeConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="531c2454-5" id="addscoreDialog" type="dialog" ref="__r" data-ref="addscoreDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('531c2454-6')+','+('531c2454-5')}}" mode="input" title="{{'加'+$root.m6}}" value="" placeholder="{{'请输入增加'+$root.m7+'数'}}" data-event-opts="{{[['^confirm',[['addscoreConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="531c2454-7" id="xianjinrechargeDialog" type="dialog" ref="__r" data-ref="xianjinrechargeDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('531c2454-8')+','+('531c2454-7')}}" mode="input" title="充值" value="" placeholder="请输入充值金额" data-event-opts="{{[['^confirm',[['xianjinrechargeConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="531c2454-9" id="remarkDialog" type="dialog" ref="__r" data-ref="remarkDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('531c2454-10')+','+('531c2454-9')}}" mode="input" title="设置备注" value="" placeholder="请输入备注" data-event-opts="{{[['^confirm',[['remarkConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="531c2454-11" id="dialogChangelv" type="dialog" ref="__r" data-ref="dialogChangelv" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请选择等级</text></view><view class="uni-dialog-content"><picker style="width:100%;font-size:28rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;" value="{{index2}}" range="{{levelList2}}" data-event-opts="{{[['change',[['levelChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{levelList2[index2]}}</view></picker></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogChangelvClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmChangelv',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup></block></block><popmsg vue-id="531c2454-12" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="531c2454-13" onVueInit="__l"></loading></block></view>