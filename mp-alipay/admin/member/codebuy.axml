<view><block a:if="{{isload}}"><block><view class="orderinfo"><view class="item"><text class="t1">ID</text><text class="t2">{{member.id}}</text></view><view class="item"><text class="t1">头像</text><view class="t2"><image style="width:80rpx;height:80rpx;" src="{{member.headimg}}"></image></view></view><view class="item"><text class="t1">昵称</text><text class="t2">{{member.nickname}}</text></view><view class="item"><text class="t1">加入时间</text><text class="t2">{{member.createtime}}</text></view><view class="item"><text class="t1">{{$root.m0}}</text><text class="t2">{{member.money}}</text></view><view class="item"><text class="t1">{{$root.m1}}</text><text class="t2">{{member.score}}</text></view><view class="item"><text class="t1">等级</text><text class="t2">{{member.levelname}}</text></view></view><view style="width:100%;height:60rpx;"></view><button data-event-opts="{{[['tap',[['openDeductDialog',[1]]]]]}}" class="btn" onTap="__e">{{$root.m2+"消费"}}</button><block a:if="{{deductmoney}}"><button data-event-opts="{{[['tap',[['openDeductDialog',[2]]]]]}}" class="btn" onTap="__e">{{$root.m3+"消费"}}</button></block><uni-popup vue-id="6832beca-1" id="deductDialog" type="dialog" ref="__r" data-ref="deductDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('6832beca-2')+','+('6832beca-1')}}" mode="input" title="{{deducttypename}}" value="" placeholder="{{'请输入'+deducttypename+'数'}}" data-event-opts="{{[['^confirm',[['deductConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><popmsg vue-id="6832beca-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="6832beca-4" onVueInit="__l"></loading></block></view>