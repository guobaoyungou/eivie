<view class="container"><block a:if="{{isload}}"><block><view class="orderinfo"><view class="item"><text class="t1">提交人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view><view class="item"><text class="t1">标题</text><text class="t2">{{detail.title}}</text></view><view class="item" a:for="{{formcontent}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t1">{{item.val1}}</text><block a:if="{{item.key=='upload'}}"><view class="t2"><image style="width:50px;" src="{{detail['form'+index]}}" mode="widthFix" data-url="{{detail['form'+index]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><block a:if="{{item.key=='upload_file'}}"><view class="t2" style="overflow:hidden;white-space:pre-wrap;word-wrap:break-word;color:#4786BC;">{{''+detail['form'+index]+''}}</view></block><block a:else><block a:if="{{item.key=='upload_video'}}"><view class="t2"><video style="width:80%;height:300rpx;margin-top:20rpx;" src="{{detail['form'+index]}}"></video></view></block><block a:else><block a:if="{{item.key=='upload_pics'}}"><view class="t2"><block a:for="{{detail['form'+index]}}" a:for-item="item2" a:for-index="index2" a:key="index2"><image style="width:50px;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></view></block><block a:else><text class="t2">{{detail['form'+index]}}</text></block></block></block></block></view><view class="item"><text class="t1">提交时间</text><text class="t2">{{detail.createtime}}</text></view><view class="item"><text class="t1">审核状态</text><block a:if="{{detail.status==0&&(!detail.payorderid||detail.paystatus==1)}}"><text class="t2" style="color:#88e;">待确认</text></block><block a:if="{{detail.status==0&&detail.payorderid&&detail.paystatus==0}}"><text class="t2" style="color:red;">待支付</text></block><block a:if="{{detail.status==1}}"><text class="t2" style="color:green;">已确认</text></block><block a:if="{{detail.status==2}}"><text class="t2" style="color:red;">已驳回</text></block></view><block a:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block><block a:if="{{form.payset==1}}"><block><block a:if="{{detail.yx_order_discount_rand&&detail.discount_rand_money>0}}"><view class="item"><text class="t1">随机立减</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"-￥"+detail.discount_rand_money}}</text></view></block><view class="item"><text class="t1">付款金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype}}</text></view><view class="item"><text class="t1">付款状态</text><block a:if="{{detail.paystatus==1&&detail.isrefund==0}}"><text class="t2" style="color:green;">已付款</text></block><block a:if="{{detail.paystatus==1&&detail.isrefund==1}}"><text class="t2" style="color:red;">已退款</text></block><block a:if="{{detail.paystatus==0}}"><text class="t2" style="color:red;">未付款</text></block></view><block a:if="{{detail.paystatus>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block></block></block></view><view style="width:100%;height:160rpx;"></view><view class="bottom notabbarbot"><view data-event-opts="{{[['tap',[['copyForm',['$event']]]]]}}" class="btn2" onTap="__e">复制</view><block a:if="{{detail.status==0}}"><view class="btn2" data-st="{{1}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" onTap="__e">确认</view></block><block a:if="{{detail.status==0}}"><view class="btn2" data-st="{{2}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setst2',['$event']]]]]}}" onTap="__e">驳回</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" onTap="__e">删除</view></view><uni-popup vue-id="c4065f8c-1" id="dialogSetst2" type="dialog" ref="__r" data-ref="dialogSetst2" onVueInit="__l"><uni-popup-dialog vue-id="{{('c4065f8c-2')+','+('c4065f8c-1')}}" mode="input" title="驳回原因" value="{{detail.reason}}" placeholder="请输入驳回原因" data-event-opts="{{[['^confirm',[['setst2confirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="c4065f8c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="c4065f8c-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="c4065f8c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>