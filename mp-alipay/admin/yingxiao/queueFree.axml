<view class="container"><block a:if="{{isload}}"><block><view style="position:fixed;width:100%;top:0;z-index:100;"><dd-tab vue-id="0ecd3718-1" itemdata="{{['排队中','已完成']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.$orig.statusLabel}}</text></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item.$orig.bname}}</text></view><view class="detail"><text class="t1">{{$root.m0+"信息："+item.$orig.nickname+"(ID:"+item.$orig.mid+")"}}</text></view><view class="detail"><text class="t1">{{$root.m1+"手机号："+item.$orig.tel}}</text></view><view class="detail">消费金额：<text class="t1" style="{{('color:'+$root.m2)}}">{{item.$orig.ordermoney}}</text></view><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m3)}}">{{item.$orig.money}}</text></view><view class="detail">{{''+$root.m4+"："}}<text class="t1" style="{{('color:'+$root.m5)}}">{{item.$orig.money_give}}</text></view><block a:if="{{item.$orig.queue_no}}"><view class="detail">当前排名：<text class="t1" style="{{('color:'+item.m6)}}">{{item.$orig.queue_noLabel}}</text></view></block><view class="detail"><text class="t1">{{"排队时间："+item.$orig.createtimeFormat}}</text></view><view class="bottom"><block a:if="{{item.$orig.status==0&&set.edit_money_status==1}}"><view class="btn2" style="{{('background:'+item.m7+';border:0')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['editmoney',['$event']]]]]}}" onTap="__e">更改排队金额</view></block><block a:if="{{item.$orig.status==0&&item.$orig.show_changeno}}"><view class="btn2" style="{{('background:'+item.m8+';border:0')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeno',['$event']]]]]}}" onTap="__e">更改排队号</view></block><block a:if="{{item.$orig.status==0}}"><view class="btn" style="{{('background:linear-gradient(90deg,'+item.m9+' 0%,rgba('+item.m10+',0.8) 100%)')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['queueQuit',['$event']]]]]}}" onTap="__e">退出</view></block></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0ecd3718-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0ecd3718-3" onVueInit="__l"></nodata></block><uni-popup vue-id="0ecd3718-4" id="changenoDialog" type="dialog" ref="__r" data-ref="changenoDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('0ecd3718-5')+','+('0ecd3718-4')}}" mode="input" title="更改排队号" value="" placeholder="请输入排队号" data-event-opts="{{[['^confirm',[['changenoConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="0ecd3718-6" id="editmoneyDialog" type="dialog" ref="__r" data-ref="editmoneyDialog" onVueInit="__l"><uni-popup-dialog vue-id="{{('0ecd3718-7')+','+('0ecd3718-6')}}" mode="input" title="更改排队金额" value="" placeholder="请输入排队金额" data-event-opts="{{[['^confirm',[['editmoneyConfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="0ecd3718-8" onVueInit="__l"></loading></block><dp-tabbar vue-id="0ecd3718-9" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0ecd3718-10" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>