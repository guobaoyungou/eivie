<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchChange',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view><block a:if="{{showsearch}}"><image class="close" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideSearch',['$event']]]]]}}" onTap="__e"></image></block></view><block a:if="{{yearlist.length>0&&!showsearch}}"><view class="content"><view class="yearitem" a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="index"><view class="label" data-index="{{index}}" data-event-opts="{{[['tap',[['yearToggle',['$event']]]]]}}" onTap="__e"><block a:if="{{item.$orig.isshow}}"><image src="{{pre_url+'/static/img/location/down-dark.png'}}"></image></block><block a:if="{{!item.$orig.isshow}}"><image src="{{pre_url+'/static/img/location/right-dark.png'}}"></image></block><text class="t1">{{item.$orig.name}}</text></view><block a:for="{{item.l1}}" a:for-item="item1" a:for-index="index1" a:key="index1"><block a:if="{{item.$orig.isshow}}"><view class="monthbox"><view class="{{(('month-title')+' '+(item1.$orig.isshow?'on':''))}}" data-yindex="{{index}}" data-index="{{index1}}" data-event-opts="{{[['tap',[['monthToggle',['$event']]]]]}}" onTap="__e"><block a:if="{{!item1.$orig.isshow}}"><image src="{{pre_url+'/static/img/arrowright.png'}}"></image></block><block a:if="{{item1.$orig.isshow}}"><image style="height:24rpx;width:24rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></block><text>{{item1.$orig.name}}</text></view><block a:if="{{item1.$orig.isshow}}"><view class="listitem"><scroll-view class="classify-box" scroll-y="true" data-yindex="{{index}}" data-index="{{index1}}" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="item" a:for="{{item1.l0}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="f1"><image class="t1" src="{{item2.$orig.headimg}}"></image><text class="t2">{{item2.$orig.nickname}}</text></view><view class="f2"><text class="t1" style="color:#000;">{{item2.$orig.title}}</text><text class="t2">{{item2.m1}}</text><text class="t3">{{"备注："+item2.$orig.remark}}</text></view></view><block a:if="{{nomore}}"><nomore vue-id="{{'6b135a93-1-'+index+'-'+index1}}" onVueInit="__l"></nomore></block></scroll-view></view></block></view></block></block></view></view></block><block a:if="{{showsearch}}"><view class="searchbox content"><view class="item" a:for="{{$root.l3}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="t1" src="{{item.$orig.headimg}}"></image><text class="t2">{{item.$orig.nickname}}</text></view><view class="f2"><text class="t1" style="color:#000;">{{item.$orig.title}}</text><text class="t2">{{item.m2}}</text><text class="t3">{{"备注："+item.$orig.remark}}</text></view></view><block a:if="{{nomores}}"><nomore vue-id="6b135a93-2" onVueInit="__l"></nomore></block><block a:if="{{nodatas}}"><nomore vue-id="6b135a93-3" onVueInit="__l"></nomore></block></view></block></block></block><block a:if="{{loading}}"><loading vue-id="6b135a93-4" onVueInit="__l"></loading></block><popmsg vue-id="6b135a93-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>