<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'message?mid='+item.mid}}" data-mid="{{item.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]],['longTap',[['showdel',['$event']]]]]}}" onTap="__e" onLongTap="__e"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><block a:if="{{item.msgtype=='image'}}"><text class="x2">[图片]</text></block><block a:else><block a:if="{{item.msgtype=='voice'}}"><text class="x2">[语音]</text></block><block a:else><block a:if="{{item.msgtype=='video'}}"><text class="x2">[小视频]</text></block><block a:else><block a:if="{{item.msgtype=='music'}}"><text class="x2">[音乐]</text></block><block a:else><block a:if="{{item.msgtype=='news'}}"><text class="x2">[图文]</text></block><block a:else><block a:if="{{item.msgtype=='link'}}"><text class="x2">[链接]</text></block><block a:else><block a:if="{{item.msgtype=='miniprogram'}}"><text class="x2">[小程序]</text></block><block a:else><block a:if="{{item.msgtype=='location'}}"><text class="x2">[地理位置]</text></block><block a:else><text class="x2">{{item.content}}</text></block></block></block></block></block></block></block></block><text class="x3">{{item.showtime}}</text></view></view><block a:if="{{item.noreadcount>0}}"><view class="unread">{{item.noreadcount}}</view></block></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="45a888e2-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="45a888e2-2" onVueInit="__l"></nodata></block><view class="tabbar"><view class="tabbar-bot"></view><view class="tabbar-bar" style="background-color:#ffffff;"><block a:if="{{auth_data.member}}"><view class="tabbar-item" data-url="../member/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/member.png?v=1'}}"></image></view><view class="tabbar-text">{{$root.m1}}</view></view></block><block a:if="{{auth_data.zixun}}"><view class="tabbar-item" data-url="../kefu/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/zixun2.png?v=1'}}"></image></view><view class="tabbar-text active">咨询</view></view></block><block a:if="{{auth_data.finance}}"><view class="tabbar-item" data-url="../finance/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/finance.png?v=1'}}"></image></view><view class="tabbar-text">财务</view></view></block><view class="tabbar-item" data-url="../index/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/my.png?v=1'}}"></image></view><view class="tabbar-text">我的</view></view></view></view><popmsg vue-id="45a888e2-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></block></block><block a:if="{{loading}}"><loading vue-id="45a888e2-4" onVueInit="__l"></loading></block></view>