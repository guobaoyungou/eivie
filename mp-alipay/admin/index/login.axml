<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="title">管理员登录</view><view class="loginform"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-tel.png'}}"></image><input class="input" type="text" placeholder="请输入登录账号" placeholder-style="font-size:30rpx;color:#B2B5BE" name="username" value="{{username}}" data-event-opts="{{[['input',[['__set_model',['','username','$event',[]]]]]]}}" onInput="__e"/></view><block a:if="{{logintype==1&&(smslogin==0||smslogin==1)}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-pwd.png'}}"></image><input class="input" type="text" placeholder="请输入密码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="password" value="" password="{{true}}"/></view></block><block a:if="{{logintype==2||smslogin==2}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="请输入短信验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="sms_code" value=""/><button class="mini-btn" style="{{'color:'+(smsdjs?'#999':$root.m0)+';'}}" type="default" size="mini" disabled="{{!!smsdjs}}" data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" onTap="__e">{{''+(smsdjs||'获取验证码')+''}}</button></view></block><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="请输入验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="captcha" value=""/><image style="width:240rpx;height:80rpx;" src="{{pre_url+'/?s=/ApiIndex/captcha&aid='+aid+'&session_id='+session_id+'&t='+randt}}" data-event-opts="{{[['tap',[['regetcaptcha',['$event']]]]]}}" onTap="__e"></image></view><block a:if="{{forgetpwd}}"><view style="height:50rpx;"><text style="color:#B2B5BE;float:right;padding:20rpx 0 20rpx 20rpx;" data-url="/adminExt/set/forgetPwd" data-opentype="redirect" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">忘记密码</text></view></block><button class="form-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" form-type="submit">登录</button><block a:if="{{smslogin==1}}"><view data-event-opts="{{[['tap',[['switchLoginType',['$event']]]]]}}" class="switch-login-type" style="{{'color:'+($root.m3)+';'}}" onTap="__e">{{''+(logintype==1?'短信登录':'密码登录')+''}}</view></block></view></form></block></block><block a:if="{{loading}}"><loading vue-id="35e7330e-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="35e7330e-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="35e7330e-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>