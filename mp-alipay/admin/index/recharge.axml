<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{data.money}}</view></view><view class="content2"><view class="item2"><view class="f1">充值金额(元)</view></view><block a:if="{{caninput==1}}"><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="请输入充值金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" onInput="__e"/></view></view></block></block></view><view class="op"><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m2)+';'}}" onTap="__e">去支付</view></view></block></block><block a:if="{{loading}}"><loading vue-id="1fef42ec-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="1fef42ec-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1fef42ec-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>