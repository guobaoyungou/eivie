<view><block a:if="{{isload}}"><block><view class="contentdata"><view class="list"><block a:if="{{uinfo.tmpl_orderconfirm_show==1}}"><view><view class="item" style="border-top:0;"><view class="f2">订单提交通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_orderconfirm==1?true:false}}" data-type="tmpl_orderconfirm" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_orderpay_show==1}}"><view><view class="item"><view class="f2">订单支付通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_orderpay==1?true:false}}" data-type="tmpl_orderpay" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_ordershouhuo_show==1}}"><view><view class="item"><view class="f2">订单收货通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_ordershouhuo==1?true:false}}" data-type="tmpl_ordershouhuo" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_ordertui_show==1}}"><view><view class="item"><view class="f2">退款申请通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_ordertui==1?true:false}}" data-type="tmpl_ordertui" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_withdraw_show==1}}"><view><view class="item"><view class="f2">提现申请通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_withdraw==1?true:false}}" data-type="tmpl_withdraw" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_formsub_show==1}}"><view class="item"><view class="f2">表单提交通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_formsub==1?true:false}}" data-type="tmpl_formsub" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></block><block a:if="{{uinfo.tmpl_kehuzixun_show==1}}"><view><view class="item"><view class="f2">用户咨询通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_kehuzixun==1?true:false}}" data-type="tmpl_kehuzixun" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_maidanpay_show==1}}"><view><view class="item"><view class="f2">买单付款通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_maidanpay==1?true:false}}" data-type="tmpl_maidanpay" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_stockwarning_show==1}}"><view><view class="item"><view class="f2">库存不足通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_stockwarning==1?true:false}}" data-type="tmpl_stockwarning" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block><block a:if="{{uinfo.tmpl_hotelbooking_success_show==1}}"><view><view class="item"><view class="f2">客户预定成功通知</view><view class="f3"><switch value="1" checked="{{uinfo.tmpl_hotelbooking_success==1?true:false}}" data-type="tmpl_hotelbooking_success" data-event-opts="{{[['change',[['switchchange',['$event']]]]]}}" onChange="__e"></switch></view></view></view></block></view><block a:if="{{nopctk}}"><view id="mask-rule"><view class="box-rule" style="margin:50% auto;height:480rpx;background-color:#fff;padding:40rpx 0 10rpx 0;"><view class="h2" style="color:#1A1A1A;font-size:43rpx;">未响应</view><view class="con" style="color:unset;height:56%;margin-top:38rpx;"><view class="text" style="padding-top:70rpx;"><view style="font-size:34rpx;">请前往PC管理端检查订阅消息配置</view><view style="margin-top:20rpx;">平台 - 微信小程序 - 订阅消息配置</view></view></view><view style="width:100%;text-align:center;display:flex;justify-content:center;"><view data-event-opts="{{[['tap',[['closenopctk',['$event']]]]]}}" class="zdl" onTap="__e">知道了</view></view></view></view></block><block a:if="{{nomestk}}"><view style="text-align:center;display:flex;justify-content:center;background-color:rgba(0, 0, 0);" id="mask-rule"><view style="color:#FF8E3F;margin-top:130rpx;font-size:40rpx;">您未开启小程序订阅消息通知</view><view data-event-opts="{{[['tap',[['closenomestk',['$event']]]]]}}" class="nomestk_bg" style="{{('background:url('+pre_url+'/static/img/kqxxts.png) no-repeat;background-size:100% 100%;')}}" onTap="__e"></view></view></block></view></block></block><popmsg vue-id="388de9dd-1" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>