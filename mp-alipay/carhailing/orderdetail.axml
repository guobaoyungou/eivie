<view class="container"><block a:if="{{isload}}"><block><view class="ordertop flex" style="{{('background:url('+pre_url+'/static/img/orderbg.png);background-size:100%')}}"><block a:if="{{detail.status==0&&detail.refund_status==0}}"><view class="f1 "><view class="t1">等待买家付款</view><block a:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block a:if="{{detail.status==1&&detail.refund_status==0}}"><view class="f1"><view class="t2">订单已付款</view></view></block><block a:if="{{detail.status==3&&detail.refund_status==0}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block a:if="{{detail.status==4&&detail.refund_status==0}}"><view class="f1"><view class="t1">订单已取消</view></view></block><block a:if="{{detail.refund_status==1}}"><view class="f1"><view class="t1">退款审核中</view></view></block><block a:if="{{detail.refund_status==2}}"><view class="f1"><view class="t1">订单已退款</view></view></block><view class="orderx"><image src="{{pre_url+'/static/img/orderx.png'}}"></image></view></view><view class="orderinfo orderinfotop"><view class="title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.cid=='2'}}"><view class="item"><text class="t1">乘车日期</text><text class="t2">{{detail.yy_date}}</text></view></block><block a:if="{{detail.cid=='1'}}"><view class="item"><text class="t1" style="flex:0.6;">租车时间</text><text class="t2" style="flex:2;">{{detail.zc_start_time+" 至 "+detail.zc_end_time}}</text></view></block><block a:if="{{detail.cid=='3'}}"><view class="item"><text class="t1">包车时间</text><text class="t2">{{detail.yy_date}}</text></view></block><block a:if="{{detail.cid=='1'}}"><view class="item"><text class="t1">租车天数</text><text class="t2">{{"x "+detail.num}}</text></view></block><block a:if="{{detail.cid=='3'}}"><view class="item"><text class="t1">包车数量</text><text class="t2">{{"x "+detail.num}}</text></view></block></view><block a:if="{{detail.formdata.length>0}}"><view class="orderinfo"><view class="item" a:for="{{detail.formdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><text class="t1">{{item[0]}}</text><block a:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></view></block><view class="product"><view class="title">约车信息</view><view class="content"><view data-url="{{'product?id='+detail.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{detail.propic}}"></image></view><view class="detail"><text class="t1">{{detail.proname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.product_price+''}}<block a:if="{{detail.cid=='2'}}"><text>/人</text></block><block a:if="{{detail.cid=='1'||detail.cid=='3'}}"><text>/天</text></block></text></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1">应付金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block a:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block a:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block a:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block a:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block a:if="{{detail.status==2}}"><text class="t2">服务中</text></block><block a:if="{{detail.status==3}}"><text class="t2">已完成</text></block><block a:if="{{detail.status==4}}"><text class="t2">已关闭</text></block><block a:if="{{detail.refundCount}}"><text style="margin-left:8rpx;">{{"有退款("+detail.refundCount+")"}}</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block a:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block a:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.paytypeid}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">派单时间</text><text class="t2">{{detail.send_time}}</text></view></block><block a:if="{{detail.status>1&&detail.addmoney>0}}"><view class="item"><text class="t1">补差价</text><text class="t2 red">{{"￥"+detail.addmoney}}</text></view></block><block a:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">完成时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="title">客户信息</view><view class="item"><text class="t1">姓名</text><text class="t2">{{detail.linkman}}</text></view><view class="item"><text class="t1">手机号</text><text class="t2">{{detail.tel}}</text></view></view><view style="width:100%;height:180rpx;"></view><block a:if="{{desc_status}}"><view class="desc"><checkbox-group data-event-opts="{{[['change',[['isagreeChange',['$event']]]]]}}" style="display:inline-block;" onChange="__e"><checkbox style="transform:scale(0.6);" value="1" checked="{{isagree}}"></checkbox>我已阅读<text data-event-opts="{{[['tap',[['showdescClick',['$event']]]]]}}" style="color:#3388FF;" onTap="__e">《退款说明》</text></checkbox-group></view></block><view class="bottom"><block a:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" onTap="__e">关闭订单</view><block a:if="{{detail.paytypeid!=5}}"><view class="btn1" style="{{'background:'+($root.m3)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去付款</view></block><block a:if="{{detail.paytypeid==5}}"><view class="btn1" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/pages/pay/transfer?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">上传付款凭证</view></block></block></block><block a:if="{{detail.status==1&&detail.totalprice>0}}"><block><block a:if="{{detail.paytypeid!='4'&&detail.refund_status==0||detail.refund_status==3}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['torefund',['$event']]]]]}}" onTap="__e">退款</view></block></block></block></block><block a:if="{{detail.status==2}}"><block><block a:if="{{detail.balance_pay_status==0&&detail.balance_price>0}}"><view class="btn1" style="{{'background:'+($root.m5)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.balance_pay_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">支付尾款</view></block></block></block><block a:if="{{detail.status==3||detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除订单</view></block></block></view><block a:if="{{showdesc}}"><view class="xieyibox"><view class="xieyibox-content"><view style="overflow:scroll;height:100%;"><parse vue-id="276ae20c-1" content="{{sysset.refund_desc}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view><view data-event-opts="{{[['tap',[['canceldescClick',['$event']]]]]}}" style="position:absolute;z-index:9999;bottom:10px;left:7%;margin:0 auto;text-align:center;width:30%;height:60rpx;line-height:60rpx;color:#fff;border-radius:8rpx;background:#bdbdbd;" onTap="__e">取消</view><view data-event-opts="{{[['tap',[['hidedescClick',['$event']]]]]}}" style="{{'position:absolute;z-index:9999;bottom:10px;right:7%;margin:0 auto;text-align:center;width:50%;height:60rpx;line-height:60rpx;color:#fff;border-radius:8rpx;'+('background:'+('linear-gradient(90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';')}}" onTap="__e">已阅读并同意</view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="276ae20c-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="276ae20c-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="276ae20c-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>