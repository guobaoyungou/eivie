<view><block a:if="{{isload}}"><block><scroll-view class="scroll-Y" scroll-top="{{scrollTop}}" scroll-y="true" data-event-opts="{{[['scrollToLower',[['lower',['$event']]]]]}}" onScrollToLower="__e"><block a:if="{{isplay==0}}"><view class="swiper-container"><swiper class="swiper" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{500000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper><block a:if="{{product.pics.length>1}}"><view class="imageCount">{{current+1+"/"+product.pics.length}}</view></block><block a:if="{{product.video}}"><view data-event-opts="{{[['tap',[['payvideo',['$event']]]]]}}" class="provideo" onTap="__e"><image src="{{pre_url+'/static/img/video.png'}}"></image><view class="txt">{{product.video_duration}}</view></view></block></view></block><view class="header"><view class="price_share"><view class="title">{{product.name}}</view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><view class="pricebox flex"><view class="sellpoint"><block a:if="{{product.cid==1}}"><text>租车</text></block><block a:if="{{product.cid==2}}"><text>拼车</text></block><block a:if="{{product.cid==3}}"><text>包车</text></block>{{'费用：￥'+product.sell_price+''}}<block a:if="{{product.cid==2}}"><text>/人</text></block><block a:else><text>/天</text></block></view></view><block a:if="{{product.sellpoint}}"><view class="sellpoint">{{product.sellpoint}}</view></block></view><block a:if="{{product.cid==2}}"><view class="module"><view class="module_num"><view class="module_lable"><view>当前</view><view>预约</view></view><view class="module_view"><block a:for="{{yyorderlist}}" a:for-item="item2" a:for-index="index2"><image src="{{item2.headimg}}"></image></block></view><block a:if="{{product.leftnum>0}}"><view class="module_tag">{{"剩余"+product.leftnum+"个名额"}}</view></block><block a:else><view class="module_tag module_end">满员</view></block></view></view></block><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">预定须知</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><dp vue-id="f4d58088-1" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view><view style="width:100%;height:140rpx;"></view><block a:if="{{desc_status}}"><view class="desc"><checkbox-group data-event-opts="{{[['change',[['isagreeChange',['$event']]]]]}}" style="display:inline-block;" onChange="__e"><checkbox style="transform:scale(0.6);" value="1" checked="{{isagree}}" disabled="true"></checkbox>我已阅读<text data-event-opts="{{[['tap',[['showdescClick',['$event']]]]]}}" style="color:#3388FF;" onTap="__e">{{"《"+(product.cid==1?'租车':product.cid==2?'拼车':product.cid==3?'包车':'')+"说明》"}}</text></checkbox-group></view></block><block a:if="{{product.status==1}}"><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="f1"><view class="item" data-url="{{'prolist?bid='+product.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/shou.png'}}"></image><view class="t1">首页</view></view><block a:if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block a:else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block><view data-event-opts="{{[['tap',[['addfavorite',['$event']]]]]}}" class="item" onTap="__e"><image class="img" src="{{pre_url+'/static/img/shoucang.png'}}"></image><view class="t1">{{isfavorite?'已收藏':'收藏'}}</view></view></view><view class="op"><block a:if="{{product.cid==2}}"><block><block a:if="{{product.yystatus==0&&product.leftnum>0}}"><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+('#aaa')+';'}}">非预约时间</view></block><block a:else><block><block a:if="{{product.leftnum<=0}}"><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+('#aaa')+';'}}">满员</view></block><block a:else><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m0)+';'}}" onTap="__e">立即预约</view></block></block></block></block></block><block a:else><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m1)+';'}}" onTap="__e"><block a:if="{{product.cid==1}}"><text>立即租车</text></block><block a:if="{{product.cid==3}}"><text>立即包车</text></block></view></block></view></view></block></scroll-view><scrolltop vue-id="f4d58088-2" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m2=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m3=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m4!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{showdesc}}"><view class="xieyibox"><view class="xieyibox-content"><view style="overflow:scroll;height:100%;"><parse vue-id="f4d58088-3" content="{{desc}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view><view data-event-opts="{{[['tap',[['hidedescClick',['$event']]]]]}}" style="{{'position:absolute;z-index:9999;bottom:10px;left:0;right:0;margin:0 auto;text-align:center;width:50%;height:60rpx;line-height:60rpx;color:#fff;border-radius:8rpx;'+('background:'+('linear-gradient(90deg,'+$root.m5+' 0%,rgba('+$root.m6+',0.8) 100%)')+';')}}" onTap="__e">已阅读并同意</view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="f4d58088-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="f4d58088-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="f4d58088-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>