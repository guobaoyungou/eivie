<view class="container"><block a:if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的视频" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><block a:if="{{clist.length>0}}"><dd-tab vue-id="8f9fd690-1" itemdata="{{cnamelist}}" itemst="{{cidlist}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block></view><view class="content" style="{{(clist.length>0?'margin-top:190rpx':'margin-top:100rpx')}}"><block a:if="{{sysset.list_type==1}}"><block><view class="item2" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="image" src="{{item.coverimg}}" mode="widthFix"></image></view><view class="f2"><view class="t1">{{item.name}}</view><view class="t2">{{item.description}}</view><view class="t3">{{"播放量 "+item.view_num+''}}<text style="padding:0 20rpx;">·</text>{{'点赞数 '+item.zan_num}}</view><view class="t4"><image class="touxiang" src="{{item.binfo.logo}}"></image>{{item.binfo.name}}</view></view></view></block></block><block a:else><block><view class="item" style="{{(index%2==0?'margin-right:2%':'')}}" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><image class="ff" mode="widthFix" src="{{item.coverimg}}" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image><view class="f2"><view class="t1"><image class="touxiang" src="{{item.binfo.logo}}"></image></view><view class="t2"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_playnum.png'}}"></image>{{item.view_num}}</view><view class="t3"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_likenum.png'}}"></image>{{item.zan_num}}</view></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="8f9fd690-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><view class="item" style="display:block;"><nodata vue-id="8f9fd690-3" onVueInit="__l"></nodata></view></block><block a:if="{{sysset.can_upload==1}}"><view class="{{(('covermy')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" data-url="{{'uploadvideo?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/shortvideo_uploadbtn.png'}}"></image></view></block></block></block><block a:if="{{loading}}"><loading vue-id="8f9fd690-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="8f9fd690-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="8f9fd690-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>