<view class="container"><block a:if="{{isload}}"><block><view class="navbg"></view><view class="nav"><scroll-view scroll-x="true" scroll-left="{{top_bar_scroll}}"><view class="f1"><block a:for="{{navlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(selected==index?'active':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e"><view class="t3">{{item.seckill_date_m}}</view><view class="t1">{{item.showtime}}</view><block a:if="{{item.active==-1}}"><view class="t2">已结束</view></block><block a:if="{{item.active==0}}"><view class="t2">已开抢</view></block><block a:if="{{item.active==1}}"><view class="t2">拼团中</view></block><block a:if="{{item.active==2}}"><view class="t2">即将开始</view></block></view></block></view></scroll-view></view><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><image class="f1" mode="widthFix" src="{{item.$orig.pic}}" data-url="{{'product2?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image><view class="f2"><text class="t1">{{item.$orig.name}}</text><view class="t3"><view class="text1"><text class="x1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.$orig.sell_price}}</text><text class="x2">{{"￥"+item.$orig.market_price}}</text></view><block a:if="{{item.$orig.istatus==1}}"><button class="x3" style="{{'background:'+('linear-gradient(90deg,'+item.m1+' 0%,rgba('+item.m2+',0.8) 100%)')+';'}}" data-url="{{'product2?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">立即抢购</button></block><block a:else><block a:if="{{item.$orig.istatus==-1}}"><button class="x3 xx1" data-url="{{'product2?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去看看</button></block><block a:else><button class="x3" style="{{'background:'+(item.m3)+';'}}" data-url="{{'product2?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">抢先看看</button></block></block></view></view></view><block a:if="{{nodata}}"><view class="item" style="display:block;"><nodata vue-id="e29312e8-1" onVueInit="__l"></nodata></view></block><block a:if="{{nomore}}"><nomore vue-id="e29312e8-2" onVueInit="__l"></nomore></block></view></block></block><block a:if="{{loading}}"><loading vue-id="e29312e8-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="e29312e8-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e29312e8-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>