<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="7f74865c-1" itemdata="{{['全部','待付款','待发货','待收货','已完成','退款']}}" itemst="{{['all','0','1','2','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.$orig.bid!=0&&item.$orig.binfo}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.binfo.name}}</view></block><block a:else><view>{{"订单号："+item.$orig.ordernum}}</view></block><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type!=1}}"><text class="st1">待发货</text></block><block a:if="{{item.$orig.status==1&&item.$orig.freight_type==1}}"><text class="st1">待提货</text></block><block a:if="{{item.$orig.status==2}}"><text class="st2">待收货</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item.$orig.propic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.proname}}</text><view class="t3"><text class="x1 flex1"><block a:if="{{showprice_dollar&&item.$orig.usd_productprice}}"><text>{{"$"+item.$orig.usd_productprice+''}}</text></block>{{'￥'+item.$orig.sell_price+''}}</text><text class="x2">{{"×"+item.$orig.num}}</text></view></view></view><view class="bottom"><text>{{"共计"+item.$orig.num+'件商品 实付:'}}<block a:if="{{showprice_dollar&&item.$orig.usd_real_price}}"><text>{{"$"+item.$orig.usd_real_price+''}}</text></block>{{'￥'+item.$orig.real_price}}</text><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><block a:if="{{item.g0}}"><block><view class="btn2" data-url="{{'/pagesExt/order/invoice?type=tuangou&orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">发票</view></block></block><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">详情</view><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去付款</view></block></block><block a:if="{{item.$orig.status==1}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.real_price}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block></block></block><block a:if="{{item.$orig.status==2}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.real_price}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block><block a:if="{{item.$orig.freight_type!=3&&item.$orig.freight_type!=4}}"><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+item.$orig.express_com+'&express_no='+item.$orig.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看物流</view></block><view class="btn-wrapper"><view class="btn1" style="{{'background:'+(item.m1)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" catchTap="__e">确认收货</view><block a:if="{{collect_reward_set&&collect_reward_set.prompt&&item.$orig.is_collect_reward}}"><view class="tips-container" style="{{'background:'+('rgba('+item.m2+', 0.7)')+';'+('color:'+(collect_reward_set.fontcolor||'#fff')+';')}}"><text class="tips-text">{{collect_reward_set.prompt}}</text><view data-event-opts="{{[['tap',[['closeTips',[index]]]]]}}" class="close-btn" catchTap="__e">×</view><view class="arrow-up" style="{{'border-bottom:'+('12rpx solid rgba('+item.m3+', 0.7)')+';'}}"></view></view></block></view></block></block><block a:if="{{item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchTap="__e">删除订单</view></block></block></view></view></block></view><uni-popup vue-id="7f74865c-2" type="center" ref="__r" data-ref="popupReward" onVueInit="__l"><view class="popup-reward-content"><view class="popup-reward-price flex"><view class="price-num-text popup-color-text"><text>恭喜你获得</text><text>{{collect_reward}}</text></view><view data-event-opts="{{[['tap',[['popupRewardClose',['$event']]]]]}}" class="popup-reward-confirm" onTap="__e">确认</view></view><image src="{{pre_url+'/static/img/ordercollect/rewardbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupRewardClose',['$event']]]]]}}" class="popupMiandan-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="7f74865c-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="7f74865c-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="7f74865c-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="7f74865c-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7f74865c-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>