<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'complete?rid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="content flex"><view class="detail"><text class="t1">{{item.title}}</text><text class="t2">{{item.date}}</text></view><view class="score"><text class="t3">{{item.score}}</text><text class="t4">分</text></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0767f2eb-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0767f2eb-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="0767f2eb-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0767f2eb-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0767f2eb-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>