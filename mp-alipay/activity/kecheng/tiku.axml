<view><block a:if="{{isload}}"><block><view class="wrap"><view class="top flex"><block a:if="{{tkdata.type==1&&tkdata.rightcount==1}}"><view class="f1">单选题</view></block><block a:if="{{tkdata.type==1&&tkdata.rightcount==2}}"><view class="f1">多选题</view></block><block a:if="{{tkdata.type==2}}"><view class="f1">填空题</view></block><view class="f2">{{"倒计时："+djs}}</view><view class="f3">{{hasnum+"/"+nums}}</view></view><view class="question"><view class="title">{{''+hasnum+"."+tkdata.title+''}}</view><block a:if="{{tkdata.type==1&&tkdata.rightcount==1}}"><block><view class="option_group"><view class="{{('option flex '+(index==currentindex?'on':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" onTap="__e" a:for="{{tkdata.option}}" a:for-item="item" a:for-index="index" a:key="index">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item}}</view></view></view></block></block><block a:if="{{tkdata.type==1&&tkdata.rightcount>1}}"><block><view class="option_group"><view class="{{('option flex '+(item.g0!=-1?'on':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item.$orig}}</view></view></view></block></block><block a:if="{{tkdata.type==2}}"><block><view class="option_group"><view class="uni-textarea"><textarea placeholder-style="color:#222" placeholder="答:" data-event-opts="{{[['blur',[['bindTextAreaBlur',['$event']]]]]}}" value="{{right_option}}" onBlur="__e"></textarea></view></view></block></block></view></view><view class="bottom flex"><block a:if="{{hasnum==1}}"><block><button class="upbut flex-x-center flex-y-center hui">上一题</button></block></block><block a:if="{{hasnum>1}}"><block><button class="upbut flex-x-center flex-y-center" style="{{'background:'+($root.m0)+';'}}" data-dttype="up" data-event-opts="{{[['tap',[['prevquestion',['$event']]]]]}}" onTap="__e">上一题</button></block></block><block a:if="{{nums==hasnum}}"><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m1)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" onTap="__e">交卷</button></block><block a:else><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m2)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['nextquestion',['$event']]]]]}}" onTap="__e">下一题</button></block></view></block></block><block a:if="{{loading}}"><loading vue-id="3d8adaaa-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="3d8adaaa-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="3d8adaaa-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>