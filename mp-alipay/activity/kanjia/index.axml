<view class="container"><block a:if="{{isload}}"><block><view class="banner"><image src="{{pic}}" mode="widthFix"></image></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="t1" a:for="{{item.joinlist}}" a:for-item="join" a:for-index="index2" a:key="index2"><image src="{{join.headimg}}"></image></view><block a:if="{{item.saleing>7}}"><view class="t1"><image src="{{pre_url+'/static/img/moreuser.png'}}"></image></view></block><view class="t2">{{item.saleing+"人正在参加"}}</view></view><view class="p3"><view class="t1"><text class="x1"><text style="font-size:22rpx;">最低￥</text>{{item.min_price}}</text><text class="x2">{{"￥"+item.sell_price}}</text></view><button class="t2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" onTap="__e">去砍价</button></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="5e78262d-1" textcolor="#faa" linecolor="#f66" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="5e78262d-2" onVueInit="__l"></nodata></block><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的订单</button></block></block><block a:if="{{loading}}"><loading vue-id="5e78262d-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5e78262d-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5e78262d-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>