<view class="container"><view class="comment"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="t1" src="{{item.headimg}}"></image><view class="t2">{{item.nickname}}</view><view class="flex1"></view><view class="t3"><image class="img" src="{{'/static/img/star'+(item.score>item2?'2':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2" a:key="index2"></image></view></view><view style="color:#777;font-size:22rpx;">{{item.createtime}}</view><view class="f2"><text class="t1">{{item.content}}</text><view class="t2"><block a:if="{{item.content_pic!=''}}"><block><block a:for="{{item.content_pic}}" a:for-item="itemp" a:for-index="index" a:key="index"><view data-url="{{itemp}}" data-urls="{{item.content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></view><text class="t3">{{"规格："+item.ggname}}</text></view><block a:if="{{item.reply_content}}"><view class="f3"><view class="arrow"></view><view class="t1">{{"商家回复："+item.reply_content}}</view></view></block></view></view><block a:if="{{nomore}}"><nomore vue-id="5eb8f5d3-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="5eb8f5d3-2" text="暂无评价~" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="5eb8f5d3-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5eb8f5d3-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5eb8f5d3-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>