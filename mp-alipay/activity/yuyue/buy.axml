<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" onSubmit="__e"><block a:if="{{!protype}}"><block><block a:if="{{sindex==1||sindex==3}}"><view class="address-add"><view class="linkitem"><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view><view class="linkitem"><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view></view></block><block a:else><view class="address-add flex-y-center" data-url="{{'/pagesB/address/'+(address.id?'address':'addressadd')+'?fromPage=buy&type=1'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><image class="img" src="/static/img/address.png"></image></view><block a:if="{{address.id}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block a:if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block a:else><view class="f2 flex1">请选择您的地点</view></block><image class="f3" src="/static/img/arrowright.png"></image></view></block></block></block><block a:if="{{sindex==3}}"><view class="address-add flex-y-center" data-url="{{'/pagesB/yuyue/selectbusiness?prodata='+prodata}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><image class="img" src="/static/img/address.png"></image></view><block a:if="{{fwbusiness.id}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{fwbusiness.name}}</view></view></block><block a:else><view class="f2 flex1">请选择要去的商家</view></block><image class="f3" src="/static/img/arrowright.png"></image></view></block><view class="buydata" a:for="{{$root.l1}}" a:for-item="buydata" a:for-index="index" a:key="index"><block a:if="{{sindex==1}}"><view class="business-info"><view class="linkitem"><text class="f1">店铺名称：</text><text class="f2">{{buydata.$orig.business.name}}</text></view><view class="linkitem"><text class="f1">店铺地址：</text><text class="f2"><block a:if="{{buydata.$orig.business.province!='北京市'||buydata.$orig.business.province!='上海市'||buydata.$orig.business.province!='重庆市'||buydata.$orig.business.province!='天津市'}}"><text>{{buydata.$orig.business.province}}</text></block>{{''+buydata.$orig.business.city+buydata.$orig.business.district+buydata.$orig.business.address+''}}</text></view></view></block><view class="bcontent"><block a:if="{{protype==0}}"><view class="btitle">服务信息</view></block><block a:if="{{protype==0}}"><view class="product"><view class="item flex" a:for="{{buydata.$orig.prodata}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="img" data-url="{{'product?id='+item.product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><block a:if="{{item.guige.pic}}"><image src="{{item.guige.pic}}"></image></block><block a:else><image src="{{item.product.pic}}"></image></block></view><view class="info flex1"><view class="f1">{{item.product.name}}</view><view class="f2">{{item.guige.name}}</view><view class="f3"><text style="font-weight:bold;">{{"￥"+item.guige.sell_price}}</text><text style="padding-left:20rpx;">{{'× '+item.num}}</text></view></view></view></view></block><view class="freight"><view class="f1">服务方式</view><view class="freight-ul"><block a:for="{{buydata.l0}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="freight-li" style="{{(item.$orig.key==sindex?'color:'+item.m0+';background:rgba('+item.m1+',0.2)':'')}}" data-index="{{item.$orig.key}}" data-event-opts="{{[['tap',[['selectFwtype',['$event']]]]]}}" onTap="__e">{{item.$orig.name+''}}</view></block></view></view><block a:if="{{protype==1}}"><view class="price"><view class="f1">选择服务规格</view><view class="f2" data-btntype="2" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">{{ggname?ggname:'请选择服务规格'}}</view></view></block><block a:if="{{protype==1}}"><view class="price"><view class="f1">购买数量</view><view class="f2">{{num+danwei}}</view></view></block><view class="price"><view class="f1">预约时间</view><block a:if="{{isdate}}"><view data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{yydate}}"><text>{{yydate}}</text></block><block a:else><text style="color:#999;">请选择预约时间</text></block></view></block><block a:else><view class="f2">{{''+yydate+" \n              "+(yydates_num>0?yydates_num+'个时间段':'')+''}}</view></block></view><block a:if="{{buydata.$orig.fwpeople==1||buydata.$orig.fwpeople==3}}"><view class="price"><view class="f1">服务人员</view><block a:if="{{!workerid||workerid==0}}"><view class="f2" data-url="{{'selectpeople?prodata='+prodata+'&yydate='+yydate+'&sindex='+sindex+'&linkman='+linkman+'&tel='+tel}}" data-event-opts="{{[['tap',[['gotopeople',['$event']]]]]}}" onTap="__e">{{''+(!buydata.m2?buydata.$orig.fw.realname:'请选择人员')}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block a:else><view class="f2">{{''+(!buydata.m3?buydata.$orig.fw.realname:'请选择人员')+''}}</view></block></view></block></view><block a:if="{{protype&&protype==1}}"><view class="bcontent2"><block a:if="{{sindex==2}}"><view><view class="price"><text class="f1">车辆位置</text><view data-event-opts="{{[['tap',[['locationSelect',['$event']]]]]}}" class="f2" style="overflow:hidden;line-height:60rpx;" onTap="__e"><text>{{carlocat_name}}</text><image style="width:30rpx;height:30rpx;float:right;margin-top:16rpx;" src="/static/img/arrowright.png"></image></view></view><view class="price"><text class="f1">停靠位置</text><view class="f2" style="overflow:hidden;line-height:60rpx;padding-left:20rpx;"><input class="input" type="text" name="carlocat_stop" placeholder="请输入车辆停靠位置" placeholder-style="font-size:28rpx" data-event-opts="{{[['input',[['inputCarlocatStop',['$event']]]]]}}" value="{{carlocat_stop}}" onInput="__e"/></view></view></view></block><view class="price"><text class="f1">车辆信息</text><view class="f2" style="overflow:hidden;line-height:60rpx;" data-url="/pagesA/yuyuecar/car" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{carinfor?carinfor.infor:''}}</text><image style="width:30rpx;height:30rpx;float:right;margin-top:16rpx;" src="/static/img/arrowright.png"></image></view></view></view></block><view class="bcontent2"><block a:if="{{buydata.$orig.leveldk_money>0}}"><view class="price"><text class="f1">{{buydata.m4+"折扣("+userinfo.discount+"折)"}}</text><text class="f2">{{"-¥"+buydata.$orig.leveldk_money}}</text></view></block><block a:if="{{yyset.iscoupon==1}}"><view class="price"><view class="f1">{{$root.m5}}</view><block a:if="{{buydata.$orig.couponCount>0}}"><view class="f2" data-bid="{{buydata.$orig.bid}}" data-event-opts="{{[['tap',[['showCouponList',['$event']]]]]}}" onTap="__e"><text style="{{'color:#fff;padding:4rpx 16rpx;font-weight:normal;border-radius:8rpx;font-size:24rpx;'+('background:'+(buydata.m6)+';')}}">{{buydata.$orig.couponrid!=0?buydata.$orig.couponList[buydata.$orig.couponkey].couponname:buydata.$orig.couponCount+'张可用'}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block a:else><text class="f2" style="color:#999;">{{"无可用"+buydata.m7}}</text></block></view></block><view class="price"><text class="f1">服务价格</text><text class="f2">{{"¥"+buydata.$orig.product_price}}</text></view><block a:if="{{buydata.$orig.prodata[0].product.balance>0}}"><view class="price"><text class="f1">应付定金</text><text class="f2">{{"¥"+buydata.$orig.sell_price}}</text></view></block><block a:if="{{buydata.$orig.coupontype==3}}"><view class="price"><text class="f1">计次卡</text><text class="f2" style="color:red;">{{"-"+buydata.$orig.product_price}}</text></view></block><view style="display:none;">{{test}}</view><view class="form-item" a:for="{{buydata.$orig.formdata}}" a:for-item="item" a:for-index="idx" a:key="id"><view class="label">{{item.val1}}<block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+buydata.$orig.bid+'_'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+buydata.$orig.bid+'_'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+buydata.$orig.bid+'_'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form'+buydata.$orig.bid+'_'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+buydata.$orig.bid+'_'+idx}}" value="" range="{{item.val2}}" data-bid="{{buydata.$orig.bid}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{buydata.$orig.editorFormdata[idx]||buydata.$orig.editorFormdata[idx]===0}}"><view>{{''+item.val2[buydata.$orig.editorFormdata[idx]]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+buydata.$orig.bid+'_'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-bid="{{buydata.$orig.bid}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{buydata.$orig.editorFormdata[idx]}}"><view>{{buydata.$orig.editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+buydata.$orig.bid+'_'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-bid="{{buydata.$orig.bid}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{buydata.$orig.editorFormdata[idx]}}"><view>{{buydata.$orig.editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+buydata.$orig.bid+'_'+idx}}" value="{{buydata.$orig.editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{buydata.$orig.editorFormdata[idx]}}"><view class="form-imgbox"><view class="layui-imgbox-close" style="z-index:2;" data-bid="{{buydata.$orig.bid}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="/static/img/ico-del.png"></image></view><view class="form-imgbox-img"><image class="image" src="{{buydata.$orig.editorFormdata[idx]}}" data-url="{{buydata.$orig.editorFormdata[idx]}}" mode="aspectFit" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-bid="{{buydata.$orig.bid}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view></block></block></view></view></view><block a:if="{{userinfo.canscoredk&&userinfo.score2money>0&&(userinfo.scoremaxtype==0||userinfo.scoremaxtype==1&&userinfo.scoredkmaxmoney>0)}}"><view class="scoredk"><checkbox-group data-event-opts="{{[['change',[['scoredk',['$event']]]]]}}" class="flex" style="width:100%;" onChange="__e"><view class="f1"><view>{{userinfo.score*1+" "+$root.m8+'可抵扣'}}<text style="color:#e94745;">{{userinfo.scoredk_money*1}}</text>元</view><block a:if="{{userinfo.scoremaxtype==0&&userinfo.scoredkmaxpercent>0&&userinfo.scoredkmaxpercent<100}}"><view style="font-size:22rpx;color:#999;">{{'最多可抵扣订单金额的'+userinfo.scoredkmaxpercent+"%"}}</view></block><block a:else><block a:if="{{userinfo.scoremaxtype==1}}"><view style="font-size:22rpx;color:#999;">{{'最多可抵扣'+userinfo.scoredkmaxmoney+"元"}}</view></block></block></view><view class="f2">{{"使用"+$root.m9+'抵扣'}}<checkbox style="margin-left:6px;transform:scale(.8);" value="1"></checkbox></view></checkbox-group></view></block><view style="width:100%;height:182rpx;"></view><view class="footer flex"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+alltotalprice}}</text></view><block a:if="{{issubmit}}"><button class="op" style="background:#999;">确认提交</button></block><block a:else><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m10+' 0%,rgba('+$root.m11+',0.8) 100%)')+';'}}" form-type="submit">确认提交</button></block></view></form><block a:if="{{couponvisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+$root.m12}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="/static/img/close.png" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><couponlist vue-id="4aca786a-1" couponlist="{{allbuydata[bid].couponList}}" choosecoupon="{{true}}" selectedrid="{{allbuydata[bid].couponrid}}" bid="{{bid}}" data-event-opts="{{[['^chooseCoupon',[['chooseCoupon']]]]}}" onChooseCoupon="__e" onVueInit="__l"></couponlist></view></view></view></block></block></block><block a:if="{{timeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidetimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择时间</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="/static/img/close.png" data-event-opts="{{[['tap',[['hidetimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="order-tab"><view class="order-tab2"><block a:for="{{datelist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e"><view class="datetext">{{item.weeks}}</view><view class="datetext2">{{item.date}}</view><view class="after" style="{{'background:'+($root.m13)+';'}}"></view></view></block></view></view><view class="flex daydate"><block a:for="{{timelist}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="{{('date '+(timeindex==index2&&item.status==1?'on':'')+(item.status==0?'hui':''))}}" data-index2="{{index2}}" data-status="{{item.status}}" data-time="{{item.timeint}}" data-event-opts="{{[['tap',[['switchDateTab',['$event']]]]]}}" onTap="__e">{{''+item.time}}</view></block></view><view class="op"><button data-event-opts="{{[['tap',[['selectDate',['$event']]]]]}}" class="tobuy on" style="{{'background-color:'+($root.m14)+';'}}" onTap="__e">确 定</button></view></view></view></block><block a:if="{{buydialogShow}}"><yybuydialog vue-id="4aca786a-2" proid="{{proid}}" btntype="{{btntype}}" menuindex="{{menuindex}}" isfuwu="{{isfuwu}}" data-event-opts="{{[['^currgg',[['currgg']]],['^buydialogChange',[['buydialogChange']]],['^addcart',[['addcart']]],['^tobuy',[['tobuy']]]]}}" onCurrgg="__e" onBuydialogChange="__e" onAddcart="__e" onTobuy="__e" onVueInit="__l"></yybuydialog></block><block a:if="{{loading}}"><loading vue-id="4aca786a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="4aca786a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4aca786a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>