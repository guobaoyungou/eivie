<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="top flex"><view class="headimg"><image src="{{data.headimg}}"></image></view><view class="f1"><view class="t1">{{data.realname}}</view><view class="t2">{{data.jineng}}</view><view class="t3"><text class="t11"><text class="bold">{{data.totalnum}}</text>次服务</text><text class="t11"><text class="bold">{{data.comment_score}}</text>评价</text></view></view></view><block a:if="{{data.desc}}"><view class="desc">{{''+data.desc+''}}</view></block><view class="list"><view class="tab"><view class="{{('item '+(curTopIndex==0?'on':''))}}" data-index="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{"服务 "+data.count}}<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><view class="{{('item '+(curTopIndex==1?'on':''))}}" data-index="{{1}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{"评价 "+data.comment_score}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view><block a:if="{{data.showdesc}}"><view class="{{('item '+(curTopIndex==2?'on':''))}}" data-index="{{2}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">个人资料<view class="after" style="{{'background:'+($root.m2)+';'}}"></view></view></block></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{curTopIndex==0}}"><view class="content2 flex" data-id="{{item.id}}"><view class="f1" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="headimg"><image src="{{item.pic}}"></image></view><view class="text1" style="margin-bottom:16rpx;"><text class="t1">{{item.name+''}}</text><view class="text2">{{"已售 "+item.sales}}</view><view class="text3"><text class="t4">￥<text class="price">{{''+item.sell_price}}</text></text></view></view></view><view><view class="yuyue" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">预约</view></view></view></block></block><block a:if="{{curTopIndex==1}}"><view class="comment"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="t1" src="{{item.headimg}}"></image><view class="t2">{{item.nickname}}</view><view class="flex1"></view><view class="t3"><image class="img" src="{{'/static/img/star'+(item.score>item2?'2':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2" a:key="index2"></image></view></view><view style="color:#777;font-size:22rpx;">{{item.createtime}}</view><view class="f2"><text class="t1">{{item.content}}</text><view class="t2"><block a:if="{{item.content_pic!=''}}"><block><block a:for="{{item.content_pic}}" a:for-item="itemp" a:for-index="index" a:key="index"><view data-url="{{itemp}}" data-urls="{{item.content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></view></view><block a:if="{{item.reply_content}}"><view class="f3"><view class="arrow"></view><view class="t1">{{"商家回复："+item.reply_content}}</view></view></block></view></view></block><block a:if="{{curTopIndex==2}}"><view><view class="plugdesc"><view class="item"><label class="t1">服务类目：</label>{{data.typename}}</view><view class="item"><label class="t1">服务城市：</label>{{data.citys}}</view><view class="item"><label class="t1">服务公里数：</label>{{data.fuwu_juli+"km"}}</view><view class="item"><label class="t1">性别：</label>{{data.sex}}</view><view class="item"><label class="t1">年龄：</label>{{data.age}}</view><view class="item"><label class="t1">联系信息：</label>{{data.tel}}</view></view></view></block></view></view><block a:if="{{nomore}}"><nomore vue-id="ad10c1b6-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="ad10c1b6-2" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="ad10c1b6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="ad10c1b6-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="ad10c1b6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>