<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item1" style="font-weight:bold;">评价</view><view class="form-item2 flex flex-y-center"><view class="label">您的打分</view><view data-event-opts="{{[['touchMove',[['handleTouchMove',['$event']]]]]}}" class="i-rate" onTouchMove="__e"><input class="i-rate-hide-input" type="text" name="score" value="{{score}}"/><view class="{{(('i-rate-star')+' '+(index<score?'i-rate-current':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['handleClick',['$event']]]]]}}" onTap="__e" a:for="{{5}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{index<score}}"><image src="/static/img/star2.png"></image></block><block a:else><image src="/static/img/star.png"></image></block></view><view class="i-rate-text"></view></view></view><view class="form-item3 flex-col"><view class="label">您的评价</view><textarea style="height:200rpx;" placeholder="输入您的评价内容" placeholder-style="color:#ccc;" name="content" disabled="{{comment.id?true:false}}" value="{{comment.content}}"></textarea></view><view class="form-item4 flex-col"><view class="label">上传图片</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{content_pic}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{!comment.id}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="content_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="/static/img/ico-del.png"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{!comment.id&&content_pic.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="content_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><block a:if="{{!comment.id}}"><button class="subbtn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">确定</button></block></form></block></block><block a:if="{{loading}}"><loading vue-id="6952e6ce-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="6952e6ce-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6952e6ce-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>