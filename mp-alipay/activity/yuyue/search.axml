<view class="container"><block a:if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="/static/img/search_ico.png"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view><view data-event-opts="{{[['tap',[['searchbtn',['$event']]]]]}}" class="search-btn" onTap="__e"><block a:if="{{!history_show&&productlisttype=='itemlist'}}"><image style="height:36rpx;width:36rpx;" src="/static/img/show-cascades.png"></image></block><block a:if="{{!history_show&&productlisttype=='item2'}}"><image style="height:36rpx;width:36rpx;" src="/static/img/show-list.png"></image></block><block a:if="{{history_show}}"><text>搜索</text></block></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" onTap="__e"><image style="width:36rpx;height:36rpx;" src="/static/img/del.png"></image></view></view><view class="search-history-list"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" onTap="__e" a:for="{{history_list}}" a:for-item="item" a:for-index="index" a:key="index">{{item+''}}</view><block a:if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="/static/img/tanhao.png"></image>暂无记录</view></block></view></view></view><view class="product-container"><block a:if="{{datalist&&datalist.length>0}}"><block><block a:if="{{productlisttype=='item2'}}"><dp-yuyue-item vue-id="1ab4fb30-1" data="{{datalist}}" onVueInit="__l"></dp-yuyue-item></block><block a:if="{{productlisttype=='itemlist'}}"><dp-yuyue-itemlist vue-id="1ab4fb30-2" data="{{datalist}}" onVueInit="__l"></dp-yuyue-itemlist></block></block></block><block a:if="{{nomore}}"><nomore vue-id="1ab4fb30-3" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1ab4fb30-4" text="没有查找到相关商品" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="1ab4fb30-5" onVueInit="__l"></loading></block></view></block></block><block a:if="{{loading}}"><loading vue-id="1ab4fb30-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="1ab4fb30-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1ab4fb30-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>