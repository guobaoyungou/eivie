<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的可提现"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.commission}}</view><view class="f3" data-url="commissionlog?st=0&type=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>佣金明细</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view><view class="flex"><view class="flex1"><view class="data_lable">投资金额(元)</view><view class="data_value">{{userinfo.touzimoney}}</view></view><view class="flex1"><view class="data_lable">待结算(元)</view><view class="data_value">{{userinfo.commissionyj}}</view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="d73ee28c-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="d73ee28c-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d73ee28c-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>