<view class="container"><block a:if="{{isload}}"><block><block a:if="{{level_tab}}"><block><block a:if="{{userlevel&&userlevel.can_agent>=1}}"><dd-tab vue-id="39e8da01-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block></block></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="content"><block a:if="{{userlevel&&userlevel.team_show_down_order}}"><view class="date-search"><view class="flex-bt"><view data-event-opts="{{[['tap',[['setDate',[1]]]]]}}" class="date-btn" style="{{(selectedDateRange==1?'color:#fff;background-color:'+$root.m0:'')}}" onTap="__e">今日</view><view data-event-opts="{{[['tap',[['setDate',[2]]]]]}}" class="date-btn" style="{{(selectedDateRange==2?'color:#fff;background-color:'+$root.m1:'')}}" onTap="__e">近七日</view><view data-event-opts="{{[['tap',[['setDate',[3]]]]]}}" class="date-btn" style="{{(selectedDateRange==3?'color:#fff;background-color:'+$root.m2:'')}}" onTap="__e">近30日</view><view data-event-opts="{{[['tap',[['toSelectDate',['$event']]]]]}}" class="date-btn" style="{{(selectedDateRange==4?'color:#fff;background-color:'+$root.m3:'')}}" onTap="__e">自定义</view></view><block a:if="{{sdate&&edate}}"><view class="show-search-date">{{sdate+" / "+edate}}</view></block></view></block><block a:if="{{userlevel&&userlevel.team_month_data==1}}"><view class="topsearch flex-y-center sx"><text class="t1">日期筛选：</text><view data-event-opts="{{[['tap',[['toCheckDate',['$event']]]]]}}" class="body_data" style="min-width:200rpx;" onTap="__e">{{''+(startDate?startDate:'点击选择日期')+(endDate?' 至 '+endDate:'')+''}}</view><view class="t_date"><block a:if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" onTap="__e">清除</view></block></view></view></block><block a:if="{{team_auth==1&&userlevel&&userlevel.team_month_data==1||!showlevel}}"><view class="topsearch flex-y-center sx"><block a:if="{{!showlevel}}"><text class="t1">等级筛选：</text></block><block a:else><text class="t1">身份筛选：</text></block><view data-event-opts="{{[['tap',[['chooseLevel',['$event']]]]]}}" class="t2" onTap="__e"><block a:if="{{checkLevelname}}"><view class="uni-input">{{checkLevelname}}</view></block><block a:else><view style="font-size:28rpx;color:#686868;">请选择级别</view></block></view></view></block><block a:if="{{userinfo.month_yeji_show}}"><view class="topsearch flex-y-center sx"><text class="t1">月份筛选：</text><view class="t2"><picker range="{{month_item}}" data-event-opts="{{[['change',[['chooseMonth',['$event']]]]]}}" onChange="__e"><block a:if="{{month_item[monthindex]}}"><view class="uni-input">{{month_item[monthindex]}}</view></block><block a:else><view style="font-size:28rpx;color:#686868;">请选择月份</view></block></picker></view></view></block><view class="yejilabel"><block a:if="{{custom&&custom.yeji_with_pronum}}"><block><block a:if="{{userlevel}}"><view class="t1">{{"个人业绩："+(is_end==1?userinfo.yeji_pronum:'计算中')+"，"+$root.m4+"业绩："+(is_end==1?userinfo.team_yeji_pronum:'计算中')}}</view></block></block></block><block a:else><block><block a:if="{{userlevel}}"><view class="t1">{{$root.m5+"业绩："+(is_end==1?userinfo.team_yeji_total:'计算中')+" 元"}}</view></block><block a:if="{{userlevel&&userinfo.miniyeji_show}}"><view class="t1">{{"小市场业绩："+(is_end==1?userinfo.team_miniyeji_total:'计算中')+"  元"}}</view></block><block a:if="{{userlevel&&userinfo.maxyeji_show}}"><view class="t1">{{"大市场业绩："+(is_end==1?userinfo.team_maxyeji_total:'计算中')+"  元"}}</view></block><block a:if="{{userinfo&&userinfo.next_ordermoney_show}}"><view class="t1" style="width:100%;">{{"距升级"+$root.m6+"："+(is_end==1?userinfo.next_up_ordermoney:'计算中')+" 元"}}</view></block><block a:if="{{userlevel&&userinfo.month_yeji_show}}"><view class="t1">{{month_text+"："+(is_end==1?userinfo.now_month_yeji:'计算中')+" 元"}}</view></block><block a:if="{{userlevel&&userlevel.team_show_down_order}}"><view class="t1">{{"总成单量："+userinfo.team_order_count+" 单"}}</view></block><block a:if="{{userlevel&&userlevel.team_show_down_order}}"><view class="t1">{{"总退款单数："+userinfo.team_refund_order+" 单"}}</view></block><block a:if="{{userlevel&&userlevel.team_show_down_order}}"><view class="t1">{{"成交总额："+userinfo.team_order_money+" 元"}}</view></block><block a:if="{{userlevel&&userlevel.team_yeji_zhitui}}"><view class="t1">{{"直推业绩："+(is_end==1?userinfo.team_yeji_zhitui:'计算中')+" 元"}}</view></block><block a:if="{{userlevel&&userlevel.team_yeji_jiantui}}"><view class="t1">{{"间推业绩："+(is_end==1?userinfo.team_yeji_jiantui:'计算中')+" 元"}}</view></block><block a:if="{{userlevel&&userlevel.team_yeji_current_month}}"><view class="t1">{{"当月团队业绩："+(is_end==1?userinfo.team_yeji_current_month:'计算中')+" 元"}}</view></block></block></block></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label flex-bt"><block a:if="{{zt_member_limit!=0&&st==1}}"><text class="t1">{{"直推名额："+zt_member_limit}}</text></block><block a:if="{{userlevel.downorder_list}}"><button class="btn1" style="{{'background-color:'+($root.m7)+';'}}" data-url="/pagesC/my/downshoporder" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">下级订单</button></block></view><block a:if="{{levelup_uesnum&&levelup_uesnum.length>0}}"><view class="levelup-num"><text class="t1">可升级数量</text><view class="flex list"><view class="num" a:for="{{levelup_uesnum}}" a:for-item="item" a:for-index="index">{{item.name+"："+item.num+" 个"}}</view></view></view></block><view class="label"><text class="t1">成员信息</text><text class="t2">{{"来自TA的"+$root.m8}}</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" onTap="__e"><image src="{{item.headimg}}" mode="widthFix"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.id+")"}}</text><block a:if="{{custom&&custom.team_show_visittime}}"><block><text class="x2">{{"加入时间："+item.createtime}}</text><text class="x2">{{"最后访问："+item.last_visittime}}</text></block></block><block a:else><text class="x2">{{item.createtime}}</text></block><text class="x2">{{"等级："+item.levelname}}</text><block a:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block a:if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block><block a:if="{{custom&&custom.yx_gift_pack}}"><block><text class="x3">{{"礼包订单："+item.packcount}}</text><text class="x3">{{"订单金额：￥"+item.totalpackmoney}}</text></block></block><block a:if="{{item.xianxia_sales}}"><text class="x2">{{"出券量："+item.xianxia_sales+"组"}}</text></block><block a:for="{{item.custom_field}}" a:for-item="v" a:for-index="k" a:key="k"><block a:if="{{item.custom_field}}"><block><block a:if="{{v.key=='upload'}}"><view><text class="x2">{{v.field+"："}}</text><image style="max-width:60rpx;height:60rpx;" src="{{v.value}}" mode="widthFix"></image></view></block><block a:else><text class="x2">{{v.field+"："+v.value}}</text></block></block></block></block></view></view><view class="f2"><block a:if="{{userlevel&&userlevel.team_yeji==1}}"><text class="t4">{{$root.m9+"业绩："+item.teamyeji}}</text></block><block a:if="{{userlevel&&userlevel.team_self_yeji==1}}"><text class="t4">{{"个人业绩："+item.selfyeji}}</text></block><block a:if="{{userlevel&&userlevel.team_down_total==1}}"><text class="t4">{{$root.m10+"人数："+item.team_down_total+" 人"}}</text></block><block a:if="{{userlevel&&userlevel.team_score==1}}"><text class="t4">{{$root.m11+"："+item.score}}</text></block><block a:if="{{userlevel&&userlevel.team_view_zhitui_member_num==1}}"><text class="t4">{{$root.m12+"："+item.team_view_zhitui_member_num+"人"}}</text></block><block a:if="{{userlevel&&userlevel.team_show_down_order==1}}"><text class="t4" style="text-decoration:underline;" data-mid="{{item.id}}" data-event-opts="{{[['tap',[['toDown',['$event']]]]]}}" catchTap="__e">{{"成交订单："+item.team_order_count+"(单)"}}</text></block><block a:if="{{userlevel&&userlevel.team_show_down_order==1}}"><text class="t4">{{"成交金额："+item.team_order_money+"(元)"}}</text></block><text class="t1">{{"+"+item.commission}}</text><view class="t3"><block a:if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m13}}</view></block><block a:if="{{userlevel&&userlevel.team_givescore==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givescoreshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m14}}</view></block><block a:if="{{userlevel&&userlevel.team_levelup==1}}"><view class="x1" data-id="{{item.id}}" data-levelid="{{item.levelid}}" data-levelsort="{{item.levelsort}}" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" onTap="__e">升级</view></block><block a:if="{{userlevel&&userlevel.team_shortvideo==1}}"><view class="x1" data-url="{{'/pagesA/shortvideo/looklog?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">短视频记录</view></block><block a:if="{{userlevel&&userlevel.team_callphone==1&&item.tel}}"><view class="x1" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchTap="__e">拨打电话</view></block><block a:if="{{userlevel&&userlevel.team_view_down_to_down==1&&item.team_view_zhitui_member_num>0}}"><view class="x1" data-mid="{{item.id}}" data-event-opts="{{[['tap',[['toDown',['$event']]]]]}}" catchTap="__e">人员</view></block><block a:if="{{custom&&custom.team_member_history}}"><view class="x1" data-url="{{'/pagesExt/my/history?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看足迹</view></block><block a:if="{{userlevel&&userlevel.team_update_member_info==1}}"><view class="x1" data-url="{{'/pagesC/my/saveinfo?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">修改资料</view></block><block a:if="{{item.can_change_pid==1}}"><view data-event-opts="{{[['tap',[['changedown',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="x1" onTap="__e">链动换位</view></block></view></view></view></block></view></block><uni-popup vue-id="39e8da01-2" id="dialogmoneyInput" type="dialog" ref="__r" data-ref="dialogmoneyInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('39e8da01-3')+','+('39e8da01-2')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="39e8da01-4" id="dialogscoreInput" type="dialog" ref="__r" data-ref="dialogscoreInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('39e8da01-5')+','+('39e8da01-4')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><block a:if="{{dialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">升级</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="sheet-item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><text class="item-text flex-item">{{item.$orig.name}}</text><view class="flex1"></view><block a:if="{{item.$orig.id!=tempLevelid&&item.$orig.sort>tempLevelsort}}"><view style="{{'color:'+(item.m15)+';'}}" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['changeLevel',['$event']]]]]}}" onTap="__e">选择</view></block><block a:else><view style="color:#ccc;">选择</view></block></view></view></view></view></block><block a:if="{{levelDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择级别</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-id="0" data-name="全部" data-event-opts="{{[['tap',[['levelRadioChange',['$event']]]]]}}" onTap="__e"><view class="flex1">全部</view><view class="radio" style="{{('')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><view class="pstime-item" data-id="{{item.id}}" data-name="{{item.name}}" data-event-opts="{{[['tap',[['levelRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{allLevel}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.name}}</view><view class="radio" style="{{('')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></view></block><uni-popup vue-id="39e8da01-6" id="dialogChangeDown" type="center" background-color="#fff" ref="__r" data-ref="dialogChangeDown" onVueInit="__l"><view class="popup_centent_view"><view class="popup_title_view-c">链动换位</view><view class="popup_input-view"><view class="options-view flex "><view class="title-text" style="width:30%;">选择会员：</view><view class="flex flex-xy-center num-options">{{''+select_member.nickname+"(ID:"+select_member.id+')'}}</view></view><view class="options-view flex "><view class="title-text" style="width:30%;">换位会员:</view><view class="flex flex-xy-center num-options"><radio-group class="flex" style="flex-wrap:wrap;" name="new_down" data-event-opts="{{[['change',[['olddownchange',['$event']]]]]}}" onChange="__e"><label class="flex-y-center" a:for="{{change_downs}}" a:for-item="item" a:for-index="idx"><radio class="radio" style="transform:scale(0.8);" value="{{item.mid}}"></radio>{{item.nickname+"(ID："+item.mid+')'}}</label></radio-group></view></view></view><view class="popup_but_view"><view data-event-opts="{{[['tap',[['closechangedown']]]]}}" class="poput_options_but" onTap="__e">取消</view><view data-event-opts="{{[['tap',[['tochange']]]]}}" class="poput_options_but success" style="{{'background-color:'+($root.m16)+';'}}" onTap="__e">确认换位</view></view></view></uni-popup></block></block><block a:if="{{nodata}}"><nodata vue-id="39e8da01-7" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="39e8da01-8" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="39e8da01-9" onVueInit="__l"></loading></block><dp-tabbar vue-id="39e8da01-10" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="39e8da01-11" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>