<view class="container"><block a:if="{{isload}}"><block><block a:if="{{is_cashdesk_commission}}"><view class="module_tab"><dd-tab vue-id="0220edf2-1" itemdata="{{['商城订单','收银台订单']}}" itemst="{{['shop','cashdesk']}}" st="{{module}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changemoduletab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view></block><view class="{{((('topfix')+' '+'')+' '+(is_cashdesk_commission?'top90':''))}}"><view class="toplabel"><text class="t1">{{$root.m0+"（"+count+"）"}}</text><text class="t2">{{"预计：+"+commissionyj+"元"}}</text></view><dd-tab vue-id="0220edf2-2" itemdata="{{tabitem}}" itemst="{{tabst}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view class="{{(('mt190')+' '+(is_cashdesk_commission?'mt280':''))}}"></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="item" data-show="{{item.$orig.order_info?1:0}}" data-url="{{'/pagesExt/order/detail?id='+item.$orig.order_info.id+'&fromfenxiao=1'}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1 flex" style="justify-content:flex-start;"><image class="img" src="{{item.$orig.headimg}}"></image><view class="t1"><block a:if="{{item.$orig.nickname}}"><view>{{''+item.$orig.nickname+''}}</view></block><view>{{''+item.$orig.ordernum+"("+item.$orig.dengji+')'}}</view></view><block a:if="{{item.$orig.dannum&&item.$orig.dannum>0}}"><view style="color:#a55;margin-left:30rpx;">{{'第'+item.$orig.dannum+'单'}}</view></block></view><view class="f2"><view class="t1 flex"><view class="x1 flex"><image class="img" src="{{item.$orig.pic}}"></image><view style="margin-left:20rpx;"><view class="x1t" style="line-height:50rpx;">{{item.$orig.name}}</view><view class="x1t">{{'下单时间：'+item.$orig.createtime}}</view></view></view><view>{{"共"+item.$orig.num+"件"}}</view></view><view class="t2 flex"><view>{{"合计金额：￥"+item.$orig.totalprice}}</view><view>{{"预估"+$root.m1+"："}}<text style="color:#ff6600;">{{item.$orig.commission}}</text></view><view><block a:if="{{item.$orig.status==1||item.$orig.status==2}}"><text class="dior-sp6 yfk"><block a:if="{{module=='shop'}}"><text>已付款</text></block><block a:else><text>已完成</text></block></text></block><block a:if="{{item.$orig.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.$orig.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block a:if="{{item.$orig.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view><block a:if="{{item.$orig.order_info}}"><view class="t3 flex"><view data-event-opts="{{[['tap',[['logistics',['$0'],[[['datalist','',index,'order_info']]]]]]]}}" class="btn2" style="{{('border:solid 2rpx '+item.m2+';color:'+item.m3)}}" catchTap="__e">查看物流</view></view></block></view></view></view><uni-popup vue-id="0220edf2-3" id="dialogSelectExpress" type="dialog" ref="__r" data-ref="dialogSelectExpress" onVueInit="__l"><block a:if="{{express_content}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><view class="sendexpress-item" style="display:flex;border-bottom:1px solid #f5f5f5;padding:20rpx 0;" data-url="{{'/pagesExt/order/logistics?express_com='+item.express_com+'&express_no='+item.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{express_content}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.express_com+" - "+item.express_no}}</view><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></uni-popup></block></block></block></block><block a:if="{{nodata}}"><nodata vue-id="0220edf2-4" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="0220edf2-5" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="0220edf2-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="0220edf2-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0220edf2-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>