<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="48bbde85-1" itemdata="{{[$root.m0+'明细','提现记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><block a:if="{{st==0}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.$orig.createtime}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text><block a:if="{{set.commission_service_fee_show&&set.commission_service_fee_show==1}}"><text class="t3">{{"平台服务费："+item.$orig.service_fee}}</text></block><block a:if="{{item.$orig.order}}"><block><text class="t3">{{"订单金额: "+item.$orig.order.totalprice}}</text><block a:if="{{item.$orig.order.member}}"><text class="t3">下单人:<image src="{{item.$orig.order.member.headimg}}"></image>{{item.$orig.order.member.nickname}}</text></block><block a:if="{{item.$orig.order.business}}"><view class="t3"><image src="{{item.$orig.order.business.logo}}"></image>{{item.$orig.order.business.name}}</view></block></block></block><block a:if="{{show_from_member&&item.$orig.frommid>0}}"><view class="x3">{{"来源"+item.m1+"："}}<image src="{{item.$orig.from_headimg}}"></image>{{item.$orig.from_nickname}}</view></block></view><view class="f2"><block a:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block a:else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></block><block a:if="{{st==1}}"><block><view class="item" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money}}</text><text class="t2">{{item.$orig.createtime}}</text><block a:if="{{item.$orig.status==2}}"><text class="t2">{{"驳回原因："+(item.$orig.reason||'无')}}</text></block></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block><block a:if="{{item.$orig.status==4}}"><block><block a:if="{{item.$orig.wx_state=='WAIT_USER_CONFIRM'||item.$orig.wx_state=='TRANSFERING'}}"><view data-event-opts="{{[['tap',[['confirm_shoukuan',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m2)+';'}}" onTap="__e">确认收款</view></block><block a:else><block a:if="{{item.$orig.wx_state=='FAIL'}}"><view class="t1">转账失败</view></block><block a:else><view class="t1">处理中</view></block></block></block></block></view></view></block></block></view></block></block><block a:if="{{nodata}}"><nodata vue-id="48bbde85-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="48bbde85-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="48bbde85-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="48bbde85-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="48bbde85-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>