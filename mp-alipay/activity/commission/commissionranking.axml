<block a:if="{{isload}}"><block><view class="container"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank_notext.png'}}" mode="widthFix"></image><view class="title"><view class="t1">{{sysset.rank_title||'业绩排行榜'}}</view><view class="t2">{{sysset.rank_desc||'历史累积榜单'}}</view></view><view class="top"><view class="t1"><view class="label">我的佣金</view><view class="value">{{commission}}</view></view><view class="t2"><text style="color:#9e9e9e;">累计佣金：</text>{{totalcommission+''}}</view></view><view class="content"><block a:if="{{sysset.rank_type.length>1}}"><view class="tab1"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('t1 '+(item.$orig==ranktype?'on':''))}}" style="{{'color:'+(item.$orig==ranktype?item.m0:'')+';'}}" data-ranktype="{{item.$orig}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" onTap="__e">{{(item.$orig==1?'累计佣金':item.$orig==2?'自购订单金额':'')+''}}<block a:if="{{item.$orig==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m1)}}"></view></block></view></block></view></block><view class="tab"><view class="t1">排名</view><view class="t2">姓名</view><view class="t3">{{ranktype==1?'累计佣金':ranktype==2?'自购订单金额':''}}</view></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" style="{{(index<3?'margin-top:20rpx':'')}}"><block a:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block a:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3" style="{{'color:'+($root.m2)+';'}}">{{''+(ranktype==1?item.sumcommission:ranktype==2?item.sumtotalprice:'')}}</text></view></block></view></view></view><block a:if="{{nodata}}"><nodata vue-id="410c1b5a-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="410c1b5a-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="410c1b5a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="410c1b5a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="410c1b5a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block></block>