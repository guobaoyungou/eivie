<view class="container"><block a:if="{{isload}}"><block><view class="content"><block a:if="{{mendian_member_levelup_fenhong}}"><view class="topsearch flex-y-center sx"><text class="t1">日期筛选：</text><view class="f2 flex" style="line-height:30px;"><picker mode="date" value="{{startDate}}" data-event-opts="{{[['change',[['bindStartDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{startDate}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">至</view><picker mode="date" value="{{endDate}}" data-event-opts="{{[['change',[['bindEndDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{endDate}}</view></picker><view class="t_date"><block a:if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" onTap="__e">清除</view></block></view></view></view></block></view><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text><block a:if="{{item.$orig.copies}}"><text class="t3">{{"份数："+item.$orig.copies}}</text></block><block a:if="{{show_from_member&&item.$orig.frommid>0}}"><view class="x3">{{"来源"+item.m1+"："}}<image src="{{item.$orig.from_headimg}}"></image>{{item.$orig.from_nickname}}</view></block></view><view class="f2"><block a:if="{{item.$orig.commission>0}}"><text class="t1">{{"+"+item.$orig.commission}}</text></block><block a:else><text class="t2">{{item.$orig.commission}}</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="70813d48-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="70813d48-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="70813d48-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="70813d48-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="70813d48-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>