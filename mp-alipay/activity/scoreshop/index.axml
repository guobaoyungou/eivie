<view class="container"><block a:if="{{isload}}"><block><view class="topimg" style="{{'background:'+($root.m0)+';'}}"><image class="img" src="{{bgurl}}"></image></view><view class="topinfo"><view class="flex"><view class="myscore"><text class="t1" style="{{'color:'+($root.m1)+';'}}">{{score}}</text><text class="t2">{{"我的"+$root.m2}}</text></view><view class="scorelog" style="{{'color:'+($root.m3)+';'+('background:'+('rgba('+$root.m4+',0.2)')+';')}}" data-url="/pagesExt/my/scorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{$root.m5+"明细"}}<text class="iconfont iconjiantou"></text></view><view class="orderlog" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">兑换记录<text class="iconfont iconjiantou"></text></view></view><view class="search-container"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="商品搜索..." placeholder-style="font-size:24rpx;color:#C2C2C2" type="text" confirm-type="search" data-event-opts="{{[['confirm',[['search',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view></view><block a:if="{{clist.length>0}}"><block><view class="navbox"><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="nav_li" style="cursor:pointer;" data-url="{{item.url?item.url:'prolist?bid='+bid+'&cid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{item.pic}}"></image><view class="txt">{{item.name}}</view></view></block><view class="nav_li" data-url="{{'prolist?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/all.png'}}"></image><view class="txt">全部</view></view></view></block></block><view id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="itemcontent"><view class="product-pic"><image class="img" src="{{item.$orig.pic}}"></image></view><view class="product-info"><view class="p1">{{item.$orig.name}}</view><view class="p2"><block a:if="{{item.$orig.sell_price>0}}"><block>{{"价值"+item.$orig.sell_price+"元"}}</block></block></view><view class="p3"><view class="t1 flex"><view class="x1" style="{{'color:'+($root.m6)+';'}}"><text style="font-size:13px;"><block a:if="{{item.$orig.score_price>0}}"><block>{{item.$orig.score_price+item.m7}}</block></block><block a:if="{{item.$orig.money_price>0}}"><block><block a:if="{{item.$orig.score_price>0}}"><block>+</block></block>{{item.$orig.money_price+"元"}}</block></block></text></view></view></view></view></view><view class="itembottom"><view class="f1">已兑换<text style="{{'color:'+($root.m8)+';'}}">{{''+item.$orig.sales+''}}</text>件</view><button class="f2" style="{{'background:'+($root.m9)+';'}}">立即兑换</button></view></view></block><block a:if="{{nomore}}"><nomore vue-id="4ae20663-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4ae20663-2" onVueInit="__l"></nodata></block></view></block></block><block a:if="{{loading}}"><loading vue-id="4ae20663-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="4ae20663-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4ae20663-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>