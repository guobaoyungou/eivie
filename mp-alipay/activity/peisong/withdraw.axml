<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+('#06A051')+';'}}"><view class="f1">可提现余额</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.money}}</view><view class="f3" data-url="moneylog?st=2" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>提现记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">提现金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入提现金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><block a:if="{{sysset.withdrawfee>0||sysset.withdrawmin>0}}"><view class="item4"><block a:if="{{sysset.withdrawmin>0}}"><text style="margin-right:10rpx;">{{"最低提现金额"+sysset.withdrawmin+'元'}}</text></block><block a:if="{{sysset.withdrawfee>0}}"><text>{{"提现手续费"+sysset.withdrawfee+'%'}}</text></block></view></block></view><block><view class="withdrawtype"><view class="f1">选择提现方式：</view><view class="f2"><block a:if="{{sysset.withdraw_weixin==1}}"><view class="item" data-paytype="微信钱包" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-weixin.png'}}"></image>微信钱包</view><view class="radio" style="{{(paytype=='微信钱包'?'background:'+$root.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block><block a:if="{{sysset.withdraw_weixincode==1}}"><view class="item2"><view class="pay-item" data-paytype="微信收款码" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-weixin.png'}}"></image>微信收款码</view><view class="radio" style="{{(paytype=='微信收款码'?'background:'+$root.m1+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:if="{{paytype=='微信收款码'}}"><view class="upload-img flex-xy-center"><block a:if="{{wechat_payment_code}}"><image class="upload-img-class" src="{{wechat_payment_code}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['wechat_payment_code']]]]]}}" onTap="__e"></image></block><block a:else><view class="upload-icon-view flex-xy-center" data-key="wechat_payment_code" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block a:if="{{wechat_payment_code}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="close-view" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></block></view></block><block a:if="{{sysset.withdraw_alipaycode==1}}"><view class="item2"><view class="pay-item" data-paytype="支付宝收款码" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝收款码</view><view class="radio" style="{{(paytype=='支付宝收款码'?'background:'+$root.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:if="{{paytype=='支付宝收款码'}}"><view class="upload-img flex-xy-center"><block a:if="{{alipay_payment_code}}"><image class="upload-img-class" src="{{alipay_payment_code}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['alipay_payment_code']]]]]}}" onTap="__e"></image></block><block a:else><view class="upload-icon-view flex-xy-center" data-key="alipay_payment_code" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block a:if="{{alipay_payment_code}}"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="close-view" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></block></view></block><block a:if="{{sysset.withdraw_aliaccount==1}}"><label class="item" data-paytype="支付宝" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝</view><view class="radio" style="{{(paytype=='支付宝'?'background:'+$root.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block a:if="{{sysset.withdraw_bankcard==1}}"><label class="item" data-paytype="银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>银行卡</view><view class="radio" style="{{(paytype=='银行卡'?'background:'+$root.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block></view></view></block><button class="btn" style="{{'background:'+('#06A051')+';'}}" form-type="submit">立即提现</button></form></block></block><block a:if="{{loading}}"><loading vue-id="eb61c8ec-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="eb61c8ec-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="eb61c8ec-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>