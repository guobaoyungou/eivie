<view class="container"><block a:if="{{isload}}"><block><view><view class="search-container"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="search-text" placeholder="关键字搜索" placeholder-style="color:#aaa;font-size:24rpx" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" onConfirm="__e"/></view></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="order-box" data-url="{{'orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.leftminute>0}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image><text class="t1">{{item.leftminute+"分钟内"}}</text>送达</view></block><block a:else><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已超时<text class="t1" style="margin-left:10rpx;">{{-item.leftminute+"分钟"}}</text></view></block><view class="flex1"></view><view class="f2"><text class="t1">{{item.ticheng}}</text>元<block a:if="{{item.tip_fee&&item.tip_fee>0}}"><text>{{'+'+item.tip_fee+'元小费'}}</text></block><block a:if="{{item.up_floor_fee&&item.up_floor_fee>0}}"><text style="margin-left:20rpx;">{{'+'+item.up_floor_fee+'元上楼费'}}</text></block></view></view><view class="content"><block a:if="{{item.type=='deposit_refund_order'}}"><block><view class="f1"><view class="t1"><text class="x1">{{item.juli2}}</text><text class="x2">{{item.juli2_unit}}</text></view><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view><view class="t3"><text class="x1">{{item.juli}}</text><text class="x2">{{item.juli_unit}}</text></view></view><view class="f2"><view class="t1">{{item.orderinfo.address}}</view><view class="t2">{{item.orderinfo.area}}</view><view class="t3">{{item.binfo.name}}</view><view class="t2">{{item.binfo.address}}</view></view></block></block><block a:else><block><view class="f1"><view class="t1"><text class="x1">{{item.juli}}</text><text class="x2">{{item.juli_unit}}</text></view><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view><view class="t3"><text class="x1">{{item.juli2}}</text><text class="x2">{{item.juli2_unit}}</text></view></view><view class="f2"><view class="t1">{{item.binfo.name}}</view><view class="t2">{{item.binfo.address}}</view><view class="t3">{{item.orderinfo.address}}</view><view class="t2">{{item.orderinfo.area}}</view></view></block></block><view class="f3" data-index="{{index}}" data-type="{{item.type}}" data-event-opts="{{[['tap',[['daohang',['$event']]]]]}}" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/ps_daohang.png'}}"></image></view></view><view class="op"><view class="flex1"></view><view class="btn1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['qiangdan',['$event']]]]]}}" catchTap="__e">抢单</view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="3ffd5649-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="3ffd5649-2" onVueInit="__l"></nodata></block></view><view class="tabbar"><view class="tabbar-bot"></view><view class="tabbar-bar" style="background-color:#ffffff;"><view class="tabbar-item" data-url="dating" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/peisong/home2.png'}}"></image></view><view class="tabbar-text active">大厅</view></view><view class="tabbar-item" data-url="orderlist" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/peisong/order.png'}}"></image></view><view class="tabbar-text">订单</view></view><view class="tabbar-item" data-url="orderlist?st=4" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/peisong/orderwc.png'}}"></image></view><view class="tabbar-text">已完成</view></view><view class="tabbar-item" data-url="my" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/peisong/my.png'}}"></image></view><view class="tabbar-text">我的</view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="3ffd5649-3" onVueInit="__l"></loading></block><popmsg vue-id="3ffd5649-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><view style="display:none;">{{timestamp}}</view><wxxieyi vue-id="3ffd5649-5" onVueInit="__l"></wxxieyi></view>