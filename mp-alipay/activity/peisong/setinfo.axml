<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><block a:if="{{sysset.withdraw_weixincode==1}}"><view class="form"><view class="form-item" style="border:0;"><text class="label">微信收款码</text></view><view class="upload-img flex-xy-center"><block a:if="{{wechat_payment_code}}"><image class="upload-img-class" src="{{wechat_payment_code}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['wechat_payment_code']]]]]}}" onTap="__e"></image></block><block a:else><view class="upload-icon-view flex-xy-center" data-key="wechat_payment_code" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block a:if="{{wechat_payment_code}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="close-view" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></view></block><block a:if="{{sysset.withdraw_aliaccount==1||sysset.withdraw_alipaycode==1}}"><view class="form"><block a:if="{{sysset.withdraw_aliaccount==1}}"><view class="form-item"><text class="label">支付宝账号</text><input class="input" type="text" placeholder="请输入支付宝账号" placeholder-style="color:#BBBBBB;font-size:28rpx" name="aliaccount" value="{{userinfo.aliaccount}}"/></view></block><block a:if="{{sysset.withdraw_alipaycode==1}}"><block><view class="form-item" style="border:0;"><text class="label">支付宝收款码</text></view><view class="upload-img flex-xy-center"><block a:if="{{alipay_payment_code}}"><image class="upload-img-class" src="{{alipay_payment_code}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['alipay_payment_code']]]]]}}" onTap="__e"></image></block><block a:else><view class="upload-icon-view flex-xy-center" data-key="alipay_payment_code" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block a:if="{{alipay_payment_code}}"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="close-view" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></block></block></view></block><view class="form"><view class="form-item"><text class="label">开户行</text><picker class="picker" mode="selector" name="bankname" value="0" range="{{banklist}}" data-event-opts="{{[['change',[['bindBanknameChange',['$event']]]]]}}" onChange="__e"><block a:if="{{bankname}}"><view>{{bankname}}</view></block><block a:else><view>请选择开户行</view></block></picker></view><view class="form-item"><text class="label">持卡人姓名</text><input class="input" type="text" placeholder="请输入持卡人姓名" name="bankcarduser" placeholder-style="color:#BBBBBB;font-size:28rpx" value="{{userinfo.bankcarduser}}"/></view><view class="form-item"><text class="label">银行卡号</text><input class="input" type="text" placeholder="请输入银行卡号" name="bankcardnum" placeholder-style="color:#BBBBBB;font-size:28rpx" value="{{userinfo.bankcardnum}}"/></view></view><view class="form"><view class="form-item"><text class="label">短信验证码</text><input class="input" type="text" placeholder="请输入短信验证码" placeholder-style="color:#BBBBBB;font-size:28rpx" name="code" value=""/><view data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" class="code" onTap="__e">{{smsdjs||'获取验证码'}}</view></view></view><button class="set-btn" form-type="submit">保 存</button></form></block></block><block a:if="{{loading}}"><loading vue-id="84568bb8-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="84568bb8-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="84568bb8-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>