.topbg{width:100%;height:248rpx;position:relative;z-index:0}.topbg .image{width:100%;height:100%}.topbox{width:94%;margin:0 3%;margin-top:-140rpx;background:#fff;border-radius:16rpx;padding:24rpx;display:flex;position:relative;z-index:1}.topbox .left{flex-shrink:0;width:240rpx;height:240rpx}.topbox .left image{width:100%;height:100%}.topbox .right{flex:1;padding-left:20rpx;padding-right:20rpx;display:flex;flex-direction:column}.topbox .right .f1{color:#32201b;height:80rpx;line-height:40rpx;font-size:30rpx;font-weight:700;overflow:hidden}.topbox .right .f2{display:flex;margin-top:10rpx}.topbox .right .f2 .t1{display:flex;background:rgba(255,49,67,.2);border-radius:20rpx;padding:0 20rpx;height:40rpx;line-height:40rpx;color:#ff3143;font-size:24rpx}.topbox .right .f3{display:flex;align-items:center;color:#ff3143;margin-top:40rpx}.topbox .right .f3 .t1{font-size:28rpx}.topbox .right .f3 .t2{font-size:40rpx;font-weight:700;flex:1}.topbox .right .f3 .t3{font-size:26rpx;font-weight:700}.teambox{width:94%;margin:0 3%;margin-top:20rpx;background:#fff;border-radius:16rpx;padding:24rpx;display:flex;flex-direction:column}.userlist{width:100%;background:#fff;text-align:center;padding-top:40rpx;margin-top:20rpx}.userlist .item{display:inline-block;width:120rpx;height:120rpx;position:relative}.userlist .item .f1{width:100rpx;height:100rpx;border-radius:50%;border:1px #ffc32a solid}.userlist .item .f2{background:#ffab33;border-radius:100rpx;padding:4rpx 16rpx;border:1px #fff solid;position:absolute;top:0;left:-20rpx;color:#9f7200;font-size:30rpx}.join-text{color:#000;padding:30rpx 0;font-size:36rpx;font-weight:600;background:#fff;text-align:center;width:100%}.join-btn{width:90%;margin:20rpx 5%;background:linear-gradient(90deg,#ff3143,#fe6748);color:#fff;font-size:30rpx;height:80rpx;border-radius:40rpx}.join-btn2{width:90%;margin:20rpx 5%;border:2rpx solid #ff3143;color:#ff3143;font-size:30rpx;height:80rpx;border-radius:40rpx}.buydialog-mask{position:fixed;top:0;left:0;width:100%;background:rgba(0,0,0,.5);bottom:0;z-index:10}.buydialog{position:fixed;width:100%;left:0;bottom:0;background:#fff;z-index:11;border-radius:20rpx 20rpx 0 0}.buydialog .close{position:absolute;top:0;right:0;padding:20rpx;z-index:12}.buydialog .close .image{width:30rpx;height:30rpx}.buydialog .title{width:94%;position:relative;margin:0 3%;padding:20rpx 0;border-bottom:0;height:190rpx}.buydialog .title .img{width:160rpx;height:160rpx;position:absolute;top:20rpx;border-radius:10rpx;border:0 #e5e5e5 solid;background-color:#fff}.buydialog .title .price{padding-left:180rpx;width:100%;font-size:36rpx;height:70rpx;color:#fc4343;overflow:hidden}.buydialog .title .price .t1{font-size:26rpx}.buydialog .title .price .t2{font-size:26rpx;text-decoration:line-through;color:#aaa}.buydialog .title .choosename{padding-left:180rpx;width:100%;font-size:24rpx;height:42rpx;line-height:42rpx;color:#888}.buydialog .title .stock{padding-left:180rpx;width:100%;font-size:24rpx;height:42rpx;line-height:42rpx;color:#888}.buydialog .guigelist{width:94%;position:relative;margin:0 3%;padding:0 0 10px 0;border-bottom:0}.buydialog .guigelist .name{height:70rpx;line-height:70rpx}.buydialog .guigelist .item{font-size:30rpx;color:#333;flex-wrap:wrap}.buydialog .guigelist .item2{height:60rpx;line-height:60rpx;margin-bottom:4px;border:0;border-radius:4rpx;padding:0 40rpx;color:#666;margin-right:10rpx;font-size:26rpx;background:#f4f4f4}.buydialog .guigelist .on{color:#fc4343;background:rgba(252,67,67,.1);font-weight:700}.buydialog .buynum{width:94%;position:relative;margin:0 3%;padding:10px 0 10px 0}.buydialog .addnum{font-size:30rpx;color:#666;width:auto;display:flex;align-items:center}.buydialog .addnum .plus{width:48rpx;height:36rpx;background:#f6f8f7;display:flex;align-items:center;justify-content:center}.buydialog .addnum .minus{width:48rpx;height:36rpx;background:#f6f8f7;display:flex;align-items:center;justify-content:center}.buydialog .addnum .img{width:24rpx;height:24rpx}.buydialog .addnum .input{flex:1;width:70rpx;border:0;text-align:center;color:#2b2b2b;font-size:24rpx}.buydialog .op{width:90%;margin:20rpx 5%;border-radius:36rpx;overflow:hidden;display:flex;margin-top:100rpx}.buydialog .addcart{flex:1;height:72rpx;line-height:72rpx;color:#fff;border-radius:0;border:none;font-size:28rpx;font-weight:700}.buydialog .tobuy{flex:1;height:72rpx;line-height:72rpx;color:#fff;border-radius:0;border:none}.buydialog .nostock{flex:1;height:72rpx;line-height:72rpx;background:#aaa;color:#fff;border-radius:0;border:none}.teambox .item1{width:100%;padding:32rpx 20rpx;border-top:1px #eaeaea solid;min-height:112rpx;display:flex;align-items:center}.teambox .item1 image{width:90rpx;height:90rpx;border-radius:4px}.teambox .item1 .f1{display:flex;flex:1;align-items:center}.teambox .item1 .f1 .t2{display:flex;flex-direction:column;padding-left:20rpx}.teambox .item1 .f1 .t2 .x1{color:#333;font-size:26rpx}.teambox .item1 .f2{display:flex;flex-direction:column;width:200rpx;border-left:1px solid #eee;text-align:right}.teambox .item1 .f2 .t1{font-size:40rpx;color:#666;height:40rpx;line-height:40rpx}.teambox .item1 .f2 .t2{font-size:28rpx;color:#999;height:50rpx;line-height:50rpx}.teambox .item1 .f2 .t4{display:flex;margin-top:10rpx;margin-left:10rpx;color:#666;flex-wrap:wrap;font-size:18rpx}