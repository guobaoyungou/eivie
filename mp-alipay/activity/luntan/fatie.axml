<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formsubmit',['$event']]]]]}}" onSubmit="__e"><view class="st_box"><view class="st_title flex-y-center"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" style="width:100rpx;" onTap="__e"><image src="{{pre_url+'/static/img/goback.jpg'}}"></image></view><view style="margin-right:40%;">我要发帖</view></view><view class="st_form"><block a:if="{{cateArr}}"><view class="flex flex-y-center select-cate"><picker style="height:80rpx;line-height:80rpx;font-size:18px;" value="{{cindex}}" range="{{cateArr}}" data-event-opts="{{[['change',[['cateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{cindex==-1?'请选择发帖类型':cateArr[cindex]}}</view></picker><view class="jiantou-icon"><image src="{{pre_url+'/static/img/lt_right_jiantou.png'}}"></image></view></view></block><block a:if="{{cate2&&cateArr2&&cateArr2.length>0}}"><view><picker style="height:80rpx;line-height:80rpx;border-bottom:1px solid #EEEEEE;font-size:18px;" value="{{cindex2}}" range="{{cateArr2}}" data-event-opts="{{[['change',[['cateChange2',['$event']]]]]}}" onChange="__e"><view class="picker">{{cindex2==-1?'请选择二级分类':cateArr2[cindex2]}}</view></picker></view></block><block a:if="{{formcontent.length>0}}"><view><view class="dp-form-item2" a:for="{{formcontent}}" a:for-item="item" a:for-index="idx" a:key="id"><view class="label"><block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block>{{item.val1}}</view><block a:if="{{item.key=='input'}}"><block><block a:if="{{item.val5}}"><text style="margin-right:10rpx;">{{item.val5}}</text></block><block><input class="input" type="{{item.val4==1||item.val4==2?'digit':'text'}}" readonly="{{true}}" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" value="" data-formidx="{{'form'+idx}}" data-event-opts="{{[['input',[['setfield',['$event']]]]]}}" onInput="__e"/></block></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="{{(('textarea')+' '+('form'+idx))}}" adjust-position="{{false}}" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" value="" data-formidx="{{'form'+idx}}" data-event-opts="{{[['focus',[['inputFocus',['$event']]]],['blur',[['inputBlur',['$event']]]],['input',[['setfield',['$event']]]]]}}" onFocus="__e" onBlur="__e" onInput="__e"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="{{(item.val10=='1'?'rowalone':'flex')}}" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" onChange="__e"><label class="{{((('flex-y-center')+' '+(item.val11=='1'?'checkborder':''))+' '+(item.val10=='1'?'':'rowmore'))}}" style="{{'padding:'+('0 10rpx')+';'+('margin-top:'+('10rpx')+';')+('border-radius:'+('10rpx')+';')}}" data-idx="{{idx}}" data-index="{{idx1}}" data-value="{{item1}}" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="{{(item.val4=='1'?'rowalone':'flex')}}" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" onChange="__e"><label class="{{((('flex-y-center')+' '+(item.val9=='1'?'checkborder':''))+' '+(item.val4=='1'?'':'rowmore'))}}" style="{{'padding:'+('0 10rpx')+';'+('margin-top:'+('10rpx')+';')+('border-radius:'+('10rpx')+';')}}" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view class="flex-y-center flex-bt"><text>{{item.val2[editorFormdata[idx]]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block a:else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block a:else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block a:else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block a:if="{{item.key=='year'}}"><block><picker class="picker" name="{{'form'+idx}}" value="" data-idx="{{idx}}" range="{{yearList}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['yearChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block a:else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block a:if="{{item.key=='region'}}"><block><uni-data-picker style="flex:1;width:100%;" vue-id="{{'43efc750-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" placeholder="请选择省市区" data-formidx="{{'form'+idx}}" data-event-opts="{{[['^change',[['onchange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+idx}}" value=""/></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value=""/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{editorFormdata[idx]}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-close" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgForm',['$event']]]]]}}" onTap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="dp-form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="dp-form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view></block></block><block a:if="{{item.key=='upload_pics'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="" maxlength="-1"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><view class="dp-form-imgbox" a:for="{{editorFormdata[idx]}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="dp-form-imgbox-close" data-index="{{index2}}" data-type="pics" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgForm',['$event']]]]]}}" onTap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="dp-form-imgbox-img" style="margin-bottom:10rpx;"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="dp-form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')+('margin-bottom:'+('10rpx')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-type="pics" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></view></block></block></view></view></block><view><textarea placeholder="{{inputtips}}" name="content" maxlength="-1"></textarea></view><block a:if="{{need_call}}"><view><input type="text" placeholder="输入联系电话" name="mobile"/></view></block><block a:if="{{isphone}}"><block><view><input type="text" placeholder="请输入姓名" name="name"/></view><view><input type="text" placeholder="请输入手机号" name="mobile"/></view><block a:if="{{isphoneother}}"><block><view><input type="text" placeholder="请输入QQ" name="qq"/></view><view><input type="text" placeholder="请输入微信号" name="wechat"/></view></block></block></block></block><view class="uploadbtn_ziti1">插入图片</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<9}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g0}}"/><view class="uploadbtn_ziti2">插入视频</view><view class="flex-y-center" style="width:100%;padding:20rpx 0;margin-top:20rpx;"><image style="width:200rpx;height:200rpx;background:#eee;" src="{{pre_url+'/static/img/uploadvideo.png'}}" data-event-opts="{{[['tap',[['uploadvideo',['$event']]]]]}}" onTap="__e"></image><block a:if="{{video}}"><text style="padding-left:20rpx;color:#333;">已上传短视频</text></block></view><input type="text" hidden="true" name="video" maxlength="-1" value="{{video}}"/><block a:if="{{paytop==1&&topoptions}}"><block><view class="uploadbtn_ziti2">帖子置顶展示</view><scroll-view class="top-scroll" style="padding:20rpx 0;" scroll-x="true" show-scrollbar="false" scroll-with-animation="{{true}}"><view class="top-options flex"><view data-event-opts="{{[['tap',[['selectTopTime',[index]]]]]}}" class="{{(('top-option')+' '+((topselected===index)?'selected':''))}}" style="{{'background:'+(topselected==index?'linear-gradient(-90deg,'+item.m0+' 0%,rgba('+item.m1+',0.8) 100%)':'')+';'}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="time">{{"置顶"+item.$orig.hour+"小时"}}</view><view class="price">{{item.$orig.price+"元"}}</view></view></view></scroll-view></block></block></view></view><view class="st_title flex-y-center"><block a:if="{{paytop==1&&topselected>=0}}"><button style="{{'background:'+('linear-gradient(-90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" form-type="submit">{{"支付"+topprice+"元 发表"}}</button></block><block a:else><button style="{{'background:'+('linear-gradient(-90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" form-type="submit">发表</button></block></view><view style="width:100%;margin-top:20rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="fatielog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的发帖记录<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view style="width:100%;height:50rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="43efc750-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="43efc750-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="43efc750-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>