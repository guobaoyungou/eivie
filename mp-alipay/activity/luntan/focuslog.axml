<view><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" style="overflow:hidden;" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view style="width:100rpx;"><image style="width:90rpx;height:90rpx;" src="{{item.pic}}"></image></view><view class="f1" style="width:560rpx;float:right;"><text class="t1">{{item.content}}</text><text class="t2">{{item.createtime}}</text></view></view></block><block a:if="{{nodata}}"><nodata vue-id="1633b0cf-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="1633b0cf-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="1633b0cf-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1633b0cf-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1633b0cf-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>