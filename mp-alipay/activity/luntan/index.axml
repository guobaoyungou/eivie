<view><block a:if="{{isload}}"><block><view class="container2"><block a:if="{{sysset.pic}}"><image style="width:100%;height:auto;" src="{{sysset.pic}}" mode="widthFix" data-url="{{sysset.picurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image></block><block a:if="{{clist.length>0}}"><view class="navbox"><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="nav_li" style="cursor:pointer;" data-url="{{'ltlist?cid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.pic}}"></image><view>{{item.name}}</view></view></block></view></block></view><view style="display:flex;width:100%;height:16rpx;background:#F7F7F7;"></view><view class="container2"><view class="listtitle">最新动态</view><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="top"><image class="f1" src="{{item.headimg}}"></image><view class="f2"><view class="t1">{{item.nickname}}</view><view class="t2">{{item.showtime}}</view></view></view><view class="con"><block a:if="{{item.form}}"><block><block a:for="{{item.form.formcontent}}" a:for-item="subitem" a:for-index="sindex" a:key="sindex"><block a:if="{{item.form['form'+sindex]}}"><view class="dp-form-item"><block a:if="{{subitem.key!='upload'&&subitem.key!='upload_pics'}}"><block><view>{{item.form['form'+sindex]}}</view></block></block><block a:if="{{subitem.key=='upload_pics'||subitem.key=='upload'}}"><block><view class="flex"><block a:for="{{item.form['form'+sindex]}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item2}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-img"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="heightFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" catchTap="__e"></image></view></view></block></block></view></block></block></view></block></block></block></block><block a:if="{{item.luntan_content_ueditor}}"><view class="f1"><rich-text style="word-wrap:break-word;" nodes="{{item.content}}"></rich-text></view></block><block a:else><view class="f1"><text style="white-space:pre-wrap;">{{item.content}}</text></view></block><block a:if="{{item.pics}}"><view class="f2"><image src="{{pic}}" a:for="{{item.pics}}" a:for-item="pic" a:for-index="idx" a:key="idx"></image></view></block><block a:if="{{item.video}}"><video class="video" id="video" src="{{item.video}}" data-event-opts="{{[['tap',[['playvideo',['$event']]]]]}}" catchTap="__e"></video></block></view><block a:if="{{item.isshowphone}}"><view class="phone"><view class="f1"><label class="t1">姓名：</label>{{item.name}}</view><block a:if="{{isphoneother}}"><block><block a:if="{{item.mobile}}"><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block><block a:if="{{item.qq}}"><view class="f1"><label class="t1">QQ：</label>{{item.qq}}</view></block><block a:if="{{item.wechat}}"><view class="f1"><label class="t1">微信号：</label>{{item.wechat}}</view></block></block></block><block a:else><block><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block></block></view></block><view class="bot"><view class="f1"><image style="margin-top:0;" src="{{pre_url+'/static/img/lt_read.png'}}"></image>{{item.readcount}}</view><view class="f1" style="margin-left:60rpx;"><image src="{{pre_url+'/static/img/lt_pinglun.png'}}"></image>{{item.plcount}}</view><block a:if="{{need_call&&item.mobile}}"><view class="f1" style="margin-left:60rpx;" data-phone="{{item.mobile}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchTap="__e"><image style="width:30rpx;height:30rpx;margin-top:0;" src="{{pre_url+'/static/img/mobile.png'}}"></image></view></block><view class="f2"></view><block a:if="{{sysset.cansave}}"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savecontent',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_save.png'}}"></image>保存</view></block><view class="f3" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['zan',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_like'+(item['iszan']==0?'':'2')+'.png'}}"></image>{{item.zan}}</view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="111e6b9b-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="111e6b9b-2" onVueInit="__l"></nodata></block></view></view><view class="{{((('covermy-view')+' '+'flex-col')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="covermy" data-url="pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/lt_gohome.png'}}"></image></view><block a:if="{{sysset&&sysset.sendcheck!=2}}"><view class="covermy" data-url="fatie" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/lt_fatie2.png'}}"></image></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="111e6b9b-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="111e6b9b-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="111e6b9b-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="111e6b9b-6" onVueInit="__l"></wxxieyi></view>