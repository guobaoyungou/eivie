<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="container2"><block a:if="{{banner}}"><image style="width:100%;height:auto;" src="{{banner}}" mode="widthFix"></image></block><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="top"><image class="f1" src="{{item.headimg}}"></image><view class="f2"><view class="t1">{{item.nickname}}</view><view class="t2">{{item.showtime}}</view></view></view><view class="con"><block a:if="{{item.form}}"><block><block a:for="{{item.form.formcontent}}" a:for-item="subitem" a:for-index="sindex" a:key="sindex"><block a:if="{{item.form['form'+sindex]}}"><view class="dp-form-item"><block a:if="{{subitem.key!='upload'&&subitem.key!='upload_pics'}}"><block><view>{{item.form['form'+sindex]}}</view></block></block><block a:if="{{subitem.key=='upload_pics'||subitem.key=='upload'}}"><block><view class="flex"><block a:for="{{item.form['form'+sindex]}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item2}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-img"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="heightFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" catchTap="__e"></image></view></view></block></block></view></block></block></view></block></block></block></block><view class="f1"><text style="white-space:pre-wrap;">{{item.content}}</text></view><block a:if="{{item.pics}}"><view class="f2"><image style="height:auto;" src="{{pic}}" mode="widthFix" a:for="{{item.pics}}" a:for-item="pic" a:for-index="idx" a:key="idx"></image></view></block><block a:if="{{item.video}}"><video class="video" id="video" src="{{item.video}}" data-event-opts="{{[['tap',[['playvideo',['$event']]]]]}}" catchTap="__e"></video></block></view><block a:if="{{item.isshowphone}}"><view class="phone"><block a:if="{{item.name}}"><view class="f1"><label class="t1">姓名：</label>{{item.name}}</view></block><block a:if="{{item.mobile}}"><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block></view></block><view class="bot"><view class="f1"><image style="margin-top:0;" src="{{pre_url+'/static/img/lt_read.png'}}"></image>{{item.readcount}}</view><view class="f1" style="margin-left:60rpx;"><image src="{{pre_url+'/static/img/lt_pinglun.png'}}"></image>{{item.plcount}}</view><view class="f2"></view><block a:if="{{sysset.cansave}}"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savecontent',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_save.png'}}"></image>保存</view></block><view class="f3" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['zan',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_like'+(item['iszan']==0?'':'2')+'.png'}}"></image>{{item.zan}}</view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="38d90c15-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="38d90c15-2" onVueInit="__l"></nodata></block></view></view><view class="{{(('covermy')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" data-url="{{'fatie?cid='+cid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/lt_fatie.png'}}"></image></view></block></block><block a:if="{{loading}}"><loading vue-id="38d90c15-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="38d90c15-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="38d90c15-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="38d90c15-6" onVueInit="__l"></wxxieyi></view>