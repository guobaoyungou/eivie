<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1+"收益"}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.yuebao_money}}</view><view class="f3" data-url="yuebaolog?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>提现记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">提现金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入提现金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><block a:if="{{sysset.yuebao_withdrawfee>0||sysset.yuebao_withdrawmin>0}}"><view class="item4"><block a:if="{{sysset.yuebao_withdrawmin>0}}"><text style="margin-right:10rpx;">{{"最低提现金额"+sysset.yuebao_withdrawmin+'元'}}</text></block><block a:if="{{sysset.yuebao_withdrawfee>0}}"><text>{{"提现手续费"+sysset.yuebao_withdrawfee+'%'}}</text></block></view></block></view><view class="withdrawtype"><view class="f1">选择提现方式：</view><view class="f2"><block a:if="{{sysset.withdraw_weixin==1}}"><view class="item" data-paytype="微信钱包" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-weixin.png'}}"></image>微信钱包</view><view class="radio" style="{{(paytype=='微信钱包'?'background:'+$root.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block><block a:if="{{sysset.withdraw_aliaccount==1}}"><label class="item" data-paytype="支付宝" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝</view><view class="radio" style="{{(paytype=='支付宝'?'background:'+$root.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block a:if="{{sysset.withdraw_bankcard==1}}"><label class="item" data-paytype="银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>银行卡</view><view class="radio" style="{{(paytype=='银行卡'?'background:'+$root.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block></view></view><block a:if="{{sysset.yuebao_turn_yue=='1'}}"><button data-event-opts="{{[['tap',[['tomoney',['$event']]]]]}}" class="opbtn2" onTap="__e">{{"直接转到账户"+$root.m5}}</button></block><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" onTap="__e">立即提现</button><block a:if="{{paytype=='支付宝'}}"><view style="width:100%;margin-top:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/pagesExt/my/setaliaccount" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">设置支付宝账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><block a:if="{{paytype=='银行卡'}}"><view style="width:100%;margin-top:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/pagesExt/my/setbankinfo" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">设置银行卡账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></form><uni-popup vue-id="8fa41448-1" id="dialogInput" type="dialog" ref="__r" data-ref="dialogInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('8fa41448-2')+','+('8fa41448-1')}}" mode="input" title="{{$root.m7+'收益转'+$root.m8}}" value="" placeholder="请输入转入金额" data-event-opts="{{[['^confirm',[['tomonenyconfirm']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="8fa41448-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="8fa41448-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="8fa41448-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>