<view class="container data-v-deb99c5a" style="{{'background:'+(backcolor==''?'#c40004':backcolor)+';'}}"><block a:if="{{isload}}"><block class="data-v-deb99c5a"><block a:if="{{backimg!=''}}"><image class="back_img _img data-v-deb99c5a" src="{{backimg}}" mode="widthFix" alt></image></block><view class="body data-v-deb99c5a"><view class="wrap data-v-deb99c5a"><view class="header clearfix data-v-deb99c5a"><view data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="rule data-v-deb99c5a" onTap="__e">活动规则</view><view class="my data-v-deb99c5a" data-url="{{'myprize?hid='+info.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的奖品</view></view><view class="title data-v-deb99c5a" style="{{('background-image:url('+info.banner+');background-size:100% 100%;')}}"></view><view class="scratch-bg data-v-deb99c5a"><view style="position:relative;" class="data-v-deb99c5a"><image class="scratch-bg-1 data-v-deb99c5a" src="{{pre_url+'/static/img/ggk/scratch_bg.png'}}"></image><image class="scratch-bg-2 data-v-deb99c5a" id="frame" src="{{pre_url+'/static/img/ggk/scratch_kuang.png'}}"></image><view class="scratch-award data-v-deb99c5a"><view class="scratch-award-a data-v-deb99c5a"><block a:if="{{isStart&&!showmaskrule&&!jxshow}}"><block class="data-v-deb99c5a"><canvas class="scratch-canvas data-v-deb99c5a" style="position:absolute;left:0;z-index:888;" canvasId="scratch" disableScroll="{{isScroll}}" id="scratch" data-event-opts="{{[['touchEnd',[['touchEnd',['$event']]]],['touchMove',[['touchMove',['$event']]]],['touchStart',[['touchStart',['$event']]]]]}}" onTouchEnd="__e" onTouchMove="__e" onTouchStart="__e"></canvas></block></block><view class="scratch-bg-text data-v-deb99c5a"><block a:if="{{award_name}}"><block class="data-v-deb99c5a"><text class="scratch-text-1 data-v-deb99c5a">{{jxmc||'刮开图层'}}</text></block></block><block a:if="{{remaindaytimes>0&&award_name}}"><block class="data-v-deb99c5a"><view data-event-opts="{{[['tap',[['onStart',['$event']]]]]}}" class="scratch-bg-text-2 data-v-deb99c5a" onTap="__e">再刮一次</view></block></block><block a:if="{{remaindaytimes<=0&&award_name}}"><block class="data-v-deb99c5a"><view class="scratch-bg-text-3 data-v-deb99c5a">再刮一次</view></block></block></view></view></view></view></view><block a:if="{{info.use_type!=2}}"><view class="border data-v-deb99c5a">您今日还有<text id="change" class="data-v-deb99c5a">{{remaindaytimes}}</text>次抽奖机会</view></block><block a:if="{{info.use_type==1&&info.usescore>0}}"><view class="border2 data-v-deb99c5a"><block a:if="{{!info.is_tr}}"><text class="data-v-deb99c5a">每次</text></block><block a:else><text class="data-v-deb99c5a">本次</text></block>抽奖将消耗<text class="data-v-deb99c5a">{{info.usescore}}</text>{{''+$root.m0+'，您共有'}}<text id="myscore" class="data-v-deb99c5a">{{member.score}}</text>{{''+$root.m1}}</view></block><block a:if="{{info.use_type==2&&info.usemoney>0}}"><view class="border2 data-v-deb99c5a">每次抽奖将消耗<text class="data-v-deb99c5a">{{$root.m2}}</text>{{info.usemoney+'元 ，您共有'}}<text id="mymoney" class="data-v-deb99c5a">{{member.money}}</text>元</view></block><view style="text-align:center;margin-top:40rpx;line-height:60rpx;color:#fff;" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" class="data-v-deb99c5a"><text class="data-v-deb99c5a">返回首页</text></view><view class="scroll data-v-deb99c5a"><view class="p data-v-deb99c5a" style="{{('background-image:url('+pre_url+'/static/img/dzp/list.png);background-size:100% 100%;')}}"></view><view class="sideBox data-v-deb99c5a"><swiper class="bd data-v-deb99c5a" autoplay="true" current="0" vertical="true" circular="true"><block a:for="{{zjlist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{index%2==0}}"><swiper-item class="sitem data-v-deb99c5a"><view class="data-v-deb99c5a">{{"恭喜"+item.nickname+" 获得"}}<text class="info data-v-deb99c5a">{{item.jxmc}}</text></view><block a:if="{{zjlist[index+1]}}"><view class="data-v-deb99c5a">{{"恭喜"+zjlist[index+1].nickname+" 获得"}}<text class="info data-v-deb99c5a">{{zjlist[index+1].jxmc}}</text></view></block></swiper-item></block></block></swiper></view></view><block a:if="{{showmaskrule}}"><view id="mask-rule" class="data-v-deb99c5a"><view class="box-rule data-v-deb99c5a"><view class="h2 data-v-deb99c5a">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e" class="data-v-deb99c5a"></view><view class="con data-v-deb99c5a"><view class="text data-v-deb99c5a"><text decode="true" space="true" class="data-v-deb99c5a">{{info.guize}}</text></view></view></view></view></block><block a:if="{{showqrpopup}}"><view class="popup__container data-v-deb99c5a"><view data-event-opts="{{[['tap',[['hideqrmodal',['$event']]]]]}}" class="popup__overlay data-v-deb99c5a" catchTap="__e"></view><view class="popup__modal data-v-deb99c5a"><view class="popup__content data-v-deb99c5a"><view class="data-v-deb99c5a"><image data-url="{{info.qrcode}}" src="{{info.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e" class="data-v-deb99c5a"></image></view><block a:if="{{info.qrcode_tip}}"><view class="txt data-v-deb99c5a">{{info.qrcode_tip}}</view></block></view></view></view></block><block a:if="{{maskshow&&!formdata}}"><view id="mask-rule1" class="data-v-deb99c5a"><view class="box-rule data-v-deb99c5a" style="height:640rpx;"><view class="h2 data-v-deb99c5a">请填写兑奖信息</view><view style="{{('background: no-repeat center / contain;background-image: url('+pre_url+'/static/img/dzp/close.png);')}}" id="close-rule1" data-event-opts="{{[['tap',[['changemaskshow',['$event']]]]]}}" onTap="__e" class="data-v-deb99c5a"></view><view class="con data-v-deb99c5a"><form data-event-opts="{{[['submit',[['formsub',['$event']]]]]}}" onSubmit="__e" class="data-v-deb99c5a"><view class="pay-form data-v-deb99c5a" style="margin-top:0.18rem;"><view class="item flex-y-center data-v-deb99c5a" a:for="{{info.formcontent}}" a:for-item="item" a:for-index="idx" a:key="idx"><view class="f1 data-v-deb99c5a">{{item.val1+"："}}</view><view class="f2 flex flex1 data-v-deb99c5a"><block a:if="{{item.key=='input'}}"><block class="data-v-deb99c5a"><input class="input data-v-deb99c5a" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}"/></block></block><block a:if="{{item.key=='textarea'}}"><block class="data-v-deb99c5a"><textarea class="textarea data-v-deb99c5a" name="{{'form'+idx}}" placeholder="{{item.val2}}"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block class="data-v-deb99c5a"><radio-group class="radio-group data-v-deb99c5a" name="{{'form'+idx}}"><label class="data-v-deb99c5a" a:for="{{item.val2}}" a:for-item="item1" a:for-index="index" a:key="index"><radio value="{{item1}}" class="data-v-deb99c5a"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block class="data-v-deb99c5a"><checkbox-group name="{{'form'+idx}}" class="data-v-deb99c5a"><label class="data-v-deb99c5a" a:for="{{item.val2}}" a:for-item="item1" a:for-index="index" a:key="index"><checkbox class="xyy-zu data-v-deb99c5a" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='switch'}}"><block class="data-v-deb99c5a"><switch class="xyy-zu data-v-deb99c5a" value="1" name="{{'form'+idx}}"></switch></block></block><block a:if="{{item.key=='selector'}}"><block class="data-v-deb99c5a"><picker class="xyy-pic data-v-deb99c5a" mode="selector" name="{{'form'+idx}}" range="{{item.val2}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['selector_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{item.val2[selectIndex]}}"><view class="picker data-v-deb99c5a">{{''+item.val2[selectIndex]}}</view></block><block a:else><view class="data-v-deb99c5a">请选择</view></block></picker></block></block><block a:if="{{item.key=='time'}}"><block class="data-v-deb99c5a"><picker class="xyy-pic data-v-deb99c5a" mode="time" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['time_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{picker_tmer}}"><view class="picker data-v-deb99c5a">{{picker_tmer}}</view></block><block a:else><view class="data-v-deb99c5a">选择时间</view></block></picker></block></block><block a:if="{{item.key=='date'}}"><block class="data-v-deb99c5a"><picker class="xyy-pic data-v-deb99c5a" mode="date" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['date_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{picker_date}}"><view class="picker data-v-deb99c5a">{{''+picker_date}}</view></block><block a:else><view class="data-v-deb99c5a">选择日期</view></block></picker></block></block><block a:if="{{item.key=='region'}}"><block class="data-v-deb99c5a"><uni-data-picker class="flex1 data-v-deb99c5a" style="color:#333;" vue-id="{{'096ee700-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['^change',[['region_editorBindPickerChange']]]]}}" onChange="__e" onVueInit="__l"><input style="border:none;font-size:28rpx;padding:0rpx;color:#fff;" type="text" name="{{'form'+idx}}" placeholder="请选择省市区" placeholder-style="color:#fff;font-size:28rpx" value="{{picker_region}}" class="data-v-deb99c5a"/></uni-data-picker></block></block></view></view><view class="data-v-deb99c5a"><button class="subbtn data-v-deb99c5a" form-type="submit">确 定</button></view></view></form></view></view></view></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="096ee700-2" class="data-v-deb99c5a" onVueInit="__l"></loading></block><dp-tabbar vue-id="096ee700-3" opt="{{opt}}" class="data-v-deb99c5a" onVueInit="__l"></dp-tabbar><popmsg vue-id="096ee700-4" ref="__r" data-ref="popmsg" class="data-v-deb99c5a" onVueInit="__l"></popmsg><wxxieyi vue-id="096ee700-5" class="data-v-deb99c5a" onVueInit="__l"></wxxieyi></view>