<view class="container" style="background-color:#c40004;min-height:100vh;"><block a:if="{{isload}}"><block><view class="banner"><image src="{{info.banner}}" mode="widthFix"></image></view><view class="activity"><view class="activity-amin"><view class="h2">我的奖品</view><view class="tb0"><view class="tr"><view class="td">中奖时间</view><view class="td">中奖奖品</view><view class="td">领奖状态</view><view class="td">操作</view></view><view class="tr" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="td td2">{{item.createtime}}</view><view class="td td2">{{item.jxmc}}</view><view class="td td2"><block a:if="{{item.status==0}}"><block>未领奖</block></block><block a:else><block>已领奖</block></block></view><view class="td td2"><block a:if="{{item.status==0}}"><text style="background-color:#fb5a43;padding:4rpx 8rpx;" data-k="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['duijiang',['$event']]]]]}}" onTap="__e">兑奖</text></block><block a:if="{{item.jxtp==3&&item.status==1}}"><text style="background-color:#fb6a43;padding:4rpx 8rpx;" data-url="/pagesExt/coupon/mycoupon" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看</text></block></view></view></view><block a:if="{{datalist.length==0}}"><view style="width:100%;padding:40rpx 0;text-align:center;color:#f19132;">暂无中奖记录~</view></block><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="goback" onTap="__e">返回</view></view></view><block a:if="{{maskshow&&formdata}}"><view id="mask-rule2"><view class="box-rule" style="height:900rpx;"><view class="h2">兑奖信息</view><view style="{{('background: no-repeat center / contain;background-image: url('+pre_url+'/static/img/dzp/close.png);')}}" id="close-rule2" data-event-opts="{{[['tap',[['changemaskshow',['$event']]]]]}}" onTap="__e"></view><view class="con"><view class="text" style="text-align:center;"><view style="text-align:left;margin-left:10%;" id="linkinfo"><view>{{"奖品："+record.jxmc}}</view><view a:for="{{formdata}}" a:for-item="item" a:for-index="index" a:key="index">{{index+"："+item}}</view></view><image style="width:80%;" src="{{record.hexiaoqr}}" id="hexiaoqr" mode="widthFix"></image><view>请出示兑奖码给核销员进行兑奖</view></view></view></view></view></block><block a:if="{{maskshow&&!formdata}}"><view id="mask-rule1"><view class="box-rule" style="height:640rpx;"><view class="h2">请填写兑奖信息</view><view style="{{('background: no-repeat center / contain;background-image: url('+pre_url+'/static/img/dzp/close.png);')}}" id="close-rule1" data-event-opts="{{[['tap',[['changemaskshow',['$event']]]]]}}" onTap="__e"></view><view class="con"><form data-event-opts="{{[['submit',[['formsub',['$event']]]]]}}" onSubmit="__e"><view class="pay-form" style="margin-top:0.18rem;"><view class="item flex-y-center" a:for="{{info.formcontent}}" a:for-item="item" a:for-index="idx" a:key="idx"><view class="f1">{{item.val1+"："}}</view><view class="f2 flex flex1"><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+idx}}"><label a:for="{{item.val2}}" a:for-item="item1" a:for-index="index" a:key="index"><radio value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group name="{{'form'+idx}}"><label a:for="{{item.val2}}" a:for-item="item1" a:for-index="index" a:key="index"><checkbox class="xyy-zu" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='switch'}}"><block><switch class="xyy-zu" value="1" name="{{'form'+idx}}"></switch></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="xyy-pic" mode="selector" name="{{'form'+idx}}" range="{{item.val2}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['selector_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{item.val2[selectIndex]}}"><view class="picker">{{''+item.val2[selectIndex]}}</view></block><block a:else><view>请选择</view></block></picker></block></block><block a:if="{{item.key=='time'}}"><block><picker class="xyy-pic" mode="time" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['time_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{picker_tmer}}"><view class="picker">{{picker_tmer}}</view></block><block a:else><view>选择时间</view></block></picker></block></block><block a:if="{{item.key=='date'}}"><block><picker class="xyy-pic" mode="date" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['date_editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{picker_date}}"><view class="picker">{{''+picker_date}}</view></block><block a:else><view>选择日期</view></block></picker></block></block><block a:if="{{item.key=='region'}}"><block><uni-data-picker class="flex1" style="color:#333;" vue-id="{{'ec8ca228-1-'+idx}}" border="{{false}}" localdata="{{items}}" popup-title="请选择省市区" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['^change',[['region_editorBindPickerChange']]]]}}" onChange="__e" onVueInit="__l"><input style="border:none;color:#fff;font-size:28rpx;padding:0rpx;" type="text" name="{{'form'+idx}}" placeholder="请选择省市区" placeholder-style="color:#fff;font-size:28rpx" value="{{picker_region}}"/></uni-data-picker></block></block></view></view><view style="padding:0 40px 0 80px;"><button class="subbtn" form-type="submit">确 定</button></view></view></form></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="ec8ca228-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="ec8ca228-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="ec8ca228-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>