<view><block a:if="{{isload}}"><block><block a:if="{{sysset.showgzts}}"><block><view style="width:100%;height:88rpx;"></view><view class="follow_topbar"><view class="headimg"><image src="{{sysset.logo}}"></image></view><view class="info"><view class="i">欢迎进入<text style="{{'color:'+($root.m0)+';'}}">{{sysset.name}}</text></view><view class="i">关注公众号享更多专属服务</view></view><view data-event-opts="{{[['tap',[['showsubqrcode',['$event']]]]]}}" class="sub" style="{{'background-color:'+($root.m1)+';'}}" onTap="__e">立即关注</view></view><uni-popup vue-id="62192142-1" id="qrcodeDialog" type="dialog" ref="__r" data-ref="qrcodeDialog" onVueInit="__l"><view class="qrcodebox"><image class="img" src="{{sysset.qrcode}}" data-url="{{sysset.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">长按识别二维码关注</view><view data-event-opts="{{[['tap',[['closesubqrcode',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block><block a:if="{{bboglist.length>0}}"><view style="position:fixed;top:15vh;left:20rpx;z-index:9;background:rgba(0,0,0,0.6);border-radius:20rpx;color:#fff;padding:0 10rpx;"><swiper style="position:relative;height:54rpx;width:350rpx;" autoplay="{{true}}" interval="{{5000}}" vertical="{{true}}"><swiper-item class="flex-y-center" data-url="{{'product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{bboglist}}" a:for-item="item" a:for-index="index" a:key="index"><image style="width:40rpx;height:40rpx;border:1px solid rgba(255,255,255,0.7);border-radius:50%;margin-right:4px;" src="{{item.headimg}}"></image><view style="width:300rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:22rpx;" class="_div">{{item.nickname+" "+item.showtime+"购买了该商品"}}</view></swiper-item></swiper></view></block><block a:if="{{isplay==0}}"><view class="swiper-container"><swiper class="swiper" style="{{'height:'+(swiperHeight+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><view class="swiper-item-view" style="{{'height:'+(swiperHeight+'px')+';'}}" id="{{'content-wrap'+index}}"><image class="img" src="{{item}}" mode="widthFix" data-event-opts="{{[['load',[['loadImg',['$event']]]]]}}" onLoad="__e"></image></view></swiper-item></block></swiper><view class="imageCount">{{current+1+"/"+product.pics.length}}</view><block a:if="{{product.video}}"><view data-event-opts="{{[['tap',[['payvideo',['$event']]]]]}}" class="provideo" onTap="__e"><image src="{{pre_url+'/static/img/video.png'}}"></image><view class="txt">{{product.video_duration}}</view></view></block></view></block><block a:if="{{isplay==1}}"><view class="videobox"><video class="video" autoplay="true" id="video" src="{{product.video}}"></video><view data-event-opts="{{[['tap',[['parsevideo',['$event']]]]]}}" class="parsevideo" onTap="__e">退出播放</view></view></block><view class="seckill_title"><image class="f0" src="{{pre_url+'/static/img/tjms.png'}}"></image><view class="f1"><view class="t1"><block a:if="{{showprice_dollar&&product.usd_sellprice}}"><block><text style="font-size:24rpx;">$</text>{{product.usd_sellprice+''}}<text style="font-size:24rpx;">￥</text>{{product.sell_price+''}}</block></block><block a:else><block><text style="font-size:24rpx;">￥</text>{{product.sell_price+''}}</block></block><text class="x2">{{"￥"+product.market_price}}</text></view><block a:if="{{seckill_status==0}}"><view class="t2">秒杀未开始</view></block><block a:if="{{seckill_status==1}}"><view class="t2">火爆抢购中</view></block><block a:if="{{seckill_status==2}}"><view class="t2">秒杀已结束</view></block></view><block a:if="{{seckill_status==0||seckill_status==1}}"><view class="f3"><view class="t1">{{"距秒杀"+(seckill_status==0?'开始':'结束')+"还剩"}}</view><view class="t2" id="djstime"><text class="djsspan">{{djshour}}</text>:<text class="djsspan">{{djsmin}}</text>:<text class="djsspan">{{djssec}}</text></view></view></block></view><view class="header"><view class="price_share"><view class="price"><view class="f1" style="{{'color:'+($root.m2)+';'}}"><block a:if="{{showprice_dollar&&product.usd_sellprice}}"><block><text style="font-size:24rpx;">$</text>{{product.usd_sellprice+''}}<text style="font-size:32rpx;"><text style="font-size:24rpx;">￥</text>{{product.sell_price}}</text></block></block><block a:else><block><text style="font-size:36rpx;">￥</text>{{product.sell_price+''}}</block></block></view><block a:if="{{product.market_price*1>product.sell_price*1}}"><view class="f2">{{"￥"+product.market_price}}</view></block></view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><view class="title">{{product.name}}</view><view class="sales_stock"><view class="f1">{{"销量："+product.sales+''}}</view><view class="f2">{{"库存："+product.stock}}</view></view><block a:if="{{seckillset.showcommission==1&&product.commission>0}}"><view class="commission" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}">{{"分享好友购买预计可得"+$root.m5+"："}}<text style="font-weight:bold;padding:0 2px;">{{product.commission}}</text>元</view></block></view><view class="choose" data-btntype="2" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e"><view class="f1 flex1">请选择商品规格及数量</view><image class="f2" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block a:if="{{product.givescore>0}}"><view class="cuxiaodiv"><view class="cuxiaopoint"><view class="f0">{{"送"+$root.m6}}</view><view class="f1" style="font-size:26rpx;">{{"购买可得"+$root.m7+product.givescore+"个"}}</view></view></view></block><block a:if="{{cuxiaolist.length>0||couponlist.length>0||product.discount_tips!=''}}"><view class="cuxiaodiv"><block a:if="{{cuxiaolist.length>0}}"><view class="cuxiaopoint"><view class="f0">促销</view><view class="f1"><view class="t" style="{{'background:'+('rgba('+$root.m8+',0.1)')+';'+('color:'+($root.m9)+';')}}" a:for="{{cuxiaolist}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t0">{{item.tip}}</text><text class="t1">{{item.name}}</text></view></view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block a:if="{{product.discount_tips!=''}}"><view class="cuxiaopoint"><view class="f0">折扣</view><view class="f1" style="padding-left:10rpx;">{{product.discount_tips}}</view><view class="f2" data-url="/pagesExt/my/levelinfo" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/arrow-point.png'}}" mode="widthFix"></image></view></view></block><block a:if="{{couponlist.length>0}}"><view class="cuxiaopoint"><view class="f0">优惠</view><view class="f1"><view class="t" style="{{'background:'+('rgba('+$root.m10+',0.1)')+';'+('color:'+($root.m11)+';')}}" a:for="{{couponlist}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t0" style="padding:0 6px;">券</text><text class="t1">{{item.name}}</text></view></view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/arrow-point.png'}}"></image></view></view></block></view></block><block a:if="{{showcuxiaodialog}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidecuxiaodetail',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal coupon-modal"><view class="popup__title"><text class="popup__title-text">优惠促销</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hidecuxiaodetail',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="service-item" a:for="{{cuxiaolist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="suffix"><view class="type-name"><text style="border-radius:4px;border:1px solid #f05423;color:#ff550f;font-size:20rpx;padding:2px 5px;">{{item.tip}}</text><text style="color:#333;margin-left:20rpx;">{{item.name}}</text></view></view></view><couponlist vue-id="62192142-2" couponlist="{{couponlist}}" data-event-opts="{{[['^getcoupon',[['getcoupon']]]]}}" onGetcoupon="__e" onVueInit="__l"></couponlist></view></view></view></block><block a:if="{{seckillset.comment==1&&commentcount>0}}"><view class="commentbox"><view class="title"><view class="f1">{{"评价("+commentcount+")"}}</view><view class="f2" data-url="{{'commentlist?proid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">好评度<text style="{{'color:'+($root.m12)+';'}}">{{product.comment_haopercent+"%"}}</text><image style="width:32rpx;height:32rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="comment"><block a:if="{{commentlist.length>0}}"><view class="item"><view class="f1"><image class="t1" src="{{commentlist[0].headimg}}"></image><view class="t2">{{commentlist[0].nickname}}</view><view class="flex1"></view><view class="t3"><image class="img" src="{{pre_url+'/static/img/star'+(commentlist[0].score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2" a:key="index2"></image></view></view><view class="f2"><text class="t1">{{commentlist[0].content}}</text><view class="t2"><block a:if="{{commentlist[0].content_pic!=''}}"><block><block a:for="{{commentlist[0].content_pic}}" a:for-item="itemp" a:for-index="index" a:key="index"><view data-url="{{itemp}}" data-urls="{{commentlist[0].content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></view></view><view class="f3" data-url="{{'commentlist?proid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看全部评价</view></view></block><block a:else><view class="nocomment">暂无评价~</view></block></view></view></block><block a:if="{{seckillset.showjd==1}}"><view class="shop"><image class="p1" src="{{business.logo}}"></image><view class="p2 flex1"><view class="t1">{{business.name}}</view><view class="t2">{{business.desc}}</view></view><button class="p4" style="{{'background:'+('linear-gradient(90deg,'+$root.m13+' 0%,rgba('+$root.m14+',0.8) 100%)')+';'}}" data-url="{{product.bid==0?'/pages/index/index':'/pagesExt/business/index?id='+product.bid}}" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">进入店铺</button></view></block><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">商品描述</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><dp vue-id="62192142-3" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view><view style="width:100%;height:140rpx;"></view><block a:if="{{product.status==1}}"><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="f1"><block a:if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block a:else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="item flex1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share2.png'}}"></image><view class="t1">分享</view></view><view data-event-opts="{{[['tap',[['addfavorite',['$event']]]]]}}" class="item" onTap="__e"><image class="img" src="{{pre_url+'/static/img/shoucang.png'}}"></image><view class="t1">{{isfavorite?'已收藏':'收藏'}}</view></view></view><view class="op"><block a:if="{{seckill_status==1}}"><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m15)+';'}}" data-btntype="2" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">立即抢购</view></block><block a:else><block a:if="{{seckill_status==2}}"><view class="tobuy flex-x-center flex-y-center" style="background:#ccc;">秒杀已结束</view></block><block a:else><view class="tobuy flex-x-center flex-y-center" style="background:#ccc;">秒杀未开始</view></block></block></view></view></block><scrolltop vue-id="62192142-4" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m16=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m17=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m18!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{buydialogShow}}"><buydialog vue-id="62192142-5" proid="{{product.id}}" btntype="{{btntype}}" menuindex="{{menuindex}}" controller="ApiSeckill" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" onBuydialogChange="__e" onVueInit="__l"></buydialog></block><scrolltop vue-id="62192142-6" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop></block></block><block a:if="{{loading}}"><loading vue-id="62192142-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="62192142-8" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="62192142-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>