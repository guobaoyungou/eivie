<view class="container" style="{{'background:'+(info.color1)+';'}}"><block a:if="{{isload}}"><block><view class="banner"><image src="{{info.banner}}" mode="widthFix"></image></view><view class="box1"><view class="item"><view class="t1" style="{{'color:'+(info.color2)+';'}}">{{info.joinnum}}</view><view class="t2">参与人数</view></view><view class="item"><view class="t1" style="{{'color:'+(info.color2)+';'}}">{{info.helpnum}}</view><view class="t2">累计投票</view></view><view class="item"><view class="t1" style="{{'color:'+(info.color2)+';'}}">{{info.readcount}}</view><view class="t2">访问次数</view></view></view><view class="box2"><view class="f1"><image style="width:32rpx;height:32rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/clock.png'}}"></image><text>{{info.starttime>nowtime?'距活动开始还有':'距活动结束还剩'}}</text></view><view class="f2" style="{{'color:'+(info.color2)+';'}}"><text class="t1">{{djsday}}</text><text class="t2">天</text><text class="t1">{{djshour}}</text><text class="t2">小时</text><text class="t1">{{djsmin}}</text><text class="t2">分钟</text><text class="t1">{{djssec}}</text><text class="t2">秒</text></view><view class="topsearch flex-y-center"><view class="topsearch-f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索编号或选手名称" placeholder-style="font-size:24rpx;color:#778899" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/><view data-event-opts="{{[['tap',[['searchConfirm',['$event']]]]]}}" class="search-btn-class" style="{{'color:'+(info.color2)+';'}}" onTap="__e">搜索</view></view></view></view><view class="box3"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{info.listtype==0}}"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="pic"><image class="img" src="{{item.pic}}" mode="widthFix"></image></view><view class="name">{{item.name}}</view><view class="no">{{"NO: "+item.number}}</view><view class="helpnum">{{item.helpnum+"票"}}</view><view class="tou" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-id="{{item.id}}" data-type="0" data-isconfirm="{{isconfirm}}" data-event-opts="{{[['tap',[['toupiao',['$event']]]]]}}" catchTap="__e">{{info.helptext}}</view></view></block><block a:if="{{info.listtype==1}}"><view class="itemlist" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="pic"><image class="img" src="{{item.pic}}" mode="widthFix"></image></view><view class="right"><view class="name">{{item.name}}</view><view class="no">{{"NO: "+item.number}}</view><view class="helpnum">{{item.helpnum+"票"}}</view><view class="tou" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-id="{{item.id}}" data-type="0" data-isconfirm="{{isconfirm}}" data-event-opts="{{[['tap',[['toupiao',['$event']]]]]}}" catchTap="__e">{{info.helptext}}</view></view></view></block></block></view><block a:if="{{nodata}}"><view style="background:#fff;width:94%;margin:0 3%;border-radius:12rpx;"><nodata vue-id="65654f8a-1" onVueInit="__l"></nodata></view></block><view style="width:100%;height:60rpx;"></view><block a:if="{{isconfirm==0}}"><uni-popup vue-id="65654f8a-2" id="dialogPayscore" type="dialog" ref="__r" data-ref="dialogPayscore" onVueInit="__l"><view class="hxqrbox"><view class="hxqrbox1"><text>{{confirmmsg}}</text></view><view class="tou2" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-id="{{nowjoinid}}" data-type="0" data-isconfirm="1" data-event-opts="{{[['tap',[['toupiaoGoon',['$event']]]]]}}" onTap="__e">继续投票</view><view data-event-opts="{{[['tap',[['closePayscore',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block><uni-popup vue-id="65654f8a-3" id="dialogPaynotenough" type="dialog" ref="__r" data-ref="dialogPaynotenough" onVueInit="__l"><view class="hxqrbox"><view class="hxqrbox2"><text>{{confirmmsg}}</text></view><block a:if="{{paynotenoughtxt!=''&&paynotenoughurl!=''}}"><view class="tou2" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-url="{{paynotenoughurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{paynotenoughtxt}}</view></block><view data-event-opts="{{[['tap',[['closePaynotenough',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block a:if="{{info.help_check==1}}"><uni-popup vue-id="65654f8a-4" id="dialogCaptcha" type="dialog" ref="__r" data-ref="dialogCaptcha" onVueInit="__l"><view class="hxqrbox"><view class="hxqrbox1"><input type="text" placeholder="请输入验证码" data-event-opts="{{[['input',[['setcaptcha',['$event']]]]]}}" onInput="__e"/><image src="{{pre_url+'/?s=/ApiIndex/captcha&aid='+aid+'&session_id='+session_id+'&t='+randt}}" data-event-opts="{{[['tap',[['regetcaptcha',['$event']]]]]}}" onTap="__e"></image></view><view class="tou2" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-id="{{nowjoinid}}" data-type="1" data-isconfirm="{{isconfirm}}" data-event-opts="{{[['tap',[['toupiao',['$event']]]]]}}" onTap="__e">确 定</view><view data-event-opts="{{[['tap',[['closeCaptcha',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block><block a:if="{{info.help_check==2}}"><uni-popup vue-id="65654f8a-5" id="dialogSmscode" type="dialog" ref="__r" data-ref="dialogSmscode" onVueInit="__l"><view class="hxqrbox"><view class="hxqrbox1"><image style="width:44rpx;height:44rpx;margin-right:30rpx;" src="{{pre_url+'/static/img/reg-tel.png'}}"></image><input type="text" placeholder="请输入手机号" data-event-opts="{{[['input',[['setsmstel',['$event']]]]]}}" onInput="__e"/><view data-event-opts="{{[['tap',[['sendsmscode',['$event']]]]]}}" class="code" style="{{'font-size:30rpx;width:160rpx;text-align:center;'+('color:'+($root.m0)+';')}}" onTap="__e">{{smsdjs||'获取验证码'}}</view></view><view class="hxqrbox1" style="margin-top:40rpx;"><image style="width:44rpx;height:44rpx;margin-right:30rpx;" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input type="text" placeholder="请输入短信验证码" data-event-opts="{{[['input',[['setsmscode',['$event']]]]]}}" onInput="__e"/></view><view class="tou2" style="{{'background:'+('linear-gradient(90deg,'+info.color2+' 0%,rgba('+info.color2rgb+',0.7) 100%)')+';'}}" data-id="{{nowjoinid}}" data-type="1" data-isconfirm="{{isconfirm}}" data-event-opts="{{[['tap',[['toupiao',['$event']]]]]}}" onTap="__e">确 定</view><view data-event-opts="{{[['tap',[['closeSmscode',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block></block><block a:if="{{loading}}"><loading vue-id="65654f8a-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="65654f8a-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="65654f8a-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>