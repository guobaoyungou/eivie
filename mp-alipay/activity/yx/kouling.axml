<view class="container"><block a:if="{{isload}}"><block><view class="wrap" style="height:100%;"><block a:if="{{info.banner}}"><view class="title" style="{{('background-image:url('+info.banner+');background-size:100% 100%;')}}"></view></block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form"><view class="form-item"><input class="input" type="text" placeholder="请输入口令" placeholder-style="color:#BBBBBB;font-size:28rpx" name="kouling" value=""/></view></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">确 定</button></form><block a:if="{{info.guize}}"><view class="guizeBox"><view class="gztitle">— 活动规则 —</view><view class="guize_txt"><text decode="true" space="true">{{info.guize}}</text></view></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="16f67683-1" onVueInit="__l"></loading></block><popmsg vue-id="16f67683-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>