<view class="container"><block a:if="{{isload}}"><block><view class="topbox"><view class="order-tab"><view class="order-tab2"><view class="{{('item '+(curIndex==-1?'on':''))}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.appid}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view></block></view></view><block a:if="{{curIndex!='-1'}}"><view class="classify-ul"><view class="libox flex" style="width:100%;"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="classify-li" style="{{(curIndex2==idx2?'color:'+item.m2+';background:rgba('+item.m3+',0.2)':'')}}" data-id="{{item.$orig.appid}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view></view></block></view><view class="content flex" style="{{(curIndex==-1?'top: 100rpx;':'top:'+toppx)}}"><view class="f1" data-url="{{'peodetail2?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="headimg"><image src="{{item.avatar}}"></image></view><view class="text1 flex"><text class="t1">{{item.name+''}}</text><text class="t3">{{item.distanceDesc+''}}</text></view><view class="text3 flex"><block a:if="{{curIndex==-1}}"><view class="t3">{{"接单量:"+item.acceptOrderTotal+''}}<text class="statusdesc">{{item.statusDesc}}</text></view></block><block a:else><text class="t3">{{item.priceDesc+''}}</text></block><view class="yuyue" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/yuyue/yuyue/peodetail2?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">预约</view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="006116e0-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="006116e0-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="006116e0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="006116e0-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="006116e0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="006116e0-6" onVueInit="__l"></wxxieyi></view>