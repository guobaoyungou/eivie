<view><block a:if="{{isload}}"><block><block a:if="{{sysset.showgzts}}"><block><view style="width:100%;height:88rpx;"></view><view class="follow_topbar"><view class="headimg"><image src="{{sysset.logo}}"></image></view><view class="info"><view class="i">欢迎进入<text style="{{'color:'+($root.m0)+';'}}">{{sysset.name}}</text></view><view class="i">关注公众号享更多专属服务</view></view><view data-event-opts="{{[['tap',[['showsubqrcode',['$event']]]]]}}" class="sub" style="{{'background-color:'+($root.m1)+';'}}" onTap="__e">立即关注</view></view><uni-popup vue-id="36abb787-1" id="qrcodeDialog" type="dialog" ref="__r" data-ref="qrcodeDialog" onVueInit="__l"><view class="qrcodebox"><image class="img" src="{{sysset.qrcode}}" data-url="{{sysset.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">长按识别二维码关注</view><view data-event-opts="{{[['tap',[['closesubqrcode',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block><block a:if="{{isplay==0}}"><view class="swiper-container"><swiper class="swiper" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{500000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{sysset.pic}}" mode="widthFix"></image></view></swiper-item></swiper></view></block><view class="header"><view class="price_share"><view class="title">{{product.name}}</view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><view class="pricebox flex"><view class="price"><view class="f1" style="{{'color:'+($root.m2)+';'}}"><text>{{product.price+product.unit}}</text></view></view></view></view><view class="choosebox"><view data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" class="choosedate" onTap="__e"><view class="f0">服务时间</view><view class="f1 flex1">{{days+" "+selectDates}}</view><image class="f2" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" class="choosedate" onTap="__e"><view class="f0">服务时长</view><view class="f1 flex1"><slider class="slider" block-size="10" min="{{1}}" max="{{10}}" value="{{currentnum}}" activeColor="#595959" data-event-opts="{{[['change',[['sliderChange',['$event']]]],['changing',[['sliderChanging',['$event']]]]]}}" onChange="__e" onChanging="__e"></slider><text>{{currentnum+" "+product.unit}}</text></view><image class="f2" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">服务详情</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><image src="{{sysset.detailpic}}" mode="widthFix"></image></view><view style="width:100%;height:140rpx;"></view><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':''))}}"><view class="f1"><view class="item" data-url="{{'prolist?bid='+product.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/shou.png'}}"></image><view class="t1">首页</view></view><block a:if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block a:else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block></view><view class="op"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m3)+';'}}" onTap="__e">立即预约</view></view></view><block a:if="{{buydialogShow}}"><yybuydialog vue-id="36abb787-2" proid="{{product.id}}" btntype="{{btntype}}" menuindex="{{menuindex}}" data-event-opts="{{[['^currgg',[['currgg']]],['^buydialogChange',[['buydialogChange']]],['^addcart',[['addcart']]]]}}" onCurrgg="__e" onBuydialogChange="__e" onAddcart="__e" onVueInit="__l"></yybuydialog></block><scrolltop vue-id="36abb787-3" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m4=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m5=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m6!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{timeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidetimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择时间</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hidetimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="order-tab"><view class="order-tab2"><block a:for="{{datelist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e"><view class="datetext">{{item.weeks}}</view><view class="datetext2">{{item.date}}</view><view class="after" style="{{'background:'+($root.m7)+';'}}"></view></view></block></view></view><view class="flex daydate"><block a:for="{{timelist}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="{{('date '+(timeindex==index2&&item.status==1?'on':'')+(item.status==0?'hui':''))}}" data-index2="{{index2}}" data-status="{{item.status}}" data-time="{{item.timeint}}" data-event-opts="{{[['tap',[['switchDateTab',['$event']]]]]}}" onTap="__e">{{''+item.time}}</view></block></view><view class="op"><button data-event-opts="{{[['tap',[['selectDate',['$event']]]]]}}" class="tobuy on" style="{{'background-color:'+($root.m8)+';'}}" onTap="__e">确 定</button></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="36abb787-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="36abb787-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="36abb787-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>