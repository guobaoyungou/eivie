<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="order-tab"><view class="order-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view></block></view></view><view class="content flex" data-id="{{item.id}}" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1" data-url="{{'peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="headimg"><image src="{{item.headimg}}"></image></view><view class="text1"><text class="t1">{{item.realname+''}}</text><block a:if="{{item.typename}}"><text class="t2">{{item.typename+''}}</text></block><view class="text2">{{item.jineng}}</view><view class="text3 flex"><view class="t4">服务<text>{{''+item.totalnum}}</text>次</view><view class="t5">评分<text>{{item.comment_score}}</text></view></view></view></view><view><view class="yuyue" style="{{'background:'+($root.m2)+';'}}" data-url="{{'/yuyue/yuyue/peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">预约</view></view></view><block a:if="{{nodata}}"><nodata vue-id="f802c574-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="f802c574-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="f802c574-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="f802c574-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="f802c574-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="f802c574-6" onVueInit="__l"></wxxieyi></view>