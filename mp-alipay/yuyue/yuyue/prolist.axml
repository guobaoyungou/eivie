<view class="container"><block a:if="{{isload}}"><block><view class="search-container" data-url="search" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商品</view></view></view><view class="content-container"><view class="nav_left"><view class="{{('nav_left_items '+(curIndex==-1?'active':''))}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('nav_left_items '+(curIndex==index?'active':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.name}}</view></block></view><view class="nav_right"><view class="nav_right-content"><block a:if="{{curIndex>-1&&clist[curIndex].child.length>0}}"><view class="classify-ul"><view class="flex" style="width:100%;overflow-y:hidden;overflow-x:scroll;"><view class="classify-li" style="{{(curIndex2==-1?'color:'+$root.m2+';background:rgba('+$root.m3+',0.2)':'')}}" data-id="{{clist[curIndex].id}}" data-index="-1" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="classify-li" style="{{(curIndex2==idx2?'color:'+item.m4+';background:rgba('+item.m5+',0.2)':'')}}" data-id="{{item.$orig.id}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view></view></block><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="product-itemlist"><view class="item" data-type="{{item.$orig.type?item.$orig.type:0}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" onTap="__e" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.$orig.name}}</text></view><view class="p2"><block a:if="{{item.$orig.show_free&&item.$orig.sell_price<=0}}"><view class="t1" style="{{'color:'+(item.m6)+';'}}">免费</view></block><block a:else><view class="t1" style="{{'color:'+(item.m7)+';'}}">{{item.$orig.sell_price}}<text style="font-size:24rpx;padding-left:2px;">{{"元/"+item.$orig.danwei}}</text></view></block><block a:if="{{item.$orig.market_price*1>item.$orig.sell_price*1}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block></view><view class="p3"><block a:if="{{item.$orig.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.$orig.sales+"件"}}</text></view></block></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="139bb113-1" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="139bb113-2" text="暂无相关商品" onVueInit="__l"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view><block a:if="{{buydialogShow}}"><buydialog vue-id="139bb113-3" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></block></block><block a:if="{{loading}}"><loading vue-id="139bb113-4" loadstyle="left:62.5%" onVueInit="__l"></loading></block><dp-tabbar vue-id="139bb113-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="139bb113-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>