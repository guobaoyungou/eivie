<view class="container"><block a:if="{{isload}}"><block><view class="ordertop flex" style="{{('background:url('+pre_url+'/static/img/orderbg.png);background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1 "><view class="t1">等待买家付款</view><block a:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block a:if="{{detail.status==1&&detail.refund_status==0}}"><view class="f1"><block a:if="{{!detail.worker_id}}"><block><view class="t2">我们会尽快为您派单</view></block></block><block a:else><block><view class="t2">订单已接单</view></block></block></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单服务中</view></view></block><block a:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block a:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block><view class="orderx"><image src="{{pre_url+'/static/img/orderx.png'}}"></image></view></view><view class="orderinfo orderinfotop"><view class="title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><view class="item"><text class="t1">预约时间</text><text class="t2">{{detail.yy_time}}</text></view></view><block a:if="{{detail.formdata.length>0}}"><view class="orderinfo"><view class="item" a:for="{{detail.formdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><text class="t1">{{item[0]}}</text><block a:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><block a:if="{{item[2]=='upload_video'}}"><view class="t2"><video style="width:100%;" src="{{item[1]}}"></video></view></block><block a:else><block a:if="{{item[2]=='upload_pics'}}"><view class="t2"><block a:for="{{item[1]}}" a:for-item="vv" a:for-index="__i1__" a:key="*this"><image style="width:200rpx;height:auto;margin-right:10rpx;" src="{{vv}}" mode="widthFix" data-url="{{vv}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></view></block><block a:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></block></block></view></view></block><view class="product"><view class="title">服务信息</view><view class="content"><view data-url="{{'product?id='+prolist.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{prolist.propic}}"></image></view><view class="detail"><text class="t1">{{prolist.proname}}</text><view class="t2 flex flex-y-center flex-bt"><text>{{prolist.ggname}}</text><block a:if="{{detail.status==3&&prolist.iscomment==0}}"><view class="btn3" data-url="{{'comment?oid='+prolist.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去评价</view></block><block a:if="{{detail.status==3&&prolist.iscomment==1}}"><view class="btn3" data-url="{{'comment?oid='+prolist.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看评价</view></block></view><view class="t3"><text class="x1 flex1">{{"￥"+prolist.product_price}}</text><text class="x2">{{"×"+prolist.num}}</text></view></view></view></view><block a:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">{{resetname?'服务金额':'商品金额'}}</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><view class="item"><text class="t1">订单金额</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block a:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block a:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block a:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block a:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><block a:if="{{detail.dec_money>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.dec_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.paymoney}}</text></view><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block a:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block a:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block a:if="{{detail.status==2&&detail.worker&&detail.worker.endtime}}"><text class="t2">待确认</text></block><block a:else><block a:if="{{detail.status==2}}"><text class="t2">服务中</text></block></block><block a:if="{{detail.status==3}}"><text class="t2">已完成</text></block><block a:if="{{detail.status==4}}"><text class="t2">已关闭</text></block><block a:if="{{detail.refundCount}}"><text style="margin-left:8rpx;">{{"有退款("+detail.refundCount+")"}}</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.paytypeid}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">派单时间</text><text class="t2">{{detail.send_time}}</text></view></block><block a:if="{{detail.status>1&&detail.addmoney>0}}"><view class="item"><text class="t1">补差价</text><text class="t2 red">{{"￥"+detail.addmoney}}</text></view></block><block a:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">完成时间</text><text class="t2">{{detail.collect_time}}</text></view></block><view class="item"><text class="t1">服务方式</text><text class="t2"><block a:if="{{detail.fwtype==2}}"><block>{{''+text['上门服务']+''}}</block></block><block a:if="{{detail.fwtype==3}}"><block>到商家服务</block></block><block a:if="{{detail.fwtype==1}}"><block>{{''+text['到店服务']+''}}</block></block></text></view><block a:if="{{detail.remark&&detail.show_remark}}"><view class="item"><text class="t1">备注</text><text class="t2" data-remark="{{detail.remark}}" data-event-opts="{{[['longTap',[['copyRemark',['$event']]]],['tap',[['gotourl',['$0'],['detail.remark_tourl']]]]]}}" onLongTap="__e" onTap="__e">{{detail.remark}}</text></view></block><block a:if="{{detail.fwbid&&detail.fwbinfo}}"><block><view class="item"><text class="t1">商家名称</text><text class="t2">{{detail.fwbinfo.name}}</text></view><block a:if="{{detail.fwbinfo.address}}"><view class="item"><view class="t1">商家地址</view><block a:if="{{!detail.fwbinfo.latitude||!detail.fwbinfo.longitude}}"><view class="t2">{{''+detail.fwbinfo.address+''}}</view></block><block a:else><view class="t2" data-latitude="{{detail.fwbinfo.latitude}}" data-longitude="{{detail.fwbinfo.longitude}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e">{{''+detail.fwbinfo.address+''}}</view></block></view></block></block></block><block a:if="{{detail.guarantee_start_date&&detail.guarantee_end_date}}"><view class="item"><text class="t1">保质期</text><text class="t2">{{detail.guarantee_start_date+" - "+detail.guarantee_end_date}}</text></view></block><block a:if="{{detail.remark_pics&&detail.remark_pics.length>0}}"><view class="item" style="align-items:center;"><text class="t1">图片</text><view class="t2"><view class="pics-content flex-row"><view class="pic-img" a:for="{{detail.remark_pics}}" a:for-item="pic" a:for-index="__i2__"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block></view><view class="orderinfo"><view class="title"><block a:if="{{!detail.carid}}"><block>顾客信息</block></block><block a:else><block><block a:if="{{detail.fwtype==2}}"><block>{{''+text['上门服务']+''}}</block></block><block a:if="{{detail.fwtype==3}}"><block>到商家服务</block></block><block a:if="{{detail.fwtype==1}}"><block>{{''+text['到店服务']+''}}</block></block></block></block></view><view class="item"><text class="t1">姓名</text><text class="t2">{{detail.linkman}}</text></view><view class="item"><text class="t1">手机号</text><text class="t2">{{detail.tel}}</text></view><block a:if="{{!detail.carid}}"><block><block a:if="{{detail.fwtype==2}}"><view class="item"><text class="t1">上门地址</text><text class="t2">{{detail.area+" "+detail.address}}</text></view></block></block></block><block a:else><block><block a:if="{{detail.fwtype==2}}"><block><view class="item"><text class="t1">车辆位置</text><text class="t2">{{detail.area}}</text></view><view class="item"><text class="t1">停靠位置</text><text class="t2">{{detail.address}}</text></view></block></block><view class="item"><text class="t1">车辆信息</text><text class="t2">{{detail.car_number+"."+detail.car_color+"."+(detail.car_type==1?'SUV':detail.car_type==2?'MPV':'轿车')}}</text></view></block></block></view><view class="orderinfo"><view class="title">店铺信息</view><view class="item"><text class="t1">店铺名称</text><text class="t2">{{detail.binfo.name}}</text></view><view class="item"><text class="t1">店铺地址</text><text class="t2">{{detail.binfo.fulladdress}}</text></view></view><block a:if="{{detail.show_service_pics}}"><view class="orderinfo"><view class="title">服务图片</view><block a:if="{{detail.service_before_pics.length>0}}"><view class="item flex-bt" style="align-items:center;"><text class="t1">施工前</text><view class="t2"><view class="pics-content flex-row"><view class="pic-img" a:for="{{detail.service_before_pics}}" a:for-item="pic" a:for-index="__i3__"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block><block a:if="{{detail.service_pics.length>0}}"><view class="item flex-bt" style="align-items:center;"><text class="t1">施工中</text><view class="t2"><view class="pics-content flex-row"><view class="pic-img" a:for="{{detail.service_pics}}" a:for-item="pic" a:for-index="__i4__"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block><block a:if="{{detail.service_finish_pics.length>0}}"><view class="item flex-bt" style="align-items:center;"><text class="t1">完成施工</text><view class="t2"><view class="pics-content flex-row"><view class="pic-img" a:for="{{detail.service_finish_pics}}" a:for-item="pic" a:for-index="__i5__"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block a:if="{{detail.isworkorder==1}}"><block><view class="btn2" data-url="{{'/pagesB/workorder/index?type=2&id='+detail.id}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">发起工单</view></block></block><block a:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" onTap="__e">关闭订单</view><block a:if="{{detail.paytypeid!=5}}"><view class="btn1" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去付款</view></block><block a:if="{{detail.paytypeid==5}}"><view class="btn1" style="{{'background:'+($root.m5)+';'}}" data-url="{{'/pages/pay/transfer?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">上传付款凭证</view></block></block></block><block a:if="{{detail.status==1}}"><block><block a:if="{{detail.paytypeid!='4'&&detail.refund_status==0||detail.refund_status==3}}"><block><view class="btn2" data-url="{{'refund?orderid='+detail.id+'&price='+detail.paymoney}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">退款</view></block></block></block></block><block a:if="{{hexiao_status&&detail.hexiao_code&&(detail.status==1||detail.status==2)}}"><block><view class="btn2" data-id="{{detail.id}}" data-hexiao_code="detail.hexiao_code" data-hexiao_qr="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" catchTap="__e">核销码</view></block></block><block a:if="{{(detail.status==2||detail.status==3||detail.worker_id>0)&&detail.status!=4}}"><block><view class="btn2" data-express_com="{{detail.express_com}}" data-express_no="{{detail.worker_orderid}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" onTap="__e">查看进度</view></block></block><block a:if="{{detail.status==2}}"><block><block a:if="{{detail.balance_pay_status==0&&detail.balance_price>0}}"><view class="btn1" style="{{'background:'+($root.m6)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.balance_pay_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">支付尾款</view></block></block></block><block a:if="{{detail.status==3||detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除订单</view></block></block><block a:if="{{detail.bid>0&&detail.status==3}}"><block><block a:if="{{iscommentdp==1}}"><view class="btn2" data-url="{{'commentdp?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看评价</view></block></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="198b303f-1" onVueInit="__l"></loading></block><uni-popup vue-id="198b303f-2" id="dialogHxqr" type="dialog" ref="__r" data-ref="dialogHxqr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><dp-tabbar vue-id="198b303f-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="198b303f-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>