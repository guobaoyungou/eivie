<view class="container"><block a:if="{{isload}}"><block><view class="content flex" data-id="{{item.id}}" data-realname="{{item.realname}}" data-tel="{{item.tel}}" data-yystatus="{{item.yystatus}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><view class="headimg"><block a:if="{{item.headimg}}"><image src="{{item.headimg}}"></image></block><block a:else><image src="{{pre_url+'/static/img/touxiang.png'}}"></image></block></view><view class="text1"><text class="t1">{{item.realname+''}}</text><block a:if="{{item.typename}}"><text class="t2">{{item.typename}}</text></block><view class="text2">{{item.jineng}}</view></view></view><view class="{{('yuyue '+(item.yystatus==-1?'hui':''))}}">预约</view></view><block a:if="{{nodata}}"><nodata vue-id="cc5f87c2-1" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="cc5f87c2-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="cc5f87c2-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="cc5f87c2-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>