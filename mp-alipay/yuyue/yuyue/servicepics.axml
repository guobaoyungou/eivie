<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-content"><view class="form-item flex-bt"><view class="label">施工前<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><view class="layui-imgbox" a:for="{{service_before_pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_before_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_before_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></view><view class="form-item flex-bt"><view class="label">施工中<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><view class="layui-imgbox" a:for="{{service_pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></view><view class="form-item flex-bt"><view class="label">完成施工<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><view class="layui-imgbox" a:for="{{service_finish_pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_finish_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_finish_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></view></view><button class="btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">提交</button><view style="padding-top:30rpx;"></view><view style="display:none;">{{txt}}</view></form></block></block><block a:if="{{loading}}"><loading vue-id="22e36860-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="22e36860-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="22e36860-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>