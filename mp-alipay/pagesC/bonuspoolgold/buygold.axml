<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;"></text>{{userinfo.gold}}</view><view class="f1">{{"当前"+$root.m2+"价值："+set.gold_price}}</view><view class="f3" data-url="/pagesC/bonuspoolgold/goldlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{$root.m3+"记录"}}</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">购买金额(元)</view></view><block a:if="{{set.caninput==1||giveset.length==0}}"><view class="item3"><view class="f2"><input class="input" type="digit" name="buy_num" placeholder="请输入购买金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{buy_num}}" onInput="__e"/></view></view></block><block a:if="{{giveset.length>0}}"><view class="giveset"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.$orig>0}}"><view class="{{(('item')+' '+(buy_num==item.$orig?'active':''))}}" style="{{(buy_num==item.$orig?'background:'+item.m4:'')}}" data-money="{{item.$orig}}" data-event-opts="{{[['tap',[['selectgiveset',['$event']]]]]}}" onTap="__e"><text class="t1">{{item.$orig+"元"}}</text></view></block></block></view></block><block a:if="{{set.show_buy_fee==1}}"><view class="tips-box"><view class="item4 tips"><block a:if="{{set.bonuspool_gold_rate>0}}"><text>{{"购买手续费"+set.bonuspool_gold_rate+'%'}}</text></block></view></view></block></view><view class="withdrawtype"><view class="f1">选择支付方式：</view><view class="f2"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index"><view class="item" data-paytype="{{item.$orig.type}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1">{{item.$orig.name}}<block a:if="{{item.$orig.type!='online'}}"><text>{{"(余额："+item.$orig.remain+")"}}</text></block></view><view class="radio" style="{{(paytype==item.$orig.type?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" onTap="__e">立即购买</button></form><block a:if="{{set.desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{set.desc}}</text></view></block></block></block><block a:if="{{loading}}"><loading vue-id="46d7ecec-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="46d7ecec-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="46d7ecec-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>