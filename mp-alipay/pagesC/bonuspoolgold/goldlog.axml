<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{mygold}}<view class="btn-mini" data-url="/pagesC/bonuspoolgold/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">兑换</view></view><view class="f1">{{"当前每个"+$root.m2+"价值"+set.gold_price+"元"}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row" data-url="{{'/pagesB/my/greenscorelog?jilu_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="column"><text>{{"金币数量: "+item.value}}</text><text>{{"剩余数量: "+item.remain}}</text></view><view class="column"><text>{{"获取价格: "+item.gold_price}}</text></view></view><view class="item-row highlight"><text>{{"可提取金额: "+item.gold_value}}</text></view><view class="item-row"><text class="time">{{item.remark+" "+item.createtime}}</text></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="3799a0ae-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="3799a0ae-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="3799a0ae-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="3799a0ae-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="3799a0ae-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>