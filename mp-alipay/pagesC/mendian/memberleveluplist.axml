<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{$root.m0+"列表（共"+count+"人）"}}</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><view class="x1 flex-y-center">{{''+item.nickname+"(ID："+item.id+')'}}<block a:if="{{item.sex==1}}"><image style="margin-left:10rpx;width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/nan2.png'}}"></image></block><block a:if="{{item.sex==2}}"><image style="margin-left:10rpx;width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/nv2.png'}}"></image></block></view><block a:if="{{item.add_mendian_time}}"><block><text class="x2">{{"加入时间："+item.add_mendian_time}}</text></block></block><block a:if="{{item.tel}}"><block><text class="x2">{{"手机号："+item.tel}}</text></block></block></view></view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="36362042-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="36362042-2" onVueInit="__l"></nodata></block></block></block><popmsg vue-id="36362042-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="36362042-4" onVueInit="__l"></loading></block></view>