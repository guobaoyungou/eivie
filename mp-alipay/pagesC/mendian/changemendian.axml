<view><block a:if="{{isload}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{$root.m0+"列表（共"+count+"个）"}}</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['changeMendian',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="item" onTap="__e"><view class="f1"><image src="{{item.pic}}"></image><view class="t2"><text>{{item.name}}</text><text class="x2">{{item.address}}</text></view></view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="57414ea6-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="57414ea6-2" onVueInit="__l"></nodata></block></block></block><popmsg vue-id="57414ea6-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="57414ea6-4" onVueInit="__l"></loading></block></view>