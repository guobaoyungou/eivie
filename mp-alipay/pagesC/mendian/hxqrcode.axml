<scroll-view class="pageContainer"><block a:if="{{isload}}"><view><block a:if="{{data.hxqrcode}}"><view class="container nodiydata"><view class="topcontent"><view class="logo"><image class="img" src="{{data.hxqrcode}}" data-url="{{data.hxqrcode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="topcontent1"><view class="title" style="margin-top:20rpx;font-size:42rpx;font-weight:bold;">{{"向"+$root.m0+"出示二维码提货"}}</view><block a:if="{{data.mendiantel}}"><view class="title" style="margin-top:20rpx;font-size:28rpx;">{{$root.m1+"客服："}}<text class="tel" style="color:#1E9FFF;" data-tel="{{data.mendiantel}}" data-event-opts="{{[['tap',[['calltel',['$event']]]]]}}" onTap="__e">{{data.mendiantel}}</text></view></block></view><view class="topcontent1"><button data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="btn" catchTap="__e">返回</button></view></view></block><block a:if="{{nodata}}"><nodata vue-id="0bbf5dc5-1" onVueInit="__l"></nodata></block></view></block><popmsg vue-id="0bbf5dc5-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="0bbf5dc5-3" onVueInit="__l"></loading></block><wxxieyi vue-id="0bbf5dc5-4" onVueInit="__l"></wxxieyi></scroll-view>