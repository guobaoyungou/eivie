<view class="container"><block a:if="{{isload}}"><block><block><dd-tab vue-id="a8a0b4be-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.headimg}}" mode="widthFix"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.mid+")"}}</text><text class="x2">{{"等级："+item.level_name}}</text><block a:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block a:if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block></view></view></view></block></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="a8a0b4be-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="a8a0b4be-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="a8a0b4be-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="a8a0b4be-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="a8a0b4be-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>