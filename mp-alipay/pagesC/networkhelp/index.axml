<block a:if="{{isload}}"><view class="container"><view class="score-card" style="{{'background:'+($root.m0)+';'}}"><view class="score-title">{{$root.m1}}</view><view class="score-value">{{member_help_score}}</view><view class="score-info-row"><view class="score-info-item" data-url="/pagesC/networkhelp/helpscorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="info-label">{{"累计"+$root.m2+"："}}</view><view class="info-value">{{total_bonus.help_score_total}}</view></view><view class="score-info-item" data-url="/activity/commission/commissionlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="info-label">{{$root.m3+"："}}</view><view class="info-value">{{total_bonus.commission_total}}</view></view></view><view class="score-info-row"><view class="score-info-item" data-url="/pagesExt/money/moneylog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="info-label">{{$root.m4+"："}}</view><view class="info-value">{{total_bonus.money_total}}</view></view><view class="score-info-item" data-url="/pagesExt/my/scorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="info-label">{{$root.m5+"："}}</view><view class="info-value">{{total_bonus.score_total}}</view></view></view></view><view class="divider"></view><view class="content" style="{{'background:'+($root.m6)+';'}}"><view class="level-tabs"><block a:for="{{active_list}}" a:for-item="active" a:for-index="index"><view data-event-opts="{{[['tap',[['changeTab',['$0'],[[['active_list','',index,'id']]]]]]]}}" class="{{(('tab-item')+' '+(active_id==active.id?'active':''))}}" onTap="__e">{{active.name}}</view></block></view><view class="user-info"><view class="user-count">{{"活动人脉："+down_members}}</view><view class="user-type" data-url="{{'/pagesC/networkhelp/myteam?active_id='+active_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">点击查看</view></view><view class="level-list"><view class="level-item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index2"><view class="level-left"><view class="level-line" style="{{'background:'+($root.m7)+';'}}"></view><view class="level-content"><view class="level-header"><view class="level-name">{{item.$orig.name}}</view><block a:if="{{item.$orig.is_up==1}}"><view class="level-tag creator" style="{{'background:'+(item.m8)+';'}}">已激活</view></block><block a:if="{{item.$orig.is_up==0}}"><view class="level-tag no-creator">未激活</view></block></view><view class="level-condition">{{"达标条件："+item.$orig.up_con}}</view></view></view><view class="level-right" data-url="/activity/commission/poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="level-action">>> 邀请好友</view></view></view></view></view><block a:if="{{loading}}"><loading vue-id="74db8ba8-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="74db8ba8-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="74db8ba8-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>