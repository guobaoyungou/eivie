<view class="sel-seat"><block a:if="{{isload}}"><block><view style="background-color:#ffff;position:relative;z-index:9;"><view style="width:680rpx;margin:auto;line-height:40rpx;padding:10rpx 0;text-align:center;"><view style="font-weight:bold;">{{perform.title}}</view><view>{{"日期："+perform.performDate+" "+perform.performTime}}</view></view></view><view class="seat-main"><movable-area class="vm-area" style="height:100%;"><movable-view style="{{('width: '+boxWidth+'px;height:'+boxHeight+'px;')}}" inertia="{{true}}" scale="{{true}}" scale-min="{{0.95}}" x="{{-(boxWidth/2)+200}}" scale-max="{{2}}" direction="all" out-of-bounds="{{true}}" data-event-opts="{{[['scale',[['onScale',['$event']]]]]}}" onScale="__e"><view class="sm-title"><text class="text">舞台方向</text></view><view class="sm-cell" style="{{('height:'+seatSize+'px;justify-content:'+cellJustifycontent)}}" a:for="{{seatArray}}" a:for-item="item" a:for-index="index" a:key="index"><block a:for="{{item}}" a:for-item="seat" a:for-index="col" a:key="col"><block a:if="{{seat.twoSeater&&seat.twoSeater==1}}"><block><block a:if="{{seat.type>-3}}"><view data-event-opts="{{[['tap',[['handleChooseSeat',[index,col]]]]]}}" class="dp-ib-suang" style="{{('width:'+(seatSize*2+3)+'px;height:'+seatSize+'px')}}" onTap="__e"><block a:if="{{seat.type>=0}}"><block><block a:if="{{seat.type===1}}"><image style="width:100%;height:100%;position:absolute;top:0;left:0;" src="{{pre_url+'/static/img/seat/issel2.png'}}"></image></block><view class="dp-item" style="{{('background:'+seat.areacolor)}}"></view></block></block><block a:else><block a:if="{{seat.type==-1}}"><block><view class="dp-item" style="background:#dddddd;"></view></block></block></block></view></block></block></block><block a:else><block><block a:if="{{seat.type>-3}}"><view data-event-opts="{{[['tap',[['handleChooseSeat',[index,col]]]]]}}" class="dp-ib" style="{{('width:'+seatSize+'px;height:'+seatSize+'px')}}" onTap="__e"><block a:if="{{seat.type>=0}}"><block><block a:if="{{seat.type===1}}"><image style="width:100%;height:100%;position:absolute;top:0;left:0;" src="{{pre_url+'/static/img/seat/issel.png'}}"></image></block><view class="dp-item" style="{{('background:'+seat.areacolor)}}"></view></block></block><block a:else><block a:if="{{seat.type==-1}}"><block><view class="dp-item" style="background:#dddddd;"></view></block></block></block></view></block></block></block></block></view><block a:if="{{mArr&&mArr.length>0}}"><view class="sm-line-index" style="{{('left: '+(10-moveX/scale)+'px;')}}"><text class="text" style="{{('height:'+seatSize+'px;')}}" a:for="{{mArr}}" a:for-item="m" a:for-index="mindex" a:key="mindex">{{m}}</text></view></block></movable-view></movable-area></view><view style="width:100%;height:400rpx;"></view><view class="seat-foot" style="position:fixed;width:100%;bottom:0;left:0;"><view class="fix-tips"><block a:for="{{areaData}}" a:for-item="item" a:for-index="index" a:key="index"><view class="v-tips"><view class="tip-areacolor" style="{{('background:'+item.areacolor)}}"></view><text class="text">{{item.areaname}}</text></view></block><view class="v-tips"><view class="tip-areacolor" style="background:#dddddd;"></view><text class="text">不可选</text></view></view><view class="sf-arselect"><view class="text">已选(<text style="color:red;">{{SelectNum}}</text>)</view><scroll-view style="margin-bottom:20rpx;" scroll-x="true"><view class="scr-wrap"><view data-event-opts="{{[['tap',[['handleChooseSeat',['$0','$1'],[[['optArr','SeatCode',optItem.SeatCode,'rowIndex']],[['optArr','SeatCode',optItem.SeatCode,'colIndex']]]]]]]}}" class="sfr-selt" onTap="__e" a:for="{{optArr}}" a:for-item="optItem" a:for-index="optindex" a:key="SeatCode"><view><view class="text" style="line-height:40rpx;">{{optItem.RowNum+'排'+optItem.ColumnNum+'座'}}</view><block a:if="{{optItem.Price>=0}}"><view class="price">{{"￥"+optItem.Price}}</view></block></view><view class="sfr-close">X</view></view></view></scroll-view></view><view class="f-btn"><block a:if="{{SelectNum>0}}"><view data-event-opts="{{[['tap',[['buySeat',['$event']]]]]}}" style="background-color:#F45664;" onTap="__e"><view class="text"><block a:if="{{aPrice>=0}}"><text>{{"￥"+aPrice}}</text></block>确认座位</view></view></block><block a:else><view style="background-color:#F45664;opacity:0.7;"><text class="text">请选座位</text></view></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="e295b47c-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="e295b47c-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="e295b47c-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="e295b47c-4" onVueInit="__l"></wxxieyi></view>