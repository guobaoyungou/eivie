<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="35a84255-1" itemdata="{{['全部','待付款','待发码','待核销','已核销','退款/售后']}}" itemst="{{['all','0','1','2','3','5']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head flex" style="align-items:center;"><view>{{"订单号："+item.$orig.ordernum}}</view><block a:if="{{item.$orig.status==0}}"><view class="st0 flex-y-center">待付款</view></block><block a:if="{{item.$orig.status==1}}"><view class="st1 flex-y-center">待发码</view></block><block a:if="{{item.$orig.status==2}}"><view class="st2 flex-y-center">待核销</view></block><block a:if="{{item.$orig.status==3}}"><view class="st3 flex-y-center">已核销</view></block><block a:if="{{item.$orig.status==4}}"><view class="st4 flex-y-center">已关闭</view></block></view><view class="content" style="border-bottom:none;"><view class="detail"><view style="display:flex;margin-bottom:20rpx;"><block a:if="{{item.$orig.pic}}"><view class="content-pic"><image style="width:100%;border-radius:10rpx 10rpx;" src="{{item.$orig.pic}}" mode="widthFix"></image></view></block><view style="margin-left:10rpx;"><view class="title">{{item.$orig.title}}</view><view class="title2">{{"日期："+item.$orig.performDate}}</view><view class="title2">{{"时间："+item.$orig.performTime}}</view></view></view><view style="background-color:#fff;border-bottom:8rpx;"><view style="border-top:2rpx solid #f1f1f1;padding:20rpx;"><view style="color:#191919;font-weight:bold;">{{item.$orig.theaterPlaceName}}</view><block a:if="{{item.$orig.beforeCheckTime&&item.$orig.beforeCheckTime>0}}"><view style="color:#191919;">{{"提前检票时间："+item.$orig.beforeCheckTime+"分钟"}}</view></block><block a:if="{{item.$orig.beforeTime&&item.$orig.beforeTime>0}}"><view style="color:#191919;">{{"提前演出入场时间："+item.$orig.beforeTime+"分钟"}}</view></block><block a:if="{{item.$orig.timeLong&&item.$orig.timeLong>0}}"><view style="color:#191919;">{{"演出时长："+item.$orig.timeLong+"分钟"}}</view></block><block a:if="{{item.$orig.address}}"><view style="color:#999;font-size:26rpx;">{{"地址："+item.$orig.address}}</view></block></view></view></view></view><block a:for="{{item.$orig.ordergoods}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="content"><view style="color:#191919;font-weight:bold;line-height:50rpx;">{{item2.areaName}}</view><block a:for="{{item2.certs}}" a:for-item="item3" a:for-index="index3" a:key="index3"><view class="detail"><text class="t1">{{item3.fname}}</text><block a:if="{{item3.realName||item3.certNo}}"><view class="t2">{{item3.realName+" "+item3.certNo}}</view></block><block a:if="{{item.$orig.checkCodeType==2&&item3.status>=1&&item3.status<=4}}"><view class="status-view flex flex-y-center"><block a:if="{{item3.status==1}}"><view style="color:#ff8758;">待发码</view></block><block a:if="{{item3.status==2}}"><view style="color:green;">待核销</view></block><block a:if="{{item3.status==3}}"><view style="color:red;">已核销</view></block><block a:if="{{item3.status==4}}"><view style="color:#bbb;">已驳回</view></block></view></block><block a:if="{{item3.refund_status!=0}}"><view class="status-view flex flex-y-center" style="justify-content:space-between;"><block a:if="{{item3.refund_status!=0}}"><view style="display:flex;margin-right:20rpx;"><view style="color:#8D8D8D;font-weight:bold;">退款状态：</view><block a:if="{{item3.refund_status==1}}"><text style="color:#ff8758;">审核中</text></block><block a:if="{{item3.refund_status==2}}"><text style="color:green;">已审核</text></block><block a:if="{{item3.refund_status==3}}"><text style="color:red;">已退款</text></block><block a:if="{{item3.refund_status==4}}"><text style="color:#bbb;">已驳回</text></block></view></block></view></block><block a:if="{{item3.status==2&&item3.hexiao_qr}}"><block><view class="btn2" style="position:absolute;top:40rpx;right:10rpx;" data-hexiao_qr="{{item3.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" catchTap="__e">核销码</view></block></block></view></block></view></block><block a:if="{{item.$orig.othermsg}}"><view style="line-height:40rpx;padding:10rpx 0;">{{item.$orig.othermsg}}</view></block><view class="bottom flex" style="flex-wrap:wrap;"><view class="flex-y-center"><view class="title-text">实付：</view><view class="price-text flex flex-y-center"><text style="font-size:24rpx;">￥</text>{{item.$orig.totalprice+''}}</view><block a:if="{{item.$orig.refund_money>0}}"><view style="color:red;font-size:26rpx;">(<text>已退款:</text><text>{{"￥"+item.$orig.refund_money}}</text>)</view></block></view><block a:if="{{item.$orig.refund_money>0&&item.$orig.refund_reason}}"><view style="color:red;font-size:26rpx;width:100%;text-align:right;"><text>{{"退款原因："+item.$orig.refund_reason}}</text></view></block></view><view class="op"><block a:if="{{item.$orig.status==2&&item.$orig.hexiao_qr}}"><block><view class="btn2" data-hexiao_qr="{{item.$orig.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" catchTap="__e">核销码</view></block></block><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e"><text>关闭订单</text></view><block a:if="{{item.$orig.canpay}}"><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去付款</view></block></block></block><block a:if="{{item.$orig.canrefund}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">退款</view></block><block a:if="{{item.$orig.refundcount>0}}"><view class="btn2" data-url="{{'refundlist?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">售后详情</view></block><block a:if="{{item.$orig.candel}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchTap="__e">删除订单</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="35a84255-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="35a84255-3" onVueInit="__l"></nodata></block><uni-popup vue-id="35a84255-4" id="dialogHxqr" type="dialog" ref="__r" data-ref="dialogHxqr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="35a84255-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="35a84255-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="35a84255-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>