<block a:if="{{isload}}"><view class="page-view"><view class="top-view flex-col"><scroll-view style="height:676rpx;width:100%;position:relative;padding-bottom:20rpx;" scroll-y="{{true}}"><calendar vue-id="e5e67ea2-1" is-show="{{true}}" isFixed="{{false}}" between-start="{{betweenStart}}" between-end="{{betweenEnd}}" initMonth="24" ys-num="{{ysNum}}" choose-type="{{chooseType}}" start-date="{{startDate}}" end-date="{{endDate}}" tip-data="{{tipData}}" mode="{{mode}}" showhas="{{true}}" dayPerforms="{{dayPerforms}}" themeColor="{{$root.m0}}" data-event-opts="{{[['^callback',[['getCalendar']]]]}}" onCallback="__e" onVueInit="__l"></calendar></scroll-view></view><block a:if="{{datalist&&datalist.length>0}}"><view style="width:95%;margin:20rpx auto;"><view class="content" data-url="{{'detail?id='+item.id+'&playDate='+playDate}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view style="display:flex;"><block a:if="{{item.pic}}"><view class="content-pic"><image style="width:100%;border-radius:10rpx 10rpx;height:auto;min-height:0;" src="{{item.pic}}" mode="widthFix"></image></view></block><view style="margin-left:10rpx;"><view class="content-title">{{item.title}}</view><view class="content-title2">{{"日期："+item.performDate}}</view><view class="content-title2">{{"时间："+item.performTime}}</view><view class="title2" style="{{('color:'+$root.m1)}}"><block a:if="{{item.price>=0}}"><text>{{"￥"+item.price+"起"}}</text></block><block a:else><text>暂无价格</text></block></view></view></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="e5e67ea2-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="e5e67ea2-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="e5e67ea2-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="e5e67ea2-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="e5e67ea2-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>