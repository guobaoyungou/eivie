<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="64a6ac11-1" itemdata="{{['全部','审核中','已审核','已通过','已驳回']}}" itemst="{{['all','1','2','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.binfo}}"><block><block a:if="{{item.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block a:else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></block></block><view class="flex1"></view><block a:if="{{item.refund_status==0}}"><text class="st3">已取消</text></block><block a:if="{{item.refund_status==1}}"><text class="st0">审核中</text></block><block a:if="{{item.refund_status==2}}"><text class="st4" style="color:green;">已审核</text></block><block a:if="{{item.refund_status==3}}"><text class="st2">已通过</text></block><block a:if="{{item.refund_status==4}}"><text class="st2">已驳回</text></block></view><block a:for="{{item.refundgoods}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view class="detail"><text class="t1">{{item2.fname}}</text><text class="t2">{{item2.realName+" "+item2.certNo}}</text></view></view></block><block a:if="{{item.refund_status==3}}"><view class="bottom"><block a:if="{{item.refund_status==3}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block></view></block><view class="op"><view class="btn2" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">详情</view><block a:if="{{item.refund_status==1}}"><block><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">取消</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="64a6ac11-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="64a6ac11-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="64a6ac11-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="64a6ac11-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="64a6ac11-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>