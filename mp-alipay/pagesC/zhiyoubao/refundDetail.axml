<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop_refund.jpg);background-size:100%')}}"><block a:if="{{detail.refund_status==0}}"><view class="f1"><view class="t1">已取消</view></view></block><block a:if="{{detail.refund_status==1}}"><view class="f1"><view class="t1">审核中</view></view></block><block a:if="{{detail.refund_status==2}}"><view class="f1"><view class="t1">已审核</view></view></block><block a:if="{{detail.refund_status==3}}"><view class="f1"><view class="t1">已通过</view></view></block><block a:if="{{detail.refund_status==4}}"><block><view class="t1">已驳回</view></block></block></view><block a:if="{{detail.refundgoods&&detail.refundgoods.length>0}}"><view class="product"><view class="content" a:for="{{detail.refundgoods}}" a:for-item="item" a:for-index="idx" a:key="idx"><view class="detail"><text class="t1">{{item.fname}}</text><text class="t2">{{item.realName+" "+item.certNo}}</text></view></view></view></block><view class="orderinfo"><view class="item"><text class="t1">售后单编号</text><text class="t2" user-select="true" selectable="true">{{detail.refund_ordernum}}</text></view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true" data-url="{{'detail?id='+detail.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{detail.ordernum}}</text></view><view class="item"><text class="t1">申请时间</text><text class="t2">{{detail.createtime}}</text></view></view><view class="orderinfo"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==0}}"><text class="t2 grey">已取消</text></block><block a:if="{{detail.refund_status==1}}"><text class="t2 red">审核中</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">已审核</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已通过￥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==4}}"><text class="t2 red">已驳回</text></block></view><view class="item"><text class="t1">原因</text><text class="t2">{{detail.refund_reason}}</text></view><block a:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2">{{detail.refund_checkremark}}</text></view></block><block a:if="{{detail.refund_pics}}"><view class="item"><text class="t1">图片</text><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{detail.refund_pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view></block></block><block a:if="{{loading}}"><loading vue-id="41d57544-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="41d57544-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="41d57544-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="41d57544-4" onVueInit="__l"></wxxieyi></view>