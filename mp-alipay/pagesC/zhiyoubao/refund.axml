<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><block a:if="{{ordergoods}}"><block><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="form-content"><view style="color:#191919;font-weight:bold;line-height:50rpx;width:96%;margin:0 2%;margin-top:10rpx;">{{item.$orig.areaName}}</view><view class="product"><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="content"><view class="radio" style="{{(item2.$orig.issel?'border:0;background:'+item2.m0:'')}}" data-index="{{index}}" data-index2="{{index2}}" data-certid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" onTap="__e"><image class="radio-img" style="width:100%;height:100%;" mode="widthFix" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="detail" data-index="{{index}}" data-index2="{{index2}}" data-certid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" onTap="__e"><text class="t1">{{item2.$orig.realName+" "+item2.$orig.certNo}}</text></view></view></block></view></view></block></block></block><view class="form-item"><text class="label">退款原因</text><view class="input-item"><textarea style="width:100%;border:2rpx solid #f1f1f1;border-radius:4rpx;padding:10rpx;" placeholder="请输入退款原因" placeholder-style="color:#999;padding: 10rpx;" name="reason"></textarea></view></view><block a:if="{{showpic}}"><view class="form-item flex-col"><view class="label">上传图片</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="pics"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<3}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view></view></block><button class="ref-btn" form-type="submit">确定</button></form><block a:if="{{loading}}"><loading vue-id="ae2a9122-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="ae2a9122-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="ae2a9122-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></block></block></view>