<view><block a:if="{{isload&&is_show}}"><block><view class="content-view"><scroll-view scroll-y="{{true}}"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="options-view flex flex-y-center flex-bt"><view class="user-info flex"><image src="{{pre_url+'/static/img/vehicle/chelianglist.png'}}"></image><view class="user-info-right flex flex-col"><view class="name-text">{{item.$orig.car_num}}</view><view class="release-time">{{"录入时间："+item.m0}}</view></view></view><view data-event-opts="{{[['tap',[['editCar',['$0'],[[['lists','',index,'id']]]]]]]}}" class="edit-but" onTap="__e"><image src="{{pre_url+'/static/img/editicon.png'}}"></image></view><view data-event-opts="{{[['tap',[['editTime',['$0'],[[['lists','',index,'id']]]]]]]}}" class="edit-time-but" onTap="__e"><image src="{{pre_url+'/static/img/vehicle/settime.png'}}"></image></view></view></block></scroll-view></view><view style="width:100%;height:calc(230rpx + env(safe-area-inset-bottom));"></view><view class="{{(('pageBottom-class')+' '+(menuindex>-1?'tabbarbot':'notabbarbot2'))}}"><button data-event-opts="{{[['tap',[['addCar',['$event']]]]]}}" class="pageBottom-but" style="{{'background:'+($root.m1)+';'}}" onTap="__e">添加</button></view></block></block><block a:if="{{nomore}}"><nomore vue-id="1a338e1a-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1a338e1a-2" onVueInit="__l"></nodata></block><dp-tabbar vue-id="1a338e1a-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar></view>