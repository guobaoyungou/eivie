<view class="container"><block a:if="{{isload}}"><block><view class="topfix"><view class="tongji flex-y-center " style="{{'background:'+(color1)+';'}}"><view><view class="price">{{total_back_price}}</view><view>{{"待补"+money_text}}</view></view><view><view class="price">{{total_money}}</view><view>{{"已补"+money_text}}</view></view></view><dd-tab vue-id="722c70d2-1" itemdata="{{['补贴记录','待补记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="margin-top:300rpx;"></view><view class="content"><block a:if="{{st==0}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex-bt flex-y-center"><view class="f1"><text class="t1"><block a:if="{{item.$orig.type==1&&item.$orig.cashback_name!=''}}"><text>{{item.$orig.cashback_name}}</text></block><block a:else><text>{{"补贴"+money_text}}</text></block>{{"："+item.$orig.money}}</text><text class="t2">{{item.$orig.createtime}}</text><block a:if="{{item.$orig.status==2}}"><text class="t2">{{"过期时间："+(item.$orig.expiretime||'')}}</text></block><block a:if="{{item.$orig.status==1}}"><text class="t2">{{"领取时间："+(item.$orig.collecttime||'')}}</text></block></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1" style="color:red;">待领取</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已领取</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已过期</text></block></view></view><block a:if="{{send_condition==false}}"><view class="flex-x-bottom"><block a:if="{{item.$orig.status==0}}"><view data-event-opts="{{[['tap',[['receiveinit',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m0)+';'}}" onTap="__e">领取</view></block></view></block></view></block></block><block a:if="{{st==1}}"><block><view class="item flex-xy-center" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后"+money_text+": "+item.after}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block a:else><text class="t2">{{item.money}}</text></block></view></view></block></block></view><block a:if="{{showvideo}}"><view class="video-container" style="height:100vh;"><block a:if="{{!showVideoClose&&this_play_seconds>0}}"><view class="close">{{this_play_seconds+"秒"}}</view></block><block a:if="{{showVideoClose}}"><view data-event-opts="{{[['tap',[['videoClose',['$event']]]]]}}" class="close" onTap="__e">关闭</view></block><video class="video" style="height:100vh;" id="video" autoplay="{{true}}" controls="{{false}}" src="{{video_url}}" data-event-opts="{{[['timeUpdate',[['timeupdate',['$event']]]],['ended',[['videoend',['$event']]]]]}}" onTimeUpdate="__e" onEnded="__e"></video></view></block><block a:if="{{send_condition}}"><view data-event-opts="{{[['tap',[['handleSignin',['$event']]]]]}}" class="signing" style="{{(signing?'background-color:rgba(17,17,17,0.3)':'background-color:'+$root.m1)}}" onTap="__e">{{signing?'已签到':'签到'}}</view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="722c70d2-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="722c70d2-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="722c70d2-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="722c70d2-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="722c70d2-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>