<view class="container"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'/pagesExt/mingpian/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="data" style="{{'background:'+(item.bgpic?'url('+item.bgpic+')':'#fff')+';'+('background-size:'+('100% 100%')+';')}}"><view class="data_info" style="{{(field_list2?'':'border:0;margin:0')}}"><image class="data_head _img" src="{{item.headimg}}" alt></image><view><view class="data_name">{{item.realname}}</view><block a:if="{{item.touxian1}}"><view class="data_text">{{item.touxian1}}</view></block><block a:if="{{item.touxian2}}"><view class="data_text">{{item.touxian2}}</view></block><block a:if="{{item.touxian3}}"><view class="data_text">{{item.touxian3}}</view></block></view></view><view class="data_list" a:for="{{field_list2}}" a:for-item="item2" a:for-index="index2"><block a:if="{{index2=='tel'}}"><image src="{{pre_url+'/static/images/tel.png'}}" alt class="_img"></image></block><block a:else><block a:if="{{index2=='weixin'}}"><image src="{{pre_url+'/static/images/weixin.png'}}" alt class="_img"></image></block><block a:else><block a:if="{{index2=='address'}}"><image src="{{pre_url+'/static/images/address.png'}}" alt class="_img"></image></block><block a:else><image src="{{item2.icon}}" alt class="_img"></image></block></block></block>{{''+item[index2]+''}}</view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="e4825828-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="e4825828-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="e4825828-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="e4825828-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e4825828-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>