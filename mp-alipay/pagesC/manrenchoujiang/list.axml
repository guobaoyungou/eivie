<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="67513328-1" itemdata="{{['待开奖','已开奖']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="coupon-list"><view class="coupon" data-url="{{'details?bid='+bid+'&rid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="pt_left"><view class="pt_left-content"><block a:if="{{item.pic}}"><image style="width:100%;max-height:200rpx;border-radius:4rpx;" src="{{item.pic}}" mode="widthFix"></image></block></view></view><view style="width:2rpx;height:100rpx;background-color:#eee;"></view><view class="pt_right"><view class="title" style="{{'color:'+($root.m0)+';'}}">{{item.proname}}</view><view class="t3" style="font-size:24rpx;padding:20rpx 0;"><block a:if="{{st==0}}"><view class="shortcontent">{{item.custom_text}}</view></block><block a:else><view class="shortcontent">{{"第"+item.cycles+"期开奖结果"}}</view></block></view><block a:if="{{st==0}}"><view class="p2" style="padding-bottom:20rpx;"><progress class="my-progress" percent="{{item.percent}}" stroke-width="6" border-radius="10" show-info="{{true}}" font-size="{{14}}" activeColor="#fb743b"></progress></view></block><block a:if="{{st==0}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" data-index="{{index}}" data-proid="{{item.proid}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchTap="__e">邀请好友</button></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="67513328-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="67513328-3" onVueInit="__l"></nodata></block><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m3=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m4}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m5!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="67513328-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="67513328-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="67513328-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>