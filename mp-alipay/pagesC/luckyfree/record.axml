<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><view class="list-item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item-row" style="margin-bottom:40rpx;"><view><block a:if="{{activity.business}}"><text class="tag" style="{{'background-color:'+($root.m0)+';'}}">{{activity.business+"免单"}}</text></block><block a:else><text class="tag" style="{{'background-color:'+($root.m1)+';'}}">平台免单</text></block></view><view style="font-weight:bold;">{{"第 "+item.ranking+"名"}}</view><block a:if="{{item.status==0}}"><view style="font-weight:bold;">{{"到达 "+item.opennum+"人开奖"}}</view></block><block a:else><view style="font-weight:bold;"><block a:if="{{item.is_winner}}"><text style="color:red;">已中奖</text></block><block a:else><text style="color:grey;">未中奖</text></block></view></block></view><view class="item-row-text"><text>活动名称</text>{{"："+item.name}}</view><view class="item-row-text"><text>订单号</text>{{"："+item.ordernum}}</view><view class="item-row-text"><text>消费金额</text>{{"："+item.consumption_amt}}</view><view class="item-row-text"><text>参与用户</text>{{"："+item.nickname}}</view><view class="item-row-text"><text>排队时间</text>{{"："+item.createtime}}</view><block a:if="{{item.mdname}}"><view class="item-row-text"><text>所在门店</text>{{"："+item.mdname}}</view></block></view></view><block a:if="{{nodata}}"><nodata vue-id="d7116584-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="d7116584-2" onVueInit="__l"></nomore></block></block></block><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" style="{{'background-color:'+($root.m2)+';'}}" onTap="__e">活动规则</button><block a:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule" style="{{'background-color:'+($root.m3)+';'}}"><view class="h2">活动规则</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e"></view><view class="con"><view class="text"><block a:if="{{activity.hd&&activity.hd.guize}}"><text decode="true" space="true">{{activity.hd.guize}}</text></block></view></view></view></view></block><block a:if="{{loading}}"><loading vue-id="d7116584-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d7116584-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d7116584-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>