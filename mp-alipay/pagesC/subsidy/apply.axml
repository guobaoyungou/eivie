<view><block a:if="{{isload}}"><block><view class="container2"><block a:if="{{set&&set.banner}}"><image style="width:100%;height:auto;" src="{{set.banner}}" mode="widthFix"></image></block><view class="form"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item"><view class="f1"><text style="color:red;">*</text>姓名：</view><view class="f2"><input type="text" name="name" value="" placeholder="请填写姓名" placeholder-style="color:#888"/></view></view><view class="form-item"><view class="f1"><text style="color:red;">*</text>身份证：</view><view class="f2"><input type="text" name="idcard" value="" placeholder="请填写身份证号码" placeholder-style="color:#888"/></view></view><view class="form-item"><view class="f1"><text style="color:red;">*</text>手机号：</view><view class="f2"><input type="text" name="mobile" value="" placeholder="请填写手机号" placeholder-style="color:#888"/></view></view></view><block a:if="{{set&&set.desc}}"><view class="form-box form-desc">{{''+set.desc}}</view></block><block a:if="{{!isSubmit}}"><button class="savebtn" style="background:#999;">确认提交</button></block><block a:else><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button></block></form></view></view></block></block><block a:if="{{loading}}"><loading vue-id="4821a754-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="4821a754-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="4821a754-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="4821a754-4" onVueInit="__l"></wxxieyi></view>