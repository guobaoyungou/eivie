<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;"></text></text><block a:if="{{item.market_price*1>item.sell_price*1}}"><text class="t2"></text></block></view></view><view class="p3"><view class="t1">商品数量<text style="font-size:28rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">查看详情</text></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="6944e78c-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="6944e78c-2" onVueInit="__l"></nodata></block></view><button class="covermy" style="{{('background:'+$root.m4)}}" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的订单</button></block></block><block a:if="{{loading}}"><loading vue-id="6944e78c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="6944e78c-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6944e78c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>