<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" onSubmit="__e"><block a:if="{{product.product_thali_school==1}}"><view class="address-add"><view class="linkitem"><text class="f1" style="margin:0;">学生姓名：</text><input class="input" type="text" disabled="{{true}}" placeholder-style="color:#626262;font-size:28rpx;" value="{{address.product_thali_student_name}}"/></view><view class="linkitem"><text class="f1" style="margin:0;">学校信息：</text><input class="input" type="text" disabled="{{true}}" placeholder-style="color:#626262;font-size:28rpx;" value="{{address.product_thali_school}}"/></view></view></block><view class="address-add flex-y-center" data-url="{{'/pagesB/address/address?fromPage=product_thali_buy&type='+(havetongcheng==1?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><image class="img" src="{{pre_url+'/static/img/address.png'}}"></image></view><block a:if="{{address.name}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block a:if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block a:else><view class="f2 flex1">请选择收货地址</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="buydata"><view class="bcontent"><view class="product"><view class="f2" style="font-weight:bold;color:#111111;font-size:30rpx;padding-top:10px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{product.title}}</view><view class="item flex" a:for="{{productlist}}" a:for-item="item" a:for-index="index"><view class="img"><block a:if="{{item.pic}}"><image class="img" src="{{item.pic}}"></image></block><block a:else><image class="img" src="{{item.pic}}"></image></block></view><view class="info flex1"><view class="f1" style="height:35px;overflow:hidden;text-overflow:ellipsis;">{{item.name}}</view><view class="f1"></view><view class="f1"></view><view class="f2" style="color:red;">{{"￥"+item.sell_price+"  x  "+item.num}}</view></view></view></view><block a:for="{{freightList[freightkey].formdata}}" a:for-item="item" a:for-index="idx" a:key="id"><block a:if="{{freightList}}"><view class="form-item"><view class="label">{{item.val1}}<block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.val2[editorFormdata[idx]]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{editorFormdata[idx]}}"><view class="form-imgbox"><view class="layui-imgbox-close" style="z-index:2;" data-idx="{{idx}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view></block></block></view></block></block></view></view><view style="width:100%;height:calc(110rpx + env(safe-area-inset-bottom));"></view><view class="footer flex notabbarbot"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}<block a:if="{{product.deliver_type==1}}"><text style="font-size:12px;">{{"(运费:"+product.freight+")"}}</text></block></text></view><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">提交订单</button></view></form></block></block><block a:if="{{loading}}"><loading vue-id="5a8530d8-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="5a8530d8-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5a8530d8-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="5a8530d8-4" onVueInit="__l"></wxxieyi></view>