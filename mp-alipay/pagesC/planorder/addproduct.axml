<view><view style="width:100%;padding:0 24rpx;"><view class="dp-product-itemlist"><view class="dp-product-item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" class="item" onTap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><block a:if="{{item.$orig.sellpoint}}"><view class="p5" style="{{'color:'+(item.m0)+';'}}"><text>{{item.$orig.sellpoint}}</text></view></block><block a:if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m1)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m2}}</text></view></block><block a:if="{{item.$orig.show_cost&&item.$orig.price_type!=1}}"><view style="{{'color:'+(item.$orig.cost_color?item.$orig.cost_color:'#999')+';'+('font-size:'+('36rpx')+';')}}"><text style="font-size:24rpx;">{{item.$orig.cost_tag}}</text>{{item.$orig.cost_price}}</view></block><block a:if="{{(!item.$orig.show_sellprice||item.$orig.show_sellprice&&item.$orig.show_sellprice==true)&&(item.$orig.price_type!=1||item.$orig.sell_price>0)}}"><view class="p2"><view class="t1" style="{{'color:'+(item.$orig.price_color?item.$orig.price_color:item.m3)+';'}}"><text style="font-size:24rpx;padding-right:1px;">{{item.$orig.price_tag?item.$orig.price_tag:'￥'}}</text>{{item.$orig.sell_price+''}}<block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block a:if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block><block a:if="{{item.m4}}"><text style="font-size:28rpx;">{{"+"+item.$orig.service_fee+item.m5}}</text></block><block a:if="{{item.$orig.product_type==2&&item.$orig.unit_price&&item.$orig.unit_price>0}}"><text class="t1-m" style="{{'color:'+(item.m6)+';'}}">{{'(约'+item.$orig.unit_price+'元/斤)'}}</text></block><block a:if="{{item.$orig.fwlist&&item.$orig.fwlist.length>0}}"><view class="p6"><view class="p6-m" style="{{('background:rgba('+item.m7+',0.15);color:'+item.m8+';')}}" a:for="{{item.$orig.fwlist}}" a:for-item="fw" a:for-index="fwidx" a:key="fwidx">{{''+fw+''}}</view></view></block></view><block a:if="{{item.$orig.show_sellprice&&item.$orig.market_price*1>item.$orig.sell_price*1&&showprice=='1'}}"><view class="t2">{{"￥"+item.$orig.market_price}}</view></block><block a:if="{{item.$orig.addstatus<=0}}"><view class="right-btn" style="{{'background-color:'+(item.m9)+';'}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-type="one" data-event-opts="{{[['tap',[['addit',['$event']]]]]}}" catchTap="__e">上橱窗</view></block><block a:else><view class="right-btn" style="background-color:#ddd;">已添加</view></block></view></block><block a:if="{{item.$orig.commission>0}}"><view class="couponitem"><view class="f1"><view class="t" style="{{'background:'+('rgba('+item.m10+',0.1)')+';'+('color:'+(item.m11)+';')}}"><text>{{item.m12+item.$orig.commission+item.$orig.commission_desc}}</text></view></view></view></block></view></view></view></view><block a:if="{{nomore}}"><nomore style="width:100%;" vue-id="43f4211c-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata style="width:100%;" vue-id="43f4211c-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="43f4211c-3" onVueInit="__l"></loading></block><view style="width:100%;height:140rpx;clear:both;"></view><view class="{{(('bottom-wc')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view>{{"共计"+count+"件商品"}}</view><view class="bottom-btn" style="{{'background-color:'+($root.m13)+';'}}" data-id data-index data-type="all" data-event-opts="{{[['tap',[['addit',['$event']]]]]}}" catchTap="__e">一键添加所有商品</view></view></view><dp-tabbar vue-id="43f4211c-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="43f4211c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="43f4211c-6" onVueInit="__l"></wxxieyi></view>