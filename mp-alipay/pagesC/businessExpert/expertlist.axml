<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="18f4e751-1" itemdata="{{['全部','待审核','已通过','已驳回','已过期']}}" itemst="{{['all','0','1','-1','-2']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1" style="width:100%;"><view style="display:flex;justify-content:space-between;"><view class="t1" style="margin-bottom:10rpx;width:calc(100% - 110rpx;);" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{'商户：'+item.business.name+''}}</view><view style="width:110rpx;"><block a:if="{{item.status==0}}"><text style="color:#ff8758;">待审核</text></block><block a:if="{{item.status==1}}"><text style="color:green;">已通过</text></block><block a:if="{{item.status==-1}}"><text style="color:#bbb;">已驳回</text></block><block a:if="{{item.status==-2}}"><text style="color:#bbb;">已过期</text></block></view></view><view class="t2">{{"联系人姓名："+item.linkman}}</view><view class="t2">{{"联系人电话："+item.linktel}}</view><view class="t2">{{"申请原因："+item.reason}}</view><block a:if="{{item.pics}}"><block><view class="con previewImgContent" style="width:100%;padding:24rpx 0;display:flex;flex-wrap:wrap;"><view class="dp-form-imgbox" a:for="{{item.pics}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="dp-form-imgbox-img" style="margin-bottom:10rpx;"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="aspectFit" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block><block a:if="{{item.premonthinfo}}"><view class="t2">{{item.premonthinfo}}</view></block><view class="t2">{{"提交时间："+item.createtime}}</view><block a:if="{{item.checktime}}"><view class="t2">{{"审核时间："+item.checktime}}</view></block><block a:if="{{item.expiredtime}}"><view class="t2">{{"失效时间："+item.expiredtime}}</view></block><block a:if="{{item.check_reason}}"><view class="t2" style="color:red;">{{"审核原因："+item.check_reason}}</view></block><block a:if="{{item.expiredremark}}"><view class="t2" style="color:red;">{{item.expiredremark}}</view></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="18f4e751-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="18f4e751-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="18f4e751-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="18f4e751-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="18f4e751-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>