<view class="container"><block a:if="{{isload}}"><block><form autocomplete="off" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="content2"><view class="item2"><view class="f1">商户ID</view></view><view class="item3"><block a:if="{{business.id}}"><view class="member-info"><view class="info-view flex-y-center"><block a:if="{{business.logo}}"><image class="head-img" src="{{business.logo}}"></image></block><block a:else><image class="head-img" src="{{pre_url+'/static/img/wxtx.png'}}"></image></block><view class="member-text-view"><view class="member-nickname">{{business.name}}</view><view class="member-id">{{"ID："+business.id}}</view></view></view><view data-event-opts="{{[['tap',[['switchBusiness',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m0)+';'}}" onTap="__e">切换</view></view></block><block a:else><view class="member-info"><input class="input" type="number" name="bid" placeholder="请输入商户ID" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['businessInput',['$event']]]]]}}" value="{{bid}}" onInput="__e"/><view data-event-opts="{{[['tap',[['changeQuery',['$0'],['bid']]]]]}}" class="query-button" style="{{'color:'+($root.m1)+';'}}" onTap="__e">查询</view></view></block></view><view class="item4" style="height:1rpx;"></view><view class="item2"><view class="f1">转账金额</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="money" value="" placeholder="请输入转账金额" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><view class="item4"></view><view class="desText">{{"您的当前"+$root.m2+"："+mycommission+'，转账后不可退回'}}</view><block a:if="{{transfer_rate>0}}"><view class="desText">{{"转账费率："+transfer_rate+"%"}}</view></block></view><button class="btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">转账</button><view class="text-center" style="margin-top:40rpx;line-height:60rpx;" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{"返回"+$root.m4+"中心"}}</text></view></form></block></block><block a:if="{{loading}}"><loading vue-id="a38941ee-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="a38941ee-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>