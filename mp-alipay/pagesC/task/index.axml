<view class="view-width"><block a:if="{{isload}}"><block><view class="head-class" style="{{'background:'+('url('+taskset.bgpic+')')+';'+('background-size:'+('cover')+';')+('background-repeat:'+('no-repeat')+';')}}"><view class="navigation" style="{{('top:'+menuButton+'px')}}"><image class="imgback" src="{{pre_url+'/static/img/goback2.png'}}" data-event-opts="{{[['tap',[['goback']]]]}}" onTap="__e"></image><view style="width:100%;text-align:center;color:#fff;font-weight:bold;">任务</view></view><view class="log" style="{{('background-color: rgba('+$root.m0+',0.4);top:'+logtop+'px')}}" data-url="log" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">历史任务</view><view class="taskprogress-wc" style="{{('top:'+taskprogresstop+'px')}}"><view class="taskprogress">任务进度<progress style="width:560rpx;" percent="{{taskprogress}}" show-info="{{true}}" stroke-width="5" border-radius="5"></progress></view></view><block a:if="{{taskset.givescore>0||taskset.givecouponid>0&&taskset.givecouponname}}"><view class="taskprogress-wc" style="{{'bottom:20rpx;'+('top:'+endgivetop+'px')}}"><view style="width:700rpx;margin:0 auto;text-align:center;font-size:26rpx;">当日任务全部完成奖励：<block a:if="{{taskset.givescore>0}}"><text>{{'+'+taskset.givescore+$root.m1}}</text></block><block a:if="{{taskset.givecouponid>0&&taskset.givecouponname}}"><text style="{{(taskset.givescore>0?'margin-left: 10rpx;':'')}}">{{'+'+taskset.givecouponname+$root.m2}}</text></block></view></view></block></view><view class="task-wc"><view style="display:flex;justify-content:space-between;"><view class="task-title" style="{{'font-size:30rpx;padding-left:10rpx;'+('border-left: 6rpx solid '+$root.m3)}}">任务列表</view><view data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" style="display:flex;align-items:center;" onTap="__e"><image class="imgback" src="{{pre_url+'/static/img/wh.png'}}"></image><view style="{{('color:'+$root.m4)}}">规则说明</view></view></view></view><view class="tasklist"><view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="task-item"><view style="width:70rpx;height:70rpx;border-radius:50% 50%;overflow:hidden;"><image style="width:100%;height:100%;" src="{{item.$orig.pic}}"></image></view><view style="width:400rpx;"><view>{{item.$orig.name}}</view><view style="font-size:26rpx;color:#8E8E8E;">{{''+item.$orig.shortcontent+''}}</view><view style="font-size:26rpx;"><block a:if="{{item.$orig.givescore>0}}"><text style="{{('color:'+item.m5)}}">{{'+'+item.$orig.givescore+item.m6}}</text></block><block a:if="{{item.$orig.givecouponid>0&&item.$orig.givecouponname}}"><text style="{{(item.$orig.givescore>0?'margin-left: 10rpx;color:'+item.m7:'color:'+item.m8)}}">{{'+'+item.$orig.givecouponname+item.m9}}</text></block></view></view><block a:if="{{item.$orig.takestatus==0}}"><view class="opt" style="{{('background-color:'+item.m10)}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['takeTask',['$event']]]]]}}" onTap="__e">领任务</view></block><block a:if="{{item.$orig.takestatus==1}}"><view class="opt" style="{{('background-color: rgba('+item.m11+',0.75)')}}" data-url="{{'detail?type=1&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去完成</view></block><block a:if="{{item.$orig.takestatus==2}}"><view class="opt" style="{{('background-color: rgba('+item.m12+',0.45)')}}" data-url="{{'detail?type=1&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">已完成</view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="07f388e2-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="07f388e2-2" onVueInit="__l"></nomore></block></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e"></view><scroll-view class="content" scroll-y="true"><view style="padding:0 20rpx;"><parse vue-id="07f388e2-3" content="{{taskset.content}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></scroll-view></view></view></block><popmsg vue-id="07f388e2-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="07f388e2-5" onVueInit="__l"></loading></block></view>