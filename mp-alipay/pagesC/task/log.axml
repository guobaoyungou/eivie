<view><block a:if="{{isload}}"><view class="content"><view class="task" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-url="{{'logdetail?logid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view>{{'任务时间：'+item.$orig.daytime+''}}</view><view class="taskprogress">任务进度:<progress style="width:360rpx;margin-left:4rpx;" percent="{{item.$orig.taskprogress}}" show-info="{{true}}" stroke-width="4" border-radius="4"></progress></view><block a:if="{{item.$orig.status>=0&&(item.$orig.givescore>0||item.$orig.givecouponid>0&&item.$orig.givecouponname)}}"><view>完成奖励：<block a:if="{{item.$orig.givescore>0}}"><text>{{'+'+item.$orig.givescore+item.m0}}</text></block><block a:if="{{item.$orig.givecouponid>0&&item.$orig.givecouponname}}"><text style="{{(item.$orig.givescore>0?'margin-left: 10rpx;':'')}}">{{'+'+item.$orig.givecouponname+item.m1}}</text></block></view></block><view>任务状态：<block a:if="{{item.$orig.status==-1}}"><text style="color:#999;">已关闭</text></block><block a:if="{{item.$orig.status==0}}"><text>未完成</text></block><block a:if="{{item.$orig.status==1}}"><text style="color:green;">已完成</text></block></view></view><image class="imgback" src="{{pre_url+'/static/img/location/right-black.png'}}"></image></view><block a:if="{{nomore}}"><nomore vue-id="86b15ca0-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="86b15ca0-2" onVueInit="__l"></nodata></block></view></block><block a:if="{{loading}}"><loading vue-id="86b15ca0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="86b15ca0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="86b15ca0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>