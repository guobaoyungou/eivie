<view class="view-width"><block a:if="{{isload}}"><block><view class="tasklist"><view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="task-item"><view style="width:60rpx;height:60rpx;border-radius:50% 50%;overflow:hidden;"><image style="width:100%;height:100%;" src="{{item.$orig.pic}}"></image></view><view style="width:400rpx;"><view>{{item.$orig.name}}</view><view style="font-size:26rpx;color:#8E8E8E;">{{''+item.$orig.shortcontent+''}}</view><view style="font-size:26rpx;"><block a:if="{{item.$orig.givescore>0}}"><text style="{{('color:'+item.m0)}}">{{'+'+item.$orig.givescore+item.m1}}</text></block><block a:if="{{item.$orig.givecouponid>0&&item.$orig.givecouponname}}"><text style="{{(item.$orig.givescore>0?'margin-left: 10rpx;color:'+item.m2:'color:'+item.m3)}}">{{'+'+item.$orig.givecouponname+item.m4}}</text></block></view></view><block a:if="{{item.$orig.status==0}}"><view class="opt" style="{{('background-color: rgba('+item.m5+',0.75)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去完成</view></block><block a:if="{{item.$orig.status==1}}"><view class="opt" style="{{('background-color: rgba('+item.m6+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">已完成</view></block><block a:if="{{item.$orig.status==-2}}"><view class="opt" style="{{('background-color: rgba('+item.m7+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">已失效</view></block><block a:if="{{item.$orig.status==-1}}"><view class="opt" style="{{('background-color: rgba('+item.m8+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">已关闭</view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="7efc7a02-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="7efc7a02-2" onVueInit="__l"></nomore></block></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e"></view><scroll-view class="content" scroll-y="true"><view style="padding:0 20rpx;"><parse vue-id="7efc7a02-3" content="{{set.content}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></scroll-view></view></view></block><popmsg vue-id="7efc7a02-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="7efc7a02-5" onVueInit="__l"></loading></block></view>