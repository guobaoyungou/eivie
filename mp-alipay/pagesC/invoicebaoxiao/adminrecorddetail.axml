<view class="container"><block a:if="{{isload}}"><block><view class="recorddetail"><view class="item"><text class="t1">标题：</text><text class="t2">{{$root.m0+"报销记录"}}</text></view><view class="item-pics"><view class="t1">已上传发票截图</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{invoicepic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view><view class="item-pics"><view class="t1">已上传现场消费照片</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{consumepic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view><view class="item-pics"><view class="t1">OCR发票信息</view><view style="padding-bottom:20rpx;"><view class="layui-text" a:for="{{detail.invoice_data}}" a:for-item="item" a:for-index="index" a:key="index">{{'发票编号：'+item.invoice_number+''}}</view></view></view><view class="item"><view class="t1">发票真伪</view><block a:if="{{detail.authenticity==0}}"><text class="t2 red">发票存疑</text></block><block a:if="{{detail.authenticity==1}}"><text class="t2 green">发票为真</text></block><block a:if="{{detail.authenticity==-1}}"><text class="t2" style="color:#a0a0a0;">待辩真伪</text></block></view><view class="item"><text class="t1">提交人：</text><text class="t2"><view style="width:100rpx;height:100rpx;"><block a:if="{{detail.userinfo.headimg}}"><image style="width:100%;height:100%;" src="{{detail.userinfo.headimg}}" mode></image></block></view>{{''+detail.userinfo.nickname+''}}</text></view><view class="item"><text class="t1">{{$root.m1+"ID："}}</text><text class="t2">{{detail.mid}}</text></view><view class="item"><text class="t1">提交时间：</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0}}"><view class="item"><text class="t1">审核时间：</text><text class="t2">{{detail.operatetime}}</text></view></block><view class="item"><text class="t1">审核状态：</text><block a:if="{{detail.status==0}}"><text class="t2 red">待审核</text></block><block a:if="{{detail.status==1}}"><text class="t2 green">已通过</text></block><block a:if="{{detail.status==2}}"><text class="t2 yellow">已驳回</text></block><block a:if="{{detail.status==3}}"><text class="t2">已关闭</text></block></view><view class="item"><text class="t1">打款状态：</text><block a:if="{{detail.payment_status==0}}"><text class="t2">未打款</text></block><block a:if="{{detail.payment_status==1}}"><text class="t2 red">待打款</text></block><block a:if="{{detail.payment_status==2}}"><text class="t2 green">已打款</text></block><block a:if="{{detail.payment_status==3}}"><text class="t2">已关闭</text></block></view><block a:if="{{detail.deduct_score}}"><view class="item"><text class="t1">{{"扣除"+$root.m2+"："}}</text><text class="t2">{{detail.deduct_score}}</text></view></block><block a:if="{{detail.money}}"><view class="item"><text class="t1">打款金额：</text><text class="t2">{{detail.money}}</text></view></block><block a:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因：</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block></view><view style="width:100%;height:160rpx;"></view><view class="bottom"><block a:if="{{detail.status==0&&detail.payment_status==0}}"><block><view data-event-opts="{{[['tap',[['pass',[1]]]]]}}" class="btn2" onTap="__e">通过</view><view data-event-opts="{{[['tap',[['nopassPopup',['$event']]]]]}}" class="btn2" onTap="__e">驳回</view></block></block><block a:if="{{detail.status==1&&detail.payment_status==1}}"><block><view data-event-opts="{{[['tap',[['nopassPopup',['$event']]]]]}}" class="btn2" onTap="__e">驳回</view><view data-event-opts="{{[['tap',[['dakuan',['$event']]]]]}}" class="btn2" onTap="__e">已打款</view></block></block><block a:if="{{detail.payment_status<2}}"><block><view class="btn2" data-url="{{'adminedit?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">编辑</view><view data-event-opts="{{[['tap',[['pass',[3]]]]]}}" class="btn2" onTap="__e">关闭</view></block></block></view><uni-popup vue-id="7c8e0aa6-1" id="dialogNopass" type="dialog" ref="__r" data-ref="dialogNopass" onVueInit="__l"><uni-popup-dialog vue-id="{{('7c8e0aa6-2')+','+('7c8e0aa6-1')}}" mode="input" title="确定要驳回申请吗？" placeholder="请输入驳回原因" data-event-opts="{{[['^confirm',[['nopass']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="7c8e0aa6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="7c8e0aa6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7c8e0aa6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="7c8e0aa6-6" onVueInit="__l"></wxxieyi></view>