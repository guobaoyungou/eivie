<view><block a:if="{{isload}}"><block><block a:if="{{set&&set.pic}}"><view class="banner"><image src="{{set.pic}}" mode="widthFix"></image></view></block><block a:if="{{set&&set.shuoming}}"><view class="content"><parse vue-id="661228b6-1" content="{{set.shuoming}}" onVueInit="__l"></parse></view></block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="title"><view class="line"><text>上传发票和照片</text></view></view><view class="form-field"><view class="form-field-title">上传发票截图<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{invoicepic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="invoicepic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="invoicepic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view><input type="text" hidden="true" name="invoicepic" maxlength="-1" value="{{$root.g0}}"/><view class="form-field"><view class="form-field-title">上传消费照片<text style="color:red;">*</text></view><block a:if="{{set&&set.upload_tips}}"><view class="upload-tips">{{"提示："+set.upload_tips}}</view></block></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{consumepic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="consumepic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="consumepic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view><input type="text" hidden="true" name="consumepic" maxlength="-1" value="{{$root.g1}}"/></view><view class="withdrawtype"><view class="f1">选择收款方式：</view><view class="f2"><block a:if="{{sysset.withdraw_aliaccount==1}}"><label class="item" data-paytype="支付宝" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝</view><view class="radio" style="{{(paytype=='支付宝'?'background:'+$root.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block a:if="{{sysset.withdraw_bankcard==1}}"><label class="item" data-paytype="银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>银行卡</view><view class="radio" style="{{(paytype=='银行卡'?'background:'+$root.m1+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block a:if="{{sysset.withdraw_paycode==1}}"><label class="item" data-paytype="收款码" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>收款码</view><view class="radio" style="{{(paytype=='收款码'?'background:'+$root.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block></view><block a:if="{{selectbank&&paytype=='银行卡'&&bank}}"><view class="banklist"><view class="f1">{{"默认银行卡："+bank.bankname+" "+bank.bankcardnum}}</view><view class="t2" data-url="/pagesA/banklist/bank?fromPage=commission" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">修改</view></view></block></view><block a:if="{{paytype=='支付宝'}}"><view class="textbtn" data-url="/pagesExt/my/setaliaccount" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">设置支付宝账户<image src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><block a:if="{{paytype=='银行卡'&&!sysset.withdraw_huifu}}"><view class="textbtn" data-url="/pagesExt/my/setbankinfo" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">设置银行卡账户<image src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><block a:if="{{paytype=='收款码'}}"><view class="textbtn" data-url="/pagesB/my/setpaycode" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">设置收款码<image src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m3)+';'}}" onTap="__e">提交</button><view style="width:100%;height:100rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="661228b6-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="661228b6-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="661228b6-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="661228b6-5" onVueInit="__l"></wxxieyi></view>