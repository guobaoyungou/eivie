<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="302ec222-1" itemdata="{{['全部','待审核','已通过','已驳回','已关闭']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'recorddetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><view class="t2"><text class="x1">报销记录</text><text class="x2">{{"记录编号："+item.id}}</text><text class="x2">{{"扣除"+$root.m0+"："+item.deduct_score}}</text><text class="x2">{{"打款金额："+item.money}}</text><text class="x2">{{"提交日期："+item.createtime}}</text></view></view><view class="f2"><block a:if="{{item.status==0}}"><text class="t1 red">待审核</text></block><block a:if="{{item.status==1}}"><text class="t1 green">已通过</text></block><block a:if="{{item.status==2}}"><text class="t1 yellow">已驳回</text></block><block a:if="{{item.status==1&&item.payment_status==2}}"><text class="t1 green">已打款</text></block><block a:if="{{item.status==3&&item.payment_status==3}}"><text class="t1">已关闭</text></block></view></view><block a:if="{{item.status==0}}"><view class="op"><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除</view></view></block></block></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="302ec222-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="302ec222-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="302ec222-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="302ec222-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="302ec222-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>