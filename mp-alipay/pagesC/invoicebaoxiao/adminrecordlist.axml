<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="12124339-1" itemdata="{{['全部','待确认','已确认','已驳回','已关闭']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'adminrecorddetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><view class="t2"><text class="x1">报销记录</text><text class="x2">{{"ID："+item.id}}</text><block a:if="{{item.nickname}}"><text class="x2">{{"昵称："+item.nickname}}</text></block><block a:if="{{item.realname}}"><text class="x2">{{"姓名："+item.realname}}</text></block><block a:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><text class="x2">{{"提交日期："+item.createtime}}</text></view></view><view class="f2"><block a:if="{{item.status==0}}"><text class="t1 red">待审核</text></block><block a:if="{{item.status==1}}"><text class="t1 green">已通过</text></block><block a:if="{{item.status==2}}"><text class="t1 yellow">已驳回</text></block><block a:if="{{item.payment_status==0}}"><text class="t1">未打款</text></block><block a:if="{{item.payment_status==1}}"><text class="t1 red">待打款</text></block><block a:if="{{item.payment_status==2}}"><text class="t1 green">已打款</text></block><block a:if="{{item.status==3&&item.payment_status==3}}"><text class="t1">已关闭</text></block></view></view></block></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="12124339-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="12124339-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="12124339-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="12124339-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="12124339-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>