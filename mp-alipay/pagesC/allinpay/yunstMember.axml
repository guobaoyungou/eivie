<block a:if="{{isload}}"><view><view class="schedule-view flex-x-center"><view class="schedule-options flex-col"><view class="{{((signstatus>=1?'active-class':'')+' '+'num-text')}}">1</view><view class="tips-text">注册会员</view></view><view class="dashed-line" style="{{'border:'+(''+signstatus==true?'1px dashed #a9000e':'1px dashed #b3b3b3')+';'}}"></view><view class="schedule-options flex-col"><view class="{{((signstatus>=2?'active-class':'')+' '+'num-text')}}">2</view><view class="tips-text">绑定手机号</view></view><view class="dashed-line" style="{{'border:'+(''+signstatus==true?'1px dashed #a9000e':'1px dashed #b3b3b3')+';'}}"></view><view class="schedule-options flex-col"><view class="{{((signstatus>=3?'active-class':'')+' '+'num-text')}}">3</view><view class="tips-text">实名认证</view></view><view class="dashed-line" style="{{'border:'+(''+signstatus==true?'1px dashed #a9000e':'1px dashed #b3b3b3')+';'}}"></view><view class="schedule-options flex-col"><view class="{{((signstatus==4?'active-class':'')+' '+'num-text')}}">4</view><view class="tips-text">绑定银行卡</view></view></view><block a:if="{{signstatus==2}}"><view class="form-view"><view class="form-item"><view class="label">手机号</view><input style="flex:1;" type="text" placeholder="请输入手机号" name="phone" data-field="phone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{phone}}" onInput="__e"/></view><view class="form-item"><view class="label">验证码</view><input type="text" placeholder="请输入验证码" name="verificationCode" data-field="verificationCode" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{verificationCode}}" onInput="__e"/><view data-event-opts="{{[['tap',[['sendSmscode',['$event']]]]]}}" class="code" style="{{('color:'+$root.m0)}}" onTap="__e">{{smsdjs||'获取验证码'}}</view></view></view></block><block a:else><block a:if="{{signstatus==3}}"><view class="form-view"><view class="form-item"><view class="label">真实姓名</view><input style="flex:1;" type="text" placeholder="请输入真实姓名" name="name" data-field="name" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{name}}" onInput="__e"/></view><view class="form-item"><view class="label">身份证号</view><input style="flex:1;" type="text" placeholder="请输入身份证号" name="identityNo" data-field="identityNo" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{identityNo}}" onInput="__e"/></view><view style="color:red;line-height:70rpx;">请认真填写真实姓名、身份证号，绑定银行卡号时将会使用此信息</view></view></block><block a:else><block a:if="{{signstatus==4}}"><view class="form-view"><view class="form-item"><view class="label">真实姓名</view><input style="flex:1;" type="text" name="name" disabled="{{true}}" placeholder="请输入真实姓名" value="{{name}}"/></view><view class="form-item"><view class="label">身份证号</view><input style="flex:1;" type="text" name="identityNo" disabled="{{true}}" placeholder="请输入身份证号" value="{{identityNo}}"/></view><view class="form-item"><view class="label">银行卡号</view><input style="flex:1;" type="text" placeholder="请输入银行卡号" name="cardNo" data-field="cardNo" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{cardNo}}" onInput="__e"/></view><view class="form-item"><view class="label">银行预留手机</view><input style="flex:1;" type="text" placeholder="请输入银行预留手机" name="cardPhone" data-field="cardPhone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{cardPhone}}" onInput="__e"/></view><block a:if="{{cardCheck!=8}}"><view class="form-item"><view class="label">验证码</view><input type="text" placeholder="请输入验证码" name="verificationCode2" data-field="verificationCode2" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{verificationCode2}}" onInput="__e"/><view data-event-opts="{{[['tap',[['sendSmscode2',['$event']]]]]}}" class="code" style="{{('color:'+$root.m1)}}" onTap="__e">{{smsdjs2||'获取验证码'}}</view></view></block></view></block></block></block><block a:if="{{signstatus==1}}"><view class="form-view"><view class="form-item"><view class="label">会员名称</view><input style="flex:1;" placeholder="请输入会员名称" name="bizUserId" data-field="bizUserId" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{bizUserId}}" onInput="__e"/></view><view style="color:red;line-height:70rpx;">仅支持英文数字符号，不支持汉字</view></view></block><view class="but-view"><block a:if="{{signstatus==2}}"><button data-event-opts="{{[['tap',[['goBandPhone',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" onTap="__e">确定绑定</button></block><block a:else><block a:if="{{signstatus==3}}"><button data-event-opts="{{[['tap',[['goRenzheng',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" onTap="__e">确定认证</button></block><block a:else><block a:if="{{signstatus==4}}"><button data-event-opts="{{[['tap',[['goBindBankCard',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';'}}" onTap="__e">确定绑定</button></block><block a:else><block a:if="{{signstatus==1}}"><button data-event-opts="{{[['tap',[['getReg',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m8+' 0%,rgba('+$root.m9+',0.8) 100%)')+';'}}" onTap="__e">注册</button></block></block></block></block></view></view></block>