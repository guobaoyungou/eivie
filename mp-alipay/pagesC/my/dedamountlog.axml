<view class="container"><block a:if="{{isload}}"><block><block a:if="{{pid<=0}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的抵扣金</view><view class="item flex-bt flex-y-center"><view class="value">{{mydedamount}}</view></view></view></block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block a:if="{{item.dedamount>0}}"><text style="color:green;">{{"+"+item.dedamount}}</text></block><block a:else><text style="color:red;">{{item.dedamount}}</text></block></view><block a:if="{{pid<=0&&item.dedamount>0}}"><view class="t2" style="color:#000;">{{"剩余变动金额："+item.dedamount2}}</view></block></view><view class="f1"><view class="t2">{{"来源："+item.bname}}</view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view><block a:if="{{pid<=0&&item.dedamount>0}}"><view class="f1"><view class="btn2" style="margin:0 auto;" data-url="{{'dedamountlog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看变动金额使用记录</view></view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="0e7a895c-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="0e7a895c-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="0e7a895c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0e7a895c-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0e7a895c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>