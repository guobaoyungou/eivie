<view class="container"><view class="myjichamoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}</view><view class="f2">{{myjichamoney}}<block a:if="{{canwithdraw}}"><view class="btn-mini" data-url="jichamoneywithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></block></view></view><block a:if="{{isload}}"><block><dd-tab vue-id="16b496e8-1" itemdata="{{['明细记录','提现记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><block a:if="{{st==0}}"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后: "+item.after}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block a:else><text class="t2">{{item.money}}</text></block></view></view></block></block><block a:if="{{st==1}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.$orig.createtime}}</text><block a:if="{{item.$orig.status==2}}"><text class="t2">{{"驳回原因："+(item.$orig.reason||'无')}}</text></block></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==4}}"><block><block a:if="{{item.$orig.wx_state=='WAIT_USER_CONFIRM'||item.$orig.wx_state=='TRANSFERING'}}"><view data-event-opts="{{[['tap',[['confirm_shoukuan',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m2)+';'}}" onTap="__e">确认收款</view></block><block a:else><block a:if="{{item.$orig.wx_state=='FAIL'}}"><view class="t1">转账失败</view></block><block a:else><view class="t1">处理中</view></block></block></block></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="16b496e8-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="16b496e8-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="16b496e8-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="16b496e8-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="16b496e8-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>