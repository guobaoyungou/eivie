<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+(shopset.order_detail_toppic?shopset.order_detail_toppic:pre_url+'/static/img/ordertop.png')+');background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block a:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block a:if="{{detail.freight_type!=1}}"><view class="t2">请尽快发货</view></block><block a:if="{{detail.freight_type==1}}"><view class="t2">待提货</view></block></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block a:if="{{detail.freight_type!=3}}"><view class="t2">{{"发货信息："+detail.express_com+" "+detail.express_no}}</view></block></view></block><block a:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block a:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><view class="t1"><text user-select="true" selectable="true">{{detail.linkman}}</text><block a:if="{{detail.tel}}"><text style="margin-left:20rpx;" data-url="{{'tel:'+detail.tel}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{detail.tel}}</text></block></view><block a:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block a:if="{{detail.product_thali}}"><text class="t2">{{"学生姓名："+detail.product_thali_student_name}}</text></block><block a:if="{{detail.product_thali}}"><text class="t2">{{"学校信息："+detail.product_thali_school}}</text></block><block a:if="{{detail.freight_type==1}}"><text class="t2" data-address="{{storeinfo.address}}" data-latitude="{{storeinfo.latitude}}" data-longitude="{{storeinfo.longitude}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address}}</text></block><block a:if="{{detail.worknum}}"><view class="t2">{{"工号："+detail.worknum}}</view></block></view></view><block a:if="{{detail.usegiveorder&&detail.usegiveorder==1}}"><view class="orderinfo"><view class="title">赠好友</view><view class="item"><view class="t1">领取状态</view><block a:if="{{detail.giveordermid>0}}"><view class="t2" style="color:green;">已领取</view></block><block a:else><view class="t2" style="color:red;">未领取</view></block></view><block a:if="{{detail.giveordermid>0&&detail.givemember}}"><block><view class="item"><text class="t1">好友信息</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.givemember.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.givemember.nickname+"(ID:"+detail.giveordermid+")"}}</text></view></block></block></view></block><view class="product"><view class="box" a:for="{{prolist}}" a:for-item="item" a:for-index="idx" a:key="idx"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.ggname}}</text><block a:if="{{item.product_type&&item.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item.real_total_weight+"斤"}}</text></view></block><block a:else><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></block><block a:if="{{shopset.show_shd_remark==1&&item.shd_remark}}"><text class="t2" style="height:auto;">{{"备注："+item.shd_remark}}</text></block><block a:if="{{(detail.status==1||detail.status==2)&&detail.is_quanyi==1&&item.hexiao_code}}"><block><view class="btn3" style="position:absolute;top:46rpx;right:0rpx;" data-id="{{item.id}}" data-num="{{item.hexiao_num_total}}" data-hxnum="{{item.hexiao_num_used}}" data-hexiao_code="{{item.hexiao_code}}" data-event-opts="{{[['tap',[['showhxqr2',['$event']]]]]}}" catchTap="__e">权益核销</view></block></block></view></view><block a:if="{{item.glassrecord}}"><view class="glassitem"><view class="gcontent"><view class="glassheader">{{''+item.glassrecord.name+"\r\n\t\t\t\t\t\t\t"+(item.glassrecord.nickname?item.glassrecord.nickname:'')+"\r\n\t\t\t\t\t\t\t"+(item.glassrecord.check_time?item.glassrecord.check_time:'')+"\r\n\t\t\t\t\t\t\t"+item.glassrecord.typetxt+''}}<block a:if="{{item.glassrecord.double_ipd==0}}"><text class="pdl10">{{item.glassrecord.ipd?'PD'+item.glassrecord.ipd:''}}</text></block><block a:else><text class="pdl10">{{"PD R"+item.glassrecord.ipd_right+" L"+item.glassrecord.ipd_left}}</text></block></view><view class="glassrow bt"><view class="grow">{{'R '+item.glassrecord.degress_right+"/"+(item.glassrecord.ats_right?item.glassrecord.ats_right:'0.00')+"*"+(item.glassrecord.ats_zright?item.glassrecord.ats_zright:'0')+''}}<block a:if="{{item.glassrecord.type==3}}"><text class="pdl10">{{"ADD+"+(item.glassrecord.add_right?item.glassrecord.add_right:0)}}</text></block></view><view class="grow">{{'L '+item.glassrecord.degress_left+"/"+(item.glassrecord.ats_left?item.glassrecord.ats_left:'0.00')+"*"+(item.glassrecord.ats_zleft?item.glassrecord.ats_zleft:'0')+''}}<block a:if="{{item.glassrecord.type==3}}"><text class="pdl10">{{"ADD+"+(item.glassrecord.add_left?item.glassrecord.add_left:0)}}</text></block></view></view><block a:if="{{item.glassrecord.remark}}"><view class="glassrow">{{item.glassrecord.remark}}</view></block></view></view></block></view><block a:if="{{detail.crk_givenum&&detail.crk_givenum>0}}"><view style="color:#f60;line-height:70rpx;">{{"+随机赠送"+detail.crk_givenum+"件"}}</view></block></view><block a:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><block a:if="{{detail.mid>0}}"><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view></block><block a:if="{{detail.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2" user-select="true" selectable="true">{{detail.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block a:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><block a:if="{{detail.issource&&detail.source&&detail.source=='supply_zhenxin'}}"><view class="item"><text class="t1">商品来源</text><text class="t2">甄新汇选</text></view></block><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m1+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block a:if="{{detail.invoice_money>0}}"><view class="item"><text class="t1">发票费用</text><text class="t2 red">{{"+¥"+detail.invoice_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block a:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block a:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block a:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block a:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><block a:if="{{detail.dec_money>0}}"><view class="item"><text class="t1">{{$root.m4+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.dec_money}}</text></view></block><block a:if="{{detail.silvermoneydec&&detail.silvermoneydec>0}}"><view class="item"><text class="t1">{{$root.m5+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.silvermoneydec}}</text></view></block><block a:if="{{detail.goldmoneydec&&detail.goldmoneydec>0}}"><view class="item"><text class="t1">{{$root.m6+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.goldmoneydec}}</text></view></block><block a:if="{{detail.discount_rand_money>0}}"><view class="item"><text class="t1">随机立减</text><text class="t2 red">{{"-¥"+detail.discount_rand_money}}</text></view></block><block a:if="{{detail.dedamount_dkmoney&&detail.dedamount_dkmoney>0}}"><view class="item"><text class="t1">抵扣金抵扣</text><text class="t2 red">{{"-¥"+detail.dedamount_dkmoney}}</text></view></block><block a:if="{{detail.shopscoredk_money>0}}"><view class="item"><text class="t1">{{$root.m7+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.shopscoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><block a:if="{{detail.combine_money&&detail.combine_money>0}}"><view class="item"><text class="t1">{{$root.m8+"已付"}}</text><text class="t2 red">{{"-¥"+detail.combine_money}}</text></view></block><block a:if="{{detail.paytypeid==2&&detail.status<=3&&detail.combine_wxpay&&detail.combine_wxpay>0}}"><view class="item"><text class="t1">微信已付</text><text class="t2 red">{{"-¥"+detail.combine_wxpay}}</text></view></block><block a:if="{{(detail.paytypeid==3||detail.paytypeid>=302&&detail.paytypeid<=330)&&detail.combine_alipay&&detail.combine_alipay>0}}"><view class="item"><text class="t1">支付宝已付</text><text class="t2 red">{{"-¥"+detail.combine_alipay}}</text></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block a:if="{{detail.status==2}}"><text class="t2">已发货</text></block><block a:if="{{detail.status==3}}"><text class="t2">已收货</text></block><block a:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason||'暂无'}}</text></view></block><block a:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block><block a:if="{{(detail.status==1||detail.status==2)&&detail.freight_type==1&&detail.is_quanyi==0&&!detail.hidefahuo}}"><view class="item flex-col"><text class="t1">核销码</text><view class="flex-x-center"><image style="width:400rpx;height:400rpx;" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block a:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block a:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block a:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block></view><block a:if="{{detail.checkmemid}}"><view class="orderinfo"><view class="item"><text class="t1">所选会员</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.checkmember.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.checkmember.nickname}}</text></view></view></block><block a:if="{{detail.isdygroupbuy==1}}"><view class="orderinfo"><view class="item"><text class="t1">抖音团购券信息</text><text class="t2">{{detail.dyorderids}}</text></view></view></block><block a:if="{{detail.formdata.length>0}}"><view class="orderinfo"><view class="item" a:for="{{detail.formdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><text class="t1">{{item[0]}}</text><block a:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block a:if="{{detail.status==2&&userlevel.downorder_collect}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" onTap="__e">确认收货</view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="19494af4-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="19494af4-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="19494af4-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>