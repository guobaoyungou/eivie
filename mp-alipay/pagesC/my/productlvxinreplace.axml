<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入商品名称搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.pic}}"></image><view class="t2" style="width:540rpx;"><view class="x1 flex-y-center">{{'可用天数：'+(item.day?item.day:0)+'天'}}</view><text class="x2">{{"滤芯名称："+item.name}}</text><block a:if="{{item.txing}}"><view class="x1 flex-y-center" style="margin-top:10rpx;"><button class="btn-mini2" data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">立即更换</button><button class="btn-mini2" style="margin-left:60rpx;" data-tel="{{item.tel}}" data-event-opts="{{[['tap',[['callMendian',['$event']]]]]}}" onTap="__e">联系客服</button></view></block></view></view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="ecbeb886-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="ecbeb886-2" onVueInit="__l"></nodata></block></block></block><popmsg vue-id="ecbeb886-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="ecbeb886-4" onVueInit="__l"></loading></block></view>