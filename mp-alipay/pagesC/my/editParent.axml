<view class="container"><block a:if="{{isload}}"><block><form autocomplete="off" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="content2"><block><view class="item2"><view class="f1">{{"新上级"+$root.m0+"ID"}}</view></view><view class="item3"><block a:if="{{member_info.id}}"><view class="member-info"><view class="info-view flex-y-center"><block a:if="{{member_info.headimg}}"><image class="head-img" src="{{member_info.headimg}}"></image></block><block a:else><image class="head-img" src="{{pre_url+'/static/img/wxtx.png'}}"></image></block><view class="member-text-view"><view class="member-nickname">{{member_info.nickname}}</view><view class="member-id">{{"ID："+member_info.id}}</view></view></view><view data-event-opts="{{[['tap',[['switchMember',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m1)+';'}}" onTap="__e">切换</view></view></block><block a:else><view class="member-info"><input class="input" type="number" name="mid" placeholder="{{'请输入新上级'+$root.m2+'ID'}}" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['memberInput',['$event']]]]]}}" value="{{mid}}" onInput="__e"/><view data-event-opts="{{[['tap',[['changeQuery',['$0'],['mid']]]]]}}" class="query-button" style="{{'color:'+($root.m3)+';'}}" onTap="__e">查询</view></view></block></view><view class="item4" style="height:1rpx;"></view></block><view class="item5"><text class="redtxt" style="margin-right:10rpx;">{{"您当前剩余修改次数："+remain_num+'次'}}</text></view><block a:if="{{reject_reason}}"><view class="item5"><text class="redtxt" style="margin-right:10rpx;">{{"拒绝原因："+reject_reason+''}}</text></view></block></view><button class="btn" style="{{'background:'+($root.m4)+';'}}" form-type="submit">提交</button></form></block></block><block a:if="{{loading}}"><loading vue-id="72abfbe7-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="72abfbe7-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>