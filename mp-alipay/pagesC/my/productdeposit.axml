<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="61c83c68-1" itemdata="{{['全部','未提现','待审核','已提现','已驳回']}}" itemst="{{['all','0','1','3','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row highlight"><view>{{"押金: "+item.money}}</view><block a:if="{{item.istx&&item.status==0}}"><view><button class="btn-mini2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['tixian',['$event']]]]]}}" onTap="__e">提现</button></view></block></view><view class="item-row"><view class="column"><text>{{"订单号: "+item.ordernum}}</text><text>{{"下单时间: "+item.createtime}}</text><block a:if="{{item.status==0}}"><text style="color:black;">{{"押金状态: "+item.status_name}}</text></block><block a:if="{{item.status==1}}"><text style="color:orange;">{{"押金状态: "+item.status_name}}</text></block><block a:if="{{item.status==2}}"><text style="color:red;">{{"押金状态: "+item.status_name}}</text></block><block a:if="{{item.status==3}}"><text style="color:green;">{{"押金状态: "+item.status_name}}</text></block><block a:if="{{item.status==2&&item.reason}}"><text>{{"驳回原因: "+item.reason}}</text></block></view></view><view class="item-row"><block a:if="{{item.diff}}"><text class="time">{{item.diff+"后可提现"}}</text></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="61c83c68-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="61c83c68-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="61c83c68-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="61c83c68-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="61c83c68-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>