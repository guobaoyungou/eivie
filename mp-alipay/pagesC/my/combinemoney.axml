<view class="container"><block a:if="{{isload}}"><block><view style="{{'width:100%;height:100%;'+('color:'+($root.m0)+';')}}"><view class="content"><view style="height:20rpx;line-height:20rpx;"></view><view class="mymoney" style="{{('background-color:'+$root.m1)}}"><view style="font-size:36rpx;font-weight:bold;">{{''+userinfo.money+''}}</view><view style="margin-top:10rpx;">{{'我的'+$root.m2+''}}</view><view class="tixian" style="{{('color:'+$root.m3)}}" data-url="/pagesExt/money/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我要提现</view></view><view class="mycombine" style="{{('background-color:'+$root.m4)}}"><view class="item"><view class="item-left">{{"我的"+$root.m5}}</view><view>{{userinfo.score}}</view></view><view class="item"><view class="item-left">{{"我的"+$root.m6}}</view><view>{{userinfo.commission}}</view></view><view class="item"><view class="item-left">{{"合成"+$root.m7+"数量"}}</view><view class="item-right"><input class="money" type="number" placeholder="请输入要合成的数量" placeholder-style="height: 60rpx;line-height: 60rpx;padding: 0 10rpx;" data-event-opts="{{[['input',[['inputMoney',['$event']]]]]}}" onInput="__e"/></view></view></view><view data-event-opts="{{[['tap',[['tocombine',['$event']]]]]}}" class="btn" style="{{('background-color:'+$root.m8)}}" onTap="__e">确认合成</view><view class="combinelog" data-url="/pagesC/my/combinemoneylog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">合成记录</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="7632caba-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="7632caba-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7632caba-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>