<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的冻结'+$root.m1+''}}</view><view class="f2">{{myforzengxcommission}}</view></view><dd-tab vue-id="d5506902-1" itemdata="{{['全部','释放中','已结束']}}" itemst="{{['all','0','1']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><view class="t1">{{"总冻结"+$root.m2+"："+item.commission}}</view><view class="t1">{{"未解冻"+$root.m3+"："+item.commission2}}</view><block a:if="{{item.showsendmonth}}"><block><view class="t1">{{"总释放月数："+item.sendmonth}}</view><view class="t1">{{"已释放月数："+item.sendmonth2}}</view></block></block><view class="t1">状态：<block a:if="{{item.status==1}}"><text>已结束</text></block><block a:if="{{item.status==0}}"><text style="color:green;">释放中</text></block></view><view class="t2">{{item.createtime}}</view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="d5506902-2" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="d5506902-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="d5506902-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="d5506902-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d5506902-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>