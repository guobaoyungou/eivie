<view class="container"><block a:if="{{isload}}"><block><block a:if="{{pid<=0}}"><view class="myshopscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}</view><view class="item flex-bt flex-y-center"><view class="value">{{myshopscore}}</view></view></view></block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block a:if="{{item.shopscore>0}}"><text style="color:green;">{{"+"+item.shopscore}}</text></block><block a:else><text style="color:red;">{{item.shopscore}}</text></block></view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="4e5e3193-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="4e5e3193-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="4e5e3193-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="4e5e3193-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4e5e3193-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>