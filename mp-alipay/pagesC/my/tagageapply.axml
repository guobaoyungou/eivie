<view class="container" style="{{(bgset&&bgset.bgcolor?'background-color:'+bgset.bgcolor:'')}}"><block a:if="{{errmsg==''&&isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><block a:if="{{aglevelCount>0&&!tagid}}"><view class="contentbox"><view class="form-item1"><view class="panel">请选择要申请的：</view><radio-group name="tagid" data-event-opts="{{[['change',[['changelevel',['$event']]]]]}}" onChange="__e"><block a:for="{{aglevelList}}" a:for-item="item" a:for-index="idx" a:key="idx"><label class="radio-item"><view class="flex1"><text style="font-weight:bold;">{{item.name}}</text></view><block a:if="{{item.id!=userlevel.id}}"><radio value="{{item.id+''}}"></radio></block></label></block></radio-group></view></view></block><block a:if="{{selectedLevel}}"><view class="contentbox"><view class="applytj"><view class="f1"><text>{{selectedLevel.name}}</text></view><view class="f2"><block a:if="{{bh_info}}"><view class="t4" style="color:red;font-size:26rpx;margin-bottom:20rpx;">{{bh_info}}</view></block><block a:if="{{selectedLevel.apply_formdata}}"><view class="t4">请填写申请资料</view></block></view></view><view class="applydata"><view class="form-item" a:for="{{selectedLevel.apply_formdata}}" a:for-item="item" a:for-index="idx" a:key="id"><view class="label">{{item.val1}}<block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" data-key="{{idx}}" data-event-opts="{{[['input',[['inputchange',['$event']]]]]}}" onInput="__e"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.val2[editorFormdata[idx]]}}</view></block><block a:else><view>请选择</view></block></picker></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker></block></block><block a:if="{{item.key=='region'}}"><block><uni-data-picker vue-id="{{'65a418e4-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" styleData="width:100%" data-event-opts="{{[['^change',[['onchange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{regiondata}}"/></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{editorFormdata[idx]}}"><view class="form-imgbox"><view class="layui-imgbox-close" style="z-index:2;" data-idx="{{idx}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view></block></block></view></view><button class="form-btn" form-type="submit">申 请</button></view></block></form><block a:if="{{nodata}}"><nodata vue-id="65a418e4-2" text="{{nots}}" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="65a418e4-3" onVueInit="__l"></nomore></block></block></block><view style="display:none;">{{test}}</view><block a:if="{{errmsg!=''&&isload}}"><block><view class="zan-box"><view class="zan-text">{{errmsg}}</view></view></block></block><block a:if="{{loading}}"><loading vue-id="65a418e4-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="65a418e4-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>