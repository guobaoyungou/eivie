<view class="container"><block a:if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><view class="title">请扫描码或输入随机码进行绑定</view><view class="inputdiv"><input id="bindcode" type="text" name="bindcode" placeholder-style="color:#666;" placeholder="扫描码或输入随机码" value="{{bindcode}}"/><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></view><button class="btn" form-type="submit">立即绑定</button><view class="f0" data-url="bindlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>查看绑定记录</text></view></form></block></block><block a:if="{{loading}}"><loading vue-id="1c639402-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="1c639402-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1c639402-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="1c639402-4" onVueInit="__l"></wxxieyi></view>