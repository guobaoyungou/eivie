<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><view style="width:200rpx;height:200rpx;"><image style="width:100%;height:100%;" src="{{item.qrcode}}" data-url="{{item.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view><view class="t2" style="width:470rpx;"><block a:if="{{item.code}}"><view>{{"随机码："+item.code}}</view></block><view>{{"绑定时间："+item.bindtime}}</view><block a:if="{{canbindsound}}"><block><view style="display:flex;justify-content:space-between;align-items:center;margin:20rpx auto;" data-id="{{item.id}}" data-soundid="{{item.soundid}}" data-event-opts="{{[['tap',[['openSound',['$event']]]]]}}" onTap="__e"><view>{{"绑定云音响："+item.soundname}}</view><view style="display:flex;align-items:center;"><text>去绑定</text><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></block><view class="unbind" data-id="{{item.id}}" data-event-opts="{{[['tap',[['unbind',['$event']]]]]}}" onTap="__e">解绑</view></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="0021940d-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="0021940d-2" onVueInit="__l"></nomore></block></block></block><uni-popup vue-id="0021940d-3" id="dialogSound" type="dialog" ref="__r" data-ref="dialogSound" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请选择云音响</text></view><view class="uni-dialog-content"><view class="flex-y-center flex-x-center" style="margin:20rpx 20rpx;"><view style="font-size:28rpx;color:#555;">云音响：</view><picker style="font-size:28rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;min-width:300rpx;" value="{{soundindex}}" range="{{sounds}}" range-key="name" mode="selector" data-event-opts="{{[['change',[['soundChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{soundindex>=0?sounds[soundindex]['name']:'请选择'}}</view></picker></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogSoundClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmSound',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><block a:if="{{loading}}"><loading vue-id="0021940d-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="0021940d-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0021940d-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>