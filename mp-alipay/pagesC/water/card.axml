<view class="container"><block a:if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><block a:if="{{cardlist.length>0}}"><block><view class="top" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.$orig.status==1}}"><view class="cardbg" style="{{('background: '+item.m0)}}"></view></block><block a:else><view class="cardbg"></view></block><view class="hyk flex"><view class="f1"><image src="{{set.logo}}"></image></view><view class="f2"><text class="t1">{{set.name}}</text><text class="t2">{{item.$orig.card_no}}</text><block a:if="{{item.$orig.status==-1}}"><text class="t3">已挂失</text></block><block a:if="{{item.$orig.status==0}}"><text class="t3">停用</text></block></view></view><view class="fr"><view class="btn-mini" data-cardno="{{item.$orig.card_no}}" data-event-opts="{{[['tap',[['unbind',['$event']]]]]}}" catchTap="__e">解绑</view></view></view></block></block><block a:else><block><block a:if="{{set.bind_card_status==1}}"><block><view class="title">请扫码进行绑定</view><view class="inputdiv"><input id="cardno" type="text" name="cardno" placeholder-style="color:#666;" placeholder="请输入您的卡号" value="{{cardno}}"/><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></view><button class="btn" form-type="submit">绑 定</button></block></block></block></block></form></block></block><block a:if="{{loading}}"><loading vue-id="6c11dfa2-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="6c11dfa2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6c11dfa2-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="6c11dfa2-4" onVueInit="__l"></wxxieyi></view>