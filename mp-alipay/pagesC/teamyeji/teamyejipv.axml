<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="topsearch flex-y-center sx"><text class="t1">日期筛选：</text><view data-event-opts="{{[['tap',[['toCheckDate',['$event']]]]]}}" class="body_data" style="min-width:200rpx;" onTap="__e">{{''+(startDate?startDate:'点击选择日期')+(endDate?' 至 '+endDate:'')+''}}</view><view class="t_date"><block a:if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" onTap="__e">清除</view></block></view></view><view class="yejilabel"><view class="t1 flex-bt" style="padding:10rpx;"><view>总群服务业绩</view><view>{{userinfo.teamyeji_pv}}</view></view><view class="t1 flex-bt" style="padding:10rpx;"><view>个群服务业绩</view><view>{{userinfo.my_teamyeji_pv}}</view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="651a1249-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="651a1249-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="651a1249-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="651a1249-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="651a1249-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>