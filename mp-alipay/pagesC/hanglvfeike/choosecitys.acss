page{height:100%}.title{padding:0 20rpx;font-weight:700}.hotname{width:160rpx;text-align:center;line-height:70rpx;border:2rpx solid #fff;border-radius:70rpx;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;background-color:#fff;display:inline-block;margin-right:10rpx;border:2rpx solid #f1f1f1}.cityname{background:#fff;padding:0 20rpx}.cityname-item{border-bottom:2rpx solid #f1f1f1}.cityname:last-child{border-bottom:0rpx}.topsearch{width:100%;padding:16rpx 20rpx;position:fixed;top:0;left:0;background-color:#fff;z-index:10}.topsearch .f1{height:60rpx;border-radius:30rpx;border:0;background-color:#f7f7f7;flex:1}.topsearch .f1 .img{width:24rpx;height:24rpx;margin-left:10px}.topsearch .f1 input{height:100%;flex:1;padding:0 20rpx;font-size:28rpx;color:#333}.topsearch .f1 .camera{height:72rpx;width:72rpx;color:#666;border:0;padding:0;margin:0;background-position:50%;background-repeat:no-repeat;background-size:40rpx}.topsearch .search-btn{display:flex;align-items:center;color:#5a5a5a;font-size:30rpx;width:60rpx;text-align:center;margin-left:20rpx}.search-navbar{display:flex;text-align:center;align-items:center;padding:5rpx 0}.search-navbar-item{flex:1;height:70rpx;line-height:70rpx;position:relative;font-size:28rpx;font-weight:700;color:#323232}