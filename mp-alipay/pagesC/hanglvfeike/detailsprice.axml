ound-color:'+$root.m4)}}" data-index="{{index}}" data-event-opts="{{[['tap',[['gobuy',['$event']]]]]}}" onTap="__e"><block a:if="{{item.$orig.showstock}}"><block><view style="color:#fff;padding:6rpx 0;">订</view><view style="{{('font-size: 24rpx;;color:'+item.m5+';background-color:#fff')}}">{{"剩"+item.$orig.stock+"张"}}</view></block></block><block a:else><block><view style="color:#fff;padding:20rpx 0;">订</view></block></block></view></view><view style="color:#999;line-height:50rpx;">{{item.$orig.levelname}}</view><view style="color:#999;line-height:50rpx;display:flex;align-items:center;border-radius:0 0 8rpx 8rpx;" data-index="{{index}}" data-cabinno="{{item.$orig.cabinNo}}" data-event-opts="{{[['tap',[['getguize',['$event']]]]]}}" onTap="__e">{{item.$orig.discount+'折退改详情'}}<image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view></block></view></block><block a:else><block><nodata vue-id="5cf95548-3" text="暂无航班信息" onVueInit="__l"></nodata></block></block></block></block></view><uni-popup vue-id="5cf95548-4" id="popup" type="bottom" ref="__r" data-ref="popup" onVueInit="__l"><view class="popup__content" style="bottom:0;padding-top:0;padding-bottom:0;max-height:86vh;background-color:#fff;border-radius:16rpx 16rpx;overflow:hidden;"><dd-tab vue-id="{{('5cf95548-5')+','+('5cf95548-4')}}" itemdata="{{['产品说明','行李规定','退改规则']}}" itemst="{{['0','1','2']}}" st="{{st2}}" showstatus="{{showstatus2}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab2']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><scroll-view style="height:auto;max-height:calc(86vh - 130rpx);" scrollIntoView="{{intoviewid}}" scrollWithAnimation="{{true}}" scroll-y="{{true}}"><block a:if="{{guize}}"><view style="padding:0 20rpx;"><view class="popup_title" id="scrollid0">产品说明</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m6+',0.4)')}}">票价/其他说明</view><block a:if="{{guize.baoxiaocontent}}"><view style="border-top:2rpx solid #f1f1f1;"><view style="display:flex;align-items:center;"><view class="popup-item-title">报销凭证</view><view class="popup-item-content">{{''+guize.baoxiaocontent+''}}</view></view></view></block><block a:if="{{guize.pricecontent}}"><view style="border-top:2rpx solid #f1f1f1;"><view style="display:flex;align-items:center;"><view class="popup-item-title">价格说明</view><view class="popup-item-content">{{''+guize.pricecontent+''}}</view></view></view></block></view><view class="popup_title" id="scrollid1">行李规定</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m7+',0.4)')}}">托运/手提行李</view><block a:if="{{guize.checkedluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">托运行李</view><view class="popup-item-content">{{''+guize.checkedluggage+''}}</view></view></block><block a:if="{{guize.cabinluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">手提行李</view><view class="popup-item-content">{{''+guize.cabinluggage+''}}</view></view></block><block a:if="{{guize.infantluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">婴儿行李</view><view class="popup-item-content">{{''+guize.infantluggage+''}}</view></view></block><block a:if="{{guize.luggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">其他说明</view><view class="popup-item-content">{{''+guize.luggage+''}}</view></view></block></view><view class="popup_title" id="scrollid2">退改规则</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m8+',0.4)')}}">退改费用/规则</view><block a:if="{{guize.refundStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">退改费</view><view class="popup-item-content"><block a:if="{{guize.refundStipulate.rules&&guize.refundStipulate.rules.length>0}}"><block><view a:for="{{guize.refundStipulate.rules}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.txt+" ￥"+item.charge+'/人'}}</view></block></block><block a:else><block><block a:if="{{guize.refundStipulate.comment}}"><view>{{guize.refundStipulate.comment}}</view></block></block></block></view></view></block><block a:if="{{guize.changeStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">同舱改签票</view><view class="popup-item-content"><block a:if="{{guize.changeStipulate.rules&&guize.changeStipulate.rules.length>0}}"><block><view a:for="{{guize.changeStipulate.rules}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.txt+" ￥"+item.charge+'/人'}}</view></block></block><block a:else><block><block a:if="{{guize.changeStipulate.comment}}"><view>{{guize.changeStipulate.comment}}</view></block></block></block></view></view></block><block a:if="{{guize.modifyStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">签转</view><view class="popup-item-content">{{''+guize.modifyStipulate+''}}</view></view></block><block a:if="{{guize.othercontent}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">其他说明</view><view class="popup-item-content">{{''+guize.othercontent+''}}</view></view></block></view></view></block><view style="width:100%;height:10rpx;"></view></scroll-view></view></uni-popup><block a:if="{{loading}}"><loading vue-id="5cf95548-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="5cf95548-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5cf95548-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>