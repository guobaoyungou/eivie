<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><block a:if="{{ordergoods}}"><view class="form-content"><view class="product"><view class="content" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="radio" style="{{(item.$orig.issel?'border:0;background:'+item.m0:'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" onTap="__e"><image class="radio-img" style="width:100%;height:100%;" mode="widthFix" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="detail" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" onTap="__e"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.cardNo}}</text></view></view></view></view></block><button data-event-opts="{{[['tap',[['changeapply',['$event']]]]]}}" class="ref-btn" onTap="__e">确定</button></form><block a:if="{{loading}}"><loading vue-id="dc9d025a-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="dc9d025a-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="dc9d025a-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></block></block></view>