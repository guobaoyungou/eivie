<view style="height:100%;background-color:#fff;"><block a:if="{{isload}}"><block><view style="width:750rpx;height:100%;"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索城市名称或拼音" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]],['focus',[['searchFocus',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e" onFocus="__e"/><block a:if="{{searchshow}}"><view data-event-opts="{{[['tap',[['closeSearch',['$event']]]]]}}" class="camera" style="{{('background-image:url('+pre_url+'/static/img/ico-del.png)')}}" onTap="__e"></view></block></view></view><view style="width:100%;height:100rpx;"></view><view style="width:100%;height:calc(100% - 100rpx);"><block a:if="{{letterlist&&letterlist.length>0}}"><scroll-view style="width:100%;height:100%;" scrollIntoView="{{intoviewid}}" scrollWithAnimation="{{animation}}" scroll-y="true"><view style="line-height:80rpx;font-size:28rpx;" id="letterpos"><view class="title" style="display:flex;justify-content:space-between;"><view>当前城市</view><view data-event-opts="{{[['tap',[['checkLocation',['$event']]]]]}}" style="{{('color:'+$root.m0)}}" onTap="__e">重新定位</view></view><block a:if="{{poslist&&poslist.length>0}}"><view style="width:100%;padding:0 20rpx;"><view class="hotname" style="background-color:#af1e24;color:#fff;border:0;" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" onTap="__e" a:for="{{poslist}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.name+''}}</view></view></block></view><block a:if="{{hotlist&&hotlist.length>0}}"><view style="line-height:80rpx;font-size:28rpx;" id="letterhot"><view class="title">热门城市</view><block a:if="{{hotlist&&hotlist.length>0}}"><view style="width:100%;padding:0 20rpx;"><view class="hotname" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" onTap="__e" a:for="{{hotlist}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.name+''}}</view></view></block></view></block><view style="line-height:80rpx;font-size:28rpx;" id="{{'letter'+item.letter}}" a:for="{{letterlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="title">{{item.letter}}</view><block a:if="{{item.childs&&item.childs.length>0}}"><view style="width:100%;padding:0 20rpx;"><view class="hotname" data-name="{{item2.name}}" data-code="{{item2.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" onTap="__e" a:for="{{item.childs}}" a:for-item="item2" a:for-index="index2" a:key="index2">{{''+item2.name+''}}</view></view></block></view></scroll-view></block></view><view style="position:fixed;right:0;top:20%;width:50rpx;text-align:center;font-size:24rpx;line-height:45rpx;"><block a:if="{{letterlist&&letterlist.length>0}}"><scroll-view scrollWithAnimation="{{animation}}" scroll-y="true"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view style="{{(index===currentActiveIndex?'color:'+item.m1:'')}}" data-letter="{{item.$orig.letter}}" data-index="{{index}}" data-event-opts="{{[['tap',[['toviewid',['$event']]]]]}}" onTap="__e">{{''+item.$orig.letter+''}}</view></block></scroll-view></block></view><block a:if="{{searchshow}}"><view style="{{'background-color:#fff;position:fixed;top:80rpx;left:0;width:100%;border-top:2rpx solid #f1f1f1;line-height:80rpx;'+('height:'+('calc(100% + 80rpx)')+';')}}"><view class="cityname" id="{{'letter'+index}}" a:for="{{searchlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="cityname-item" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" onTap="__e">{{item.name+" "+item.code}}</view></view></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="03d99f54-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="03d99f54-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar></view>