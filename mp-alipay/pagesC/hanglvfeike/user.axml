<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/证件号码搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view style="{{'width:170rpx;line-height:60rpx;border-radius:60rpx 60rpx;text-align:center;margin-left:20rpx;'+('color:'+$root.m0+';background:rgba('+$root.m1+',0.3)')}}" data-url="userdetail" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加旅客</view><view class="content" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.name}}</text><text class="t2"></text><text class="flex1"></text><image class="t3" src="{{pre_url+'/static/img/edit.png'}}" data-url="{{'userdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"></image></view><view class="f2">{{item.$orig.typename+":"+item.$orig.usercard}}</view><view class="f3"><block a:if="{{type=='choose'}}"><view class="flex-y-center" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" onTap="__e"><view class="radio" style="{{(item.$orig.issel?'border:0;background:'+item.m2:'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block><view class="flex1"></view><view class="del" style="{{'color:'+($root.m3)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" catchTap="__e">删除</view></view></view><block a:if="{{nodata}}"><nodata vue-id="866d7950-1" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view><block a:if="{{type=='choose'}}"><view data-event-opts="{{[['tap',[['backchoose',['$event']]]]]}}" class="{{(('btn-add')+' '+(menuindex>-1?'tabbarbot':'notabbarbot3'))}}" style="{{('background:linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')}}" onTap="__e">确定选择</view></block></block></block><block a:if="{{loading}}"><loading vue-id="866d7950-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="866d7950-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="866d7950-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>