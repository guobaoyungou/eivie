<block a:if="{{isload}}"><view class="page-view"><view class="banner-view"><view class="swiper-container"><block a:if="{{banners}}"><swiper class="swiper" style="{{'height:'+(swiperHeight+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" current="{{current}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{banners}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><view class="swiper-item-view" style="{{'height:'+(swiperHeight+'px')+';'}}" data-linkurl="{{item.linkurl}}" id="{{'content-wrap'+index}}" data-event-opts="{{[['tap',[['golinkurl',['$event']]]]]}}" onTap="__e"><image class="img" src="{{item.pic}}" mode="widthFix" data-event-opts="{{[['load',[['loadImg',['$event']]]]]}}" onLoad="__e"></image></view></swiper-item></block></swiper></block></view></view><view class="content-view flex-col"><view class="tab-view flex flex-y-center"><view data-event-opts="{{[['tap',[['tabChange',[0]]]]]}}" class="{{((tabIndex==0?'tab-options-active':'')+' '+'tab-options')}}" onTap="__e">机票</view></view><view class="fun-view flex-col"><view class="fun-tab flex felx-y-center"><view data-event-opts="{{[['tap',[['funTabChange',[0]]]]]}}" class="{{((airtype==0?'funtab-left-active':'not-left-active')+' '+'fun-tab-options')}}" onTap="__e">单程</view></view><view class="info-view flex-col"><view class="address-view flex"><view class="address-text" style="text-align:left;" data-url="choosecitys?type=from" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><block a:if="{{fromCityname}}"><text style="color:#000;">{{fromCityname}}</text></block><block a:else><text>出发地</text></block></view><view data-event-opts="{{[['tap',[['switchChange',['$event']]]]]}}" class="address-switch flex" onTap="__e"><image class="{{((switchType?'bg-img-active':'')+' '+'bg-img')}}" src="{{pre_url+'/static/img/planeticket/qiehuan.png'}}"></image><image class="logo-img" src="{{pre_url+'/static/img/planeticket/feijizhong.png'}}"></image></view><view class="address-text" style="text-align:right;" data-url="choosecitys?type=to" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><block a:if="{{toCityname}}"><text style="color:#000;">{{toCityname}}</text></block><block a:else><text>目的地</text></block></view></view><view class="time-view flex-col"><view class="title-text">出发时间</view><view class="time-num-text" style="display:flex;justify-content:space-between;"><view data-event-opts="{{[['tap',[['toSelectDate',[1,'$0'],['daytime']]]]]}}" onTap="__e">{{day+" "+week}}</view><block a:if="{{airtype==1}}"><view data-event-opts="{{[['tap',[['toSelectDate',[2,'$0','$1'],['daytime','daytime2']]]]]}}" onTap="__e">{{day2+" "+week2}}</view></block></view></view><view data-event-opts="{{[['tap',[['godetails',['$event']]]]]}}" class="search-but" onTap="__e">搜索机票</view></view></view><view style="position:relative;height:120rpx;"><block a:if="{{linktel}}"><view style="font-size:32rpx;text-align:center;color:#af1e24;" data-phone="{{linktel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" onTap="__e">联系客服</view></block><view style="width:70rpx;position:absolute;top:50rpx;right:20rpx;"><block a:if="{{kfurl!='contact::'}}"><view style="width:70rpx;" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" style="width:70rpx;height:70rpx;" src="{{pre_url+'/static/img/kefu.png'}}"></image></view></block><block a:else><button style="width:70rpx;" open-type="contact" show-message-card="true"><image class="img" style="width:70rpx;height:70rpx;" src="{{pre_url+'/static/img/kefu.png'}}"></image></button></block></view></view></view><block a:if="{{loading}}"><loading vue-id="3119b6da-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="3119b6da-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="3119b6da-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>