<block a:if="{{isload}}"><view class="page-view"><view class="top-view flex-col"><block a:if="{{headlist&&headlist.length>0}}"><view class="time-view flex flex-y-center"><view class="time-left-view flex"><scroll-view style="flex:1;white-space:nowrap;" scroll-x="{{true}}"><view style="display:flex;justify-content:space-between;"><view style="display:flex;padding-right:5rpx;width:99%;"><block a:if="{{headlist&&headlist.length>0}}"><block><view style="display:inline-block;width:30%;" a:for="{{headlist}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['toSelectDate',['$0','$1'],['goDate','backDate']]]]]}}" class="{{((item.issel?'time-options-active':'')+' '+'time-options flex-col')}}" onTap="__e"><view class="time-title">{{item.week}}</view><view class="time-num">{{item.daystr}}</view><view class="time-title">去</view></view></view></block></block></view><view style="width:10rpx;height:130rpx;background-color:#f1f1f1;"></view><view style="display:flex;padding-left:5rpx;width:99%;"><block a:if="{{headlist2&&headlist2.length>0}}"><block><view style="display:inline-block;width:30%;" a:for="{{headlist2}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['toSelectDate',['$0','$1'],['goDate','backDate']]]]]}}" class="{{((item.issel?'time-options-active':'')+' '+'time-options flex-col')}}" onTap="__e"><view class="time-title">{{item.week}}</view><view class="time-num">{{item.daystr}}</view><view class="time-title">返</view></view></view></block></block></view></view></scroll-view></view><view class="time-right-view flex flex-y-center flex-x-center"><image class="rili-icon" src="{{pre_url+'/static/img/planeticket/rili.png'}}" data-event-opts="{{[['tap',[['toSelectDate',['$0','$1'],['goDate','backDate']]]]]}}" onTap="__e"></image></view></view></block></view><view class="jipiao-list-view flex-col"><block a:if="{{datalist&&datalist.length>0}}"><block><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="jipiao-options flex-col" data-index="{{index}}" data-event-opts="{{[['tap',[['goprice',['$event']]]]]}}" onTap="__e"><view class="info-view flex"><block a:if="{{item.airlinePic}}"><view class="info-touxiang"><image src="{{item.airlinePic}}"></image></view></block><view class="info-details-view flex flex-y-center"><view class="location-view flex-col"><view class="location-time">{{item.departTime}}</view><view class="location-name">{{item.deparAirportName+item.departTerminal}}</view></view><view class="location-icon"><image src="{{pre_url+'/static/img/planeticket/jiantou.png'}}" mode="widthFix"></image></view><view class="location-view flex-col"><view class="location-time">{{item.arriveTime}}</view><view class="location-name">{{item.arriveAirportName+item.arriveTerminal}}</view></view></view><view class="price-view flex-col flex-y-center"><view class="price-num flex flex-y-center"><view style="font-size:24rpx;">￥</view><view style="font-size:38rpx;">{{item.minFdPrice}}</view></view><view class="price-name">{{''+item.levelname+''}}</view></view></view><view class="jipiao-introduce">{{''+item.airlineName+item.no+"| "+item.planeCName+" ("+item.planeTypeName+") | "+item.flightTime+''}}</view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="c0dd2b0e-1" text="暂无航班信息" onVueInit="__l"></nodata></block></view><block a:if="{{loading}}"><loading vue-id="c0dd2b0e-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="c0dd2b0e-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="c0dd2b0e-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>