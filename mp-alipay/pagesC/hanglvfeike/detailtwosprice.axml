<block a:if="{{isload}}"><view class="page-view"><view style="background-color:#fff;padding:20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><block a:if="{{airlinePic}}"><view style="width:50rpx;height:50rpx;"><image style="width:100%;height:100%;" src="{{airlinePic}}"></image></view></block><view><view style="font-size:26rpx;color:#999;">{{''+fromDate+" "+week+"\n              "+deparAirportName+departTerminal+" - "+arriveAirportName+arriveTerminal+''}}</view><view style="display:flex;align-items:center;margin:25rpx 0;"><view style="font-size:36rpx;font-weight:bold;">{{departTime}}</view><image style="margin:0 20rpx;width:100rpx;" src="{{pre_url+'/static/img/planeticket/jiantou.png'}}" mode="widthFix"></image><view style="font-size:36rpx;font-weight:bold;">{{arriveTime}}</view></view><view style="font-size:26rpx;color:#999;">{{''+airlineName+no+"| "+planeCName+" ("+planeTypeName+") | "+flightTime+''}}</view></view></view></view><view class="jipiao-list-view flex-col"><view style="border-top:2rpx solid #f1f1f1;"><dd-tab vue-id="ec92fa98-1" itemdata="{{itemdata}}" itemst="{{itemst}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><block a:if="{{st==0}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view style="padding:0 20rpx;margin-top:20rpx;"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view style="background-color:#fff;border-radius:12rpx;margin-bottom:20rpx;"><view style="padding:10rpx 20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="{{('color:'+$root.m0)}}"><text>￥</text><text style="font-size:40rpx;">{{item.fdPrice}}</text></view><view style="{{'border-radius:8rpx;overflow:hidden;padding:4rpx;width:90rpx;'+('text-align:center;background-color:'+$root.m1)}}" data-index="{{index}}" data-event-opts="{{[['tap',[['gobuy',['$event']]]]]}}" onTap="__e"><view style="color:#fff;padding:6rpx 0;">订</view><view style="{{('font-size: 24rpx;;color:'+$root.m2+';background-color:#fff')}}">{{"剩"+item.stock+"张"}}</view></view></view><view style="color:#999;line-height:50rpx;">{{item.levelname}}</view><view data-event-opts="{{[['tap',[['getguize',['$event']]]]]}}" style="color:#999;line-height:50rpx;display:flex;align-items:center;border-radius:0 0 8rpx 8rpx;" onTap="__e">{{item.discount+'折退改详情'}}<image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view></block></view></block><block a:else><block><nodata vue-id="ec92fa98-2" text="暂无航班信息" onVueInit="__l"></nodata></block></block></block></block><block a:if="{{st==1}}"><block><block a:if="{{datalist2&&datalist2.length>0}}"><view style="padding:0 20rpx;margin-top:20rpx;"><block a:for="{{datalist2}}" a:for-item="item" a:for-index="index" a:key="index"><view style="background-color:#fff;border-radius:12rpx;margin-bottom:20rpx;"><view style="padding:10rpx 20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="{{('color:'+$root.m3)}}"><text>￥</text><text style="font-size:40rpx;">{{item.fdPrice}}</text></view><view style="{{'border-radius:8rpx;overflow:hidden;padding:4rpx;width:90rpx;'+('text-align:center;background-color:'+$root.m4)}}" data-index="{{index}}" data-event-opts="{{[['tap',[['gobuy',['$event']]]]]}}" onTap="__e"><view style="color:#fff;padding:6rpx 0;">订</view><view style="{{('font-size: 24rpx;;color:'+$root.m5+';background-color:#fff')}}">{{"剩"+item.stock+"张"}}</view></view></view><view style="color:#999;line-height:50rpx;">{{item.levelname}}</view><view data-event-opts="{{[['tap',[['getguize',['$event']]]]]}}" style="color:#999;line-height:50rpx;display:flex;align-items:center;border-radius:0 0 8rpx 8rpx;" onTap="__e">{{item.discount+'折退改详情'}}<image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></vi