y:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">手提行李</view><view class="popup-item-content">{{''+(guize?guize.cabinluggage:'')+''}}</view></view><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">婴儿行李</view><view class="popup-item-content">{{''+(guize?guize.infantluggage:'')+''}}</view></view></view><view class="popup_title" id="scrollid2">退改规则</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m8+',0.4)')}}">退改费用/规则</view><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">退改费</view><view class="popup-item-content"><block a:if="{{guize&&guize.refundStipulate&&guize.refundStipulate.length>0}}"><block><block a:if="{{guize.refundStipulate.rules&&guize.refundStipulate.rules.length>0}}"><block><view a:for="{{guize.refundStipulate.rules}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.txt+" ￥"+item.txt+'/人'}}</view></block></block></block></block></view></view><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">同舱改签票</view><view class="popup-item-content"><block a:if="{{guize&&guize.changeStipulate&&guize.changeStipulate.length>0}}"><block><block a:if="{{guize.changeStipulate.rules&&guize.changeStipulate.rules.length>0}}"><block><view a:for="{{guize.changeStipulate.rules}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item.txt+" ￥"+item.txt+'/人'}}</view></block></block></block></block></view></view><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">签转</view><view class="popup-item-content">{{''+(guize?guize.modifyStipulate:'')+''}}</view></view><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">其他说明</view><view class="popup-item-content">{{''+(guize?g