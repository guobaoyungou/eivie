<block a:if="{{isload}}"><view class="page-view"><view style="background-color:#fff;padding:20rpx;"><view style="display:flex;align-items:center;margin:25rpx 0;justify-content:space-between;"><view><view style="font-weight:bold;font-size:32rpx;text-align:center;">{{''+changesdata.departAirport+changesdata.departTerminal+" - "+changesdata.arriveAirport+changesdata.arriveTerminal+" "+changeTime+" "+week+''}}</view></view></view></view><view style="background-color:#fff;border-radius:10rpx 10rpx;padding:20rpx;margin:20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="font-weight:bold;font-size:32rpx;">改签人员<block a:if="{{changesdata&&changesdata.showstock}}"><text style="font-size:24rpx;">{{"(剩"+changesdata.stock+"张)"}}</text></block></view></view><block a:if="{{userdata&&userdata.length>0}}"><view style="padding:20rpx 0;"><view style="display:flex;align-items:center;" a:for="{{userdata}}" a:for-item="item2" a:for-index="index" a:key="index"><view style="margin-left:20rpx;"><view>{{item2.name}}</view><view style="color:#999;">{{item2.typename+" "+item2.usercard}}</view></view></view></view></block><view style="line-height:80rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">改签原因</view><textarea style="width:100%;border:2rpx solid #f1f1f1;border-radius:4rpx;padding:10rpx;" placeholder="请输入改签原因" placeholder-style="color:#999;padding: 10rpx;" name="reason" data-event-opts="{{[['input',[['inputReason',['$event']]]]]}}" onInput="__e"></textarea></view></view></view><block a:if="{{changesdata.showFee||changesdata.showchildFee}}"><view style="background-color:#fff;border-radius:10rpx 10rpx;padding:20rpx;margin:20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="font-weight:bold;font-size:32rpx;">费用明细</view></view><block a:if="{{changesdata.showFee}}"><view style="line-height:80rpx;"><block a:if="{{changesdata.gqFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">手续费</view><view style="{{('color:'+$root.m0)}}">{{"￥"+changesdata.gqFee+"/人"}}</view></view></block><block a:if="{{changesdata.upgradeFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">升舱费</view><view style="{{('color:'+$root.m1)}}">{{"￥"+changesdata.upgradeFee+"/人"}}</view></view></block><block a:if="{{changesdata.allFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">总收费</view><view style="{{('color:'+$root.m2)}}">{{"￥"+changesdata.allFee+"/人"}}</view></view></block></view></block><block a:if="{{changesdata.showchildFee}}"><view style="line-height:80rpx;"><block a:if="{{changesdata.childGqFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童手续费</view><view style="{{('color:'+$root.m3)}}">{{"￥"+changesdata.childGqFee+"/人"}}</view></view></block><block a:if="{{changesdata.childUpgradeFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童升舱费</view><view style="{{('color:'+$root.m4)}}">{{"￥"+changesdata.childUpgradeFee+"/人"}}</view></view></block><block a:if="{{changesdata.childAllFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童总费用</view><view style="{{('color:'+$root.m5)}}">{{"￥"+changesdata.childAllFee+"/人"}}</view></view></block></view></block></view></block><block a:if="{{xieyidata&&xieyidata.length>0}}"><view style="width:100%;height:290rpx;"></view></block><block a:else><view style="width:100%;height:182rpx;"></view></block><view class="footer  notabbarbot"><view style="display:flex;align-items:center;padding:20rpx 0;"><button data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="op" style="{{'width:50%;'+('background:'+('linear-gradient(-90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';')}}" onTap="__e">确定申请改签</button></view></view><block a:if="{{loading}}"><loading vue-id="8f6d6ae2-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="8f6d6ae2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="8f6d6ae2-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>