<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="6cb21439-1" itemdata="{{['全部','待付款','待出票','已出票','退款/售后']}}" itemst="{{['all','0','1','2','5']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head flex"><view class="flight-name flex flex-y-center"><view class="flight-icon"><image src="{{pre_url+'/static/img/planeticket/hangban.png'}}"></image></view><view>{{item.$orig.airlineName+item.$orig.flightNo}}</view></view><block a:if="{{item.$orig.status==0}}"><view class="st0 flex-y-center">待付款</view></block><block a:if="{{item.$orig.status==1}}"><view class="st1 flex-y-center">待出票</view></block><block a:if="{{item.$orig.status==2}}"><view class="st2 flex-y-center">已出票</view></block><block a:if="{{item.$orig.status==3}}"><view class="st2 flex-y-center">已完成</view></block><block a:if="{{item.$orig.status==4}}"><view class="st4 flex-y-center">已关闭</view></block></view><view class="content" style="border-bottom:none;"><view class="detail"><view class="t1">{{item.$orig.fromCityname+" - "+item.$orig.toCityname}}</view><view class="t1">{{item.$orig.fromDate+"("+item.$orig.week+')'}}<block a:if="{{item.$orig.flightdata}}"><text style="margin-left:10rpx;">{{item.$orig.flightdata.departTime+" - "+item.$orig.flightdata.arriveTime}}</text></block></view><view class="t1 flex flex-y-center"><view class="t1-title">订单号：</view><view>{{item.$orig.ordernum}}</view></view><block a:if="{{!item.$orig.ischange}}"><block><view class="t1"><text class="t1-title">机票类型：</text>普通机票</view></block></block><block a:else><block><view class="t1"><text class="t1-title">机票类型：</text><text style="color:#ff8758;">改签机票</text></view></block></block><block a:if="{{item.$orig.change_status!=0}}"><view class="t1 flex flex-y-center"><text class="t1-title">改签状态：</text><block a:if="{{item.$orig.change_status==1}}"><text style="color:#ff8758;">待审核</text></block><block a:if="{{item.$orig.change_status==2}}"><text style="color:green;">已审核</text></block><block a:if="{{item.$orig.change_status==3}}"><text style="color:#999;">已完成</text></block><block a:if="{{item.$orig.change_status==-1}}"><text style="color:#bbb;">已取消</text></block><block a:if="{{item.$orig.change_status==-2}}"><text style="color:#bbb;">已驳回</text></block></view></block></view></view><view class="bottom flex"><view class="flex-y-center"><view class="title-text">实付：</view><block a:if="{{item.$orig.ischange&&item.$orig.status==0&&item.$orig.change_status==1}}"><view>审核中</view></block><block a:else><view class="price-text flex flex-y-center"><text style="font-size:24rpx;">￥</text>{{item.$orig.totalprice+''}}</view></block><block a:if="{{item.$orig.refund_money>0}}"><view style="color:red;font-size:26rpx;">(<text>已退款:</text><text>{{"￥"+item.$orig.refund_money}}</text>)</view></block></view></view><view class="op"><block a:if="{{item.g0}}"><block><view class="btn2" data-url="{{'/pagesExt/order/invoice?type=hanglvfeike&orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">发票</view></block></block><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-ischange="{{item.$orig.ischange}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e"><block a:if="{{item.$orig.ischange}}"><text>取消改签</text></block><block a:else><text>关闭订单</text></block></view><block a:if="{{item.$orig.canpay}}"><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去付款</view></block></block></block><block a:if="{{item.$orig.canchange}}"><view class="btn2" data-url="{{'change?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">改签</view></block><block a:if="{{item.$orig.canrefund}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">退款</view></block><block a:if="{{item.$orig.refundcount>0}}"><view class="btn2" data-url="{{'refundlist?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">售后详情</view></block><block a:if="{{item.$orig.candel}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchTap="__e">删除订单</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="6cb21439-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="6cb21439-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="6cb21439-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="6cb21439-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6cb21439-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>