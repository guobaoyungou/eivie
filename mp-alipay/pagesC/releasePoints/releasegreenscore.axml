<block a:if="{{isload}}"><view><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放积分</view><view class="points-num">{{total_data.have_release}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{total_data.green_score}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{total_data.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日价值</view><view class="num-text">{{total_data.green_score_price}}</view></view></view></view><view class="list-title-view">{{'释放'+$root.m1+'日记'}}</view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark+":"+item.dec_score}}</view><view class="time-text">{{item.create_time}}</view></view><view class="price-view">{{item.green_score_value}}</view></view></block><block a:if="{{nodata}}"><nodata vue-id="431058e6-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="431058e6-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="431058e6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="431058e6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="431058e6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>