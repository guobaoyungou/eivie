<block a:if="{{isload}}"><view><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{cashback_total.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日新增</view><view class="num-text">{{cashback_total.today_add}}</view></view></view></view><view class="list-title-view">释放日记</view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark}}</view><view class="time-text">{{item.create_time}}</view></view><view class="price-view">{{item.back_price}}</view></view></block><block a:if="{{nodata}}"><nodata vue-id="bee2df7e-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="bee2df7e-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="bee2df7e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="bee2df7e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="bee2df7e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>