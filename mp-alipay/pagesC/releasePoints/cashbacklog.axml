<block a:if="{{isload}}"><view><block a:if="{{showyejidata}}"><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view><block a:if="{{set.cashback_multiply_yeji_type==0}}"><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{cashback_total.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日新增</view><view class="num-text">{{cashback_total.today_add}}</view></view></view></block></view></block><dd-tab vue-id="1392e4ce-1" itemdata="{{[$root.m1+'列表','已完成记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row"><view class="column"><text>{{"发放数量: "+item.back_price}}</text><text>{{"剩余数量: "+item.remain}}</text></view><view class="column"><text>{{"释放数量: "+(item.have_send||0)}}</text><block a:if="{{showLastCircleYeji}}"><text>{{"上期业绩: "+(item.last_circle_yeji||0)}}</text></block></view></view><view class="item-row highlight"><block a:if="{{item.status!=2}}"><text>{{"上期释放: "+item.last_circle_send}}</text></block><block a:if="{{item.status==2}}"><text>已完成</text></block></view><view class="item-row"><text class="time">{{item.createtime}}</text><block><button class="btn-mini2" data-url="{{'/pagesC/releasePoints/ogdetails?og_id='+item.sog_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看明细</button></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="1392e4ce-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="1392e4ce-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="1392e4ce-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="1392e4ce-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1392e4ce-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>