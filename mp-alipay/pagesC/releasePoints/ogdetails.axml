<block a:if="{{isload}}"><view><block a:if="{{showyejidata}}"><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><block a:if="{{showHaveRelease}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view></block><block a:if="{{showRemainRelease||showLastCircleYeji||showNextCircleYeji}}"><view class="top-data-list flex flex-y-center"><block a:if="{{showRemainRelease}}"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view></block><block a:if="{{showRemainRelease&&showLastCircleYeji}}"><view class="line-class"></view></block><block a:if="{{showLastCircleYeji}}"><view class="data-options flex-col"><view class="title-text">上期平台业绩</view><view class="num-text">{{cashback_total.last_circle_yeji}}</view></view></block><block a:if="{{showLastCircleYeji&&showNextCircleYeji}}"><view class="line-class"></view></block><block a:if="{{showNextCircleYeji}}"><view class="data-options flex-col"><view class="title-text">下期平台业绩</view><view class="num-text">{{cashback_total.next_circle_yeji}}</view></view></block></view></block></view></block><view class="list-title-view">释放日记</view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark}}</view><view class="time-text">{{item.create_time}}</view></view><block a:if="{{item.is_yuji==1}}"><view class="price-view" style="color:green;">{{item.back_price}}</view></block><block a:else><view class="price-view">{{item.back_price}}</view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="1cfe9659-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="1cfe9659-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="1cfe9659-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1cfe9659-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1cfe9659-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>