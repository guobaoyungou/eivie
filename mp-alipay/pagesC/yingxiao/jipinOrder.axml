<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="16acfabf-1" itemdata="{{['全部','未完成','已完成']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入活动名称/订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row highlight"><view>{{"序号: "+item.num}}</view><view><button class="btn-mini2" data-url="{{'jipinCharts?id='+item.id}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">关系图</button></view></view><view class="item-row"><view class="column"><text>{{"所属活动: "+item.collage_jipin_name}}</text><text>{{"订单号: "+item.ordernum}}</text><text>{{"订单商品: "+item.goods_name}}</text><text>{{"时间: "+item.createtime}}</text><block a:if="{{item.status==0}}"><text style="color:#2D66FC;">{{"状态: "+item.status_name}}</text></block><block a:if="{{item.status==1}}"><text style="color:#888;">{{"状态: "+item.status_name}}</text></block><block a:if="{{item.status==1}}"><text style="color:#888;">{{"出局时间："+item.outtime}}</text></block></view></view><view class="item-row"><block a:if="{{item.diff}}"><text class="time">{{item.diff+"后可提现"}}</text></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="16acfabf-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="16acfabf-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="16acfabf-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="16acfabf-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="16acfabf-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>