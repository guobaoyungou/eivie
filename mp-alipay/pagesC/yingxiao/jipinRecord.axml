<view class="container"><block a:if="{{isload}}"><block><view class="flex flex-x-center statistics-view"><view class="flex-col flex-y-center statais-options"><view class="top-num">{{platform_group_num}}</view><view class="title-text">平台成团次数</view></view><view class="flex-col flex-y-center statais-options"><view class="top-num">{{platform_cumulative}}</view><view class="title-text">平台累计奖励</view></view></view><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center"><view class="avatar-view"><image src="{{member.headimg}}"></image></view><view style="padding-left:20rpx;"><view class="user-name flex flex-y-center"><view>{{member.nickname}}</view><block a:if="{{ktjl>0}}"><view class="tuanzhang-tag flex flex-y-center"><image class="tuanzhang-icon" src="{{pre_url+'/static/img/jipin_tuanzhang.png'}}"></image>团长</view></block></view><block a:if="{{member.p_nickname}}"><view class="reference-name">{{"推荐人："+member.p_nickname}}</view></block></view></view><block a:if="{{yx_collage_jipin_optimize&&hdinfo.go_withdraw_name}}"><view class="withdraw-money" data-url="{{hdinfo.go_withdraw_name_tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{hdinfo.go_withdraw_name}}</view></block></view><view class="rewards-view flex flex-y-center"><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">累计团长奖励(元)</view><view class="rewards-price">{{group_cumulative}}</view></view><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">累计成团(次)</view><view class="rewards-price">{{group_num}}</view></view><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">累计直推开团(次)</view><view class="rewards-price">{{group_recommend_num}}</view></view></view><view class="de-img-view"><image src="{{pre_url+'/static/img/jipinde.png'}}"></image></view><block a:if="{{ktjl<=0}}"><view class="mask-view">暂无开团记录</view></block></view><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center"><view>参团活动产品</view></view><block a:if="{{yx_collage_jipin_optimize&&hdinfo.description_name}}"><view class="activity-description" data-url="{{hdinfo.description_name_tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{hdinfo.description_name}}</view></block></view><block a:if="{{product_list.length>0}}"><block><view class="shop-list-view"><scroll-view style="white-space:nowrap;width:100%;" scroll-x="{{true}}"><block a:for="{{product_list}}" a:for-item="item" a:for-index="index"><view class="shop-view flex-col flex-y-center" data-url="{{'pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="shop-image"><image src="{{item.pic}}"></image></view><view class="shop-price-view">{{"￥"+item.sell_price}}</view></view></block></scroll-view></view></block></block><block a:else><block><view class="shop-list-view" style="text-align:center;display:block;color:#959494;">{{''+product_jzai+''}}</view></block></block></view><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center" style="justify-content:space-between;"><view data-event-opts="{{[['tap',[['changeTab',[0]]]]]}}" class="{{((tabIndex==0?'tab-options-active':'')+' '+'tab-options')}}" onTap="__e">进行中</view><view data-event-opts="{{[['tap',[['changeTab',[1]]]]]}}" class="{{((tabIndex==1?'tab-options-active':'')+' '+'tab-options')}}" onTap="__e">已成团</view></view></view><block a:if="{{tabIndex==0}}"><block><block a:if="{{progress_list.length>0}}"><view class="activity-list-view flex-col"><block a:for="{{progress_list}}" a:for-item="item" a:for-index="index"><view class="flex active-options"><view class="active-image" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e"><image src="{{item.pic}}"></image></view><view class="active-info-list flex-col"><view class="active-name" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.name}}</view><view class="active-jingdu" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.cantuan}}</view><view data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e"><progress percent="{{item.hc_offered_num}}" font-size="13" show-info="{{true}}" activeColor="#fb484c" active="{{true}}" stroke-width="8" border-radius="12"></progress></view><block a:if="{{yx_collage_jipin_optimize&&item.award_display}}"><view class="reward-amount" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.award_display}}</view></block><view class="active-fun-view flex flex-y-center"><block a:if="{{hdinfo.invite_land==1}}"><block><block a:if="{{$root.m0=='app'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><block a:if="{{$root.m1=='mp'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><block a:if="{{$root.m2=='h5'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><button class="btn2 fun-class invite-friends" style="line-height:32rpx;" open-type="share" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}">邀请好友</button></block></block></block></block></block><block a:if="{{hdinfo.invite_land==0}}"><view class="fun-class invite-friends" data-url="/activity/commission/poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:if="{{hdinfo.opening_detail==1}}"><view class="fun-class view-details" style="margin-left:25rpx;" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">查看详情</view></block></view></view></view></block></view></block><block a:else><view class="activity-list-view flex-col"><view class="flex active-options" style="text-align:center;display:block;color:#959494;">{{progress_jzai}}</view></view></block></block></block><block a:if="{{tabIndex==1}}"><block><block a:if="{{clustering_list.length>0}}"><view class="activity-list-view flex-col"><block a:for="{{clustering_list}}" a:for-item="item" a:for-index="index"><block a:if="{{clustering_list.length>0}}"><block><view class="flex active-options"><view class="active-image" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e"><image src="{{item.pic}}"></image></view><view class="active-info-list flex-col"><view class="active-name" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.name}}</view><view class="active-jingdu" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.cantuan}}</view><view data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e"><progress percent="{{item.hc_offered_num}}" font-size="13" show-info="{{true}}" activeColor="#fb484c" active="{{true}}" stroke-width="8" border-radius="12"></progress></view><block a:if="{{item.award_display}}"><view class="reward-amount" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">{{item.award_display}}</view></block><view class="active-fun-view flex flex-y-center"><block a:if="{{hdinfo.invite_land==1}}"><block><block a:if="{{$root.m3=='app'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><block a:if="{{$root.m4=='mp'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><block a:if="{{$root.m5=='h5'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:else><button class="btn2 fun-class invite-friends" style="line-height:32rpx;" open-type="share" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}">邀请好友</button></block></block></block></block></block><block a:if="{{hdinfo.invite_land==0}}"><view class="fun-class invite-friends" data-url="/activity/commission/poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">邀请好友</view></block><block a:if="{{hdinfo.opening_detail==1}}"><view class="fun-class view-details" style="margin-left:25rpx;" data-url="{{'jipinCharts?id='+item.id}}" data-opening_detail="{{item.opening_detail}}" data-event-opts="{{[['tap',[['ckjpxq',['$event']]]]]}}" catchTap="__e">查看详情</view></block></view></view></view></block></block></block></view></block><block a:else><view class="activity-list-view flex-col"><view class="flex active-options" style="text-align:center;display:block;color:#959494;">{{clustering_jzai}}</view></view></block></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="2c8c7eac-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="2c8c7eac-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2c8c7eac-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>