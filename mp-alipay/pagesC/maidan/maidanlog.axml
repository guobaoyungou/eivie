<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'maidandetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><text class="t1">{{item.paytime}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><block a:if="{{canrefund&&item.refund_money>0}}"><text class="t2">{{"退款金额：￥"+item.refund_money}}</text></block></view><view class="f2"><text class="t1">{{"-￥"+item.money}}</text></view></view></block></view></block></block><block a:if="{{nodata}}"><nodata vue-id="c455b656-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="c455b656-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="c455b656-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="c455b656-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="c455b656-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>