<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><view class="t1">活动人数<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.total_num}}</text>人</view></view><view class="p2 flex flex-y-center"><view class="fun-class invite-friends" data-url="{{'/pagesC/liandong/team?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看活动</view><view class="fun-class invite-friends" data-id="{{item.id}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchTap="__e">邀请好友</view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="8287fa4e-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="8287fa4e-2" onVueInit="__l"></nodata></block></view></block></block><block a:if="{{loading}}"><loading vue-id="8287fa4e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="8287fa4e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="8287fa4e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m0!='h5'}}"><button class="f1" open-type="share" data-id="{{share_active_id}}"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></view>