<view class="container"><block a:if="{{isload}}"><block><view style="{{'min-height:100vh;background-size:cover;'+('background-image:'+('url('+pages_bg+')')+';')}}"><view class="title" style="{{'color:'+(title_color)+';'}}">{{title_text}}</view><view class="content"><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><block a:if="{{lipinset.needno==1}}"><block><view class="inputdiv"><input id="cardno" type="text" name="cardno" placeholder-style="color:#666;" placeholder="请输入您的卡号" value="{{cardno}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao2',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view><view class="inputdiv"><input id="dhcode" type="text" name="dhcode" placeholder-style="color:#666;" placeholder="请输入您的密码" value="{{dhcode}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view></block></block><block a:else><block><view class="inputdiv flex-y-center"><image class="cardimg" src="{{pre_url+'/static/img/exchange_card.png'}}" mode="widthFix"></image><input id="dhcode" type="text" name="dhcode" placeholder-style="color:#d0cfcf;font-size:32rpx" placeholder="请输入您的兑换码" value="{{dhcode}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view></block></block><button class="btn" style="{{'background-color:'+(btn_bgcolor)+';'+('color:'+(btn_text_color)+';')}}" form-type="submit">立即兑换</button><view class="f0" data-url="dhlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="logimg" src="{{pre_url+'/static/img/exchange_card_record.png'}}" mode="widthFix"></image><text style="font-size:32rpx;letter-spacing:4rpx;">查看兑换记录</text></view></form><block a:if="{{lipinset.guize}}"><view class="qd_guize"><view class="guize_txt"><parse vue-id="27bb2ff4-1" content="{{lipinset.guize}}" onVueInit="__l"></parse></view></view></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="27bb2ff4-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="27bb2ff4-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="27bb2ff4-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>