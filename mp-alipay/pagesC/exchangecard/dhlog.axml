<block a:if="{{isload==1}}"><view class="container"><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1" style="margin-bottom:10rpx;">{{item.remark}}</text><text class="t1">{{"兑换码："+item.code}}</text><block a:if="{{item.total_take_times>1}}"><text class="t1">{{"总提货次数："+item.total_take_times+"次"}}</text></block><block a:if="{{item.total_take_times>1}}"><text class="t1">{{"已提货次数："+item.take_times+"次"}}</text></block><text class="t2">{{"兑换时间："+item.createtime}}</text></view></view></block><block a:if="{{nodata}}"><nodata vue-id="1bb6b546-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="1bb6b546-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="1bb6b546-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1bb6b546-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1bb6b546-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>