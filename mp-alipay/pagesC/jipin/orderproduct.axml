<view class="container"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'/pages/shop/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.$orig.product.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:22rpx;">￥</text>{{item.$orig.product.sell_price}}</text></view></view></view><view class="foot"><text class="flex1">{{"下单时间："+item.m1}}</text></view></view><block a:if="{{nodata}}"><nodata vue-id="2cc6c2e0-1" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="2cc6c2e0-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="2cc6c2e0-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2cc6c2e0-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>