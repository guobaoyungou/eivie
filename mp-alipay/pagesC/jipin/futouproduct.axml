<view class="container"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2"><view class="product-pic" data-url="{{'/pages/shop/product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.name}}</view><view class="p2" style="display:flex;justify-content:space-between;"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:22rpx;">￥</text>{{item.$orig.sell_price}}</text><view class="f3" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchTap="__e"><view class="flex-y-center"><view class="radio" style="{{(item.$orig.isdefault?'border:0;background:'+item.m1:'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="mrtxt">{{item.$orig.isdefault?'默认商品':'设为默认'}}</view></view></view></view><view class="p3"><block a:if="{{item.$orig.sales>0}}"><text class="t1">已售<text style="font-size:24rpx;color:#f40;padding:0 2rpx;">{{item.$orig.sales}}</text>件</text></block></view></view></view></view><block a:if="{{nodata}}"><nodata vue-id="1779fc26-1" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="1779fc26-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="1779fc26-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1779fc26-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>