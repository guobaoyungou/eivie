.pyramid-container{border:20rpx solid transparent;border-image:linear-gradient(180deg,#fd4a46,#ffb6c1) 10;background:linear-gradient(180deg,#fd4a46,#ffb6c1)}.pyramid{display:flex;flex-direction:column;align-items:center;margin-top:10rpx;border-radius:20rpx;background:#fff;padding:20rpx 10rpx 10rpx 10rpx}.level{display:flex;justify-content:space-around;width:100%}.user-container{display:flex;flex-direction:column;align-items:center}.avatar{width:100rpx;height:100rpx;border-radius:50%}.user-name{font-size:20rpx;text-align:center}.arrow-container{display:flex;justify-content:space-around;width:100%}.arrow{width:50rpx;height:50rpx}.pyramidinfo{margin-top:40rpx;background:#fff;border-radius:20rpx;padding:10rpx 30rpx;margin-top:-50rpx}.info-row{display:flex;justify-content:space-between;width:100%;margin:20rpx 0}.info-item{text-align:justify}.button-container{display:flex;justify-content:space-around;margin-top:10rpx;padding:20rpx}.btn{border-radius:50px;background-color:#fd4a46;color:#fff;padding:8rpx 60rpx;border:none;text-align:center;cursor:pointer;width:45%}.progress-info{text-align:center;margin-top:20rpx}.progress-container{position:relative;display:inline-block}.progress-img{width:300rpx;height:80rpx}.progress-text{position:absolute;top:40%;left:50%;-webkit-transform:translate(-50%,-50%);transform:translate(-50%,-50%);font-size:28rpx;color:red}