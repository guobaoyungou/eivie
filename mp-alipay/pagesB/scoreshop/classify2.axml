<view class="container"><block a:if="{{isload}}"><block><view class="search-container" data-url="/activity/scoreshop/prolist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商品</view></view></view><view class="order-tab"><view class="order-tab2"><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e"><view class="toppic"><block a:if="{{item.pic}}"><image style="width:100%;" src="{{item.pic}}" mode="widthFix"></image></block></view>{{''+item.name+''}}<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view></block></view></view><view class="content-container"><view class="nav_left"><view class="{{('nav_left_items '+(curIndex==-1?'active':''))}}" style="{{'color:'+(curIndex==-1?$root.m1:'#333')+';'}}" data-index="-1" data-id="{{clist[curTopIndex].id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m2)+';'}}"></view>全部</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="{{('nav_left_items '+(curIndex==index2?'active':''))}}" style="{{'color:'+(curIndex==index2?item.m3:'#333')+';'}}" data-index="{{index2}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m4)+';'}}"></view>{{item.$orig.name}}</view></block></view><view class="nav_right"><view class="nav_right-content"><view class="nav-pai"><view class="nav-paili" style="{{'color:'+(!field||field=='sort'?$root.m5:'#323232')+';'}}" data-field="sort" data-order="desc" data-event-opts="{{[['tap',[['changeOrder',['$event']]]]]}}" onTap="__e">综合</view><view class="nav-paili" style="{{(field=='sales'?'color:'+$root.m6:'')}}" data-field="sales" data-order="desc" data-event-opts="{{[['tap',[['changeOrder',['$event']]]]]}}" onTap="__e">兑换数量</view><view class="nav-paili" data-field="score_price" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['changeOrder',['$event']]]]]}}" onTap="__e"><text style="{{(field=='score_price'?'color:'+$root.m7:'')}}">{{"所需"+$root.m8}}</text><text class="iconfont iconshangla" style="{{(field=='score_price'&&order=='asc'?'color:'+$root.m9:'')}}"></text><text class="iconfont icondaoxu" style="{{(field=='score_price'&&order=='desc'?'color:'+$root.m10:'')}}"></text></view></view><block a:if="{{curTopIndex>-1&&curIndex>-1&&clist[curTopIndex].child[curIndex].child.length>0}}"><view class="classify-ul"><view class="flex" style="width:100%;overflow-y:hidden;overflow-x:scroll;"><view class="classify-li" style="{{(curIndex2==-1?'color:'+$root.m11+';background:rgba('+$root.m12+',0.2)':'')}}" data-id="{{clist[curTopIndex].child[curIndex].id}}" data-index="-1" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="classify-li" style="{{(curIndex2==idx2?'color:'+item.m13+';background:rgba('+item.m14+',0.2)':'')}}" data-id="{{item.$orig.id}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view></view></block><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="product-itemlist"><view class="item" data-url="{{'/activity/scoreshop/product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.$orig.name}}</text></view><view><view class="p2"><view class="t1" style="{{'color:'+($root.m15)+';'}}"><block a:if="{{item.$orig.score_price>0}}"><block>{{item.$orig.score_price+item.m16}}</block></block><block a:if="{{item.$orig.money_price>0}}"><block><block a:if="{{item.$orig.score_price>0}}"><block>+</block></block>{{item.$orig.money_price+'元'}}</block></block></view><block a:if="{{item.$orig.market_price*1>item.$orig.sell_price*1}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block></view></view><view class="p3"><block a:if="{{item.$orig.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.$orig.sales+"件"}}</text></view></block></view><block a:if="{{item.$orig.sales<=0&&item.$orig.merchant_name}}"><view style="height:44rpx;"></view></block><block a:if="{{item.$orig.hide_cart!=true}}"><view class="p4" style="{{'background:'+('rgba('+item.m17+',0.1)')+';'+('color:'+(item.m18)+';')}}" data-proid="{{item.$orig.id}}" data-canaddcart="{{item.$orig.canaddcart}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchTap="__e"><text class="iconfont icon_gouwuche"></text></view></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="d2197d10-1" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="d2197d10-2" text="没有查找到相关商品" onVueInit="__l"></nodata></block></scroll-view></view></view></view><block a:if="{{buydialogShow}}"><view><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-mask" onTap="__e"></view><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title flex"><image class="img" src="{{nowguige.pic||product.pic}}" data-url="{{nowguige.pic||product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="flex1"><view class="price" style="{{'color:'+($root.m19)+';'}}">{{''+nowguige.score_price+$root.m20}}<block a:if="{{nowguige.money_price*1>0}}"><text>{{"+"+nowguige.money_price+"元"}}</text></block><block a:if="{{nowguige.market_price>0}}"><text class="t2">{{"￥"+nowguige.market_price}}</text></block></view><block a:if="{{!shopset||shopset.hide_stock!=1}}"><view class="stock">{{"库存："+nowguige.stock}}</view></block><block a:if="{{product.guigeset==1}}"><view class="choosename">{{"已选规格: "+nowguige.name}}</view></block></view></view><block a:if="{{product.guigeset==1}}"><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col" a:for="{{guigedata}}" a:for-item="item" a:for-index="index" a:key="index"><view class="name">{{item.title}}</view><view class="item flex flex-y-center"><block a:for="{{item.items}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="{{('item2 '+(ggselected[item.k]==item2.k?'on':''))}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" onTap="__e">{{item2.title}}</view></block></view></view></view></block><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><view class="op"><block a:if="{{nowguige.stock<=0}}"><block><button class="nostock">库存不足</button></block></block><block a:else><block><block a:if="{{btntype==0&&canaddcart}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m21)+';'}}" onTap="__e">加入购物车</button></block><block a:if="{{btntype==0}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m22)+';'}}" onTap="__e">立即购买</button></block><block a:if="{{btntype==1}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m23)+';'}}" onTap="__e">确 定</button></block><block a:if="{{btntype==2}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m24)+';'}}" onTap="__e">确 定</button></block></block></block></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="d2197d10-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d2197d10-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="d2197d10-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="d2197d10-6" onVueInit="__l"></wxxieyi></view>