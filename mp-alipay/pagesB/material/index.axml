<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="1257077f-1" itemdata="{{['图片','视频']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="content-container"><view class="nav_left"><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('nav_left_items '+(curIndex==index?'active':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name+''}}</view></block></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="product-itemlist"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><block a:if="{{item.ctype==0}}"><image class="image" src="{{item.url}}" mode="widthFix"></image></block><block a:else><block a:if="{{item.ctype==1}}"><image class="image" src="{{item.cover}}" mode="widthFix"></image></block></block></view></view><block a:if="{{nomore}}"><nomore vue-id="1257077f-2" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1257077f-3" text="暂无相关商品" onVueInit="__l"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="1257077f-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="1257077f-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1257077f-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>