<view><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{deposit}}</view><block a:if="{{deposit_refund}}"><view class="f3"><block a:if="{{refund_status==1}}"><text>审核中</text></block><block a:if="{{refund_status!=1&&deposit>0}}"><text data-event-opts="{{[['tap',[['depositRefund']]]]}}" onTap="__e">退款申请</text></block></view></block></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m2}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block a:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block a:else><text class="t2">{{item.$orig.money}}</text></block></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="c18489fa-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="c18489fa-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="c18489fa-3" onVueInit="__l"></loading></block><popmsg vue-id="c18489fa-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>