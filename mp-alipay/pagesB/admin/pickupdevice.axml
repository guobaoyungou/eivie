<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'pickupdevicegoods?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/imgsrc/pickup_device.png'}}" mode="widthFix"></image><view class="f1"><view class="title">{{item.$orig.name}}</view><view class="t1"><text>柜子编号：</text>{{item.$orig.device_no}}</view><view class="t1"><text>格子总数：</text>{{item.$orig.goods_lane}}</view><view class="t1"><text>柜子地址：</text>{{item.$orig.address}}</view><view class="flex" style="justify-content:flex-end;"><block a:if="{{item.$orig.lack_stock>0}}"><button class="btn" style="{{'background:'+(item.m0)+';'}}">补货</button></block></view></view><view class="status"><block a:if="{{device_status==1}}"><text>在线</text></block><block a:else><text style="color:#fff;">离线</text></block></view><block a:if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">{{"缺货: "+item.$orig.lack_stock}}</view></view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="300ea552-1" onVueInit="__l"></nodata></block></view><view class="bottom-view"><view class="bottom flex "><view class="button" style="{{'background:'+($root.m1)+';'}}" data-url="pickupdeviceaddstock" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">补货统计</view><view class="button" style="{{'background:'+($root.m2)+';'}}" data-url="pickupdeviceaddstocklog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">补货清单</view></view></view><block a:if="{{nomore}}"><nomore vue-id="300ea552-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="300ea552-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="300ea552-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="300ea552-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>