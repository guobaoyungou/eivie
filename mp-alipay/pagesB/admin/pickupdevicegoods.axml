<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><image class="img" src="{{item.$orig.pic}}"></image><view class="f1"><view class="title">{{"柜门编号-"+item.$orig.goods_lane}}</view><view class="t1"><text>商品信息：</text>{{item.$orig.proname+"["+item.$orig.ggname+"]"}}</view><view class="t1"><text>近期补货：</text>{{item.$orig.add_time}}</view><view class="flex" style="justify-content:flex-end;"><block a:if="{{item.$orig.lack_stock>0}}"><button data-event-opts="{{[['tap',[['addstock',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+(item.m0)+';'}}" onTap="__e">补货</button></block><button data-event-opts="{{[['tap',[['openBox',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+($root.m1)+';'}}" onTap="__e">开门</button></view></view><block a:if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">待补货</view></view></block></view></block><block a:if="{{nodata}}"><nodata vue-id="299eb77b-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="299eb77b-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="299eb77b-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="299eb77b-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="299eb77b-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>