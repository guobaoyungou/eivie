<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view><uni-datetime-picker vue-id="398bf8a2-1" type="datetimerange" rangeSeparator="~" value="{{datetimerange}}" data-event-opts="{{[['^change',[['timeChange']]],['^input',[['__set_model',['','datetimerange','$event',[]]]]]]}}" onChange="__e" onInput="__e" onVueInit="__l"></uni-datetime-picker></view><view class="total">合计补货：<text style="color:red;margin-right:10rpx;">{{total_stock}}</text>件</view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><view class="t1">柜子名称：<text style="color:#1e88e5;">{{item.device_name}}</text></view><view class="t1">柜子编号：<text style="color:#333;">{{''+item.device_no}}</text></view><view class="t1">补货时间：<text style="color:#333;">{{''+item.createtime}}</text></view><view class="t1">小计补货：<text style="color:red;margin-right:10rpx;">{{item.total_stock}}</text>件</view><view class="t1"><text style="color:#1e88e5;">补货商品明细：</text></view><block a:for="{{item.goodsdata}}" a:for-item="item2" a:for-index="index"><view class="t2 flex flex-bt"><view>{{item2.proname+"["+item2.ggname+"]"}}</view><view style="color:#333;">{{"x"+item2.add_stock}}</view></view></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="398bf8a2-2" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="398bf8a2-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="398bf8a2-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="398bf8a2-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="398bf8a2-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>