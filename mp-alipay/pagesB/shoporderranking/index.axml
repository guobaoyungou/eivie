<block a:if="{{isload}}"><view><view><block a:if="{{set&&set.showpool}}"><view class="poolmoney" style="{{(pic?'background:url('+pic+') no-repeat;background-size:100% 100%;':'background-color:'+$root.m0)}}"><view style="text-align:center;"><view style="font-size:36rpx;">分红池总金额</view><view style="font-size:40rpx;margin-top:20rpx;">{{poolmoney+"元"}}</view></view></view></block><block a:if="{{set&&(set.showselfranking&&selfranking>0||set.showlast&&lastid>0)}}"><view style="width:720rpx;margin:0 auto;line-height:70rpx;height:70rpx;"><block a:if="{{set&&set.showselfranking&&selfranking>0}}"><view style="float:left;">{{'当前自己排名：'+selfranking+''}}</view></block><block a:if="{{set&&set.showlast&&lastid>0}}"><view style="float:right;" data-url="{{'detail?id='+lastid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">上一期</view></block></view></block><view class="dd-tab2"><scroll-view scroll-x="true"><view class="dd-tab2-content"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e" a:for="{{itemdata}}" a:for-item="item" a:for-index="index" a:key="index"><view>{{item.name}}</view><view class="after" style="{{'background:'+(color1?color1:$root.m1)+';'}}"></view><block a:if="{{set&&set.showchildpool}}"><view style="{{('text-align: center;line-height: 50rpx;color:'+$root.m2)}}">{{item.childmoney+"元"}}</view></block></view></view></scroll-view></view><block a:if="{{showmoney}}"><view style="font-size:34rpx;text-align:center;">{{'参与该分红池差距消费金额:'+money+'元'}}</view></block><view class="contentbox"><view class="content"><view class="tab"><view class="t1" style="width:80rpx;">排名</view><view class="t1" style="width:280rpx;">姓名</view><view class="t2">消费金额</view><block a:if="{{display==1}}"><view class="t3" style="width:112rpx;">预估奖金</view></block></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><text class="t1" style="width:80rpx;">{{index+1+''}}</text><view class="t2" style="width:280rpx;"><image src="{{item.headimg}}"></image><view style="width:180rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{''+item.nickname+''}}</view></view><text class="t3">{{''+item.summoney+"元"}}</text><block a:if="{{display==1}}"><text class="t3" style="width:112rpx;">{{''+item.avgmoney+"元"}}</text></block></view></block></view><block a:if="{{nodata}}"><nodata vue-id="61d407b0-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="61d407b0-2" onVueInit="__l"></nomore></block></view></view><block a:if="{{loading}}"><loading vue-id="61d407b0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="61d407b0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="61d407b0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></view></block>