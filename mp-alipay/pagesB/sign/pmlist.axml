<view class="container"><view class="qd_guize"><view class="gztitle">— 第<text class="t2">{{bonuscount}}</text>期 奖励排名 —</view><view class="desc">前10名奖励排行榜</view><view class="paiming"><view class="item flex" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="headimg" src="{{item.headimg}}"></image><text class="t1">{{item.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+item.money+''}}</text><text class="t2">元</text></view></view></view><block a:if="{{userinfo.money}}"><view class="item item2 flex"><view class="f1"><image class="headimg" src="{{userinfo.headimg}}"></image><text class="t1">{{userinfo.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+userinfo.money+''}}</text><text class="t2">元</text></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="20137cf2-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="20137cf2-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="20137cf2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="20137cf2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="20137cf2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>