<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的可转出"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.paiming_fenhong_money}}</view></view><view class="content2"><view class="item2"><view class="f1">转出金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入转出金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><view class="tips-box"><block a:if="{{sysset.max_point_amount>0}}"><view class="item4 tips"><text style="margin-right:10rpx;">{{"最低转出金额"+sysset.max_point_amount+''}}</text></view></block><block a:if="{{sysset.max_point_amount>0}}"><view class="tips">{{'最低转出金额按\r\n\t\t\t\t\t\t\t\t\t\t'+sysset.max_point_amount+'\r\n\t\t\t\t\t\t\t\t\t\t整倍数转出'}}</view></block></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m2)+';'}}" onTap="__e">立即转出</button></form></block></block><block a:if="{{loading}}"><loading vue-id="0be3fc68-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="0be3fc68-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0be3fc68-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>