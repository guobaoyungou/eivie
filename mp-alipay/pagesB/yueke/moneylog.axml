<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="e1c4140e-1" itemdata="{{['余额明细','提现记录']}}" itemst="{{['0','2']}}" st="{{st}}" isfixed="{{true}}" color1="#06A051" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><block a:if="{{st==0}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block a:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block a:else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></block><block a:if="{{st==2}}"><block><view class="item" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m1}}</text></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="e1c4140e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="e1c4140e-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="e1c4140e-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="e1c4140e-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e1c4140e-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>