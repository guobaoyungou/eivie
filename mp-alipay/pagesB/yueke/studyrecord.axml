<view class="container"><block a:if="{{isload}}"><block><view style="width:100%;height:10rpx;"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0&&item.$orig.start_study_time==''}}"><text class="st3">待预约</text></block><block a:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><text class="st1">待上课</text></block><block a:if="{{item.$orig.status==1}}"><text class="st3">上课中</text></block><block a:if="{{item.$orig.status==2}}"><text class="st4">已完成</text></block><block a:if="{{item.$orig.status==3}}"><text class="st4">已退款</text></block></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{$root.m0+"："+item.$orig.workerinfo.realname+" "+(item.$orig.workerinfo.dengji||'')}}</text><block a:if="{{item.$orig.start_study_time}}"><text class="t2">{{"开课时间："+item.$orig.start_study_time}}</text></block><block a:if="{{item.$orig.hx_time}}"><text class="t2">{{"结束时间："+item.$orig.hx_time}}</text></block></view><block a:if="{{item.$orig.comment}}"><view class="comment"><text class="t2">{{item.m1+"点评："+item.$orig.comment}}</text></view></block></view><view class="op"><block a:if="{{item.$orig.status==1}}"><view class="btn1" style="{{'background:'+(item.m2)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" onTap="__e">上课完成</view></block><block a:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" onTap="__e">取消</view></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="581b56d1-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="581b56d1-2" text="暂无学习记录" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="581b56d1-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="581b56d1-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="581b56d1-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>