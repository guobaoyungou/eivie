<view class="container"><block a:if="{{isload}}"><block><view class="message-list"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.formatTime}}"><view class="message-time">{{item.formatTime}}</view></block><block a:if="{{item.isreply==1}}"><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'}}"><image class="message-avatar" mode="aspectFill" src="{{item.uheadimg}}"></image><view class="message-text-left"><view class="arrow-box arrow-left"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-white.png'}}"></image></view><view class="message-text"><parse vue-id="{{'4653363d-1-'+index}}" content="{{item.content}}" onVueInit="__l"></parse></view></view></view></block><block a:else><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'+('justify-content:'+('flex-end')+';')}}"><view class="message-text-right"><view class="arrow-box arrow-right"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-green.png'}}"></image></view><view class="message-text"><parse vue-id="{{'4653363d-2-'+index}}" content="{{item.content}}" onVueInit="__l"></parse></view></view><image class="message-avatar" mode="aspectFill" src="{{item.headimg}}"></image></view></block></block></view><view class="input-box notabbarbot" id="input-box"><view class="input-form"><image class="pic-icon" src="{{pre_url+'/static/img/msg-pic.png'}}" data-event-opts="{{[['tap',[['sendimg',['$event']]]]]}}" onTap="__e"></image><input class="input" confirmHold="{{true}}" confirmType="send" cursor-spacing="20" type="text" maxlength="-1" data-event-opts="{{[['confirm',[['sendMessage',['$event']]]],['focus',[['onInputFocus',['$event']]]],['input',[['messageChange',['$event']]]]]}}" value="{{message}}" onConfirm="__e" onFocus="__e" onInput="__e"/><image class="face-icon" src="{{pre_url+'/static/img/face-icon.png'}}" data-event-opts="{{[['tap',[['toggleFaceBox',['$event']]]]]}}" onTap="__e"></image><block a:if="{{trimMessage}}"><button data-event-opts="{{[['tap',[['sendMessage',['$event']]]]]}}" class="send-button-active" style="{{'background:'+($root.m0)+';'}}" onTap="__e">发送</button></block></view><block a:if="{{faceshow}}"><wxface onSelectface="__e" vue-id="4653363d-3" data-event-opts="{{[['^selectface',[['selectface']]]]}}" onVueInit="__l"></wxface></block></view><view class="{{('anit '+(msgtipsShow==1?'show':msgtipsShow==2?'hide':''))}}" data-url="{{'index?bid='+msgtips.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{msgtips.unickname+"："+msgtips.content}}</view></block></block><block a:if="{{loading}}"><loading vue-id="4653363d-4" onVueInit="__l"></loading></block><popmsg vue-id="4653363d-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>