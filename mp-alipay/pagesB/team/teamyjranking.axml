<view><block a:if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank.png'}}" mode="widthFix"></image><view class="content"><view class="top"><view class="t1">{{"我的"+$root.m1+"："+total_yeji}}</view></view><view class="tab"><view class="t1">排名</view><view class="t2">姓名</view><view class="t3" style="{{'color:'+($root.m2)+';'}}">{{"累计"+$root.m3}}</view></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><block a:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block a:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3">{{''+item.totalyeji}}</text></view></block></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="40ca9453-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="40ca9453-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="40ca9453-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="40ca9453-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="40ca9453-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>