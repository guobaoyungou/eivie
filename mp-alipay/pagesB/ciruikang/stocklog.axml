<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的库存</view><view class="f2">{{mynum}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image style="width:50rpx;height:50rpx;border-radius:50% 50%;margin-right:10rpx;" src="{{item.headimg}}"></image><text class="t1">{{item.nickname}}</text></view><view class="f2"><block><text class="t1">{{item.allnum}}</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="feae864a-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="feae864a-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="feae864a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="feae864a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="feae864a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>