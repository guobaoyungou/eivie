<view class="container"><block a:if="{{isload}}"><block><view style="width:100%;height:100%;"><view class="bg_div1" style="{{(loginset_data.bgtype==1?'background:'+loginset_data.bgcolor:'background:url('+loginset_data.bgimg+') no-repeat center;background-size:100% 100%')}}"><view style="overflow:hidden;"><view class="content_div1"><view class="card_div1" style="{{('background:'+loginset_data.cardcolor)}}"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="title">重置密码</view><view class="regform"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-tel.png'}}"></image><input class="input" type="text" placeholder="请输入手机号" placeholder-style="font-size:30rpx;color:#B2B5BE" name="tel" value="" data-event-opts="{{[['input',[['telinput',['$event']]]]]}}" onInput="__e"/></view><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="请输入验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="smscode" value=""/><view data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" class="code" style="{{('color:'+loginset_data.codecolor)}}" onTap="__e">{{smsdjs||'获取验证码'}}</view></view><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-pwd.png'}}"></image><input class="input" type="text" placeholder="6-16位字母数字组合密码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="pwd" value="" password="{{true}}"/></view><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-pwd.png'}}"></image><input class="input" type="text" placeholder="再次输入登录密码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="repwd" value="" password="{{true}}"/></view><block a:if="{{loginset_data.btntype==1}}"><block><button class="btn1" style="{{('background:rgba('+$root.m0+');color: '+loginset_data.btnwordcolor)}}" form-type="submit">确定</button></block></block><block a:if="{{loginset_data.btntype==2}}"><block><button class="btn1" style="{{('background-color:'+loginset_data.btncolor+';color:'+loginset_data.btnwordcolor)}}" form-type="submit">确定</button></block></block></view></form></view></view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="2864b2e5-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="2864b2e5-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2864b2e5-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>