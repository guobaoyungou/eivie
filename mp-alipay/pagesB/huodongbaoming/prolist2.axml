<view class="container"><block a:if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索活动名称" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['search',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view></view><view class="ind_business"><view class="ind_buslist" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="ind_busbox flex1 flex-row"><view class="ind_buspic flex0"><image src="{{item.$orig.pic}}" mode="aspectFill"></image></view><view class="right  flex1"><view class="bus_title">{{item.$orig.name}}</view><view style="color:#887e7e;">{{"活动开始时间:"+item.$orig.huodong_start_time}}</view><view style="color:#887e7e;">{{"活动结束时间:"+item.$orig.huodong_end_time}}</view><view style="color:#887e7e;">{{"报名开始时间:"+item.$orig.start_time}}</view><block a:if="{{item.$orig.countdown!=''&&!item.$orig.isend&&item.$orig.isstart}}"><view style="color:#887e7e;">{{"报名截止:"+item.$orig.countdown}}</view></block><view style="color:#887e7e;">{{"已报名:"+item.$orig.apply_num}}</view><view class="p2"><block a:if="{{item.$orig.score_price>0&&item.$orig.sell_price<=0}}"><block><view class="t1" style="{{'color:'+(item.m0)+';'}}">{{item.$orig.score_price+item.m1+"/人"}}</view></block></block><block a:if="{{item.$orig.score_price<=0&&item.$orig.sell_price>0}}"><block><view class="t1" style="{{'color:'+(item.m2)+';'}}">{{"￥"+item.$orig.sell_price}}</view></block></block><block a:if="{{item.$orig.score_price>0&&item.$orig.sell_price>0}}"><block><view class="t1" style="{{'color:'+(item.m3)+';'}}">{{item.$orig.score_price+item.m4}}<block a:if="{{item.$orig.sell_price>0}}"><text>{{"+"+item.$orig.sell_price+"元"}}</text></block></view></block></block><block a:if="{{!item.$orig.isend&&item.$orig.isapply>0&&item.$orig.isstart}}"><view class="btn" style="{{'background:'+(item.m5)+';'}}">已报名</view></block><block a:else><block a:if="{{item.$orig.isend}}"><view class="btn" style="background:#aaa;">报名已结束</view></block><block a:else><block a:if="{{!item.$orig.isend&&item.$orig.isapply==0&&item.$orig.isstart}}"><view class="btn" style="{{'background:'+(item.m6)+';'}}">报名进行中</view></block><block a:else><block a:if="{{!item.$orig.isstart}}"><view class="btn" style="background:#aaa;">报名未开始</view></block></block></block></block></view></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="acb756b0-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="acb756b0-2" onVueInit="__l"></nodata></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="acb756b0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="acb756b0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="acb756b0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="acb756b0-6" onVueInit="__l"></wxxieyi></view>