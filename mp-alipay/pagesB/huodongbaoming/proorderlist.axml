<view class="container"><block a:if="{{isload}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">报名列表</text></view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.$orig.headimg}}"></image><view class="t2"><text class="x1">{{item.$orig.nickname}}</text><text class="x2">{{item.m0}}</text><view a:for="{{item.$orig.formdata}}" a:for-item="items" a:for-index="__i0__" a:key="*this"><text class="x1" style="margin-right:5px;">{{items[0]+":"}}</text><block a:if="{{items[2]=='upload'}}"><view class="x1"><image style="width:400rpx;height:auto;" src="{{items[1]}}" mode="widthFix" data-url="{{items[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><text class="x1" user-select="true" selectable="true">{{items[1]}}</text></block></view></view></view></view></block></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="13a28be0-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="13a28be0-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="13a28be0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="13a28be0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="13a28be0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>