<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="30bb7ba7-1" itemdata="{{['待拆红包','已拆红包','失效红包']}}" itemst="{{['0','1','-1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="coupon-list"><view class="coupon" data-url="{{'redpacketdetail?rplid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="pt_left"><view class="pt_left-content"><block a:if="{{item.pic}}"><image style="width:100%;max-height:200rpx;border-radius:4rpx;" src="{{item.pic}}" mode="widthFix"></image></block></view></view><view style="width:2rpx;height:100rpx;background-color:#eee;"></view><view class="pt_right"><view class="f1"><view class="t1" style="{{'color:'+($root.m0)+';'}}"><text class="t0">￥</text><text style="font-size:50rpx;font-weight:bold;">{{item.redpacket}}</text></view><block a:if="{{item.shortcontent}}"><view class="t3" style="font-size:24rpx;"><view>使用说明：</view><view class="shortcontent">{{item.shortcontent}}</view></view></block><view class="t3">{{"有效期至 "+item.cuttime}}</view></view><block a:if="{{st==0}}"><block><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-redpacketid="{{item.redpacketid}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchTap="__e">立即分享</button></block></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="30bb7ba7-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="30bb7ba7-3" onVueInit="__l"></nodata></block><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m3=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m4}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m5!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="30bb7ba7-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="30bb7ba7-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="30bb7ba7-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>