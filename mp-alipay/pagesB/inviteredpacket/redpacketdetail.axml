<view style="width:100%;height:auto;min-height:100%;"><block a:if="{{isload}}"><block><view class="content" style="{{('background:url('+bgpic+') no-repeat ;background-size:100% 100%;')}}"><block a:if="{{notices&&notices.length>0}}"><view class="bobaobox"><swiper style="position:relative;height:54rpx;width:450rpx;" autoplay="true" interval="{{5000}}" vertical="true"><swiper-item class="flex-y-center" a:for="{{notices}}" a:for-item="item" a:for-index="index" a:key="index"><image style="width:40rpx;height:40rpx;border:1px solid rgba(255,255,255,0.7);border-radius:50%;margin-right:4px;" src="{{item.headimg}}"></image><view style="width:400rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:22rpx;"><text style="padding-right:2px;">{{item.nickname}}</text><text style="padding-right:4px;">{{item.showtime}}</text><text>{{item.msg}}</text></view></swiper-item></swiper></view></block><block a:if="{{data.shortcontent}}"><view data-event-opts="{{[['tap',[['changeshortcontent',['$event']]]]]}}" class="shortcontent" onTap="__e">使用说明</view></block><view style="width:100%;clear:both;height:230rpx;"></view><view class="centercontent" style="{{('background:url('+centerpic+') no-repeat ;background-size:100% 100%;')}}"><view style="color:#A1351D;text-align:center;margin-top:34rpx;"><block a:if="{{!data.status||data.status==0}}"><text>当前待拆金额</text></block><block a:else><block a:if="{{data.status&&data.status==1}}"><text>红包金额(已拆完)</text></block><block a:else><text>红包金额(已失效)</text></block></block></view><view style="text-align:center;font-weight:bold;"><text style="color:#FE0000;font-size:30rpx;">￥</text><text style="color:#FE0000;font-size:60rpx;">{{data.redpacket}}</text></view><view style="text-align:center;color:#A1351D;margin-top:10rpx;"><text>已邀请</text><text>{{data.invitenum+"/"+data.newnum+"人"}}</text></view><block a:if="{{!data.status||data.status==0}}"><view class="jindu"><view style="width:140rpx;font-size:24rpx;">邀请进度</view><view style="width:320rpx;"><progress activeColor="#FFE72B" backgroundColor="#FAA0AD" percent="{{data.invitepercent}}" show-info="{{true}}" stroke-width="3" font-size="10"></progress></view></view></block><block a:if="{{!data.status||data.status==0}}"><view style="width:100%;position:absolute;bottom:150rpx;left:0;"><view class="optred"><view data-event-opts="{{[['tap',[['takeredpacket',['$event']]]]]}}" class="optred1" style="{{('background:url('+btnpic+') no-repeat ;background-size:100% 100%;')}}" onTap="__e"><view style="line-height:72rpx;">拆红包</view></view><block a:if="{{data.showinvite}}"><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="optred1" style="{{('background:url('+btnpic+') no-repeat ;background-size:100% 100%;')}}" onTap="__e"><view style="line-height:72rpx;">邀请好友</view></view></block></view></view></block><block a:if="{{!data.status||data.status==0}}"><view style="width:100%;position:absolute;bottom:70rpx;left:0;"><view class="daojishi"><view style="color:#FCD09D;margin-right:10rpx;">红包有效倒计时:</view><view class="daojishi0"><block a:if="{{day&&day!=='00'}}"><block><view class="daojishi1">{{day}}</view><view class="daojishi2" style="width:40rpx;padding-left:4rpx;text-align:left;">天</view></block></block><view class="daojishi1">{{hour}}</view><view class="daojishi2">：</view><view class="daojishi1">{{minute}}</view><view class="daojishi2">：</view><view class="daojishi1">{{second}}</view></view></view></view></block></view><view class="join"><view class="jointitle">助力列表</view><scroll-view style="width:660rpx;margin:0 auto;height:410rpx;" scroll-y="true"><block a:for="{{childs}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{childs}}"><block><view class="joincontent"><view style="width:440rpx;display:flex;align-items:center;"><view class="joinpic"><image style="width:100%;height:100%;" src="{{item.headimg}}"></image></view><view class="joinname">{{item.nickname}}</view></view><view class="jointip"><text style="font-size:24rpx;">￥</text><text style="font-size:30rpx;">{{item.money}}</text></view></view></block></block></block></scroll-view></view><view style="width:100%;clear:both;height:60rpx;"></view></view><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m1}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m2!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block></view></view></view></view></block></block></block><block a:if="{{showshortcontent}}"><block><view style="width:100%;height:100%;background-color:#000;position:fixed;opacity:0.5;z-index:99;top:0;"></view><view style="width:700rpx;margin:0 auto;position:fixed;top:10%;left:25rpx;z-index:100;"><scroll-view style="background-color:#fff;border-radius:20rpx;overflow:hidden;width:100%;height:900rpx;padding:20rpx;" scroll-y="true"><parse vue-id="d46a40d8-1" content="{{data.shortcontent}}" onVueInit="__l"></parse></scroll-view><view data-event-opts="{{[['tap',[['changeshortcontent',['$event']]]]]}}" style="width:60rpx;height:60rpx;line-height:60rpx;text-align:center;font-size:30rpx;background-color:#fff;margin:0 auto;border-radius:50%;margin-top:20rpx;" onTap="__e">X</view></view></block></block><block a:if="{{loading}}"><loading vue-id="d46a40d8-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="d46a40d8-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d46a40d8-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>