<view class="container"><block a:if="{{isload}}"><block><view class="expressinfo"><view class="head"><view class="f1"><image src="{{pre_url+'/static/img/feiji.png'}}"></image></view><view class="f2"><view class="t1">快递公司：<text style="color:#333;" user-select="true" selectable="true">{{express_com}}</text></view><view class="t2">快递单号：<text style="color:#333;" user-select="true" selectable="true">{{express_no}}</text></view></view></view><view class="content"><view class="{{('item '+(index==0?'on':''))}}" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/dot'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{item.time}}</text><text class="t1">{{item.context}}</text></view></view><block a:if="{{nodata}}"><nodata vue-id="11bcdb8b-1" text="暂未查找到物流信息" onVueInit="__l"></nodata></block></view></view></block></block><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m0)+';'}}" data-url="mail" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我要寄件</view><block a:if="{{loading}}"><loading vue-id="11bcdb8b-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="11bcdb8b-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="11bcdb8b-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>