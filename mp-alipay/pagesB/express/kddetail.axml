<view class="container"><block a:if="{{isload}}"><block><view class="expressinfo"><view class="head"><view class="f1"><block a:if="{{data.kuaidinum}}"><view>{{"运单号："+data.kuaidinum}}</view></block><block a:else><view>{{"订单号："+data.ordernum}}</view></block><view></view></view><view class="f2 flex"><view class="t2_box"><text>{{data.sendManPrintCity}}</text><text class="t2">{{data.sendManName}}</text></view><view class="t2_box"><image class="jiantou" src="{{pre_url+'/static/img/jiantou2.png'}}"></image><view class="t2">{{data.sta}}</view></view><view class="t2_box"><text>{{data.recManPrintCity}}</text><text class="t2">{{data.sendManName}}</text></view></view></view><view class="content"><block a:if="{{datalist}}"><block><view class="{{('item '+(index==0?'on':''))}}" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/dot'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{item.time}}</text><text class="t1">{{item.context}}</text></view></view><block a:if="{{nodata}}"><nodata vue-id="8610a640-1" text="暂未查找到物流信息" onVueInit="__l"></nodata></block></block></block><block a:else><view class="item"><view class="f1"><image src="{{'/static/img/dot'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{data.sta}}</text><text class="t1"></text></view></view></block></view></view></block></block><uni-popup vue-id="8610a640-2" id="dialogRemark" type="dialog" ref="__r" data-ref="dialogExpress" onVueInit="__l"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="sendexpress-item" style="padding:20rpx 0;"><view><input class="input" type="text" placeholder="请输入原因" placeholder-style="font-size:28rpx;color:#BBBBBB" name="remark"/></view><button class="submit" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">确定取消</button></view></form></view></uni-popup><block a:if="{{loading}}"><loading vue-id="8610a640-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="8610a640-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="8610a640-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>