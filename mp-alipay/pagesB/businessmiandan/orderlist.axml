<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="80d5fd4c-1" itemdata="{{['全部','待使用','已完成']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head"><block a:if="{{item.bid!=0&&item.binfo}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block a:else><view>{{"订单号："+item.ordernum}}</view></block><view class="flex1"></view><block a:if="{{item.status==0}}"><text class="st0">待使用</text></block><block a:if="{{item.status==1}}"><text class="st1">已完成</text></block></view><view class="content" style="border-bottom:none;"><view><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><text class="t1"><block a:if="{{item.num}}"><text>{{"数量:"+item.num}}</text></block></text><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.totalprice}}</text></view></view></view><view class="op"><block a:if="{{item.status==0}}"><block><view class="btn2" data-hexiao_qr="{{item.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" onTap="__e">核销码</view></block></block></view></view></block></view><uni-popup vue-id="80d5fd4c-2" id="dialogHxqr" type="dialog" ref="__r" data-ref="dialogHxqr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="80d5fd4c-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="80d5fd4c-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="80d5fd4c-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="80d5fd4c-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="80d5fd4c-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>