<view><block a:if="{{isload}}"><block><view class="headcontent" style="{{(bgpic?'background:url('+bgpic+') no-repeat,background-size:100% 100%':'background: linear-gradient(180deg, rgba('+$root.m0+',0.65) 0%, rgba('+$root.m1+',0) 100%);')}}"><view style="width:710rpx;margin:0 auto;padding:20rpx 0;"><view style="display:flex;align-items:center;justify-content:space-between;"><view style="display:flex;align-items:center;" data-url="{{canedit?'/pagesB/kecheng/lecturerapply?opttype=1':''}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="headimg"><image style="width:100%;height:100%;" src="{{lecturer.headimg}}"></image></view><view>{{''+lecturer.nickname+''}}</view></view><block a:if="{{canedit}}"><view class="send" style="{{('background-color:'+$root.m2)}}" data-url="/pagesB/kecheng/lecturersend" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">发布</view></block></view><view style="margin-top:20rpx;line-height:40rpx;white-space:pre-wrap;word-wrap:break-word;">{{lecturer.shortdesc}}</view></view></view><view style="background-color:#fff;"><view style="width:400rpx;"><dd-tab vue-id="cb989220-1" itemdata="{{itemdata}}" itemst="{{itemst}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view></view><view class="content"><view class="item" style="{{(index+1>=datalen?'border:0':'')}}" data-url="{{'/pagesB/kecheng/lecturermldetail?kcid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item1"><view class="title">{{''+item.name+''}}</view><view style="width:200rpx;height:140rpx;background-color:#f1f1f1;border-radius:8rpx;overflow:hidden;"><image style="width:100%;" src="{{item.pic}}" mode="widthFix"></image></view></view><view style="font-size:24rpx;color:#999;display:flex;align-items:center;"><view>{{item.showtime}}</view><block a:if="{{canedit}}"><view class="btn" data-url="{{'/pagesB/kecheng/lecturersend?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">编辑</view></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="cb989220-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="cb989220-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="cb989220-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="cb989220-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="cb989220-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>