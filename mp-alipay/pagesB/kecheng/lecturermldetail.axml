<view class="wrap"><block a:if="{{isload}}"><block><view class="title">{{detail.name}}</view><view style="display:flex;justify-content:space-between;padding:30rpx;align-items:center;"><view style="display:flex;align-items:center;"><view class="headimg" data-url="{{'/pagesB/kecheng/lecturercenter?id='+detail.lecturer.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><block a:if="{{detail.lecturer&&detail.lecturer.headimg}}"><image style="width:100%;height:100%;" src="{{detail.lecturer.headimg}}"></image></block></view><view style="line-height:50rpx;"><view style="max-width:400rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><block a:if="{{detail.lecturer&&detail.lecturer.nickname}}"><text>{{detail.lecturer.nickname}}</text></block></view><view style="color:#757575;display:flex;align-items:center;">{{''+detail.createtime+''}}<view style="width:4rpx;height:4rpx;border-radius:4rpx;overflow:hidden;background-color:#000;margin:0 10rpx;" class="_div"></view>{{''+detail.readnum+'次浏览'}}</view></view></view><view><image class="img" style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/share.png'}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{freecontent}}"><view><view style="padding:0 20rpx;font-size:28rpx;"><parse vue-id="4baa5d35-1" content="{{freecontent}}" onVueInit="__l"></parse></view></view></block><block a:if="{{!detail.needbuy}}"><view><block a:if="{{detail.kctype==1}}"><block><block a:if="{{pagecontent}}"><block><dp vue-id="4baa5d35-2" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></block></block><view style="margin-bottom:40rpx;"></view></block></block><block a:if="{{detail.kctype==2}}"><view class="audo-video"><view class="audoimg"><image src="{{detail.pic}}"></image></view><view class="play"><view class="play-left"><image hidden="{{!(playshow)}}" src="{{pre_url+'/static/img/video_icon.png'}}" data-event-opts="{{[['tap',[['play',['$event']]]]]}}" onTap="__e"></image><image hidden="{{!(!playshow)}}" src="{{pre_url+'/static/img/play.png'}}" data-event-opts="{{[['tap',[['pauseaudio',['$event']]]]]}}" onTap="__e"></image><text>{{nowtime}}</text></view><view class="play-right"><slider class="slider" block-size="16" min="{{0}}" max="{{time}}" value="{{currentTime}}" activeColor="#595959" data-event-opts="{{[['change',[['sliderChange',['$event']]]],['changing',[['sliderChanging',['$event']]]]]}}" onChange="__e" onChanging="__e"></slider></view><view class="play-end"><text>{{duration}}</text></view></view><block a:if="{{pagecontent}}"><view><dp vue-id="4baa5d35-3" pagecontent="{{pagecontent}}" onVueInit="__l"></dp><view style="margin-bottom:40rpx;"></view></view></block></view></block><block a:if="{{detail.kctype==3}}"><view class="videobox"><video class="video" id="video" autoplay="{{true}}" src="{{detail.video_url}}" initial-time="{{detail.startTime}}" data-event-opts="{{[['pause',[['pause',['$event']]]],['timeUpdate',[['timeupdate',['$event']]]],['ended',[['ended',['$event']]]]]}}" onPause="__e" onTimeUpdate="__e" onEnded="__e"></video><block a:if="{{showspeed}}"><view class="speed"><block a:if="{{showspeed==1}}"><view data-event-opts="{{[['tap',[['setspeed',['$event']]]]]}}" class="t1" onTap="__e">{{speedtext}}</view></block><block a:if="{{showspeed==2}}"><view class="f2"><block a:for="{{speedlist}}" a:for-item="item" a:for-index="index"><view class="{{('f22 '+(rate==item?'on':''))}}" data-rate="{{item}}" data-event-opts="{{[['tap',[['bindButtonRate',['$event']]]]]}}" onTap="__e"><text class="t2">{{item}}</text><text>X</text></view></block></view></block></view></block><block a:if="{{pagecontent}}"><view><dp vue-id="4baa5d35-4" pagecontent="{{pagecontent}}" onVueInit="__l"></dp><view style="margin-bottom:40rpx;"></view></view></block></view></block></view></block><block a:if="{{detail.needbuy}}"><block><view style="position:relative;width:100%;height:450rpx;overflow:hidden;"><block a:if="{{detail.kctype==1&&detail.detail}}"><block><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view><view style="padding:0 20rpx;">付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看付费后可以查看</view></block></block><block a:else><block><block a:if="{{detail.video_url}}"><video class="video" style="width:100%;" autoplay="{{false}}" src></video></block></block></block><view class="needbuytip">付费后查看详情</view></view></block></block><view style="width:100%;height:100rpx;clear:both;"></view><block a:if="{{detail.needbuy||showbuy}}"><view style="position:fixed;width:100%;left:0;bottom:60rpx;z-index:999;"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m0)+';'}}" onTap="__e">{{'查看完整版：'+detail.price+'元'}}</view></view></block><block a:if="{{sharetypevisible}}"><view class="popup__container" style="z-index:99;"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m1=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m2=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m3!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block></block><block a:if="{{nomore}}"><nomore vue-id="4baa5d35-5" text="没有更多课程了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4baa5d35-6" text="没有查找到相关课程" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="4baa5d35-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="4baa5d35-8" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="4baa5d35-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>