<view class="container"><block a:if="{{isload}}"><block><view class="view-show"><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{(('nav_left')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" style="{{'color:'+(index===currentActiveIndex?item.m0:'#333')+';'}}" data-root-item-id="{{item.$orig.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.$orig.name+''}}</view></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="detail-list" scroll-y="true" show-scrollbar="{{false}}" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="classification-detail-item" a:for="{{$root.l1}}" a:for-item="detail" a:for-index="indexs" a:key="indexs"><view class="head" data-id="{{detail.$orig.id}}" id="{{'detail-'+detail.$orig.id}}"><view class="txt">{{detail.$orig.name}}</view><view class="show-all" data-id="{{detail.$orig.id}}" data-event-opts="{{[['tap',[['gotoCatproductPage',['$event']]]]]}}" onTap="__e">更多<text class="iconfont iconjiantou"></text></view></view><view class="product-itemlist"><view class="item" data-url="{{'/activity/kecheng/product?id='+item.id+'&bid='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{detail.$orig.child}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.name}}</text></view><view class="p2" style="{{'color:'+(detail.m2)+';'}}"><text class="t1"><block a:if="{{item.price<=0}}"><text>免费</text></block><block a:else><text><text style="font-size:20rpx;padding-right:1px;">￥</text>{{item.price+''}}</text></block></text><block a:if="{{item.market_price>0}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view></view></view></view><block a:if="{{nodata}}"><nomore vue-id="b9ca85d6-1" text="没有更多分类了" onVueInit="__l"></nomore></block></scroll-view></view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="b9ca85d6-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="b9ca85d6-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="b9ca85d6-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>