<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的提现积分</view><view class="f2">{{myscore}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block a:else><block><text class="t2">{{item.score}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="06bc9155-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="06bc9155-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="06bc9155-3" onVueInit="__l"></loading></block></view>