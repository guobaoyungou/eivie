<view class="container"><block a:if="{{isload}}"><block><view class="content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1" style="width:100%;"><view class="t1">{{item.$orig.proname}}</view><block a:if="{{item.$orig.status>=0}}"><block><block a:if="{{item.$orig.commission}}"><view style="line-height:50rpx;"><block a:if="{{item.$orig.status==1}}"><text class="t1">分佣：</text></block><block a:if="{{item.$orig.status==0}}"><text class="t1">预估分佣：</text></block><text class="t1" style="margin-left:10rpx;">{{item.$orig.commission+item.m0}}</text></view></block><block a:else><view style="line-height:50rpx;"><block a:if="{{item.$orig.status==1}}"><text class="t1">分佣：</text></block><block a:if="{{item.$orig.status==0}}"><text class="t1">预估分佣：</text></block><text class="t1" style="margin-left:10rpx;">{{"0"+item.m1}}</text></view></block></block></block><block a:if="{{item.$orig.from_ordernum}}"><text class="t2">{{"订单编号："+item.$orig.from_ordernum}}</text></block><block a:if="{{item.$orig.create_time}}"><text class="t2">{{item.$orig.create_time}}</text></block><block a:if="{{item.$orig.tipinfor}}"><text class="t2" style="color:#ff8758;">{{item.$orig.tipinfor}}</text></block></view><view class="f2" style="width:120rpx;flex:unset;"><block a:if="{{item.$orig.status==1}}"><text class="t1">已发放</text></block><block a:if="{{item.$orig.status==0}}"><text class="t1" style="color:red;">未发放</text></block><block a:if="{{item.$orig.status==-1}}"><text class="t1" style="color:#999;">已失效</text></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="694aeb3e-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="694aeb3e-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="694aeb3e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="694aeb3e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="694aeb3e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>