<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{mysilvermoney}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.silvermoney>0}}"><block><text class="t1">{{"+"+item.silvermoney}}</text></block></block><block a:else><block><text class="t2">{{item.silvermoney}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="fba2eb2a-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="fba2eb2a-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="fba2eb2a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="fba2eb2a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="fba2eb2a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>