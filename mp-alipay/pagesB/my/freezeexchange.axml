<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的可兑换"+$root.m1}}</view><view class="f2">{{freeze_credit}}</view><view class="f3" data-url="exchangelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>兑换记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><block a:if="{{wallet.length>0}}"><block><view class="content2"><view class="item2"><view class="f1">兑换数量</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入兑换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><view class="tips-box"><view class="tips">{{'兑换需消耗'+$root.m2+",1"+$root.m3+"="+sysset.score2money+$root.m4+''}}</view></view></view><view class="withdrawtype"><view class="f1">选择兑换方式：</view><view class="f2"><view class="item" data-paytype="{{item.$orig.type}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="__i0__"><view class="t1"><block a:if="{{item.$orig.img!=''}}"><image class="img" src="{{item.$orig.img}}"></image></block>{{item.$orig.title+''}}</view><view class="radio" style="{{(paytype==item.$orig.type?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" onTap="__e">立即兑换</button></block></block><block a:else><block><view style="text-align:center;margin-top:100rpx;font-size:38rpx;">抱歉，暂不支持兑换</view></block></block></form><block a:if="{{sysset.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{sysset.withdraw_desc}}</text></view></block></block></block><block a:if="{{loading}}"><loading vue-id="37fbdae2-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="37fbdae2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="37fbdae2-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>