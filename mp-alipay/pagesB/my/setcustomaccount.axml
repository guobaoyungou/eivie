<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form"><view class="form-item"><text class="label">账户名称</text><input class="input" type="text" placeholder="请输入账户名称" name="customaccountname" placeholder-style="color:#BBBBBB;font-size:28rpx" value="{{account.customaccountname}}"/></view><view class="form-item"><text class="label">账户编号</text><input class="input" type="text" placeholder="请输入账户编号" name="customaccount" placeholder-style="color:#BBBBBB;font-size:28rpx" value="{{account.customaccount}}"/></view><view class="form-item"><text class="label">手机号</text><input class="input" type="text" placeholder="请输入手机号" name="customtel" placeholder-style="color:#BBBBBB;font-size:28rpx" value="{{account.customtel}}"/></view><block a:if="{{sysset.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{sysset.withdraw_desc}}</text></view></block></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block a:if="{{loading}}"><loading vue-id="42eae3bc-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="42eae3bc-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="42eae3bc-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>