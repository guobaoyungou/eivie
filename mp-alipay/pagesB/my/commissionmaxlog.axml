<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{commission_max}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item-moudle" style="background-color:#FFFFFF;"><view>{{item.remark}}</view><view class="item"><view><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.value>0}}"><block><text class="t1" style="color:#03bc01;">{{"+"+item.value}}</text></block></block><block a:else><block><text class="t2">{{item.value}}</text></block></block></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="cc21659e-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="cc21659e-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="cc21659e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="cc21659e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="cc21659e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>