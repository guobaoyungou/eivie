<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的积分权</view><view class="f2">{{myscoreweight}}</view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item-moudle" style="background-color:#FFFFFF;"><view>{{item.remark}}</view><view class="item"><view><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.score_weight>0}}"><block><text class="t1" style="color:#03bc01;">{{"+"+item.score_weight}}</text></block></block><block a:else><block><text class="t2">{{item.score_weight}}</text></block></block></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="025cfdbc-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="025cfdbc-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="025cfdbc-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="025cfdbc-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="025cfdbc-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>