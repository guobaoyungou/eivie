<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"可兑换"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.commission_max_self}}</view><view class="f3" data-url="/pagesB/my/commissionmaxlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{$root.m2+"记录"}}</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view><block a:if="{{userinfo.commission_max_plate>0}}"><view class="f1">{{"总数量："+userinfo.commission_max+" 不可兑换数量："+userinfo.commission_max_plate}}</view></block><view class="f1">{{"转换比例："+userinfo.member_commission_max_toscore_ratio+"%"}}</view></view><view class="content2"><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="请输入转换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" onInput="__e"/></view></view></block><view class="item2"><view class="f1" style="font-size:34rpx;">{{"转换积分："+score}}</view></view></view><view class="op"><view data-event-opts="{{[['tap',[['toSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m3)+';'}}" onTap="__e">确定</view></view></block></block><block a:if="{{loading}}"><loading vue-id="0d6542de-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="0d6542de-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0d6542de-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>