<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">微信收款码</view><view class="f2"><block a:if="{{wxpaycode}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="wxpaycode" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{wxpaycode}}" data-url="{{wxpaycode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:if="{{!wxpaycode}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="wxpaycode" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="wxpaycode" maxlength="-1" value="{{wxpaycode}}"/></view><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">支付宝收款码</view><view class="f2"><block a:if="{{alipaycode}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="alipaycode" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{alipaycode}}" data-url="{{alipaycode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:if="{{!alipaycode}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="alipaycode" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="alipaycode" maxlength="-1" value="{{alipaycode}}"/></view></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block a:if="{{loading}}"><loading vue-id="76072849-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="76072849-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="76072849-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>