<view class="container"><block a:if="{{isload}}"><block><view class="main"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="left"><view class="img"><image src="{{item.headimg||pre_url+'/static/img/touxiang.png'}}"></image></view><view class="info"><view class="title">{{item.form0}}</view><view class="desc">{{item.form1}}</view></view></view><view class="opt">{{item.createtime}}</view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="1166b33a-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1166b33a-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="1166b33a-3" onVueInit="__l"></loading></block><popmsg vue-id="1166b33a-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>