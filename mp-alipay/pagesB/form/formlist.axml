<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的活动" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><dd-tab vue-id="e07e22dc-1" itemdata="{{['全部','未开始','进行中','已结束']}}" itemst="{{['all','0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="article_list"><view class="article-itemlist" data-url="{{item.listpage_tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="article-pic"><image class="image" src="{{item.listpage_pic}}" mode="widthFix"></image></view><view class="article-info"><view class="p1">{{item.listpage_title}}</view><block a:if="{{item.listpage_description}}"><block><block a:if="{{item.listpage_description}}"><view class="p3">{{item.listpage_description}}</view></block></block></block><view class="p2"><text class="flex1" style="overflow:hidden;">{{item.starttime}}</text><text style="overflow:hidden;color:#f50;">{{item.count+"人已报名"}}</text></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="e07e22dc-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="e07e22dc-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="e07e22dc-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="e07e22dc-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e07e22dc-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>