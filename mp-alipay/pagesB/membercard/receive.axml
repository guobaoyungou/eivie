<view class="container"><block a:if="{{isload}}"><block><view class="top"><block a:if="{{data.bg_type==1}}"><view class="cardbg"><image src="{{data.background_pic_url}}"></image></view></block><block a:else><view class="cardbg" style="{{('background: '+data.color)}}"></view></block><view class="hyk flex"><view class="f1"><image src="{{data.logo_url}}"></image></view><view class="f2"><text class="t1">{{data.brand_name}}</text><text class="t2">{{data.title}}</text></view></view></view><view style="height:100rpx;"></view><view class="center"><view class="title">开卡即可获得以下奖励</view><view class="item"><block a:if="{{data.givescore>0}}"><view class="score"><view class="f1"><image src="{{pre_url+'/static/img/membercard/score_icon.png'}}"></image></view><view class="f2"><text class="t1">{{data.givescore}}</text><text class="t2">{{$root.m0}}</text></view></view></block><block a:if="{{data.givemoney>0}}"><view class="score"><view class="f1"><image src="{{pre_url+'/static/img/membercard/money.png'}}"></image></view><view class="f2"><text class="t1">{{data.givemoney}}</text><text class="t2">{{$root.m1}}</text></view></view></block><block a:if="{{data.couponcount>0}}"><view class="score"><view class="f1"><image src="{{pre_url+'/static/img/membercard/coupon_icon2.png'}}"></image></view><view class="f2"><text class="t1">{{data.couponcount}}</text><text class="t2">{{$root.m2}}</text></view></view></block></view><view class="cooupondesc"><image src="{{pre_url+'/static/img/membercard/icon.png'}}"></image><block a:for="{{data.couponlist}}" a:for-item="item" a:for-index="index"><block a:if="{{data.couponlist}}"><text class="t1">{{item.name+" "+item.nums+"张"}}</text></block></block></view></view><view class="bottom"><view class="title">会员卡详情</view><view class="content"><view class="itembox"><view class="item"><label>特权说明</label><text class="t1">{{data.prerogative}}</text></view><view class="item"><label>联系电话</label><text class="t2" data-url="{{'tel::'+data.service_phone}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{data.service_phone}}</text></view><view class="item"><label>使用说明</label><text class="t1">{{data.description}}</text></view></view></view></view><view class="buttonbox"><button class="button" style="{{'background:'+('linear-gradient(-90deg,'+$root.m3+' 0%,rgba('+$root.m4+',0.8) 100%)')+';'}}" data-url="{{data.ret_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">立即开卡</button></view></block></block><block a:if="{{loading}}"><loading vue-id="549d54eb-1" onVueInit="__l"></loading></block></view>