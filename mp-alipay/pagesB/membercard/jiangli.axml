<view class="container"><block a:if="{{isload}}"><block><view class="top"><view class="title">累计获得</view><view class="item"><view class="score"><view class="f2"><text class="t1">{{info.totalscore}}</text><text class="t2">{{$root.m0}}</text></view><view class="f2"><text class="t1">{{info.totalmoney}}</text><text class="t2">{{$root.m1}}</text></view><view class="f2"><text class="t1">{{info.totalcoupon}}</text><text class="t2">{{$root.m2}}</text></view></view></view></view><view class="center2"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><block a:if="{{datalist}}"><view class="item"><view class="headimg"><image src="{{item.$orig.headimg}}"></image><view class="f1"><view class="t1">{{item.$orig.nickname}}</view><view class="t2">{{item.$orig.createtime+" 开卡"}}</view></view></view><view class="kkimg"><block a:if="{{item.$orig.parent_givemoney>0}}"><text>{{''+item.$orig.parent_givemoney+item.m3+''}}</text></block><block a:if="{{item.$orig.parent_givescore>0}}"><text>{{'+ '+item.$orig.parent_givescore+" "+item.m4+''}}</text></block><block a:if="{{item.$orig.coupon}}"><text>{{'+ '+item.$orig.coupon+" "+item.m5+''}}</text></block></view></view></block></block></view></block></block></view>