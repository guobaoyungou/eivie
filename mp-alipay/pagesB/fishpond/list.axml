<view class="container"><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索你感兴趣的鱼塘" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><text class="iconfont icondingwei" style="color:#888;"></text><block a:if="{{item.address}}"><text class="t2" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.name}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e">{{item.address}}</text></block></view><view class="p2"><image class="img-tel" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="t2" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e">{{item.tel}}</text></view></view><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="31fd1f9f-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="31fd1f9f-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="31fd1f9f-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="31fd1f9f-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="31fd1f9f-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>