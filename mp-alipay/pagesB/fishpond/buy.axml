<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" onSubmit="__e"><view class="address-add"><view class="linkitem"><block a:if="{{contact_require==1}}"><label style="color:red;">*</label></block><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view><view class="linkitem"><block a:if="{{contact_require==1}}"><label style="color:red;">*</label></block><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view></view><view class="buydata"><view class="btitle"><image class="img" src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{business.name}}</view><view class="bcontent"><view class="product"><view class="item flex"><view class="img"><block a:if="{{guige.pic}}"><image class="img" src="{{guige.pic}}"></image></block><block a:else><image class="img" src="{{product.pic}}"></image></block></view><view class="info flex1"><view class="f1">{{product.name}}</view><view class="f2">{{"规格："+guige.name}}</view><view class="f2">位置：<text style="margin-right:10rpx;" a:for="{{basan_data}}" a:for-item="item" a:for-index="index" a:key="index">{{item.name}}</text></view><view class="f3">{{"￥"+guige.sell_price}}<text style="padding-left:20rpx;">{{'× '+sum}}</text></view></view></view></view><view class="price"><text class="f1">商品金额</text><text class="f2">{{"¥"+product_price}}</text></view><view style="display:none;">{{test}}</view></view></view><view style="width:100%;height:calc(110rpx + env(safe-area-inset-bottom));"></view><view class="footer flex notabbarbot"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}</text></view><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">提交订单</button></view></form></block></block><block a:if="{{loading}}"><loading vue-id="6391df25-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="6391df25-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6391df25-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="6391df25-4" onVueInit="__l"></wxxieyi></view>