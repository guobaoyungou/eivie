<view class="container"><block a:if="{{isload}}"><block><view class="content " data-id="{{item.id}}" data-name="{{item.name}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex" style="justify-content:space-between;"><view class="f1"><view class="headimg"><block a:if="{{item.logo}}"><image src="{{item.logo}}"></image></block><block a:else><image src="{{pre_url+'/static/img/touxiang.png'}}"></image></block></view><view class="text1"><text class="t1">{{item.name+''}}</text></view></view><view class="yuyue">选择</view></view><view>{{''+item.address+''}}</view></view><block a:if="{{nodata}}"><nodata vue-id="0ea2816a-1" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="0ea2816a-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="0ea2816a-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="0ea2816a-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>