<view class="container"><view class="head flex-bt"><view>{{"有效期："+expiring_date}}</view><view class="totla-sum"><text>合计数量：</text><text class="total-number">{{count}}</text></view></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'/pages/shop/product?id='+item.proid+'&show_image=0'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><text class="t2">规格：</text><text class="t2">{{item.ggname}}</text></view><view class="p3"><text class="t2">数量：</text><text class="t2">{{item.num}}</text></view></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="2d698d3e-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="2d698d3e-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="2d698d3e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="2d698d3e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2d698d3e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>