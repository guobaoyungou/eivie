<view class="container"><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'posterpurchaseorder?orderid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view class="f1">{{item.ordernum}}</view></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p3" style="margin-top:10rpx;"><text class="t2">数量：</text><text class="t2">{{item.totalnum}}</text></view><view class="p3"><text class="t2">有效天数：</text><text class="t2">{{item.validity_day}}</text></view><view class="p3"><text class="t2">失效日期：</text><text class="t2">{{item.expiring_date}}</text></view><view class="p3"><text class="t2">创建时间：</text><text class="t2">{{item.createtime}}</text></view><view class="p3"><text class="t2">备注：</text><text class="t2">{{item.remark}}</text></view></view><view class="op"><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['purchaseOrderRemarkOpen',['$event']]]]]}}" catchTap="__e">备注</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchTap="__e">删除记录</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['purchaseOrderSetOpen',['$event']]]]]}}" catchTap="__e">修改有效期</view></view></view></view></view><uni-popup vue-id="76b2ee31-1" id="purchaseOrderSet" type="dialog" mask-click="{{false}}" ref="__r" data-ref="purchaseOrderSet" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">设置</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center form-item"><view class="form-label">有效期：</view><input class="text-input" type="number" data-event-opts="{{[['input',[['inputChange',['$event']]]]]}}" value="{{editday}}" onInput="__e"/><view class="form-label" style="margin-left:10rpx;">天</view></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['purchaseOrderSetClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['toedit',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><uni-popup vue-id="76b2ee31-2" id="purchaseOrderRemark" type="dialog" mask-click="{{false}}" ref="__r" data-ref="purchaseOrderRemark" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">备注</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center form-item"><input type="text" placeholder="请输入备注" data-event-opts="{{[['input',[['inputChangeRemark',['$event']]]]]}}" value="{{remark}}" onInput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['purchaseOrderRemarkClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['toeditRemark',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="76b2ee31-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="76b2ee31-4" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="76b2ee31-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="76b2ee31-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="76b2ee31-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>