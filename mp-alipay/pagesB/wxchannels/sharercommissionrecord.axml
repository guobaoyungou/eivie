<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="e548cc5c-1" itemdata="{{['全部','已发放','未发放']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f2"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><block a:if="{{item.$orig.frommid>0}}"><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></block></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block a:if="{{item.$orig.status==0}}"><block><block a:if="{{item.$orig.orderstatus==1||item.$orig.orderstatus==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.$orig.orderstatus==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.$orig.orderstatus==3}}"><text class="dior-sp6 ywc">待发放</text></block><block a:if="{{item.$orig.orderstatus==4}}"><text class="dior-sp6 ygb">已关闭</text></block></block></block><block a:if="{{item.$orig.status==1}}"><block><text class="dior-sp6 yfk">已发放</text></block></block></view></view><block a:if="{{item.$orig.goods&&item.$orig.goods.name}}"><view class="goodsinfo  flex"><view class="x1 flex"><image class="img" src="{{item.$orig.goods.pic}}"></image><view style="margin-left:20rpx;"><view class="x1t name">{{item.$orig.goods.name}}</view><view class="x1t" style="color:red;">{{"￥"+item.$orig.goods.sell_price}}</view><view class="x1t" style="color:#616161;">{{item.$orig.goods.createtime}}</view></view></view><view>{{"共"+item.$orig.goods.num+"件"}}</view></view></block></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="e548cc5c-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="e548cc5c-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="e548cc5c-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="e548cc5c-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e548cc5c-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>