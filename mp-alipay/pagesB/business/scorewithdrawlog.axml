<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="a35c6ff0-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="listrow" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现"+$root.m0+"："+item.score}}<text class="money" style="{{'color:'+($root.m1)+';'}}">{{"(￥"+item.money+")"}}</text></text><text class="t2">{{item.showtime}}</text></view><view class="f3"><block a:if="{{item.status==0}}"><text class="st0">审核中</text></block><block a:if="{{item.status==1}}"><text class="st1">已审核</text></block><block a:if="{{item.status==2}}"><text class="st2">已驳回</text></block><block a:if="{{item.status==3}}"><text class="st3">已打款</text></block></view></view><block a:if="{{item.status==2&&item.reason}}"><view class="tips">{{item.reason}}</view></block></view></view><block a:if="{{nomore}}"><nomore vue-id="a35c6ff0-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="a35c6ff0-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="a35c6ff0-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="a35c6ff0-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="a35c6ff0-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>