<view class="container"><block a:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{"分红订单（"+ordercount+"）"}}</text></view><dd-tab vue-id="52d7d35f-1" itemdata="{{['待结算','已结算']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="margin-top:190rpx;"></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1 flex-y-center"><text>{{item.$orig.ordernum}}</text><text class="flex1"></text><text style="font-size:24rpx;color:#999;">{{item.$orig.fhname}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.$orig.name+" ×"+item.$orig.num}}</text><text class="x2" style="{{'font-size:28rpx;'+('color:'+($root.m0)+';')}}">{{"￥"+item.$orig.real_totalprice}}</text><text class="x2">{{item.m1}}</text><view class="x3"><image src="{{item.$orig.headimg}}"></image>{{item.$orig.nickname}}</view></view><view class="t2"><block a:if="{{item.$orig.status==1||item.$orig.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.$orig.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.$orig.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block a:if="{{item.$orig.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view><view style="width:100%;height:20rpx;"></view></view></block></block></block></block><block a:if="{{nodata}}"><nodata vue-id="52d7d35f-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="52d7d35f-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="52d7d35f-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="52d7d35f-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="52d7d35f-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>