<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.service_fee}}</view><view class="f3" data-url="/pagesB/service_fee/servicefee_log?st=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{$root.m2+"记录"}}</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">{{"充值"+$root.m3+"(元)"}}</view></view><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="{{'请输入充值'+$root.m4}}" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" onInput="__e"/></view></view></block></view><view class="op"><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m5)+';'}}" onTap="__e">去支付</view></view></block></block><block a:if="{{loading}}"><loading vue-id="48e20b4f-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="48e20b4f-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="48e20b4f-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>