<view><block a:if="{{isload}}"><block><view class="daily-detail"><view class="box-name flexc"><view class="title">{{'['+sysset.name+"]"}}</view><view class="ml10 hou">{{detail.name}}</view></view><view class="box-wq" data-url="/pagesB/daily/wqlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="see">查看往期</view></view><view class="box-content mlt30"><view class="logo"><image class="imgs" src="{{sysset.logo}}"></image></view><block a:if="{{detail.voice_url}}"><view class="content-audio flexjsa"><view class="left"><image class="bf" src="{{pre_url+'/static/img/daily/bf.png'}}"></image><text>{{detail.voice_duration}}</text></view><block a:if="{{playshow}}"><view data-event-opts="{{[['tap',[['play',['$event']]]]]}}" class="right flex" onTap="__e"><text>点击听语音</text><audio src="{{detail.voice_url}}"></audio><image src="{{pre_url+'/static/img/daily/sz.png'}}"></image></view></block><block a:if="{{!playshow}}"><view data-event-opts="{{[['tap',[['pause',['$event']]]]]}}" class="right flex" onTap="__e"><text>点击关语音</text><audio src="{{detail.voice_url}}"></audio><image src="{{pre_url+'/static/img/daily/sz.png'}}"></image></view></block></view></block><view class="content"><view><rich-text nodes="{{detail.content}}"></rich-text></view></view><view class="time mlt30"><text>{{sysset.name}}</text><text class="ml10">{{detail.fabutime}}</text></view></view><block a:if="{{detail.tourldata}}"><view class="box-content2"><view class="item" data-url="{{item.tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{detail.tourldata}}" a:for-item="item" a:for-index="index" a:key="index"><view class="image"><image src="{{item.tourlpic}}"></image></view><view class="more" data-url="{{item.tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看</view></view></view></block><block a:if="{{detail.is_ganwu}}"><block><view class="box-ganwu mlt40">已分享过感悟</view></block></block><block a:else><block><block a:if="{{detail.can_daka}}"><block><view data-event-opts="{{[['tap',[['share',['$event']]]]]}}" class="box-ganwu mlt40" onTap="__e">分享自己的感悟并打卡</view><block a:if="{{detail.is_daka==0}}"><view data-event-opts="{{[['tap',[['daka',['$event']]]]]}}" class="box-daka mlt30" onTap="__e">不了, 直接打卡</view></block></block></block></block></block><view class="box-commont mlt40"><view class="top">全部感悟</view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="commont flexcm"><view class="flex"><view class="commont-left"><image class="headimg" src="{{item.headimg}}"></image></view><view class="commont-right flexcm"><view class="commont-top">{{item.nickname+"    "+item.createtime}}</view><view>{{item.ganwu}}</view><view class="commont-bottom"><view class="cuIon" data-orderid="{{item.id}}" data-mid="{{item.mid}}" data-index="{{index}}" data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/daily/share.png'}}"></image><text class="ml10">{{item.share_num}}</text></view><view class="cuIon  ml40 cuIcon-like"><block a:if="{{item.is_star==0}}"><image data-status="1" data-orderid="{{item.id}}" data-index="{{index}}" src="{{pre_url+'/static/img/daily/fav.png'}}" data-event-opts="{{[['tap',[['savestar',['$event']]]]]}}" onTap="__e"></image></block><block a:if="{{item.is_star==1}}"><image data-status="0" data-orderid="{{item.id}}" data-index="{{index}}" src="{{pre_url+'/static/img/daily/fav2.png'}}" data-event-opts="{{[['tap',[['savestar',['$event']]]]]}}" onTap="__e"></image></block><text class="ml10">{{item.star_num}}</text></view></view></view></view><view class="border"></view></view></block><block a:if="{{nomore}}"><nomore vue-id="0c60f8bc-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0c60f8bc-2" onVueInit="__l"></nodata></block></view><block a:if="{{showmodal}}"><view class="cu-modal"><form report-submit="true" data-event-opts="{{[['submit',[['saveganwu',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="cu-dialog"><view class="cu-bar bg-white justify-end"><view class="content">感悟</view><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="close" onTap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view></view><view class="padding-xl"><textarea style="background:#F8F8F8;" placeholder="请输入感悟" id="ganwuinput" name="ganwuval"></textarea></view><view class="cu-bar bg-white justify-center"><view class="aciton"><button data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="cu-btn1" onTap="__e">取消</button><button class="cu-btn2" form-type="submit">确定</button></view></view></view></form></view></block><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m0!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><view class="{{((('covermy-view')+' '+'flex-col')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="covermy" data-url="pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/lt_gohome.png'}}"></image></view></view></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="0c60f8bc-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0c60f8bc-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0c60f8bc-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>