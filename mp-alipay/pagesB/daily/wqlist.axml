<view><block a:if="{{isload}}"><block><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="daily-box"><view class="item" data-url="{{'/pagesB/daily/daily?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="top"><view class="left"><image class="douhao" src="{{pre_url+'/static/img/daily/yhleft.png'}}"></image></view><view class="content"><rich-text nodes="{{item.content}}"></rich-text></view><view class="right"><image class="douhao" src="{{pre_url+'/static/img/daily/yhright.png'}}"></image></view></view><view class="bottom"><view class="left"><image class="logo" src="{{item.shop_logo}}"></image><text class="ml20 txt">{{item.shop_name}}</text><text class="ml25 txt">{{item.fabutime}}</text></view><view class="btn">马上去听</view></view></view></view><view style="width:100%;height:20rpx;"></view></block></block></block><block a:if="{{nomore}}"><nomore vue-id="e4a5cc0a-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="e4a5cc0a-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="e4a5cc0a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="e4a5cc0a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e4a5cc0a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>