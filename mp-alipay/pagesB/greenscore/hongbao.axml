<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="0477ec39-1" itemdata="{{['排队中','已完成']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.$orig.statusLabel}}</text></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item.$orig.bname}}</text></view><block a:if="{{item.$orig.title}}"><view class="detail">排队名称：<text class="t1" style="{{('color:'+item.m0)}}">{{item.$orig.title}}</text></view></block><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{item.$orig.money}}</text></view><view class="detail">已返金额：<text class="t1" style="{{('color:'+$root.m2)}}">{{item.$orig.money_give}}</text><block a:if="{{item.$orig.status==0&&set.quit_wxhb==1&&item.$orig.money_quit_hb>0}}"><text style="{{('color:'+item.m3+';margin-left: 30rpx;')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitWithHb',['$event']]]]]}}" catchTap="__e">退出排队抽红包</text></block></view><block a:if="{{item.$orig.queue_no}}"><view class="detail">当前排名：<text class="t1" style="{{('color:'+item.m4)}}">{{item.$orig.queue_noLabel}}</text></view></block><view class="detail"><text class="t1">{{"排队时间："+item.$orig.createtimeFormat}}</text></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0477ec39-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0477ec39-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{prizeVisible}}"><view data-event-opts="{{[['touchMove',[['e0',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchTouchMove="__e" onMousewheel="__e"><view class="hongbao-view"><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view data-event-opts="{{[['tap',[['hbclose',['$event']]]]]}}" class="hongbao-view-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup onChange="__e" vue-id="0477ec39-4" ref="__r" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" onVueInit="__l"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{hbmoney}}</text><text class="unit">元</text></view><view class="title">{{''+hbtext+''}}</view><view class="cl-button"><text data-event-opts="{{[['tap',[['hbsuccess',['$event']]]]]}}" onTap="__e">确定</text></view></view></view></view></uni-popup></view></block><block a:if="{{loading}}"><loading vue-id="0477ec39-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="0477ec39-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0477ec39-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>