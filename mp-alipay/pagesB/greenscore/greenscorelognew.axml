<view class="container"><block a:if="{{isload}}"><block><block a:if="{{show_top==1}}"><view class="top-data-list flex flex-y-center" style="{{'background:'+($root.m0)+';'}}"><view class="data-options flex-col"><view class="title-text">最大份额</view><view class="num-text">{{set.max_green_score}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">已发放</view><view class="num-text">{{set.green_score_total}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">剩余</view><view class="num-text">{{set.plate_remain_green_score}}</view></view></view></block><view class="myscore" style="{{'background:'+($root.m1)+';'}}"><view class="f1">{{"我的"+$root.m2}}</view><view class="f2">{{myscore}}<block a:if="{{set.open_withdraw==1}}"><view class="btn-mini" data-url="/pagesB/my/greenscoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">全部提取</view></block></view><view class="f1">{{"当前每个"+$root.m3+"价值"+set.green_score_price+"元"}}</view><block a:if="{{green_score_hb>0}}"><view class="f1">{{"已领增值红包"+green_score_hb+"元"}}</view></block></view><dd-tab vue-id="5ad843b4-1" itemdata="{{[$root.m4+'列表','已完成记录']}}" itemst="{{['0','1']}}" st="{{is_withdraw}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row" data-url="{{'/pagesB/my/greenscorelog?jilu_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="column"><text>{{"发放数量: "+item.value}}</text><text>{{"剩下数量: "+item.remain}}</text></view><block a:if="{{greenscore_max==1}}"><view class="column"><text>{{"封顶额度: "+(item.maximum_num||0)}}</text><text>{{"已扣额度: "+(item.dec_maximum||0)}}</text></view></block></view><view class="item-row highlight"><text>{{"可提取金额: "+item.green_score_value}}</text></view><view class="item-row"><text class="time">{{item.remark+" "+item.createtime}}</text><block a:if="{{withdraw_type==1&&set.open_withdraw==1}}"><block><block a:if="{{item.is_withdraw==0&&item.remain>0}}"><button class="btn-mini2" data-url="{{'/pagesB/my/greenscoreWithdraw?log_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提取</button></block><block a:else><button class="btn-mini3">已提取</button></block></block></block><block a:if="{{false}}"><block><button class="btn-mini2">查看明细</button></block></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="5ad843b4-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="5ad843b4-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="5ad843b4-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="5ad843b4-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5ad843b4-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>