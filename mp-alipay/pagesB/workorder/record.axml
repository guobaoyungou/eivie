<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="12e43406-1" itemdata="{{['全部','待处理','处理中','已处理','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:90rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['input',[['searchInput',['$event']]]],['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onInput="__e" onConfirm="__e"/></view></view><view class="searchbox"><view class="cates"><uni-data-picker vue-id="12e43406-2" localdata="{{cateList}}" border="{{false}}" placeholder="{{catenames||'请选择类型'}}" data-event-opts="{{[['^change',[['catechange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker></view><view class="date"><view class="begindate"><picker mode="date" value="{{begindate}}" start="{{startDate}}" end="{{endDate}}" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{begindate?begindate:'选择开始日期'}}</view></picker></view>-<view class="enddate"><picker mode="date" value="{{enddate}}" start="{{startDate}}" end="{{endDate}}" data-event-opts="{{[['change',[['bindDateChange2',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{''+(enddate?enddate:'选择结束日期')}}</view></picker></view></view><view data-event-opts="{{[['tap',[['search',['$event']]]]]}}" class="searchbtn" style="{{'background:'+($root.m0)+';'}}" onTap="__e">搜索</view></view><view class="content" id="datalist"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="itembox"><view class="f1"><view class="title"><view class="t11">用户姓名：<text class="t1" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{item.nickname}}</text></view><view class="t11">工单类型：<text class="t1" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{item.cname}}</text></view><view class="t11">工单名称：<text class="t1" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{item.title}}</text></view></view><view class="f2"><block a:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">等待处理</text></block><block a:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block a:if="{{item.status==1}}"><text class="t1" style="color:green;">{{item.clname}}</text></block><block a:if="{{item.status==2}}"><text class="t1" style="color:red;">已完成</text></block><block a:if="{{item.status==-1}}"><text class="t1" style="color:red;">已驳回</text></block></view></view><view class="flex" style="justify-content:space-between;"><view class="time">提交时间：<text class="t2" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{item.createtime}}</text></view><block a:if="{{!item.payorderid||item.payorderid&&item.paystatus==1}}"><view class="jindu" data-url="{{'/pagesA/workorder/workjindu?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看进度</view></block></view><block a:if="{{item.ordertype==1&&item.glordernum&&item.orderid}}"><block><view class="flex" style="justify-content:space-between;"><text class="t2" data-url="{{'pages/order/detail?id='+item.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"关联订单：商城订单（"+item.glordernum+"）"}}</text></view></block></block><block a:if="{{item.ordertype==2&&item.glordernum&&item.orderid}}"><block><view class="flex" style="justify-content:space-between;"><text class="t2" data-url="{{'/activity/yuyue/orderdetail?id='+item.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"关联订单：预约订单（"+item.glordernum+"）"}}</text></view></block></block></view></view></view><block a:if="{{ishowjindu}}"><view class="modal"><view class="modal_jindu"><form data-event-opts="{{[['submit',[['formsubmit',['$event']]]]]}}" style="width:100%;" onSubmit="__e"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="close" onTap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view><block a:if="{{jdlist.length>0}}"><block><view class="item " a:for="{{jdlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image src="{{'/static/img/jindu'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{'时间：'+item.time}}</text><text class="t1">{{item.desc+"("+item.remark+')'}}</text><block a:for="{{item.content_pic}}" a:for-item="pic" a:for-index="ind"><block a:if="{{item.content_pic.length>0}}"><view><view class="layui-imgbox-img"><image src="{{pic}}" data-url="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></block><view a:for="{{item.hflist}}" a:for-item="hf" a:for-index="hfindex" a:key="hfindex"><block a:if="{{hf.hfremark}}"><view class="t3">{{"我的回复："+hf.hfremark+''}}</view></block><block a:if="{{hf.hftime}}"><view class="t4">{{"回复时间："+hf.hftime+''}}</view></block><block a:for="{{hf.hfcontent_pic}}" a:for-item="pic2" a:for-index="ind2"><block a:if="{{hf.hfcontent_pic.length>0}}"><view><view class="layui-imgbox-img"><image src="{{pic2}}" data-url="{{pic2}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></block></view></view></view><input style="display:none;" type="hidden" name="lcid" value="{{jdlist[0].id}}"/><block a:if="{{statuss!=2}}"><view class="huifu"><view class="form-item4 flex-col"><view class="label"><label>回复:</label></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{content_pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="content_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{content_pic.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 40rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="content_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view></view><view class="hfbox"><textarea placeholder="输入回复内容" name="content" maxlength="-1" value="{{jdlist[0].hfremark}}"></textarea></view><view class="btnbox"><view class="f1"><button data-event-opts="{{[['tap',[['confirmend',['$event']]]]]}}" class="btn1" onTap="__e">确认结束</button><button class="btn2" form-type="submit">提交</button></view></view></view></block><block a:if="{{statuss==2&&iscomment==0}}"><view class="btnbox"><view class="pjitem"><view class="item"><view style="margin-right:10rpx;">满意度</view><radio-group data-event-opts="{{[['change',[['radioChange',['$event']]]]]}}" onChange="__e"><label class="radio"><radio value="1"></radio>不满意</label><label class="radio"><radio value="2"></radio>一般</label><label class="radio"><radio value="3"></radio>满意</label></radio-group></view><button data-event-opts="{{[['tap',[['tocomment',['$event']]]]]}}" class="btn1" onTap="__e">确认评价</button></view></view></block><block a:if="{{statuss==2&&iscomment==1}}"><view class="btnbox"><view class="pjitem"><view class="item"><view style="margin-right:10rpx;">满意度:</view><block a:if="{{comment_status==1}}"><view class="t1" style="color:red;">不满意</view></block><block a:if="{{comment_status==2}}"><view class="t1" style="color:#88e;">一般</view></block><block a:if="{{comment_status==3}}"><view class="t1" style="color:green;">满意</view></block></view></view></view></block></block></block><block a:else><block a:if="{{statuss==-1}}"><block><view style="font-size:14px;color:#f05555;padding:10px;">工单已驳回</view></block></block><block a:else><block><view style="font-size:14px;color:#f05555;padding:10px;">等待处理</view></block></block></block></form></view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="12e43406-3" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="12e43406-4" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="12e43406-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="12e43406-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="12e43406-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>