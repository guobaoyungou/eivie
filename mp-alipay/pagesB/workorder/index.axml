<view class="container"><view class="detail"><parse vue-id="13294642-1" content="{{formdata.desc}}" onVueInit="__l"></parse></view><form data-formcontent="{{formdata.content}}" data-formid="{{cateid}}" data-event-opts="{{[['submit',[['editorFormSubmit',['$event']]]]]}}" onSubmit="__e"><view class="content"><view class="form-item flex"><view class="title">工单类型:</view><view class="inputbox flex"><picker class="picker" mode="selector" range="{{newcate}}" value="{{index}}" range-key="name" data-event-opts="{{[['change',[['BindPickerChange2',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{newcatename}}</view></picker><text class="iconfont iconjiantou" style="color:#ccc;font-weight:normal;"></text></view></view><view class="form-item flex"><view class="title">工单名称:</view><view class="inputbox flex"><picker class="picker" mode="selector" range="{{cate}}" value="{{index}}" range-key="name" data-event-opts="{{[['change',[['BindPickerChange',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{catename}}</view></picker><text class="iconfont iconjiantou" style="color:#ccc;font-weight:normal;"></text></view></view><block a:for="{{formdata.content}}" a:for-item="fitem" a:for-index="findex"><view class="dp-form-separate" data-index="{{findex}}" data-event-opts="{{[['tap',[['formChange',['$event']]]]]}}" catchTap="__e"><text>{{fitem.name}}</text><image src="{{pre_url+'/static/img/workorder/'+(currentindex==findex?'down':'up')+'.png'}}"></image></view><view class="parentitem" style="{{(currentindex!=findex?'display:none':'')}}"><view class="form-item" a:for="{{fitem.list}}" a:for-item="item" a:for-index="idx"><view class="label">{{item.val1}}<block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+item.id}}" placeholder="{{item.val2}}" data-formidx="{{'form'+item.id}}" placeholder-style="font-size:28rpx"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+item.id}}" placeholder="{{item.val2}}" data-formidx="{{'form'+item.id}}" placeholder-style="font-size:28rpx"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+item.id}}" data-formidx="{{'form'+item.id}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form'+item.id}}" data-formidx="{{'form'+item.id}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+item.id}}" range="{{item.val2}}" data-idx="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[item.id]||editorFormdata[item.id]===0}}"><view>{{''+item.val2[editorFormdata[item.id]]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+item.id}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-bid="{{formdata}}" data-idx="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[item.id]}}"><view>{{editorFormdata[item.id]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+item.id}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-bid="{{formdata}}" data-idx="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[item.id]}}"><view>{{editorFormdata[item.id]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='region'}}"><block><uni-data-picker vue-id="{{'13294642-2-'+findex+'-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" placeholder="{{formdata['form'+item.id]||'请选择省市区'}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['^change',[['onchange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+item.id}}" value="{{regiondata?regiondata:formdata['form'+item.id]}}"/></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+item.id}}" value="{{editorFormdata['content_pics'+item.id]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:for="{{editorFormdata['content_pic'+item.id]}}" a:for-item="item1" a:for-index="index1" a:key="*this"><block a:if="{{editorFormdata['content_pic'+item.id]}}"><view class="form-imgbox"><view class="form-imgbox-close" data-pindex="{{index1}}" data-field="{{'content_pic'+item.id}}" data-idx="{{item.id}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="form-imgbox-img"><image src="{{item1}}" data-url="{{item1}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></block><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')+('background-position:'+('center')+';')}}" data-field="{{'content_pic'+item.id}}" data-idx="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></view></block></block><block a:if="{{item.key=='upload_video'}}"><block><input style="display:none;" type="text" name="{{'form'+item.id}}" value="{{editorFormdata[item.id]}}"/><view class="flex-y-center" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{editorFormdata[item.id]}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-close" data-idx="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view style="overflow:hidden;white-space:pre-wrap;word-wrap:break-word;color:#4786BC;width:230rpx;"><video style="width:100%;" src="{{editorFormdata[item.id]}}"></video></view></view></block><block a:else><block><view class="dp-form-uploadbtn" style="{{'margin-right:20rpx;'+('background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 30rpx')+';')+('background-size:'+('50rpx 50rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-id="{{item.id}}" data-formidx="{{'form'+item.id}}" data-event-opts="{{[['tap',[['upVideo',['$event']]]]]}}" onTap="__e"></view><block a:if="{{item.val2}}"><view style="color:#999;">{{item.val2}}</view></block></block></block></view></block></block></view></view></block><block a:if="{{formdata.payset==1}}"><view class="form-item"><text class="label">支付金额：</text><block a:if="{{formdata.priceedit==1}}"><input class="input" type="text" name="price" data-formidx="price" value="{{formdata.price}}"/></block><block a:if="{{formdata.priceedit==0}}"><text>{{formdata.price}}</text></block><text style="padding-left:10rpx;">元</text></view></block></view><view style="height:100rpx;"></view><view class="btnbox"><button class="dp-form-btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit" data-formcontent="{{formdata.content}}" data-formid="{{cateid}}">提交</button></view></form><view class="myworkorder" data-url="record" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的工单</view><block a:if="{{nodata}}"><nodata vue-id="13294642-3" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="13294642-4" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="13294642-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="13294642-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="13294642-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="13294642-8" onVueInit="__l"></wxxieyi></view>