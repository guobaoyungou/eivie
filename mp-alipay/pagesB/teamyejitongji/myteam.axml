<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="content"><block a:if="{{1}}"><view class="topsearch flex-y-center sx"><text class="t1">日期筛选：</text><view class="f2 flex" style="line-height:30px;"><picker mode="date" value="{{startDate}}" data-event-opts="{{[['change',[['bindStartDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{startDate}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">至</view><picker mode="date" value="{{endDate}}" data-event-opts="{{[['change',[['bindEndDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{endDate}}</view></picker><view class="t_date"><block a:if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" onTap="__e">清除</view></block></view></view></view></block><view class="yejilabel"><block a:if="{{(userinfo.set_tongji.slje==2||userinfo.set_tongji.slje==3)&&userlevel.team_yeji==1}}"><text class="t1">{{$root.m0+"总"+$root.m1+"："+(is_end==1?userinfo.team_yeji_total:'计算中')+" 元"}}</text></block><block a:if="{{userinfo.set_tongji.slje==1||userinfo.set_tongji.slje==3}}"><text class="t1">{{"商品总数量："+(is_end==1?userinfo.team_num_total:'计算中')+''}}</text></block></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:if="{{zt_member_limit!=0&&st==1}}"><view class="label"><text class="t1">{{"团队人数："+zt_member_limit}}</text></view></block><view class="label"><text class="t1">成员信息</text><block a:if="{{userinfo.set_tongji.yeji_name}}"><text class="t2">{{"来自TA的"+$root.m2}}</text></block><block a:else><text class="t2">{{"来自TA的"+$root.m3}}</text></block></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" onTap="__e"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.id+")"}}</text><text class="x2">{{item.createtime}}</text><text class="x2">{{"等级："+item.levelname}}</text><block a:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block a:if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block></view></view><view class="f2"><block a:if="{{userinfo.set_tongji.slje==2||userinfo.set_tongji.slje==3}}"><text class="t4" style="color:#0F5EE5;font-size:23rpx !important;" data-url="{{'/pagesB/teamyejitongji/goodsinfo?type=1&mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{$root.m4+$root.m5+"："+item.teamyeji}}</text></block><block a:if="{{userinfo.set_tongji.slje==1||userinfo.set_tongji.slje==3}}"><text class="t4" style="color:#0F5EE5;font-size:23rpx !important;" data-url="{{'/pagesB/teamyejitongji/goodsinfo?type=0&mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"商品数量："+item.goodsnum+''}}</text></block><view class="t3"><block a:if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m6}}</view></block></view></view></view></block></view></block><uni-popup vue-id="3a988fbc-1" id="dialogmoneyInput" type="dialog" ref="__r" data-ref="dialogmoneyInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('3a988fbc-2')+','+('3a988fbc-1')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="3a988fbc-3" id="dialogscoreInput" type="dialog" ref="__r" data-ref="dialogscoreInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('3a988fbc-4')+','+('3a988fbc-3')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{nodata}}"><nodata vue-id="3a988fbc-5" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="3a988fbc-6" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="3a988fbc-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="3a988fbc-8" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="3a988fbc-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>