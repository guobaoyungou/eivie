<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;">联系信息</view></view><block a:for="{{field_list}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.isshow==1}}"><view class="form-item"><view class="f1">{{item.name}}</view><view class="f2"><radio-group><label data-event-opts="{{[['tap',[['changseeaddfields',[index,true]]]]]}}" onTap="__e"><radio value="{{true}}" checked="{{seeaddfields[index]?true:false}}"></radio>展示</label><label data-event-opts="{{[['tap',[['changseeaddfields',[index,false]]]]]}}" style="margin-left:20rpx;" onTap="__e"><radio value="{{false}}" checked="{{seeaddfields[index]?false:true}}"></radio>不展示</label></radio-group></view><view class="f3" style="color:#58e;font-size:24rpx;margin-left:6rpx;"></view></view></block></block></view><block a:if="{{log.applysee==1}}"><view style="margin-top:60rpx;display:flex;justify-content:space-between;width:680rpx;margin:0 auto;"><button class="savebtn" style="background:#fff;color:#212121;" form-type="submit2">驳回</button><button class="savebtn" form-type="submit">提交并同意</button></view></block><block a:else><block a:if="{{log.applysee==2}}"><view style="margin-top:60rpx;width:680rpx;margin:0 auto;"><button class="savebtn" style="width:100%;" form-type="submit">提交</button></view></block></block><view style="height:50rpx;"></view></form></block></block><view style="display:none;">{{test}}</view><block a:if="{{loading}}"><loading vue-id="202b70c2-1" onVueInit="__l"></loading></block><popmsg vue-id="202b70c2-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="202b70c2-3" onVueInit="__l"></wxxieyi></view>