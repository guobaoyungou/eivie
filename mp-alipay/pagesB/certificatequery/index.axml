<view class="container"><block a:if="{{isload}}"><block><block a:if="{{set.header_text}}"><view><parse vue-id="1d2ff3d5-1" content="{{set.header_text}}" onVueInit="__l"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><view class="title">{{queryText}}</view><view class="inputdiv"><input type="text" name="realname" placeholder-style="color:#666;" placeholder="请输入姓名" value="{{realname}}"/></view><block a:if="{{set&&set.query_type=='id_card'}}"><view class="inputdiv"><input type="text" name="id_card" placeholder-style="color:#666;" placeholder="请输入身份证号" value="{{id_card}}"/></view></block><block a:if="{{set&&set.query_type=='tel'}}"><view class="inputdiv"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入手机号" value="{{tel}}"/></view></block><button class="btn" form-type="submit">查询</button></form><block a:if="{{set.footer_text}}"><view><parse vue-id="1d2ff3d5-2" content="{{set.footer_text}}" onVueInit="__l"></parse></view></block></block></block><block a:if="{{loading}}"><loading vue-id="1d2ff3d5-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1d2ff3d5-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1d2ff3d5-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>