<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><view class="item" data-url="{{'detail?tel='+item.tel+'&posterid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"姓名："+item.realname}}</text><text class="t2">{{"性别："+item.sex}}</text><block a:if="{{item.id_card}}"><text class="t2">{{"身份证号："+item.id_card}}</text></block><block a:if="{{item.tel}}"><text class="t2">{{"手机号："+item.tel}}</text></block><text class="t2">{{"证书编号："+item.certificate_no}}</text><text class="t2">{{"工种："+item.type}}</text><text class="t2">{{"等级："+item.certificate_level}}</text><text class="t2">{{"发证日期："+item.start_time}}</text></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="769b0860-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="769b0860-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="769b0860-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="769b0860-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="769b0860-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>