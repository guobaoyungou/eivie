<view><block a:if="{{isload}}"><block><view class="banner" style="{{'background:'+($root.m0)+';'}}"></view><view class="topsearch "><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="city" data-url="searchlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{city1?city1:city}}</view><input placeholder="{{'输入'+$root.m1+'名称'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view><view class="title">{{"当前"+$root.m2}}</view></view><view class="currentshequ"><view class="border"><view class="headimg"><image src="{{mendian.pic?mendian.pic:pre_url+'/static/img/touxiang.png'}}"></image></view><view class="name">{{mendian.name?mendian.name:'无'}}</view><view class="xqname">{{mendian.xqname}}</view><view class="address">{{mendian.address}}</view></view></view><view style="height:500rpx;"></view><view class="storeitem"><view class="title">{{'附近'+$root.m3}}</view><view class="radio-item" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['changeMendian',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="headimg"><image src="{{item.pic?item.pic:pre_url+'/static/img/touxiang.png'}}"></image></view><view class="f1"><view class="f11"><view><block a:if="{{item.xqname}}"><view>{{item.xqname}}</view></block><view class="name-text-view">{{$root.m4+"："+item.name}}</view></view><block a:if="{{item.distance}}"><text class="juli">{{"距离"+item.distance}}</text></block></view><view class="address"><view class="address2" data-address="{{item.address}}" data-longitude="{{item.longitude}}" data-latitude="{{item.latitude}}" data-event-opts="{{[['tap',[['toMendian',['$event']]]]]}}" catchTap="__e"><block a:if="{{item.province!='北京市'||item.province!='上海市'||item.province!='重庆市'||item.province!='天津市'}}"><text>{{item.province}}</text></block>{{item.city+item.district}}<block a:if="{{item.address}}"><text>{{item.address}}</text></block></view><image style="display:inline-block;width:24rpx;height:24rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="choose-view" style="{{'background-color:'+($root.m5)+';'}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['changeMendian',['$event']]]]]}}" catchTap="__e">选择</view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="893d8dc2-1" onVueInit="__l"></loading></block><block a:if="{{nodata}}"><nodata vue-id="893d8dc2-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="893d8dc2-3" onVueInit="__l"></nomore></block><dp-tabbar vue-id="893d8dc2-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="893d8dc2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>