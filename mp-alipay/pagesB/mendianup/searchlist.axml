<view><block a:if="{{isload}}"><block><block a:if="{{datalist.length>0}}"><view class="initials-list-wrap"><scroll-view class="scroll-list" scroll-y="{{true}}" scroll-into-view="{{scrollViewId}}"><view a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="letter" id="{{item.zimu}}">{{item.zimu}}</view><view class="con" data-city="{{item.city}}" data-event-opts="{{[['tap',[['search',['$event']]]]]}}" onTap="__e"><view class="list-item">{{''+item.city}}</view></view></view></scroll-view><view class="{{(('letter-list-bar')+' '+((touchmove)?'active':''))}}"><text data-event-opts="{{[['tap',[['letterSelect',[index]]]]]}}" class="{{(('text')+' '+((touchmoveIndex==index)?'active':''))}}" catchTap="__e" a:for="{{letterList}}" a:for-item="item" a:for-index="index" a:key="index">{{''+item+''}}</text></view><block a:if="{{touchmove}}"><view class="letter-alert">{{letterList[touchmoveIndex]+''}}</view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="47907c92-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="47907c92-2" text onVueInit="__l"></nodata></block><dp-chat-tabbar vue-id="47907c92-3" currentIndex="2" onVueInit="__l"></dp-chat-tabbar></block></block><popmsg vue-id="47907c92-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="47907c92-5" onVueInit="__l"></loading></block></view>