<view><block a:if="{{isload}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"拣货单记录（共"+count+"条）"}}</text></view><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t2">{{"总件数："+item.$orig.number}}</text></view><view class="f2"><text class="t2">{{item.m0}}</text><block a:if="{{item.$orig.status==0}}"><text class="t3">未收货</text></block><block a:if="{{item.$orig.status==1}}"><text class="t3">已收货</text></block></view><view class="f3"><text class="t3 btn2" data-url="{{'/pagesB/mendianup/fahuoinfo?oid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看</text><block a:if="{{item.$orig.status==0}}"><text data-event-opts="{{[['tap',[['shouhuo',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="t3 btn2" onTap="__e">收货</text></block></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="34242d20-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="34242d20-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="34242d20-3" onVueInit="__l"></loading></block><popmsg vue-id="34242d20-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>