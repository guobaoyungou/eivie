<view><block a:if="{{isload}}"><block><view class="navigation"><view class="navcontent" style="{{'margin-top:'+(navigationMenu.top+'px')+';'+('width:'+(navigationMenu.right+'px')+';')}}"><view class="header-location-top" style="{{'height:'+(navigationMenu.height+'px')+';'}}"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="header-back-but" onTap="__e"><image src="{{pre_url+'/static/img/hotel/fanhui.png'}}"></image></view></view></view></view><view class="dp-banner"><swiper class="dp-banner-swiper" autoplay="{{true}}" indicator-dots="{{false}}" current="{{0}}" circular="{{true}}" interval="{{3000}}"><block a:for="{{photolist}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item><view data-event-opts="{{[['tap',[['viewPicture',['$0','$1'],['photolist',[['photolist','',index]]]]]]]}}" onTap="__e"><image class="dp-banner-swiper-img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper></view><view class="position-view"><view class="banner-tab-view"><scroll-view style="width:auto;white-space:nowrap;margin-top:7.5rpx;" scroll-x="{{true}}"><block a:for="{{photos}}" a:for-item="item" a:for-index="index"><view class="{{('tab-options-banner '+(index==pindex?'tab-options-banner-active':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['chanagePhoto',['$event']]]]]}}" onTap="__e">{{item.name}}</view></block></scroll-view></view><view class="content-view" style="{{'background:'+('linear-gradient(180deg, '+$root.m0+' 0%, #FFFFFF 45px, #FFFFFF 63%, #FFFFFF 100%)')+';'}}"><view class="title-view">{{hotel.name}}</view><view class="hotel-nature"><block a:if="{{hotel.hotellevel>0}}"><view class="star-view"><image class="start" src="{{pre_url+'/static/img/star2native.png'}}" a:for="{{hotel.hotellevel+2}}" a:for-item="item" a:for-index="index"></image></view></block><block a:if="{{nature!=null}}"><view class="hotspot-nature-text">{{nature}}</view></block></view><block a:if="{{hotel.tag.length}}"><view class="hotspot-view"><view class="hotspot-view-left"><view class="hotspot-options" a:for="{{hotel.tag}}" a:for-item="item" a:for-index="index">{{''+item+''}}</view></view></view></block><view class="address-view"><view style="flex:1;"><view class="address-text">{{hotel.address}}</view><view class="address-traffic"><image src="{{pre_url+'/static/img/hotel/address.png'}}"></image>{{"距您"+hotel.juli+''}}</view></view><view class="fangshi-view"><view class="fagnshi-options" data-latitude="{{hotel.latitude}}" data-longitude="{{hotel.longitude}}" data-company="{{hotel.name}}" data-address="{{hotel.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/hotel/dingwei.png'}}"></image><view>导航</view></view></view></view><view data-event-opts="{{[['tap',[['selectDate',['$event']]]]]}}" class="time-view flex flex-y-center flex-bt" onTap="__e"><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{startDate}}</view><view class="day-tetx">{{startWeek+"入住"}}</view></view><view class="content-text"><view class="content-decorate left-c-d"></view>{{'共'+dayCount+'晚'}}<view class="content-decorate right-c-d"></view></view><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{endDate}}</view><view class="day-tetx">{{endWeek+"离店"}}</view></view></view></view><view class="screen-view"><view class="screen-view-left"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="{{('screen-options ')}}" style="{{(item.m1?'background:rgba('+item.m2+',0.05);color:'+item.m3:'')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['groupChange',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view></view><view class="hotels-list"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index"><view class="hotels-options" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['hotelDetail',['$event']]]]]}}" catchTap="__e"><view class="hotel-img"><block a:if="{{roomstyle==1}}"><image src="{{item.$orig.pic}}"></image></block><block a:else><image class="fangxing" src="{{item.$orig.pic}}"></image></block></view><view class="hotel-info"><view class="hotel-title">{{item.$orig.name}}</view><block a:if="{{roomstyle==1}}"><view class="hotel-characteristic"><block a:for="{{item.$orig.tag}}" a:for-item="items" a:for-index="indexs"><view class="characteristic-options" style="{{('background:rgba('+item.m4+',0.05);color:'+item.m5)}}">{{items}}</view></block></view></block><block a:else><view class="hotel-characteristic "><block a:if="{{item.$orig.bedxing!='不显示'}}"><view class="under_title"><view class="options-title">{{item.$orig.bedxing}}</view></view></block><view class="under_title"><view class="options-title">{{item.$orig.square+"m²"}}</view></view><block a:if="{{item.$orig.ischuanghu!='不显示'}}"><view class="under_title"><view class="options-title">{{item.$orig.ischuanghu}}</view></view></block><block a:if="{{item.$orig.breakfast!='不显示'}}"><view class="under_title"><view class="options-title">{{item.$orig.breakfast+"早餐"}}</view></view></block></view></block><view class="hotel-but-view"><view class="make-info"><block a:if="{{item.$orig.daymoney}}"><view class="hotel-price" style="{{'color:'+(item.m6)+';'}}"><view class="hotel-price-num">{{item.$orig.daymoney+moneyunit}}</view><view>/晚起</view></view></block><block a:else><view class="hotel-price" style="{{'color:'+(item.m7)+';'}}"><view>￥</view><view class="hotel-price-num">{{item.$orig.sell_price}}</view><view>起</view></view></block><block a:if="{{roomstyle==1}}"><view class="hotel-text">{{item.$orig.sales+"人已预定 | 剩"+item.$orig.stock+text['间']+"可订"}}</view></block><block a:else><view class="hotel-text">{{item.$orig.sales+"人已预定"}}</view></block></view><block a:if="{{btnstyle==1}}"><block><block a:if="{{item.$orig.stock>0&&!item.$orig.isbooking}}"><view class="hotel-make" style="{{('background:rgba('+item.m8+',0.8);color:#FFF')}}">预约</view></block><block a:else><block a:if="{{item.$orig.isbooking}}"><view class="hotel-make" style="background:#999999;color:#fff;">不可订</view></block><block a:else><view class="hotel-make" style="background:#999999;color:#fff;">已满</view></block></block></block></block></view><block a:if="{{btnstyle==2}}"><view><block a:if="{{item.$orig.stock>0&&!item.$orig.isbooking}}"><view class="hotel-make-new" style="{{'border-color:'+(item.m9)+';'}}"><view class="make-new-view" style="{{('background:'+item.m10+'')}}">订</view><view class="make-new-view2" style="{{'color:'+(item.m11)+';'+('border-color:'+(item.m12)+';')}}">{{"剩"+item.$orig.stock+text['间']}}</view></view></block><block a:else><block a:if="{{item.$orig.isbooking}}"><view class="hotel-make-new" style="background:#999999;border:1px #999999 solid;color:#fff;"><view class="make-new-view" style="background:#999999;color:#fff;">不可订</view><view class="make-new-view2" style="background:#999999;border-bottom:1px #999999 solid;color:#fff;">{{"剩"+item.$orig.stock+text['间']}}</view></view></block><block a:else><view class="hotel-make-new" style="background:#999999;border:1px #999999 solid;color:#fff;"><view class="make-new-view" style="background:#999999;color:#fff;">已满</view><view class="make-new-view2" style="background:#999999;border-bottom:1px #999999 solid;color:#fff;">{{"剩"+item.$orig.stock+text['间']}}</view></view></block></block></view></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="26375868-1" text="没有更多了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="26375868-2" text="没有查找到相关房型" onVueInit="__l"></nodata></block><block a:if="{{totalpagenum>pagenum}}"><view data-event-opts="{{[['tap',[['showmore',['$event']]]]]}}" class="hotel-more" style="{{'color:'+($root.m13)+';'}}" onTap="__e">查看剩余房型<image src="{{pre_url+'/static/img/hotel/mroe-hotel.png'}}"></image></view></block><view class="work-order-view flex flex-col"><view class="work-order-title"><view class="work-order-title-left">配套设施</view></view><view class="facilities-view flex "><block a:for="{{hotel.ptsheshi}}" a:for-item="item" a:for-index="index"><view class="options-facilities flex flex-col"><image src="{{item.icon}}"></image><view class="facilities-text">{{item.text}}</view></view></block></view></view><view class="work-order-view flex flex-col"><view class="work-order-title"><view class="work-order-title-left">订房须知</view></view><view class="required-reading-view"><parse vue-id="26375868-3" content="{{hotel.content}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></view><block a:if="{{hotel.comment==1}}"><view class="work-order-view flex flex-col"><view class="work-order-title"><view class="work-order-title-left">住客评价</view><view class="work-order-title-right" data-url="{{'/hotel/order/commentlist?hotelid='+hotel.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/hotel/rightjiantou.png'}}"></image></view></view><block a:if="{{commentlist.length>0}}"><view class="score-view"><view class="score-content flex flex-y-center flex-bt"><view class="total-score-view flex flex-col"><view class="total-score-num flex flex-y-center" style="{{'color:'+($root.m14)+';'}}"><view class="total-num">{{hotel.comment_score}}</view><view class="tatal-describe">{{haoping}}</view></view></view></view><view class="evaluate-list-view flex flex-col"><block a:for="{{commentlist}}" a:for-item="item" a:for-index="index"><view class="text-options flex flex-col"><view class="user-info-view flex flex-y-center flex-bt"><view class="info-view flex flex-y-center"><image class="avater-view" src="{{item.headimg}}"></image><view class="name-view flex flex-col"><view class="name-text">{{item.nickname}}</view><view class="time-view">{{item.createtime}}</view></view></view><view class="scoring-view flex flex-xy-center" style="{{('background:rgba('+$root.m15+',0.08);color:'+$root.m16)}}"><view>{{item.score}}</view><view style="font-size:20rpx;margin-left:5rpx;">分</view></view></view><view class="evaluate-imgList flex flex-y-center"><block a:for="{{item.content_pic}}" a:for-item="pic" a:for-index="index"><view class="img-options"><image src="{{pic}}"></image></view></block></view><view class="evaluate-value">{{''+item.content+''}}</view></view></block></view></view></block><block a:else><view><nodata vue-id="26375868-4" text="没有查找到记录" onVueInit="__l"></nodata></view></block></view></block></view><uni-popup vue-id="26375868-5" id="popup" type="bottom" ref="__r" data-ref="popup" onVueInit="__l"><view class="popup__content" style="bottom:0;padding-top:0;padding-bottom:0;max-height:86vh;"><view data-event-opts="{{[['tap',[['popupdetailClose',['$event']]]]]}}" class="popup-close" onTap="__e"><image src="{{pre_url+'/static/img/hotel/popupClose.png'}}"></image></view><scroll-view style="height:auto;max-height:90vh;" scroll-y="{{true}}"><view class="popup-banner-view" style="height:450rpx;"><swiper class="dp-banner-swiper" autoplay="{{true}}" indicator-dots="{{false}}" current="{{0}}" circular="{{true}}" interval="{{3000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{room.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item><view data-event-opts="{{[['tap',[['viewPicture',['$0','$1'],['room.pics',[['room.pics','',index]]]]]]]}}" onTap="__e"><image class="dp-banner-swiper-img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper><block a:if="{{bannerList.length}}"><view class="popup-numstatistics flex flex-xy-center">{{''+bannerindex+" / "+bannerList.length+''}}</view></block></view><view class="hotel-details-view flex flex-col"><view class="hotel-title">{{room.name}}</view><view class="introduce-view flex "><block a:if="{{room.bedxing!='不显示'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/dachuang.png'}}"></image><view class="options-title">{{room.bedxing}}</view></view></block><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/pingfang.png'}}"></image><view class="options-title">{{room.square+"m²"}}</view></view><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/chuangkuan.png'}}"></image><view class="options-title">{{room.bedwidth+"米"}}</view></view><block a:if="{{room.ischuanghu!='不显示'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/youchuang.png'}}"></image><view class="options-title">{{room.ischuanghu}}</view></view></block><block a:if="{{room.breakfast!='不显示'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/zaocan.png'}}"></image><view class="options-title">{{room.breakfast+"早餐"}}</view></view></block></view><view class="other-view flex flex-y-center"><view class="other-title">特色</view><view class="other-text" style="white-space:pre-line;">{{room.tese}}</view></view><view class="other-view flex flex-y-center"><view class="other-title">房型详情</view><dp vue-id="{{('26375868-6')+','+('26375868-5')}}" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view></view><block a:if="{{qystatus==1}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">{{qyname}}</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('26375868-7')+','+('26375868-5')}}" content="{{hotel.hotelquanyi}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></view></block><block a:if="{{fwstatus==1}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">{{fwname}}</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('26375868-8')+','+('26375868-5')}}" content="{{hotel.hotelfuwu}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></view></block><view class="hotel-e