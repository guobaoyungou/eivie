<view class="container"><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-item"><text class="label">退款原因</text><view class="input-item"><textarea placeholder="请输入退款原因" placeholder-style="color:#999;" name="reason"></textarea></view></view><view class="form-item"><text class="label">退款金额(元)</text><view class="flex"><input name="money" type="digit" placeholder="请输入退款金额" placeholder-style="color:#999;" value="{{totalprice}}"/></view><block a:if="{{detail.use_money&&detail.use_money>0}}"><view style="{{'color:'+($root.m0)+';'+('font-size:'+('26rpx')+';')+('padding-top:'+('20rpx')+';')}}">{{"*"+$root.m1+"抵扣部分审核通过后自动退还，"+$root.m2+"抵扣："+detail.use_money+"元"}}</view></block></view><button class="ref-btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">确定</button></form><block a:if="{{loading}}"><loading vue-id="449ea98c-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="449ea98c-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="449ea98c-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>