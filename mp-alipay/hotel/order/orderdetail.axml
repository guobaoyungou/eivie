<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block a:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t2">已付款，等待商家确认</view></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t2">商家已确认，等待入住</view></view></block><block a:if="{{detail.status==3}}"><view class="f1"><view class="t1">已到店</view></view></block><block a:if="{{detail.status==4}}"><view class="f1"><view class="t1">已离店</view></view></block><block a:if="{{detail.status==5}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block a:if="{{detail.status==-1}}"><view class="f1"><view class="t1">订单已关闭</view></view></block></view><view class="product"><view class="content"><view class="hotelpic"><image src="{{hotel.pic}}"></image></view><view class="detail"><text class="t1">{{hotel.name}}</text><text class="t2">{{hotel.address}}</text></view></view><view class="content" style="width:80%;margin:0 auto;display:flex;justify-content:space-between;"><view class="item1" data-latitude="{{hotel.latitude}}" data-longitude="{{hotel.longitude}}" data-company="{{hotel.name}}" data-address="{{hotel.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/hotel/add2.png'}}"></image><text>地图导航</text></view><view class="item1" data-phone="{{hotel.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/hotel/tel.png'}}"></image><text>{{"联系"+text['酒店']}}</text></view></view></view><view class="orderinfo1"><view class="item flex-bt"><view class="f1"><label class="t1">在线支付</label><text class="price flex-bt">{{"￥"+detail.totalprice+''}}</text></view><view data-event-opts="{{[['tap',[['mignxiChange',['$event']]]]]}}" class="cost-details flex flex-y-center" style="{{'color:'+($root.m0)+';'}}" onTap="__e">费用明细<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view></view><view class="orderinfo1"><view class="time-view flex flex-y-center flex-bt"><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{detail.in_date}}</view></view><view class="content-text"><view class="content-decorate left-c-d"></view>{{''+detail.daycount+'晚'}}<view class="content-decorate right-c-d"></view></view><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{detail.leave_date}}</view></view></view><view class="name-info flex flex-y-center flex-bt"><view class="flex flex-col"><view class="name-text">{{room.name}}</view><view class="name-tisp">{{room.tag}}</view></view><view data-event-opts="{{[['tap',[['showDetail',['$event']]]]]}}" class="hotel-details-view flex flex-y-center" style="{{'color:'+($root.m1)+';'}}" onTap="__e">查看房型<image src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></view><view class="item"><view class="f1"><label class="t1">入住姓名</label><text class="t2 flex-bt">{{detail.linkman+''}}</text></view></view><view class="item"><view class="f1"><label class="t1">联系手机</label><text class="t2 flex-bt">{{detail.tel+''}}</text></view></view><block a:if="{{detail.message}}"><view class="item"><view class="f1"><label class="t1">预定备注</label><text class="t2 flex-bt">{{detail.message+''}}</text></view></view></block></view><block a:if="{{detail.isbefore==1&&(detail.real_usemoney>0||detail.real_roomprice>0)}}"><view class="orderinfo"><view class="title">实际支付</view><view class="item flex-bt"><text class="t1">房费</text><block a:if="{{detail.real_usemoney>0&&detail.real_roomprice>0}}"><text class="t2 red">{{detail.real_usemoney+moneyunit+" + ￥"+detail.real_roomprice}}</text></block><block a:else><block a:if="{{detail.real_usemoney>0&&detail.real_roomprice==0}}"><text class="t2 red">{{detail.real_usemoney+moneyunit}}</text></block><block a:else><text class="t2 red">{{"￥"+detail.real_roomprice}}</text></block></block></view><block a:if="{{detail.real_fuwu_money>0}}"><view class="item flex-bt"><text class="t1">{{text['服务费']}}</text><view class="ordernum-info flex-bt"><text class="t2 red">{{"￥"+detail.real_fuwu_money}}</text></view></view></block></view></block><block a:if="{{detail.yajin_money>0&&detail.status>2}}"><view class="orderinfo"><view class="title">押金信息</view><view class="item flex-bt"><text class="t1">押金状态</text><view class="ordernum-info flex-bt"><block a:if="{{detail.yajin_refund_status==0}}"><text class="t2">待申请</text></block><block a:if="{{detail.yajin_refund_status==1}}"><text class="t2">审核中</text></block><block a:if="{{detail.yajin_refund_status==2}}"><text class="t2">已退款</text></block><block a:if="{{detail.yajin_refund_status==-1}}"><text class="t2">已驳回</text></block></view></view><block a:if="{{detail.yajin_refund_status==-1}}"><view class="item flex-bt"><text class="t1">驳回原因</text><view class="ordernum-info flex-bt"><text class="t2">{{detail.yajin_refund_reason?detail.yajin_refund_reason:'无'}}</text></view></view></block></view></block><view class="orderinfo"><view class="title">订单信息</view><view class="item flex-bt"><text class="t1">订单编号</text><view class="ordernum-info flex-bt"><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text><view class="btn-class" style="margin-left:20rpx;" data-text="{{detail.ordernum}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" onTap="__e">复制</view></view></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.daodian_time}}"><view class="item"><text class="t1">到店时间</text><text class="t2">{{detail.daodian_time}}</text></view></block><block a:if="{{detail.real_leavedate}}"><view class="item"><text class="t1">离店日期</text><text class="t2">{{detail.real_leavedate}}</text></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">待确认</text></block><block a:if="{{detail.status==2}}"><text class="t2">待入住</text></block><block a:if="{{detail.status==3}}"><text class="t2">已到店</text></block><block a:if="{{detail.status==4}}"><text class="t2">已离店</text></block><block a:if="{{detail.status==5}}"><text class="t2">已完成</text></block><block a:if="{{detail.status==-1}}"><text class="t2">已关闭</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason}}</text></view></block><block a:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block></view><block a:if="{{detail.formdata.length>0}}"><view class="orderinfo"><view class="item" a:for="{{detail.formdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><text class="t1">{{item[0]}}</text><block a:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block a:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" onTap="__e">关闭订单</view><view class="btn1" style="{{'background:'+($root.m2)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去付款</view></block></block><block a:if="{{detail.status==1&&detail.isrefund==1}}"><block><block a:if="{{detail.refund_status==0||detail.refund_status==3}}"><view class="btn2" data-url="{{'refund?id='+detail.id+'&price='+detail.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">申请退款</view></block></block></block><block a:if="{{detail.status==2&&detail.isrefund==1}}"><block><block a:if="{{detail.paytypeid!='4'}}"><block><block a:if="{{detail.refund_status==0||detail.refund_status==3}}"><view class="btn2" data-url="{{'refund?id='+detail.id+'&price='+detail.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">申请退款</view></block></block></block></block></block><block a:if="{{detail.status==2}}"><block><view data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" class="btn2" onTap="__e">核销码</view></block></block><block a:if="{{detail.status==-1}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除订单</view></block></block></view><uni-popup vue-id="150265d7-1" id="dialogHxqr" type="dialog" ref="__r" data-ref="dialogHxqr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><uni-popup vue-id="150265d7-2" id="popup" type="bottom" ref="__r" data-ref="popup" onVueInit="__l"><view class="hotelpopup__content"><view data-event-opts="{{[['tap',[['popupClose',['$event']]]]]}}" class="popup-close" onTap="__e"><image src="{{pre_url+'/static/img/hotel/popupClose2.png'}}"></image></view><scroll-view style="height:auto;max-height:50vh;" scroll-y="{{true}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex" style="padding-bottom:40rpx;"><view class="equity-title">费用明细</view></view><view class="cost-details flex flex-col"><view class="price-view flex flex-bt flex-y-center" style="margin-bottom:30rpx;"><view class="price-text-title">房费</view></view><view class="price-view flex flex-bt flex-y-center"><view class="price-text">优惠券抵扣</view><view class="price-num">{{"￥"+detail.coupon_money}}</view></view><view class="price-view flex flex-bt flex-y-center"><view class="price-text">{{$root.m3+"抵扣"}}</view><view class="price-num">{{(detail.use_money?detail.use_money:0)+moneyunit}}</view></view><view class="price-view flex flex-bt flex-y-center"><view class="price-text">现金支付</view><view class="price-num">{{"￥"+detail.leftmoney}}</view></view></view><view class="cost-details flex flex-col"><view class="price-view flex flex-bt flex-y-center" style="margin-bottom:30rpx;"><view class="price-text-title">其他</view><view class="price-num-title"></view></view><block a:if="{{detail.yajin_money>0}}"><view class="price-view flex flex-bt flex-y-center"><view class="price-text">押金(可退)</view><view class="price-num">{{"￥"+detail.yajin_money}}</view></view></block><block a:if="{{detail.fuwu_money>0}}"><view class="price-view flex flex-bt flex-y-center"><view class="price-text">{{text['服务费']}}</view><view class="price-num">{{"￥"+detail.fuwu_money}}</view></view></block></view><block a:if="{{detail.couponmoney>0||detail.scoredk_money>0||detail.upgradescoredk_money&&detail.upgradescoredk_money>0}}"><view class="cost-details flex flex-col"><view class="price-view flex flex-bt flex-y-center" style="margin-bottom:30rpx;"><view class="price-text-title">优惠</view><view class="price-num-title"></view></view><block a:if="{{detail.couponmoney>0}}"><view class="price-view flex flex-bt flex-y-center"><view class="price-text">优惠券抵扣</view><view class="price-num">{{"-￥"+detail.couponmoney}}</view></view></block><block a:if="{{detail.scoredk_money>0}}"><view class="price-view flex flex-bt flex-y-center"><view class="price-text">{{$root.m4+"抵扣"}}</view><view class="price-num">{{"-￥"+detail.scoredk_money}}</view></view></block><block a:if="{{detail.upgradescoredk_money>0}}"><view class="price-view flex flex-bt flex-y-center"><view class="price-text">{{text['升级积分']+"抵扣"}}</view><view class="price-num">{{"-￥"+detail.upgradescoredk_money}}</view></view></block></view></block></view></scroll-view></view></uni-popup><uni-popup vue-id="150265d7-3" id="popupDetail" type="bottom" ref="__r" data-ref="popupDetail" onVueInit="__l"><view class="hotelpopup__content"><view data-event-opts="{{[['tap',[['popupdetailClose',['$event']]]]]}}" class="popup-close" onTap="__e"><image src="{{pre_url+'/static/img/hotel/popupClose.png'}}"></image></view><scroll-view style="height:auto;max-height:70vh;" scroll-y="{{true}}"><view class="popup-banner-view" style="height:450rpx;"><swiper class="dp-banner-swiper" autoplay="{{true}}" indicator-dots="{{false}}" current="{{0}}" circular="{{true}}" interval="{{3000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{room.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item><view data-event-opts="{{[['tap',[['viewPicture',['$0'],[[['room.pics','',index]]]]]]]}}" onTap="__e"><image class="dp-banner-swiper-img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper><block a:if="{{room.pics.length}}"><view class="popup-numstatistics flex flex-xy-center">{{''+bannerindex+" / "+room.pics.length+''}}</view></block></view><view class="hotel-details-view flex flex-col"><view class="hotel-title">{{room.name}}</view><view class="introduce-view flex "><block a:if="{{room.bedxing!='不显示'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/dachuang.png'}}"></image><view class="options-title">{{room.bedxing}}</view></view></block><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/pingfang.png'}}"></image><view class="options-title">{{room.square+"m²"}}</view></view><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/dachuang.png'}}"></image><view class="options-title">{{room.bedwidth+"米"}}</view></view><block a:if="{{room.ischuanghu!='0'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/youchuang.png'}}"></image><view class="options-title">{{room.ischuanghu}}</view></view></block><block a:if="{{room.breakfast!='不显示'}}"><view class="options-intro flex flex-y-center"><image src="{{pre_url+'/static/img/hotel/zaocan.png'}}"></image><view class="options-title">{{room.breakfast+"早餐"}}</view></view></block></view><view class="other-view flex flex-y-center"><view class="other-title">特色</view><view class="other-text" style="white-space:pre-line;">{{room.tese}}</view></view></view><block a:if="{{qystatus==1}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">{{qyname}}</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('150265d7-4')+','+('150265d7-3')}}" content="{{hotel.hotelquanyi}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></view></block><block a:if="{{fwstatus==1}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">{{fwname}}</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('150265d7-5')+','+('150265d7-3')}}" content="{{hotel.hotelfuwu}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></view></block></scroll-view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="150265d7-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="150265d7-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="150265d7-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="150265d7-9" onVueInit="__l"></wxxieyi></view>