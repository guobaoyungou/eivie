<view><block a:if="{{isload}}"><block><block a:if="{{isplay==0}}"><view class="swiper-container"><swiper class="swiper" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{500000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper><view class="imageCount">{{current+1+"/"+product.pics.length}}</view><block a:if="{{product.video}}"><view data-event-opts="{{[['tap',[['payvideo',['$event']]]]]}}" class="provideo" onTap="__e"><image src="{{pre_url+'/static/img/video.png'}}"></image><view class="txt">{{product.video_duration}}</view></view></block></view></block><block a:if="{{isplay==1}}"><view class="videobox"><video class="video" autoplay="true" id="video" src="{{product.video}}"></video><view data-event-opts="{{[['tap',[['parsevideo',['$event']]]]]}}" class="parsevideo" onTap="__e">退出播放</view></view></block><view class="header"><view class="price_share"><view class="price"><view class="f1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:36rpx;">￥</text>{{product.sell_price+''}}<block a:if="{{product.price_show&&product.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{product.price_show_text}}</text></block></view><block a:if="{{product.market_price*1>product.sell_price*1}}"><view class="f2">{{"￥"+product.market_price}}</view></block><block a:if="{{product.pack_fee>0}}"><view class="f3">{{"打包费￥"+product.pack_fee+"/份"}}</view></block></view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><block a:if="{{product.price_show&&product.price_show==1}}"><view style="line-height:50rpx;"><text style="font-size:30rpx;">{{"￥"+product.sell_putongprice}}</text></view></block><block a:if="{{product.priceshows&&product.priceshows.length>0}}"><view><view style="line-height:50rpx;" a:for="{{product.priceshows}}" a:for-item="item" a:for-index="index"><text style="font-size:30rpx;">{{"￥"+item.sell_price}}</text><text style="margin-left:15rpx;font-size:24rpx;font-weight:400;">{{item.price_show_text}}</text></view></view></block><view class="title">{{product.name}}</view><block a:if="{{product.sellpoint}}"><view class="sellpoint">{{product.sellpoint}}</view></block><view class="sales_stock"><view class="f1">{{"销量："+product.sales+''}}</view><block a:if="{{product.limit_start>0}}"><view class="f1">{{"起售："+product.limit_start+''}}</view></block><block a:if="{{product.limit_per>0}}"><view class="f1">{{"限购："+product.limit_per+''}}</view></block><view class="f2">{{"库存："+product.stock}}</view></view><block a:if="{{shopset.showcommission==1&&product.commission>0}}"><view class="commission" style="{{'background:'+('rgba('+$root.m1+',0.1)')+';'+('color:'+($root.m2)+';')}}">{{"分享好友购买可得"+$root.m3+"："}}<text style="font-weight:bold;padding:0 2px;">{{product.commission}}</text>{{product.commission_desc}}</view></block></view><view class="choose" data-btntype="1" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e"><view class="f1 flex1">请选择商品规格及数量</view><image class="f2" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block a:if="{{product.givescore>0}}"><view class="cuxiaodiv"><view class="cuxiaopoint"><view class="f0">{{"送"+$root.m4}}</view><view class="f1" style="font-size:26rpx;">{{"购买可得"+$root.m5+product.givescore+"个"}}</view></view></view></block><block a:if="{{cuxiaolist.length>0||couponlist.length>0}}"><view class="cuxiaodiv"><block a:if="{{cuxiaolist.length>0}}"><view class="cuxiaopoint"><view class="f0">促销</view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f1" onTap="__e"><view class="t" style="{{'background:'+('rgba('+$root.m6+',0.1)')+';'+('color:'+($root.m7)+';')}}" a:for="{{cuxiaolist}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t0">{{item.tip}}</text><text class="t1">{{item.name}}</text></view></view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block a:if="{{couponlist.length>0}}"><view class="cuxiaopoint"><view class="f0">优惠</view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f1" onTap="__e"><view class="t" style="{{'background:'+('rgba('+$root.m8+',0.1)')+';'+('color:'+($root.m9)+';')}}" a:for="{{couponlist}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t0" style="padding:0 6px;">券</text><text class="t1">{{item.name}}</text></view></view><view data-event-opts="{{[['tap',[['showcuxiaodetail',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></view></block><block a:if="{{showcuxiaodialog}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidecuxiaodetail',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal coupon-modal"><view class="popup__title"><text class="popup__title-text">优惠促销</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hidecuxiaodetail',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="service-item" a:for="{{cuxiaolist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="suffix"><view class="type-name"><text style="border-radius:4px;border:1px solid #f05423;color:#ff550f;font-size:20rpx;padding:2px 5px;">{{item.tip}}</text><text style="color:#333;margin-left:20rpx;">{{item.name}}</text></view></view></view><couponlist vue-id="c8353e5c-1" couponlist="{{couponlist}}" data-event-opts="{{[['^getcoupon',[['getcoupon']]]]}}" onGetcoupon="__e" onVueInit="__l"></couponlist></view></view></view></block><block a:if="{{shopset.shop_comment==1&&commentcount>0}}"><view class="commentbox"><view class="title"><view class="f1">{{"评价("+commentcount+")"}}</view><view class="f2" data-url="{{'commentlist?proid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">好评度<text style="{{'color:'+($root.m10)+';'}}">{{product.comment_haopercent+"%"}}</text><image style="width:32rpx;height:32rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="comment"><block a:if="{{commentlist.length>0}}"><view class="item"><view class="f1"><image class="t1" src="{{commentlist[0].headimg}}"></image><view class="t2">{{commentlist[0].nickname}}</view><view class="flex1"></view><view class="t3"><image class="img" src="{{pre_url+'/static/img/star'+(commentlist[0].score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2" a:key="index2"></image></view></view><view class="f2"><text class="t1">{{commentlist[0].content}}</text><view class="t2"><block a:if="{{commentlist[0].content_pic!=''}}"><block><block a:for="{{commentlist[0].content_pic}}" a:for-item="itemp" a:for-index="index" a:key="index"><view data-url="{{itemp}}" data-urls="{{commentlist[0].content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></view></view><view class="f3" data-url="{{'commentlist?proid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看全部评价</view></view></block><block a:else><view class="nocomment">暂无评价~</view></block></view></view></block><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">商品描述</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><dp vue-id="c8353e5c-2" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view><view style="width:100%;height:140rpx;"></view><block a:if="{{product.status==1}}"><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':''))}}"><view class="f1"><block a:if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block a:else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block><block a:if="{{$root.m11}}"><view class="item flex1" data-url="{{'index?bid='+product.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/gwc.png'}}"></image><view class="t1">购物车</view><block a:if="{{cartnum>0}}"><view class="cartnum" style="{{'background:'+('rgba('+$root.m12+',0.8)')+';'}}">{{cartnum}}</view></block></view></block><view data-event-opts="{{[['tap',[['addfavorite',['$event']]]]]}}" class="item" onTap="__e"><block a:if="{{isfavorite}}"><image class="img" src="{{pre_url+'/static/img/tabbar/shoucangselected.png'}}"></image></block><block a:else><image class="img" src="{{pre_url+'/static/img/shoucang.png'}}"></image></block><view class="t1">{{isfavorite?'已收藏':'收藏'}}</view></view></view><block a:if="{{product.stock>0&&product.stock_daily>product.sales_daily}}"><view class="op"><block a:if="{{$root.m13}}"><view class="tocart flex-x-center flex-y-center" style="{{'background:'+($root.m14)+';'}}" data-btntype="1" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">加入购物车</view></block><block a:if="{{$root.m15}}"><view class="tocart flex-x-center flex-y-center" style="{{'background:'+($root.m16)+';'}}" data-btntype="2" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">立即购买</view></block></view></block><block a:else><view class="op"><view class="tobuy flex-x-center flex-y-center" style="background-color:#ccc;" data-btntype="2">已售罄</view></view></block></view></block><block a:if="{{buydialogShow}}"><buydialog-restaurant vue-id="c8353e5c-3" proid="{{product.id}}" btntype="{{btntype}}" menuindex="{{menuindex}}" controller="ApiRestaurantShop" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]],['^addcart',[['afteraddcart']]]]}}" onBuydialogChange="__e" onAddcart="__e" onVueInit="__l"></buydialog-restaurant></block><scrolltop vue-id="c8353e5c-4" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m17=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m18=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m19!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="c8353e5c-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="c8353e5c-6" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar></view>