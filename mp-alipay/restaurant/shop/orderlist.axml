<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="50942096-1" itemdata="{{['全部','待付款','已付款','已完成','退款']}}" itemst="{{['all','0','1','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="order-content"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.$orig.bid!=0&&item.$orig.binfo}}"><view class="f1" data-url="{{'/restaurant/shop/index?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.binfo.name}}</view></block><block a:else><view>{{"订单号："+item.$orig.ordernum}}</view></block><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1&&item.$orig.paytypeid!=4}}"><text class="st1">已付款</text></block><block a:if="{{item.$orig.status==1&&item.$orig.paytypeid==4}}"><text class="st1">线下付款</text></block><block a:if="{{item.$orig.status==12}}"><text class="st1">已接单</text></block><block a:if="{{item.$orig.status==2}}"><text class="st2">配送中</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view style="width:140rpx;overflow:hidden;"><image src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><block a:if="{{item2.$orig.ggtext&&item2.$orig.ggtext.length}}"><view class="flex-col"><block a:for="{{item2.$orig.ggtext}}" a:for-item="item3" a:for-index="index"><text class="t2">{{item3}}</text></block></view></block><block a:if="{{item2.$orig.ggname}}"><text class="t2">{{item2.$orig.ggname+(item2.$orig.jltitle?item2.$orig.jltitle:'')}}</text></block><view class="t3"><block a:if="{{item2.$orig.jlprice}}"><text class="x1 flex1">{{"￥"+item2.g0}}<block a:if="{{item2.$orig.product_type&&item2.$orig.product_type==1}}"><text style="font-size:20rpx;">/斤</text></block></text></block><block a:else><text class="x1 flex1">{{"￥"+item2.$orig.sell_price}}<block a:if="{{item2.$orig.product_type&&item2.$orig.product_type==1}}"><text style="font-size:20rpx;">/斤</text></block></text></block><text class="x2">{{"×"+item2.$orig.num}}<block a:if="{{item2.$orig.product_type&&item2.$orig.product_type==1}}"><text style="font-size:20rpx;">斤</text></block></text></view></view></view></block><view class="bottom"><text>{{"共计"+item.$orig.procount+"件商品 实付:￥"+item.$orig.totalprice}}</text><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">详情</view><block a:if="{{item.$orig.status==0}}"><block><block a:if="{{item.$orig.is_bar_table_order==0||item.$orig.eattype==1}}"><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'index?tableId='+item.$orig.tableid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">加菜</view></block><block a:if="{{item.$orig.eattype==1}}"><view data-event-opts="{{[['tap',[['toBuy',['$0'],[[['datalist','',index]]]]]]]}}" class="btn1" style="{{'background:'+(item.m1)+';'}}" catchTap="__e">去结算</view></block><block a:else><view class="btn1" style="{{'background:'+(item.m2)+';'}}" data-id="{{item.$orig.payorderid}}" data-istopay="{{item.$orig.is_topay}}" data-event-opts="{{[['tap',[['toPay',['$event']]]]]}}" catchTap="__e">去付款</view></block></block></block><block a:if="{{item.$orig.status==12||item.$orig.status==2}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block></block></block><block a:if="{{item.$orig.status==2}}"><block><block a:if="{{item.$orig.paytypeid!='4'}}"><view class="btn1" style="{{'background:'+(item.m3)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" catchTap="__e">确认收货</view></block></block></block><block a:if="{{item.$orig.status==3}}"><block><block a:if="{{item.$orig.iscommentdp==0}}"><view class="btn1" style="{{'background:'+(item.m4)+';'}}" data-url="{{'commentdp?orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">评价店铺</view></block></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="50942096-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="50942096-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="50942096-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="50942096-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>