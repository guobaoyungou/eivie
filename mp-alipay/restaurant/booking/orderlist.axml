<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="18b15e2a-1" itemdata="{{['全部','待付款','待审核','已完成','退款']}}" itemst="{{['all','0','1','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="order-content"><block><view class="order-box" a:for="{{datalist}}" a:for-item="item2" a:for-index="idx" a:key="idx"><block><view class="content" data-url="{{'detail?id='+item2.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="pic"><image class="img" src="{{item2.binfo.logo}}"></image></view><view class="detail"><text class="t1">{{item2.binfo.name}}</text><text class="t2">{{"预约桌台："+item2.tableName}}</text><text class="t2">{{"预约时间："+item2.booking_time}}</text></view></view></block></view></block></view><block a:if="{{nomore}}"><nomore vue-id="18b15e2a-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="18b15e2a-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="18b15e2a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="18b15e2a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>