<view class="container"><block a:if="{{isload}}"><block><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" onTap="__e">{{item.name}}</view></block></view></view><view class="shop-box"><view class="shop-item" a:for="{{contentList}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><image class="shop-img" src="{{item.pic?item.pic:logo}}" mode="aspectFill"></image><view class="f2 flex-col flex1"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="desc">{{textset['座位数']+"："+item.seat}}</view><view class="desc"><block a:if="{{set.show_booking_fee}}"><text>{{"预定费："+item.booking_fee}}</text></block>{{"最低消费："+item.limit_fee}}</view></view><view class="f3 button" data-url="{{'add?bid='+opt.bid+'&tableId='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">选择</view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="84304cec-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="84304cec-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="84304cec-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="84304cec-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>