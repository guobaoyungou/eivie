<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'detail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view class="f1" data-url="{{item.$orig.bid!=0?'/pages/business/index?bid='+item.$orig.bid:'/pages/index/index'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item.$orig.binfo.logo}}"></image><text>{{item.$orig.binfo.name}}</text><text class="flex1"></text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view class="pic"><image class="img" src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><text class="t2">{{"数量："+item2.$orig.num}}</text><text class="t2">{{"存入时间："+item2.m0}}</text></view><block a:if="{{item2.$orig.status==0}}"><view class="takeout st0" data-orderid="{{item2.$orig.id}}">审核中</view></block><block a:if="{{item2.$orig.status==1}}"><view class="takeout" data-bid="{{item.$orig.bid}}" data-orderid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" onTap="__e"><image class="img" src="/static/restaurant/deposit_takeout.png"></image>取出</view></block><block a:if="{{item2.$orig.status==2}}"><view class="takeout st2" data-orderid="{{item2.$orig.id}}">已取走</view></block><block a:if="{{item2.$orig.status==3}}"><view class="takeout st3" data-orderid="{{item2.$orig.id}}">未通过</view></block><block a:if="{{item2.$orig.status==4}}"><view class="takeout st4" data-orderid="{{item2.$orig.id}}">已过期</view></block></view></block><view class="op"><view class="btn2" data-url="{{'orderdetail?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">寄存记录</view><view class="btn2" data-url="{{'add?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">我要寄存</view><view class="btn1" style="{{'background:'+($root.m1)+';'}}" data-bid="{{item.$orig.bid}}" data-orderid="0" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" catchTap="__e">一键取出</view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="54d85d45-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="54d85d45-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="54d85d45-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="54d85d45-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>