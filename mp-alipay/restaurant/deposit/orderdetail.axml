<view class="container"><block a:if="{{isload}}"><block><view class="topbg"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderlog?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="pic"><image class="img" src="{{item.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{"数量："+item.$orig.num}}</text><text class="t2">{{"存入时间："+item.m0}}</text></view><block a:if="{{item.$orig.status==0}}"><view class="takeout st0">审核中</view></block><block a:if="{{item.$orig.status==1}}"><view class="takeout" data-orderid="{{item.$orig.id}}" data-num="{{item.$orig.num}}" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/deposit_takeout.png'}}"></image>取出</view></block><block a:if="{{item.$orig.status==2}}"><view class="takeout st2" data-orderid="{{item.$orig.id}}">已取走</view></block><block a:if="{{item.$orig.status==3}}"><view class="takeout st3" data-orderid="{{item.$orig.id}}">未通过</view></block><block a:if="{{item.$orig.status==4}}"><view class="takeout st3">已过期</view></block></view></block></view><block a:if="{{nomore}}"><nomore vue-id="2635d1b2-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="2635d1b2-2" onVueInit="__l"></nodata></block><view class="bottom"><block a:if="{{sysset.is_use_table==1}}"><view class="btn2" data-orderid="0" data-event-opts="{{[['tap',[['allTakeOperate',['$event']]]]]}}" onTap="__e">一键取出</view></block><block a:else><view class="btn2" data-orderid="0" data-event-opts="{{[['tap',[['takeouts',['$event']]]]]}}" onTap="__e">一键取出</view></block><view class="btn1" style="{{'background:'+($root.m1)+';'}}" data-url="{{'add?bid='+bid+'&isusetable='+sysset.is_use_table}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我要寄存</view></view></block></block><block a:if="{{loading}}"><loading vue-id="2635d1b2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="2635d1b2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><block a:if="{{boxShow}}"><view data-event-opts="{{[['touchMove',[['disabledScroll',['$event']]]]]}}" catchTouchMove="__e"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请输入取出数量</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content takeoutBox"><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="orderinfo"><view class="item"><text class="t1">取出数量</text><input class="t2" type="text" placeholder="请输入要取出的数量" placeholder-style="font-size:28rpx;color:#BBBBBB" name="numbers" value="{{num}}"/></view></view><button class="btn" style="{{'background:'+($root.m2)+';'}}" form-type="submit">确定</button></form></view></view></view></block><block a:if="{{allTakeShow}}"><view><view data-event-opts="{{[['tap',[['allTakeOperate',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">一键取出</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content takeoutBox"><view class="orderinfo"><view class="item"><text class="t1">选择桌台</text></view><view style="max-height:40vh;overflow:hidden;overflow-y:auto;"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['tableChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.$orig.id==tableid?'background:'+item.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view><button data-event-opts="{{[['tap',[['allTakeSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m4)+';'}}" onTap="__e">确定</button></view></view></view></block></view>