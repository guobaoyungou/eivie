<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.queue_no}}</text><text class="t2">{{item.$orig.cname}}</text><text class="t2">{{item.m0}}</text></view><view class="f2"><block a:if="{{item.$orig.status==0}}"><text class="t1">排队中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t2">已叫号</text></block><block a:if="{{item.$orig.status==2}}"><text class="t3">已过号</text></block><block a:if="{{item.$orig.status==3}}"><text class="t3">已取消</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="210b1c39-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="210b1c39-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="210b1c39-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="210b1c39-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>