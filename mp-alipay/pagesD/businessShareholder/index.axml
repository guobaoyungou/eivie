<view class="container"><block a:if="{{isload}}"><block><view style="width:720rpx;margin:0 auto;margin-bottom:20rpx;"><view style="padding:10rpx 20rpx;border:2rpx solid #f1f1f1;border-radius:12rpx 12rpx;line-height:50rpx;margin-top:20rpx;" a:for="{{banks}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.type==0}}"><view><view>{{"银行名称："+item.bankname}}</view><view>{{"户名："+item.bankcarduser}}</view><view style="display:flex;"><view>{{"账户："+item.bankcardnum}}</view><view style="color:#fff;background-color:red;padding:0 20rpx;border-radius:12rpx 12rpx;margin-left:20rpx;" data-content="{{item.bankcardnum}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" onTap="__e">复制</view></view></view></block><block a:else><view style="display:flex;align-items:center;justify-content:space-between;"><view>{{item.ewmname+"："+(item.ewmcardnum||'')}}</view><view style="height:100rpx;"><image style="height:100%;" src="{{item.ewmpic}}" data-url="{{item.ewmpic}}" mode="heightFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></view></view><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form"><block a:if="{{id==0}}"><view><view class="form-item"><view class="label">选择门店类型</view><picker style="width:100%;" value="{{shareholderindex}}" range="{{shareholders}}" range-key="name" data-event-opts="{{[['change',[['pickerShareholder',['$event']]]]]}}" onChange="__e"><view style="display:flex;justify-content:space-between;background-color:#f1f1f1;height:70rpx;line-height:70rpx;padding:0 20rpx;align-items:center;"><view>{{shareholders[shareholderindex]['name']}}</view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></picker></view><view class="form-item"><view class="label">需要支付金额</view><input class="input" type="text" disabled="{{true}}" placeholder-style="font-size:28rpx;color:#BBBBBB" value="{{shareholders[shareholderindex]['price']+'元'}}"/></view></view></block><block a:else><view><view class="form-item"><view class="label">{{"入股份额(剩余份额："+record.needjoinnum+"份)"}}</view><input class="input" type="number" name="num" placeholder-style="font-size:28rpx;color:#BBBBBB" data-event-opts="{{[['input',[['inputNum',['$event']]]]]}}" value="{{num}}" onInput="__e"/></view><view class="form-item"><view class="label">需要支付金额</view><input class="input" type="text" name="totalprice" disabled="{{true}}" placeholder-style="font-size:28rpx;color:#BBBBBB" value="{{totalprice}}"/></view></view></block><block a:if="{{!opttype}}"><view class="form-item"><view class="label">上传打款凭证</view><view style="flex-wrap:wrap;display:flex;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<3}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g0}}"/></view></block></view><block a:if="{{!opttype}}"><view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><button class="savebtn" style="{{('border:2rpx solid '+$root.m2+';color:'+$root.m3)}}" data-url="/pagesD/businessShareholder/applylog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看申请记录</button></view></block><block a:else><block a:if="{{opttype=='share'&&!sharetypevisible}}"><view><button data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')}}" onTap="__e">点击分享</button></view></block></block></form></block></block><block a:if="{{showScheme}}"><view class="posterDialog schemeDialog"><view class="main"><view data-event-opts="{{[['tap',[['schemeDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="schemecon"><view style="line-height:30rpx;text-align:center;padding:10rpx;">{{schemetitle}}</view><view>邀请链接：<text style="color:#00A0E9;word-break:break-all;">{{schemeurl}}</text></view><view class="copybtn" style="{{'background:'+('linear-gradient(90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';'}}" data-text="{{'邀请链接：'+schemeurl}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" catchTap="__e">一键复制</view></view></view></view></block><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m8!='h5'}}"><button class="f1" open-type="share" data-event-opts="{{[['tap',[['hideshow',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></view></view></view></view></block><block a:if="{{loading}}"><loading vue-id="7396c28f-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="7396c28f-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7396c28f-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="7396c28f-4" onVueInit="__l"></wxxieyi></view>