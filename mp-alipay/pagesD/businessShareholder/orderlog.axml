<view class="container"><block a:if="{{isload}}"><block><view style="width:100%;position:fixed;top:0;left:0;height:290rpx;"><view style="margin-top:2rpx;display:flex;justify-content:space-between;background-color:#fff;padding:30rpx 20rpx;"><view>{{"累计投资："+count}}</view><view>{{"股东收入："+count2}}</view></view><view style="margin-top:4rpx;"><dd-tab vue-id="5dfbe1d1-1" itemdata="{{['今日','本周','本月','累计']}}" itemst="{{['0','1','2','3']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="margin-top:4rpx;"><dd-tab vue-id="5dfbe1d1-2" itemdata="{{itemdata2}}" itemst="{{itemst2}}" st="{{st2}}" showstatus="{{showstatus2}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab2']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view></view><view style="width:100%;height:290rpx;"></view><view class="content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'maidandetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><view class="t1">{{item.$orig.paytime}}</view><view class="t2">{{"订单编号："+item.$orig.ordernum}}</view><view class="t2">{{"所属商户："+item.$orig.bname}}</view><block a:if="{{item.$orig.fenhongmoney>=0}}"><view class="t2">已分红金额：<text style="{{('color:'+item.m0)}}">{{"￥"+item.$orig.fenhongmoney}}</text></view></block><block a:if="{{item.$orig.fenhongmoney2>=0}}"><view class="t2">待分红金额：<text style="{{('color:'+item.m1)}}">{{"￥"+item.$orig.fenhongmoney2}}</text></view></block></view><view class="f2"><view class="t1">{{"￥"+item.$orig.totalprice}}</view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="5dfbe1d1-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="5dfbe1d1-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="5dfbe1d1-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="5dfbe1d1-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5dfbe1d1-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>