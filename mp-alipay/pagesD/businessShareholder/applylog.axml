<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="0bf0841e-1" itemdata="{{['发起众筹列表','申请入股列表']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view><view><view>{{"所属商户："+item.$orig.bname}}</view></view><view><view>{{"门店类型："+item.$orig.shname}}</view></view><view style="display:flex;flex-wrap:wrap;align-items:center;"><view>凭证：</view><view style="margin:10rpx 0;" a:for="{{item.$orig.pics}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view style="width:180rpx;height:180rpx;margin-right:10rpx;overflow:hidden;"><image style="width:100%;" src="{{item2}}" data-url="{{item2}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view><view>状态：<block a:if="{{item.$orig.status==0}}"><text style="color:#f30;">待审核</text></block><block a:if="{{item.$orig.status==1}}"><text style="color:green;">已通过</text></block><block a:if="{{item.$orig.status==-1}}"><text style="color:#999;">已驳回</text></block></view><block a:if="{{item.$orig.status==-1}}"><view>{{"拒绝原因："+item.$orig.checkreason}}</view></block><view style="display:flex;justify-content:space-between;align-items:center;"><view>{{"时间："+item.$orig.createtime}}</view><block a:if="{{item.$orig.status==1&&item.$orig.endstatus==0}}"><view style="{{('border: 2rpx solid'+item.m0+';border-radius: 8rpx 8rpx ;padding: 0 18rpx;font-size:26rpx;color:'+item.m1)}}" data-url="{{'/pagesD/businessShareholder/index?type=1&id='+item.$orig.id+'&pid='+item.$orig.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">继续入股</view></block><block a:if="{{item.$orig.status==1&&item.$orig.endstatus==0}}"><view style="{{('border: 2rpx solid'+item.m2+';border-radius: 8rpx 8rpx ;padding: 0 18rpx;font-size:26rpx;color:'+item.m3)}}" data-url="{{'/pagesD/businessShareholder/index?opttype=share&type=1&id='+item.$orig.id+'&pid='+item.$orig.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">邀请入股</view></block></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="0bf0841e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0bf0841e-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="0bf0841e-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="0bf0841e-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0bf0841e-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>