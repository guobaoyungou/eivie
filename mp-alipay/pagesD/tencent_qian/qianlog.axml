<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="d10cdb08-1" itemdata="{{['全部','待签署','已完成','已失效']}}" itemst="{{['all','1','2','-1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view><view><view>{{"合同名称："+item.FlowName}}</view></view><view><view>{{"类型："+item.typename}}</view></view><block a:if="{{item.type=='member_uplevel'}}"><view><view>{{"等级："+item.levelname}}</view></view></block><block a:if="{{item.wxurl}}"><view><view style="word-wrap:break-word;line-height:40rpx;">{{"微信小程序链接："+item.wxurl}}</view><view style="width:130rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-content="{{item.wxurl}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" onTap="__e">复制</view></view></block><block a:if="{{item.h5url}}"><view><view style="word-wrap:break-word;line-height:40rpx;">{{"手机H5链接："+item.h5url}}</view><view style="width:130rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-content="{{item.h5url}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" onTap="__e">复制</view></view></block><view style="display:flex;"><view>状态：</view><block a:if="{{item.status==0}}"><view style="color:#f30;">待发起</view></block><block a:if="{{item.status==1}}"><view style="display:flex;align-items:center;"><view style="color:green;">待签署</view><block a:if="{{item.cancelFlow}}"><view style="width:100rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-id="{{item.id}}" data-event-opts="{{[['tap',[['popupCancelflowOpen',['$event']]]]]}}" onTap="__e">撤销</view></block></view></block><block a:if="{{item.status==2}}"><view style="color:#999;">已完成</view></block><block a:if="{{item.status==-1||item.status==-2}}"><view style="color:#bbb;">已失效</view></block></view><block a:if="{{(item.status==-1||item.status==-2)&&item.reason}}"><view><view>{{item.reason}}</view></view></block><view><view>{{"时间："+item.createtime}}</view></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="d10cdb08-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="d10cdb08-3" onVueInit="__l"></nodata></block><uni-popup vue-id="d10cdb08-4" id="popupCancelflow" type="dialog" ref="__r" data-ref="popupCancelflow" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">撤销签署合同</text></view><view class="uni-dialog-content"><view style="padding:0 20rpx;width:100%;line-height:60rpx;"><view style="margin-bottom:20rpx;display:flex;">撤销理由：<input class="input" style="width:460rpx;height:60rpx;line-height:60rpx;" data-field="reason" type="text" placeholder="请输入撤销理由" placeholder-style="color:#999;font-size:32rpx;height:60rpx;line-height: 60rpx;" data-event-opts="{{[['input',[['popupInput',['$event']]]]]}}" value="{{reason}}" onInput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['popupCancelflowClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['popupCancelflowConfirm',['$event']]]]]}}" class="uni-dialog-button" style="{{'color:'+($root.m0)+';'}}" onTap="__e"><text class="uni-dialog-button-text">确定</text></view></view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="d10cdb08-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="d10cdb08-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d10cdb08-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>