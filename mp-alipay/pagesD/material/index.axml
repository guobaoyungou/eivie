<block a:if="{{isload}}"><block><view class="container"><view class="{{(('navigation')+' '+((showCustomNav)?'show':''))}}"><view class="custom-nav"><view class="nav-left-icon" data-url="/pagesD/material/collect" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></view><view class="nav-log-box"><image class="nav-logo" src="{{set.logo}}" mode="aspectFit"></image></view></view></view><view class="swiper-container"><swiper class="swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="{{5000}}" indicator-active-color="#ffffff" indicator-color="rgba(255,255,255,0.5)"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{set.pics&&set.pics.length>0}}"><block><swiper-item class="swiper-item"><block a:if="{{!item.m0}}"><image src="{{item.$orig}}" mode="aspectFill"></image></block><block a:else><video src="{{item.$orig}}" autoplay="{{true}}" loop="{{true}}" controls="{{false}}" show-play-btn="{{false}}" show-fullscreen-btn="{{true}}" show-center-play-btn="{{false}}" enable-progress-gesture="{{false}}" object-fit="cover" muted="{{true}}"></video></block></swiper-item></block></block></block></swiper></view><view style="height:450rpx;"></view><view class="content-container flex-bt" style="height:calc(150vh - (450rpx - 180rpx));"><view class="nav-left sticky"><block a:for="{{navlist}}" a:for-item="item" a:for-index="parentIndex" a:key="parentIndex"><view class="nav-header">{{item.name}}</view><block a:for="{{item.children}}" a:for-item="child" a:for-index="childIndex" a:key="childIndex"><view class="{{('nav-items '+(curParentIndex===parentIndex&&curChildIndex===childIndex?'active':''))}}" data-id="{{child.id}}" data-parent="{{parentIndex}}" data-child="{{childIndex}}" data-type="{{child.type}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e">{{''+child.name+''}}</view></block></block></view><view class="nav-right"><view class="classify-container"><block a:if="{{classify&&classify.length>0}}"><view class="classify flex"><block a:for="{{classify}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{(('classify-item')+' '+(item.id===threeid?'active':''))}}" data-id="{{item.id}}" data-type="{{item.type}}" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" onTap="__e">{{''+item.name+''}}</view></block></view></block></view><block a:if="{{classtype==1}}"><view class="material-columns"><view class="material-item" data-url="{{'details?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="material-pic"><image class="image" src="{{item.url}}" mode="widthFix"></image></view><view class="material-name">{{item.name}}</view></view></view></block><block a:if="{{classtype==4}}"><view class="imagetext"><view class="imagetext-item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view style="padding:20rpx;"><view class="top flex-bt"><view class="head flex"><image class="f1" src="{{set.logo}}"></image><view class="f2"><view class="t1">{{set.name}}</view><view class="t2">{{item.createtime}}</view></view></view></view><view class="con"><view class="f1"><text class="{{((!item.showFullText)?'text-truncate':'')}}" style="white-space:pre-wrap;font-size:24rpx;">{{item.content}}</text></view><block a:if="{{item.content&&item.content.length>100&&!item.showFullText}}"><view data-event-opts="{{[['tap',[['toggleFullText',[index]]]]]}}" class="view-more" onTap="__e">查看全文</view></block><block a:if="{{item.pics}}"><view class="f2"><view class="pic-box" a:for="{{item.pics}}" a:for-item="pic" a:for-index="idx" a:key="idx"><image src="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImageReset',['$0',idx],[[['datalist','id',item.id,'pics']]]]]]]}}" onTap="__e"></image></view></view></block></view></view><view class="bot flex-bt"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savepics',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/material/download.png'}}"></image></view><view class="f4" data-index="{{index}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/material/copy.png'}}"></image></view><view class="f4" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['collect',['$event']]]]]}}" catchTap="__e"><block a:if="{{item.is_collected==1}}"><image src="{{pre_url+'/static/img/material/collect_active.png'}}"></image></block><block a:else><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></block></view></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="2b88f281-1" text="————End————" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="2b88f281-2" text="暂无相关素材" onVueInit="__l"></nodata></block></view></view><block a:if="{{loading}}"><loading vue-id="2b88f281-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="2b88f281-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="2b88f281-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block></block>