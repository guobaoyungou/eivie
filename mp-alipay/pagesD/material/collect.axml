<block a:if="{{isload}}"><block><view class="container"><dd-tab vue-id="43788d2e-1" itemdata="{{['图片','图文']}}" itemst="{{['1','4']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="item-list"><block a:if="{{st==1}}"><view class="material-columns"><view class="material-item" data-url="{{'details?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="material-pic"><image class="image" src="{{item.url}}" mode="widthFix"></image></view><view class="material-name">{{item.name}}</view></view></view></block><block a:if="{{st==4}}"><view class="imagetext"><view class="imagetext-item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view style="padding:20rpx;"><view class="top flex-bt"><view class="head flex"><image class="f1" src="{{item.set_logo}}"></image><view class="f2"><view class="t1">{{item.set_name}}</view><view class="t2">{{item.createtime}}</view></view></view></view><view class="con"><view class="f1"><text class="{{((!item.showFullText)?'text-truncate':'')}}" style="white-space:pre-wrap;font-size:24rpx;">{{item.content}}</text></view><block a:if="{{item.content&&item.content.length>100&&!item.showFullText}}"><view data-event-opts="{{[['tap',[['toggleFullText',[index]]]]]}}" class="view-more" onTap="__e">查看全文</view></block><block a:if="{{item.pics}}"><view class="f2"><view class="pic-box" a:for="{{item.pics}}" a:for-item="pic" a:for-index="idx" a:key="idx"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block></view></view><view class="bot flex-bt"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savepics',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/material/download.png'}}"></image></view><view class="f4" data-index="{{index}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/material/copy.png'}}"></image></view><view class="f4" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['collect',['$event']]]]]}}" catchTap="__e"><block a:if="{{item.is_collected==1}}"><image src="{{pre_url+'/static/img/material/collect_active.png'}}"></image></block><block a:else><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></block></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="43788d2e-2" text="————End————" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="43788d2e-3" text="暂无收藏内容" onVueInit="__l"></nodata></block></view></block></block>