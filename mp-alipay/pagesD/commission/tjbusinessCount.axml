<view class="container"><block a:if="{{isload}}"><block><view class="topfix"><view class="tongji flex-y-center " style="{{'background:'+(color1?color1:$root.m0)+';'}}"><view class="stat-item" data-url="/pagesExt/commission/tjbusinessList" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="price">{{count.count}}</view><view>商家数量</view></view><view class="stat-item"><view class="price">{{count.order_price_total}}</view><view>营业额</view></view><view class="stat-item mb0"><view class="price">{{count.commission_today}}</view><view>今日收益</view></view><view class="stat-item mb0"><view class="price">{{count.commission_total}}</view><view>累计收益</view></view></view><dd-tab vue-id="832a9114-1" itemdata="{{['待结算','已结算']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="margin-top:340rpx;"></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><block a:if="{{st==1}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text>{{item.$orig.ordernum}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.$orig.name+" ×"+item.$orig.num}}</text><text class="x2" style="{{'font-size:28rpx;'+('color:'+($root.m1)+';')}}">{{"￥"+item.$orig.real_totalprice}}</text><text class="x2">{{item.m2}}</text><view class="x3"><image src="{{item.$orig.b_logo}}"></image>{{item.$orig.b_name}}</view></view><view class="t2"><block a:if="{{item.$orig.status==1||item.$orig.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.$orig.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.$orig.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block a:if="{{item.$orig.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block></block><block a:if="{{st==2}}"><block><view class="item" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text>{{item.$orig.remark}}</text></view><view class="f2"><view class="t1">{{''+item.m3+''}}</view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text></view></view></view></block></block></view></block></block><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{nodata}}"><nodata vue-id="832a9114-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="832a9114-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="832a9114-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="832a9114-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="832a9114-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>