<view class="container"><block a:if="{{isload}}"><block><view class="topfix"><view class="head-total" style="background-color:#fd2936;color:#feef2f;"><view class="data-search flex-xy-center"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="header-back-but" onTap="__e"><image src="{{pre_url+'/static/img/hotel/fanhui.png'}}"></image></view><view data-event-opts="{{[['tap',[['changeDateType',['today']]]]]}}" class="{{(('data-btn')+' '+((datetype==='today')?'selected':''))}}" onTap="__e">今日</view><view data-event-opts="{{[['tap',[['changeDateType',['week']]]]]}}" class="{{(('data-btn')+' '+((datetype==='week')?'selected':''))}}" onTap="__e">近7天</view><view data-event-opts="{{[['tap',[['changeDateType',['month']]]]]}}" class="{{(('data-btn')+' '+((datetype==='month')?'selected':''))}}" onTap="__e">本月</view><block a:if="{{opttype&&opttype=='member_business_area'}}"><view data-event-opts="{{[['tap',[['changeDateType',['year']]]]]}}" class="{{(('data-btn')+' '+((datetype==='year')?'selected':''))}}" onTap="__e">本年</view></block><block a:else><view data-event-opts="{{[['tap',[['changeDateType',['all']]]]]}}" class="{{(('data-btn')+' '+((datetype==='all')?'selected':''))}}" onTap="__e">累计</view></block></view><view class="area-box"><text>{{areaname}}</text></view><view class="tongji flex-y-center"><view class="stat-item"><view>商家数量</view><view class="price">{{count.business_count}}</view></view><view class="divider"></view><view class="stat-item mb0"><view>区域业绩</view><view class="price">{{count.commission_count}}</view></view><view class="divider"></view><view class="stat-item"><view>订单数量</view><view class="price">{{count.order_count}}</view></view></view><view class="pv-box"><view class="pv">{{count.rangli_count}}</view><view class="pv-title" style="{{'background:'+('url('+pre_url+'/static/img/countbj.png) no-repeat')+';'+('background-size:'+('70%')+';')+('background-position:'+('center')+';')+('filter:'+('brightness(1000%) saturate(0%)')+';')}}">业绩统计(PV)</view></view><view style="height:40rpx;"></view></view><dd-tab vue-id="0e3be436-1" itemdata="{{['累计让利优先','让利比例优先']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view class="ind_business"><block a:if="{{st==1}}"><block><view data-url="{{'/pagesExt/business/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="ind_busbox"><view class="flex1 flex-row"><view style="width:42%;"><view class="ind_buspic flex0"><image src="{{item.logo}}"></image></view></view><view class="flex1"><view style="display:flex;justify-content:space-between;align-items:center;"><view class="bus_title">{{item.name}}</view></view><view class="bus_score"><view style="display:flex;align-items:center;"><image class="img" src="{{pre_url+'/static/img/star'+(item.comment_score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2"></image><view class="txt">{{item.comment_score+"分"}}</view></view></view><block a:if="{{item.address}}"><view class="bus_address" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.name}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image><text class="x1">{{item.address}}</text><text class="x2">{{item.juli}}</text></view></block><block a:if="{{item.nickname&&item.pid}}"><view class="bus_address"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="x1" style="overflow:unset;">{{"推荐人："+item.nickname}}</text><text class="x1" style="margin-left:20rpx;">{{"ID："+item.pid}}</text></view></block></view></view><view class="flex"><view class="activecoin flex rl-ratio"><text class="rl-title">让利比例</text><text class="rl-number">{{item.newscore_ratio+"%"}}</text></view><view class="activecoin flex rl-total"><text class="rl-title">累计让利</text><text class="rl-number">{{item.newscore_total}}</text></view></view></view></view></block></block><block a:if="{{st==2}}"><block><view data-url="{{'/pagesExt/business/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="ind_busbox"><view class="flex1 flex-row"><view style="width:42%;"><view class="ind_buspic flex0"><image src="{{item.logo}}"></image></view></view><view class="flex1"><view style="display:flex;justify-content:space-between;align-items:center;"><view class="bus_title">{{item.name}}</view></view><view class="bus_score"><view style="display:flex;align-items:center;"><image class="img" src="{{pre_url+'/static/img/star'+(item.comment_score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2"></image><view class="txt">{{item.comment_score+"分"}}</view></view></view><block a:if="{{item.address}}"><view class="bus_address" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.name}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image><text class="x1">{{item.address}}</text></view></block><block a:if="{{item.nickname&&item.pid}}"><view class="bus_address"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="x1" style="overflow:unset;">{{"推荐人："+item.nickname}}</text><text class="x1" style="margin-left:20rpx;">{{"ID："+item.pid}}</text></view></block></view></view><view class="flex"><view class="activecoin flex rl-ratio"><text class="rl-title">让利比例</text><text class="rl-number">{{item.newscore_ratio+"%"}}</text></view><view class="activecoin flex rl-total"><text class="rl-title">累计让利</text><text class="rl-number">{{item.newscore_total}}</text></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="0e3be436-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="0e3be436-3" onVueInit="__l"></nomore></block></view></block></block><block a:if="{{loading}}"><loading vue-id="0e3be436-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="0e3be436-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0e3be436-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>