<view class="container"><block a:if="{{isload}}"><block><view style="{{'padding:20rpx;color:#fff;'+('background-color:'+$root.m0)}}"><view style="font-size:30rpx;">我的信息</view><view style="margin:20rpx 0;display:flex;align-items:center;"><view style="width:80rpx;height:80rpx;overflow:hidden;border-radius:6rpx;background-color:#f1f1f1;"><image style="width:100%;height:100%;" src="{{userinfo.headimg}}"></image></view><view style="margin-left:10rpx;"><view>{{''+userinfo.nickname}}</view><view class="head-item2"><view class="head-item2-level" style="{{('background-color:'+$root.m1)}}">{{userinfo.levelname}}</view><view class="head-item2-id">{{"ID："+userinfo.id}}</view></view></view></view><view class="teamcount"><view style="width:50%;"><view style="font-size:30rpx;">{{userinfo.childnum}}</view><view>直属用户（人）</view></view><view style="width:50%;"><view style="font-size:30rpx;">{{userinfo.childnum2}}</view><view>总用户（人）</view></view></view></view><view style="padding:20rpx 0;background-color:#fff;"><view class="teamcount"><view style="width:50%;"><view style="font-size:30rpx;font-weight:bold;">{{"￥"+userinfo.childOrderpirce}}</view></view><view style="width:50%;"><view style="font-size:30rpx;font-weight:bold;">{{"￥"+userinfo.childOrderpirce2}}</view></view></view><view class="teamcount" style="color:#A4A4A4;"><view style="width:50%;"><view>直属团队订单额</view></view><view>|</view><view style="width:50%;"><view>总团队订单额</view></view></view></view><view class="today"><view class="today-content"><view style="display:flex;align-items:center;"><view style="{{'width:20rpx;height:20rpx;border-radius:50% 50%;'+('border:4rpx solid '+$root.m2)}}"></view><view style="margin-left:10rpx;font-weight:bold;font-size:30rpx;">今日收益</view><view style="{{'margin-left:10rpx;'+('color:'+$root.m3)}}">{{'￥'+userinfo.todayCommission}}</view></view><view style="display:flex;align-items:center;color:#A4A4A4;font-size:26rpx;" data-url="/adminExt/commission/myIncome" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>查看最近收益</text><image style="width:30rpx;height:30rpx;margin-left:10rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view><view style="padding:20rpx 0rpx;background-color:#fff;margin-top:20rpx;"><view style="width:750rpx;margin:20rpx auto;padding:0 20rpx;"><view style="display:flex;align-items:center;"><view style="{{'width:4rpx;height:28rpx;'+('background-color:'+$root.m4)}}"></view><view style="margin-left:10rpx;font-weight:bold;font-size:30rpx;">我的粉丝</view></view><view style="margin:20rpx 0;display:flex;justify-content:space-between;align-items:center;"><view class="myteam-search"><input style="height:40rpx;line-height:40rpx;width:180rpx;" placeholder="请输入名称" placeholder-style="color:#999;height: 40rpx;line-height: 40rpx;font-size:26rpx" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['inputTeamname',['$event']]]]]}}" onConfirm="__e" onInput="__e"/><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/search_ico.png'}}"></image></view><view class="myteam-search"><input style="height:40rpx;line-height:40rpx;width:180rpx;" placeholder="请输入下级ID" placeholder-style="color:#999;height: 40rpx;line-height: 40rpx;font-size:26rpx" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['inputTeamid',['$event']]]]]}}" onConfirm="__e" onInput="__e"/><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/search_ico.png'}}"></image></view><view data-event-opts="{{[['tap',[['chooseLevel',['$event']]]]]}}" style="{{'width:26%;text-align:center;line-height:60rpx;color:#fff;border-radius:6rpx;'+('background-color:'+$root.m5)}}" onTap="__e">等级筛选<text class="iconfont iconshaixuan" style="font-size:26rpx;margin-left:5rpx;"></text></view></view><view style="color:#A4A4A4;">{{"等级筛选："+(checkLevelname||'全部')}}</view></view></view><view style="width:730rpx;margin:0rpx auto;border-radius:6rpx;"><view style="background-color:#fff;padding:20rpx 0;margin-top:20rpx;" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view style="margin:20rpx 0;display:flex;padding:0 20rpx;" data-url="{{'teamManageDetail?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view><view style="width:130rpx;height:130rpx;overflow:hidden;border-radius:6rpx;background-color:#f1f1f1;"><image style="width:100%;height:100%;" src="{{item.headimg}}"></image></view><view style="{{'line-height:40rpx;font-size:26rpx;text-align:center;'+('color:'+$root.m6)}}">{{"(ID:"+item.id+")"}}</view></view><view style="margin-left:16rpx;"><view>{{''+item.nickname}}</view><view class="head-item2"><view class="head-item2-level" style="{{('background-color:'+$root.m7)}}">{{item.levelname}}</view></view><view style="font-size:26rpx;margin-top:6rpx;color:#797979;">{{"加入时间： "+item.createtime}}</view><block a:if="{{item.tel}}"><view style="font-size:26rpx;margin-top:6rpx;" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchTap="__e"><text style="color:#797979;">电话：</text><text style="color:#1E9FFF;">{{item.tel}}</text></view></block></view></view></view><block a:if="{{nodata}}"><nodata vue-id="f7ebe712-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="f7ebe712-2" onVueInit="__l"></nomore></block></view></block></block><block a:if="{{levelDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择级别</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><scroll-view style="max-height:100%;height:auto;" scroll-y="{{true}}"><view class="pstime-item" data-id="0" data-name="全部" data-event-opts="{{[['tap',[['levelRadioChange',['$event']]]]]}}" onTap="__e"><view class="flex1">全部</view><view class="radio" style="{{(checkLevelid==0?'background-color:red ;border-color:red':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><view class="pstime-item" data-id="{{item.id}}" data-name="{{item.name}}" data-event-opts="{{[['tap',[['levelRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{allLevel}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.name}}</view><view class="radio" style="{{(checkLevelid==item.id?'background-color:red;border-color:red ;':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></scroll-view></view></view></view></block><block a:if="{{loading}}"><loading vue-id="f7ebe712-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="f7ebe712-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f7ebe712-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>