<view><block a:if="{{isload}}"><block><view class="swiper-container"><swiper class="swiper" style="{{'height:'+(swiperHeight+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><view class="swiper-item-view" style="{{'height:'+(swiperHeight+'px')+';'}}"><image class="img" src="{{item}}" mode="widthFix" data-event-opts="{{[['load',[['loadImg',['$event']]]]]}}" onLoad="__e"></image></view></swiper-item></block></swiper><view class="imageCount">{{current+1+"/"+product.pics.length}}</view></view><view class="header"><view class="price_share"><view class="price"><view class="f1" style="{{'color:'+($root.m0)+';'}}">{{product.score_price+$root.m1}}<block a:if="{{product.money_price*1>0}}"><text>{{"+"+product.money_price+"元"}}</text></block></view><view class="f2">{{"￥"+product.sell_price+''}}</view></view><block a:if="{{product.show_lvprice==1}}"><view class="price2"><view class="{{(item.is_select==1?'f1':'f2')}}" a:for="{{product.new_lvprice_data}}" a:for-item="item" a:for-index="index">{{''+item.name+"价:"+item.score+$root.m2}}<block a:if="{{item.money*1>0}}"><text>{{"+"+item.money+"元"}}</text></block></view></view></block><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" onTap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><view class="title">{{product.name}}</view><view class="sales_stock"><view class="f1">{{"已兑换"+product.sales+"件"}}</view><view class="f2">{{"库存："+product.stock}}</view></view><block a:if="{{shopset.showcommission==1&&(product.commission>0||product.commission_score>0)}}"><view class="commission" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}">{{'分享好友购买预计可得'+$root.m5+'：'}}<block a:if="{{product.commission>0}}"><block><text style="font-weight:bold;padding:0 2px;">{{product.commission}}</text>{{product.commission_desc}}</block></block><block a:if="{{product.commission>0&&product.commission_score>0}}"><text>+</text></block><block a:if="{{product.commission_score>0}}"><block><text style="font-weight:bold;padding:0 2px;">{{product.commission_score}}</text>{{product.commission_score_desc}}</block></block></view></block></view><block a:if="{{product.givescore}}"><view class="cuxiaodiv"><view class="cuxiaopoint"><view class="f0">{{"送"+$root.m6}}</view><view class="f1" style="font-size:26rpx;">{{"购买可得"+$root.m7+product.givescore+"个"}}</view></view></view></block><block a:if="{{shopset.showjd==1}}"><view class="shop"><image class="p1" src="{{business.logo}}"></image><view class="p2 flex1"><view class="t1">{{business.name}}</view><view class="t2">{{business.desc}}</view></view><button class="p4" style="{{'background:'+('linear-gradient(90deg,'+$root.m8+' 0%,rgba('+$root.m9+',0.8) 100%)')+';'}}" data-url="{{product.bid==0?'/pages/index/index':'/pagesExt/business/index?id='+product.bid}}" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">进入店铺</button></view></block><block a:if="{{showNearbyMendian&&mendianids.length>0&&latitude&&longitude}}"><view class="nearby-mendian-box"><view class="nearby-mendian-title"><view class="t1">{{"附近"+$root.m10}}<block a:if="{{mendianids.length>1}}"><text>{{"（"+mendianids.length+"家）"}}</text></block></view><view class="t2" data-url="{{'/pagesExt/business/mendian?type=scoreshop&bid='+product.bid+'&proid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{(mendianids.length>1?'全部':'查看')+$root.m11}}</text><image src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="nearby-mendian-info"><view class="b1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{mendian.pic}}"></image></view><view class="b2"><view class="t1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{mendian.name}}</view><view class="t2 flex-y-center"><block a:if="{{mendian.distance}}"><block><view class="nearby-tag" style="{{'background:'+('rgba('+$root.m12+',0.1)')+';'+('color:'+($root.m13)+';')}}">最近</view><view class="mendian-distance">{{mendian.distance+''}}</view></block></block><view class="mendian-address">{{mendian.address?mendian.address:mendian.area}}</view></view></view><view class="b3"><view data-tel="{{mendian.tel}}" data-event-opts="{{[['tap',[['callMendian',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/location/tel.png'}}"></image></view></view></view></view></block><block a:if="{{showNearbyMendian&&(longitude==''||latitude=='')}}"><view class="cuxiaodiv"><view class="cuxiaopoint"><view class="f0">定位服务未授权，授权后查看附近门店</view><button data-event-opts="{{[['tap',[['toLocation',['$event']]]]]}}" class="shouquan" style="{{'background:'+('linear-gradient(90deg,'+$root.m14+' 0%,rgba('+$root.m15+',0.8) 100%)')+';'}}" onTap="__e">授权</button></view></view></block><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">商品描述</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><dp vue-id="171fe5c5-1" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view><view style="width:100%;height:140rpx;"></view><block a:if="{{product.status==1}}"><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="f1"><block a:if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block a:else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block><view class="item flex1" data-url="cart" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/gwc.png'}}"></image><view class="t1">购物车</view><block a:if="{{cartnum>0}}"><view class="cartnum">{{cartnum}}</view></block></view><view data-event-opts="{{[['tap',[['addfavorite',['$event']]]]]}}" class="item" onTap="__e"><image class="img" src="{{pre_url+'/static/img/shoucang.png'}}"></image><view class="t1">{{isfavorite?'已收藏':'收藏'}}</view></view></view><view class="op"><view class="tocart flex-x-center flex-y-center" style="{{'background:'+($root.m16)+';'}}" data-btntype="1" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">加入购物车</view><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m17)+';'}}" data-btntype="2" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" onTap="__e">立即兑换</view></view></view></block><scrolltop vue-id="171fe5c5-2" isshow="{{scrolltopshow}}" onVueInit="__l"></scrolltop><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m18=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m19=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block a:else><block a:if="{{$root.m20!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{buydialogShow}}"><view><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-mask" onTap="__e"></view><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title flex"><image class="img" src="{{nowguige.pic||product.pic}}" data-url="{{nowguige.pic||product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="flex1"><view class="price" style="{{'color:'+($root.m21)+';'}}">{{''+nowguige.score_price+$root.m22}}<block a:if="{{nowguige.money_price*1>0}}"><text>{{"+"+nowguige.money_price+"元"}}</text></block><block a:if="{{nowguige.market_price>0}}"><text class="t2">{{"￥"+nowguige.market_price}}</text></block></view><view class="stock">{{"库存："+nowguige.stock}}</view><block a:if="{{product.guigeset==1}}"><view class="choosename">{{"已选规格: "+nowguige.name}}</view></block></view></view><block a:if="{{product.guigeset==1}}"><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col" a:for="{{guigedata}}" a:for-item="item" a:for-index="index" a:key="index"><view class="name">{{item.title}}</view><view class="item flex flex-y-center"><block a:for="{{item.items}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="{{('item2 '+(ggselected[item.k]==item2.k?'on':''))}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" onTap="__e">{{item2.title}}</view></block></view></view></view></block><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><view class="op"><block a:if="{{nowguige.stock<=0}}"><block><button class="nostock">库存不足</button></block></block><block a:else><block><block a:if="{{btntype==0&&canaddcart}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m23)+';'}}" onTap="__e">加入购物车</button></block><block a:if="{{btntype==0}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m24)+';'}}" onTap="__e">立即购买</button></block><block a:if="{{btntype==1}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m25)+';'}}" onTap="__e">确 定</button></block><block a:if="{{btntype==2}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m26)+';'}}" onTap="__e">确 定</button></block></block></block></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="171fe5c5-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="171fe5c5-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="171fe5c5-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>