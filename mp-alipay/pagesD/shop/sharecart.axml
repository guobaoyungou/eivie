<view class="container"><block a:if="{{isload}}"><block><block a:if="{{cartlist.length>0}}"><block><view class="cartmain"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="bid"><view class="item"><view class="btitle"><view class="flex flex-xy-center click-radio" data-index="{{index}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="radio" style="{{(item.$orig.checked?'background:'+item.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><view class="btitle-name" data-url="{{item.$orig.bid==0?indexurl:'/pagesExt/business/index?id='+item.$orig.business.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{''+item.$orig.business.name}}</view><view class="flex1"></view></view><view class="content" data-url="{{'/pages/shop/product?id='+item2.$orig.product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{item.l0}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="flex flex-xy-center click-radio" data-index="{{index}}" data-index2="{{index2}}" data-event-opts="{{[['tap',[['changeradio2',['$event']]]]]}}" catchTap="__e"><view class="radio" style="{{(item2.$orig.checked?'background:'+item2.m1+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><view class="proinfo" style="{{(item.$orig.prolist.length==index2+1?'border:0':'')}}"><image class="img" src="{{item2.$orig.guige.pic?item2.$orig.guige.pic:item2.$orig.product.pic}}"></image><view class="detail"><view class="title"><text>{{item2.$orig.product.name}}</text></view><view class="desc"><text>{{item2.$orig.guige.name}}</text></view><view class="price" style="{{'color:'+(item.m2)+';'}}"><view><text style="font-size:24rpx;">￥</text>{{item2.$orig.guige.sell_price+" × "+item2.$orig.num}}</view></view></view></view></view></view></block></view></block></block></block></block><block a:if="{{loading}}"><loading vue-id="33a61a45-1" onVueInit="__l"></loading></block><block a:if="{{cartlist.length>0}}"><block><view style="height:auto;position:relative;"><view style="width:100%;height:110rpx;"></view><view class="{{((('footer')+' '+'flex')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="radio" style="{{(allchecked?'background:'+$root.m3+';border:0':'')}}" catchTap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="text0" catchTap="__e">{{"全选（"+selectedcount+"）"}}</view><view class="flex1"></view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" onTap="__e">分享</view></view></view></block></block><block a:if="{{sharevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m6!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></view></view></view></view></block><dp-tabbar vue-id="33a61a45-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="33a61a45-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="33a61a45-4" onVueInit="__l"></wxxieyi></view>