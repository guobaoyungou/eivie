<view><view class="banner-view" style="{{'background-image:'+('url('+pre_url+'/static/img/watherbg.png)')+';'+('background-color:'+('#89c3f6')+';')}}"></view><view class="position-view"><view class="top-position-view flex flex-bt"><view class="flex flex-y-center"><view class="add-icon"><image src="{{pre_url+'/static/img/water/address_icon.png'}}"></image></view><view class="address-text">{{locationCache.street?locationCache.street:'定位中'}}</view><view class="xiala-icon flex flex-xy-center"><image src="{{pre_url+'/static/img/water/jiantou_xiala.png'}}"></image></view></view></view><view class="pos-options-view list-view"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-options-view flex flex-y-center flex-bt"><view class="flex-col left-view"><view class="title-text flex flex-y-center">{{(item.location?item.location:'净水机')+''}}<block a:if="{{index==0&&item.juli}}"><view class="juli-tisp">距离最近</view></block></view><view class="tisp-text">{{item.location?item.location:'净水机'}}</view></view><block a:if="{{item.juli}}"><view class="right-icon flex-col flex-xy-center"><image class="dizhi-icon" src="{{pre_url+'/static/img/water/dizhi.png'}}"></image><view class="dizhi-text">{{item.juli?item.juli:''}}</view></view></block></view></block></view></view><block a:if="{{nodata}}"><nodata vue-id="31758443-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="31758443-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="31758443-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="31758443-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="31758443-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="31758443-6" onVueInit="__l"></wxxieyi></view>