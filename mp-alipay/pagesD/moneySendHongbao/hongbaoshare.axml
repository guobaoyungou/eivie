<view><block a:if="{{isload}}"><block><view class="page-content"><view class="bg-view flex-col"><view class="icon-image"><image src="{{pre_url+'/static/img/redenvelope/duihao.png'}}"></image></view><view class="title-text">红包已包好</view><view class="tips-text">快把红包分享给好友吧</view></view><view class="poster-view flex-col"><image class="img-bg-view" style="width:87%;margin:0 auto;" src="{{posterpic}}" mode="widthFix"></image><view class="but-view flex-bt"><view data-event-opts="{{[['tap',[['savpic2',['$event']]]]]}}" class="but-class class-type1" onTap="__e">保存图片</view><block a:if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="but-class class-type2" onTap="__e">分享红包</view></block><block a:else><block a:if="{{$root.m1=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="but-class class-type2" onTap="__e">分享红包</view></block><block a:else><block a:if="{{$root.m2!='h5'}}"><button class="but-share class-type2" open-type="share">分享红包</button></block></block></block></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="9e1fe972-1" onVueInit="__l"></loading></block><uni-popup vue-id="9e1fe972-2" ref="__r" data-ref="envelopePopup" onVueInit="__l"><view class="envelopePopup-content"><view class="{{((openShow?'top-view-active':'')+' '+'top-view')}}"><image src="{{data.pic}}"></image></view><view class="{{((openShow?'bottom-view-active':'')+' '+'bottom-view')}}"><image src="{{pre_url+'/static/img/redenvelope/hb_bottom.png'}}"></image></view><block a:if="{{!openShow}}"><view data-event-opts="{{[['tap',[['openEnvelope',['$event']]]]]}}" class="jinbi-view" onTap="__e"><image src="{{pre_url+'/static/img/redenvelope/jinbi.png'}}"></image></view></block></view></uni-popup></view>