<view><block a:if="{{isload}}"><block><view class="tab-view flex flex-bt"><view data-event-opts="{{[['tap',[['tabChange',[0]]]]]}}" class="{{((tabIndex==0?'options-tab-active':'')+' '+'options-tab')}}" onTap="__e">我收到的</view><view data-event-opts="{{[['tap',[['tabChange',[1]]]]]}}" class="{{((tabIndex==1?'options-tab-active':'')+' '+'options-tab')}}" onTap="__e">我发出的</view></view><view class="statistics-view flex-col"><view class="tj-title flex-y-center">{{tabIndex==0?'收到':'发出'}}<text style="color:#f74a32;padding:0rpx 5rpx;">{{count}}</text>个红包，共</view><view class="tj-price flex-y-bottom">{{totalmoney}}<text style="font-size:28rpx;color:#666666;padding:0rpx 10rpx;margin-bottom:15rpx;">元</text></view></view><view class="flex-col"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{tabIndex==0}}"><block><view class="options-log flex-y-center flex-bt"><view class="left-view flex flex-y-center"><image class="left-icon" style="border-radius:50%;" src="{{item.headimg}}"></image><view class="info-view flex-col"><view class="info-title">{{item.type_text}}</view><view class="info-content">来自<text style="color:#333;margin-right:10rpx;">{{item.nickname}}</text>{{''+item.showtime}}</view></view></view><view class="right-view flex-col"><view class="price-view">{{item.money+" 元"}}</view><view class="price-status">已领取</view></view></view></block></block></block><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{tabIndex==1}}"><block><view class="options-log flex-y-center flex-bt" data-url="{{'hongbaoshare?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="left-view flex flex-y-center"><image class="left-icon" src="{{pre_url+'/static/img/redenvelope/red_pin.png'}}"></image><view class="info-view flex-col"><view class="info-title">{{item.type_text}}</view><view class="info-content">包<text style="color:#333;margin-right:10rpx;">{{item.num+"个红包"}}</text>{{''+item.showtime}}</view><view class="info-content">{{item.expire_time+''}}<text style="color:#333;margin-right:10rpx;">过期</text></view></view></view><view class="right-view flex-col"><view class="price-view">{{item.money+" 元"}}</view><view class="price-status"><block a:if="{{item.status==0}}"><text>进行中</text></block><block a:if="{{item.status==1}}"><text>已完成</text></block><block a:if="{{item.status==2}}"><text>已撤回</text></block></view><block a:if="{{item.status==0}}"><view class="price-status" style="color:#f74a32;" data-id="{{item.id}}" data-event-opts="{{[['tap',[['cancelHongbao',['$event']]]]]}}" catchTap="__e">撤回</view></block></view></view></block></block></block></view></block></block><block a:if="{{nodata}}"><nodata vue-id="237670fc-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="237670fc-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="237670fc-3" onVueInit="__l"></loading></block></view>