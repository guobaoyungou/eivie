<view class="container"><block a:if="{{isload}}"><block><view class="banner-container"><image class="bg-image" src="{{set.banner}}" mode="widthFix"></image><block a:if="{{set.btpic}}"><image class="front-image" src="{{set.btpic}}" mode="widthFix"></image></block></view><view class="main-wrapper"><block a:if="{{set.drawing_type==0}}"><view class="content-box" style="{{('background-color: '+set.bgcolor)}}"><view class="countdown-section" style="{{('background-color: rgba('+set.theme_color_rgb+',0.3)')}}"><text class="countdown-label">距离开奖还有</text><text class="countdown-time" style="{{('color: '+set.theme_color)}}">{{countdownText}}</text></view></view></block><dd-tab vue-id="0833c5ec-1" itemdata="{{['待开奖','已开奖','往期中奖']}}" itemst="{{['0','1','2']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="order-container" style="{{('background-color: '+set.bgcolor)}}"><block a:if="{{datalist.length>0}}"><view class="order-list"><view class="{{(('order-item')+' '+((st=='1')?'award-item':''))}}" data-url="{{'details?id='+order.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="order" a:for-index="index" a:key="index"><block a:if="{{st==0||st==1}}"><block><view class="order-info"><block a:if="{{st=='1'}}"><view class="field"><text class="label">抽奖结果：</text><text class="{{((order.status==2)?'red':'')}}">{{order.award_name}}</text></view></block><view class="field"><text class="label">订单号：</text><text>{{order.ordernum}}</text></view><view class="field"><text class="label">参与时间：</text><text>{{order.createtime}}</text></view><view class="field"><text class="label">抽奖码：</text><text>{{order.code}}</text></view><block a:if="{{order.award_type>0}}"><view class="field"><text class="label">状态：</text><block a:if="{{order.status==2}}"><text>未领取</text></block><block a:if="{{order.status==3}}"><text>已领取</text></block></view></block><block a:if="{{order.award_type==3}}"><view class="field" data-url="/pagesExt/coupon/mycoupon" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text style="color:#949494;">前往我的优惠券查看</text></view></block></view><block a:if="{{st=='1'&&order.status==2&&order.hexiaoqr}}"><view class="qrcode-icon"><image class="icon-img" src="{{order.hexiaoqr}}" data-url="{{order.hexiaoqr}}" mode="aspectFit" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block></block></block><block a:if="{{st==2}}"><block><view class="order-info" data-url="{{'winnerlist?id='+order.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="field"><text class="label">开奖时间：</text><text>{{order.createtime}}</text></view><view class="field"><text class="label">中奖金额：</text><text>{{"￥"+order.win_money}}</text></view></view></block></block></view></view></block><block a:if="{{nomore}}"><nomore vue-id="0833c5ec-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0833c5ec-3" text="{{st=='0'?'暂没有符合抽奖的订单':'暂无已开奖订单'}}" onVueInit="__l"></nodata></block></view></view><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" onTap="__e">活动规则</button><block a:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule" style="{{('background-color: '+set.theme_color)}}"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{set.guize}}</text></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="0833c5ec-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="0833c5ec-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0833c5ec-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="0833c5ec-7" onVueInit="__l"></wxxieyi></view>