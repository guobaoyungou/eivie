<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"中奖用户："+item.nickname}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"获得奖品："+item.award_name}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"参与时间："+item.createtime}}</view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="d4f2c0a2-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="d4f2c0a2-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="d4f2c0a2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d4f2c0a2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d4f2c0a2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>