<view class="container"><block a:if="{{isload}}"><block><view class="top-nav"><view class="{{(('nav-item')+' '+(st==2?'active':''))}}" data-status="2" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" onTap="__e"><text>全部</text></view><view class="{{(('nav-item')+' '+(st==1?'active':''))}}" data-status="1" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" onTap="__e"><text>已种植</text></view><view class="{{(('nav-item')+' '+(st==0?'active':''))}}" data-status="0" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" onTap="__e"><text>未种植</text></view></view><block><view class="farm-list"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><text class="num">{{item.sort+"号"}}</text><view class="media"><image class="icon" style="max-width:100rpx;" src="{{item.logo}}" mode="widthFix"></image><text class="label">{{item.name}}</text><text class="label" style="font-size:16rpx;">{{"(ID:"+item.id+")"}}</text></view><block a:if="{{item.tree_status==1}}"><block><view class="progress-bar"><image class="background" src="{{pre_url+'/static/img/farm/jdt_bg.png'}}" mode="widthFix"></image><view class="inner"><view class="clip-box" style="{{'width:'+(item.tree_progress+'%')+';'+('background-image:'+('url('+pre_url+'/static/img/farm/jdt.png)')+';')}}"></view></view></view><text class="progress">{{item.tree_progress+"%"}}</text></block></block><block a:if="{{item.tree_status!=1}}"><block><view class="progress-bar"></view></block></block><block a:if="{{item.tree_status==1}}"><text class="button" data-url="{{'/pagesD/farm/landdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">进入</text></block><block a:else><text class="button" data-id="{{item.id}}" data-event-opts="{{[['tap',[['addtree',['$event']]]]]}}" onTap="__e">种植</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="36edcdfb-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="36edcdfb-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="36edcdfb-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="36edcdfb-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="36edcdfb-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>