<view class="container"><block a:if="{{isload}}"><block><view class="exchange-list"><block a:for="{{fert_types}}" a:for-item="item" a:for-index="index" a:key="id"><block a:if="{{item.score>0}}"><view class="exchange-item"><view class="item-left"><image class="item-logo" src="{{item.logo}}" mode="aspectFill"></image><view class="item-info"><text class="item-name">{{item.name}}</text><text class="item-owned">{{"当前持有: "+(item.num||0)}}</text><text class="item-owned">{{"所需"+farm_textset['美宝']+": "+(item.score||0)}}</text></view></view><view class="item-right"><text class="exchange-btn" data-type="{{item.type}}" data-name="{{item.name}}" data-score="{{item.score}}" data-event-opts="{{[['tap',[['openExchangePopup',['$event']]]]]}}" onTap="__e">兑换</text><text class="exchange-btn" data-url="{{'/pagesD/farm/fertlog?st='+item.type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看明细</text></view></view></block></block></view><block a:if="{{nodata}}"><nodata vue-id="a7512344-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="a7512344-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="a7512344-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="a7512344-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="a7512344-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><uni-popup vue-id="a7512344-6" type="center" ref="__r" data-ref="exchangePopup" onVueInit="__l"><view class="exchange-popup"><view class="popup-title">{{"兑换"+selectedItem.name}}</view><view class="popup-content"><view class="score-info"><text class="info-label">单价:</text><text class="info-value">{{selectedItem.score+farm_textset['美宝']}}</text></view><view class="quantity-selector"><text class="selector-label">兑换数量:</text><view class="selector-control"><text data-event-opts="{{[['tap',[['decreaseQuantity',['$event']]]]]}}" class="control-btn" onTap="__e">-</text><input class="quantity-input" type="number" data-event-opts="{{[['input',[['__set_model',['','exchangeQuantity','$event',[]]]]]]}}" value="{{exchangeQuantity}}" onInput="__e"/><text data-event-opts="{{[['tap',[['increaseQuantity',['$event']]]]]}}" class="control-btn" onTap="__e">+</text></view></view><view class="total-score"><text class="total-label">总计:</text><text class="total-value">{{totalScore+farm_textset['美宝']}}</text></view></view><view class="popup-actions"><text data-event-opts="{{[['tap',[['closeExchangePopup',['$event']]]]]}}" class="action-btn cancel" onTap="__e">取消</text><text data-event-opts="{{[['tap',[['confirmExchange',['$event']]]]]}}" class="action-btn confirm" onTap="__e">确认兑换</text></view></view></uni-popup></view>