<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="132e92be-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">{{"我的"+fert_name}}</view><view class="value" style="margin-top:20rpx;">{{remain}}</view><block a:if="{{show_buy}}"><view class="btn" data-url="/pagesD/farm/buy" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">兑换</view></block></view></view><block a:if="{{show_ljnum==1}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">累计获得</view><view class="value" style="margin-top:20rpx;">{{ljnum}}</view></view></view></block></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后"+$root.m1+": "+item.after}}</text></view><view class="f2"><block a:if="{{item.num>0}}"><text class="t1">{{"+"+item.num}}</text></block><block a:else><text class="t2">{{item.num}}</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="132e92be-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="132e92be-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="132e92be-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="132e92be-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="132e92be-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>