<block a:if="{{isload}}"><view><view class="top-view flex-col"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>{{$root.m0}}</view><view class="points-num">{{info.score||0}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">{{textset['已释放']}}</view><view class="num-text">{{info.release_score||0}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">{{textset['累计补贴']}}</view><view class="num-text">{{info.send_all||0}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">{{textset['剩余数量']}}</view><view class="num-text">{{info.remain||0}}</view></view></view></view><view class="list-title-view">补贴日记</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="options-view flex-bt" data-url="{{item.$orig.batchlog_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="left-view flex-col"><view class="left-title">{{item.$orig.remark}}</view><view class="time-text">{{item.$orig.createtime}}</view></view><view class="price-view flex-col"><view class="money">{{''+item.$orig.money+''}}<block a:if="{{item.$orig.batchlog_url}}"><text class="iconfont iconjiantou" style="font-size:28rpx;"></text></block></view><block a:if="{{item.m1}}"><view class="pack_money">{{item.m2+"提速："+item.$orig.pack_money}}</view></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="193e5e03-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="193e5e03-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="193e5e03-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="193e5e03-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="193e5e03-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>