<block a:if="{{isload}}"><view><view class="top-view flex-col"><view class="points-view flex-col"><view class="points-title-view flex">总释放</view><view class="points-num">{{info.money||0}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">总账期</view><view class="num-text">{{info.batch_num||0}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">已释放账期</view><view class="num-text">{{info.batch_num_send||0}}</view></view></view></view><view class="list-title-view">账期明细</view><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="item"><view class="f1"><text class="t1">{{"账期金额："+item.money+"元"}}</text><text class="t2">{{item.remark}}</text><text class="t2">{{"预计发放时间："+item.send_time}}</text></view><view class="f3"><block a:if="{{item.status==0}}"><text class="t1">未发放</text></block><block a:if="{{item.status==1}}"><text class="t2">已发放</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="1b70dd94-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="1b70dd94-2" onVueInit="__l"></nomore></block></view><block a:if="{{loading}}"><loading vue-id="1b70dd94-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1b70dd94-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1b70dd94-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>