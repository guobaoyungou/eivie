<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="1b7baaf0-1" itemdata="{{['未使用','已使用','已过期']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="coupon-list"><view class="coupon" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="pt_left"><view class="pt_left-content"><view class="f1" style="{{'color:'+($root.m0)+';'}}"><text class="t1">{{item.$orig.pack_ratio+"%"}}</text></view><view class="f2" style="{{'color:'+($root.m1)+';'}}">{{''+$root.m2+'加速'}}</view></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.$orig.pack_name}}</view><text class="t2" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}">{{item.$orig.type_txt}}</text><block a:if="{{item.$orig.type!=20}}"><view class="t3" style="{{(item.$orig.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"有效期至 "+item.$orig.endtime}}</view></block><block a:if="{{item.$orig.bid>0}}"><view class="t4">{{"适用商家："+item.$orig.bname}}</view></block></view><view style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;width:140rpx;"><block a:if="{{item.$orig.status==1}}"><block><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m5+' 0%,rgba('+item.m6+',0.8) 100%)')+';'}}">加速中</button></block></block><block a:if="{{st==2}}"><image class="sygq" src="{{pre_url+'/static/img/ygq.png'}}"></image></block></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="1b7baaf0-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1b7baaf0-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="1b7baaf0-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="1b7baaf0-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="1b7baaf0-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>