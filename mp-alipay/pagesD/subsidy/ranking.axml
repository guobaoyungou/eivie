<block a:if="{{isload}}"><block><view class="container"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank_notext.png'}}" mode="widthFix"></image><view class="title"><view class="t1">每日收款排行榜</view><view class="t2">每日消费排行榜</view></view><view class="top"><view class="t1"><view class="label">我的排名</view><view class="value">{{my_ranking}}</view></view><view class="t2"><text style="color:#9e9e9e;">{{''+(ranktype==1?'累计收款':ranktype==2?'累计消费':'')+"："}}</text>{{my_order_price+''}}</view></view><view class="content"><block a:if="{{rank_type.length>1}}"><view class="tab1"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('t1 '+(item.$orig==ranktype?'on':''))}}" style="{{'color:'+(item.$orig==ranktype?item.m0:'')+';'}}" data-ranktype="{{item.$orig}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" onTap="__e">{{(item.$orig==1?'商家收款':item.$orig==2?'会员消费':'')+''}}<block a:if="{{item.$orig==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m1)}}"></view></block></view></block></view></block><view class="tab"><view class="t1">排名</view><view class="t2">{{ranktype==1?'商家':ranktype==2?'会员':''}}</view><view class="t3">{{ranktype==1?'商家收款':ranktype==2?'会员消费':''}}</view></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" style="{{(index<3?'margin-top:20rpx':'')}}"><block a:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block a:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3" style="{{'color:'+($root.m2)+';'}}">{{''+item.order_price}}</text></view></block></view></view></view><block a:if="{{nodata}}"><nodata vue-id="5b0a1eab-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="5b0a1eab-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="5b0a1eab-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5b0a1eab-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5b0a1eab-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block></block>