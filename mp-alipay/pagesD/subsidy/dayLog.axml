<block a:if="{{isload}}"><view><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>{{"我的"+$root.m1}}</view><view class="points-num">{{total.subsidy_score}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">累计释放</view><view class="num-text">{{total.commission||0}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{total.commission_today||0}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日新增</view><view class="num-text">{{total.today_add||0}}</view></view></view></view><dd-tab vue-id="82882682-1" itemdata="{{['日汇总',$root.m2+'明细','释放记录']}}" itemst="{{['0','1','2']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><block a:if="{{st==1||st==2}}"><view class="content"><view class="topsearch flex-y-center sx"><text class="t1">期数筛选：</text><view class="t2"><picker range="{{release_item}}" data-event-opts="{{[['change',[['chooseMonth',['$event']]]]]}}" onChange="__e"><block a:if="{{release_item[release_index]}}"><view class="uni-input">{{release_item[release_index]}}</view></block><block a:else><view style="font-size:28rpx;color:#686868;">请选择释放期数</view></block></picker></view></view></view></block><view class="content" id="datalist"><block a:if="{{st==0}}"><block><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-item"><view class="item-row"><view class="column"><text>{{"发放数量: "+item.score_total}}</text><text>{{"剩余数量: "+item.score}}</text></view><view class="column"><text>{{"释放数量: "+(item.have_release||0)}}</text><text>{{"释放期数: "+(item.release_num||0)}}</text></view></view><view class="item-row"><text class="time">{{item.createday}}</text><block></block></view></view></block></block></block><block a:if="{{st==1}}"><block><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block a:if="{{item.score>0}}"><text style="color:green;">{{"+"+item.score}}</text></block><block a:else><text style="color:red;">{{item.score}}</text></block></view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block></block></block><block a:if="{{st==2}}"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1" style="color:green;">{{"释放"+$root.m3+"：+"+item.member_score_bonus+"元"}}</text><text class="t1" style="color:red;">{{"本期"+$root.m4+"："+item.member_score}}</text></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block></block></view><block a:if="{{nodata}}"><nodata vue-id="82882682-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="82882682-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="82882682-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="82882682-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="82882682-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>