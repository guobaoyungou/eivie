<view><block a:if="{{isload}}"><block><view class="top-view" style="{{'background-image:'+('linear-gradient(rgba('+$root.m0+',0.2),#f6f6f6)')+';'}}"><view class="card-view flex-col flex-y-center" style="{{'background-image:'+('url('+pre_url+'/static/img/deposit/cardbg.png)')+';'+('background-color:'+('rgba('+$root.m1+',0.8)')+';')}}"><view class="title-view flex-y-center">{{"当前"+$root.m2+"余额（元）"}}<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}" data-event-opts="{{[['tap',[['showExplain',['$event']]]]]}}" onTap="__e"></image></view><view class="price-view">{{total_data.totalmoney}}</view><view class="but-view flex flex-y-center"><view class="but-class but1" style="{{'color:'+($root.m3)+';'}}" data-url="refund" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">退还</view><view class="but-class but2" style="{{'background:'+($root.m4)+';'}}" data-url="buy" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">购买</view></view></view></view><view class="tab-view flex flex-y-center"><view data-event-opts="{{[['tap',[['tabChange',[0]]]]]}}" class="{{((type==0?'tab-options-active':'')+' '+'tab-options')}}" onTap="__e">{{$root.m5}}<block a:if="{{type==0}}"><view class="tab-tag" style="{{'background:'+($root.m6)+';'}}"></view></block></view><view data-event-opts="{{[['tap',[['tabChange',[1]]]]]}}" class="{{((type==1?'tab-options-active':'')+' '+'tab-options')}}" onTap="__e">{{$root.m7+"记录"}}<block a:if="{{type==1}}"><view class="tab-tag" style="{{'background:'+($root.m8)+';'}}"></view></block></view></view><block a:if="{{type==0}}"><view class="content-view"><view class="content-list"><scroll-view style="max-height:65vh;height:auto;" scroll-y="{{true}}"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-options flex"><view class="img-view"><image src="{{item.$orig.pic}}"></image></view><view class="info-view flex-col"><view class="title-view">{{item.$orig.name}}</view><view class="price-fun-view flex flex-y-center flex-bt"><view class="flex flex-y-center flex-bt" style="line-height:46rpx;"><view class="price-text" style="{{'color:'+($root.m9)+';'}}">{{"￥"+item.$orig.money}}</view><view style="margin-left:20rpx;">{{"数量："+item.$orig.num}}</view></view><view class="fun-view flex flex-y-center"><block a:if="{{item.$orig.buynum>0}}"><view class="fun-class minus-class flex-xy-center" style="{{'color:'+(item.m10)+';'+('border-color:'+(item.m11)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['subnum',['$event']]]]]}}" onTap="__e">-</view></block><block a:if="{{item.$orig.buynum>0}}"><view class="input-view">{{item.$orig.buynum}}</view></block><block a:if="{{numkey==-1||numkey==index}}"><view class="fun-class add-class flex-xy-center" style="{{'background-color:'+(item.m12)+';'+('border-color:'+(item.m13)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['addnum',['$event']]]]]}}" onTap="__e">+</view></block></view></view></view></view></block></scroll-view><block a:if="{{nomore}}"><nomore vue-id="0b1ab5fc-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0b1ab5fc-2" onVueInit="__l"></nodata></block></view></view></block><block a:else><view class="list-view flex-col"><scroll-view style="max-height:65vh;height:auto;" scroll-y="{{true}}"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="list-options flex-col"><view class="title-name">{{item.name}}</view><view class="num-view">{{"数量 x"+item.num}}</view><view class="flex-y-center flex-bt"><view class="time-view">{{item.createtime}}</view><view class="price-view" style="{{'color:'+($root.m14)+';'}}"><block a:if="{{item.type==1}}"><text>-</text></block>{{"￥"+item.totalmoney}}</view></view></view></block></scroll-view><block a:if="{{nomore}}"><nomore vue-id="0b1ab5fc-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0b1ab5fc-4" onVueInit="__l"></nodata></block></view></block><uni-popup vue-id="0b1ab5fc-5" ref="__r" data-ref="refPopup" onVueInit="__l"><view class="popup-content flex flex-col" style="{{'background-image:'+('linear-gradient(rgba('+$root.m15+',0.2),#fff)')+';'}}"><view class="popup-img"><image src="{{pre_url+'/static/img/deposit/buy.png'}}"></image></view><view class="title-view">抱歉 押金不足！</view><view class="tips-view">请勾选需要XXXXXXXXXX</view><view class="popup-but" style="{{'background:'+($root.m16)+';'}}">确认</view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="0b1ab5fc-6" onVueInit="__l"></loading></block></view>