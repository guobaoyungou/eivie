<view><block a:if="{{isload}}"><block><view class="top-view flex" style="{{'background-image:'+('linear-gradient(to right , rgba('+$root.m0+',0.7),'+$root.m1+')')+';'}}"><view class="left-view flex-col"><view class="title-view">金额总计（元）</view><view class="price-view">{{totalprice}}</view></view><view class="right-view"><image src="{{pre_url+'/static/img/deposit/buy.png'}}"></image></view></view><view class="content-view"><view class="filter-view flex flex-bt"><view class="filter-title">{{$root.m2+"名称"}}</view></view><view class="content-list"><scroll-view style="max-height:65vh;height:auto;" scroll-y="{{true}}"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list-options flex" style="{{'border-color:'+($root.m3)+';'}}"><view class="img-view"><image src="{{item.$orig.pic}}"></image></view><view class="info-view flex-col"><view class="title-view">{{item.$orig.name}}</view><view class="bname">{{"适用商家："+item.$orig.bname}}</view><view class="price-fun-view flex flex-y-center flex-bt"><view class="price-text" style="{{'color:'+($root.m4)+';'}}">{{"￥"+item.$orig.money}}</view><view class="fun-view flex flex-y-center"><block a:if="{{item.$orig.buynum>0}}"><view class="fun-class minus-class flex-xy-center" style="{{'color:'+(item.m5)+';'+('border-color:'+(item.m6)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['subnum',['$event']]]]]}}" onTap="__e">-</view></block><block a:if="{{item.$orig.buynum>0}}"><view class="input-view">{{item.$orig.buynum}}</view></block><block a:if="{{numkey==-1||numkey==index}}"><view class="fun-class add-class flex-xy-center" style="{{'background-color:'+(item.m7)+';'+('border-color:'+(item.m8)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['addnum',['$event']]]]]}}" onTap="__e">+</view></block></view></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="51484970-1" onVueInit="__l"></nodata></block></scroll-view></view></view><view style="height:calc(140rpx + env(safe-area-inset-bottom));"></view><view class="buy-but-view"><view data-event-opts="{{[['tap',[['toBuy',['$event']]]]]}}" class="buy-but" style="{{'background-color:'+($root.m9)+';'}}" onTap="__e">确定购买</view></view></block></block><block a:if="{{loading}}"><loading vue-id="51484970-2" onVueInit="__l"></loading></block><block a:if="{{nodata}}"><nodata vue-id="51484970-3" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="51484970-4" onVueInit="__l"></nomore></block></view>