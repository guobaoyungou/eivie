<view class="container"><block a:if="{{isload}}"><block><view class="coupon-list"><view class="coupon" data-url="{{'coupondetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="pt_left"><view class="pt_left-content"><image src="{{item.pic}}" mode="widthFix"></image></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.name}}</view><view class="t4">{{'x '+item.limit_count}}</view><block a:if="{{item.price>0}}"><view class="t4 price"><text class="price_tag">￥</text>{{item.price}}</view></block></view><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-price="{{item.price}}" data-score="{{item.score}}" data-key="{{index}}" data-event-opts="{{[['tap',[['getcoupon',['$event']]]]]}}" catchTap="__e">{{item.price>0?'购买':item.score>0?'兑换':'领取'}}</button></view></view></view><block a:if="{{nodata}}"><nodata vue-id="81942c14-1" text="{{'暂无可领'+$root.m2}}" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="81942c14-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="81942c14-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="81942c14-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="81942c14-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>