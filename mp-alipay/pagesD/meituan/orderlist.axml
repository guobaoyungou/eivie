<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="ec15f43e-1" itemdata="{{['全部','待付款','待出票','已出票','退款/售后']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view class="f1"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.product.spot_name}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1}}"><text class="st0">待出票</text></block><block a:if="{{item.$orig.status==2}}"><text class="st1">已出票</text></block><block a:if="{{item.$orig.status==3}}"><text class="st1">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st1">已取消</text></block><block a:if="{{item.$orig.status==-1}}"><text class="st4">已关闭</text></block></view><view class="content"><view><image src="{{item.$orig.product.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.title}}</text><block a:if="{{item.$orig.book_date==2&&(item.$orig.sell_start_date||item.$orig.sell_end_date)}}"><text class="t2" style="color:#666;">{{item.$orig.sell_start_date+"~"+item.$orig.sell_end_date}}</text></block><text class="t3" style="color:#666;">{{"张数："+item.$orig.num}}</text><view class="t3">{{"价格：￥"+item.$orig.sell_price}}</view></view></view><view class="bottom" style="display:flex;justify-content:space-between;"><text>{{"实付:￥"+item.$orig.totalprice}}</text></view><block a:if="{{item.$orig.refund_status>0}}"><view class="bottom"><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">详情</view><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去付款</view></block></block><block a:if="{{item.$orig.status==1}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="ec15f43e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="ec15f43e-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="ec15f43e-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="ec15f43e-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="ec15f43e-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>