<view><block a:if="{{isload}}"><block><view class="dp-banner"><swiper class="dp-banner-swiper" autoplay="{{true}}" indicator-dots="{{false}}" current="{{0}}" circular="{{true}}" interval="{{3000}}"><block a:for="{{detail.pic}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item><view data-event-opts="{{[['tap',[['viewPicture',['$0'],['detail.pic']]]]]}}" onTap="__e"><image class="dp-banner-swiper-img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper></view><view class="position-view"><view data-event-opts="{{[['tap',[['selectDate',['$event']]]]]}}" class="content-view" onTap="__e"><view class="title-view">{{detail.spot_name}}</view><block a:if="{{detail.spot_tag}}"><view class="hotel-nature" style="padding:0;margin-top:5rpx;"><view class="hotspot-nature-text">{{detail.spot_tag}}</view></view></block><view class="hotel-nature"><block a:if="{{detail.spot_address}}"><view class="hotspot-nature-text"><view class="hotspot-value">{{detail.spot_address}}</view></view></block></view></view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{!$root.m0}}"><view class="hotel-select-time"><view data-event-opts="{{[['tap',[['selectDate',['$event']]]]]}}" class="time-view flex flex-y-center flex-bt" onTap="__e"><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{startDate}}</view><view class="day-tetx">{{startWeek+"入住"}}</view></view><view class="content-text"><view class="content-decorate left-c-d"></view>{{'共'+dayCount+'晚'}}<view class="content-decorate right-c-d"></view></view><view class="time-options flex flex-y-center flex-bt"><view class="month-tetx">{{endDate}}</view><view class="day-tetx">{{endWeek+"离店"}}</view></view></view></view></block><view class="hotels-list"><view class="hotels-list-title"><view class="title">{{item.m1}}</view></view><block a:for="{{item.$orig}}" a:for-item="val" a:for-index="key" a:key="key"><view class="hotels-options" data-id="{{val.id}}" data-index="{{index}}" data-key="{{key}}" data-event-opts="{{[['tap',[['openDetail',['$event']]]]]}}" catchTap="__e"><view class="hotel-img"><image src="{{val.pic}}" mode="widthFix"></image></view><view class="hotel-info"><view class="hotel-title">{{val.name}}</view><view class="hotel-but-view"><view class="make-info"><view class="hotel-price" style="{{'color:'+(item.m2)+';'}}"><view>￥</view><view class="hotel-price-num">{{val.sell_price}}</view></view></view><view class="hotel-make" style="{{('background:rgba('+item.m3+',0.8);color:#FFF')}}">预约</view></view></view></view></block></view></block></view><uni-popup vue-id="05e7dc04-1" id="popup" type="bottom" ref="__r" data-ref="popup" onVueInit="__l"><view class="popup__content" style="bottom:0;padding-top:0;padding-bottom:0;max-height:86vh;"><view data-event-opts="{{[['tap',[['popupdetailClose',['$event']]]]]}}" class="popup-close" onTap="__e"><image src="{{pre_url+'/static/img/hotel/popupClose.png'}}"></image></view><scroll-view style="height:auto;max-height:90vh;" scroll-y="{{true}}"><view class="popup-banner-view" style="height:450rpx;"><swiper class="dp-banner-swiper" autoplay="{{true}}" indicator-dots="{{false}}" current="{{0}}" circular="{{true}}" interval="{{3000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item><view data-event-opts="{{[['tap',[['viewPicture',['$0','$1'],['product.pics',[['product.pics','',index]]]]]]]}}" onTap="__e"><image class="dp-banner-swiper-img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></swiper></view><view class="hotel-details-view flex flex-col"><view class="hotel-title">{{product.name}}</view></view><block a:if="{{product.importent_point}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">重要提示</view></view><view class="equity-options flex flex-col">{{product.importent_point}}</view></view></block><block a:if="{{product.booking_info}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">预定说明</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('05e7dc04-2')+','+('05e7dc04-1')}}" content="{{product.booking_info}}" onVueInit="__l"></parse></view></view></block><block a:if="{{product.sell_start_date||product.sell_end_date||product.goods_extra_info&&product.goods_extra_info.visit_way||product.visit_address}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">使用说明</view></view><view class="equity-options flex flex-col"><block a:if="{{product.book_date==2&&(product.sell_start_date||product.sell_end_date)}}"><view class="sub-desc-view flex"><view class="sub-title">有效期</view><view class="sub-value">{{product.sell_start_date+"~"+product.sell_end_date}}</view></view></block><block a:if="{{product.goods_extra_info&&product.goods_extra_info.visit_way}}"><view class="sub-desc-view flex"><view class="sub-title">入园方式</view><view class="sub-value">{{product.goods_extra_info.visit_way}}</view></view></block><block a:if="{{product.visit_address}}"><view class="sub-desc-view flex"><view class="sub-title">入园地址</view><view class="sub-value">{{product.visit_address}}</view></view></block></view></view></block><block a:if="{{product.cost_include||product.cost_no_include}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">费用说明</view></view><view class="equity-options flex flex-col"><block a:if="{{product.cost_include}}"><view class="sub-desc-view flex"><view class="sub-title">费用包含</view><view class="sub-value">{{product.cost_include}}</view></view></block><block a:if="{{product.cost_no_include}}"><view class="sub-desc-view flex"><view class="sub-title">费用不包含</view><view class="sub-value">{{product.cost_no_include}}</view></view></block></view></view></block><block a:if="{{product.goods_extra_info&&(product.goods_extra_info.buy_limit_info||product.goods_extra_info.goods_other_desc)}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">其他说明</view></view><view class="equity-options flex flex-col"><block a:if="{{product.goods_extra_info.buy_limit_info}}"><view class="sub-desc-view flex"><view class="sub-title">限购说明</view><view class="sub-value">{{product.goods_extra_info.buy_limit_info}}</view></view></block><block a:if="{{product.goods_extra_info&&product.goods_extra_info.goods_other_desc}}"><view class="sub-desc-view flex"><view class="sub-title">其他</view><view class="sub-value">{{product.goods_extra_info.goods_other_desc}}</view></view></block></view></view></block><block a:if="{{product.notice}}"><view class="hotel-equity-view flex flex-col"><view class="equity-title-view flex"><view class="equity-title">入园须知</view></view><view class="equity-options flex flex-col"><parse vue-id="{{('05e7dc04-3')+','+('05e7dc04-1')}}" content="{{product.notice}}" onVueInit="__l"></parse></view></view></block><view style="width:100%;height:140rpx;"></view><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="f1 flex"><view class="price" style="{{'color:'+($root.m4)+';'}}"><text style="font-size:18px;">￥</text>{{product.sell_price}}</view><view class="market_price">{{product.market_price}}</view></view><view class="op"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m5)+';'}}" onTap="__e">购买</view></view></view></scroll-view></view></uni-popup><block a:if="{{calendarvisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">选择日期</text><image class="popup__close" style="width:56rpx;height:56rpx;top:20rpx;right:20rpx;" src="{{pre_url+'/static/img/hotel/popupClose2.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="reserve-time-view"><view class="time-view"><view class="time-title">入住</view><view class="flex flex-y-center" style="margin-top:15rpx;align-items:flex-end;"><view class="date-time">{{startDate}}</view><view class="time-title">{{startWeek}}</view></view></view><view class="statistics-view"><view class="statistics-date"><view class="content-decorate left-c-d"></view>{{'共'+dayCount+'晚'}}<view class="content-decorate right-c-d"></view></view><view class="color-line"></view></view><view class="time-view"><view class="time-title">离店</view><view class="flex flex-y-center" style="margin-top:15rpx;align-items:flex-end;"><view class="date-time">{{endDate}}</view><view class="time-title">{{endWeek}}</view></view></view></view><view class="calendar-view"><calendar vue-id="05e7dc04-4" is-show="{{true}}" isFixed="{{false}}" showstock="0" start-date="{{starttime}}" end-date="{{endtime}}" mode="2" themeColor="{{$root.m6}}" maxdays="10" initMonth="1" data-event-opts="{{[['^callback',[['getDate']]]]}}" onCallback="__e" onVueInit="__l"></calendar></view><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="choose-but-class" style="{{('background: linear-gradient(90deg,rgba('+$root.m7+',1) 0%,rgba('+$root.m8+',1) 100%)')}}" onTap="__e">{{'确认'+dayCount+'晚'}}</view></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="05e7dc04-5" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="05e7dc04-6" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="05e7dc04-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="05e7dc04-8" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="05e7dc04-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>