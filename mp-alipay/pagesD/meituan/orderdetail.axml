<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block a:if="{{detail.pay_end_date}}"><view class="t2">{{"剩余时间："+detail.pay_end_date}}</view></block></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t2">待出票</view></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t2">已出票</view></view></block><block a:if="{{detail.status==3}}"><view class="f1"><view class="t1">已完成</view></view></block><block a:if="{{detail.status==4}}"><view class="f1"><view class="t1">已取消</view></view></block><block a:if="{{detail.status==-1}}"><view class="f1"><view class="t1">订单已关闭</view></view></block></view><view class="product"><view class="content"><view class="hotelpic"><image src="{{product.pic}}"></image></view><view class="detail"><text class="t1">{{product.name}}</text><block a:if="{{product.type==2}}"><text class="t2">{{"日期："+detail.visit_date+" - "+detail.visit_end_date}}</text></block><text class="t2">{{"￥"+detail.product_price}}</text></view></view></view><view class="orderinfo1"><view class="title">游客信息</view><block a:for="{{detail.travellerdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><block a:if="{{item.traveller_name}}"><view class="item"><view class="f1"><label class="t1">姓名</label><text class="t2 flex-bt">{{item.traveller_name+''}}</text></view></view></block><block a:if="{{item.traveller_mobile}}"><view class="item"><view class="f1"><label class="t1">联系方式</label><text class="t2 flex-bt">{{item.traveller_mobile+''}}</text></view></view></block><block a:if="{{item.traveller_email}}"><view class="item"><view class="f1"><label class="t1">Email</label><text class="t2 flex-bt">{{item.traveller_email+''}}</text></view></view></block><block a:if="{{item.traveller_credentials}}"><view class="item"><view class="f1"><label class="t1">证件号码</label><text class="t2 flex-bt">{{item.traveller_credentials+''}}</text></view></view></block></block></view><block a:if="{{detail.serial_code}}"><view class="orderinfo"><view class="title">入园凭证</view><view class="item flex-bt"><text class="t1">凭证码</text><text class="t2">{{detail.serial_code}}</text></view><block a:if="{{detail.qr_code}}"><view class="item-serial-code"><image style="width:100%;height:100%;" src="{{detail.qr_code}}" mode="mode"></image></view></block></view></block><view class="orderinfo"><view class="title">订单信息</view><view class="item flex-bt"><text class="t1">订单编号</text><view class="ordernum-info flex-bt"><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text><view class="btn-class" style="margin-left:20rpx;" data-text="{{detail.ordernum}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" onTap="__e">复制</view></view></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{product.type!=2&&detail.visit_date}}"><view class="item"><text class="t1">游玩时间</text><text class="t2">{{detail.visit_date}}</text></view></block><block a:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.product_price>0&&detail.paytime}}"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view></block><block a:if="{{detail.dedamountdk_money>0&&detail.paytime}}"><view class="item"><text class="t1">抵扣金支付</text><text class="t2 red">{{"-¥"+detail.dedamountdk_money}}</text></view></block><block a:if="{{detail.totalprice>0&&detail.paytime}}"><view class="item"><text class="t1">实付</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block a:if="{{detail.status==1}}"><text class="t2">待出票</text></block><block a:if="{{detail.status==2}}"><text class="t2">已出票</text></block><block a:if="{{detail.status==3}}"><text class="t2">已完成</text></block><block a:if="{{detail.status==4}}"><text class="t2">已取消</text></block><block a:if="{{detail.status==-1}}"><text class="t2">已关闭</text></block></view><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason}}</text></view></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block a:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" onTap="__e">关闭订单</view><view class="btn1" style="{{'background:'+($root.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去付款</view></block></block><block a:if="{{detail.status==2||detail.status==1}}"><block><block a:if="{{detail.refund_status==0||detail.refund_status==3}}"><view class="btn2" data-url="{{'refund?id='+detail.id+'&price='+detail.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">申请退款</view></block></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="f26a7964-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="f26a7964-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f26a7964-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="f26a7964-4" onVueInit="__l"></wxxieyi></view>