<view class="container data-v-651ef82a"><block a:if="{{isload}}"><block class="data-v-651ef82a"><view class="search-container data-v-651ef82a"><view class="topsearch flex-y-center data-v-651ef82a"><view class="f1 flex-y-center data-v-651ef82a"><image class="img data-v-651ef82a" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="请输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e" class="data-v-651ef82a"/></view></view><view class="banner data-v-651ef82a"><block a:if="{{set.pics}}"><swiper class="swiper data-v-651ef82a" autoplay="true" interval="{{5000}}"><block class="data-v-651ef82a" a:for="{{set.pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item data-v-651ef82a"><image src="{{item.pic}}" mode="widthFix" data-url="{{item.url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" class="data-v-651ef82a"></image></swiper-item></block></swiper></block></view></view><view class="waterfalls-box data-v-651ef82a" style="{{'height:'+(height+'px')+';'}}"><view class="waterfalls-list data-v-651ef82a" style="{{'--offset:'+(offset+'px')+';'+('--cols:'+(cols)+';')+('top:'+(allPositionArr[index]?allPositionArr[index].top:0)+';')+('left:'+(allPositionArr[index]?allPositionArr[index].left:0)+';')}}" id="{{'waterfalls-list-id-'+item.id}}" ref="__r" data-ref-in-for="{{'waterfalls-list-id-'+item.id}}" data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><image class="waterfalls-list-image data-v-651ef82a" style="{{(imageStyle)}}" mode="widthFix" src="{{item.spot_pic||' '}}" data-event-opts="{{[['load',[['imageLoadHandle',[index]]]],['error',[['imageLoadHandle',[index]]]]]}}" onLoad="__e" onError="__e"></image><view class="article-waterfall-info data-v-651ef82a"><view class="p1 data-v-651ef82a">{{item.spot_name}}</view><block a:if="{{item.spot_tag}}"><view class="p3 data-v-651ef82a">{{item.spot_tag}}</view></block><view class="p2 data-v-651ef82a"><view class="p2-1 data-v-651ef82a"><view class="flex-y-center data-v-651ef82a"><view class="t1 data-v-651ef82a" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;" class="data-v-651ef82a">￥</text>{{item.sell_price}}<text style="font-size:24rpx;" class="data-v-651ef82a">起</text></view></view></view></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="a7fdab8a-1" text="没有更多商品了" class="data-v-651ef82a" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="a7fdab8a-2" text="没有查找到相关商品" class="data-v-651ef82a" onVueInit="__l"></nodata></block></block></block><dp-tabbar vue-id="a7fdab8a-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" class="data-v-651ef82a" onVueInit="__l"></dp-tabbar><popmsg vue-id="a7fdab8a-4" ref="__r" data-ref="popmsg" class="data-v-651ef82a" onVueInit="__l"></popmsg></view>