<transition vue-id="e2e8a8d4-1" name="{{transition}}" class="data-v-48ad70f4" onVueInit="__l"><block a:if="{{isShow}}"><view class="{{(((('calendar-tz')+' '+'_div')+' '+'data-v-48ad70f4')+' '+(isFixed&&'fixed'))}}"><slot name="header"></slot><view class="week-number _div data-v-48ad70f4"><label style="{{'color:'+((index==0||index==weekList.length-1)&&themeColor)+';'}}" class="_span data-v-48ad70f4" a:for="{{weekList}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}</label></view><block a:if="{{title}}"><view class="tips _p data-v-48ad70f4">{{title}}</view></block><view class="content _div data-v-48ad70f4" id="scrollWrap"><view class="con _div data-v-48ad70f4" id="{{item.$orig.year+''+item.$orig.month}}" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="_h3 data-v-48ad70f4">{{item.$orig.year+'年'+item.$orig.month+'月'}}</view><label class="month-bg _span data-v-48ad70f4" style="{{'color:'+(getBetweenColor)+';'}}">{{item.$orig.month}}</label><view class="each-month _ul data-v-48ad70f4"><view data-event-opts="{{[['tap',[['chooseDate',['$0','$1','$2'],[[['calendar','',index],['dayList','',idx]],[['calendar','',index,'month']],[['calendar','',index,'year']]]]]]]}}" class="{{(((('each-day')+' '+'_li')+' '+'data-v-48ad70f4')+' '+day.m0)}}" style="{{'background:'+(day.m1)+';'}}" onTap="__e" a:for="{{item.l0}}" a:for-item="day" a:for-index="idx" a:key="idx"><block a:if="{{mode!=4}}"><view class="{{((('_div')+' '+'data-v-48ad70f4')+' '+day.m2)}}" style="{{'background:'+(day.m3)+';'}}"><view class="day _p data-v-48ad70f4">{{day.$orig?day.$orig:''}}</view><block a:if="{{day.m4}}"><view class="recent _p data-v-48ad70f4"><view class="_i data-v-48ad70f4">{{day.m5}}</view></view></block><block a:else><block a:if="{{showstock==1&&day.$orig>0}}"><view class="recent _p data-v-48ad70f4"><block a:if="{{dayroomprice[item.$orig.year+'-'+(item.$orig.month<=9?'0':'')+item.$orig.month+'-'+(day.$orig>0&&day.$orig<=9?'0':'')+(day.$orig?day.$orig: