<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-content"><view class="product"><view class="content"><view data-url="{{'/pagesD/meituan/product?id='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="productimg" src="{{product.pic}}"></image></view><view class="detail"><text class="t1">{{product.name}}</text><text class="t2">{{"数量："+detail.num}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.sell_price}}</text><view class="num-wrap"><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['blur',[['gwcinput',['$event']]]],['input',[['__set_model',['','refundNum','$event',[]]]]]]}}" value="{{refundNum}}" onBlur="__e" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view><view class="text-desc">{{"申请数量：最多可申请"+detail.canRefundNum+"件"}}</view></view></view></view></view></view></view><view class="form-content"><view class="form-item"><text class="label">退款原因</text><view class="input-item"><textarea placeholder="请输入原因" placeholder-style="color:#999;" name="reason" data-event-opts="{{[['input',[['reasonInput',['$event']]]]]}}" onInput="__e"></textarea></view></view><view class="form-item"><text class="label">退款金额(元)</text><view class="flex"><input name="money" type="digit" placeholder="请输入退款金额" placeholder-style="color:#999;" data-event-opts="{{[['input',[['moneyInput',['$event']]]]]}}" value="{{money}}" onInput="__e"/></view></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m0)+';'}}" onTap="__e">确定</button><view style="padding-top:30rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="68837f63-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="68837f63-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="68837f63-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="68837f63-4" onVueInit="__l"></wxxieyi></view>