<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;"></text>{{userinfo.digital_score}}</view><view class="f1">{{"当前"+$root.m2+"："+set.digital_price}}</view><view class="f1">{{"当前"+$root.m3+"价值："+userinfo.alldigital_price}}</view></view><view class="content2"><view class="item2"><view class="f1">兑换数量</view></view><view class="item3"><view class="f2"><input class="input" type="digit" name="withdraw_num" placeholder="请输入兑换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{withdraw_num}}" onInput="__e"/><view data-event-opts="{{[['tap',[['allwithdraw',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m4)+';'}}" onTap="__e">全部</view></view></view><view class="tips-box"><view class="item4 tips"><block a:if="{{set.cash_fee>0}}"><text>{{"兑换手续费"+set.cash_fee+'%'}}</text></block></view></view></view><view class="withdrawtype"><view class="f1">选择兑换方式：</view><view class="f2"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="item" data-paytype="{{item.$orig.type}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1">{{item.$orig.name}}</view><view class="radio" style="{{(paytype==item.$orig.type?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" onTap="__e">立即兑换</button></form><block a:if="{{set.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{set.withdraw_desc}}</text></view></block></block></block><block a:if="{{loading}}"><loading vue-id="6cab2673-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="6cab2673-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6cab2673-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>