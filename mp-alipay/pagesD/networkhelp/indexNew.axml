<block a:if="{{isload}}"><view class="container"><block a:if="{{show_wallet==1}}"><view class="custom_field"><view class="item"><text class="t2">{{$root.m0}}</text><text class="t1">{{userinfo.commission}}</text></view><view class="item"><text class="t2">{{$root.m1}}</text><text class="t1">{{userinfo.money}}</text></view><view class="item"><text class="t2">{{$root.m2}}</text><text class="t1">{{userinfo.score}}</text></view></view></block><view class="score-card" style="{{'background:'+($root.m3)+';'}}"><block a:for="{{score_data}}" a:for-item="item" a:for-index="index"><view class="score-info-row"><block a:for="{{item}}" a:for-item="item2" a:for-index="index2"><view class="score-info-item" data-url="{{item2.url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="info-label">{{item2.name+"："}}</view><view class="info-value">{{item2.value}}</view></view></block></view></block></view><view class="divider"><view>——</view><view>——</view><view>——</view></view><view class="content" style="{{'background:'+($root.m4)+';'}}"><view class="level-tabs"><block a:for="{{active_list}}" a:for-item="active" a:for-index="index"><view data-event-opts="{{[['tap',[['changeTab',['$0'],[[['active_list','',index,'id']]]]]]]}}" class="{{(('tab-item')+' '+(active_id==active.id?'active':''))}}" onTap="__e">{{active.name}}</view></block></view><view class="user-info"><view class="user-count">{{"活动人脉："+down_members}}</view></view><view class="level-list"><view class="level-item" a:for="{{level_list}}" a:for-item="item" a:for-index="index2"><view class="level-left"><view class="level-line" style="{{'background:'+($root.m5)+';'}}"></view><view class="level-content"><view class="level-header"><view class="level-name">{{item.name}}</view></view></view></view><view class="level-right" data-url="{{'/pagesD/networkhelp/netteam?active_id='+active_id+'&net_path_level='+item.level}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="level-action">>> 查看人脉</view></view></view></view></view><block a:if="{{loading}}"><loading vue-id="d10162c6-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="d10162c6-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d10162c6-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>