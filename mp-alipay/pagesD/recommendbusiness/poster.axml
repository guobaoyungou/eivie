<view class="container"><block a:if="{{isload}}"><block><image class="sjew-img" src="{{poster}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="sjew-he"></view><view class="{{(('sjew-bottom')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="sjew-bottom-content"><block a:if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m1)+';'}}" onTap="__e">分享链接</view></block><block a:else><block a:if="{{$root.m2=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m3)+';'}}" onTap="__e">分享链接</view></block><block a:else><block a:if="{{$root.m4=='h5'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m5)+';'}}" onTap="__e">分享链接</view></block><block a:else><button class="sjew-bot-a1" style="{{'background:'+($root.m6)+';'}}" open-type="share">分享链接</button></block></block></block><view class="sjew-bot-a2" style="{{'background:'+($root.m7)+';'}}" data-url="{{poster}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e">分享图片</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="1869572b-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="1869572b-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="1869572b-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>