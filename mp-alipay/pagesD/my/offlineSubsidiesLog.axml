<view class="container"><block a:if="{{isload}}"><block><view class="content"><block a:if="{{st==0}}"><block><block a:if="{{ly_type==6&&zhitui_num!='-1'}}"><view class="item"><view class="f1"><text class="t1">{{"当月直推新人"+zhitui_num+"个"}}</text></view></view></block><block a:if="{{ly_type==1}}"><view class="item"><block a:if="{{weisj!='-1'}}"><view class="f1"><text class="t1">{{"您还差"+weisj+"个升级奖励升级"}}<block a:if="{{level_name}}"><text>{{"到["+level_name+"]"}}</text></block>，请继续努力</text></view></block><block a:if="{{yisj!='-1'}}"><view class="f1"><text class="t1">{{"恭喜您，您已升级成为["+yisj+"]，剩下的钱自动转入爱心基金"}}</text></view></block></view></block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t2">{{item.createtime}}</text><text class="t1">{{item.remark}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block a:else><text class="t2">{{item.money}}</text></block></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="7b459670-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="7b459670-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="7b459670-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="7b459670-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7b459670-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>