<view><block a:if="{{isload}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1">{{''+item.createtime+''}}</view><view class="f1">{{''+item.un+''}}</view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="5940eab3-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="5940eab3-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="5940eab3-3" onVueInit="__l"></loading></block><popmsg vue-id="5940eab3-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>