<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"活动名称："+item.name}}</view></view><block a:if="{{item.jump_detail_status}}"><view class="st0 flex-y-center" data-url="{{item.jump_detail_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看详情<image class="arrowright" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">活动时间：<text style="font-size:24rpx;">{{item.starttime+" ~ "+item.endtime}}</text></view></view></view><view style="border-bottom:1px #f4f4f4 solid;"></view><view class="content flex-bt"><view class="option-content flex"><view>我的业绩：</view><view style="color:#ff8758;">{{"￥"+item.yeji}}</view></view><view class="option-content flex"><view><block a:if="{{item.fafang_fenhong>0}}"><text>已发奖励</text></block><block a:else><text>预估奖励：</text></block></view><view style="color:#ff8758;"><block a:if="{{item.fafang_fenhong>0}}"><text>{{"￥"+item.fafang_fenhong}}</text></block><block a:else><text>{{"￥"+item.fenhong}}</text></block></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="0b66c549-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0b66c549-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="0b66c549-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0b66c549-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0b66c549-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>