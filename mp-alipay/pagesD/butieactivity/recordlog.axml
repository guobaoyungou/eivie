<view class="container"><block a:if="{{isload}}"><block><view class="content"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.back_type_name}}</text><block a:if="{{item.remark}}"><text class="t2">{{item.send_day+item.remark}}</text></block><text class="t2">{{item.create_time}}</text></view><view class="f2"><text class="t1">{{"+"+item.cashback_num}}</text></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="56e5f466-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="56e5f466-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="56e5f466-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="56e5f466-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="56e5f466-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>