<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list"><view class="{{(('collage-product')+' '+('bc'+item.buy_status))}}"><block a:if="{{item.buy_status==2||item.buy_status==3}}"><text class="status_str str2">已完成</text></block><block a:if="{{item.buy_status==1}}"><text class="status_str str1">已购买</text></block><view class="product-pic"><image src="{{item.pic}}" mode="aspectFit"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-d">{{item.start_date+"~"+item.end_date}}</view><view data-event-opts="{{[['tap',[['showmemberstage',[index]]]]]}}" class="p2-d p-rule" catchTap="__e"><view><block a:if="{{item.member_stage.back_days}}"><text>{{"补贴"+item.member_stage.back_days+"天"}}</text></block><block a:if="{{item.member_stage.back_everyday_money}}"><text>{{"每日补贴"+item.member_stage.back_everyday_money+"元"}}<block a:if="{{item.tuiguangdata[0].tuiguang}}"><text>,</text></block>{{"推"+item.tuiguangdata[0].tuiguang+"人"}}</text></block><block a:if="{{item.tuiguangdata[0].addday}}"><text>{{"加"+item.tuiguangdata[0].addday}}</text></block><block a:if="{{item.tuiguangdata[0].addmoney}}"><text>{{"天,每日多补贴"+item.tuiguangdata[0].addmoney+"元"}}</text></block></view><view class="rule-more">更多<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;font-size:24rpx;"></text></view></view></view><block a:if="{{item.buy_status>0}}"><view class="p3"><progress class="t1" percent="{{item.progress}}" stroke-width="5" activeColor="#48c78d" backgroundColor="#c9c9c9" border-radius="20"></progress><view class="t2"><text>{{item.member_check.tuiguang_num+"/"+item.member_check.tuiguang_num_max+"人"}}</text></view></view></block></view></view><view class="product-bottom"><view data-event-opts="{{[['tap',[['shareClick',['$0'],[[['datalist','',index]]]]]]]}}" class="btn t1" onTap="__e">立即分享</view><view class="btn t2" data-url="{{'/pagesD/butieactivity/index?id='+item.productids+'&butie_activity_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的分享</view><block a:if="{{item.buy_status==0}}"><view class="btn t3 buybtn-bc0" data-url="{{'/pages/shop/product?id='+item.productids}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去购买</view></block><block a:if="{{item.buy_status==1}}"><view class="btn t3 buybtn-bc1">去复购</view></block><block a:if="{{item.buy_status==2||item.buy_status==3}}"><view class="btn t3 buybtn-bc2" data-url="{{'/pages/shop/product?id='+item.productids}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去复购</view></block></view></view></block></view><uni-popup vue-id="50a343ea-1" id="dialogTuiguang" type="dialog" ref="__r" data-ref="dialogTuiguang" onVueInit="__l"><view class="dialog-main"><view class="dialog-header">{{member_stage.name}}</view><view class="dialog-content"><view style="margin-bottom:20rpx;"><block a:if="{{member_stage.back_days}}"><text>{{"补贴"+member_stage.back_days+"天"}}</text></block><block a:if="{{member_stage.back_everyday_money}}"><text>{{"每日补贴"+member_stage.back_everyday_money+"元"}}</text></block></view><view class="rule-item" a:for="{{member_stage.tuiguangdata}}" a:for-item="item" a:for-index="index" a:key="index"><text class="dot"></text><view><block a:if="{{item.tuiguang}}"><text>{{"推广"+item.tuiguang+"人"}}</text></block><block a:if="{{item.addday}}"><text>{{"加"+item.addday}}</text></block><block a:if="{{item.addmoney}}"><text>{{"天,每日多补贴"+item.addmoney+"元"}}</text></block></view></view><view class="weekday">{{member_stage.week_day}}</view></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="50a343ea-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="50a343ea-3" onVueInit="__l"></nodata></block></view><block a:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block a:if="{{$root.m0!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" onTap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="50a343ea-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="50a343ea-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="50a343ea-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>