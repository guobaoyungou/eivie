<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="17fd9bae-1" itemdata="{{['全部','发放中','已完成']}}" itemst="{{['all','1','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="{{(show_rebate?'height:260rpx;width:100%;':'height:100rpx;width:100%;')}}"></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'recordlog?butie_member_product_id='+item.id+'&butie_activity_id='+item.butie_activity_id+'&pro_id='+item.pro_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><block a:if="{{item.pic}}"><image src="{{item.pic}}"></image></block><block a:else><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image></block><view class="head-title">{{item.name}}</view></view><text class="{{(('st')+' '+('st'+item.status))}}">{{item.status_str}}</text></view><view class="report-box"><view class="report-item"><view class="item-txt">已补贴天数</view><view class="item-num">{{item.back_days_total+"天"}}</view></view><view class="report-item"><view class="item-txt">累计可补贴天数</view><view class="item-num">{{item.back_days+"天"}}</view></view><view class="report-item"><view class="item-txt">推广增加天数</view><view class="item-num">{{item.back_days_add+"天"}}</view></view></view><view class="report-box"><view class="report-item"><view class="item-txt">每日发放金额</view><view class="item-num">{{"￥"+item.back_everyday_money}}</view></view><view class="report-item"><view class="item-txt">推广增加日金额</view><view class="item-num">{{"￥"+item.back_everyday_money_add}}</view></view><view class="report-item"><view class="item-txt">已发放金额</view><view class="item-num">{{"￥"+item.back_money_total}}</view></view></view><view class="report-box"><view class="report-item"><view class="item-txt">已推人数</view><view class="item-num">{{item.tuiguang_num+"人"}}</view></view><view data-event-opts="{{[['tap',[['showmemberstage',['$0'],[[['datalist','',index]]]]]]]}}" class="report-item" catchTap="__e"><view class="item-txt">推广人数</view><view class="item-num">{{item.tuiguang_num_max+"人"}}</view></view></view><view class="weekdays"><view class="weekday" a:for="{{item.week_day}}" a:for-item="day" a:for-index="i" a:key="i">{{day}}</view></view></view></block></view><uni-popup vue-id="17fd9bae-2" id="dialogTuiguang" type="dialog" ref="__r" data-ref="dialogTuiguang" onVueInit="__l"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><view class="sendexpress-item" style="display:flex;border-bottom:1px solid #f5f5f5;padding:20rpx 0;" a:for="{{member_stage.tuiguangdata}}" a:for-item="item" a:for-index="index" a:key="index"><view><block a:if="{{item.tuiguang}}"><text>{{"推广"+item.tuiguang+"人"}}</text></block><block a:if="{{item.addday}}"><text>{{"增加"+item.addday}}</text></block><block a:if="{{item.addmoney}}"><text>{{"天,每日多补贴"+item.addmoney+"元"}}</text></block></view></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="17fd9bae-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="17fd9bae-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="17fd9bae-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="17fd9bae-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="17fd9bae-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>