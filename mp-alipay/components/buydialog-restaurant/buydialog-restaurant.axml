<view><block a:if="{{isload}}"><view><view class="buydialog-mask flex-xy-center"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-back" onTap="__e"></view><view data-event-opts="{{[['touchMove',[['',['$event']]]]]}}" class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot2'))}}" catchTouchMove="__e"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><scroll-view scroll-y="true"><scroll-view class="page-scroll" scroll-y="true"><view class="box"><image class="banner" src="{{nowguige.pic||product.pic}}" mode="aspectFit" data-url="{{nowguige.pic||product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view><block a:if="{{product.sellpoint}}"><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col"><view class="name">产品描述</view><view class="item flex flex-y-center"><view class="description">{{product.sellpoint}}</view></view></view></view></block><block a:if="{{jlselectdata.length>0&&(controller=='ApiRestaurantShop'||controller=='ApiRestaurantTakeaway')}}"><view style="height:auto;"><view class="guigelist flex-col"><view class="name">加料</view><view class="item flex flex-y-center"><view class="jlitem" style="{{(jitem.$orig.num>0?'color:'+jitem.m0+';border-color:'+jitem.m1:'')}}" a:for="{{$root.l0}}" a:for-item="jitem" a:for-index="jindex" a:key="jindex"><view data-event-opts="{{[['tap',[['jlsubnum',[jindex]]]]]}}" class="addsub" style="{{('color:'+$root.m2+';border:4rpx solid '+$root.m3)}}" onTap="__e">－</view><view class="text">{{jitem.$orig.title}}</view><view data-event-opts="{{[['tap',[['jladdnum',[jindex]]]]]}}" class="addsub" style="{{('color:#fff;background-color:'+$root.m4)}}" onTap="__e">＋</view><block a:if="{{jitem.$orig.num>0}}"><view class="jlnum" style="{{('background-color:'+jitem.m5)}}">{{jitem.$orig.num}}</view></block></view></view></view></view></block><view style="height:auto;"><view class="guigelist flex-col" a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="index"><view class="name">{{item.$orig.title}}</view><view class="item flex flex-y-center"><block a:for="{{item.l1}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="item2" style="{{(ggselected[item.$orig.k]==item2.$orig.k?'color:'+item2.m6+';'+'border-color:'+item2.m7:'')}}" data-itemk="{{item.$orig.k}}" data-idx="{{item2.$orig.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" onTap="__e">{{item2.$orig.title}}</view></block></view></view></view><block a:if="{{jialiaodata.length>0&&(controller=='ApiRestaurantShop'||controller=='ApiRestaurantTakeaway')}}"><view style="height:auto;"><view class="guigelist flex-col"><view class="name">加料</view><view class="item flex flex-y-center"><view data-event-opts="{{[['tap',[['jlchange',[jlindex]]]]]}}" class="item2" style="{{(jlitem.$orig.active?'color:'+jlitem.m8+';'+'border-color:'+jlitem.m9:'')}}" onTap="__e" a:for="{{$root.l3}}" a:for-item="jlitem" a:for-index="jlindex" a:key="jlindex">{{jlitem.$orig.jltitle}}</view></view></view></view></block></scroll-view><view class="page_price" style="{{'color:'+($root.m10)+';'}}">{{"￥"+totalprice}}</view><view class="page_content">{{"已选规格: "+nowguige.name+jltitle}}</view><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><block a:if="{{shopset&&shopset.showcommission==1&&nowguige.commission>0}}"><view class="tips-text" style="{{'color:'+($root.m11)+';'}}">{{"分享好友购买预计可得"+$root.m12+"："}}<text style="font-weight:bold;padding:0 2px;">{{nowguige.commission}}</text>{{nowguige.commission_desc}}</view></block><view class="op"><block a:if="{{nowguige.stock<=0||nowguige.stock_daily<=0}}"><block><button class="nostock">库存不足</button></block></block><block a:else><block><block a:if="{{btntype==0&&canaddcart}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m13)+';'}}" onTap="__e">加入购物车</button></block><block a:if="{{btntype==0}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m14)+';'}}" onTap="__e">立即购买</button></block><block a:if="{{btntype==1}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m15)+';'}}" onTap="__e">确 定</button></block><block a:if="{{btntype==2}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m16)+';'}}" onTap="__e">确 定</button></block></block></block></view></scroll-view></view></view></view></block><block a:if="{{loading}}"><loading vue-id="a7e1b950-1" onVueInit="__l"></loading></block></view>