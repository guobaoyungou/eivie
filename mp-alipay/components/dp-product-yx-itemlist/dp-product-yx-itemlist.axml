<view style="width:100%;"><view class="dp-product-itemlist"><view class="dp-product-item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="id"><view data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" class="item" style="{{(item.$orig.product_promotion_tag?'align-items: normal; background-color: '+probgcolor+';':'background-color: '+probgcolor+';')}}" onTap="__e"><view class="product-pic" style="{{(item.$orig.product_promotion_tag?'width:40%;height:auto;':'')}}"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info" style="{{(item.$orig.product_promotion_tag?'width:60%;padding: 6rpx 0 5rpx 20rpx':'')}}"><block a:if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><block a:if="{{item.$orig.sellpoint}}"><view class="p5" style="{{'color:'+(item.m0)+';'}}"><text>{{item.$orig.sellpoint}}</text></view></block><block a:if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m1)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m2}}</text></view></block><block a:if="{{item.$orig.show_cost&&item.$orig.price_type!=1}}"><view style="{{'color:'+(item.$orig.cost_color?item.$orig.cost_color:'#999')+';'+('font-size:'+('36rpx')+';')}}"><text style="font-size:24rpx;">{{item.$orig.cost_tag}}</text>{{item.$orig.cost_price}}</view></block><block a:if="{{(!item.$orig.show_sellprice||item.$orig.show_sellprice&&item.$orig.show_sellprice==true)&&(item.$orig.price_type!=1||item.$orig.sell_price>0)&&showprice!='0'}}"><view class="p2"><block a:if="{{item.$orig.price_show_type=='0'||!item.$orig.price_show_type}}"><view class="flex-bt flex-y-center"><text class="t1" style="{{'color:'+(item.$orig.price_color?item.$orig.price_color:item.m3)+';'}}"><block><text style="font-size:24rpx;padding-right:1px;">{{item.$orig.price_tag?item.$orig.price_tag:'￥'}}</text>{{item.$orig.sell_price+''}}<block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block a:if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block></block></text><block a:if="{{!item.$orig.product_promotion_tag}}"><view><block a:if="{{item.$orig.yingxiao_tag&&item.$orig.yingxiao_tag.id}}"><view style="color:#999;font-size:20rpx;">{{item.$orig.yingxiao_tag.sales_text}}</view></block><block a:else><view style="color:#999;font-size:20rpx;">{{"已售"+item.$orig.sales+"人"}}</view></block></view></block></view></block><block a:if="{{item.$orig.show_sellprice&&item.$orig.market_price*1>item.$orig.sell_price*1&&showprice=='1'}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block><block a:if="{{item.$orig.juli}}"><text class="t3">{{item.$orig.juli}}</text></block></view></block><block a:if="{{item.$orig.product_promotion_tag}}"><block><block a:if="{{item.$orig.tag_commission_rate||item.$orig.tag_commission}}"><view class="flex-y-center product_promotion_tag" style="{{('color:'+item.m4+';')}}"><block a:if="{{item.$orig.tag_commission_rate}}"><view class="pro-label flex-col flex-y-center" style="width:33%;"><view style="color:#999;">{{item.m5+"率"}}</view><view style="font-weight:bold;">{{item.$orig.tag_commission_rate}}</view></view></block><block a:if="{{item.$orig.tag_commission_rate}}"><view class="separator"></view></block><block a:if="{{item.$orig.tag_commission}}"><view class="pro-label flex-col flex-y-center" style="width:33%;"><view style="color:#999;">{{"预估"+item.m6}}</view><view style="font-weight:bold;">{{"￥"+item.$orig.tag_commission}}</view></view></block><block a:if="{{item.$orig.tag_commission_rate||item.$orig.tag_commission}}"><view class="separator"></view></block><block a:if="{{item.$orig.tag_upgrade_money}}"><view class="pro-label flex-col flex-y-center" style="width:33%;"><view style="color:#999;">{{item.m7}}</view><view style="font-weight:bold;">{{"￥"+item.$orig.tag_upgrade_money}}</view></view></block></view></block><view class="p3" style="justify-content:flex-end;"><view class="right tag-share"><image style="width:30rpx;height:30rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/share_white.png'}}" mode></image><block a:if="{{item.$orig.tag_commission}}"><text>{{"赚￥"+item.$orig.tag_commission}}</text></block><block a:else><text>立即分享</text></block></view></view></block></block><block a:else><block><block a:if="{{item.$orig.yingxiao_tag&&item.$orig.yingxiao_tag.id}}"><view class="p3"><view class="left">{{item.$orig.yingxiao_tag.title}}</view><view class="right"><view class="yuandian"></view>{{''+item.$orig.yingxiao_tag.btn_text+''}}</view></view></block><block a:else><view class="p3"><view class="left">限量低价，先到先得</view><view class="right"><view class="yuandian"></view>立即抢购</view></view></block></block></block></view></view></view></view><block><block a:if="{{buydialogShow}}"><buydialog vue-id="0e4dbb18-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></block></view>