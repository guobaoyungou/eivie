<view class="dp-shortvideo" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><view class="dp-shortvideo-content"><view class="item" style="{{'margin-right:'+(index%2==0?'2%':'0')+';'}}" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="index"><image class="ff" mode="widthFix" src="{{item.coverimg}}" data-url="{{'/activity/shortvideo/detail?id='+item.videoId+'&cid='+params.category}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image><view class="f2"><block a:if="{{params.showlogo==1}}"><view class="t1"><image class="touxiang" src="{{item.logo}}"></image></view></block><block a:if="{{params.showviewnum==1}}"><view class="t2"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_playnum.png'}}"></image>{{item.view_num}}</view></block><block a:if="{{params.showzannum==1}}"><view class="t3"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_likenum.png'}}"></image>{{item.zan_num}}</view></block></view></view></view></view>