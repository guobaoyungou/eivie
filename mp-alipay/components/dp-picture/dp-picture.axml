<view class="dp-picture" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><view style="box-sizing:border-box;" data-url="{{item.hrefurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><block a:if="{{item.hrefurl=='contact::'}}"><button class="picture-button" open-type="contact" show-message-card="true"><image class="picture-img" style="{{'border-radius:'+(params.borderradius*2.2+'rpx')+';'}}" show-menu-by-longpress="true" src="{{item.imgurl}}" mode="widthFix"></image></button></block><block a:else><block a:if="{{item.hrefurl=='share::'}}"><button class="picture-button" open-type="share"><image class="picture-img" style="{{'border-radius:'+(params.borderradius*2.2+'rpx')+';'}}" show-menu-by-longpress="true" src="{{item.imgurl}}" mode="widthFix"></image></button></block><block a:else><image class="picture-img" style="{{'border-radius:'+(params.borderradius*2.2+'rpx')+';'}}" show-menu-by-longpress="true" src="{{item.imgurl}}" mode="widthFix" data-url="{{preview&&!item.hrefurl?item.imgurl:''}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block></view></view>