<view><block a:if="{{isload}}"><view><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-mask" onTap="__e"></view><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title flex"><image class="img" src="{{nowguige.pic||product.pic}}" data-url="{{nowguige.pic||product.pic}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="flex1"><view><block a:if="{{shopset&&(shopset.price_show_type=='0'||!shopset.price_show_type)||!shopset}}"><view><block a:if="{{product.price_type!=1||nowguige.sell_price>0}}"><view class="price" style="{{'color:'+($root.m0)+';'}}"><block a:if="{{product.price_dollar&&nowguige.usdsell_price>0}}"><block><text style="margin-right:10rpx;">{{"$"+nowguige.usdsell_price}}</text></block></block>{{'￥'+nowguige.sell_price+''}}<block a:if="{{$root.m1>$root.m2}}"><text class="t2">{{"￥"+nowguige.market_price}}</text></block></view></block></view></block><block a:if="{{shopset&&(shopset.price_show_type=='1'||shopset.price_show_type=='2')}}"><view><block a:if="{{product.is_vip=='0'}}"><view><block a:if="{{product.price_type!=1||nowguige.sell_price>0}}"><view class="price" style="{{'color:'+($root.m3)+';'}}"><block a:if="{{product.price_dollar&&nowguige.usdsell_price>0}}"><block><text style="margin-right:10rpx;">{{"$"+nowguige.usdsell_price}}</text></block></block>{{'￥'+nowguige.sell_price+''}}<block a:if="{{$root.m4>$root.m5}}"><text class="t2">{{"￥"+nowguige.market_price}}</text></block></view></block><block a:if="{{shopset.price_show_type=='2'&&product.lvprice==1}}"><view class="member flex"><view class="member_module flex" style="{{('border-color:'+$root.m6)}}"><view class="member_lable flex-y-center" style="{{'background:'+($root.m7)+';'}}">{{nowguige.level_name}}</view><view class="member_value" style="{{('color:'+$root.m8)}}">￥<text>{{nowguige.sell_price_origin}}</text></view></view></view></block></view></block><block a:if="{{product.is_vip=='1'}}"><view><view class="member flex"><view class="member_module flex" style="{{('border-color:'+$root.m9)}}"><view class="member_lable flex-y-center" style="{{'background:'+($root.m10)+';'}}">{{nowguige.level_name}}</view><view class="member_value" style="{{'font-size:36rpx;'+('color:'+$root.m11)}}">￥<text>{{nowguige.sell_price}}</text></view></view></view><block a:if="{{product.price_type!=1||nowguige.sell_price>0}}"><view class="price" style="{{'color:'+($root.m12)+';'}}"><block a:if="{{product.price_dollar&&nowguige.usdsell_price>0}}"><block><text style="margin-right:10rpx;">{{"$"+nowguige.usdsell_price}}</text></block></block><text style="{{(product.lvprice=='1'?'font-size:30rpx;':'font-size:36rpx;')}}">{{'￥'+nowguige.sell_price_origin+''}}</text></view></block></view></block></view></block></view><block a:if="{{!shopset||shopset.hide_stock!=1}}"><view class="stock">{{"库存："+nowguige.stock}}</view></block><block a:if="{{product.limit_start<=1}}"><view class="choosename">{{"已选规格: "+nowguige.name+jltitle}}</view></block></view></view><block a:if="{{product.sellpoint}}"><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col"><view class="name">产品描述</view><view class="item flex flex-y-center"><view class="description">{{product.sellpoint}}</view></view></view></view></block><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="name">{{item.$orig.title}}</view><view class="item flex flex-y-center"><block a:for="{{item.l0}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="{{('item2')}}" style="{{(ggselected[item.$orig.k]==item2.$orig.k?'color:'+item2.m13+';background:rgba('+item2.m14+',0.1);font-weight:bold':'')}}" data-itemk="{{item.$orig.k}}" data-idx="{{item2.$orig.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" onTap="__e">{{item2.$orig.title}}</view></block></view></view></view><block><block a:if="{{showbuynum}}"><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]],['blur',[['gwcinputblur',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e" onBlur="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view></block><view class="op"><block><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m15)+';'}}" onTap="__e">加入采购单</button></block></view></block></view></view></block><block a:if="{{loading}}"><loading vue-id="37963ad0-1" onVueInit="__l"></loading></block></view>