<view hidden="{{!(url)}}" mode="{{modeValue}}" change:mode="{{mwx.changeMode}}" rotate="{{rotate}}" change:rotate="{{mwx.changeRotate}}" class="data-v-387a077b"><view class="panel data-v-387a077b"><view data-event-opts="{{[['touchStart',[['e0',['$event']]]],['touchMove',[['e1',['$event']]]],['touchEnd',[['e2',['$event']]]],['touchCancel',[['e3',['$event']]]]]}}" class="body data-v-387a077b" onTouchStart="__e" onTouchMove="__e" onTouchEnd="__e" onTouchCancel="__e"><view class="{{((('image-wrap')+' '+'data-v-387a077b')+' '+((transit)?'transit':''))}}" change:rect="{{mwx.changeImage}}" rect="{{image}}"><image class="{{((('image')+' '+'data-v-387a077b')+' '+((transit)?'transit':''))}}" src="{{url}}" data-event-opts="{{[['load',[['imageLoad',['$event']]]]]}}" onLoad="__e"></image></view><view class="mask data-v-387a077b"></view><view class="{{((('frame')+' '+'data-v-387a077b')+' '+((transit)?'transit':''))}}" change:rect="{{mwx.changeFrame}}" rect="{{frame}}"><view class="rect data-v-387a077b"><view class="{{((('image-rect')+' '+'data-v-387a077b')+' '+((transit)?'transit':''))}}"><image class="{{((('image')+' '+'data-v-387a077b')+' '+((transit)?'transit':''))}}" src="{{url}}"></image></view></view><view class="line-one data-v-387a077b"></view><view class="line-two data-v-387a077b"></view><view class="line-three data-v-387a077b"></view><view class="line-four data-v-387a077b"></view><view data-event-opts="{{[['touchStart',[['e4',['$event']]]]]}}" class="frame-left-top data-v-387a077b" onTouchStart="__e"></view><view data-event-opts="{{[['touchStart',[['e5',['$event']]]]]}}" class="frame-left-bottom data-v-387a077b" onTouchStart="__e"></view><view data-event-opts="{{[['touchStart',[['e6',['$event']]]]]}}" class="frame-right-top data-v-387a077b" onTouchStart="__e"></view><view data-event-opts="{{[['touchStart',[['e7',['$event']]]]]}}" class="frame-right-bottom data-v-387a077b" onTouchStart="__e"></view></view></view><view class="toolbar data-v-387a077b"><view data-event-opts="{{[['tap',[['oncancle',['$event']]]]]}}" class="btn-cancel data-v-387a077b" onTap="__e">取消</view><view data-event-opts="{{[['tap',[['rotateAngle',['$event']]]]]}}" class="btn-rotate data-v-387a077b" onTap="__e">旋转</view><view data-event-opts="{{[['tap',[['onok',['$event']]]]]}}" class="btn-ok data-v-387a077b" onTap="__e">确定</view></view></view></view>