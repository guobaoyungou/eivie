<view><view class="{{(('mask')+' '+((showPicker)?'maskShow':''))}}" catchtouchmove="true" data-event-opts="{{[['tap',[['hide',['$event']],['',['$event']]]],['touchMove',[['',['$event']]]]]}}" catchTap="__e" catchTouchMove="__e"></view><view class="{{(('cpicker-content')+' '+((showPicker)?'cpickerShow':''))}}"><view class="city-head" catchtouchmove="true" data-event-opts="{{[['tap',[['',['$event']]]],['touchMove',[['',['$event']]]]]}}" catchTap="__e" catchTouchMove="__e"><view class="city-head-title">{{headtitle}}</view><block a:if="{{rightIcon}}"><text data-event-opts="{{[['tap',[['hide',['self']]]]]}}" class="rightIcon iconfont icon-quxiao" onTap="__e"></text></block></view><scroll-view class="nav-bar" id="nav-bar" scroll-x="true" scroll-with-animation="true" scroll-left="{{scrollLeft}}"><view class="{{(('nav-item')+' '+((index===tabCurrentIndex)?'current':''))}}" id="{{'tab'+index}}" data-event-opts="{{[['tap',[['changeTab',[index]]]]]}}" onTap="__e" a:for="{{tabbars}}" a:for-item="item" a:for-index="index" a:key="index"><text class="nav-bar-title">{{item.text}}</text></view></scroll-view><view class="city_content"><scroll-view class="panel-scroll-box" scroll-y="{{enableScroll}}" cscrollTop="{{scrollTop}}" current="{{tabCurrentIndex}}" scroll-top="{{scrollTop}}"><block a:for="{{showData}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['changCity',['$0','$1'],['tabCurrentIndex',[['showData','',index]]]]]]]}}" class="flex-row-c-c" onTap="__e"><block a:if="{{tabbars[tabCurrentIndex].value==item.value}}"><icon class="ischeck" type="success_no_circle" id="{{'show'+tabCurrentIndex}}" size="14" color="#00B1B7"></icon></block><text class="city-text">{{item.text}}</text></view></block></scroll-view></view></view></view>