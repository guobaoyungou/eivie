<view class="dp-hotspot" style="{{'margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';'}}"><image class="image" src="{{params.imgurl}}" mode="widthFix"></image><view data-event-opts="{{[['tap',[['gotoUrl',['$0','$1'],[[['data','id',item.id,'hrefurl']],[['data','id',item.id]]]]]]]}}" class="hotarea" style="{{'width:'+(item.width*2.2+'rpx')+';'+('height:'+(item.height*2.2+'rpx')+';')+('left:'+(item.left*2.2+'rpx')+';')+('top:'+(item.top*2.2+'rpx')+';')}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"></view></view>