<block a:if="{{node.node=='element'}}"><block><block a:if="{{node.tag=='button'}}"><button class="{{(node.classStr)}}" style="{{(node.styleStr)}}" type="default" size="mini"><rich-text class="{{(node.classStr)}}" style="{{('user-select:'+parseSelect)}}" nodes="{{node}}"></rich-text></button></block><block a:else><block a:if="{{node.tag=='a'}}"><view class="{{(node.classStr)}}" style="{{'display:inline;border-bottom:1px solid #555555;'+(node.styleStr)}}" data-href="{{node.attr.href}}" data-event-opts="{{[['tap',[['wxParseATap',['$0','$event'],['node.attr']]]]]}}" onTap="__e"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><weixin-parse-template vue-id="{{'5ca2d41c-1-'+index}}" node="{{node}}" onVueInit="__l"></weixin-parse-template></block></view></block><block a:else><block a:if="{{node.tag=='li'}}"><view class="{{(node.classStr)}}" style="{{(node.styleStr)}}"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><rich-text class="{{(node.classStr)}}" style="{{('user-select:'+parseSelect)}}" nodes="{{node}}"></rich-text></block></view></block><block a:else><block a:if="{{node.tag=='table'}}"><weixin-parse-table class="{{(node.classStr)}}" style="{{(node.styleStr)}}" vue-id="5ca2d41c-2" node="{{node}}" onVueInit="__l"></weixin-parse-table></block><block a:else><block a:if="{{node.tag=='br'}}"><text>\n</text></block><block a:else><block a:if="{{node.tag=='video'}}"><weixin-parse-video vue-id="5ca2d41c-3" node="{{node}}" onVueInit="__l"></weixin-parse-video></block><block a:else><block a:if="{{node.tag=='audio'}}"><weixin-parse-audio vue-id="5ca2d41c-4" node="{{node}}" onVueInit="__l"></weixin-parse-audio></block><block a:else><block a:if="{{node.tag=='img'}}"><weixin-parse-img vue-id="5ca2d41c-5" node="{{node}}" onVueInit="__l"></weixin-parse-img></block><block a:else><block a:if="{{node.tag=='strong'}}"><view class="{{(node.classStr)}}" style="{{'font-weight:700;display:inline;'+(node.styleStr)}}"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><weixin-parse-template vue-id="{{'5ca2d41c-6-'+index}}" node="{{node}}" onVueInit="__l"></weixin-parse-template></block></view></block><block a:else><block a:if="{{node.tag=='span'}}"><view class="{{(node.classStr)}}" style="{{'display:inline;'+(node.styleStr)}}"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><weixin-parse-template vue-id="{{'5ca2d41c-7-'+index}}" node="{{node}}" onVueInit="__l"></weixin-parse-template></block></view></block><block a:else><block a:if="{{node.tag=='em'}}"><view class="{{(node.classStr)}}" style="{{'display:inline;font-style:italic;'+(node.styleStr)}}"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><weixin-parse-template vue-id="{{'5ca2d41c-8-'+index}}" node="{{node}}" onVueInit="__l"></weixin-parse-template></block></view></block><block a:else><view class="{{(node.classStr)}}" style="{{(node.styleStr)}}"><block a:for="{{node.nodes}}" a:for-item="node" a:for-index="index" a:key="index"><rich-text class="{{(node.classStr)}}" style="{{('user-select:'+parseSelect)}}" nodes="{{node}}"></rich-text></block></view></block></block></block></block></block></block></block></block></block></block></block></block></block><block a:else><block a:if="{{node.node=='text'}}"><block>{{node.text}}</block></block></block>