ck a:if="{{item.$orig.usd_sellprice}}"><block><text style="{{'color:'+(item.m12)+';'}}">{{"$"+item.$orig.usd_sellprice+" ￥"+item.$orig.sell_price}}</text></block></block><block a:else><block><text style="{{'color:'+(item.m13)+';'}}">{{"￥"+item.$orig.sell_price}}</text></block></block><view class="flex-xy-center" style="{{'background:'+('rgba('+$root.m14+',1)')+';'}}">马上抢</view></view></view></view></view></block><block a:if="{{params.style=='line'}}"><view class="dp-seckill-itemline"><view class="item" data-url="{{'/activity/seckill/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block a:if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block><view class="tag" style="{{'background:'+('rgba('+$root.m15+',1)')+';'}}">秒杀</view></view><view class="product-info"><block a:if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="flex"><view class="tag" style="{{'background:'+('rgba('+$root.m16+',0.12)')+';'+('color:'+($root.m17)+';')}}">{{"剩余"+(item.stock-item.sales)+"件"}}</view></view><view class="price flex-y-center flex-bt"><text style="{{'color:'+($root.m18)+';'}}">{{"￥"+item.sell_price}}</text><view class="flex-xy-center" style="{{'background:'+('rgba('+$root.m19+',1)')+';'}}"><image src="{{pre_url+'/static/imgsrc/decoration_add.png'}}"></image></view></view></view></view></view></block></view></block></view>