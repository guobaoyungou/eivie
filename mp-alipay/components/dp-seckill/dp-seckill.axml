<view class="dp-seckill" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block a:if="{{params.shopstyle=='2'}}"><view><block a:if="{{params.showtitle=='1'}}"><view><block a:if="{{params.titlestyle==1}}"><view class="dp-time flex-y-center"><image class="dp-time-back" mode="widthFix" src="{{pre_url+'/static/imgsrc/decoration_crush.png'}}" alt></image><view class="dp-time-module flex flex-bt flex-y-center"><text class="dp-time-title">限时秒杀</text><view class="dp-time-content"><block a:if="{{data[0].seckill_status==0}}"><text>距开抢</text></block><block a:if="{{data[0].seckill_status==1}}"><text>还剩余</text></block><block a:if="{{data[0].seckill_status==2}}"><text>活动已结束</text></block><block a:if="{{data[0].seckill_status!=2}}"><uni-countdown vue-id="779f0e58-1" show-day="{{false}}" color="#fd4a46" background-color="#fff" hour="{{data[0].hour}}" minute="{{data[0].minute}}" second="{{data[0].second}}" splitorColor="#fff" onVueInit="__l"></uni-countdown></block></view></view></view></block><block a:if="{{params.titlestyle==2}}"><view class="dp-bTime flex-y-center"><image class="dp-bTime-back" mode="widthFix" src="{{pre_url+'/static/imgsrc/decoration_crush.png'}}" alt></image><view class="dp-bTime-module flex flex-bt flex-y-center"><text class="dp-bTime-title">限时秒杀</text><view class="dp-bTime-content"><block a:if="{{data[0].seckill_status==0}}"><text>距开抢</text></block><block a:if="{{data[0].seckill_status==1}}"><text>还剩余</text></block><block a:if="{{data[0].seckill_status==2}}"><text>活动已结束</text></block><block a:if="{{data[0].seckill_status!=2}}"><uni-countdown vue-id="779f0e58-2" show-day="{{false}}" color="#fff" background-color="#000" hour="{{data[0].hour}}" minute="{{data[0].minute}}" second="{{data[0].second}}" splitorColor="#999ca7" onVueInit="__l"></uni-countdown></block></view></view></view></block></view></block></view></