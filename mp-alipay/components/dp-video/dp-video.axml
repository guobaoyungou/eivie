<view class="dp-video" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('height:'+('calc('+Height*(params.videoheight?params.videoheight:30)/100+'px - '+(''+(hastabbar?'110rpx - env(safe-area-inset-bottom)':'env(safe-area-inset-bottom)'))+')')+';')+('min-height:'+($root.g0+'px')+';')}}"><block a:if="{{!params.type||params.type==0}}"><video class="dp-video-video" src="{{params.src}}" show-mute-btn="{{(params.muted?params.muted:0)==1}}" play-btn-position="{{params.butposition?params.butposition:'center'}}" object-fit="{{params.objectfit?params.objectfit:'contain'}}" poster="{{params.pic}}" controls="{{(params.controls?params.controls:1)==1}}" autoplay="{{(params.autoplay?params.autoplay:0)==1}}" loop="{{(params.loop?params.loop:0)==1}}" show-fullscreen-btn="{{(params.fullscreen?params.fullscreen:1)==1}}" muted="{{params.muted==1}}"></video></block></view>