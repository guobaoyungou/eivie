<view class="dp-notice" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx'+' 0rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block a:if="{{params.showimg==1}}"><view class="left"><image class="image" src="{{params.img}}" mode="heightFix"></image></view></block><view class="right"><block a:if="{{params.showicon==1}}"><image class="ico" src="{{params.icon}}"></image></block><block a:if="{{data&&data.length==1}}"><block><view class="dp-notice-content" style="{{'text-align:'+(textAlign)+';'}}"><view class="dp-content-text" style="{{'font-size:'+(params.fontsize*2.2+'rpx')+';'+('animation-duration:'+(animationDuration)+';')+('animation-play-state:'+(animationPlayState)+';')+('padding-lift:'+(paddingLift)+';')}}" data-url="{{data[0].hrefurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{''+data[0].title+''}}</view></view></block></block><block a:else><block><swiper class="itemlist" style="position:relative;height:40rpx;" autoplay="true" interval="{{params.scroll*1000}}" vertical="true" circular="{{true}}"><swiper-item class="item" style="{{'font-size:'+(params.fontsize*2.2+'rpx')+';'}}" data-url="{{item.hrefurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="__i0__" a:key="id">{{item.title}}</swiper-item></swiper></block></block></view></view>