<view class="uni-data-pickerview data-v-348bb63d"><scroll-view class="selected-area data-v-348bb63d" scroll-x="true" scroll-y="false" show-scrollbar="{{false}}"><view class="selected-list data-v-348bb63d"><block a:for="{{selected}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.text}}"><view data-event-opts="{{[['tap',[['handleSelect',[index]]]]]}}" class="{{((('selected-item')+' '+'data-v-348bb63d')+' '+((index==selectedIndex)?'selected-item-active':''))}}" onTap="__e"><text class="data-v-348bb63d">{{item.text}}</text></view></block></block></view></scroll-view><view class="tab-c data-v-348bb63d"><block a:for="{{dataList}}" a:for-item="child" a:for-index="i" a:key="i"><block a:if="{{i==selectedIndex}}"><scroll-view class="list data-v-348bb63d" scroll-y="{{true}}"><view data-event-opts="{{[['tap',[['handleNodeClick',['$0',i,j],[[['dataList','',i],['','',j]]]]]]]}}" class="{{((('item')+' '+'data-v-348bb63d')+' '+((!!item.disable)?'is-disabled':''))}}" onTap="__e" a:for="{{child}}" a:for-item="item" a:for-index="j" a:key="j"><text class="item-text data-v-348bb63d">{{item.text}}</text><block a:if="{{selected.length>i&&item.value==selected[i].value}}"><view class="check data-v-348bb63d"></view></block></view></scroll-view></block></block><block a:if="{{loading}}"><view class="loading-cover data-v-348bb63d"><uni-load-more class="load-more data-v-348bb63d" vue-id="78d87124-1" contentText="{{loadMore}}" status="loading" onVueInit="__l"></uni-load-more></view></block><block a:if="{{errorMessage}}"><view class="error-message data-v-348bb63d"><text class="error-text data-v-348bb63d">{{errorMessage}}</text></view></block></view></view>