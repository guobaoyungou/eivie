<view style="width:100%;background-color:#fff;"><view style="width:700rpx;margin:0 auto;padding-bottom:20rpx;"><view data-event-opts="{{[['tap',[['selAddress',['$event']]]]]}}" style="overflow:hidden;font-size:30rpx;font-weight:bold;height:80rpx;line-height:80rpx;" onTap="__e"><view style="width:40rpx;float:left;margin-right:10rpx;"><view style="width:40rpx;margin:0 auto;overflow:hidden;"><image style="width:40rpx;height:40rpx;float:left;margin-top:20rpx;" src="/static/img/address3.png"></image></view></view><view style="width:600rpx;white-space:nowrap;float:left;overflow:hidden;"><text>送至:</text><text>{{mendian_data.m_address?mendian_data.m_address:'无收货地址，请选择'}}</text></view><image style="width:30rpx;height:30rpx;float:right;margin-top:24rpx;" src="/static/img/arrowright.png"></image></view><view style="overflow:hidden;font-size:30rpx;font-weight:bold;height:80rpx;line-height:80rpx;"><view data-event-opts="{{[['tap',[['selMendian',['$event']]]]]}}" style="width:40rpx;float:left;margin-right:10rpx;" onTap="__e"><view style="width:30rpx;margin:0 auto;"><image style="width:30rpx;height:30rpx;float:left;margin-top:24rpx;" src="/static/img/address3.png"></image></view></view><view data-event-opts="{{[['tap',[['selMendian',['$event']]]]]}}" style="width:600rpx;white-space:nowrap;float:left;overflow:hidden;" onTap="__e"><text>{{mendian_data.name?mendian_data.name:'附近暂无门店'}}</text></view><image style="width:30rpx;height:30rpx;float:right;margin-top:24rpx;" data-mobile="{{mendian_data.tel}}" src="/static/img/mobile.png" data-event-opts="{{[['tap',[['callMobile',['$event']]]]]}}" onTap="__e"></image></view><view style="overflow:hidden;font-size:28rpx;"><text>{{mendian_data.address?mendian_data.address:''}}</text></view></view></view>