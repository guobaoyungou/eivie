<view style="width:100%;"><view class="dp-product-itemlist"><view class="dp-product-item" style="{{'background-color:'+(probgcolor)+';'}}" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="id"><view data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" class="item" onTap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><block a:if="{{item.$orig.sellpoint}}"><view class="p5" style="{{'color:'+(item.m0)+';'}}"><text>{{item.$orig.sellpoint}}</text></view></block><block a:if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m1)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m2}}</text></view></block><block a:if="{{item.$orig.show_cost&&item.$orig.price_type!=1}}"><view style="{{'color:'+(item.$orig.cost_color?item.$orig.cost_color:'#999')+';'+('font-size:'+('36rpx')+';')}}"><text style="font-size:24rpx;">{{item.$orig.cost_tag}}</text>{{item.$orig.cost_price}}</view></block><block a:if="{{(!item.$orig.show_sellprice||item.$orig.show_sellprice&&item.$orig.show_sellprice==true)&&(item.$orig.price_type!=1||item.$orig.sell_price>0)&&showprice!='0'}}"><view class="p2"><block a:if="{{item.$orig.price_show_type=='0'||!item.$orig.price_show_type}}"><view><text class="t1" style="{{'color:'+(item.$orig.price_color?item.$orig.price_color:item.m3)+';'}}"><block a:if="{{item.$orig.usd_sellprice}}"><block><text style="font-size:24rpx;">$</text>{{item.$orig.usd_sellprice+''}}<text style="font-size:28rpx;"><text style="font-size:24rpx;padding-right:1px;">￥</text>{{item.$orig.sell_price}}</text><block a:if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block><block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block></block></block><block a:else><block><text style="font-size:24rpx;padding-right:1px;">{{item.$orig.price_tag?item.$orig.price_tag:'￥'}}</text>{{item.$orig.sell_price+''}}<block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block a:if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block><block a:if="{{item.m4}}"><text style="font-size:28rpx;">{{"+"+item.$orig.service_fee+item.m5}}</text></block><block a:if="{{item.m6}}"><text>{{"+"+item.$orig.freezemoney_price+item.m7}}</text></block><block a:if="{{item.$orig.product_type==2&&item.$orig.unit_price&&item.$orig.unit_price>0}}"><text class="t1-m" style="{{'color:'+(item.m8)+';'}}">{{'(约'+item.$orig.unit_price+'元/斤)'}}</text></block><block a:if="{{item.$orig.fwlist&&item.$orig.fwlist.length>0}}"><view class="p6"><view class="p6-m" style="{{('background:rgba('+item.m9+',0.15);color:'+item.m10+';')}}" a:for="{{item.$orig.fwlist}}" a:for-item="fw" a:for-index="fwidx" a:key="fwidx">{{''+fw+''}}</view></view></block></block></block></text></view></block><block a:if="{{item.$orig.price_show_type=='1'||item.$orig.price_show_type=='2'}}"><view><block a:if="{{item.$orig.is_vip=='0'}}"><view><text class="t1" style="{{'color:'+(item.m11)+';'}}"><block a:if="{{item.$orig.usd_sellprice}}"><block><text style="font-size:24rpx;">$</text>{{item.$orig.usd_sellprice+''}}<view style="font-size:28rpx;"><text style="font-size:20rpx;padding-right:1px;">￥</text><text style="font-size:32rpx;">{{item.$orig.sell_price}}</text><block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block></view></block></block><block a:else><block><text style="fon