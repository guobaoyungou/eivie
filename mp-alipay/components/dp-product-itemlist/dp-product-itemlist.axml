nt-size:32rpx;')}}">{{''+item.$orig.sell_price_origin}}</text></text></block></block></text></view></block></view></block><block a:if="{{item.$orig.show_sellprice&&item.$orig.market_price*1>item.$orig.sell_price*1&&showprice=='1'}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block><block a:if="{{item.$orig.juli}}"><text class="t3">{{item.$orig.juli}}</text></block></view></block><block a:if="{{item.$orig.xunjia_text&&item.$orig.price_type==1&&item.$orig.sell_price<=0}}"><view class="p2" style="height:50rpx;line-height:44rpx;"><text class="t1" style="{{'color:'+(item.m22)+';'+('font-size:'+('30rpx')+';')}}">询价</text><block a:if="{{item.$orig.xunjia_text&&item.$orig.price_type==1}}"><block><view class="lianxi" style="{{'background:'+(item.m23)+';'}}" data-lx_name="{{item.$orig.lx_name}}" data-lx_bid="{{item.$orig.lx_bid}}" data-lx_bname="{{item.$orig.lx_bname}}" data-lx_tel="{{item.$orig.lx_tel}}" data-btntype="2" data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" catchTap="__e">{{item.$orig.xunjia_text?item.$orig.xunjia_text:'联系TA'}}</view></block></block></view></block><block a:if="{{item.$orig.price_show&&item.$orig.price_show==1}}"><view style="line-height:46rpx;"><text style="font-size:26rpx;">{{"￥"+item.$orig.sell_putongprice}}</text></view></block><block a:if="{{item.$orig.priceshows&&item.$orig.priceshows.length>0}}"><view><view style="line-height:46rpx;" a:for="{{item.$orig.priceshows}}" a:for-item="item2" a:for-index="index2"><text style="font-size:26rpx;">{{"￥"+item2.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item2.price_show_text}}</text></view></view></block><block a:if="{{showcommission==1&&item.$orig.commission_price>0}}"><view class="couponitem"><view class="f1"><view class="t" style="{{'background:'+('rgba('+item.m24+',0.1)')+';'+('color:'+(item.m25)+';')}}"><text>{{item.m26+item.$orig.commission_price+item.$orig.commission_desc}}</text></view></view></view></block><block a:if="{{item.$orig.merchant_name}}"><view class="p1" style="color:#666;font-size:24rpx;white-space:nowrap;text-overflow:ellipsis;margin-top:6rpx;height:30rpx;line-height:30rpx;font-weight:normal;"><text>{{item.$orig.merchant_name}}</text></view></block><block a:if="{{item.$orig.main_business}}"><view class="p1" style="color:#666;font-size:24rpx;margin-top:4rpx;font-weight:normal;"><text>{{item.$orig.main_business}}</text></view></block><block a:if="{{item.$orig.product_type==3}}"><view class="p3"><view class="p3-1"><text style="overflow:hidden;">{{"手工费: ￥"+(item.$orig.hand_fee?item.$orig.hand_fee:0)}}</text></view></view></block><view class="p3"><block a:if="{{showsales=='1'&&item.$orig.sales>0}}"><view class="p3-1" style="flex-grow:1;text-align:left;"><text style="overflow:hidden;">{{"已售"+item.$orig.sales+"件"}}</text></view></block><block a:if="{{showstock=='1'&&item.$orig.stock>0}}"><view class="p3-1" style="flex-grow:1;text-align:left;"><text style="overflow:hidden;">{{"库存"+item.$orig.stock}}</text></view></block></view><block a:if="{{(showsales!='1'||item.$orig.sales<=0)&&item.$orig.main_business}}"><view style="height:44rpx;"></view></block><block a:if="{{!item.$orig.price_type&&item.$orig.hide_cart!=true}}"><block><block a:if="{{showcart==1}}"><view class="p4" style="{{'background:'+('rgba('+item.m27+',0.1)')+';'+('color:'+(item.m28)+';')}}" data-proid="{{item.$orig[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchTap="__e"><text class="iconfont icon_gouwuche"></text></view></block><block a:if="{{showcart==2}}"><view class="p4" style="{{'background:'+('rgba('+item.m29+',0.1)')+';'+('color:'+(item.m30)+';')}}" data-proid="{{item.$orig[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchTap="__e"><image class="img" src="{{cartimg}}"></image></view></block></block></block><block a:if="{{poshopid&&poshopid>0}}"><view class="p4" style="{{'background:'+('rgba('+$root.m31+',0.1)')+';'+('color:'+($root.m32)+';')}}">