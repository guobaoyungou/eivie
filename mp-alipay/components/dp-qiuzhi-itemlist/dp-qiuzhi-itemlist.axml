<view style="width:100%;"><view class="dp-qiuzhi-itemlist"><view class="item" data-url="{{'/zhaopin/qiuzhi/detail?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="item1 flex"><view class="product-pic"><text class="{{(('status')+' '+('st'+item.has_job))}}">{{item.has_job==1?'在职':'离职'}}</text><image class="image" style="{{('filter: blur('+item.mohu+'px);-webkit-filter: blur('+item.mohu+'px);-moz-filter: blur('+item.mohu+'px)')}}" src="{{item.thumb}}" mode="aspectFit"></image><block a:if="{{item.qianyue_id>0}}"><text class="qianyue">签约保障中</text></block><block a:else><block><block a:if="{{item.apply_id>0}}"><text class="qianyue">认证保障中</text></block><block a:else><text data-event-opts="{{[['tap',[['gorenzheng',['$event']]]]]}}" class="norenzheng" catchTap="__e">未认证</text></block></block></block></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{''+item.name+''}}<block a:if="{{item.sex==1}}"><image src="../../static/img/nan.png"></image></block><block a:if="{{item.sex==2}}"><image src="../../static/img/nv.png"></image></block></view></block><view class="p2"><text>期望薪资：</text><text class="number">{{item.salary}}</text></view><view class="p2"><text>期望岗位：</text><text>{{item.cnames}}</text></view><view class="p2"><text>期望城市：</text><text>{{item.area}}</text></view></view></view><block a:if="{{item.tags&&item.tags.length>0}}"><view class="item2 flex"><view class="tagitem" a:for="{{item.tags}}" a:for-item="wf" a:for-index="wk" a:key="wk">{{wf}}</view></view></block></view></view><block a:if="{{buydialogShow}}"><buydialog vue-id="e74c9610-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></view>