<view class="dp-jidian" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('border-radius:'+(params.borderradius+'px')+';')}}"><view class="f1 flex-y-center" style="{{'background-image:'+('url('+pre_url+'/static/img/dzp/jiangpin.png)')+';'}}"></view><view class="f2" data-url="{{'/activity/yx/jidian?bid='+params.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="text-big">{{data.name}}</view><view>再下<text>{{data.reward_num-data.have_num+"单"}}</text>得<text>{{data.reward_name}}</text>优惠券</view></view><view class="f3"><block a:for="{{data.have_num}}" a:for-item="item" a:for-index="index"><view class="circle circleCheck"><view class="gou"></view></view></block><block a:for="{{data.total_num-data.have_num}}" a:for-item="item" a:for-index="index"><view class="circle"></view></block></view></view>