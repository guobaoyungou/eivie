<view style="width:100%;"><view class="dp-product-normal-item"><view class="item" style="{{('background:'+probgcolor+';'+(showstyle==2?'width:49%;margin-right:'+(index%2==0?'2%':0):showstyle==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%'))}}" data-url="{{'/pagesA/tour/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><view class="p2"><block a:if="{{showprice==1}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.$orig.sell_price+''}}</text></view></block></view><block a:if="{{showsales=='1'&&item.$orig.sales>0}}"><view class="p3">{{"已售"+item.$orig.sales+"件"}}</view></block><block a:if="{{params.style=='2'&&params.nowbuy==1}}"><view class="nowbuy" style="{{'background:'+('rgba('+$root.m1+',0.1)')+';'+('color:'+($root.m2)+';')}}" data-url="{{'/pagesA/tour/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">立即购买</view></block><block a:if="{{showcart==1&&!item.$orig.price_type}}"><view class="p4" style="{{(params.style=='2'&&params.nowbuy==1?'bottom:24rpx;background:rgba('+item.m3+',0.1);color:'+item.m4:'background:rgba('+item.m5+',0.1);color:'+item.m6)}}" data-url="{{'/pagesA/tour/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><text class="iconfont icon_gouwuche"></text></view></block><block a:if="{{showcart==2&&!item.$orig.price_type}}"><view class="p4" style="{{(params.style=='2'&&params.nowbuy==1?'bottom:24rpx;background:rgba('+item.m7+',0.1);color:'+item.m8:'background:rgba('+item.m9+',0.1);color:'+item.m10)}}" data-url="{{'/pagesA/tour/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image class="img" src="{{cartimg}}"></image></view></block></view></view></view></view>