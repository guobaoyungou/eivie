<view style="width:100%;"><view class="dp-product-itemlist"><view class="item" data-url="{{'/activity/yuyue/product?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><block a:if="{{showprice!='0'}}"><view class="p2"><view class="t1" style="{{'color:'+($root.m0)+';'}}">{{item.sell_price}}<text style="font-size:24rpx;padding-left:4rpx;">{{"元/"+item.danwei}}</text></view></view></block><view class="p3"><block a:if="{{showsales=='1'&&item.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.sales}}</text></view></block></view></view></view></view><block a:if="{{buydialogShow}}"><buydialog vue-id="02e2ebf2-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></view>