<view style="width:100%;"><view class="dp-product-item"><view class="item" style="{{(showstyle==2?'width:49%;margin-right:'+(index%2==0?'2%':0):showstyle==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{'/activity/yuyue/product?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block a:if="{{showprice!='0'}}"><view class="p2-1"><view class="t1" style="{{'color:'+($root.m0)+';'}}">{{item.sell_price}}<text style="font-size:24rpx;padding-left:4rpx;">{{"元/"+item.danwei}}</text></view></view></block></view><block a:if="{{showsales=='1'&&item.sales>0}}"><view class="p3">{{"已售"+item.sales}}</view></block></view></view></view><block a:if="{{buydialogShow}}"><buydialog vue-id="1e8f90ae-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" onAddcart="__e" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></view>