<scroll-view class="wxface-dialog" id="facedialog" scroll-y="true"><block a:for="{{facelist}}" a:for-item="item" a:for-index="index"><block a:if="{{index!=24&&index!=35}}"><view class="wxface-face-item" data-face="{{item}}" data-event-opts="{{[['tap',[['selectface',['$event']]]]]}}" onTap="__e"><image class="wxface-face-image" src="{{pre_url+'/static/chat/wxface/'+index+'.png'}}"></image></view></block></block></scroll-view>