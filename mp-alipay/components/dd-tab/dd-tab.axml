<block a:if="{{!scroll}}"><view class="dd-tab" style="{{(isfixed?'position:fixed;':'')}}"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e" a:for="{{itemdata}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m0)+';'}}"></view></view></view></block><block a:else><view class="dd-tab2" style="{{(isfixed?'position:fixed;':'')}}"><scroll-view scroll-x="true"><block a:if="{{ismoney}}"><view class="dd-tab2-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{showstatus[index]}}"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e">{{item.$orig}}<view class="after" style="{{'background:'+(color1?color1:item.m1)+';'}}"></view></view></block></block></view></block><block a:else><view class="dd-tab2-content"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e" a:for="{{itemdata}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m2)+';'}}"></view></view></view></block></scroll-view></view></block>