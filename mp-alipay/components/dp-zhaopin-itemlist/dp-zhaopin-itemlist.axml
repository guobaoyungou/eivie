<view style="width:100%;"><view class="dp-product-zhaopin"><view class="item" data-url="{{'/zhaopin/zhaopin/detail?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="item1 flex"><view class="product-pic"><image class="image" src="{{item.thumb}}" mode="aspectFit"></image><block a:if="{{item.apply_tag}}"><text class="renzheng">担保企业</text></block></view><view class="product-info flex1"><view class="p1">{{item.title}}</view><view class="p2">{{item.salary}}</view><view class="p3"><view class="flex"><block a:if="{{item.cname}}"><view class="tagitem">{{item.cname}}</view></block><block a:if="{{item.num}}"><view class="tagitem">{{item.num+"人"}}</view></block><block a:if="{{item.experience}}"><view class="tagitem">{{item.experience}}</view></block><block a:if="{{item.education}}"><view class="tagitem">{{item.education}}</view></block></view></view><block a:if="{{showaddress&&item.area}}"><view class="p4 flex-s"><image src="../../static/img/address3.png"></image><text>{{item.area}}</text></view></block></view></view><block a:if="{{item.welfare&&item.welfare.length>0}}"><view class="item2 flex"><view class="tagitem" a:for="{{item.welfare}}" a:for-item="wf" a:for-index="wk" a:key="wk">{{wf}}</view></view></block></view></view></view>