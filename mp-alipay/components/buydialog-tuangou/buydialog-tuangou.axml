<view><block a:if="{{isload}}"><view><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-mask" onTap="__e"></view><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title"><image class="img" src="{{product.pic}}" data-url="{{product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="price" style="{{'color:'+($root.m0)+';'}}"><block a:if="{{product.price_dollar}}"><block><text style="margin-right:10rpx;">{{"$"+product.usdsell_price}}</text></block></block>{{'￥'+product.sell_price+''}}<block a:if="{{product.market_price*1>product.sell_price*1}}"><text class="t2">{{"￥"+product.market_price}}</text></block></view><view class="stock">{{"库存："+product.stock}}</view></view><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><view class="op"><block a:if="{{product.stock<=0}}"><block><button class="nostock">库存不足</button></block></block><block a:else><block><block a:if="{{btntype==0}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m1)+';'}}" onTap="__e">立即购买</button></block><block a:if="{{btntype==2}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m2)+';'}}" onTap="__e">确 定</button></block></block></block></view></view></view></block><block a:if="{{loading}}"><loading vue-id="5c2d8396-1" onVueInit="__l"></loading></block></view>