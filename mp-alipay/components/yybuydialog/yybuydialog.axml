<view><block a:if="{{isload}}"><view><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-mask" onTap="__e"></view><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':''))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" onTap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title"><image class="img" src="{{nowguige.pic||product.pic}}" data-url="{{nowguige.pic||product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="price" style="{{'color:'+($root.m0)+';'}}">{{"￥"+nowguige.sell_price+''}}<block a:if="{{nowguige.market_price>nowguige.sell_price}}"><text class="t2">{{"￥"+nowguige.market_price}}</text></block></view><view class="choosename">{{"已选规格: "+nowguige.name}}</view></view><block a:if="{{nowguige.balance_price}}"><view style="{{'width:94%;margin:10rpx 3%;font-size:24rpx;'+('color:'+($root.m1)+';')}}">{{"首付款金额："+nowguige.advance_price+"元，尾款金额："+nowguige.balance_price+"元"}}</view></block><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col" a:for="{{guigedata}}" a:for-item="item" a:for-index="index" a:key="index"><view class="name">{{item.title}}</view><view class="item flex flex-y-center"><block a:for="{{item.items}}" a:for-item="item2" a:for-index="index2" a:key="index2"><view class="{{('item2 '+(ggselected[item.k]==item2.k?'on':''))}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" onTap="__e">{{item2.title}}</view></block></view></view></view><view class="buynum flex flex-y-center"><view class="flex1">{{(yuyue_numtext?yuyue_numtext:'购买数量')+"："}}</view><view class="addnum"><view class="minus"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" onTap="__e"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]],['blur',[['gwcinputblur',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e" onBlur="__e"/><view class="plus"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" onTap="__e"></image></view></view></view><view class="op"><block a:if="{{isfuwu}}"><button data-event-opts="{{[['tap',[['addtobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m2)+';'}}" onTap="__e">确 定</button></block><block a:else><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m3)+';'}}" onTap="__e">确 定</button></block></view></view></view></block><block a:if="{{loading}}"><loading vue-id="abd5b58c-1" onVueInit="__l"></loading></block></view>