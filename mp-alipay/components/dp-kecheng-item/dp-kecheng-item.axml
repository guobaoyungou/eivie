<view style="width:100%;"><view class="dp-product-item"><view class="item" style="{{(showstyle==2?'width:49%;margin-right:'+(index%2==0?'2%':0):showstyle==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{!item.chaptertype||item.chaptertype==1?'/activity/kecheng/product?id='+item[idfield]:'/pagesB/kecheng/lecturermldetail?kcid='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block a:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block><view style="color:#fff;line-height:40rpx;position:absolute;right:4px;bottom:4px;background-color:rgba(0, 0, 0, 0.3);border-radius:12rpx;width:70rpx;"><view style="display:flex;align-items:center;justify-content:center;font-size:22rpx;"><block a:if="{{item.kctype===1}}"><view>图文</view></block><block a:else><block a:if="{{item.kctype===2}}"><view>音频</view></block><block a:else><block a:if="{{item.kctype===3}}"><view>视频</view></block><block a:else><view>综合</view></block></block></block></view></view></view><view class="product-info"><block a:if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block a:if="{{showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><block a:if="{{item.price>0}}"><text style="font-size:24rpx;">￥</text></block>{{item.price==0?'免费':item.price}}</text><block a:if="{{showprice=='1'&&item.market_price*1>item.price*1}}"><text class="t2"><text style="font-size:24rpx;">￥</text>{{item.market_price}}</text></block></view></block></view><block a:if="{{!item.chaptertype||item.chaptertype==1}}"><view class="p3">{{"共"+item.count+"节"}}<block a:if="{{showsales==1&&item.join_num>0}}"><block><text style="margin:0 6rpx;">|</text>{{item.join_num+"人已学习"}}</block></block></view></block></view></view></view><block a:if="{{buydialogShow}}"><buydialog vue-id="f2a193dc-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" onAddcart="__e" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></view>