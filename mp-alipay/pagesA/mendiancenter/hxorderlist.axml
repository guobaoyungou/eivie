<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><checkbox-group class="radio-group" name="gettj" data-event-opts="{{[['change',[['wifiprintChexbox',['$event']]]]]}}" onChange="__e"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['gotodetail',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="order-box" catchTap="__e"><view class="head"><view class="f1" style="display:flex;align-items:center;"><view class="radio" style="{{(item.$orig.checked?'background:'+item.m0+';border:0':'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="f22"><view>{{"订单号："+item.$orig.ordernum}}</view><view style="font-size:24rpx;">{{"提货人："+item.$orig.linkman+"  手机号："+item.$orig.tel+''}}</view><view class="t3" style="font-size:24rpx;">{{item.$orig.createtime}}</view></view></view><view class="f2"><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1}}"><text class="st1">待发货</text></block><block a:if="{{item.$orig.status==2}}"><text class="st2">待收货</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block><block a:if="{{item.$orig.status==8}}"><text class="st8">待提货</text></block></view></view><block a:for="{{item.$orig.prolist}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><text class="t2">{{"共"+item2.num+'件'}}</text></view></view></block></view></block></checkbox-group></view><view style="height:auto;position:relative;"><view style="width:100%;height:110rpx;"></view><view class="{{((('footer')+' '+'flex')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="radio" style="{{(allchecked?'background:'+$root.m1+';border:0':'')}}" catchTap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="text0" catchTap="__e">全选</view><view class="flex1"></view><view class="text1">合计：</view><view class="text2">{{selectedcount}}</view><view data-event-opts="{{[['tap',[['confirm',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" onTap="__e">确认提货</view></view></view><block a:if="{{nomore}}"><nomore vue-id="f8648d94-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="f8648d94-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="f8648d94-3" onVueInit="__l"></loading></block><popmsg vue-id="f8648d94-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>