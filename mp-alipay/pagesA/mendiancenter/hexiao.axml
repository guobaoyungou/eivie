ss="t3"><text class="x1 flex1"></text><text>{{"已退："+order.ogdata.refund_num+"件"}}</text></view></block></view></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block a:if="{{order.status>0&&order.paytypeid!='4'&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block a:if="{{order.status>0&&order.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{order.paytype}}</text></view></block><block a:if="{{type=='gift_bag_goods'}}"><view class="item"><text class="t1">已核销数</text><text class="t2">{{order.ogdata.hexiao_num}}</text></view></block><block a:if="{{type=='gift_bag'}}"><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+order.totalprice}}</text></view></block><block a:if="{{type=='gift_bag'}}"><block><block a:if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{order.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+order.refund_money}}</text></block><block a:if="{{order.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+order.refund_money}}</text></block><block a:if="{{order.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+order.refund_money}}</text></block></view></block><block a:if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{order.refund_reason}}</text></view></block><block a:if="{{order.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{order.refund_checkremark}}</text></view></block></block></block></view><block a:if="{{type=='gift_bag_goods'}}"><view class="orderinfo"><view class="item"><text class="t1">本次核销数</text><text class="t2" style="color:#223;font-weight:bold;font-size:32rpx;">{{order.hxnum}}</text></view></view></block></block></block><block a:if="{{type=='mendian_merge'}}"><block><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><text class="t1">{{order.linkman+" "+order.tel}}</text><block a:if="{{order.freight_type!=1&&order.freight_type!=3}}"><text class="t2">{{"地址："+order.area+order.address}}</text></block><block a:if="{{order.freight_type==1}}"><text class="t2" data-address="{{order.storeinfo.address}}" data-latitude="{{order.storeinfo.latitude}}" data-longitude="{{order.storeinfo.longitude}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e">{{"取货地点："+order.storeinfo.name+" - "+order.storeinfo.address}}</text></block></view></view><view class="product"><view class="content" a:for="{{order.prolist}}" a:for-item="item" a:for-index="idx" a:key="idx"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><block a:if="{{item.ggname}}"><text class="t2">{{item.ggname}}</text></block><block a:if="{{type=='scoreshop'}}"><view class="t3"><text class="x1 flex1"><block a:if="{{item.money_price>0}}"><text>{{"￥"+item.money_price+"+"}}</text></block>{{item.score_price+$root.m16}}</text><text class="x2">{{"×"+item.num}}</text></view></block><block a:else><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><block a:if="{{type!='cycle'}}"><text class="x2">{{"×"+item.num}}</text></block></view></block></view></view></view><block a:if="{{(order.status==3||order.status==2)&&(order.freight_type==3||order.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{order.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{order.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{order.nickname}}</text></view><view class="item"><text class="t1">{{$root.m17+"ID"}}</text><text class="t2">{{order.mid}}</text></view></view><block a:if="{{order.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2">{{order.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block a:if="{{order.status>0&&order.paytypeid!='4'&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block a:if="{{order.status>1&&order.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{$root.m18}}</text></view></block><block a:if="{{order.status==3&&order.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{order.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">配送方式</text><text class="t2">{{order.freight_text}}</text></view><block a:if="{{order.freight_time}}"><view class="item"><text class="t1">{{(order.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{order.freight_time}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+order.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block a:if="{{order.status==0}}"><text class="t2">未付款</text></block><block a:if="{{order.status==1}}"><text class="t2">已付款</text></block><block a:if="{{order.status==2}}"><text class="t2">已发货</text></block><block a:if="{{order.status==3}}"><text class="t2">已收货</text></block><block a:if="{{order.status==4}}"><text class="t2">已关闭</text></block><block a:if="{{order.status==8}}"><text class="t2">待提货</text></block></view><view class="item"><text class="t1">备注</text><text class="t2 red">{{order.message?order.message:'无'}}</text></view></view></block></block><view style="height:140rpx;"></view><view data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" class="btn-add" style="{{'background:'+($root.m19)+';'}}" onTap="__e">立即核销</view></block></block><block a:else><block><view style="height:140rpx;"></view><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="btn-add" style="{{'background:'+($root.m20)+';'}}" onTap="__e">继续核销</view></block></block></block></block><wxxieyi vue-id="4766645a-1" onVueInit="__l"></wxxieyi></view>