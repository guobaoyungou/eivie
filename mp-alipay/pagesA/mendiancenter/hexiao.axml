<view><block a:if="{{isload}}"><block><block a:if="{{!hexiao_status}}"><block><block a:if="{{type=='shop'}}"><block><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><text class="t1">{{order.linkman+" "+order.tel}}</text><block a:if="{{order.freight_type!=1&&order.freight_type!=3}}"><text class="t2">{{"地址："+order.area+order.address}}</text></block><block a:if="{{order.freight_type==1}}"><text class="t2" data-address="{{order.storeinfo.address}}" data-latitude="{{order.storeinfo.latitude}}" data-longitude="{{order.storeinfo.longitude}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e">{{"取货地点："+order.storeinfo.name+" - "+order.storeinfo.address}}</text></block></view></view><view class="product"><view class="content" a:for="{{order.prolist}}" a:for-item="item" a:for-index="idx" a:key="idx"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><block a:if="{{item.ggname}}"><text class="t2">{{item.ggname}}</text></block><block a:if="{{type=='scoreshop'}}"><view class="t3"><text class="x1 flex1"><block a:if="{{item.money_price>0}}"><text>{{"￥"+item.money_price+"+"}}</text></block>{{item.score_price+$root.m0}}</text><text class="x2">{{"×"+item.num}}</text></view></block><block a:else><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><block a:if="{{type!='cycle'}}"><text class="x2">{{"×"+item.num}}</text></block></view></block></view></view></view><block a:if="{{(order.status==3||order.status==2)&&(order.freight_type==3||order.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{order.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{order.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{order.nickname}}</text></view><view class="item"><text class="t1">{{$root.m1+"ID"}}</text><text class="t2">{{order.mid}}</text></view></view><block a:if="{{order.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2">{{order.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block a:if="{{order.status>0&&order.paytypeid!='4'&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block a:if="{{order.status>0&&order.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{order.paytype}}</text></view></block><block a:if="{{order.status>1&&order.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{$root.m2}}</text></view></block><block a:if="{{order.status==3&&order.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{order.collect_time}}</text></view></block></view><view class="orderinfo"><block a:if="{{type=='cycle'}}"><view class="item"><text class="t1">总配送期数</text><text class="t2 red">{{"共"+order.qsnum+"期"}}</text></view></block><block a:if="{{type=='cycle'}}"><view class="item"><text class="t1">当前配送期数</text><text class="t2 red">{{"第"+order.stage.cycle_number+"期"}}</text></view></block><block a:if="{{type=='cycle'}}"><view class="item"><text class="t1">每期数量</text><text class="t2 red">{{"共"+order.stage.num+"件"}}</text></view></block><block a:if="{{type=='scoreshop'}}"><view class="item"><text class="t1">商品金额</text><block a:if="{{order.totalmoney}}"><text class="t2 red">{{"¥"+order.totalmoney+" + "+order.totalscore+$root.m3}}</text></block><block a:else><text class="t2 red">{{order.totalscore+$root.m4}}</text></block></view></block><block a:else><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+order.product_price}}</text></view></block><block a:if="{{order.disprice>0}}"><view class="item"><text class="t1">{{$root.m5+"折扣"}}</text><text class="t2 red">{{"-¥"+order.leveldk_money}}</text></view></block><block a:if="{{order.jianmoney>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+order.manjian_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{order.freight_text}}</text></view><block a:if="{{order.freight_type==1&&order.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+order.freight_price}}</text></view></block><block a:if="{{order.freight_time}}"><view class="item"><text class="t1">{{(order.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{order.freight_time}}</text></view></block><block a:if="{{order.couponmoney>0}}"><view class="item"><text class="t1">{{$root.m6+"抵扣"}}</text><text class="t2 red">{{"-¥"+order.coupon_money}}</text></view></block><block a:if="{{order.scoredk>0}}"><view class="item"><text class="t1">{{$root.m7+"抵扣"}}</text><text class="t2 red">{{"-¥"+order.scoredk_money}}</text></view></block><block a:if="{{type=='scoreshop'}}"><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+order.totalprice+" + "+order.totalscore+$root.m8}}</text></view></block><block a:else><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+order.totalprice}}</text></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{order.status==0}}"><text class="t2">未付款</text></block><block a:if="{{order.status==1}}"><text class="t2">已付款</text></block><block a:if="{{order.status==2}}"><text class="t2">已发货</text></block><block a:if="{{order.status==3}}"><text class="t2">已收货</text></block><block a:if="{{order.status==4}}"><text class="t2">已关闭</text></block><block a:if="{{order.status==8}}"><text class="t2">待提货</text></block></view><block a:if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{order.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+order.refund_money}}</text></block><block a:if="{{order.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+order.refund_money}}</text></block><block a:if="{{order.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+order.refund_money}}</text></block></view></block><block a:if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{order.refund_reason}}</text></view></block><block a:if="{{order.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{order.refund_checkremark}}</text></view></block><view class="item"><text class="t1">备注</text><text class="t2 red">{{order.message?order.message:'无'}}</text></view><block a:if="{{order.field1}}"><view class="item"><text class="t1">{{order.field1data[0]}}</text><text class="t2 red">{{order.field1data[1]}}</text></view></block><block a:if="{{order.field2}}"><view class="item"><text class="t1">{{order.field2data[0]}}</text><text class="t2 red">{{order.field2data[1]}}</text></view></block><block a:if="{{order.field3}}"><view class="item"><text class="t1">{{order.field3data[0]}}</text><text class="t2 red">{{order.field3data[1]}}</text></view></block><block a:if="{{order.field4}}"><view class="item"><text class="t1">{{order.field4data[0]}}</text><text class="t2 red">{{order.field4data[1]}}</text></view></block><block a:if="{{order.field5}}"><view class="item"><text class="t1">{{order.field5data[0]}}</text><text class="t2 red">{{order.field5data[1]}}</text></view></block></view></block></block><block a:if="{{type=='coupon'}}"><block><view class="couponbg" style="{{'background:'+('linear-gradient(90deg,'+$root.m9+' 0%,rgba('+$root.m10+',0.8) 100%)')+';'}}"></view><view class="orderinfo"><view class="topitem"><block a:if="{{order.type==1}}"><view class="f1" style="{{'color:'+($root.m11)+';'}}"><text style="font-size:32rpx;">￥</text><text class="t1">{{order.money}}</text></view></block><block a:else><block a:if="{{order.type==2}}"><view class="f1" style="{{'color:'+($root.m12)+';'}}">礼品券</view></block><block a:else><block a:if="{{order.type==3}}"><view class="f1" style="{{'color:'+($root.m13)+';'}}"><text class="t1">{{order.limit_count}}</text><text class="t2">次</text></view></block><block a:else><block a:if="{{order.type==4}}"><view class="f1" style="{{'color:'+($root.m14)+';'}}">抵运费</view></block></block></block></block><view class="f2"><view class="t1">{{order.couponname}}</view><block a:if="{{order.type==1||order.type==4}}"><view class="t2"><block a:if="{{order.minprice>0}}"><text>{{"满"+order.minprice+"元可用"}}</text></block><block a:else><text>无门槛</text></block></view></block><block a:if="{{order.type==2}}"><view class="t2">礼品券</view></block><block a:if="{{order.type==3}}"><view class="t2">计次券</view></block></view></view><view class="item"><text class="t1">类型</text><block a:if="{{order.type==1}}"><text class="t2">代金券</text></block><block a:if="{{order.type==2}}"><text class="t2">礼品券</text></block><block a:if="{{order.type==3}}"><text class="t2">计次券</text></block><block a:if="{{order.type==4}}"><text class="t2">运费抵扣券</text></block></view><block a:if="{{order.type==3}}"><block><view class="item"><text class="t1">共计次数</text><text class="t2">{{order.limit_count}}</text></view><view class="item"><text class="t1">已使用次数</text><text class="t2">{{order.used_count}}</text></view><block a:if="{{order.limit_perday>0}}"><block><view class="item"><text class="t1">每天限制次数</text><text class="t2">{{order.limit_perday}}</text></view></block></block></block></block><view class="item"><text class="t1">领取时间</text><text class="t2">{{order.createtime}}</text></view><block a:if="{{order.status==1}}"><block><view class="item"><text class="t1">使用时间</text><text class="t2">{{order.usetime}}</text></view></block></block><view class="item flex-col"><text class="t1">有效期</text><text class="t2">{{order.starttime+" 至 "+order.endtime}}</text></view><view class="item flex-col"><text class="t1">使用说明</text><view class="t2 textarea">{{order.usetips}}</view></view></view></block></block><block a:if="{{type=='choujiang'}}"><block><view style="padding:15px 0 15px 0;"><view style="text-align:center;font-size:20px;color:#3cc51f;font-weight:400;margin:0 15%;">核销信息</view></view><view class="orderinfo"><view class="item"><view class="t1">核销类型</view><view class="t2" style="font-size:32rpx;">抽奖奖品</view></view><view class="item"><view class="t1">活动名称</view><view class="t2">{{order.name}}</view></view><view class="item"><view class="t1">奖品名称</view><view class="t2" style="font-size:16px;color:#000;">{{order.jxmc}}</view></view><view class="item"><view class="t1">中奖时间</view><view class="t2">{{$root.m15}}</view></view><block a:if="{{order.formdata}}"><block><view class="item" a:for="{{order.formdata}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t1">{{index}}</text><text class="t2" user-select="{{true}}" selectable="{{true}}">{{item}}</text></view></block></block></view></block></block><block a:if="{{type=='hbtk'}}"><block><view class="product"><view class="content"><view><image src="{{order.pic}}"></image></view><view class="detail"><text class="t1">{{order.name}}</text><view class="t3"><text class="x1 flex1">{{"￥"+order.price}}</text></view><view class="t2"><text>{{"已邀请"+order.yqnum+"人"}}</text></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1 flex-y-center">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{order.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{order.nickname}}</text></view></view><block a:if="{{order.yqlist}}"><view class="orderinfo"><view class="item flex-y-center" style="padding:10rpx 0;"><text class="t1">邀请人员</text><view class="t2" style="overflow:hidden;" user-select="true" selectable="true"><block a:for="{{order.yqlist}}" a:for-item="item" a:for-index="index"><image class="yq_image" src="{{item.headimg}}"></image></block></view></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block a:if="{{order.status>0&&order.price>0&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block a:if="{{order.status>=1&&order.price>0}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{order.paytype}}</text></view></block></view><view class="orderinfo"><block a:if="{{order.price>0}}"><view class="item"><text class="t1">支付金额</text><text class="t2 red">{{"¥"+order.price}}</text></view></block><view class="item"><text class="t1">订单状态</text><block a:if="{{order.status==1}}"><text class="t2">待核销</text></block><block a:if="{{order.status==2}}"><text class="t2">已核销</text></block></view></view></block></block><block a:if="{{type=='shopproduct'||type=='takeaway_order_product'}}"><block><view class="product"><view class="content"><view><image src="{{order.ogdata.pic}}"></image></view><view class="detail"><text class="t1">{{order.ogdata.name}}</text><text class="t2">{{order.ogdata.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+order.ogdata.sell_price}}</text><text class="x2">{{"×"+order.ogdata.num}}</text></view><block a:if="{{order.ogdata.refund_num&&order.ogdata.refund_num>0}}"><view class="t3"><text class="x1 flex1"></text><text>{{"已退："+order.ogdata.refund_num+"件"}}</text></view></block></view></view></view><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}