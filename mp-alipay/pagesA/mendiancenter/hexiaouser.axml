<view><block a:if="{{isload}}"><block><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"核销员列表（共"+count+"人）"}}</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2">{{''+item.nickname+''}}</view></view><view class="f2">已核销订单:<text style="color:red;">{{item.hxnum}}</text></view><view class="f3 btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" onTap="__e">删除</view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="2f8ea46f-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="2f8ea46f-2" onVueInit="__l"></nodata></block><view class="btn-add" style="{{'background:'+($root.m0)+';'}}" data-url="{{'addhexiao?mdid='+mdid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加核销员</view></block></block><popmsg vue-id="2f8ea46f-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="2f8ea46f-4" onVueInit="__l"></loading></block></view>