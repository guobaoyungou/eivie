<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m0}}</text></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block><block a:if="{{item.$orig.status==4}}"><block><block a:if="{{item.$orig.wx_state=='WAIT_USER_CONFIRM'||item.$orig.wx_state=='TRANSFERING'}}"><view data-event-opts="{{[['tap',[['confirm_shoukuan',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m1)+';'}}" onTap="__e">确认收款</view></block><block a:else><block a:if="{{item.$orig.state=='FAIL'}}"><view class="t1">转账失败</view></block><block a:else><view class="t1">处理中</view></block></block></block></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="d983c450-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="d983c450-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="d983c450-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d983c450-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d983c450-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>