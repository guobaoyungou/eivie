<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="info-item" style="height:136rpx;line-height:136rpx;"><view class="t1" style="flex:1;">头像</view><image style="width:88rpx;height:88rpx;" src="{{mendian.pic}}" data-event-opts="{{[['tap',[['uploadHeadimg',['$event']]]]]}}" onTap="__e"></image></view><view class="info-item" data-url="setnickname" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="t1">关联会员</view><view class="t2">{{member.nickname}}</view></view></view><view class="content"><view class="info-item" data-url="setrealname" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="t1">{{$root.m0+"名称"}}</view><view class="t2">{{mendian.name}}</view></view><view class="info-item" data-url="settel" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="t1">手机号</view><view class="t2">{{mendian.tel}}</view></view><view class="info-item" data-url="setsex" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text class="t1">社区名称</text><view class="t2">{{mendian.xqname}}</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="0f78d470-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="0f78d470-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0f78d470-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>