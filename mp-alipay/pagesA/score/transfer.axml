<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="content2"><view class="item2"><view class="f1">转账类型</view></view><view class="item3"><radio-group name="type" data-event-opts="{{[['change',[['typeChange',['$event']]]]]}}" onChange="__e"><label><radio style="transform:scale(0.8);" value="1" checked="{{type==1?true:false}}"></radio>个人到商户</label><label style="margin-left:50rpx;"><radio style="transform:scale(0.8);" value="0" checked="{{type==0?true:false}}"></radio>商户到个人</label></radio-group></view><view class="item4" style="height:1rpx;"></view><view class="item2"><view class="f1">转出账号</view></view><view class="item3"><view class="f2 f2-1"><block a:if="{{type==0}}"><text>{{business.name+"(bid="+business.id+")"}}</text></block><block a:if="{{type==1}}"><text>{{member.name+"(mid="+member.id+")"}}</text></block></view></view><view class="item4" style="height:1rpx;"></view><view class="item2"><view class="f1">转入账号</view></view><view class="item3"><view class="f2 f2-1"><block a:if="{{type==1}}"><text>{{business.name+"(bid="+business.id+")"}}</text></block><block a:if="{{type==0}}"><text>{{member.name+"(mid="+member.id+")"}}</text></block></view></view><view class="item4" style="height:1rpx;"></view><view class="item2"><view class="f1">转赠数量</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="integral" value="" placeholder="请输入转赠数量" placeholder-class="placeholder" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><block a:if="{{paycheck}}"><view class="item2"><view class="f1">支付密码</view></view></block><block a:if="{{paycheck}}"><view class="item3"><view class="f2"><input class="input" type="password" name="paypwd" value="" placeholder="请输入支付密码" placeholder-class="placeholder" data-event-opts="{{[['input',[['getpwd',['$event']]]]]}}" onInput="__e"/></view></view></block><view class="item4" style="{{'color:'+($root.m0)+';'}}"><text style="margin-right:10rpx;">{{"当前"+(type==1?'会员':'商户')+$root.m1+"："+myscore}}</text></view></view><button class="btn" style="{{'background:'+($root.m2)+';'}}" form-type="submit">确 定</button></form></block></block><block a:if="{{loading}}"><loading vue-id="27283040-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="27283040-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>