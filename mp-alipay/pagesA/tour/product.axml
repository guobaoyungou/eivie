<view class="container"><block a:if="{{isload}}"><block><view id="scroll_view_tab0"><view class="swiper-container"><swiper class="swiper" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" onChange="__e"><block a:for="{{product.pics}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{product.pics&&product.pics.length>0}}"><block><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></block></block></swiper><view class="imageCount">{{current+1+"/"+product.pics.length}}</view></view><view class="collage_title"><view class="f1"><view class="t1"><view class="x1">￥</view><view class="x2">{{product.sell_price}}</view></view></view></view><view class="header"><view class="title"><view class="lef"><text>{{product.name}}</text></view><view class="t2" style="font-size:26rpx;color:#777777;"><text>{{"已销售"+product.sales}}</text></view></view></view></view><block a:if="{{pagecontent}}"><view id="scroll_view_tab2"><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">商品描述</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><parse vue-id="7d63cd20-1" content="{{pagecontent}}" onVueInit="__l"></parse></view></view></block><view class="notabbarbot" style="width:100%;height:110rpx;box-sizing:content-box;"></view><block a:if="{{product.status==1}}"><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view style="text-align:center;line-height:100%;width:50%;" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">返回首页</view><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m0)+';'}}" onTap="__e"><text>立即购买</text></view></view></block><block a:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="7d63cd20-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="7d63cd20-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="7d63cd20-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>