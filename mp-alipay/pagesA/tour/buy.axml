<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" onSubmit="__e"><block a:if="{{needaddress==0}}"><view class="address-add"><view class="linkitem"><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view><view class="linkitem"><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view></view></block><block a:else><view class="address-add flex-y-center" data-url="{{'/pagesB/address/address?fromPage=buy&type='+(havetongcheng==1?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><image class="img" src="{{pre_url+'/static/img/address.png'}}"></image></view><block a:if="{{address.name}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block a:if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block a:else><view class="f2 flex1">请选择收货地址</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><view class="buydata"><view class="bcontent"><view class="product"><view class="item flex"><view class="img"><image class="img" src="{{product.pic}}"></image></view><view class="info flex1"><view class="f1">{{product.name}}</view><view class="f3">{{"￥"+product.sell_price}}</view></view></view></view><view class="freight"><view class="f1">配送方式</view><view class="freight-ul"><view class="flex" style="width:100%;overflow-y:hidden;overflow-x:scroll;"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="freight-li" style="{{(freightkey==idx2?'color:'+item.m0+';background:rgba('+item.m1+',0.2)':'')}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeFreight',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view></view><block a:if="{{freightList[freightkey].minpriceset==1&&freightList[freightkey].minprice>0&&freightList[freightkey].minprice*1>product_price*1}}"><view class="freighttips">{{"满"+freightList[freightkey].minprice+"元起送，还差"+$root.g0+"元"}}</view></block><block a:if="{{freightList[freightkey].isoutjuli==1}}"><view class="freighttips">超出配送范围</view></block></view><block a:if="{{freightList[freightkey].pstimeset==1}}"><view class="price"><view class="f1">{{(freightList[freightkey].pstype==1?'取货':'配送')+"时间"}}</view><view data-event-opts="{{[['tap',[['choosePstime',['$event']]]]]}}" class="f2" onTap="__e">{{pstimetext==''?'请选择时间':pstimetext}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view></block><block a:if="{{freightList[freightkey].pstype==1}}"><view class="storeitem"><view class="panel"><view class="f1">取货地点</view><view class="f2" data-freightkey="{{freightkey}}" data-storekey="{{freightList[freightkey].storekey}}" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" onTap="__e"><text class="iconfont icondingwei"></text>{{freightList[freightkey].storedata[freightList[freightkey].storekey].name}}</view></view><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="idx" a:key="idx"><block a:if="{{idx<5||storeshowall==true}}"><view class="radio-item" data-index="{{idx}}" data-event-opts="{{[['tap',[['choosestore',['$event']]]]]}}" catchTap="__e"><view class="f1">{{item.$orig.name+''}}</view><text style="color:#f50;">{{item.$orig.juli}}</text><view class="radio" style="{{(freightList[freightkey].storekey==idx?'background:'+item.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block><block a:if="{{storeshowall==false&&freightList[freightkey].storedata.length>5}}"><view data-event-opts="{{[['tap',[['doStoreShowAll',['$event']]]]]}}" class="storeviewmore" onTap="__e">- 查看更多 -</view></block></view></block><view class="price"><text class="f1">订单金额</text><text class="f2">{{"¥"+product_price}}</text></view><view class="price"><view class="f1"><block a:if="{{freightList[freightkey].pstype==1}}"><text>服务费</text></block><block a:else><text>运费</text></block></view><text class="f2">{{"+¥"+freight_price}}</text></view><block a:if="{{!tour_auth}}"><view class="price" style="overflow:hidden;"><text class="f1">优惠码</text><view data-event-opts="{{[['tap',[['getDecprice',['$event']]]]]}}" class="f2" style="overflow:hidden;" onTap="__e"><view style="font-weight:400;background-color:#f1f1f1;width:400rpx;line-height:70rpx;border-radius:4rpx;float:right;padding:0 20rpx;">{{tour_code}}</view></view><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" style="float:right;width:120rpx;overflow:hidden;" onTap="__e"><image style="width:50rpx;height:50rpx;float:right;" src="{{pre_url+'/static/img/ico-scan.png'}}"></image></view></view></block><block a:if="{{tour_code_decprice!==''}}"><view class="price"><text class="f1">优惠</text><text class="f2">{{'-¥'+tour_code_decprice+''}}</text></view></block><block a:if="{{showemail}}"><view class="form-item"><view class="label">邮箱</view><input class="input" type="text" name="email" placeholder="请输入邮箱" placeholder-style="font-size:28rpx" data-event-opts="{{[['input',[['inputEmail',['$event']]]]]}}" value="{{email}}" onInput="__e"/></view></block><view class="form-item" a:for="{{freightList[freightkey].formdata}}" a:for-item="item" a:for-index="idx" a:key="id"><view class="label">{{item.val1}}<block a:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block a:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"/></block></block><block a:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block a:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form'+idx}}"><label class="flex-y-center" a:for="{{item.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></checkbox-group></block></block><block a:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.val2[editorFormdata[idx]]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block a:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block a:if="{{editorFormdata[idx]}}"><view class="form-imgbox"><view class="form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></view></block></block></view></view></view><view style="width:100%;height:calc(110rpx + env(safe-area-inset-bottom));"></view><view class="footer flex notabbarbot"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}</text></view><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m3+' 0%,rgba('+$root.m4+',0.8) 100%)')+';'}}" form-type="submit">提交订单</button></view></form><block a:if="{{pstimeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidePstimeDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+(freightList[freightkey].pstype==1?'取货':'配送')+"时间"}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hidePstimeDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['pstimeRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.$orig.title}}</view><view class="radio" style="{{(freight_time==item.$orig.value?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></view></block><uni-popup vue-id="cc78388e-1" id="dialogExpress11" type="dialog" ref="__r" data-ref="dialogExpress11" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">输入优惠码</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center" style="margin:20rpx 20rpx;"><view style="font-size:28rpx;color:#555;">优惠码：</view><input style="border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;font-size:28rpx;" type="text" placeholder="请输入优惠码" data-event-opts="{{[['input',[['inputCode',['$event']]]]]}}" onInput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogExpress11Close',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmfahuo11',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="cc78388e-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="cc78388e-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="cc78388e-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="cc78388e-5" onVueInit="__l"></wxxieyi></view>