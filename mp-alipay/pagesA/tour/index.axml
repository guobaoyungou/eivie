<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-url="{{'product?id='+item.id+'&trid='+trid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text></view></view><view class="p3"><view class="t1">已售<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.sales}}</text>件</view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">去购买</text></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="58bb33a6-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="58bb33a6-2" onVueInit="__l"></nodata></block></view></block></block><block a:if="{{loading}}"><loading vue-id="58bb33a6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="58bb33a6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="58bb33a6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>