<view><block a:if="{{isload}}"><block><view style="width:650rpx;margin:0 auto;"><view class="form-item flex-col"><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item['album']}}" data-url="{{item['album']}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{pics?$root.g0:''}}"/></view></view><block a:if="{{!pics}}"><nodata vue-id="16febde2-1" onVueInit="__l"></nodata></block></block></block><dp-tabbar vue-id="16febde2-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>