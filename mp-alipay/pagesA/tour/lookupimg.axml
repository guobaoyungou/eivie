<view><block a:if="{{isload}}"><block><view style="width:650rpx;margin:0 auto;"><view class="form-item flex-col"><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{can_del}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item['img']}}" data-url="{{item['img']}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{pics?$root.g0:''}}"/></view></view><block a:if="{{!pics}}"><nodata vue-id="fdef0054-1" onVueInit="__l"></nodata></block></block></block><block a:if="{{can_del||can_add}}"><view style="position:fixed;bottom:100rpx;right:20rpx;"><block a:if="{{can_add}}"><view class="deal_css" data-url="{{'upimg?orderid='+orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">上传</view></block><block a:if="{{can_del}}"><view data-event-opts="{{[['tap',[['delall',['$event']]]]]}}" class="deal_css" style="margin-top:20rpx;" onTap="__e">全删</view></block></view></block><dp-tabbar vue-id="fdef0054-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>