<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="b318b3da-1" itemdata="{{['全部','待确认','已确认','已驳回','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><view class="item" data-url="{{'formdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.title}}</text><block a:for="{{item.formcontent}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{!item2.hidden&&item2.val12&&item2.key!='upload'&&item2.key!='upload_file'&&item2.key!='upload_video'&&item2.key!='upload_pics'}}"><text class="{{(('t2')+' '+(item2.key=='separate'?'title':''))}}">{{''+item2.val1+"："+item['form'+index2]+''}}<block a:if="{{item.show_distance&&item2.key=='map'}}"><view class="t2" data-latitude="{{item.adr_lat}}" data-longitude="{{item.adr_lon}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image>{{'距离您'+item.distance+''}}</view></block></text></block></block><block a:if="{{item.custom_number}}"><text class="t2">{{item.custom_number_text+"："+item.custom_number}}</text></block><text class="t2">{{"提交时间："+item.createtime}}</text></view><view class="f2"><block a:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待确认</text></block><block a:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block a:if="{{item.status==1}}"><text class="t1" style="color:green;">已确认</text></block><block a:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="b318b3da-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="b318b3da-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="b318b3da-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="b318b3da-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="b318b3da-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="b318b3da-7" onVueInit="__l"></wxxieyi></view>