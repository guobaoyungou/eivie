<view class="container"><block a:if="{{isload}}"><block><block a:if="{{queryform.desc}}"><view class="content"><view class="item" style="display:block;"><parse vue-id="2bfb8563-1" content="{{queryform.desc}}" onVueInit="__l"></parse></view></view></block><block a:if="{{queryform.custom_search==0}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view></block><block a:if="{{queryform.custom_search==1}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{queryform.search_title}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view><text data-event-opts="{{[['tap',[['searchKeyword',['$event']]]]]}}" style="width:80rpx;height:40rpx;text-align:center;" onTap="__e">确定</text></view></block><view class="content" id="datalist"><view class="item" style="{{'background:'+(item.background_color)+';'}}" data-url="{{'formdetail?id='+item.id+'&op=view'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><block a:if="{{queryform.show_name==1}}"><text class="t1">{{item.title}}</text></block><block a:if="{{item.form0&&item.form0_key!='upload_file'&&item.form0_show==1}}"><block><block a:if="{{item.form0_key!='upload'&&item.form0_key!='upload_pics'}}"><text class="t2">{{item.form0_val+": "+item.form0}}</text></block><block a:else><view class="t2"><block a:for="{{item.form0}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item.form0_key=='upload_pics'}}"><block><image style="width:50px;height:auto;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block><block a:else><block><image style="width:50px;height:auto;" src="{{item.form0}}" mode="widthFix" data-url="{{item.form0}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block></block></view></block></block></block><block a:if="{{item.form1&&item.form1_key!='upload_file'&&item.form1_show==1}}"><block><block a:if="{{item.form1_key!='upload'&&item.form1_key!='upload_pics'}}"><text class="t2">{{item.form1_val+": "+item.form1}}</text></block><block a:else><view class="t2"><block a:for="{{item.form1}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item.form1_key=='upload_pics'}}"><block><image style="width:50px;height:auto;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block><block a:else><block><image style="width:50px;height:auto;" src="{{item.form1}}" mode="widthFix" data-url="{{item.form1}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block></block></view></block></block></block><block a:if="{{item.form2&&item.form2_key!='upload_file'&&item.form2_show==1}}"><block><block a:if="{{item.form2_key!='upload'&&item.form2_key!='upload_pics'}}"><text class="t2">{{item.form2_val+": "+item.form2}}</text></block><block a:else><view class="t2"><block a:for="{{item.form2}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item.form2_key=='upload_pics'}}"><block><image style="width:50px;height:auto;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block><block a:else><block><image style="width:50px;height:auto;" src="{{item.form2}}" mode="widthFix" data-url="{{item.form2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block></block></view></block></block></block><block a:if="{{item.form3&&item.form3_key!='upload_file'&&item.form3_show==1}}"><block><block a:if="{{item.form3_key!='upload'&&item.form3_key!='upload_pics'}}"><text class="t2">{{item.form3_val+": "+item.form3}}</text></block><block a:else><view class="t2"><block a:for="{{item.form3}}" a:for-item="item2" a:for-index="index2" a:key="index2"><block a:if="{{item.form3_key=='upload_pics'}}"><block><image style="width:50px;height:auto;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block><block a:else><block><image style="width:50px;height:auto;" src="{{item.form3}}" mode="widthFix" data-url="{{item.form3}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></block></block></view></block></block></block><block a:if="{{item.show_distance}}"><block data-latitude="{{item.adr_lat}}" data-longitude="{{item.adr_lon}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><view class="t2">{{'距离您'+item.distance+''}}<image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image>点击导航</view></block></block><block a:if="{{queryform.show_time==1}}"><text class="t2"><block a:if="{{item.member&&item.member.realname}}"><text>{{item.member.realname}}</text></block><block a:else><text>{{item.member.nickname}}</text></block>{{'时间：'+item.createtime+''}}</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="2bfb8563-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="2bfb8563-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="2bfb8563-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="2bfb8563-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2bfb8563-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="2bfb8563-7" onVueInit="__l"></wxxieyi></view>