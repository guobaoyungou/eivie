<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="48035955-1" itemdata="{{['全部','待确认','已确认','已驳回','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:90rpx;"></view><view class="content" id="datalist"><view class="item" data-url="{{'formdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.title}}</text><text class="t2">{{"提交时间："+item.createtime}}</text></view><view class="f2"><block a:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待确认</text></block><block a:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block a:if="{{item.status==1}}"><text class="t1" style="color:green;">已确认</text></block><block a:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="48035955-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="48035955-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="48035955-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="48035955-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="48035955-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>