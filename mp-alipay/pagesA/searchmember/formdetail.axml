<view class="container" style="{{(form.form_query==1&&form.form_query_bgcolor?'min-height:100vh;background-color:'+form.form_query_bgcolor:'')}}"><block a:if="{{isload}}"><block><view class="orderinfo" style="{{(form.form_query==1&&form.form_query_bgcolor?'background-color:'+form.form_query_bgcolor+';color:'+form.form_query_txtcolor+'!important':'')}}"><view class="item"><text class="t1">标题</text><text class="t2">{{detail.title}}</text></view><view class="item" a:for="{{formcontent}}" a:for-item="item" a:for-index="index" a:key="index"><text class="t1">{{item.val1}}</text><block a:if="{{item.key!='upload'}}"><text class="t2">{{detail['form'+index]}}</text></block><block a:else><view class="t2"><image style="width:50px;" src="{{detail['form'+index]}}" mode="widthFix" data-url="{{detail['form'+index]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block></view><view class="item"><text class="t1">提交时间</text><text class="t2">{{detail.createtime}}</text></view><view class="item"><text class="t1">审核状态</text><block a:if="{{detail.status==0&&(!detail.payorderid||detail.paystatus==1)}}"><text class="t2" style="color:#88e;">待确认</text></block><block a:if="{{detail.status==0&&detail.payorderid&&detail.paystatus==0}}"><text class="t2" style="color:red;">待支付</text></block><block a:if="{{detail.status==1}}"><text class="t2" style="color:green;">已确认</text></block><block a:if="{{detail.status==2}}"><text class="t2" style="color:red;">已驳回</text></block></view><block a:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block><block a:if="{{detail.payorderid}}"><block><view class="item"><text class="t1">付款金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype}}</text></view><view class="item"><text class="t1">付款状态</text><block a:if="{{detail.paystatus==1&&detail.isrefund==0}}"><text class="t2" style="color:green;">已付款</text></block><block a:if="{{detail.paystatus==1&&detail.isrefund==1}}"><text class="t2" style="color:red;">已退款</text></block><block a:if="{{detail.paystatus==0}}"><text class="t2" style="color:red;">未付款</text></block></view><block a:if="{{detail.paystatus>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block></block></block></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="577212c4-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="577212c4-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="577212c4-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>