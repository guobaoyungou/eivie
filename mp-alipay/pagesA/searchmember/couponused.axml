<view class="container"><block a:if="{{isload}}"><block><view class="content flex" data-id="{{item.$orig.id}}" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" class="item" onTap="__e"><view class="f1"><view class="name">{{"次卡名称："+item.$orig.couponname}}</view><view class="f2"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{"使用时间："+item.m0}}</text></view></view></view></view><block a:if="{{nodata}}"><nodata vue-id="b2d56ee0-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="b2d56ee0-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="b2d56ee0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="b2d56ee0-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="b2d56ee0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>