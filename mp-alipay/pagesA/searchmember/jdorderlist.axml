<view class="container"><block a:if="{{isload}}"><block><view><view class="search-container"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="search-text" placeholder="搜索商家" placeholder-style="color:#aaa;font-size:24rpx" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" onConfirm="__e"/></view></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="order-box" data-url="{{'jdorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.fwtype==1}}"><view><block a:if="{{item.status==3}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已完成</view></block><block a:if="{{item.status==1}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image><text class="t1">等待客户上门</text></view></block><block a:if="{{item.status==2}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image><text class="t1" style="margin-left:10rpx;">服务中</text></view></block></view></block><block a:else><block a:if="{{item.fwtype==2}}"><view><block a:if="{{item.status==3}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已完成</view></block><block a:else><block a:if="{{item.status==1}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>期望上门时间<text class="t1">{{item.orderinfo.yydate}}</text></view></block><block a:else><block a:if="{{item.status==2}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已到达，服务中</view></block></block></block></view></block></block><view class="flex1"></view><view class="f2"><text class="t1">{{item.ticheng}}</text>元</view></view><view class="content"><view class="f2"><view class="t1">{{item.binfo.name}}</view><view class="t2">{{item.binfo.address}}</view><view class="t3">{{item.orderinfo.address}}</view><view class="t2">{{item.orderinfo.area}}</view></view><view class="f3" data-index="{{index}}" data-event-opts="{{[['tap',[['daohang',['$event']]]]]}}" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/ps_daohang.png'}}"></image></view></view><block a:if="{{item.fwtype==1}}"><view class="op"><block a:if="{{item.status==1}}"><view class="t1">已接单，待顾客上门</view></block><block a:if="{{item.status==2}}"><view class="t1">顾客已到达</view></block><block a:if="{{item.status==3}}"><view class="t1">已完成</view></block><view class="flex1"></view></view></block><block a:else><block a:if="{{item.fwtype==2}}"><view class="op"><block a:if="{{item.status==1}}"><view class="t1">已接单，等待上门</view></block><block a:if="{{item.status==2}}"><view class="t1">{{"已到达，共用时"+item.useminute+"分钟"}}</view></block><block a:if="{{item.status==3}}"><view class="t1">已完成</view></block><view class="flex1"></view></view></block></block></view></block><block a:if="{{nomore}}"><nomore vue-id="82a969ba-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="82a969ba-2" onVueInit="__l"></nodata></block></view></block></block><block a:if="{{loading}}"><loading vue-id="82a969ba-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="82a969ba-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="82a969ba-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><view style="display:none;">{{timestamp}}</view><wxxieyi vue-id="82a969ba-6" onVueInit="__l"></wxxieyi></view>