<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><view class="f2">{{mytongzheng}}<block a:if="{{tongzheng_transfer}}"><view class="btn-mini" data-url="/pagesA/my/tongzhengtransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转账</view></block></view></view></view><view class="myscore" style="{{'background:'+($root.m2)+';'}}"><view class="f1">{{"待释放"+$root.m3}}</view><view class="f2">{{release_total}}</view><view class="f3" data-url="/pagesA/my/tongzhengorderlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>释放记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block a:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="b6589e16-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="b6589e16-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="b6589e16-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="b6589e16-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="b6589e16-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>