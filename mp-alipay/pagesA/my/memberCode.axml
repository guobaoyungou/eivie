<view><block a:if="{{isload}}"><view class="main"><view class="cardtop" style="{{('background:rgba('+$root.m0+',0.2);')}}"><image src="{{userinfo.headimg}}"></image><text>{{userinfo.nickname}}</text></view><block a:if="{{set.code_type==1||set.code_type==2}}"><view class="codeimg mt50"><image class="barcodeimg" src="{{userinfo.member_barcode_img}}"></image><view>{{userinfo.tel?userinfo.tel:userinfo.member_code}}</view></view></block><block a:if="{{set.code_type==0||set.code_type==2}}"><view class="codeimg"><image src="{{userinfo.member_code_img}}"></image><view>{{userinfo.member_code}}</view></view></block><block a:if="{{showmeberinfo&&tablist.length>0}}"><view class="moneybox"><view class="moneytab" data-url="{{item.path}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{tablist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="txt">{{item.name}}</view><view class="money">{{item.tag+item.value}}</view></view></view></block><block a:if="{{set.iswxpay==1}}"><view data-event-opts="{{[['tap',[['wxpay',['$event']]]]]}}" class="wxpay" onTap="__e"><image class="wxicon" src="{{pre_url+'/static/img/wxpay2.png'}}"></image><text>使用微信支付</text></view></block></view></block><block a:if="{{loading}}"><loading vue-id="c2112294-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="c2112294-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="c2112294-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>