<view class="container"><block a:if="{{isload}}"><block><view class="content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1" style="width:100%;"><view class="t1">{{item.$orig.proname}}</view><block a:if="{{item.$orig.status>=0}}"><block><block a:if="{{item.$orig.allmoney||item.$orig.allscore||item.$orig.allcommission}}"><view style="line-height:50rpx;"><block a:if="{{item.$orig.status==1}}"><block><block a:if="{{item.$orig.return_type&&item.$orig.return_type==1&&item.$orig.return_day>=2}}"><text class="t1">总返现：</text></block><block a:else><text class="t1">返现：</text></block></block></block><block a:if="{{item.$orig.status==0}}"><text class="t1">预估返现：</text></block><block a:if="{{item.$orig.allmoney>0}}"><block><text class="t1">{{item.$orig.allmoney+item.m0}}</text></block></block><block a:if="{{item.$orig.allscore>0}}"><block><text class="t1" style="margin-left:10rpx;">{{item.$orig.allscore+item.m1}}</text></block></block><block a:if="{{item.$orig.allcommission>0}}"><block><text class="t1" style="margin-left:10rpx;">{{item.$orig.allcommission+item.m2}}</text></block></block></view></block><block a:else><view style="line-height:50rpx;"><block a:if="{{item.$orig.status==1}}"><text class="t1">返现：</text></block><block a:if="{{item.$orig.status==0}}"><text class="t1">预估返现：</text></block><block><text class="t1">{{"0"+item.m3}}</text></block><block><text class="t1" style="margin-left:10rpx;">{{"0"+item.m4}}</text></block><block><text class="t1" style="margin-left:10rpx;">{{"0"+item.m5}}</text></block></view></block><block a:if="{{item.$orig.status==1&&item.$orig.return_type&&item.$orig.return_type==1&&item.$orig.return_day>=2}}"><block><block a:if="{{item.$orig.allmoney||item.$orig.allscore||item.$orig.allcommission}}"><view style="line-height:50rpx;"><text class="t1" style="color:#03bc01;">已返现：</text><block a:if="{{item.$orig.allmoney>0}}"><block><text class="t1" style="color:#03bc01;">{{item.$orig.sendmoney+item.m6}}</text></block></block><block a:if="{{item.$orig.allscore>0}}"><block><text class="t1" style="margin-left:10rpx;color:#03bc01;">{{item.$orig.sendscore+item.m7}}</text></block></block><block a:if="{{item.$orig.allcommission>0}}"><block><text class="t1" style="margin-left:10rpx;color:#03bc01;">{{item.$orig.sendcommission+item.m8}}</text></block></block></view></block><block a:if="{{item.$orig.return_remark}}"><view style="line-height:40rpx;"><text class="t1" style="color:red;">{{item.$orig.return_remark}}</text></view></block></block></block><block a:if="{{item.$orig.otherremark}}"><view style="line-height:40rpx;"><text class="t1">{{item.$orig.otherremark}}</text></view></block></block></block><block a:if="{{item.$orig.create_time}}"><text class="t2">{{item.$orig.create_time}}</text></block><block a:if="{{item.$orig.tipinfor}}"><text class="t2" style="color:#ff8758;">{{item.$orig.tipinfor}}</text></block></view><view class="f2" style="width:120rpx;flex:unset;"><block a:if="{{item.$orig.status==1}}"><block><block a:if="{{item.$orig.return_type&&item.$orig.return_type==1&&item.$orig.return_day>=2}}"><block><block a:if="{{item.$orig.return_status==1}}"><text class="t1" style="color:#ff8758;">发放中</text></block><block a:else><block a:if="{{item.$orig.return_status==-2}}"><text class="t1" style="color:#999;">已停止</text></block><block a:else><block a:if="{{item.$orig.return_status==-1}}"><text class="t1" style="color:#bbb;">已取消</text></block></block></block></block></block><block a:else><text class="t1">已发放</text></block></block></block><block a:if="{{item.$orig.status==0}}"><block><block a:if="{{item.$orig.yx_invite_cashback_commission_day&&item.$orig.back_commission_day==0}}"><text class="t1" style="color:red;">未发放</text></block><block a:if="{{!item.$orig.yx_invite_cashback_commission_day}}"><text class="t1" style="color:red;">未发放</text></block></block></block><block a:if="{{item.$orig.status==-1}}"><text class="t1" style="color:#999;">已失效</text></block><block a:if="{{item.$orig.status==2}}"><view><block a:if="{{item.$orig.receive_st==0}}"><view data-event-opts="{{[['tap',[['receiveinit',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m9)+';'}}" onTap="__e">领取</view></block><block a:if="{{item.$orig.receive_st==1}}"><view class="btn1" style="background-color:#999;">今日已领</view></block></view></block></view></view></block></view><block a:if="{{nodata}}"><nodata vue-id="5facdb4a-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="5facdb4a-2" onVueInit="__l"></nomore></block><block a:if="{{showvideo}}"><view class="video-container" style="{{'height:'+(pageHeight+'px')+';'}}"><block a:if="{{showVideoClose}}"><view data-event-opts="{{[['tap',[['videoClose',['$event']]]]]}}" class="close" onTap="__e">关闭</view></block><video class="video" style="{{'height:'+(pageHeight+'px')+';'}}" id="video" autoplay="{{true}}" controls="{{false}}" src="{{video_url}}" data-event-opts="{{[['timeUpdate',[['timeupdate',['$event']]]]]}}" onTimeUpdate="__e"></video></view></block></block></block><block a:if="{{loading}}"><loading vue-id="5facdb4a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5facdb4a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5facdb4a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>