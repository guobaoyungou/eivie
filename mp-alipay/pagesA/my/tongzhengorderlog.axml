<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'/pagesA/my/tongzhengreleaselog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><text class="t1">{{"订单ID:"+item.orderid}}</text><text class="t2">{{"总数量："+item.tongzheng}}</text><text class="t2">{{"剩余："+item.remain}}</text><text class="t2">{{"状态："+item.status_str}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block><text class="t1">{{"已释放："+item.release_num}}</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="5bbc7a79-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="5bbc7a79-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="5bbc7a79-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5bbc7a79-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5bbc7a79-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>