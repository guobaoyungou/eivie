<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{"释放前数量"+item.tongzheng}}</text><text class="t2">{{"释放比例"+item.release_bili+"%"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block><text class="t1">{{item.release_num}}</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="37d6591c-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="37d6591c-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="37d6591c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="37d6591c-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="37d6591c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>