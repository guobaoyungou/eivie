<view class="container"><block a:if="{{isload}}"><block><view class="tongji flex-y-center " style="{{'background:'+(color1?color1:$root.m0)+';'}}"><view><view class="price">{{set.give_money}}</view><view>{{jiangli_text}}</view></view><block a:if="{{paidui_money_show}}"><view><view class="price">{{set.sy_money}}</view><view>{{paidui_text}}</view></view></block><block a:if="{{set.activity_rules}}"><view data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" style="position:absolute;right:14rpx;top:10rpx;font-size:26rpx;" onTap="__e">活动规则</view></block></view><view class="tab tab_top"><dd-tab vue-id="97f46c00-1" itemdata="{{itemlabel}}" itemst="{{itemvalue}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view class="height130"></view><view class="order-content "><block a:if="{{st==2}}"><block><view class="order-box" a:for="{{$root.l0}}" a:for-item="item1" a:for-index="index" a:key="index"><view class="head"><view class="f1">{{"订单号："+item1.$orig.ordernum}}</view><view class="flex1"></view></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item1.$orig.bname}}</text></view><view class="detail">拆单金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{item1.$orig.money}}</text></view><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m2)}}">{{item1.$orig.free_money}}</text></view><view class="detail">释放所需单数：<text class="t1" style="{{('color:'+$root.m3)}}">{{item1.$orig.order_count+"单"}}</text></view><view class="detail"><text class="t1">{{"创建时间："+item1.m4}}</text></view></view></view></block></block><block a:else><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.$orig.statusLabel}}</text></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item.$orig.bname}}</text></view><block a:if="{{item.$orig.title}}"><view class="detail">排队名称：<text class="t1" style="{{('color:'+item.m5)}}">{{item.$orig.title}}</text></view></block><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m6)}}">{{item.$orig.money}}</text></view><block a:if="{{set.back_money_type==1}}"><view class="detail">路上金额：<text class="t1" style="{{('color:'+$root.m7)}}">{{item.$orig.addup_money}}</text></view></block><block a:if="{{!set.back_money_type||set.back_money_type&&item.$orig.status==1}}"><view class="detail">已获金额：<text class="t1" style="{{('color:'+item.m8)}}">{{item.$orig.money_give}}</text></view></block><block a:if="{{item.$orig.queue_no}}"><view class="detail">当前排名：<text class="t1" style="{{('color:'+item.m9)}}">{{item.$orig.queue_noLabel}}</text></view></block><view class="detail"><text class="t1">{{"排队时间："+item.$orig.createtimeFormat}}</text></view></view><view class="operate flex-y-center flex-x-bottom "><block a:if="{{item.$orig.status==0&&set.quit_wxhb==1&&item.$orig.money_quit_hb>0}}"><view class="button" style="{{'background:'+(item.m10)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitWithHb',['$event']]]]]}}" catchTap="__e">{{quit_wxhb_text}}</view></block><block a:if="{{item.$orig.status==0&&set.quit_score==1}}"><view class="button" style="{{'background:'+(item.m11)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-id="{{item.$orig.id}}" data-givescore="{{item.$orig.give_score}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitScore',['$event']]]]]}}" catchTap="__e">{{"退出返"+item.m12}}</view></block><block a:if="{{item.$orig.status==0&&set.quit_random_score==1}}"><view class="button" style="{{'background:'+(item.m13)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitRandomScore',['$event']]]]]}}" catchTap="__e">{{quit_random_score_text}}</view></block><block a:if="{{item.$orig.status==0&&set.quit_back_price_st==1&&item.$orig.quit_back_price_st==1}}"><view class="button" style="{{'background:'+(item.m14)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-backprice="{{item.$orig.give_back_price}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitBackPrice',['$event']]]]]}}" catchTap="__e">退出转每日补贴</view></block><block a:if="{{item.$orig.status==0&&set.quit_freeze_money==1}}"><view class="button" style="{{'background:'+(item.m15)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-id="{{item.$orig.id}}" data-givemoney="{{item.$orig.give_freeze_money}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitFreezeMoney',['$event']]]]]}}" catchTap="__e">{{"退出返"+item.m16}}</view></block></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="97f46c00-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="97f46c00-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{prizeVisible}}"><view data-event-opts="{{[['touchMove',[['e0',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchTouchMove="__e" onMousewheel="__e"><view class="hongbao-view"><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></i