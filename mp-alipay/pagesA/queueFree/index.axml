ic/img/close2.png'}}"></image></view></view><uni-popup onChange="__e" vue-id="97f46c00-5" ref="__r" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" onVueInit="__l"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{randomScore}}</text><text class="unit">{{$root.m17}}</text></view><view class="title">{{'奖励将发放到个人'+$root.m18+'账户'}}</view><view data-event-opts="{{[['tap',[['randomScoreclose',['$event']]]]]}}" class="cl-button" onTap="__e"><text>确定</text></view></view></view></view></uni-popup></view></block><block a:if="{{backPriceVisible}}"><view data-event-opts="{{[['touchMove',[['e2',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchTouchMove="__e" onMousewheel="__e"><view class="hongbao-view"><view class="wrap" a:for="{{3}}" a:for-item="item" a:for-index="index"><view data-event-opts="{{[['tap',[['receiveBackPrice',['$event']]]]]}}" class="envelope" onTap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view data-event-opts="{{[['tap',[['quitBackpriceclose',['$event']]]]]}}" class="hongbao-view-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup onChange="__e" vue-id="97f46c00-6" ref="__r" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" onVueInit="__l"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{give_back_price}}</text></view><view class="title">奖励将发放到个人待返金额中</view><view data-event-opts="{{[['tap',[['quitBackpriceclose',['$event']]]]]}}" class="cl-button" onTap="__e"><text>确定</text></view></view></view></view></uni-popup></view></block><uni-popup vue-id="97f46c00-7" type="center" ref="__r" data-ref="popupMiandan" onVueInit="__l"><view class="popup-miandan-content"><view class="popup-miandan-price flex"><view class="price-num-text popup-color-text">{{set.give_money}}</view><view class="right-text popup-color-text">元</view></view><view class="popup-leiji-miandan popup-color-text">累计免单金额</view><view class="popup-guishu flex-col"><view class="top-text">{{set.popup_text1}}</view><view class="bottom-text">{{set.popup_text2}}</view></view><image src="{{pre_url+'/static/img/miandanpopupbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupMiandanclose',['$event']]]]]}}" class="popupMiandan-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup><block a:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">活动规则</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" onTap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{set.activity_rules}}</text></view></view></view></view></block><fireworks vue-id="97f46c00-8" fireworksShow="{{fireworksShow}}" onVueInit="__l"></fireworks><block a:if="{{loading}}"><loading vue-id="97f46c00-9" onVueInit="__l"></loading></block><dp-tabbar vue-id="97f46c00-10" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="97f46c00-11" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>