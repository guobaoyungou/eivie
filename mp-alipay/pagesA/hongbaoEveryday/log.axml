<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的补贴</view><view class="f2">{{money}}<block a:if="{{withdraw}}"><view class="btn-mini" data-url="withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></block></view></view><dd-tab vue-id="31cd491a-1" itemdata="{{['补贴记录','提现记录']}}" itemst="{{['0','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content" id="datalist"><block a:if="{{st==0}}"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block a:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block><block a:if="{{st==2}}"><block><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><view class="t1">{{"提现金额:"+item.$orig.money+'元'}}<block a:if="{{item.$orig.score>0}}"><text style="margin-left:10rpx;">{{item.m1+":"+item.$orig.score}}</text></block></view><text class="t2">{{item.$orig.createtime}}</text></view><view class="f3"><block a:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block a:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block a:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block a:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="31cd491a-2" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="31cd491a-3" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="31cd491a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="31cd491a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="31cd491a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>