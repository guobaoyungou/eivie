<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的额度</view><view class="f2">{{hongbao_everyday_edu}}</view></view><block a:if="{{scoreWithdraw}}"><view class="myscore" style="{{'background:'+($root.m1)+';'}}"><view class="f1">{{"允提"+$root.m2}}</view><view class="f2">{{myscore2}}<view class="btn-mini" data-url="/pagesExt/my/scoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></view></view></block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block a:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="09bf4108-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="09bf4108-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="09bf4108-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="09bf4108-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="09bf4108-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>