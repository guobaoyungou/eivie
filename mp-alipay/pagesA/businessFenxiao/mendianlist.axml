<view class="container"><block a:if="{{isload}}"><view><view class="bg-view"></view><view class="content-view flex-col"><view class="info-view"><view class="image-view"><image src="{{member.headimg}}"></image></view><view class="info-view-text flex-col"><view class="title-text">{{member.nickname}}</view><view class="inventory-text">{{member.tel}}</view></view></view><view class="content-view-data flex-col"><view class="title-text">门店列表</view><view class="options-view flex-bt" data-url="{{'/pagesA/businessFenxiao/mendian?bid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="image-view"><image src="{{item.logo}}"></image></view><view class="info-view-data flex-col"><view class="title-text">{{item.name}}</view><view class="inventory-text">{{item.stage}}</view></view></view></view></view></view></block><block a:if="{{nodata}}"><nodata vue-id="f2706dca-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="f2706dca-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="f2706dca-3" onVueInit="__l"></loading></block></view>