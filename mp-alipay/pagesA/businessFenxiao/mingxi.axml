<view><block a:if="{{isload}}"><block><view class="search-view flex-xy-center"><view class="input-view flex-aw"><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time1}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view><view>--</view><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time2}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view></view></view><view class="content-view flex-col"><view class="options-view flex-bt" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="info-view flex-col"><view class="title-text">门店营业额</view><view class="inventory-text flex-bt"><view class="price">{{item.yeji_total}}</view><view class="price">{{"补贴："+item.butie_yeji}}</view><view class="time">{{item.jiesuan_time}}</view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="dfc1243e-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="dfc1243e-2" onVueInit="__l"></nodata></block></view></block></block></view>