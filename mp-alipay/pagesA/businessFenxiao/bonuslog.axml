<view class="container"><block a:if="{{isload}}"><block><view class="search-view flex-xy-center"><view class="input-view flex-aw"><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time1}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view><view>--</view><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time2}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view></view></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content content-view flex-col"><block><view class="item"><view class="f2"><view class="t1"><view class="item2"><text class="x1">{{"收入合计："+total}}</text></view></view></view></view><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text>{{item.$orig.name}}</text></view><view class="f2"><view class="t1"><view class="item2"><text class="x1">{{item.m0}}</text></view></view><view class="t2"><text class="x1">{{"+"+item.$orig.bonus}}</text></view></view></view></block></view></block></block><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{nodata}}"><nodata vue-id="176fb7c2-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="176fb7c2-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="176fb7c2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="176fb7c2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="176fb7c2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>