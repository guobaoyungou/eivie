<view class="container"><block a:if="{{isload}}"><block><block a:if="{{show_rebate}}"><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="top-data-list flex flex-y-center"><view class="top-column"><view class="data-options flex-col"><view class="title-text">{{"待返"+$root.m1}}</view><view class="num-text">{{info.un_send_money}}</view></view><view class="data-options flex-col" style="margin:30rpx 0;"><view class="line-class-width"></view></view><view class="data-options flex-col"><view class="title-text">{{"已返"+$root.m2}}</view><view class="num-text">{{info.send_money}}</view></view></view><view class="line-class"></view><view class="top-column"><view class="data-options flex-col"><view class="title-text">{{"待返"+$root.m3}}</view><view class="num-text">{{info.un_send_commission}}</view></view><view class="data-options flex-col" style="margin:30rpx 0;"><view class="line-class-width"></view></view><view class="data-options flex-col"><view class="title-text">{{"已返"+$root.m4}}</view><view class="num-text">{{info.send_commission}}</view></view></view><view class="line-class"></view><view class="top-column"><view class="data-options flex-col"><view class="title-text">{{"待返"+$root.m5}}</view><view class="num-text">{{info.un_send_score}}</view></view><view class="data-options flex-col" style="margin:30rpx 0;"><view class="line-class-width"></view></view><view class="data-options flex-col"><view class="title-text">{{"已返"+$root.m6}}</view><view class="num-text">{{info.send_score}}</view></view></view></view></view></block><dd-tab class="{{(show_rebate?'container-tab':'')}}" vue-id="79d172ab-1" itemdata="{{['全部','进行中','已结束']}}" itemst="{{['all','1','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="{{(show_rebate?'height:420rpx;width:100%;':'height:100rpx;width:100%;')}}"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'recordlog?cashback_id='+item.$orig.cashback_id+'&pro_id='+item.$orig.pro_id+'&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image><view class="head-title">{{"活动名称："+item.$orig.name}}</view></view><text class="st0">{{item.$orig.status}}</text></view><view class="content flex-col"><block a:if="{{item.$orig.business_name}}"><view class="flex-y-center option-content">{{"商户名称："+item.$orig.business_name}}</view></block><block a:if="{{item.$orig.back_name}}"><view class="flex-y-center option-content">{{"返现名称："+item.$orig.back_name}}</view></block><block a:if="{{item.$orig.cashback_money_max>0}}"><view class="flex-y-center option-content">{{"返现额度："+item.$orig.cashback_money_max}}</view></block><block a:else><view class="flex-y-center option-content">返现额度：不限</view></block><view class="flex-y-center option-content">{{"已返"+item.$orig.back_type_name+"："+item.$orig.cashback_num}}</view><block a:if="{{item.$orig.shuoming}}"><view data-event-opts="{{[['tap',[['getshuoming',[index]]]]]}}" class="shuoming" style="{{'background:'+(item.m7)+';'}}" catchTap="__e">{{item.m8+"说明"}}</view></block><view class="flex-y-center option-content"><view class="progress-box"><progress percent="{{item.$orig.progress}}" show-info="{{true}}" stroke-width="5" activeColor="#ff8758" border-radius="50"></progress></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="79d172ab-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="79d172ab-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{shuomingShow}}"><view id="mask-rule"><view class="box-rule" style="{{'background-color:'+($root.m9)+';'}}"><view class="h2">{{$root.m10+"说明"}}</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['closeshuoming',['$event']]]]]}}" onTap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{shuoming}}</text></view></view></view></view></block><block a:if="{{info&&info.cashback_popup}}"><uni-popup vue-id="79d172ab-4" type="center" ref="__r" data-ref="popupMiandan" onVueInit="__l"><view class="popup-miandan-content"><view class="popup-miandan-price flex"><view class="price-num-text popup-color-text">{{info.total_send}}</view><view class="right-text popup-color-text">元</view></view><view class="popup-leiji-miandan popup-color-text">累计返现金额</view><image src="{{pre_url+'/static/img/miandanpopupbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupMiandanclose',['$event']]]]]}}" class="popupMiandan-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup></block><fireworks vue-id="79d172ab-5" fireworksShow="{{fireworksShow}}" onVueInit="__l"></fireworks><block a:if="{{loading}}"><loading vue-id="79d172ab-6" onVueInit="__l"></loading></block><dp-tabbar vue-id="79d172ab-7" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="79d172ab-8" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>