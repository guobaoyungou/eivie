<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-url="{{'detail?id='+item.id+'&gbid='+gbid+'&bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3" style="position:relative;bottom:0;"><text class="t1" style="{{'color:'+($root.m0)+';'+('font-size:'+('28rpx')+';')}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')+('position:'+('absolute')+';')+('right:'+('0')+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">详情</text></view></view><block a:if="{{item.shortdesc}}"><view class="p1" style="margin-top:10rpx;">{{item.shortdesc}}</view></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="ecc49f5a-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="ecc49f5a-2" onVueInit="__l"></nodata></block></view><view class="notabbarbot" style="width:100%;height:110rpx;box-sizing:content-box;"></view><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m4)+';'+('margin:'+('0 auto')+';')}}" onTap="__e"><text>立即领取</text></view></view></block></block><block a:if="{{loading}}"><loading vue-id="ecc49f5a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="ecc49f5a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="ecc49f5a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>