<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center" style="{{'background:'+($root.m0)+';'}}"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="listbox"><view class="tr listitem" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="info flex" data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view><view class="title">{{"活动名称："+item.$orig.title}}</view><view class="td td2">{{"参加时间："+item.$orig.createtime}}</view><block a:if="{{item.$orig.totalprice>0}}"><view class="td td2">{{"报名支付：￥"+item.$orig.totalprice}}</view></block><block a:if="{{item.$orig.is_done}}"><view class="td td2">中奖奖品：<block a:if="{{item.$orig.jxid>0}}"><text style="{{'color:'+(item.m1)+';'}}">{{item.$orig.jxmc}}</text></block><block a:if="{{item.$orig.jxid==0}}"><text>未中奖</text></block></view></block><block a:else><view>待开奖</view></block></view><view class="opt"><text data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看</text></view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="356a086a-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="356a086a-2" onVueInit="__l"></nodata></block><view class="myrecord" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">首页</view></block></block><block a:if="{{loading}}"><loading vue-id="356a086a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="356a086a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="356a086a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>