<view class="container" style="min-height:100vh;"><block a:if="{{isload}}"><block><view class="activity"><view class="activity-amin"><view class="h2">中奖名单</view><view class="listbox"><view class="tr flex listitem" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="member"><view><image src="{{item.headimg}}"></image></view><view>{{item.nickname}}</view></view><view class="info"><view class="td td2">{{"中奖备注："+item.remark}}</view><view class="td td2">{{"中奖时间："+item.createtime}}</view><view class="td td2">{{"中奖奖品："+item.jxmc}}</view></view></view></view><block a:if="{{nomore}}"><nomore vue-id="10e07562-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="10e07562-2" onVueInit="__l"></nodata></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="10e07562-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="10e07562-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="10e07562-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>