<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="orderinfo"><view class="item" style="display:block;"><text class="t1">异议内容</text><view style="margin-top:20rpx;"><textarea style="height:200rpx;" placeholder="输入异议内容" placeholder-style="color:#ccc;" name="content" value="{{detail.objection_content}}"></textarea></view></view></view><view class="form-content"><view class="form-item flex-col"><view class="label">上传异议凭证(最多三张)</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{detail.status==0}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<3}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><button class="btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">提交异议</button><view style="padding-top:30rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="ccc85158-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="ccc85158-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="ccc85158-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>