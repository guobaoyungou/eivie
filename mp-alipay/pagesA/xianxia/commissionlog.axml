<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="4297cac4-1" itemdata="{{['待打款','待确定','完成','异议']}}" itemst="{{['0','1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="title" style="line-height:40rpx;">奖励发放</view><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" onTap="__e"><image src="{{item.$orig.headimg}}"></image><view class="t2" style="flex:1;"><text class="x1">{{item.$orig.nickname+"(ID:"+item.$orig.tomid+")"}}</text><text class="x1">{{"等      级："+item.$orig.levelname}}</text><block a:if="{{item.$orig.tel}}"><text class="x1">{{"手  机 号："+item.$orig.tel}}</text></block><text class="x1">{{"产生时间："+item.$orig.createtime}}</text></view><view class="t2" style="{{('color:'+$root.m0)}}">{{"发放金额："+item.$orig.commission}}</view></view><view class="f2"><view class="t1">{{item.$orig.remark}}</view><block a:if="{{item.$orig.status==0}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m1+' 0%,rgba('+item.m2+',0.8) 100%)')+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" onTap="__e">发放奖励</button></block><block a:if="{{item.$orig.status==1}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m3+' 0%,rgba('+item.m4+',0.8) 100%)')+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" onTap="__e">查看详情</button></block></view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="4297cac4-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4297cac4-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{showsend}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{loading}}"><loading vue-id="4297cac4-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="4297cac4-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="4297cac4-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>