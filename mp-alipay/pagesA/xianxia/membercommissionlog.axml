<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="d49587c4-1" itemdata="{{['待打款','待确定','完成','异议']}}" itemst="{{['0','1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="title" style="line-height:40rpx;">打款上级</view><view class="f1"><image src="{{item.s_headimg}}"></image><view class="t2" style="flex:1;"><text class="x1">{{item.s_nickname+"(ID:"+item.mid+")"}}</text><text class="x1">{{"等   级："+item.s_levelname}}</text><block a:if="{{item.s_tel}}"><text class="x1">{{"手机号："+item.s_tel}}</text></block></view><view class="t2" style="{{('color:'+$root.m0)}}">{{"发放金额："+item.commission}}</view></view><view class="f2"><view class="t1">{{''+item.remark+''}}</view><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" onTap="__e">查看凭证</button></view></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="d49587c4-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="d49587c4-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{showsend}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{loading}}"><loading vue-id="d49587c4-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="d49587c4-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="d49587c4-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>