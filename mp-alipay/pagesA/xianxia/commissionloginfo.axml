<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="orderinfo"><view class="item"><text class="t1">支付宝</text><text class="t2">{{detail.aliaccountname}}</text></view><view class="item"><text class="t1">支付宝账号</text><text class="t2">{{detail.aliaccount}}</text></view><view class="item"><text class="t1">开户行</text><text class="t2">{{detail.bankname}}</text></view><view class="item"><text class="t1">所属支行</text><text class="t2">{{detail.bankaddress}}</text></view><view class="item"><text class="t1">持卡人</text><text class="t2">{{detail.bankcarduser}}</text></view><view class="item"><text class="t1">银行卡</text><text class="t2">{{detail.bankcardnum}}</text></view></view><view class="form-content"><view class="form-item flex-col"><view class="label"><block a:if="{{detail.mid==detail.nowmid&&detail.status==0}}"><text>上传付款凭证(最多三张)</text></block><block a:else><text>付款凭证</text></block></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{detail.status==0}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<3&&detail.status==0&&detail.mid==detail.nowmid}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><block a:if="{{detail.status==3}}"><block><view class="orderinfo"><view class="item"><text class="t1">异议内容</text><text class="t2">{{detail.objection_content}}</text></view></view><view class="form-content"><view class="form-item flex-col"><view class="label"><text>异议图片</text></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{detail.objection_pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></view></block></block><block a:if="{{detail.status==0&&detail.mid==detail.nowmid}}"><button class="btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">提交</button></block><block a:if="{{detail.status==1&&detail.tomid==detail.nowmid}}"><button class="btn" style="{{'background:'+($root.m1)+';'}}" data-url="{{'objection?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提交异议</button></block><block a:if="{{(detail.status==1||detail.status==3)&&detail.tomid==detail.nowmid}}"><button data-event-opts="{{[['tap',[['toCollect',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m2)+';'}}" onTap="__e">确定收款</button></block><view style="padding-top:30rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="029f62d6-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="029f62d6-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="029f62d6-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>