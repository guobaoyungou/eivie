<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="2897688e-1" itemdata="{{['未售出（'+sycount+')','已售出('+sendcount+')']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="coupon-list"><view class="coupon" data-url="{{'coupondetail?rid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="pt_left"><view class="pt_left-content"><block a:if="{{item.$orig.type==1}}"><view class="f1" style="{{'color:'+(item.m0)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block a:if="{{item.$orig.type==10}}"><view class="f1" style="{{'color:'+(item.m1)+';'}}"><text class="t1">{{item.$orig.discount/10}}</text><text class="t0">折</text></view></block><block a:if="{{item.$orig.type==3}}"><view class="f1" style="{{'color:'+(item.m2)+';'}}"><text class="t1">{{item.$orig.limit_count}}</text><text class="t2">次</text></view></block><block a:if="{{item.$orig.type==5}}"><view class="f1" style="{{'color:'+(item.m3)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block a:if="{{item.$orig.type!=1&&item.$orig.type!=10&&item.$orig.type!=3&&item.$orig.type!=5}}"><block><view class="f1" style="{{'color:'+(item.m4)+';'}}">{{item.$orig.type_txt}}</view></block></block><block a:if="{{item.$orig.type==1||item.$orig.type==4||item.$orig.type==5||item.$orig.type==10}}"><view class="f2" style="{{'color:'+(item.m5)+';'}}"><block a:if="{{item.$orig.minprice>0}}"><text>{{"满"+item.$orig.minprice+"元可用"}}</text></block><block a:else><text>无门槛</text></block></view></block></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.$orig.couponname}}</view><text class="t2" style="{{'background:'+('rgba('+$root.m6+',0.1)')+';'+('color:'+($root.m7)+';')}}">{{item.$orig.type_txt}}</text><block a:if="{{!item.$orig.from_mid&&(item.$orig.isgive==1||item.$orig.isgive==2)}}"><text class="t2" style="{{'background:'+('rgba('+item.m8+',0.1)')+';'+('color:'+(item.m9)+';')}}">可赠送</text></block><view class="count"><block a:if="{{st==0}}"><text>剩余</text></block><block a:else><text>数量</text></block>{{"："+item.$orig.count+" 张"}}</view><view class="t3" style="{{(item.$orig.bid>0?'margin-top:0':'')}}">{{"有效期至 "+item.$orig.endtime}}</view><block a:if="{{item.$orig.bid>0}}"><view class="t4">{{"适用商家："+item.$orig.bname}}</view></block></view><block a:if="{{st==0}}"><block><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m10+' 0%,rgba('+$root.m11+',0.8) 100%)')+';'}}" data-url="{{'myteam?couponid='+item.$orig.couponid+'&count='+item.$orig.count}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">发放</button></block></block><block a:if="{{st==1}}"><image class="sygq" src="{{pre_url+'/static/img/ysc.png'}}"></image></block><block a:if="{{st==2}}"><image class="sygq" src="{{pre_url+'/static/img/ygq.png'}}"></image></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="2897688e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="2897688e-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{showsend}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" onTap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></block><block a:if="{{loading}}"><loading vue-id="2897688e-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="2897688e-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="2897688e-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>