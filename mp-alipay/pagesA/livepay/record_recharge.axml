<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="241a5f9e-1" itemdata="{{['全部','待付款','充值中','已完成','已关闭']}}" itemst="{{['all','0','1','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content flex-col"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="options-view"><view class="info-view"><view class="type-name">{{item.$orig.type_name}}</view><view class="recharge-number-text">{{''+item.$orig.recharge_number+" | "+item.$orig.company+''}}</view><view class="time-text">{{item.m0}}</view></view><view class="price-view"><block a:if="{{item.$orig.status==0}}"><view class="success-text">待付款</view></block><block a:if="{{item.$orig.status==2}}"><view class="success-text">充值中</view></block><block a:if="{{item.$orig.status==4}}"><view class="success-text">已关闭</view></block><block a:if="{{item.$orig.status==5}}"><view class="success-text">已退款</view></block><block a:if="{{item.$orig.status==1}}"><view class="success-text">充值中</view></block><block a:if="{{item.$orig.status==3}}"><view class="success-text" style="color:#e8b200;">充值成功</view></block><view class="price-num flex-y-center"><view>{{"￥"+item.$orig.totalprice}}</view><block a:if="{{item.g0}}"><view class="discount-text" style="margin-left:10rpx;">{{"优惠: -"+item.g1}}</view></block></view><block a:if="{{item.g2}}"><view class="discount-text">{{"优惠: -"+item.g3}}</view></block><block a:if="{{item.$orig.status==0}}"><view data-event-opts="{{[['tap',[['topay',['$0'],[[['datalist','',index]]]]]]]}}" class="btn1" style="{{'background:'+(item.m1)+';'}}" onTap="__e">去支付</view></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="241a5f9e-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="241a5f9e-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="241a5f9e-4" onVueInit="__l"></loading></block><popmsg vue-id="241a5f9e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><dp-tabbar vue-id="241a5f9e-6" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar></view>