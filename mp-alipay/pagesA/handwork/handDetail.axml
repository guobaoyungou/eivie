<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop_refund.jpg);background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">待验货</view></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t1">已验货</view></view></block></view><block a:if="{{detail.bid>0&&detail.binfo}}"><view class="btitle flex-y-center" data-url="{{'/pagesExt/business/index?id='+detail.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image style="width:36rpx;height:36rpx;" src="{{detail.binfo.logo}}"></image><view class="flex1" style="padding-left:16rpx;" decode="true" space="true">{{detail.binfo.name}}</view></view></block><view class="product"><view class="content" a:for="{{prolist}}" a:for-item="item" a:for-index="idx" a:key="idx"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.ggname}}</text><view style="display:flex;justify-content:space-between;"><text class="t2">{{"手工费："+item.hand_fee}}</text><text class="t2">{{"回寄数量："+item.hand_num}}</text></view><block a:if="{{detail.status==1}}"><block><view style="display:flex;justify-content:space-between;"><text class="t2">{{"合格数量："+item.ispassnum}}</text><text class="t2">{{"不合格数量："+item.nopassnum}}</text></view><block a:if="{{item.fbpics}}"><view class="item"><text class="t2">图片:</text><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{item.fbpics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></view></view></block><block a:if="{{item.fbremark}}"><text class="t2">{{"备注："+item.fbremark}}</text></block></block></block></view></view></view><view class="orderinfo"><view class="item"><text class="t1">回寄单号</text><text class="t2" user-select="true" selectable="true">{{detail.hand_ordernum}}</text></view><view class="item"><text class="t1">订单号</text><text class="t2" user-select="true" selectable="true" data-url="{{'detail?id='+detail.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{detail.ordernum}}</text></view><view class="item"><text class="t1">回寄时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.express_com||detail.express_no}}"><block><view class="item"><text class="t1">快递公司</text><text class="t2">{{detail.express_com}}</text></view><view class="item"><text class="t1">快递单号</text><text class="t2">{{detail.express_no}}</text></view><block a:if="{{detail.express_com||detail.express_no}}"><view class="item"><view class="t1"></view><view class="t2" style="overflow:hidden;"><view class="btn2" style="float:right;" data-express_com="{{detail.express_com}}" data-express_no="{{detail.express_no}}" data-express_content="{{detail.express_content}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" onTap="__e">查看物流</view></view></view></block></block></block><block a:else><block><block a:if="{{detail.issign==1}}"><block><block a:for="{{detail.express_content}}" a:for-item="item" a:for-index="index"><view class="item"><text class="t1">快递公司</text><text class="t2">{{item.express_com}}</text></view><view class="item"><text class="t1">快递单号</text><text class="t2">{{item.express_no}}</text></view><block a:if="{{item.express_com||item.express_no}}"><view class="item"><view class="t1"></view><view class="t2" style="overflow:hidden;"><view class="btn2" style="float:right;" data-express_com="{{item.express_com}}" data-express_no="{{item.express_no}}" data-express_content="{{item.express_content}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" onTap="__e">查看物流</view></view></view></block></block></block></block><block a:else><block><block a:for="{{detail.express_content}}" a:for-item="item" a:for-index="index"><view class="form-item" style="padding:10rpx 20rpx;"><view class="label" style="display:flex;justify-content:space-between;"><text>快递公司：</text></view><view class="flex"><picker style="font-size:28rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;" value="{{item.express_index}}" range="{{detail.expressdata}}" data-index="{{index}}" data-event-opts="{{[['change',[['expresschange',['$event']]]]]}}" onChange="__e"><view class="picker">{{item.express_com}}</view></picker></view></view><view class="form-item" style="padding:10rpx 20rpx;"><text class="label">快递单号：</text><view class="flex"><input style="border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;font-size:28rpx;" type="text" data-index="{{index}}" placeholder="请输入快递单号" data-event-opts="{{[['input',[['setexpressno',['$event']]]]]}}" value="{{item.express_no}}" onInput="__e"/><view class="setup-view" data-index="{{index}}" data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/admin/saoyisao.png'}}"></image></view></view></view><block a:if="{{item.express_com||item.express_no}}"><view class="item"><view class="t1"></view><view class="t2" style="overflow:hidden;"><view class="btn2" style="float:right;" data-express_com="{{item.express_com}}" data-express_no="{{item.express_no}}" data-express_content="{{item.express_content}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" onTap="__e">查看物流</view></view></view></block></block><block a:if="{{detail.express_content}}"><view data-event-opts="{{[['tap',[['changeexpress',['$event']]]]]}}" style="width:500rpx;margin:10rpx auto;border-radius:8rpx;line-height:70rpx;border:2rpx solid #EEE;text-align:center;" onTap="__e">修改快递</view></block></block></block></block></block></view><view class="orderinfo"><view class="item"><text class="t1">签收状态</text><block a:if="{{detail.issign==0}}"><text class="t2 red">未签收</text></block><block a:if="{{detail.issign==1}}"><text class="t2">已签收</text></block></view><block a:if="{{detail.signtime}}"><view class="item"><text class="t1">签收时间</text><text class="t2">{{detail.signtime}}</text></view></block><view class="item"><text class="t1">状态</text><block a:if="{{detail.status==0}}"><text class="t2 red">待验货</text></block><block a:if="{{detail.status==1&&detail.issend==0}}"><text class="t2">已验货,待返款</text></block><block a:if="{{detail.status==1&&detail.issend==1}}"><text class="t2">已验货,已返款</text></block></view><block a:if="{{detail.checktime}}"><view class="item"><text class="t1">验货时间</text><text class="t2">{{detail.checktime}}</text></view></block><block a:if="{{detail.status==1}}"><block><view class="item"><text class="t1">总计返款</text><text class="t2 red">{{"￥"+detail.totalmoney}}</text></view><view class="item"><text class="t1">返款状态</text><block a:if="{{detail.issend==0}}"><text class="t2 red">待返款</text></block><block a:else><text class="t2">已返款</text></block></view><block a:if="{{detail.sendtime}}"><view class="item"><text class="t1">返款时间</text><text class="t2">{{detail.sendtime}}</text></view></block></block></block><block a:if="{{detail.hand_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2">{{detail.hand_checkremark}}</text></view></block></view><view style="width:100%;height:120rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="19d559b1-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="19d559b1-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="19d559b1-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="19d559b1-4" onVueInit="__l"></wxxieyi></view>