<view class="container"><block a:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-content"><view class="form-item"><text class="label">回寄商品</text></view><view class="product"><view class="content" a:for="{{prolist}}" a:for-item="item" a:for-index="index" a:key="index"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><view class="num-wrap"><view class="addnum"><view class="minus" data-index="{{index}}" data-ogid="{{item.id}}" data-num="{{handNum[index].num}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-index="{{index}}" data-ogid="{{item.id}}" data-max="{{item.num-item.hand_num}}" data-num="{{handNum[index].num}}" data-event-opts="{{[['blur',[['gwcinput',['$event']]]]]}}" value="{{handNum[index].num}}" onBlur="__e"/><view class="plus" data-index="{{index}}" data-ogid="{{item.id}}" data-max="{{item.num-item.hand_num}}" data-num="{{handNum[index].num}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view><view class="text-desc">{{"回寄数量：最多可回寄"+item.canHandNum+"件"}}</view></view></view></view></view></view></view><view class="form-content"><view class="form-item"><text class="label">商家地址</text><view class="input-item">{{''+binfo.name+" "+binfo.tel+''}}</view><view class="input-item">{{''+binfo.province+binfo.city+binfo.district+binfo.address+''}}</view></view><block a:for="{{express_content}}" a:for-item="item" a:for-index="index"><view class="form-item" style="padding:10rpx 20rpx;"><view class="label" style="display:flex;justify-content:space-between;"><text>快递公司：</text><view style="width:100rpx;text-align:center;color:red;" data-index="{{index}}" data-event-opts="{{[['tap',[['delexpress',['$event']]]]]}}" onTap="__e">删除</view></view><view class="flex"><picker style="font-size:28rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;" value="{{item.express_index}}" range="{{expressdata}}" data-index="{{index}}" data-event-opts="{{[['change',[['expresschange',['$event']]]]]}}" onChange="__e"><view class="picker">{{item.express_com}}</view></picker></view></view><view class="form-item" style="padding:10rpx 20rpx;"><text class="label">快递单号：</text><view class="flex"><input style="border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;font-size:28rpx;" type="text" placeholder="请输入快递单号" data-index="{{index}}" data-event-opts="{{[['input',[['setexpressno',['$event']]]]]}}" value="{{item.express_no}}" onInput="__e"/><view class="setup-view" data-index="{{index}}" data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/admin/saoyisao.png'}}"></image></view></view></view></block><view data-event-opts="{{[['tap',[['addexpress',['$event']]]]]}}" style="width:500rpx;margin:10rpx auto;border-radius:8rpx;line-height:70rpx;border:2rpx solid #EEE;text-align:center;" onTap="__e">+添加快递</view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m0)+';'}}" onTap="__e">确定</button><view style="padding-top:30rpx;"></view></form></block></block><block a:if="{{loading}}"><loading vue-id="29194602-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="29194602-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="29194602-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="29194602-4" onVueInit="__l"></wxxieyi></view>