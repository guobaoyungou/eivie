<view class="container"><block a:if="{{isload}}"><block><view class="content"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t2">{{"区域："+item.region}}</text></view><view class="f2"><block a:if="{{item.commission>0}}"><text class="t1">{{"+"+item.commission}}</text></block><block a:else><text class="t2">{{item.commission}}</text></block></view></view></block></view></block></block><block a:if="{{nodata}}"><nodata vue-id="283142f9-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="283142f9-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="283142f9-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="283142f9-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="283142f9-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>