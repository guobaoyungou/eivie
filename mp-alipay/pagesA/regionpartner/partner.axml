<view class="container"><block a:if="{{isload}}"><block><view class="content"><block><view class="item" data-url="{{'/pagesA/regionpartner/fhlog?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"申请区域："+item.province+"-"+item.city+"-"+item.district}}</text><text class="t2">{{"申请时间："+item.createtime}}</text><text class="t2">{{"已分红："+item.bonus}}</text><text class="t2">{{"剩余分红："+item.remain}}</text><block a:if="{{item.paidui>0}}"><text class="t2">{{"当前排队人数："+item.paidui}}</text></block></view><view class="f2"><block a:if="{{item.bonus_status>0}}"><text class="t1">已完成</text></block><block a:if="{{item.bonus_status==0}}"><text class="t2">未完成</text></block></view></view></block></view></block></block><block a:if="{{nodata}}"><nodata vue-id="08341f73-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="08341f73-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="08341f73-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="08341f73-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="08341f73-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>