<view class="container"><block a:if="{{isload}}"><block><view class="article_list flex-wp"><view class="article-itemlist flex-col" data-url="{{'/pagesA/hikvision/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="article-pic"><image class="image" src="{{item.icon}}" mode="widthFix"></image></view><view class="article-info"><view class="p1" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{item.name}}</view><block><view class="p3">{{''+item.deviceserial+''}}</view></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="1ead350d-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="1ead350d-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="1ead350d-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="1ead350d-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="1ead350d-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>