<view><block a:if="{{isload}}"><block><view class="container"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-url="{{'/activity/shortvideo/detail?id='+item.vid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2" style="display:flex;color:#888;"><view style="width:100%;">次数：<text style="color:#000;">{{item.num}}</text></view><view style="width:100%;">进度：<text style="color:#000;">{{item.jindu+"%"}}</text></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="4d3dddda-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4d3dddda-2" onVueInit="__l"></nodata></block></view></block></block><block a:if="{{loading}}"><loading vue-id="4d3dddda-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="4d3dddda-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4d3dddda-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>