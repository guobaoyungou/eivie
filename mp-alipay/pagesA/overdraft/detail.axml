<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{$root.m1}}</view><view class="f1">{{"待还款额："+userinfo.overdraft_money}}</view><view class="f1">授信额度：<text>{{userinfo.limit_overdraft_money}}</text></view><view class="f1">{{"可用额度："+userinfo.overdraft_money_use}}</view><view class="f3" data-url="/pagesA/overdraft/recharge" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>还款</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><dd-tab vue-id="18fae535-1" itemdata="{{['消费明细','还款记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><block a:if="{{st==0}}"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block a:else><text class="t2">{{item.money}}</text></block></view></view></block></block><block a:if="{{st==1}}"><block><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{"充值金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block a:if="{{item.status==0}}"><text class="t1">充值失败</text></block><block a:if="{{item.status==1}}"><text class="t2">充值成功</text></block></view></view></block></block></view><block a:if="{{nomore}}"><nomore vue-id="18fae535-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="18fae535-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="18fae535-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="18fae535-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="18fae535-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>