<view><block a:if="{{isload}}"><block><view class="detail"><parse vue-id="000b2276-1" content="{{detail.content}}" onVueInit="__l"></parse></view><view class="itembox"><view class="title">工单列表</view><block a:if="{{detail.pid>0||detail.pid==0&&detail.id==id&&ispcate==1}}"><block><view class="item" data-url="{{'/pagesB/workorder/index?cateid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index"><text>{{item.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block><block a:else><block><view class="category" a:for="{{datalist}}" a:for-item="item" a:for-index="index2"><view class="cate"><view class="img" data-id="{{item.id}}" data-index="{{index2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/workorder/'+(curIndex2==index2?'down':'up')+'.png?v1'}}" mode="widthFix"></image></view><view>{{item.name}}</view></view><block a:for="{{item.list}}" a:for-item="subitem" a:for-index="subindex"><block a:if="{{curIndex2==index2}}"><view class="item" style="padding-left:50rpx;margin-top:10rpx;" data-url="{{'/pagesB/workorder/index?cateid='+subitem.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{subitem.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></view></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="000b2276-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="000b2276-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="000b2276-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>