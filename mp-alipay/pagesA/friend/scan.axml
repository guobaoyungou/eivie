<view class="container"><block a:if="{{isload}}"><block><view class="box top"><view class="left"><image src="{{friend.headimg}}"></image></view><view class="right"><view class="nickname">{{friend.nickname}}</view><view class="desc">{{"ID："+friend.fmid}}</view><view class="desc">{{"等级："+friend.levelname}}</view><block a:if="{{friend.area}}"><view class="desc">{{"地区："+friend.area}}</view></block><block a:if="{{friend.id>0}}"><view class="desc">{{"添加时间："+friend.createtime}}</view></block></view></view><view class="box"><view class="row flex-sb"><view class="flex-s f1"><view class="label">备注：</view><view class="value"><block a:if="{{editRemark||friend.id==0}}"><input type="text" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" onInput="__e"/></block><block a:else><text>{{friend.remark}}</text></block></view></view><block a:if="{{friend.id>0&&!editRemark}}"><view data-event-opts="{{[['tap',[['showRemarkInput',['$event']]]]]}}" class="btn-r" onTap="__e">改备注</view></block><block a:if="{{friend.id>0&&editRemark}}"><view data-event-opts="{{[['tap',[['changeRemark',['$event']]]]]}}" class="btn btn2" style="{{('background:'+$root.m0+'; color:#fff')}}" onTap="__e">确定</view></block></view></view><view class="box"><view class="row"><view class="label">来 源：</view><view class="value">{{friend.from}}</view></view></view><view class="box option"><block a:if="{{friend.id>0}}"><view data-event-opts="{{[['tap',[['delFriend',['$event']]]]]}}" class="btn btn1" onTap="__e">删除好友</view></block><block a:if="{{friend.id==0&&btnauth.addFriend}}"><view class="btn" style="{{('color:'+$root.m1+'; border-bottom:1px solid '+$root.m2)}}" data-id="{{friend.fmid}}" data-event-opts="{{[['tap',[['addFriend',['$event']]]]]}}" onTap="__e">添加好友</view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="0d5114d2-1" onVueInit="__l"></loading></block><popmsg vue-id="0d5114d2-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>