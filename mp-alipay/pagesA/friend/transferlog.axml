<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="4a85b9c0-1" itemdata="{{[$root.m0+'明细',$root.m1+'明细']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.title}}</text><text class="t2">{{item.$orig.createtime}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block a:if="{{item.$orig.num>0}}"><text class="t1" style="{{'color:'+(item.m2)+';'}}">{{"+"+item.$orig.num}}</text></block><block a:else><text class="t2">{{item.$orig.num}}</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="4a85b9c0-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="4a85b9c0-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="4a85b9c0-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="4a85b9c0-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4a85b9c0-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>