<view class="container"><block a:if="{{isload}}"><block><view class="top"><view class="top-search"><image class="search-icon" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="input" type="text" placeholder="输入昵称|姓名|手机号检索" placeholder-style="font-size:26rpx;color:#999" data-event-opts="{{[['confirm',[['searchFriend',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="box"><block a:if="{{datalist.length>0}}"><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="item flex-sb"><view class="left"><image class="headimg" src="{{item.headimg}}" data-url="{{'scan?fmid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image><view class="info"><view class="nickname txthide">{{item.nickname}}</view><view class="desc">{{"等级："+item.levelname}}</view><view class="desc txthide">{{"备注："+item.remark}}</view></view></view><view class="right"><block a:if="{{btnauth.moneyTransfer}}"><button class="btn" data-url="{{'/pagesExt/money/rechargeToMember?mid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转余额</button></block><block a:if="{{btnauth.scoreTransfer}}"><button class="btn" data-url="{{'/pagesExt/my/scoreTransfer?mid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转积分</button></block><button class="btn" data-name="{{item.groupname}}" data-mid="{{item.fmid}}" data-event-opts="{{[['tap',[['showChangeGroupModal',['$event']]]]]}}" catchTap="__e">{{(item.groupname?'转换':'加入')+"分组"}}</button><block a:if="{{btnauth.moneyTransfer||btnauth.scoreTransfer}}"><button class="btn" data-url="{{'transferlog?fmid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转账明细</button></block></view></view></block></view></block><block a:if="{{datalist.length==0}}"><view class="nomore">-暂无匹配好友-</view></block></view><block a:if="{{isshowChangeGroupModal}}"><view class="popup__container group_modal popup_store"><view data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">转换分组</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:if="{{oldGroupName!=''}}"><view class="form-item"><view class="form-label">现在分组</view><view class="form-value form-txt">{{''+oldGroupName+''}}</view></view></block><view class="form-item"><view class="form-label">好友分组</view><view class="form-value "><picker class="picker" name="store_id" range="{{groupList}}" range-key="name" data-event-opts="{{[['change',[['pickerChange',['$event']]]]]}}" onChange="__e"><view class="pickerbox"><view class="{{(('uni-input')+' '+(newGroupId>0?'':'hui'))}}">{{newGroupName?newGroupName:'请选择分组'}}</view><image class="img" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view><view class="bottom"><view data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" class="btn cancel" catchTap="__e">取消</view><view data-event-opts="{{[['tap',[['changeGroup',['$event']]]]]}}" class="btn ok" onTap="__e">确定</view></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="fe0a2c72-1" onVueInit="__l"></loading></block><popmsg vue-id="fe0a2c72-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>