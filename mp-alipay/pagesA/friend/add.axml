<view class="container"><block a:if="{{isload}}"><block><view class="top"><view class="top-search"><image class="search-icon" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="input" type="text" placeholder="输入昵称|姓名|手机号添加好友" placeholder-style="font-size:26rpx;color:#999" data-event-opts="{{[['confirm',[['searchMember',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist.length>0}}"><view class="box"><view class="itembox"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="item flex-sb"><view class="left"><image class="headimg" src="{{item.$orig.headimg}}"></image><view class="info"><view class="nickname txthide">{{item.$orig.nickname}}</view><view class="desc">{{"等级："+item.$orig.levelname}}</view><view class="desc txthide">{{"地区："+(item.$orig.area?item.$orig.area:'未知')}}</view></view></view><view class="right"><block a:if="{{item.$orig.add_status==1}}"><button class="btn" style="{{'background:'+(item.m0)+';'+('color:'+('#fff')+';')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['addFriend',['$event']]]]]}}" onTap="__e">加好友</button></block><block a:if="{{item.$orig.add_status==2}}"><button class="btn btn1">已添加</button></block></view></view></block></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="5f2df010-1" onVueInit="__l"></loading></block><popmsg vue-id="5f2df010-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>