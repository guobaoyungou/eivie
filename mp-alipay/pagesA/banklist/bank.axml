<view class="container"><block a:if="{{isload}}"><block><view class="content" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.bankname}}</text><text class="t2">{{item.$orig.bankcarduser}}</text><text class="t2">{{item.$orig.bankcardnum}}</text><text class="flex1"></text><image class="t3" src="{{pre_url+'/static/img/edit.png'}}" data-url="{{'bankadd?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"></image></view><view class="f2">{{item.$orig.area+" "+item.$orig.address}}</view><view class="f3"><view class="flex-y-center"><view class="radio" style="{{(item.$orig.isdefault?'border:0;background:'+item.m0:'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="mrtxt">{{item.$orig.isdefault?'默认银行卡':'设为默认'}}</view></view><view class="flex1"></view><view class="del" style="{{'color:'+($root.m1)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" catchTap="__e">删除</view></view></view><block a:if="{{nodata}}"><nodata vue-id="e5b15ea2-1" onVueInit="__l"></nodata></block><view style="height:140rpx;"></view><view class="{{(('btn-add')+' '+(menuindex>-1?'tabbarbot':'notabbarbot3'))}}" style="{{('background:linear-gradient(90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')}}" data-url="{{'/pagesB/address/addressadd?type='+type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image style="width:28rpx;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>添加银行卡</view></block></block><block a:if="{{loading}}"><loading vue-id="e5b15ea2-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="e5b15ea2-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="e5b15ea2-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>