<view class="body"><block a:if="{{isload}}"><block><view class="header" style="{{'background:'+('linear-gradient(180deg,'+themeColor+' 0%,rgba('+$root.m0+',0) 100%)')+';'}}">{{''+detail.name+''}}</view><view class="container"><block a:if="{{detail.content}}"><view class="content box"><rich-text nodes="{{detail.content}}"></rich-text></view></block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form-main box"><view class="form-item"><view class="form-label"><text class="required">*</text>姓名</view><view class="form-value"><input type="text" name="name" placeholder="请填写姓名" placeholder-class="placeholder" value="{{form.name}}"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>性别</view><view class="form-value form-radio"><radio-group name="sex"><label><radio style="transform:scale(0.8);" value="1" checked="{{form.sex==1?true:false}}"></radio>男</label><label><radio style="transform:scale(0.8);" value="2" checked="{{form.sex==2?true:false}}"></radio>女</label></radio-group></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>年龄</view><view class="form-value flex-sb"><input type="digit" name="age" placeholder="请填写年龄" placeholder-class="placeholder" value="{{form.age}}"/><view class="form-unit">岁</view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>联系方式</view><view class="form-value"><input type="text" name="tel" placeholder="请填写联系方式" placeholder-class="placeholder" value="{{form.tel}}"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店</view><view data-event-opts="{{[['tap',[['showMendianModal',['$event']]]]]}}" class="form-value form-select" onTap="__e"><view class="{{(('select-txt')+' '+(bid_index>-1?'':'placeholder'))}}">{{bid_index>-1?bidlist[bid_index].name:'请选择门店'}}</view><view class="select-more"><text class="iconfont iconjiantou" style="font-size:24rpx;color:#BBBBBB;"></text></view></view></view><view class="form-item"><view class="form-label">家庭地址</view><view class="form-value"><input type="text" name="address" placeholder="请填写家庭地址" placeholder-class="placeholder" value="{{form.address}}"/></view></view></view><view style="height:120rpx;"></view><view class="form-opt"><button class="btn" style="{{'background:'+(themeColor)+';'}}" form-type="submit">开始评测</button><block><block a:if="{{$root.m1=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="share" onTap="__e"><image src="{{pre_url+'/static/img/share.png'}}"></image><text>分享</text></view></block><block a:else><block a:if="{{$root.m2=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="share" onTap="__e"><image src="{{pre_url+'/static/img/share.png'}}"></image><text>分享</text></view></block><block a:else><block a:if="{{$root.m3=='h5'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="share" onTap="__e"><image src="{{pre_url+'/static/img/share.png'}}"></image><text>分享</text></view></block><block a:else><button class="share" open-type="share"><image src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></button></block></block></block></block></view></form></view><block a:if="{{isshowmendianmodal}}"><view class="modal-mendian"><view class="modal-content"><block a:if="{{isshowmendianmodal}}"><view class="popup__container popup_mendian" style="z-index:999999;"><view data-event-opts="{{[['tap',[['hideMendianModal',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择门店</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideMendianModal',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="mendian-info" style="{{'background:'+(index==bid_index?'rgba('+item.m4+',0.1)':'')+';'}}" data-index="{{index}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeMendian',['$event']]]]]}}" onTap="__e"><view class="b1"><image src="{{item.$orig.logo}}"></image></view><view class="b2"><view class="t1">{{item.$orig.name}}</view><view class="t2 flex-y-center"><block a:if="{{item.$orig.distance}}"><view class="mendian-distance">{{item.$orig.distance}}</view></block><block a:if="{{item.$orig.address||item.$orig.area}}"><block><block a:if="{{item.$orig.distance}}"><view class="line"></view></block><view class="mendian-address">{{''+(item.$orig.address?item.$orig.address:item.$orig.area)}}</view></block></block></view></view></view></block></view></view></view></block></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="d2ee4558-1" onVueInit="__l"></loading></block><popmsg vue-id="d2ee4558-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="d2ee4558-3" onVueInit="__l"></wxxieyi></view>