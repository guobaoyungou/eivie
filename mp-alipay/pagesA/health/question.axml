<view style="{{'font-size:'+(fontSize)+';'}}"><block a:if="{{isload}}"><block><view class="progress">进度：<text>{{question_index+1+"/"+questionlist.length}}</text></view><view class="container"><view class="question"><view class="title"><rich-text nodes="{{question.name}}"></rich-text></view><view class="option_group"><block a:for="{{question.optionlist}}" a:for-item="item" a:for-index="index"><view class="option flex" style="{{(item.checked==1?'background:'+themeColor+';color:#ffffff':'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" onTap="__e">{{''+item.option+''}}</view></block></view></view></view><block a:if="{{custom.PSQI}}"><view class="bottom"><block><block a:if="{{question_index>0}}"><view data-event-opts="{{[['tap',[['goprev',['$event']]]]]}}" class="btn btn1" onTap="__e">上一题</view></block><block a:else><view class="btn btn0"></view></block></block><block a:if="{{question_index<questionlist.length-1}}"><view data-event-opts="{{[['tap',[['gonext',['$event']]]]]}}" class="btn btn2" onTap="__e">下一题</view></block><block a:if="{{question_index==questionlist.length-1}}"><view data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" class="btn btn2" onTap="__e">提交</view></block></view></block><block a:else><view class="bottom"><block><block a:if="{{question_index>0}}"><view data-event-opts="{{[['tap',[['goprev',['$event']]]]]}}" class="btn btn1" style="{{('background:rgba('+$root.m0+',0.16);color:'+$root.m1)}}" onTap="__e">上一题</view></block><block a:else><view class="btn btn0"></view></block></block><block a:if="{{question_index<questionlist.length-1}}"><view data-event-opts="{{[['tap',[['gonext',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'}}" onTap="__e">下一题</view></block><block a:if="{{question_index==questionlist.length-1}}"><view data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'}}" onTap="__e">提交</view></block></view></block></block></block><block a:if="{{loading}}"><loading vue-id="19478272-1" onVueInit="__l"></loading></block><popmsg vue-id="19478272-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>