<view><block a:if="{{isload}}"><block><view class="container"><view class="enter"><view class="gobtn" style="{{'background:'+(themeColor)+';'+('color:'+('#FFF')+';')}}" data-url="{{'recordlog?rid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">评测详情</view></view><view class="box"><block a:if="{{health.type!=3}}"><block><view class="tag" style="{{'color:'+(themeColor)+';'}}">{{detail.score_tag}}</view><view class="score" style="{{'color:'+(themeColor)+';'}}">{{detail.score+"分"}}</view></block></block><block a:if="{{detail.child_result.length>0}}"><view class="child-result"><view class="child-item" style="{{('border:1rpx solid '+themeColor+'')}}" a:for="{{detail.child_result}}" a:for-item="itemC" a:for-index="indexC"><view class="child-title">{{itemC.name}}</view><view class="child-score txt1"><view class="score" style="{{'color:'+(themeColor)+';'}}">{{itemC.score+"分"}}</view><view>{{itemC.score_tag}}</view></view><view class="txt1"><rich-text nodes="{{itemC.score_desc}}"></rich-text></view></view></view></block><block a:if="{{health.type!=3}}"><view class="desc"><view class="title">评测概述：</view><view class="content"><rich-text nodes="{{detail.score_desc}}"></rich-text></view></view></block><view class="desc"><view class="title">评测说明：</view><view class="content"><rich-text nodes="{{detail.desc}}"></rich-text></view></view></view><view class="box"><dp vue-id="5f4f1330-1" pagecontent="{{pagecontent}}" menuindex="{{menuindex}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" onGetdata="__e" onVueInit="__l"></dp></view></view><view style="height:90rpx;"></view><view class="bottom"><block a:if="{{custom.PSQI}}"><block><button class="btn btn1" data-url="{{'question?fid='+detail.fid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">再测一次</button><block><block a:if="{{$root.m0=='app'}}"><button data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="btn btn2" onTap="__e">邀请好友测一测</button></block><block a:else><block a:if="{{$root.m1=='mp'}}"><button data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn btn2" onTap="__e">邀请好友测一测</button></block><block a:else><block a:if="{{$root.m2=='h5'}}"><button data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn btn2" onTap="__e">邀请好友测一测</button></block><block a:else><button class="btn btn2" open-type="share">邀请好友测一测</button></block></block></block></block></block></block><block a:else><block><button class="btn btn1" style="{{('background:rgba('+$root.m3+',0.2);color:'+themeColor)}}" data-url="{{'question?fid='+detail.fid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">再测一次</button><block><block a:if="{{$root.m4=='app'}}"><button data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'+('color:'+('#FFF')+';')}}" onTap="__e">邀请好友测一测</button></block><block a:else><block a:if="{{$root.m5=='mp'}}"><button data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'+('color:'+('#FFF')+';')}}" onTap="__e">邀请好友测一测</button></block><block a:else><block a:if="{{$root.m6=='h5'}}"><button data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'+('color:'+('#FFF')+';')}}" onTap="__e">邀请好友测一测</button></block><block a:else><button class="btn" style="{{'background:'+(themeColor)+';'+('color:'+('#FFF')+';')}}" open-type="share">邀请好友测一测</button></block></block></block></block></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="5f4f1330-2" onVueInit="__l"></loading></block><popmsg vue-id="5f4f1330-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>