<view><block a:if="{{isload}}"><block><view class="container"><block a:if="{{pics.length>0}}"><swiper class="swiper" indicator-dots="{{pics[1]?true:false}}" autoplay="true" interval="{{5000}}"><block a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><swiper-item class="swiper-item"><image src="{{item}}" mode="widthFix"></image></swiper-item></block></swiper></block><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="collage-product" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block a:if="{{item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view><view class="p3"><view class="t1">礼包数量<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">立即购买</text></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="3e2968d7-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="3e2968d7-2" onVueInit="__l"></nodata></block></view><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">我的套餐</button></block></block><block a:if="{{loading}}"><loading vue-id="3e2968d7-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="3e2968d7-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="3e2968d7-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>