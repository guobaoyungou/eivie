<view class="container"><block a:if="{{isload}}"><block><view class="topbg" style="{{('background:url('+pre_url+'/static/img/lv-topbg.png) no-repeat;background-size:100%')}}"><view class="topinfo" style="{{('background:url('+pre_url+'/static/img/lv-top.png);background-size:100%')}}"><view class="info"><view class="nickname">{{frommember.nickname}}</view><view style="color:#fff;">赠送了一个会员等级给您</view><view class="flex" style="margin-top:10rpx;"><view style="margin-right:10rpx;color:#fff;">赠送等级：</view><view class="user-level"><block a:if="{{zslevel.icon}}"><image class="level-img" src="{{zslevel.icon}}"></image></block><view class="level-name">{{zslevel.name}}</view></view></view><view class="t3">{{"您的当前会员等级："+levelname}}</view></view><view class="set" data-url="set" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text class="fa fa-cog"></text></view></view><view data-event-opts="{{[['tap',[['confirmlq',['$event']]]]]}}" class="upbtn" style="{{('background:url('+pre_url+'/static/img/lv-upbtn.png) no-repeat;background-size:100%')}}" onTap="__e">我要领取</view></view><view style="width:100%;height:20rpx;background-color:#f6f6f6;"></view><view class="explain"><view class="f1">— 等级特权 —</view><view class="f2"><parse vue-id="6babff6f-1" content="{{zslevel.explain}}" onVueInit="__l"></parse></view></view></block></block><block a:if="{{loading}}"><loading vue-id="6babff6f-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="6babff6f-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6babff6f-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>