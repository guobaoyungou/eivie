<view class="container"><block a:if="{{isload}}"><block><view class="topbg" style="{{('background:url('+pre_url+'/static/img/lv-topbg.png) no-repeat;background-size:100%')}}"><view class="topinfo" style="{{('background:url('+pre_url+'/static/img/lv-top.png);background-size:100%')}}"><view class="info"><view class="flex" style="margin-top:10rpx;"><view style="margin-right:10rpx;color:#fff;">会员等级：</view><view class="user-level"><block a:if="{{userlevel.icon}}"><image class="level-img" src="{{userlevel.icon}}"></image></block><view class="level-name">{{userlevel.name}}</view></view></view><view class="flex" style="margin-top:20rpx;"><view style="margin-right:10rpx;color:#fff;">升级费用：</view><view class="level-name" style="color:#fff;">{{"￥"+userlevel.apply_paymoney}}</view></view></view></view></view><view style="width:100%;height:20rpx;background-color:#f6f6f6;"></view><view class="explain"><view class="f1">— 等级特权 —</view><view class="f2"><parse vue-id="0397ef73-1" content="{{userlevel.explain}}" onVueInit="__l"></parse></view></view><view class="bottom"><block a:if="{{$root.m0}}"><button data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" class="zsbtn" style="{{'background:'+($root.m1)+';'}}" onTap="__e">转赠</button></block><block a:else><button class="zsbtn" style="{{'background:'+($root.m2)+';'}}" open-type="share" data-type="1" data-levelid="{{userlevel.id}}">转赠</button></block><block a:if="{{$root.m3}}"><button data-event-opts="{{[['tap',[['tosale',['$event']]]]]}}" class="smbtn" style="{{'background:'+($root.m4)+';'}}" onTap="__e">售卖</button></block><block a:else><button class="smbtn" open-type="share" data-type="2" data-levelid="{{userlevel.id}}">售卖</button></block></view><block a:if="{{dialogShow}}"><view data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" class="popup_modal" onTap="__e"><view class="content1"><view class="title">我要转赠</view><view class="f1">点击下方按钮，复制链接发送给好友</view><block a:if="{{$root.m5=='wx'}}"><view data-event-opts="{{[['tap',[['shareScheme',['$event']]]]]}}" class="btnbox" onTap="__e"><button class="btn2" style="{{'background:'+($root.m6)+';'}}">复制</button></view></block><block a:else><view class="btnbox"><button class="btn2" style="{{'background:'+($root.m7)+';'}}" data-text="{{pre_url+'/h5/'+aid+'.html#/pagesA/levelupauth/give?pid='+frommid+'&levelid='+levelid}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" onTap="__e">复制</button></view></block></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="0397ef73-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="0397ef73-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0397ef73-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>