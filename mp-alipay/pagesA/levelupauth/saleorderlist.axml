<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="51d6567a-1" itemdata="{{['全部','待付款','已付款']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><block a:if="{{item.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.status==1}}"><text class="st1">{{item.ordertype==1?'已领取':'已付款'}}</text></block><block a:if="{{item.status==-1}}"><text class="st2">已取消</text></block></view><view class="content"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.title}}</text><text class="t2" style="color:#666;">{{(item.ordertype==1?'赠送':'售卖')+"等级："+item.levelname}}</text></view></view><view class="bottom"><text>{{"金额:￥"+item.totalprice}}</text></view><view class="op"><view class="btn2" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">订单详情</view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="51d6567a-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="51d6567a-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="51d6567a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="51d6567a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="51d6567a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>