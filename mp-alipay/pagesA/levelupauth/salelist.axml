<view class="container"><block a:if="{{isload}}"><block><view class="box"><view class="title flex-sb"><view class="bold">{{"剩余额度("+salelevel_money+")"}}</view></view><block a:if="{{levellist.length>0}}"><view class="itembox"><block a:for="{{levellist}}" a:for-item="item" a:for-index="index"><view class="item flex-sb"><view class="left" data-url="{{'leveldetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="headimg" src="{{item.icon}}"></image><view class="info"><view class="desc">{{item.name}}</view><view class="remark txthide">{{"升级费用："+item.apply_paymoney}}</view></view></view><view class="right"><block a:if="{{$root.m0}}"><button class="btn" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}" data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" catchTap="__e">转赠</button></block><block a:else><button class="btn" open-type="share" data-type="1" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}">转赠</button></block><block a:if="{{$root.m1}}"><button class="btn" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}" data-event-opts="{{[['tap',[['tosale',['$event']]]]]}}" catchTap="__e">售卖</button></block><block a:else><button class="btn" open-type="share" data-type="2" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}">售卖</button></block></view></view></block></view></block><block a:if="{{levellist.length==0}}"><view class="nomore">-暂无可售卖会员等级-</view></block></view><block a:if="{{dialogShow}}"><view data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" class="popup_modal" onTap="__e"><view class="content1"><view class="title">我要转赠</view><view class="f1">点击下方按钮，复制链接发送给好友</view><block a:if="{{$root.m2=='wx'}}"><view data-event-opts="{{[['tap',[['shareScheme',['$event']]]]]}}" class="btnbox" onTap="__e"><button class="btn2" style="{{'background:'+($root.m3)+';'}}">复制</button></view></block><block a:else><view class="btnbox"><button class="btn2" style="{{'background:'+($root.m4)+';'}}" data-text="{{pre_url+'/h5/'+aid+'.html#/pagesA/levelupauth/give?pid='+frommid+'&levelid='+levelid}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" onTap="__e">复制</button></view></block></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="15a7c8ca-1" onVueInit="__l"></loading></block><popmsg vue-id="15a7c8ca-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>