<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="36733a7a-1" itemdata="{{['全部','待付款','已付款']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?type=1&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1}}"><text class="st1">{{item.$orig.ordertype==1?'已领取':'已付款'}}</text></block><block a:if="{{item.$orig.status==-1}}"><text class="st2">已取消</text></block></view><view class="content"><view><image src="{{item.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.title}}</text><text class="t2" style="color:#666;">{{(item.$orig.ordertype==1?'赠送':'售卖')+"等级："+item.$orig.levelname}}</text></view></view><view class="bottom"><text>{{"金额:￥"+item.$orig.totalprice}}</text></view><view class="op"><view class="btn2" data-url="{{'orderdetail?type=1&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">订单详情</view><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">取消订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去付款</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="36733a7a-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="36733a7a-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="36733a7a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="36733a7a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="36733a7a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>