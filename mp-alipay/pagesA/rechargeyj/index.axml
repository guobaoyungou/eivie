<view><block a:if="{{isload}}"><block><view class="banner" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"></view><view class="user"><image src="{{userinfo.headimg}}" background-size="cover"></image><block a:if="{{set&&set.parent_show==1}}"><view class="info"><view><view class="nickname">{{userinfo.nickname}}</view><view>{{$root.m2+"："+(userinfo.pid>0?userinfo.pnickname:'无')}}</view></view></view></block><block a:else><view class="info"><text class="nickname">{{userinfo.nickname}}</text></view></block></view><view class="contentdata"><view class="data"><view class="data_title flex-y-center"><image class="data_icon" src="{{pre_url+'/static/imgsrc/commission_m1.png'}}"></image>我的业绩</view><view class="data_text">可提现业绩(元)</view><view class="data_price flex-y-center flex-bt"><text>{{userinfo.rechargeyj_money}}</text><block a:if="{{rechargeyj_withdraw==1}}"><view class="data_btn flex-xy-center" style="{{'background:'+('linear-gradient(90deg,'+$root.m3+' 0%,rgba('+$root.m4+',0.8) 100%)')+';'}}" data-url="withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去提现<image src="{{pre_url+'/static/imgsrc/commission_dw.png'}}"></image></view></block></view><view class="data_module flex"><view class="flex1"><view class="data_lable">已提现业绩(元)</view><view class="data_value">{{txmoney}}</view></view></view></view><view class="list"><view class="item" data-url="/activity/commission/poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/imgsrc/commission_i4.png'}}"></image><view class="flex1"><view class="title">分享海报</view><view class="text">邀请好友享收益</view></view></view><view class="item" data-url="log" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/imgsrc/commission_i3.png'}}"></image><view class="flex1"><view class="title">业绩明细</view><view class="text">查看明细</view></view></view></view></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="467f318d-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="467f318d-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="467f318d-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>