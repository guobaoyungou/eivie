<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">姓名<text style="color:red;">*</text></view><view class="f2"><input type="text" name="name" placeholder="请填写姓名" placeholder-style="color:#888" value="{{name}}"/></view></view><view class="form-item"><view class="f1">联系方式<text style="color:red;">*</text></view><view class="f2"><input type="text" name="tel" placeholder="请填写联系方式" placeholder-style="color:#888" value="{{tel}}"/></view></view><view class="form-item"><view class="f1">毕业院校<text style="color:red;">*</text></view><view class="f2"><input type="text" name="school" placeholder="请填写毕业院校" placeholder-style="color:#888" value="{{school}}"/></view></view><view class="form-item"><view class="f1">学历<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeEducationlistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{education}}"><text>{{educationname}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="form-item"><view class="f1">证书类别<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{cids.length>0}}"><text>{{cnames}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="form-item"><view class="f1">职业<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeJoblistDialog',['$event']]]]]}}" class="f2" onTap="__e"><block a:if="{{job_id.length>0}}"><text>{{job_name}}</text></block><block a:else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">证书图片<text style="color:red;">*</text></view><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{certificate_pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="certificate_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{certificate_pic.length<6}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="certificate_pic" data-pernum="6" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="certificate_pic" maxlength="-1" value="{{$root.g0}}"/></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">身份证正面<text style="color:red;">*</text></view><view class="f2"><view class="layui-imgbox" a:for="{{idcard_pic_front}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="idcard_pic_front" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{idcard_pic_front==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="idcard_pic_front" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="idcard_pic_front" maxlength="-1" value="{{$root.g1}}"/></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">身份证反面<text style="color:red;">*</text></view><view class="f2"><view class="layui-imgbox" a:for="{{idcard_pic_back}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="idcard_pic_back" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{idcard_pic_back==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="idcard_pic_back" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="idcard_pic_back" maxlength="-1" value="{{$root.g2}}"/></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form><block a:if="{{educationshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeEducationlistDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择学历</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeEducationlistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['educationChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.$orig.id==education?'background:'+item.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block><block a:if="{{clistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择证书类别</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m3?'background:'+item.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block><block a:if="{{joblistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeJoblistDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择职业</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeJoblistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['jobChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m5?'background:'+item.m6+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block></block></block></view>