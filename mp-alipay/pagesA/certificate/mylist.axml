<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索我的证书" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/><button data-event-opts="{{[['tap',[['searchConfirm',['$event']]]]]}}" class="search-btn" onTap="__e">搜索</button></view></view><view class="content"><view class="list"><view class="item" data-url="{{'detail?ismy=1&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="inex"><view class="pic"><image class="image" mode="widthFix" src="{{item.certificate_pic}}"></image></view><view class="info"><view class="p1">{{"证书名称："+item.cname}}</view><view class="p1">{{"联  系 人："+item.name}}</view><view class="p1">{{"联系方式："+item.tel}}</view><view class="p1">审核状态：<block a:if="{{item.ischecked==1}}"><text style="color:green;">审核中</text></block><block a:if="{{item.ischecked==2}}"><text style="color:red;">{{"审核驳回,"+item.check_reason}}</text></block><block a:if="{{item.ischecked==0}}"><text>待审核</text></block></view></view></view></view></view></block></block></view>