<view class="container"><block a:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+(pre_url+'/static/img/ordertop.png')+');background-size:100%')}}"><block a:if="{{detail.status==0}}"><view class="f1"><view class="t1">结算中</view></view></block><block a:if="{{detail.status==1}}"><view class="f1"><view class="t1">已完成</view></view></block><block a:if="{{detail.status==2}}"><view class="f1"><view class="t1">挂单中</view></view></block><block a:if="{{detail.status==10}}"><view class="f1"><view class="t1">已退款</view></view></block></view><view class="product"><view class="box" a:for="{{prolist}}" a:for-item="item" a:for-index="idx" a:key="idx"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><view class="t2 flex flex-y-center flex-bt"><text>{{item.ggname}}</text><block a:if="{{detail.status==3&&item.iscomment==0&&shopset.comment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去评价</view></block><block a:if="{{detail.status==3&&item.iscomment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看评价</view></block></view><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view><block a:if="{{(detail.status==1||detail.status==2)&&detail.freight_type==1&&item.hexiao_code}}"><block><view class="btn2" style="position:absolute;top:20rpx;right:0rpx;" data-id="{{item.id}}" data-num="{{item.num}}" data-hxnum="{{item.hexiao_num}}" data-hexiao_code="{{item.hexiao_code}}" data-event-opts="{{[['tap',[['showhxqr2',['$event']]]]]}}" catchTap="__e">核销码</view></block></block></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block a:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block a:if="{{detail.paytype}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block a:if="{{detail.status==2}}"><view class="item"><text class="t1">挂单时间</text><text class="t2">{{detail.hangup_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.pre_totalprice}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block a:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><block a:if="{{detail.dec_money>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.dec_money}}</text></view></block><block a:if="{{detail.moling_money>0}}"><view class="item"><text class="t1">抹零</text><text class="t2 red">{{"-¥"+detail.moling_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red"><block a:if="{{showprice_dollar&&detail.usd_totalprice>0}}"><text>{{"$"+detail.usd_totalprice}}</text></block>{{'¥'+detail.totalprice}}</text></view><view class="item"><text class="t1">收银员</text><text class="t2 ">{{detail.admin_user}}</text></view><view class="item"><text class="t1">订单状态</text><block a:if="{{detail.status==0}}"><text class="t2">结算中</text></block><block a:if="{{detail.status==1}}"><text class="t2">已完成</text></block><block a:if="{{detail.status==2}}"><text class="t2">挂单中</text></block><block a:if="{{detail.status==10}}"><text class="t2">已退款</text></block></view><block a:if="{{detail.refund_money>0}}"><view class="item"><text class="t1">已退款</text><text class="t2 red">{{"¥"+detail.refund_money}}</text></view></block><block a:if="{{detail.refund_money>0}}"><view class="item"><text class="t1">退款时间</text><text class="t2 red">{{$root.m4}}</text></view></block><block a:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 red">已退款</text></block></view></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><block a:if="{{fromfenxiao==0}}"><view class="bottom notabbarbot"><block a:if="{{detail.payaftertourl&&detail.payafterbtntext}}"><block><view style="position:relative;"><block a:if="{{detail.payafter_username}}"><block><view class="btn2">{{detail.payafterbtntext}}</view></block></block><block a:else><block><view class="btn2" data-url="{{detail.payaftertourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{detail.payafterbtntext}}</view></block></block></view></block></block></view></block><uni-popup vue-id="d05cc926-1" id="dialogHxqr" type="dialog" ref="__r" data-ref="dialogHxqr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><block a:if="{{detail.hexiao_code_member}}"><view><input style="border:1px #eee solid;padding:10rpx;margin:20rpx 10rpx;height:70rpx;border-radius:4px;flex:1;font-size:28rpx;" type="number" placeholder="请输入核销密码" data-event-opts="{{[['input',[['set_hexiao_code_member',['$event']]]]]}}" onInput="__e"/><button data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m5)+';'}}" onTap="__e">确定</button></view></block><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><uni-popup vue-id="d05cc926-2" id="dialogSelectExpress" type="dialog" ref="__r" data-ref="dialogSelectExpress" onVueInit="__l"><block a:if="{{express_content}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><view class="sendexpress" style="border-bottom:1px solid #f5f5f5;padding:20rpx 0;" a:for="{{express_content}}" a:for-item="item" a:for-index="index" a:key="index"><view class="sendexpress-item" style="display:flex;" data-url="{{'/pagesExt/order/logistics?express_com='+item.express_com+'&express_no='+item.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="flex1" style="color:#121212;">{{item.express_com+" - "+item.express_no}}</view><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block a:if="{{item.express_oglist}}"><view style="margin-top:20rpx;"><view class="oginfo-item" style="display:flex;align-items:center;margin-bottom:10rpx;" a:for="{{item.express_oglist}}" a:for-item="item2" a:for-index="index2" a:key="index2"><image style="width:50rpx;height:50rpx;margin-right:10rpx;flex-shrink:0;" src="{{item2.pic}}"></image><view class="flex1" style="color:#555;">{{item2.name+"("+item2.ggname+")"}}</view></view></view></block></view></view></block></uni-popup><block a:if="{{selecthxnumDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideSelecthxnumDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择核销数量</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideSelecthxnumDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['hxnumRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.$orig}}</view><view class="radio" style="{{(hxnum==item.$orig?'background:'+item.m6+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="d05cc926-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d05cc926-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d05cc926-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="d05cc926-6" onVueInit="__l"></wxxieyi></view>