<block a:if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image data-url="ranking" src="{{pre_url+'/static/imgsrc/rank.png'}}" mode="widthFix" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"></image><view class="content"><view class="top"><view class="t1">{{"数据统计日期： "+region_ctime}}</view></view><view class="tabsort"><block a:if="{{$root.m1}}"><view class="{{('t1 '+(1==sorttype?'on':''))}}" style="width:30%;" data-sorttype="{{1}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" onTap="__e">订单金额<block a:if="{{1==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m2)}}"></view></block></view></block><block a:if="{{$root.m3}}"><view class="{{('t1 '+(2==sorttype?'on':''))}}" style="width:30%;" data-sorttype="{{2}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" onTap="__e">订单数量<block a:if="{{2==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m4)}}"></view></block></view></block></view><view class="tab1"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('t1 '+(index==ranktype?'on':''))}}" style="{{'color:'+(index==ranktype?item.m5:'')+';'}}" data-ranktype="{{index}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" onTap="__e">{{''+item.$orig+''}}<block a:if="{{index==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m6)}}"></view></block></view></block></view><block a:if="{{selfdata&&ranktype==3}}"><view class="itembox"><view class="item"><view class="t1" style="font-size:28rpx;"><view>当前排名</view><block a:if="{{selfdata.key>=1}}"><view>{{"第"+selfdata.key+"名"}}</view></block><block a:else><view>无</view></block></view><block a:if="{{sorttype==2}}"><block><view class="t2" style="width:300rpx;"><image style="margin-right:10rpx;" src="{{selfdata.headimg}}"></image><view class="name" style="width:200rpx;">{{selfdata.nickname}}</view></view><text class="t3" style="width:100rpx;">{{''+selfdata.num}}</text><view data-url="{{'rankingorder?id='+id+'&sorttype='+sorttype}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">查看订单</view></block></block><block a:else><block><view class="t2"><image style="margin-right:10rpx;" src="{{selfdata.headimg}}"></image><view class="name">{{selfdata.nickname}}</view></view><text class="t3">{{''+selfdata.totalprice}}</text></block></block></view></view></block><view class="tab"><view class="t1">排名</view><view class="t2">{{ranktype==3?'用户':'区域名'}}</view><block a:if="{{sorttype==1}}"><view class="t3" style="{{'color:'+($root.m7)+';'}}">订单金额</view></block><block a:if="{{sorttype==2}}"><view class="t3" style="{{'color:'+($root.m8)+';'}}">订单数量</view></block></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><block a:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block a:else><view class="t1">{{index+1}}</view></block><block a:if="{{ranktype==3}}"><view class="t2"><image src="{{item.headimg}}"></image><view class="name">{{item.nickname}}</view></view></block><block a:else><view class="t2"><text style="margin-left:20rpx;"></text>{{''+item.title+''}}</view></block><block a:if="{{sorttype==1}}"><text class="t3">{{''+item.totalprice}}</text></block><block a:if="{{sorttype==2}}"><text class="t3">{{''+item.num}}</text></block></view></block></view></view></view><block a:if="{{nodata}}"><nodata vue-id="b45eb6b6-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="b45eb6b6-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="b45eb6b6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="b45eb6b6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="b45eb6b6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block></block>