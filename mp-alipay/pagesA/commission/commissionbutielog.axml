<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f2"><view class="t1"><text class="x1">{{"发放期数：第"+item.$orig.send_circle+"期"}}</text><text class="x2">{{"发放时间："+item.m0}}</text></view><view class="t2"><text class="x1">{{"+"+item.$orig.send_num}}</text></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="edef246c-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="edef246c-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="edef246c-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="edef246c-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="edef246c-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>