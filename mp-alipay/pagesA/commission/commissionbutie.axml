<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f2" data-url="{{'/pagesA/commission/commissionbutielog?pid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><block a:if="{{item.$orig.frommid>0}}"><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></block><text class="x2">{{"总期数："+item.$orig.fx_butie_circle+" 已发："+item.$orig.send_circle}}</text><text class="x2">{{item.$orig.circle_str+''}}</text></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block><text class="dior-sp6 yfk">{{"已发放："+item.$orig.have_send}}</text></block></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="27f6b03a-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="27f6b03a-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="27f6b03a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="27f6b03a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="27f6b03a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>