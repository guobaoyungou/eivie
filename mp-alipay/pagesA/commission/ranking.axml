<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'rankingdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><text class="t1">{{item.name}}</text><block a:if="{{item.createtime}}"><text class="t2">{{item.createtime}}</text></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="0edc3054-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="0edc3054-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="0edc3054-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0edc3054-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0edc3054-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>