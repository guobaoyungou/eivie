<view class="container"><block a:if="{{isload}}"><block><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head" style="justify-content:space-between;"><block a:if="{{item.ordernum}}"><view class="f1">{{"订单号:"+item.ordernum}}</view></block><block a:else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></view><block a:for="{{item.prolist}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item2.pic}}" mode="aspectFill"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><block><block a:if="{{item2.product_type&&item2.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item2.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item2.real_total_weight+"斤"}}</text></view></block><block a:else><view class="t3"><text class="x1 flex1">{{'￥'+item2.sell_price+''}}</text><text class="x2">{{"×"+item2.num}}</text></view></block></block></view></view></block><block a:if="{{item.mid||item.nickname}}"><view class="bottom" style="display:flex;"><block a:if="{{item.mid}}"><view>{{"ID:"+item.mid}}</view></block><block a:if="{{item.nickname}}"><view style="margin-left:10rpx;">{{item.nickname}}</view></block></view></block><view class="bottom"><view>{{'共计'+item.procount+"件商品 实付:￥"+item.totalprice+''}}</view></view><block a:if="{{item.tips!=''}}"><view class="bottom"><text style="color:red;">{{item.tips}}</text></view></block></view></block></view><block a:if="{{nomore}}"><nomore vue-id="7e0e7f64-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="7e0e7f64-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="7e0e7f64-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="7e0e7f64-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7e0e7f64-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>