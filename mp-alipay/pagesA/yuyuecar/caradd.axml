<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="form"><view class="form-item" style="overflow:hidden;"><text class="label">车牌</text><view style="flex:1;"></view><view data-event-opts="{{[['tap',[['openNumber',['$event']]]]]}}" style="width:200rpx;text-align:right;overflow:hidden;line-height:60rpx;" onTap="__e"><text>{{number}}</text><image style="width:30rpx;height:30rpx;float:right;margin-top:14rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="form-item"><text class="label">车型</text><view style="flex:1;"></view><view style="width:200rpx;text-align:right;overflow:hidden;line-height:60rpx;"><picker class="input" name="type" value="{{type}}" range="{{typedata}}" data-event-opts="{{[['change',[['pickerCar',['$event']]]]]}}" onChange="__e">{{''+typename+''}}<image style="width:30rpx;height:30rpx;float:right;margin-top:14rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></picker></view></view><view class="form-item"><text class="label">颜色</text><input class="input" type="text" placeholder="请输入颜色" placeholder-style="font-size:28rpx;color:#BBBBBB" name="color" value="{{color}}"/></view><view class="form-item"><text class="label">姓名</text><input class="input" type="text" placeholder="请输入姓名" placeholder-style="font-size:28rpx;color:#BBBBBB" name="name" value="{{name}}"/></view><view class="form-item"><text class="label">手机号</text><input class="input" type="number" placeholder="请输入手机号" placeholder-style="font-size:28rpx;color:#BBBBBB" name="tel" value="{{tel}}"/></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">保 存</button></form><uni-popup vue-id="565913ab-1" id="dialogCar" type="dialog" ref="__r" data-ref="dialogCar" onVueInit="__l"><view class="uni-popup-dialog" style="width:100%;position:fixed;bottom:0;left:0;"><view class="uni-dialog-content" style="padding:40rpx 0;"><carnumberinput vue-id="{{('565913ab-2')+','+('565913ab-1')}}" defaultStr="{{number}}" data-event-opts="{{[['^inputResult',[['inputnumber']]],['^close',[['dialogCarClose']]]]}}" onInputResult="__e" onClose="__e" onVueInit="__l"></carnumberinput></view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="565913ab-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="565913ab-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="565913ab-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>