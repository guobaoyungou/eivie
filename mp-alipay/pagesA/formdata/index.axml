<view class="container"><block a:if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索相关信息" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['search',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view></view><view class="ind_business"><view class="ind_buslist" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view data-url="{{item.tourl?item.tourl:'/pagesA/formdata/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="ind_busbox flex1 flex-row"><view class="ind_buspic flex0"><image src="{{item.logo}}"></image></view><view class="flex1" style="flex:1;"><view class="bus_title">{{item.title}}</view><block a:if="{{item.address}}"><view class="bus_address" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.title}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;float:left;margin-top:4rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image><text class="x1">{{item.address}}</text><text class="x2">{{item.juli}}</text></view></block><block a:if="{{item.tel}}"><view class="bus_address" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;float:left;margin-top:4rpx;" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="x1">{{"联系电话："+item.tel}}</text></view></block></view><view style="width:140rpx;text-align:center;line-height:142rpx;font-size:24rpx;" data-url="{{item.tourl?item.tourl:'/pagesA/formdata/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看信息</view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="11178b52-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="11178b52-2" onVueInit="__l"></nodata></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="11178b52-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="11178b52-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="11178b52-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="11178b52-6" onVueInit="__l"></wxxieyi></view>