<view style="width:100%;height:100%;padding-bottom:60rpx;"><block a:if="{{isload&&detail}}"><block><view style="{{('width:100%;background-color:'+detail.color)}}"><view class="content_view"><view style="width:540rpx;"><view style="font-size:36rpx;font-weight:bold;line-height:60rpx;">{{detail.title+''}}</view><view class="content" style="display:block;"><view style="width:100%;white-space:pre-wrap;word-break:break-all;">{{detail.word}}</view><view style="width:100%;white-space:pre-wrap;word-break:break-all;">{{detail.word2}}</view></view></view><view class="right_view"><image style="width:100%;height:100%;" src="{{detail.logo}}"></image></view></view></view><view style="width:680rpx;margin:0 auto;"><block a:if="{{detail.content&&detail.content.length>0}}"><block><view style="margin:20rpx 0;" a:for="{{detail.content}}" a:for-item="item" a:for-index="index" a:key="index"><view style="line-height:60rpx;color:#161616;font-size:36rpx;font-weight:bold;margin:10rpx 0;">{{''+item.name+''}}</view><view class="bottom_content"><block a:if="{{item.type=='address'}}"><view data-latitude="{{detail.latitude}}" data-longitude="{{detail.longitude}}" data-company="{{detail.title}}" data-address="{{item.content}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e"><image style="width:30rpx;height:30rpx;margin-right:20rpx;float:left;margin-top:14rpx;" src="{{pre_url+'/static/img/b_addr.png'}}" class="_img"></image>{{''+item.content+''}}</view></block><block a:else><block a:if="{{item.type=='tel'}}"><view data-phone="{{item.content}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e"><image style="width:30rpx;height:30rpx;margin-right:20rpx;float:left;margin-top:14rpx;" src="{{pre_url+'/static/img/b_tel.png'}}" class="_img"></image>{{''+item.content+''}}</view></block><block a:else><view><block a:if="{{item.key=='upload'}}"><view><image style="width:200rpx;" src="{{item.content}}" mode="widthFix" data-url="{{item.content}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><block a:if="{{item.key=='upload_file'}}"><view style="overflow:hidden;white-space:pre-wrap;word-wrap:break-word;color:#4786BC;">{{''+item.content+''}}</view></block><block a:else><block a:if="{{item.key=='upload_pics'}}"><view><block a:for="{{item.content}}" a:for-item="item2" a:for-index="index2" a:key="index2"><image style="width:200rpx;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block></view></block><block a:else><view>{{''+item.content+''}}</view></block></block></block></view></block></block></view></view></block></block></view></block></block><block a:if="{{loading}}"><loading vue-id="6a3ed98e-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="6a3ed98e-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6a3ed98e-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>