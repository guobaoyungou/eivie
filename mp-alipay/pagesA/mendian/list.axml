<view><block a:if="{{isload}}"><block><view class="tab"><view class="tab-item" style="{{(md_cid==0?'color:'+$root.m0+';background:rgba('+$root.m1+',0.2)':'')}}" data-id="{{0}}" data-event-opts="{{[['tap',[['changeCategory',['$event']]]]]}}" onTap="__e">全部</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="tab-item" style="{{(md_cid==item.$orig.id?'color:'+item.m2+';background:rgba('+item.m3+',0.2)':'')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeCategory',['$event']]]]]}}" onTap="__e">{{item.$orig.name}}</view></block></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索门店" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="storeitem"><view class="radio-item" data-url="{{'/pages/shop/mendian?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="f1"><view><text class="iconfont icondingwei"></text>{{''+item.name+''}}</view><block a:if="{{item.tel}}"><view style="color:#aaaaae;font-size:26rpx;margin-top:20rpx;">{{''+item.tel+''}}</view></block><view class="address" data-address="{{item.address}}" data-longitude="{{item.longitude}}" data-latitude="{{item.latitude}}" data-event-opts="{{[['tap',[['toMendian',['$event']]]]]}}" catchTap="__e"><view class="address2"><block a:if="{{item.province!='北京市'||item.province!='上海市'||item.province!='重庆市'||item.province!='天津市'}}"><text>{{item.province}}</text></block>{{item.city+item.district}}<block a:if="{{item.address}}"><text>{{item.address}}</text></block></view><image style="display:inline-block;width:26rpx;height:26rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><text class="juli">{{item.distance}}</text></view></view></block></block><block a:if="{{loading}}"><loading vue-id="302635c3-1" onVueInit="__l"></loading></block><block a:if="{{nodata}}"><nodata vue-id="302635c3-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="302635c3-3" onVueInit="__l"></nomore></block><dp-tabbar vue-id="302635c3-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="302635c3-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>