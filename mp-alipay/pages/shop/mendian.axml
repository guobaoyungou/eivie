<view><block><block a:if="{{isload}}"><view class="container nodiydata"><view class="bg-red" style="{{'background:'+($root.m0)+';'}}"></view><view class="topcontent"><view class="logo"><image class="img" src="{{info.pic}}"></image></view><view class="title">{{info.name}}</view><view class="desc"><block a:if="{{info.subname}}"><block>{{info.subname}}</block></block></view><view class="tel" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%, rgba('+$root.m2+',0.8) 100%)')+';'}}"><view class="tel_online" data-phone="{{info.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/telwhite.png'}}"></image>联系门店</view></view><view class="address" data-latitude="{{info.latitude}}" data-longitude="{{info.longitude}}" data-company="{{info.name}}" data-address="{{info.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><image class="f1" src="{{pre_url+'/static/img/shop_addr.png'}}"></image><view class="f2">{{info.address}}</view><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="img-view"><block a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{pics.length>0}}"><view><image class="image" src="{{item}}" mode="widthFix" data-url="{{item}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block></block></view></view><block a:if="{{info.content}}"><view class="contentbox"><view class="cp_detail" style="padding:20rpx;"><parse vue-id="b4918f98-1" content="{{info.content}}" onVueInit="__l"></parse></view></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="b4918f98-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="b4918f98-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="b4918f98-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>