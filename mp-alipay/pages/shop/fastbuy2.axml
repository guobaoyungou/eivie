<view class="container"><block a:if="{{isload}}"><block><view class="view-show"><view class="topbannerbg" style="{{(business.pic?'background:url('+business.pic+') 100%':'')}}"></view><view class="topbannerbg2"></view><view class="topbanner"><view class="left"><image class="img" src="{{business.logo}}"></image></view><view class="right"><view class="f1">{{business.name}}</view><view class="f2">{{business.desc}}</view><block a:if="{{business.address}}"><view class="f2" style="opacity:0.9;" data-latitude="{{business.latitude}}" data-longitude="{{business.longitude}}" data-company="{{business.name}}" data-address="{{business.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" onTap="__e"><text class="iconfont icondingwei"></text>{{business.address}}</view></block></view></view><view class="navtab"><block a:if="{{paylist&&paylist.length>0}}"><block><block a:for="{{menuList}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('item '+(st==item.st?'on':''))}}" data-st="{{item.st}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e">{{item.alias?item.alias:item.name}}<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view></block></block></block><block a:else><block><view class="{{(('item')+' '+(st==0?'on':''))}}" data-st="0" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e">商品<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view><view class="{{(('item')+' '+(st==1?'on':''))}}" data-st="1" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e">商家信息<view class="after" style="{{'background:'+($root.m2)+';'}}"></view></view><block a:if="{{!paylist||paylist.length==0}}"><view class="{{(('item')+' '+(st==2?'on':''))}}" data-st="2" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" onTap="__e">评价<view class="after" style="{{'background:'+($root.m3)+';'}}"></view></view></block></block></block></view><block a:if="{{st==0}}"><view class="content" style="{{'overflow:hidden;display:flex;margin-top:86rpx;'+('height:'+('calc(100% - '+(menuindex>-1?550:450)+'rpx)')+';')}}"><scroll-view class="nav_left" scrollWithAnimation="{{animation}}" scroll-y="true"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" style="{{'color:'+(index===currentActiveIndex?item.m4:'#333')+';'}}" data-root-item-id="{{item.$orig.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m5)+';'}}"></view>{{item.$orig.name}}</view></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="detail-list" scrollIntoView="{{scrollToViewId}}" scrollWithAnimation="{{animation}}" scroll-y="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" onScroll="__e"><view class="classification-detail-item" a:for="{{$root.l2}}" a:for-item="detail" a:for-index="index" a:key="index"><view class="head" data-id="{{detail.$orig.id}}" id="{{'detail-'+detail.$orig.id}}"><view class="txt">{{detail.$orig.name}}</view></view><view class="product-itemlist"><view class="item" a:for="{{detail.l1}}" a:for-item="item" a:for-index="indexs" a:key="indexs"><view class="product-pic" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.$orig.name}}</text></view><block a:if="{{custom.product_show_sellpoint&&item.$orig.sellpoint}}"><view class="p5" style="{{'color:'+(item.m6)+';'}}"><text>{{item.$orig.sellpoint}}</text></view></block><block a:if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m7)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m8}}</text></view></block><block a:if="{{item.$orig.price_type!=1||item.$orig.sell_price>0}}"><view class="p2"><view class="t1" style="{{'color:'+(item.m9)+';'}}"><text style="font-size:20rpx;padding-right:1px;">￥</text>{{item.$orig.sell_price+''}}<block a:if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block a:if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block></view><block a:if="{{item.m10}}"><text class="t1-m" style="{{'color:'+(item.m11)+';'}}">{{"+"+item.$orig.service_fee+item.m12}}</text></block><block a:if="{{custom.product_weight&&item.$orig.product_type==2&&item.$orig.unit_price}}"><text class="t1-m" style="{{'color:'+(item.m13)+';'}}">{{'(约'+item.$orig.unit_price+'元/斤)'}}</text></block><block a:if="{{item.$orig.market_price*1>item.$orig.sell_price*1}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block></view></block><block a:if="{{item.$orig.price_show&&item.$orig.price_show==1}}"><view style="line-height:46rpx;"><text style="font-size:26rpx;">{{"￥"+item.$orig.sell_putongprice}}</text></view></block><block a:if="{{item.$orig.priceshows&&item.$orig.priceshows.length>0}}"><view><view style="line-height:46rpx;" a:for="{{item.$orig.priceshows}}" a:for-item="item2" a:for-index="index2"><text style="font-size:26rpx;">{{"￥"+item2.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item2.price_show_text}}</text></view></view></block><block a:if="{{custom.product_show_fwlist&&item.$orig.fwlist&&item.$orig.fwlist.length>0}}"><view class="p6"><view class="p6-m" style="{{('background:rgba('+item.m14+',0.15);color:'+item.m15+';')}}" a:for="{{item.$orig.fwlist}}" a:for-item="fw" a:for-index="fwidx" a:key="fwidx">{{''+fw+''}}</view></view></block><view class="p3"><block a:if="{{item.$orig.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.$orig.sales+"件"}}</text></view></block></view><block a:if="{{!item.$orig.price_type}}"><view class="addnum"><block a:if="{{numtotal[item.$orig.id]>0}}"><view class="countbut-view" style="padding-right:10rpx;" data-num="-1" data-proid="{{item.$orig.id}}" data-stock="{{item.$orig.stock}}" data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" catchTap="__e"><view class="minus">-</view></view></block><block a:if="{{numtotal[item.$orig.id]>0}}"><view class="input-view" style="{{'width:'+(item.m16>=100?'75rpx':'60rpx')+';'}}"><input class="input-class" style="{{'width:'+(item.m17>=100?'75rpx':item.m18>=10?'45rpx':'30rpx')+';'}}" type="number" data-event-opts="{{[['blur',[['inpurCart',['$event','$0','$1'],[[['datalist','',index],['prolist','',indexs,'id']],[['datalist','',index],['prolist','',indexs,'gglist.__$n0.id']]]]]],['input',[['__set_model',['$0','$1','$event',[]],['numtotal',[['datalist','',index],['prolist','',indexs,'id']]]]]]]}}" value="{{numtotal[item.$orig.id]}}" onBlur="__e" onInput="__e"/></view></block><block a:if="{{item.$orig.ggcount>1}}"><view class="countbut-view" style="padding-left:10rpx;" data-proid="{{item.$orig.id}}" data-stock="{{item.$orig.stock}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchTap="__e"><view class="plus">+</view></view></block><block a:else><view class="countbut-view" style="padding-left:10rpx;" data-num="1" data-proid="{{item.$orig.id}}" data-ggid="{{item.$orig.gglist[0].id}}" data-stock="{{item.$orig.stock}}" data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" catchTap="__e"><view class="plus">+</view></view></block></view></block></view></view></view></view></scroll-view></view></view></view></block><block a:if="{{st==1}}"><view class="content1" style="margin-top:86rpx;padding-top:20rpx;"><view class="item flex-col"><text class="t1">联系电话</text><text class="t2">{{business.tel}}</text></view><view class="item flex-col"><text class="t1">商家地址</text><text class="t2">{{business.address}}</text></view><view class="item flex-col"><text class="t1">商家简介</text><view class="t2"><parse vue-id="190bef78-1" content="{{business.content}}" onVueInit="__l"></parse></view></view><block a:if="{{bid!=0}}"><view class="item flex-col"><text class="t1">营业时间</text><text class="t2">{{business.start_hours+" 至 "+business.end_hours}}</text></view></block><view style="width:100%;height:140rpx;clear:both;"></view></view></block><block a:if="{{st==2}}"><view class="content2" style="margin-top:86rpx;padding-top:20rpx;"><view class="comment" style="height:calc(100vh - 460rpx);overflow:scroll;"><block a:if="{{commentlist.length>0}}"><block><view class="title"><view class="f1">{{"评价("+business.comment_num+")"}}</view><view data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" class="f2" onTap="__e">好评率<text style="{{'color:'+($root.m19)+';'}}">{{business.comment_haopercent+"%"}}</text></view></view><view class="item" a:for="{{commentlist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="t1" src="{{item.headimg}}"></image><view class="t2">{{item.nickname}}</view><view class="flex1"></view><view class="t3"><image class="img" src="{{pre_url+'/static/img/star'+(item.score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2" a:key="index2"></image></view></view><view style="color:#777;font-size:22rpx;">{{item.createtime}}</view><view class="f2"><text class="t1">{{item.content}}</text><view class="t2"><block a:if="{{item.content_pic!=''}}"><block><block a:for="{{item.content_pic}}" a:for-item="itemp" a:for-index="index" a:key="index"><view data-url="{{itemp}}" data-urls="{{item.content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></view></view><block a:if="{{item.reply_content}}"><view class="f3"><view class="arrow"></view><view class="t1">{{"商家回复："+item.reply_content}}</view></view></block></view><view style="width:100%;height:120rpx;"></view></block></block><block a:else><block><nodata hidden="{{!(comment_nodata)}}" vue-id="190bef78-2" onVueInit="__l"></nodata></block></block></view></view></block><block a:if="{{st==3}}"><view class="content2" style="margin-top:86rpx;padding-top:20rpx;"><view class="paylist" style="height:calc(100vh - 460rpx);overflow:scroll;"><view class="item" data-id="{{item.id}}" data-event-opts="{{[['tap',[['createpayorder',['$event']]]]]}}" onTap="__e" a:for="{{paylist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="f2"><view class="t1"><text>{{item.name}}</text></view><view class="t2" style="{{'color:'+($root.m20)+';'}}">{{"￥"+item.market_price}}<text style="padding:0 4rpx;">/</text><text style="font-size:24rpx;">会员价￥</text>{{item.sell_price}}</view></view><image class="arrowright" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view></block></view><block a:if="{{buydialogShow}}"><buydialog vue-id="190bef78-3" proid="{{proid}}" menuindex="{{menuindex}}" btntype="1" needaddcart="{{false}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]],['^addcart',[['afteraddcart']]]]}}" onBuydialogChange="__e" onAddcart="__e" onVueInit="__l"></buydialog></block><view style="height:auto;position:relative;"><view style="width:100%;height:100rpx;"></view><view class="{{((('footer')+' '+'flex')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="cart_ico" style="{{'background:'+('linear-gradient(0deg,'+$root.m21+' 0%,rgba('+$root.m22+',0.8) 100%)')+';'}}" catchTap="__e"><image class="img" src="{{pre_url+'/static/img/cart.png'}}"></image><block a:if="{{cartList.total>0}}"><view class="cartnum" style="{{'background:'+($root.m23)+';'}}">{{cartList.total}}</view></block></view><view class="text1">合计</view><view class="text2" style="{{'color:'+($root.m24)+';'}}"><text style="font-size:20rpx;">￥</text>{{cartList.totalprice}}</view><view class="flex1"></view><view data-event-opts="{{[['tap',[['gopay',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(270deg,'+$root.m25+' 0%,rgba('+$root.m26+',0.8) 100%)')+';'}}" onTap="__e">去结算</view></view></view><uni-popup vue-id="190bef78-4" type="bottom" animation="{{false}}" ref="__r" data-ref="popup" onVueInit="__l"><view class="{{(('popup-content-fastbuy')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="popup__title" style="border-bottom:1px solid #EFEFEF;"><text class="popup__title-text" style="color:#323232;font-weight:bold;font-size:32rpx;">购物车</text><view data-event-opts="{{[['tap',[['clearShopCartFn',['$event']]]]]}}" class="popup__close flex-y-center" style="color:#999999;font-size:24rpx;" catchTap="__e"><image style="width:24rpx;height:24rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/del.png'}}"></image>清空</view></view><view class="popup__content" style="padding:0;"><scroll-view class="prolist" scroll-y="{{true}}"><block a:for="{{$root.l3}}" a:for-item="cart" a:for-index="index" a:key="index"><view class="proitem"><image class="pic flex0" src="{{cart.$orig.guige.pic?cart.$orig.guige.pic:cart.$orig.product.pic}}"></image><view class="con"><view class="f1">{{cart.$orig.product.name}}</view><block a:if="{{cart.$orig.guige.name!='默认规格'}}"><view class="f2">{{cart.$orig.guige.name}}</view></block><view class="f3" style="color:#ff5555;margin-top:10rpx;font-size:28rpx;">{{"￥"+cart.$orig.guige.sell_price}}</view></view><view class="addnum"><view class="minus" data-num="-1" data-proid="{{cart.$orig.proid}}" data-ggid="{{cart.$orig.ggid}}" data-stock="{{cart.$orig.guige.stock}}" data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><view class="input-view" style="{{'width:'+(cart.m27>=100?'75rpx':'60rpx')+';'}}"><input class="input-class" type="number" data-event-opts="{{[['blur',[['inpurCart',['$event','$0','$1'],[[['cartList.list','',index,'proid']],[['cartList.list','',index,'ggid']]]]]],['input',[['__set_model',['$0','num','$event',[]],[[['cartList.list','',index]]]]]]]}}" value="{{cart.$orig.num}}" onBlur="__e" onInput="__e"/></view><view class="plus" data-num="1" data-proid="{{cart.$orig.proid}}" data-ggid="{{cart.$orig.ggid}}" data-stock="{{cart.$orig.guige.stock}}" data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view></block><block a:if="{{!cartList.list.length}}"><block><text class="nopro">暂时没有商品喔~</text></block></block></scroll-view></view></view></uni-popup></block></block><block a:if="{{loading}}"><loading vue-id="190bef78-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="190bef78-6" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="190bef78-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>