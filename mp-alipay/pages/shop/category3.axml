<view class="container"><block a:if="{{isload}}"><block><view class="view-show"><view class="search-container" data-url="{{'/pages/shop/search?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商品</view></view></view><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{(('nav_left')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" data-root-item-id="{{item.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name}}</view></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="{{(('detail-list')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollIntoView="{{scrollToViewId}}" scrollWithAnimation="{{animation}}" scroll-y="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" onScroll="__e"><view class="classification-detail-item" a:for="{{clist}}" a:for-item="detail" a:for-index="index" a:key="index"><view class="head" data-id="{{detail.id}}" id="{{'detail-'+detail.id}}"><view class="txt">{{detail.name}}</view><view class="show-all" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['gotoCatproductPage',['$event']]]]]}}" onTap="__e">查看全部<text class="iconfont iconjiantou"></text></view></view><view class="detail"><view class="detail-item" style="{{((itemIndex+1)%3===0?'margin-right: 0':'')}}" data-id="{{item.id}}" form-type="submit" data-event-opts="{{[['tap',[['gotoCatproductPage',['$event']]]]]}}" catchTap="__e" a:for="{{detail.child}}" a:for-item="item" a:for-index="itemIndex" a:key="itemIndex"><image class="img" src="{{item.pic}}"></image><view class="txt">{{item.name}}</view></view></view></view><block a:if="{{nodata}}"><nodata vue-id="4aaee1a7-1" onVueInit="__l"></nodata></block></scroll-view></view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="4aaee1a7-2" loadstyle="left:62.5%" onVueInit="__l"></loading></block><dp-tabbar vue-id="4aaee1a7-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="4aaee1a7-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>