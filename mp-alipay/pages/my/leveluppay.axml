<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="info-item"><text class="t1">订单名称:</text><text class="t2">{{orderinfo.title}}</text></view><view class="info-item"><text class="t1">订单编号:</text><text class="t2">{{orderinfo.ordernum}}</text></view><view class="info-item"><text class="t1">支付金额:</text><text class="t2" style="color:#e94745;">{{"￥"+orderinfo.totalprice}}</text></view></view><block a:if="{{wxpayst==1}}"><button class="fpay-btn" data-typeid="1" data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" onTap="__e">微信支付</button></block><block a:if="{{alipay==1}}"><button class="fpay-btn" style="background:#108EE9;margin-top:20rpx;" data-typeid="10" data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" onTap="__e">支付宝支付</button></block><block a:if="{{moneypay==1}}"><block><block a:if="{{userinfo.haspwd}}"><button data-event-opts="{{[['tap',[['modalinput',['$event']]]]]}}" class="fpay-btn2" onTap="__e">{{$root.m0+"支付（当前余额¥"+userinfo.money+"）"}}</button></block><block a:else><button class="fpay-btn2" data-typeid="2" data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" onTap="__e">{{$root.m1+"支付（当前余额¥"+userinfo.money+"）"}}</button></block></block></block><block a:if="{{userinfo.haspwd}}"><view class="{{('weui-demo-dialog '+(!hiddenmodalput?'weui-demo-dialog_show':''))}}"><view data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" class="weui-mask" onTap="__e"></view><view class="weui-dialog__wrp"><view class="weui-dialog"><view class="weui-dialog__hd"><view class="weui-dialog__title">支付密码</view></view><view class="weui-dialog__bd"><view class="flex-y-center flex-x-center" style="margin:20rpx 130rpx;"><text style="font-size:40rpx;color:#000;"></text><input type="digit" placeholder="请输入支付密码" data-event-opts="{{[['input',[['getpwd',['$event']]]]]}}" onInput="__e"/></view></view><view class="weui-dialog__ft"><view data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" class="weui-dialog__btn weui-dialog__btn_default" onTap="__e">取消</view><view class="weui-dialog__btn" data-typeid="2" data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" onTap="__e">确定</view></view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="0d242379-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="0d242379-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0d242379-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>