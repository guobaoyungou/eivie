<view class="container"><block a:if="{{isload}}"><block><view class="topfix"></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text>{{item.ordernum}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.name}}</text><text class="x2">{{item.createtime}}</text><view class="x3"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></view><view class="t2"><block a:if="{{item.status==1||item.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><text class="dior-sp6 ywc">已完成</text><block a:if="{{item.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block a:if="{{item.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></view></block></block></block></block><block a:if="{{nodata}}"><nodata vue-id="c66e39b2-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="c66e39b2-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="c66e39b2-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="c66e39b2-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="c66e39b2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>