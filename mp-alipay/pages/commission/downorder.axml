<view class="container"><block a:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{$root.m0+"（"+count+"）"}}</text><text class="t2">{{"预计：+"+commissionyj+"元"}}</text></view><dd-tab vue-id="7f57ad8a-1" itemdata="{{['所有订单','待付款','已付款','已完成','退款/售后']}}" itemst="{{['0','1','2','3','5']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></view><view style="margin-top:190rpx;"></view><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1 flex"><text class="flex1">{{item.ordernum+"("+item.dengji+")"}}</text><block a:if="{{item.dannum&&item.dannum>0}}"><text style="color:#a55;">{{"第"+item.dannum+"单"}}</text></block></view><view class="f2"><view class="t1"><text class="x1">{{item.name+" ×"+item.num}}</text><text class="x2">{{item.createtime}}</text><view class="x3"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></view><view class="t2"><text class="x1">{{"+"+item.commission}}</text><block a:if="{{item.status==1||item.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block a:if="{{item.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block a:if="{{item.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></view></block></block></block></block><block a:if="{{nodata}}"><nodata vue-id="7f57ad8a-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="7f57ad8a-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="7f57ad8a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="7f57ad8a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7f57ad8a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>