<view class="container"><block a:if="{{isload}}"><block><block a:if="{{userlevel&&userlevel.can_agent==2}}"><dd-tab vue-id="b7d8e950-1" itemdata="{{['一级('+userinfo.myteamCount1+')','二级('+userinfo.myteamCount2+')']}}" itemst="{{['1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><block a:if="{{userlevel&&userlevel.can_agent==3}}"><dd-tab vue-id="b7d8e950-2" itemdata="{{['一级('+userinfo.myteamCount1+')','二级('+userinfo.myteamCount2+')','三级('+userinfo.myteamCount3+')']}}" itemst="{{['1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="/static/img/search_ico.png"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text><text class="t2">{{"来自TA的"+$root.m0}}</text></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><text class="x2">{{item.createtime}}</text><text class="x2">{{"等级："+item.levelname}}</text><block a:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block></view></view><view class="f2"><text class="t1">{{"+"+item.commission}}</text><view class="t3"><block a:if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m1}}</view></block><block a:if="{{userlevel&&userlevel.team_givescore==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givescoreshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m2}}</view></block><block a:if="{{userlevel&&userlevel.team_levelup==1}}"><view class="x1" data-id="{{item.id}}" data-levelid="{{item.levelid}}" data-levelsort="{{item.levelsort}}" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" onTap="__e">升级</view></block></view></view></view></block></view></block><uni-popup vue-id="b7d8e950-3" id="dialogmoneyInput" type="dialog" ref="__r" data-ref="dialogmoneyInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('b7d8e950-4')+','+('b7d8e950-3')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="b7d8e950-5" id="dialogscoreInput" type="dialog" ref="__r" data-ref="dialogscoreInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('b7d8e950-6')+','+('b7d8e950-5')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><block a:if="{{dialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">升级</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="/static/img/close.png" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="sheet-item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><text class="item-text flex-item">{{item.$orig.name}}</text><view class="flex1"></view><block a:if="{{item.$orig.id!=tempLevelid&&item.$orig.sort>tempLevelsort}}"><view style="{{'color:'+(item.m3)+';'}}" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['changeLevel',['$event']]]]]}}" onTap="__e">选择</view></block><block a:else><view style="color:#ccc;">选择</view></block></view></view></view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="b7d8e950-7" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="b7d8e950-8" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="b7d8e950-9" onVueInit="__l"></loading></block><dp-tabbar vue-id="b7d8e950-10" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="b7d8e950-11" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>