<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text></view><view class="f2"><block a:if="{{item.$orig.commission>0}}"><text class="t1">{{"+"+item.$orig.commission}}</text></block><block a:else><text class="t2">{{item.$orig.commission}}</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="dd44adb6-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="dd44adb6-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="dd44adb6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="dd44adb6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="dd44adb6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>