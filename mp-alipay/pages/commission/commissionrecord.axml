<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="74cc8005-1" itemdata="{{['全部','已发放','未发放']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f2"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block a:if="{{item.$orig.status==0}}"><block><block a:if="{{item.$orig.orderstatus==1||item.$orig.orderstatus==2}}"><text class="dior-sp6 yfk">已付款</text></block><block a:if="{{item.$orig.orderstatus==0}}"><text class="dior-sp6 dfk">待付款</text></block><block a:if="{{item.$orig.orderstatus==3}}"><text class="dior-sp6 ywc">待发放</text></block><block a:if="{{item.$orig.orderstatus==4}}"><text class="dior-sp6 ygb">已关闭</text></block></block></block><block a:if="{{item.$orig.status==1}}"><block><text class="dior-sp6 yfk">已发放</text></block></block></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="74cc8005-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="74cc8005-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="74cc8005-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="74cc8005-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="74cc8005-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>