<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="/static/img/search_ico.png"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text><text class="t2"></text></view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><image src="{{item.$orig.headimg}}"></image><view class="t2"><text class="x1">{{item.$orig.nickname}}</text><text class="x2">{{item.m0}}</text><text class="x2">{{"等级："+item.$orig.levelname}}</text><block a:if="{{item.$orig.tel}}"><text class="x2">{{"手机号："+item.$orig.tel}}</text></block></view></view><view class="f2"><view class="t3"><block a:if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m1}}</view></block><block a:if="{{userlevel&&userlevel.team_givescore==1}}"><view class="x1" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['givescoreshow',['$event']]]]]}}" onTap="__e">{{"转"+$root.m2}}</view></block></view></view></view></block></view></block><uni-popup vue-id="13e989e4-1" id="dialogmoneyInput" type="dialog" ref="__r" data-ref="dialogmoneyInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('13e989e4-2')+','+('13e989e4-1')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup><uni-popup vue-id="13e989e4-3" id="dialogscoreInput" type="dialog" ref="__r" data-ref="dialogscoreInput" onVueInit="__l"><uni-popup-dialog vue-id="{{('13e989e4-4')+','+('13e989e4-3')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" onConfirm="__e" onVueInit="__l"></uni-popup-dialog></uni-popup></block></block><block a:if="{{nodata}}"><nodata vue-id="13e989e4-5" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="13e989e4-6" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="13e989e4-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="13e989e4-8" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="13e989e4-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>