<view class="container"><block a:if="{{isload}}"><block><block a:if="{{postercount>1}}"><block><view class="arrowleft" data-type="-1" data-event-opts="{{[['tap',[['changeposter',['$event']]]]]}}" onTap="__e"><text class="iconfont iconjiantou"></text></view><view class="arrowright" data-type="1" data-event-opts="{{[['tap',[['changeposter',['$event']]]]]}}" onTap="__e"><text class="iconfont iconjiantou"></text></view></block></block><image class="sjew-img" src="{{poster}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="sjew-box"><view class="sjew-tle flex-y-center">{{"如何推荐好友拿"+$root.m0}}</view><view class="sjew-sp1"><text>{{guize}}</text></view></view><view class="sjew-he"></view><view class="{{(('sjew-bottom')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="sjew-bottom-content"><block a:if="{{$root.m1=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m2)+';'}}" onTap="__e">分享链接</view></block><block a:else><block a:if="{{$root.m3=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m4)+';'}}" onTap="__e">分享链接</view></block><block a:else><block a:if="{{$root.m5=='h5'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m6)+';'}}" onTap="__e">分享链接</view></block><block a:else><button class="sjew-bot-a1" style="{{'background:'+($root.m7)+';'}}" open-type="share">分享链接</button></block></block></block><view class="sjew-bot-a2" style="{{'background:'+($root.m8)+';'}}" data-url="{{poster}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e">分享图片</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="35f19294-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="35f19294-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="35f19294-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>