<block a:if="{{isload==1}}"><view class="container"><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t1">{{"兑换码："+item.code}}</text><text class="t2">{{"兑换时间："+item.createtime}}</text></view></view></block><block a:if="{{nodata}}"><nodata vue-id="d818fa48-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="d818fa48-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="d818fa48-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d818fa48-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d818fa48-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>