<block a:if="{{isload}}"><view class="container" style="{{'background-color:'+(pageinfo.bgcolor)+';'}}"><block><dp vue-id="1a24b8a6-1" pagecontent="{{pagecontent}}" menuindex="{{menuindex}}" latitude="{{latitude}}" longitude="{{longitude}}" htsignatureurl="{{htsignatureurl}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" onGetdata="__e" onVueInit="__l"></dp><dp-guanggao vue-id="1a24b8a6-2" guanggaopic="{{guanggaopic}}" guanggaourl="{{guanggaourl}}" guanggaotype="{{guanggaotype}}" param="{{guanggaoparam}}" onVueInit="__l"></dp-guanggao><dp-tabbar vue-id="1a24b8a6-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><block a:if="{{isshare}}"><dp-sharegive vue-id="1a24b8a6-4" sharegive="{{sharegive}}" data-event-opts="{{[['^toshare',[['toshare']]]]}}" onToshare="__e" onVueInit="__l"></dp-sharegive></block></block><popmsg vue-id="1a24b8a6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="1a24b8a6-6" onVueInit="__l"></loading></block><wxxieyi vue-id="1a24b8a6-7" onVueInit="__l"></wxxieyi></view></block>