<view class="body"><block a:if="{{isload}}"><block><view class="header" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"></view><view class="container"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m2)+';'}}"></view><view class="title">基础信息</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>选择行业</view><view class="form-value"><picker range="{{qualificationlist}}" data-field="settlement_id" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e"><view class="form-select"><view class="select-txt">{{qualificationlist[qualificationIndex]?qualificationlist[qualificationIndex]:"请选择"}}</view><image class="down" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></picker></view></view><block a:if="{{is_required}}"><view class="form-item"><view class="form-label"><text class="required">*</text>特殊资质图片</view><view class="form-value form-upload"><view class="imgbox"><block a:for="{{form.qualifications}}" a:for-item="pic" a:for-index="pindex" a:key="pindex"><block a:if="{{form.qualifications&&form.qualifications.length>0}}"><block><view class="imgitem-pics"><image src="{{pic}}" data-url="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block></block></block><block a:if="{{!form.qualifications||form.qualifications.length<5}}"><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="qualifications" data-pernum="5" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view></view></block></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m3)+';'}}"></view><view class="title">主体资料</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>营业执照</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.license_copy}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="license_copy" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.license_copy}}" data-url="{{form.license_copy}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="license_copy" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>商户名称</view><view class="form-value"><input type="text" name="merchant_name" placeholder="请填写商户名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','merchant_name','$event',[]],['form']]]]]}}" value="{{form.merchant_name}}" onInput="__e"/></view><view class="form-tips">若营业执照上没有名字，则填写"个体户+姓名"，如个体户张三</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>统一信用代码</view><view class="form-value"><input type="text" name="license_number" placeholder="请填写统一信用代码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','license_number','$event',[]],['form']]]]]}}" value="{{form.license_number}}" onInput="__e"/></view><view class="form-tips">请核对仔细确保无误</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>商户简称</view><view class="form-value"><input type="text" name="merchant_shortname" placeholder="请填写商户简称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','merchant_shortname','$event',[]],['form']]]]]}}" value="{{form.merchant_shortname}}" onInput="__e"/></view><view class="form-tips">在支付完成向买家展示，需与微信经营类目相关</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>客服电话</view><view class="form-value"><input type="text" name="service_phone" placeholder="请填写客服电话" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','service_phone','$event',[]],['form']]]]]}}" value="{{form.service_phone}}" onInput="__e"/></view><view class="form-tips">将在交易记录中向商家展示，提供咨询服务</view></view></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m4)+';'}}"></view><view class="title">法人身份证件</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证件人像面照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.id_card_copy}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="id_card_copy" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.id_card_copy}}" data-url="{{form.id_card_copy}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="id_card_copy" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证件国徽面照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.id_card_national}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="id_card_national" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.id_card_national}}" data-url="{{form.id_card_national}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="id_card_national" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证姓名</view><view class="form-value"><input type="text" name="id_card_name" placeholder="请填写身份证姓名" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','id_card_name','$event',[]],['form']]]]]}}" value="{{form.id_card_name}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证号码</view><view class="form-value"><input type="text" name="id_card_number" placeholder="请填写身份证号码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','id_card_number','$event',[]],['form']]]]]}}" value="{{form.id_card_number}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证有效日期</view><view class="form-value"><view class="{{(('picker-range')+' '+(form.card_period_begin?'':'placeholder'))}}"><picker mode="date" name="card_period_begin" data-field="card_period_begin" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e">{{''+(form.card_period_begin?form.card_period_begin:'请选择身份证有效日期')+''}}</picker></view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>身份证失效日期</view><view class="form-value" style="margin-bottom:20rpx;"><radio-group data-field="card_period_end_cq" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e"><label class="checkbox-lebel"><radio style="transform:scale(0.8);" value="0" checked="{{!form.card_period_end_cq||form.card_period_end_cq==0}}"></radio><text>非长期</text></label><label class="checkbox-lebel"><radio style="transform:scale(0.8);" value="1" checked="{{form.card_period_end_cq==1}}"></radio><text>长期</text></label></radio-group></view><block a:if="{{!form.card_period_end_cq||form.card_period_end_cq==0}}"><view class="form-value"><view class="{{(('picker-range')+' '+(form.card_period_end?'':'placeholder'))}}"><picker mode="date" name="card_period_end" data-field="card_period_end" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e">{{''+(form.card_period_end?form.card_period_end:'请选择日期')+''}}</picker></view></view></block></view><view class="form-item"><view class="form-label"><text class="required">*</text>手机号码</view><view class="form-value"><input type="text" name="mobile_phone" placeholder="请填写手机号码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','mobile_phone','$event',[]],['form']]]]]}}" value="{{form.mobile_phone}}" onInput="__e"/></view><view class="form-tips">用户接收微信支付的重要管理信息及日常操作验证码</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>联系邮箱</view><view class="form-value"><input type="text" name="contact_email" placeholder="请填写联系邮箱" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','contact_email','$event',[]],['form']]]]]}}" value="{{form.contact_email}}" onInput="__e"/></view><view class="form-tips">用户接收微信支付的开户邮件，及日常业务通知</view></view></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m5)+';'}}"></view><view class="title">经营信息</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店名称</view><view class="form-value"><input type="text" name="biz_store_name" placeholder="请填写门店名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','biz_store_name','$event',[]],['form']]]]]}}" value="{{form.biz_store_name}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店省市</view><view class="form-value"><uni-data-picker vue-id="7828dbf6-1" localdata="{{citylist}}" popup-title="请选择门店省市" placeholder="门店省市" data-event-opts="{{[['^change',[['cityChange',['$event','biz_address_code']]]]]}}" onChange="__e" onVueInit="__l"><view class="form-select"><view class="select-txt">{{form.biz_address_code_name?form.biz_address_code_name:'请选择门店省市'}}</view><image class="down" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></uni-data-picker></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店详细地址</view><view class="form-value"><input type="text" name="biz_store_address" placeholder="请填写门店详细地址" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','biz_store_address','$event',[]],['form']]]]]}}" value="{{form.biz_store_address}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店门口照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.store_entrance_pic}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="store_entrance_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.store_entrance_pic}}" data-url="{{form.store_entrance_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="store_entrance_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view><view class="form-tips">门店场所：提交门店门口照片，要求招牌清晰可见</view><view class="form-tips">流动经营/便民服务：提交经营/服务现场照片</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>店内环境照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.indoor_pic}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="indoor_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.indoor_pic}}" data-url="{{form.indoor_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="indoor_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view><view class="form-tips">门店场所：提交店内环境照片</view><view class="form-tips">流动经营/便民服务：提交经营/服务现场照片</view></view></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m6)+';'}}"></view><view class="title">银行信息</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>账户类型</view><view class="form-value" style="margin-bottom:20rpx;"><radio-group data-field="bank_account_type" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e"><block a:if="{{subject==1}}"><label class="checkbox-lebel"><radio style="transform:scale(0.8);" value="1" checked="{{form.bank_account_type==1}}"></radio><text>个人银行卡</text></label></block><label class="checkbox-lebel"><radio style="transform:scale(0.8);" value="2" checked="{{form.bank_account_type==2}}"></radio><text>对公银行账户</text></label></radio-group></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>开户名称</view><view class="form-value"><input type="text" name="account_name" placeholder="请填写开户名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','account_name','$event',[]],['form']]]]]}}" value="{{form.account_name}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>开户地址</view><view class="form-value"><uni-data-picker vue-id="7828dbf6-2" localdata="{{citylist}}" popup-title="请选择开户地址" placeholder="开户地址" data-event-opts="{{[['^change',[['cityChange',['$event','bank_address_code']]]]]}}" onChange="__e" onVueInit="__l"><view class="form-select"><view class="select-txt">{{form.bank_address_code_name?form.bank_address_code_name:'请选择开户地址'}}</view><image class="down" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></uni-data-picker></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>开户银行</view><view class="form-value"><picker range="{{bankList}}" data-field="account_bank" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" onChange="__e"><view class="form-select"><view class="select-txt">{{bankList[form['account_bank_index']]?bankList[form['account_bank_index']]:'请选择开户银行'}}</view><image class="down" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></picker></view></view><block a:if="{{form.account_bank_index==0}}"><view class="form-item"><view class="form-label"><text class="required">*</text>开户银全称（含支行）</view><view class="form-value"><input type="text" name="bank_name" placeholder="请填写开户银全称（含支行）" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','bank_name','$event',[]],['form']]]]]}}" value="{{form.bank_name}}" onInput="__e"/></view></view></block><view class="form-item"><view class="form-label"><text class="required">*</text>银行账号</view><view class="form-value"><input type="text" name="account_number" placeholder="请填写银行账号" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','account_number','$event',[]],['form']]]]]}}" value="{{form.account_number}}" onInput="__e"/></view></view></view><view style="display:none;">{{txt}}</view><view class="form-opt"><button data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m7)+';'}}" onTap="__e">确认无误，提交审核</button></view></form></view></block></block><block a:if="{{loading}}"><loading vue-id="7828dbf6-3" onVueInit="__l"></loading></block><popmsg vue-id="7828dbf6-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>