<view class="body"><block a:if="{{isload}}"><block><view class="header" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"></view><view class="container"><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m2)+';'}}"></view><view class="title">基础信息</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>支付宝账号</view><view class="form-value"><input type="text" name="binding_alipay_logon_id" placeholder="请填写支付宝账号" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','binding_alipay_logon_id','$event',[]],['form']]]]]}}" value="{{form.binding_alipay_logon_id}}" onInput="__e"/></view><view class="form-tips">资金将收到此支付宝账号内</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>选择行业</view><view class="form-value"><picker mode="multiSelector" range="{{pickerData}}" range-key="name" data-field="mcc" data-event-opts="{{[['change',[['onPickerChange',['$event']]]],['columnchange',[['onColumnChange',['$event']]]]]}}" onChange="__e" onColumnchange="__e"><block a:if="{{selectedFirstLevel.name&&selectedSecondLevel.name}}"><view class="picker">{{''+selectedFirstLevel.name+" - "+selectedSecondLevel.name+''}}</view></block><block a:else><view class="picker">请选择行业</view></block></picker></view></view><block a:if="{{is_required}}"><view class="form-item"><view class="form-label"><text class="required">*</text>特殊资质图片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.qualifications}}"><view class="imgitem-pics"><image src="{{form.qualifications}}" data-url="{{form.qualifications}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="qualifications" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view><block a:if="{{industryDescription}}"><view class="form-tips wrap-text">{{industryDescription}}</view></block></view></block><block a:if="{{is_required}}"><view class="form-item"><view class="form-label"><text class="required">*</text>行业资质代码</view><view class="form-value"><input type="text" name="settlement_id" placeholder="请填写行业资质代码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','settlement_id','$event',[]],['form']]]]]}}" value="{{form.settlement_id}}" onInput="__e"/></view><view class="form-tips">按照【特殊资质】描述代码填写</view></view></block></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m3)+';'}}"></view><view class="title">主体资料</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>营业执照</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.license_copy}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="license_copy" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.license_copy}}" data-url="{{form.license_copy}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="license_copy" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>营业执照省份</view><view class="form-value"><uni-data-picker vue-id="207b0b78-1" localdata="{{citylist}}" popup-title="请选择营业执照省份" placeholder="请选择营业执照省份" data-event-opts="{{[['^change',[['cityChange',['$event','biz_address_code']]]]]}}" onChange="__e" onVueInit="__l"><view class="form-select"><view class="select-txt">{{city.length>0?$root.g0:'请选择营业执照省份'}}</view><image class="down" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></uni-data-picker></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>统一信用代码</view><view class="form-value"><input type="text" name="license_number" placeholder="请填写统一信用代码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','license_number','$event',[]],['form']]]]]}}" value="{{form.license_number}}" onInput="__e"/></view><view class="form-tips">请核对仔细确保无误</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>法人姓名</view><view class="form-value"><input type="text" name="id_card_name" placeholder="请填写法人姓名" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','id_card_name','$event',[]],['form']]]]]}}" value="{{form.id_card_name}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>法人手机号码</view><view class="form-value"><input type="text" name="mobile_phone" placeholder="请填写法人手机号码" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','mobile_phone','$event',[]],['form']]]]]}}" value="{{form.mobile_phone}}" onInput="__e"/></view></view></view><view class="box"><view class="form-title"><view class="strip" style="{{'background:'+($root.m4)+';'}}"></view><view class="title">经营信息</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店名称</view><view class="form-value"><input type="text" name="biz_store_name" placeholder="请填写门店名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','biz_store_name','$event',[]],['form']]]]]}}" value="{{form.biz_store_name}}" onInput="__e"/></view></view><view class="form-item"><view class="form-label"><text class="required">*</text>门店门口照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.store_entrance_pic}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="store_entrance_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.store_entrance_pic}}" data-url="{{form.store_entrance_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="store_entrance_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view><view class="form-tips">门店场所：提交门店门口照片，要求招牌清晰可见</view><view class="form-tips">流动经营/便民服务：提交经营/服务现场照片</view></view><view class="form-item"><view class="form-label"><text class="required">*</text>店内环境照片</view><view class="form-value form-upload"><view class="imgbox"><block a:if="{{form.indoor_pic}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-field="indoor_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{form.indoor_pic}}" data-url="{{form.indoor_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="imgitem-pics"><view class="uploadbtn1" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 44rpx')+';'+('background-size:'+('60rpx 60rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-field="indoor_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view></block></view></view><view class="form-tips">门店场所：提交店内环境照片</view><view class="form-tips">流动经营/便民服务：提交经营/服务现场照片</view></view></view><view style="display:none;">{{txt}}</view><view class="form-opt"><button data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m5)+';'}}" onTap="__e">确认无误，提交审核</button></view></form></view></block></block><block a:if="{{loading}}"><loading vue-id="207b0b78-2" onVueInit="__l"></loading></block><popmsg vue-id="207b0b78-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>