<view class="container"><block a:if="{{isload}}"><block><view style="width:100%;"><view class="topsearch flex-xy-center sx"><text class="t1">日期筛选：</text><view class="f2 flex" style="line-height:30px;"><picker mode="date" value="{{startDate}}" data-event-opts="{{[['change',[['bindStartDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{startDate}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">至</view><picker mode="date" value="{{endDate}}" data-event-opts="{{[['change',[['bindEndDateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{endDate}}</view></picker><view class="t_date"><block a:if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" onTap="__e">清除</view></block></view></view></view></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.settle_abstract}}</text><text class="t2">{{"结算商户号："+item.huifu_id}}</text><text class="t2">{{"流水编号："+item.trans_id}}</text><text class="t2">{{"结算时间："+item.trans_date}}</text></view><view class="f2"><block a:if="{{item.trans_amt>0}}"><text class="t1">{{"+"+item.trans_amt}}</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="0a2fe890-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="0a2fe890-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="0a2fe890-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="0a2fe890-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="0a2fe890-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>