<view><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><block a:if="{{status==2}}"><view class="form-options" style="padding:10rpx 0;color:red;">{{'文章未审核通过，驳回原因：'+info.reason+''}}</view></block><view class="form-view flex flex-col"><view class="form-options flex flex-bt flex-y-center"><view class="options-title">标题</view><view class="options-input"><input name="name" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章标题" value="{{info.name}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">描述</view><view class="options-input"><input name="subname" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章描述" value="{{info.subname}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">作者</view><view class="options-input"><input name="author" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章作者" value="{{info.author}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">分类</view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" onTap="__e"><block a:if="{{cids.length>0}}"><text style="line-height:normal;">{{cnames}}</text></block><block a:else><text style="font-size:28rpx;color:#BFBFCB;">请选择</text></block></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">阅读量</view><view class="options-input"><input name="readcount" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章阅读量" value="{{info.readcount}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">序号</view><view class="options-input"><input name="sort" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入序号" value="{{info.sort}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">发布时间</view><view class="options-input flex flex-bt flex-y-center"><view class="flex" style="flex:1;align-items:center;justify-content:flex-end;"><picker class="picker-class flex" style="margin-right:20rpx;" mode="date" data-event-opts="{{[['change',[['startTimeChange',['$event']]]]]}}" onChange="__e"><view class="{{(startTime?'':'picker-view-class flex')}}">{{startTime?startTime:'请选择日期'}}</view></picker><picker class="picker-class flex" mode="time" data-event-opts="{{[['change',[['startTime2Change',['$event']]]]]}}" onChange="__e"><view class="{{(startTime2?'':'picker-view-class flex')}}">{{startTime2?startTime2:'请选择时间'}}</view></picker></view><image class="options-icon" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="form-options flex-col"><view class="options-title">详情页显示</view><view class="options-sex-view flex flex-y-center flex-bt"><view data-event-opts="{{[['tap',[['setzhanshi',[0]]]]]}}" class="sex-optinos" style="{{'background:'+($root.g0?$root.m0:'')+';'+('color:'+($root.g1?'#fff':'')+';')}}" onTap="__e">标题</view><view data-event-opts="{{[['tap',[['setzhanshi',[1]]]]]}}" class="sex-optinos" style="{{'background:'+($root.g2?$root.m1:'')+';'+('color:'+($root.g3?'#fff':'')+';')}}" onTap="__e">阅读量</view><view data-event-opts="{{[['tap',[['setzhanshi',[2]]]]]}}" class="sex-optinos" style="{{'background:'+($root.g4?$root.m2:'')+';'+('color:'+($root.g5?'#fff':'')+';')}}" onTap="__e">发布时间</view><view data-event-opts="{{[['tap',[['setzhanshi',[3]]]]]}}" class="sex-optinos" style="{{'background:'+($root.g6?$root.m3:'')+';'+('color:'+($root.g7?'#fff':'')+';')}}" onTap="__e">作者</view></view></view></view><view class="form-view flex flex-col" style="padding:0rpx;"><view class="form-options flex flex-bt flex-y-center"><view class="options-title">文章评论</view><view><switch style="transform:scale(0.7);" color="#3d5bf6" value="1" checked="{{canpl==1?true:false}}" data-event-opts="{{[['change',[['switchChange',['$event']]]]]}}" onChange="__e"></switch></view></view><block a:if="{{canpl}}"><block><view class="form-options flex flex-bt flex-y-center"><view class="options-title">评论回复</view><view><switch style="transform:scale(0.7);" color="#3d5bf6" value="1" checked="{{canplrp==1?true:false}}" data-event-opts="{{[['change',[['switchChange2',['$event']]]]]}}" onChange="__e"></switch></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">评论审核</view><view><switch style="transform:scale(0.7);" color="#3d5bf6" value="1" checked="{{pinglun_check==1?true:false}}" data-event-opts="{{[['change',[['switchChange3',['$event']]]]]}}" onChange="__e"></switch></view></view></block></block><block a:if="{{needcheck==0}}"><view class="form-options flex flex-bt flex-y-center"><view class="options-title">状态</view><view><switch style="transform:scale(0.7);" color="#3d5bf6" value="1" checked="{{status==1?true:false}}" data-event-opts="{{[['change',[['switchChange4',['$event']]]]]}}" onChange="__e"></switch></view></view></block></view><view class="form-view flex flex-col"><view class="form-options flex flex-col"><view class="options-title">图片</view><view class="upload-pic-view flex flex-y-center"><block a:if="{{pics.length<1}}"><view class="up-fun-view" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/uploadimage.png'}}"></image></view></block><block a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="up-fun-view"><image src="{{item}}" data-url="{{item}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="close-but" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/uploadimgdelete.png'}}"></image></view></view></block></view></view></view><view class="form-view flex flex-col" style="padding:0rpx;"><view class="form-box"><view class="form-item flex-col"><text>文章详情</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" onTap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" onTap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" onTap="__e">+视频</view></view><view><block a:for="{{pagecontent}}" a:for-item="setData" a:for-index="index" a:key="index"><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" onTap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" onTap="__e">下移</view><block a:if="{{setData.temp=='text'}}"><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailEdit',['$event']]]]]}}" onTap="__e">编辑</view></block><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" onTap="__e">删除</view></view><view class="detailbox"><block a:if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'0ffc0f9a-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-notice></block></block><block a:if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'0ffc0f9a-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-banner></block></block><block a:if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'0ffc0f9a-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-search></block></block><block a:if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'0ffc0f9a-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-text></block></block><block a:if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'0ffc0f9a-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-title></block></block><block a:if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'0ffc0f9a-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-dhlist></block></block><block a:if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'0ffc0f9a-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-line></block></block><block a:if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'0ffc0f9a-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-blank></block></block><block a:if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'0ffc0f9a-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-menu></block></block><block a:if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'0ffc0f9a-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-map></block></block><block a:if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'0ffc0f9a-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cube></block></block><block a:if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'0ffc0f9a-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-picture></block></block><block a:if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'0ffc0f9a-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-pictures></block></block><block a:if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'0ffc0f9a-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-video></block></block><block a:if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'0ffc0f9a-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}" onVueInit="__l"></dp-shop></block></block><block a:if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'0ffc0f9a-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-product></block></block><block a:if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'0ffc0f9a-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-collage></block></block><block a:if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'0ffc0f9a-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-kanjia></block></block><block a:if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'0ffc0f9a-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-seckill></block></block><block a:if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'0ffc0f9a-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-scoreshop></block></block><block a:if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'0ffc0f9a-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-coupon></block></block><block a:if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'0ffc0f9a-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-article></block></block><block a:if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'0ffc0f9a-23-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-business></block></block><block a:if="{{setData.temp=='liveroom'}}"><block><dp-liveroom vue-id="{{'0ffc0f9a-24-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-liveroom></block></block><block a:if="{{setData.temp=='button'}}"><block><dp-button vue-id="{{'0ffc0f9a-25-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-button></block></block><block a:if="{{setData.temp=='hotspot'}}"><block><dp-hotspot vue-id="{{'0ffc0f9a-26-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-hotspot></block></block><block a:if="{{setData.temp=='cover'}}"><block><dp-cover vue-id="{{'0ffc0f9a-27-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cover></block></block><block a:if="{{setData.temp=='richtext'}}"><block><dp-richtext vue-id="{{'0ffc0f9a-28-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-richtext></block></block><block a:if="{{setData.temp=='form'}}"><block><dp-form vue-id="{{'0ffc0f9a-29-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-form></block></block><block a:if="{{setData.temp=='userinfo'}}"><block><dp-userinfo vue-id="{{'0ffc0f9a-30-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-userinfo></block></block></view></view></block></view></view></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')}}" form-type="submit">提交</button></form><block a:if="{{clistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择文章分类</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="id"><view class="clist-item" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m6?'background:'+item.m7+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:for="{{item.l1}}" a:for-item="item2" a:for-index="index2" a:key="id"><view class="clist-item" style="padding-left:80rpx;" data-id="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><block a:if="{{item.$orig.child.length-1==index2}}"><view class="flex1">{{"└ "+item2.$orig.name}}</view></block><block a:else><view class="flex1">{{"├ "+item2.$orig.name}}</view></block><view class="radio" style="{{(item2.m8?'background:'+item2.m9+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block a:for="{{item2.l0}}" a:for-item="item3" a:for-index="index3" a:key="id"><view class="clist-item" style="padding-left:160rpx;" data-id="{{item3.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" onTap="__e"><block a:if="{{item2.$orig.child.length-1==index3}}"><view class="flex1">{{"└ "+item3.$orig.name}}</view></block><block a:else><view class="flex1">{{"├ "+item3.$orig.name}}</view></block><view class="radio" style="{{(item3.m10?'background:'+item3.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></block></view></view></view></block><uni-popup vue-id="0ffc0f9a-31" id="dialogDetailtxt" type="dialog" ref="__r" data-ref="dialogDetailtxt" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请输入文本内容</text></view><view class="uni-dialog-content"><scroll-view class="uni-dialog-scroll" scroll-y="true"><view style="width:100%;"><textarea placeholder="请输入文本内容" auto-height="{{true}}" maxlength="{{-1}}" data-event-opts="{{[['input',[['catcheDetailtxt',['$event']]]]]}}" value="{{edit_text}}" onInput="__e"></textarea></view></scroll-view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['dialogDetailtxtConfirm',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-popup-dialog__close" onTap="__e"><label class="uni-popup-dialog__close-icon  _span"></label></view></view></uni-popup><wxxieyi vue-id="0ffc0f9a-32" onVueInit="__l"></wxxieyi><dp-tabbar vue-id="0ffc0f9a-33" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>