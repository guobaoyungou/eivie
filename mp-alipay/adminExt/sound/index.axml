<view><block a:if="{{isload}}"><view class="container" id="datalist"><view><view class="info-item" style="line-height:40rpx;"><view class="t1" style="width:200rpx;">云音响管理</view><view style="display:flex;flex-wrap:wrap;justify-content:space-between;"><view class="btn2" data-url="edit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加唱单宝音响</view><block a:if="{{customs.sound_mqlinks}}"><view class="btn2" data-url="editmqlinks" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加劢领云喇叭</view></block><block a:if="{{customs.sound_yuzhi}}"><view class="btn2" data-url="edityuzhi" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加语智云喇叭</view></block></view></view><view class="info-item2" data-id="{{item.id}}" data-device_brand="{{item.device_brand}}" data-event-opts="{{[['tap',[['gotoedit',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view><view class="t1">{{"名称："+item.name}}</view><view class="t2">{{"终端号："+item.device_sn}}</view><view class="t2">{{"厂商："+item.device_brand_name}}</view><view class="t2">{{"添加时间："+item.createtime}}</view><view class="t2">状态：<block a:if="{{item.status==1}}"><text style="color:green;">显示</text></block><block a:else><text style="color:red;">隐藏</text></block></view></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="40f59199-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="40f59199-2" onVueInit="__l"></nodata></block></view>