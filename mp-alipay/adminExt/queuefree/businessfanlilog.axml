<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的返利</view><view class="f2">{{totalmoney}}</view></view><view class="order-box" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="head"><view class="f1">{{"订单号："+item.ordernum}}</view><view class="flex1"></view></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"类型："+item.typename}}</text></view><view class="detail">金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{"￥"+item.money}}</text></view><view class="detail">状态：<block a:if="{{item.status==1}}"><text class="t1" style="color:green;">已完成</text></block><block a:else><text class="t1" style="color:orange;">已退还</text></block></view><view class="detail"><text class="t1">{{"创建时间："+item.createtime}}</text></view></view><block a:if="{{nodata}}"><nodata vue-id="{{'08076f37-1-'+index}}" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="08076f37-2" onVueInit="__l"></nomore></block></block></block><uni-popup vue-id="08076f37-3" type="center" ref="__r" data-ref="popupMiandan" onVueInit="__l"><view class="popup-miandan-content"><view class="popup-miandan-price flex"><view class="price-num-text popup-color-text">{{totalmoney}}</view><view class="right-text popup-color-text">元</view></view><view class="popup-leiji-miandan popup-color-text">累计返现金额</view><image src="{{pre_url+'/static/img/miandanpopupbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupMiandanclose',['$event']]]]]}}" class="popupMiandan-close" onTap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup><fireworks vue-id="08076f37-4" fireworksShow="{{fireworksShow}}" onVueInit="__l"></fireworks><block a:if="{{loading}}"><loading vue-id="08076f37-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="08076f37-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="08076f37-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>