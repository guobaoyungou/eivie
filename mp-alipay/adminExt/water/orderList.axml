<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="70bbbdd2-1" itemdata="{{['全部','打水中','已结束']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><block a:if="{{item.iscd==0}}"><text class="st2">打水中</text></block><block a:if="{{item.iscd==1}}"><text class="st3">已结束</text></block></view><view class="content"><view class="detail"><view class="t1">{{"设备编号："+item.deviceId}}</view><view class="t1">{{"设备地址："+item.location}}</view><view class="t1">{{"出水口："+item.outlet_num}}</view><view class="t1">{{"支付时间："+item.paytime}}</view></view></view><view class="content"><view class="detail"><view>{{"订单金额:￥"+item.product_price}}</view><view>{{"实付金额:￥"+item.totalprice}}</view><view>{{"退款金额:￥"+item.refund_money}}</view><block a:if="{{item.scoredk_money>0}}"><view>{{"积分抵扣:￥"+item.scoredk_money}}</view></block><block a:if="{{item.coupon_money>0}}"><view>{{"优惠券抵扣:￥"+item.coupon_money}}</view></block></view></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="70bbbdd2-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="70bbbdd2-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="70bbbdd2-4" onVueInit="__l"></loading></block><popmsg vue-id="70bbbdd2-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>