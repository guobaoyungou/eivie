<view class="container"><block a:if="{{isload}}"><block><view class="coupon-list"><view class="coupon" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box"><view class="content" style="border-bottom:none;"><view class="pt_right"><view class="f1"><view class="t1">{{"出水口编号："+item.outlet_num}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"出水口单价："+item.outlet_price+"元/升"}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"设备编号："+item.deviceId}}</view><view class="t3" style="{{(item.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"添加时间 "+item.createtime}}</view></view></view></view><view class="op"><view data-event-opts="{{[['tap',[['copyUrl',['$0'],[[['datalist','',index,'qrcode']]]]]]]}}" class="btn2" style="width:240rpx;" onTap="__e">复制二维码链接</view><view class="btn2" style="width:200rpx;" data-qrcode="{{item.qrcode}}" data-event-opts="{{[['tap',[['showQr',['$event']]]]]}}" onTap="__e">查看二维码</view><view class="btn2" data-url="{{'outletEdit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">编辑</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除</view></view></view></view></view><view class="bottom-but-view notabbarbot"><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',1) 100%)')}}" data-url="{{'outletEdit?water_happyti_device_id='+water_happyti_device_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加出水口</button></view><uni-popup vue-id="1d68cf4c-1" id="dialogQr" type="dialog" ref="__r" data-ref="dialogQr" onVueInit="__l"><view class="hxqrbox"><image class="img" src="{{qrcode}}" data-url="{{qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view data-event-opts="{{[['tap',[['closeQr',['$event']]]]]}}" class="close" onTap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block a:if="{{nomore}}"><nomore vue-id="1d68cf4c-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="1d68cf4c-3" onVueInit="__l"></loading></block><block a:if="{{nodata}}"><nodata vue-id="1d68cf4c-4" onVueInit="__l"></nodata></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view></block></block></view>