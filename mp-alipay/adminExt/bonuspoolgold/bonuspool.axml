<view><block a:if="{{isload}}"><block><view class="content" style="{{(bgpic?'background-image:url('+bgpic+');background-repeat: no-repeat;background-size:100% 100%;':'')}}"><block a:if="{{notices&&notices.length>0}}"><view class="bobaobox"><swiper style="position:relative;height:54rpx;width:450rpx;" autoplay="true" interval="{{5000}}" vertical="true"><swiper-item class="flex-y-center" a:for="{{notices}}" a:for-item="item" a:for-index="index" a:key="index"><image style="width:40rpx;height:40rpx;border:1px solid rgba(255,255,255,0.7);border-radius:50%;margin-right:4px;" src="{{item.headimg}}"></image><view style="width:400rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:22rpx;"><text style="padding-right:2px;">{{item.nickname}}</text><text style="padding-right:4px;">{{item.showtime}}</text><text>{{item.msg}}</text></view></swiper-item></swiper></view></block><block a:if="{{set.show_gold_price==1||set.show_bonus_pool==1}}"><view style="width:100%;padding:40rpx 30rpx;"><view style="width:680rpx;margin:0 auto;display:flex;justify-content:space-between;align-items:center;"><block a:if="{{set.show_gold_price==1}}"><view style="text-align:center;"><view><text style="color:#FE0000;font-size:50rpx;font-weight:bold;">{{set.gold_price||0}}</text></view><view><text>实时价格</text></view></view></block><block a:if="{{set.show_bonus_pool==1}}"><view style="text-align:left;line-height:40rpx;"><view style="display:flex;"><view style="width:170rpx;">{{$root.m0+"总量"}}</view><view>{{set.gold_total}}</view></view><view style="display:flex;margin-top:10rpx;"><view style="width:170rpx;">{{$root.m1+"金额"}}</view><view>{{set.bonus_pool_total}}</view></view></view></block></view></view></block><view style="{{(set.nobgcolor?'':'background:#fff')}}"><view class="box" style="width:680rpx;margin:0 auto;"><view class="box-main range" style="{{'border-color:'+($root.m2)+';'}}"><view data-event-opts="{{[['tap',[['changeRange',[1]]]]]}}" class="range-item" style="{{(range==1?'color:'+$root.m3:'')}}" onTap="__e"><view class="range-item-name" style="{{(range==1?'border-bottom:4rpx solid '+$root.m4:'')}}">日</view></view><view data-event-opts="{{[['tap',[['changeRange',[2]]]]]}}" class="range-item" style="{{(range==2?'color:'+$root.m5:'')}}" onTap="__e"><view class="range-item-name" style="{{(range==2?'border-bottom:4rpx solid '+$root.m6:'')}}">月</view></view><view data-event-opts="{{[['tap',[['changeRange',[3]]]]]}}" class="range-item" style="{{(range==3?'color:'+$root.m7:'')}}" onTap="__e"><view class="range-item-name" style="{{(range==3?'border-bottom:4rpx solid '+$root.m8:'')}}">年</view></view></view></view><view class="echart"><view class="echart-content" style="position:relative;z-index:10;"><block a:if="{{showechart}}"><view><l-echart class="charts-box" onFinished="__e" vue-id="45ac9678-1" ref="__r" data-ref="chart" data-event-opts="{{[['^finished',[['init']]]]}}" onVueInit="__l"></l-echart></view></block></view></view></view><view style="{{'width:100%;'+(centerpic?'background-image:url('+centerpic+');background-repeat: no-repeat;background-size:100% 100%;':'')}}"><view style="width:680rpx;margin:0rpx auto;display:flex;justify-content:space-between;padding:30rpx 0;"><view style="text-align:center;"><view><text>{{"我的"+$root.m9}}</text></view><view><text style="color:#FE0000;font-size:50rpx;font-weight:bold;">{{member.gold}}</text></view><view><text>实时现金价值：</text><text style="color:#FE0000;">{{(member.allgold_price||0)+"元"}}</text></view></view></view><view style="width:100%;"><view class="optred"><view class="optred1" style="{{(btnpic?'background-image:url('+btnpic+');background-size:100% 100%;background-repeat: no-repeat;':'background:'+$root.m10)}}" data-url="{{set.buy_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view style="line-height:80rpx;">{{set.buy_btn_text||'购买'}}</view></view><view class="optred1" style="{{(btnpic?'background-image:url('+btnpic+');background-size:100% 100%;background-repeat: no-repeat;':'background:'+$root.m11)}}" data-url="/pagesC/bonuspoolgold/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view style="line-height:80rpx;">{{set.withdraw_btn_text||'兑换'}}</view></view></view></view></view><view class="join" style="{{(set.nobgcolor?'':'background:#fff')}}"><view class="jointitle">明细列表<block a:if="{{set.desc}}"><view data-event-opts="{{[['tap',[['changeshortcontent',['$event']]]]]}}" class="shortcontent" onTap="__e">{{$root.m12+"规则"}}</view></block></view><scroll-view style="width:710rpx;margin:0 auto;height:410rpx;border:2rpx solid #f1f1f1;border-radius:8rpx;" scroll-y="true"><block a:for="{{logs}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{logs}}"><block><view class="joincontent"><view style="width:530rpx;display:flex;align-items:center;"><view class="joinname" style="width:100%;">{{item.createtime+" "+item.remark}}</view></view><view class="jointip"><text style="font-size:30rpx;">{{item.value}}</text></view></view></block></block></block></scroll-view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="45ac9678-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="45ac9678-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="45ac9678-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>