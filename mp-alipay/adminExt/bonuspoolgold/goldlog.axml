<view class="container"><block a:if="{{isload}}"><block><view class="content"><view class="item" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block a:if="{{item.$orig.value>0}}"><text class="t1">{{"+"+item.$orig.value}}</text></block><block a:else><text class="t2">{{item.$orig.value}}</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="69500afb-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="69500afb-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="69500afb-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="69500afb-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="69500afb-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>