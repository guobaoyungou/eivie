<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"可兑换"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;"></text>{{userinfo.gold}}</view><view class="f1">{{"当前"+$root.m2+"价值："+sysset.gold_price}}</view><view class="f3" data-url="goldlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{$root.m3+"记录"}}</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">兑换数量</view></view><view class="item3"><view class="f1"></view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入兑换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><block a:if="{{sysset.cash_fee>0}}"><view class="item4"><block a:if="{{sysset.cash_fee>0}}"><text>{{"兑换手续费"+sysset.cash_fee+'%'}}</text></block></view></block></view><view class="withdrawtype"><view class="f1">选择兑换方式：</view><view class="f2"><view class="item" data-paytype="money" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchTap="__e"><view class="t1">余额</view><view class="radio" style="{{(paytype=='money'?'background:'+$root.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view><button class="btn" style="{{'background:'+($root.m5)+';'}}" form-type="submit">立即兑换</button></form><block a:if="{{sysset.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{sysset.withdraw_desc}}</text></view></block></block></block><block a:if="{{loading}}"><loading vue-id="f134c242-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="f134c242-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f134c242-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>