<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="32998458-1" itemdata="{{['全部','待审核','已审核','已驳回']}}" itemst="{{['all','0','1','2']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view class="content"><view class="item" data-url="{{'withdrawdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="headimg"><image src="{{item.$orig.headimg}}"></image></view><view class="f1"><text class="t1">{{"社区名称："+item.$orig.xqname}}</text><view class="t3">提现金额：<text class="t3_3" style="{{'color:'+($root.m0)+';'}}">{{item.$orig.money}}</text>元</view><text class="t2">{{item.m1}}</text></view><view class="op"><block a:if="{{item.$orig.status==0}}"><view class="st0">待审核</view></block><block a:if="{{item.$orig.status==1}}"><view class="st1">已审核</view></block><block a:if="{{item.$orig.status==2}}"><view class="st2">已驳回</view></block><block a:if="{{item.$orig.status==3}}"><view class="st3">已打款</view></block></view><button class="btn" style="{{('background:rgba('+$root.m2+',0.9)')}}" data-id="{{item.$orig.id}}">查看详情</button></view></view><block a:if="{{nomore}}"><nomore vue-id="32998458-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="32998458-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="32998458-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="32998458-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="32998458-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>