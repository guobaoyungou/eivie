<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="f8635750-1" itemdata="{{['待审核','已通过','已驳回']}}" itemst="{{['0','1','2']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'detail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="itemL" onTap="__e"><view class="f1"><image class="lgimg" src="{{item.$orig.headimg}}"></image><view class="t2"><text class="x1">{{item.$orig.xqname}}</text><block a:if="{{item.$orig.tel}}"><text class="x2">{{"手机号："+item.$orig.tel}}</text></block><text class="x2">{{"申请时间："+item.m0}}</text></view></view><view class="op"><block a:if="{{item.$orig.check_status==1}}"><view class="st1">已通过</view></block><block a:if="{{item.$orig.check_status==0}}"><view class="st0">待审核</view></block><block a:if="{{item.$orig.check_status==2}}"><view class="st2">已驳回</view></block></view><block a:if="{{!item.$orig.check_status}}"><button class="btn" style="{{('background:rgba('+item.m1+',0.9)')}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['showaudit',['$event']]]]]}}" onTap="__e">审 核</button></block></view></view></block></view></block><block a:if="{{isshowaudit}}"><view data-event-opts="{{[['tap',[['hideaudit',['$event']]]]]}}" class="alert_popup" onTap="__e"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="alert_popup_content" catchTap="__e"><view class="form-item"><text class="form-label">审核结果：</text><view class="form-radio"><label data-event-opts="{{[['tap',[['changeAudit',[1]]]]]}}" class="radio" onTap="__e"><radio style="transform:scale(0.8);" color="{{$root.m2}}" value="1" checked="{{auditst==1?true:false}}"></radio>审核通过</label><label data-event-opts="{{[['tap',[['changeAudit',[2]]]]]}}" class="radio" onTap="__e"><radio style="transform:scale(0.8);" color="{{$root.m3}}" value="2" checked="{{auditst==2?true:false}}"></radio>审核拒绝</label></view></view><block a:if="{{auditst==2}}"><view class="form-item"><text class="form-label">驳回原因：</text><view class="form-txt"><textarea style="width:450rpx;" auto-height data-event-opts="{{[['input',[['__set_model',['','auditremark','$event',[]]]]]]}}" value="{{auditremark}}" onInput="__e"></textarea></view></view></block><view class="form-sub"><button data-event-opts="{{[['tap',[['auditSub',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m4)+';'}}" onTap="__e">确 定</button></view></view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="f8635750-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="f8635750-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="f8635750-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="f8635750-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f8635750-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>