<view class="container"><block a:if="{{isload}}"><block><block a:if="{{data&&data.url}}"><view class="row"><view class="title">链接</view><view>{{data.url}}</view><view class="btn" style="{{'background:'+($root.m0)+';'}}" data-url="{{'copy::'+data.url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">复制</view></view></block><block a:if="{{data&&data.qrcode}}"><view class="row"><view class="title">门店二维码</view><image style="width:60%;" src="{{data.qrcode}}" data-url="{{data.qrcode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="btn" style="{{'background:'+($root.m1)+';'}}" data-pic="{{data.qrcode}}" data-event-opts="{{[['tap',[['savpic',['$event']]]]]}}" onTap="__e">下载</view></view></block><block a:if="{{data&&data.wx_qrcode}}"><view class="row"><view class="title">门店小程序码</view><image style="width:60%;" src="{{data.wx_qrcode}}" data-url="{{data.wx_qrcode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="btn" style="{{'background:'+($root.m2)+';'}}" data-pic="{{data.wx_qrcode}}" data-event-opts="{{[['tap',[['savpic',['$event']]]]]}}" onTap="__e">下载</view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="283622e8-1" onVueInit="__l"></loading></block><popmsg vue-id="283622e8-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="283622e8-3" onVueInit="__l"></wxxieyi></view>