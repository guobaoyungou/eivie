<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="45ac8b9f-1" itemdata="{{['全部','待付款','待使用','已完成','已取消']}}" itemst="{{['all','0','1','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1}}"><text class="st0">待使用</text></block><block a:if="{{item.$orig.status==3}}"><text class="st4">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">订单已关闭</text></block></view><view class="content"><view data-url="{{'/pagesB/huodongbaoming/orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item.$orig.propic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.proname}}</text><text class="t1"><block a:if="{{item.$orig.ggname}}"><text>{{item.$orig.ggname+";"}}</text></block><block a:if="{{item.$orig.num}}"><text>{{"数量:"+item.$orig.num}}</text></block></text><view class="t3"><block a:if="{{item.$orig.totalprice>0&&item.$orig.totalscore>0}}"><block><text class="x1 flex1">{{"实付金额：￥"+item.$orig.totalprice+" + "+item.$orig.totalscore+''}}</text></block></block><block a:if="{{item.$orig.totalprice>0&&item.$orig.totalscore==0}}"><block><text class="x1 flex1">{{"实付金额：￥"+item.$orig.totalprice+''}}</text></block></block><block a:if="{{item.$orig.totalprice==0&&item.$orig.totalscore>0}}"><block><text class="x1 flex1">{{"实付金额："+item.$orig.totalscore+" "+item.m0}}</text></block></block></view></view></view><block a:if="{{item.$orig.refund_status>0}}"><view class="bottom"><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">退款中<block a:if="{{item.$orig.refund_money>0}}"><text>{{"￥"+item.$orig.refund_money}}</text></block></text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">已退款<block a:if="{{item.$orig.refund_money>0}}"><text>{{"￥"+item.$orig.refund_money}}</text></block></text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><block a:if="{{item.$orig.status==1}}"><view class="op"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" catchTap="__e">确认使用</view></view></block><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.$orig.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.$orig.member.nickname}}</text>{{"(ID:"+item.$orig.mid+')'}}</view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="45ac8b9f-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="45ac8b9f-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="45ac8b9f-4" onVueInit="__l"></loading></block><popmsg vue-id="45ac8b9f-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>