<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入账号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"账号列表（共"+count+"人）"}}</text><view class="btn" data-url="edit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">添加管理员</view></view><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><view class="t2"><view class="x1 flex-y-center">{{''+item.un+''}}</view><block><text class="x2">{{"最后登录："+item.logintime}}</text><text class="x2">{{"加入时间："+item.createtime}}</text><block a:if="{{item.groupname}}"><text class="x2">{{"所属权限组："+item.groupname}}</text></block></block></view></view><block><view class="f2"><view class="btn" data-url="{{'edit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">编辑</view><block a:if="{{item.isadmin==0&&item.id!=userid}}"><view class="btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除</view></block></view></block></view></block></view></block><block a:if="{{nomore}}"><nomore vue-id="255f14ea-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="255f14ea-2" onVueInit="__l"></nodata></block></block></block><popmsg vue-id="255f14ea-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><block a:if="{{loading}}"><loading vue-id="255f14ea-4" onVueInit="__l"></loading></block></view>