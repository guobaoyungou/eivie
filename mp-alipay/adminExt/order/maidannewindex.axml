<view class="container"><block a:if="{{isload}}"><block><view class="box"><view class="box-title"><view class="title"><text class="line" style="{{'background:'+($root.m0)+';'}}"></text><text>买单统计</text></view><view class="more" data-url="maidannewlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>全部记录</text><image class="icon" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="box-main range" style="{{'border-color:'+($root.m1)+';'}}"><view data-event-opts="{{[['tap',[['changeRange',[1]]]]]}}" class="range-item" style="{{('border:none;background:'+(range==1?'rgba('+$root.m2+',0.2)':''))}}" onTap="__e">今天</view><view data-event-opts="{{[['tap',[['changeRange',[2]]]]]}}" class="range-item" style="{{('border-color:'+$root.m3+';background:'+(range==2?'rgba('+$root.m4+',0.2)':''))}}" onTap="__e">昨天</view><view data-event-opts="{{[['tap',[['changeRange',[3]]]]]}}" class="range-item" style="{{('border-color:'+$root.m5+';background:'+(range==3?'rgba('+$root.m6+',0.2)':''))}}" onTap="__e">本月</view><view data-event-opts="{{[['tap',[['changeRange',[4]]]]]}}" class="range-item" style="{{('border-color:'+$root.m7+';background:'+(range==4?'rgba('+$root.m8+',0.2)':''))}}" onTap="__e">上月</view><view data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" class="range-item" style="{{('border-color:'+$root.m9+';background:'+(range==5?'rgba('+$root.m10+',0.2)':''))}}" onTap="__e">自定义</view></view><view class="tab"><block a:for="{{paytypelist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="tab-item"><view class="tab-txt">{{item.paytype}}</view><view class="tab-money">{{"￥"+item.total_amount}}</view></view></block></view></view><view class="echart"><view class="box-title"><view class="title"><text class="line" style="{{'background:'+($root.m11)+';'}}"></text><text>收款趋势</text></view></view><view class="echart-content"><block a:if="{{showechart}}"><view><l-echart class="charts-box" onFinished="__e" vue-id="4f39af6e-1" ref="__r" data-ref="chart" data-event-opts="{{[['^finished',[['init']]]]}}" onVueInit="__l"></l-echart></view></block></view></view><block a:if="{{ischooserange}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><view class="headertab"><view data-event-opts="{{[['tap',[['rangeTypeChange',[1]]]]]}}" class="{{(rangeType==1?'item on':'item')}}" style="{{'color:'+(rangeType==1?$root.m12:'')+';'}}" onTap="__e">月份选择</view><view data-event-opts="{{[['tap',[['rangeTypeChange',[2]]]]]}}" class="{{(rangeType==2?'item on':'item')}}" style="{{'color:'+(rangeType==2?$root.m13:'')+';'}}" onTap="__e">日期选择</view></view><image class="popup__close" style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['toggleTimeModal',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:if="{{rangeType==1}}"><view class="month-tab"><view class="month-label">月份</view><view><picker class="date" mode="date" value="{{month}}" fields="month" end="{{curdate}}" data-field="month" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{month?month:'请选择'}}</view></picker></view></view></block><block a:if="{{rangeType==2}}"><view class="time-tab"><view class="month-label">日期</view><view class="time-date"><picker class="date" mode="date" value="{{start_date}}" end="{{curdate}}" data-field="start_date" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{start_date?start_date:'开始时间'}}</view></picker><text class="dt">至</text><picker class="date" mode="date" value="{{end_date}}" end="{{curdate}}" data-field="end_date" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" onChange="__e"><view class="uni-input">{{end_date?end_date:'结束时间'}}</view></picker></view></view></block></view><view class="popup__bottom"><button data-event-opts="{{[['tap',[['resetTimeChoose',['$event']]]]]}}" class="popup_btn btn1" onTap="__e">重 置</button><button data-event-opts="{{[['tap',[['confirmTimeChoose',['$event']]]]]}}" class="popup_btn" style="{{'background:'+($root.m14)+';'+('color:'+('#fff')+';')}}" onTap="__e">确 定</button></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="4f39af6e-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="4f39af6e-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4f39af6e-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>