<view><block a:if="{{isload}}"><block><view class="container"><view class="page"><view class="dkdiv-item flex" style="padding:0;border:0;"><view class="f1"><label style="color:red;" class="_span">*</label>订单金额</view></view><view class="page_module flex-y-center"><text class="page_tag">￥</text><view class="page_price flex-y-center" style="font-size:40rpx;margin-left:5rpx;"><input class="page_price flex1" style="font-weight:bold;text-align:left !important;" type="digit" placeholder="请输入订单金额" data-event-opts="{{[['input',[['inputMoney',['$event']]]]]}}" onInput="__e"/></view></view><view><view class="info-box"><view class="dkdiv-item flex" style="border:0;"><view class="f1"><label style="color:red;" class="_span">*</label>{{$root.m0+"手机号/ID"}}</view><input class="page_price flex1" type="digit" placeholder="请输入手机号/ID" data-event-opts="{{[['blur',[['inputTel',['$event']]]]]}}" onBlur="__e"/></view><block a:if="{{member_info}}"><view><view class="dkdiv-item flex flex-bt" style="border:0;"><view style="display:flex;justify-content:center;align-items:center;"><view class="t1">{{$root.m1+"信息"}}</view></view><view style="display:flex;justify-content:center;align-items:center;"><image class="header_icon" src="{{member_info.headimg}}"></image><text class="t2">{{member_info.nickname+"(ID:"+member_info.id+")"}}</text></view></view><block a:if="{{member_info.p_member}}"><view class="dkdiv-item flex flex-bt"><view style="display:flex;justify-content:center;align-items:center;"><text class="t1">邀请人信息</text></view><view style="display:flex;justify-content:center;align-items:center;"><image class="header_icon" src="{{member_info.p_member.headimg}}"></image><text class="t2">{{member_info.p_member.nickname+"(ID:"+member_info.p_member.id+")"}}</text></view></view></block></view></block><block a:if="{{newscoredata}}"><view class="dkdiv-item flex flex-bt" style="border-top:1px #ededed solid;"><view><view class="t2">{{$root.m2+"预估可得"+$root.m3+"："+(newscoredata.newscore_m?newscoredata.newscore_m:0)}}</view><view class="t2">{{"邀请人预估可得"+$root.m4+"："+(member_info.p_member?parent1commission:'无邀请人信息')}}</view><view class="t2">{{"商家预估可得"+$root.m5+"："+(newscoredata.newscore_b?newscoredata.newscore_b:0)}}</view></view></view></block><view class="dkdiv-item flex-y-center"><view class="f1"><label style="color:red;" class="_span">*</label>有无发票</view><view class="f2"><radio-group class="radio-group" name="tolist" data-event-opts="{{[['change',[['invoiceChange',['$event']]]]]}}" onChange="__e"><label><radio value="1" checked="{{invoice==1?true:false}}"></radio>有</label><label style="margin-left:20rpx;"><radio value="0" checked="{{invoice==0?true:false}}"></radio>无</label></radio-group></view></view><view class="dkdiv-item flex-y-center" style="justify-content:space-between;"><view class="form-item flex-col"><view class="label f1"><label style="color:red;" class="_span">*</label>买卖双方合同<sapn style="color:#5d5c5c;font-size:12px;" vue-id="8cf896a6-1" onVueInit="__l">(最多三张，仅支持jpg，png格式)</sapn></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><view class="layui-imgbox" a:for="{{contract_pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="contract_pic" data-event-opts="{{[['tap',[['removeimg2',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{contract_pic.length<3}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="contract_pic" data-event-opts="{{[['tap',[['uploadimg2',['$event']]]]]}}" onTap="__e"></view></block></view></view></view><view class="dkdiv-item flex-y-center" style="justify-co