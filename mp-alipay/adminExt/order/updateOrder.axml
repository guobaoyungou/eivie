<view><view class="content" id="capture"><view class="item flex-col"><view class="flex-y-center input-view"><text class="input-title">联 系 人：</text><input placeholder="请输入联系人的姓名" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['__set_model',['','linkman','$event',[]]],['linkmanInput',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view><view class="flex-y-center input-view"><text class="input-title">联系电话：</text><input type="number" placeholder="请输入联系人的手机号" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['__set_model',['','tel','$event',[]]],['telInput',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view><block a:if="{{!$root.m0}}"><view><view class="flex-y-center"><text class="input-title">所在地区：</text><view style="padding-left:10rpx;"><uni-data-picker vue-id="cd1ea6b2-1" localdata="{{items}}" border="{{false}}" placeholder="{{regiondata||'请选择省市区'}}" ref="__r" data-ref="unidatapicker" data-event-opts="{{[['^change',[['regionchange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker></view></view><view class="flex-y-center input-view "><text class="input-title">详细地址：</text><input style="width:100%;padding-left:10rpx;" placeholder="请输入联系人的地址" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['__set_model',['','address','$event',[]]],['addressInput',['$event']]]]]}}" value="{{address}}" onInput="__e"/></view></view></block><view class="flex-y-center input-view"><text class="input-title">订单备注：</text><input style="flex:1;" placeholder="请输入订单备注" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['__set_model',['','orderNotes','$event',[]]],['',['$event']]]]]}}" value="{{orderNotes}}" onInput="__e"/></view></view><view class="item"><view class="title-view flex-y-center"><view>商品列表</view><view data-event-opts="{{[['tap',[['addshop',['$event']]]]]}}" class="but-class cxxz" style="{{'background:'+('linear-gradient(-90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" onTap="__e">增加商品及规格</view></view><view class="product"><view a:for="{{prodata}}" a:for-item="item" a:for-index="index2" a:key="index2"><view class="item flex"><view class="img"><block a:if="{{item.guige.pic}}"><image src="{{item.guige.pic}}"></image></block><block a:else><image src="{{item.product.pic}}"></image></block></view><view class="info flex1"><view class="f1" style="height:45px;"><textarea style="border:1px solid #ddd;width:100%;height:45px;border-radius:10rpx;flex-grow:1;" name="content" placeholder="商品名称" data-event-opts="{{[['input',[['inputName',['$event',index2]]]]]}}" value="{{item.guige.name}}" onInput="__e"></textarea></view><view class="modify-price flex-y-center"><view class="f2">规格：</view><input class="inputPrice" style="width:324rpx;" type="text" data-event-opts="{{[['input',[['inputGgname',['$event',index2]]]]]}}" value="{{item.guige.ggname}}" onInput="__e"/></view><view class="modify-price flex-y-center" style="display:flex;justify-content:space-between;align-items:center;width:100%;"><view class="f2">修改单价：</view><input class="inputPrice" style="margin-left:-26%;" type="digit" data-event-opts="{{[['input',[['inputPrice',['$event',index2]]]]]}}" value="{{item.guige.sell_price}}" onInput="__e"/><view class="but-class scc" style="{{'background:'+('linear-gradient(-90deg,'+$root.m3+' 0%,rgba('+$root.m4+',0.8) 100%)')+';'}}" data-index2="{{index2}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" catchTap="__e">删除</view></view><view class="modify-price flex-y-center"><view class="f2">修改数量：</view><input class="inputPrice" type="digit" data-event-opts="{{[['input',[['inputNum',['$event',index2]]]]]}}" value="{{item.num}}" onInput="__e"/></view><view class="f3"><block><text style="font-weight:bold;">{{"￥"+(item.guige.sell_price?item.guige.sell_price:'0.00')}}</text></block><text style="padding-left:20rpx;">{{'× '+(item.num?item.num:0)}}</text></view><view class="modify-price flex-y-center"><view class="f2">备注：</view><input class="inputPrice" style="width:324rpx;" type="text" data-event-opts="{{[['input',[['inputRemark',['$event',index2]]]]]}}" value="{{item.guige.remark}}" onInput="__e"/></view></view></view></view></view><view class="flex-y-center input-view"><text class="input-title">运费金额：</text><input type="text" placeholder placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['freight_priceInput',['$event']]]]]}}" value="{{freight_price}}" onInput="__e"/></view><view class="flex-y-center input-view"><text class="input-title">商品金额：</text><input type="text" placeholder disabled="{{true}}" placeholder-style="color:#626262;font-size:28rpx" value="{{priceCount}}"/></view><view class="flex-y-center input-view"><text class="input-title">会员折扣：</text><input type="text" placeholder disabled="{{true}}" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['leveldk_moneyInput',['$event']]]]]}}" value="{{leveldk_money}}" onInput="__e"/></view><view class="flex-y-center input-view" style="justify-content:space-between;"><view class="flex-y-center"><text class="input-title">订单总价：</text><input type="text" placeholder placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['totalpriceInput',['$event']]]]]}}" value="{{totalprice}}" onInput="__e"/></view></view></view><view style="width:100%;height:182rpx;"></view><block a:if="{{order.status==0}}"><view class="footer flex notabbarbot"><view class="text1 flex1">总计：<block><text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}</text></block></view><button data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m5+' 0%,rgba('+$root.m6+',0.8) 100%)')+';'}}" onTap="__e">确定修改</button></view></block></view><block a:if="{{loading}}"><loading vue-id="cd1ea6b2-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="cd1ea6b2-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="cd1ea6b2-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>