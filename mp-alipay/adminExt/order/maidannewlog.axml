<view><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入用户昵称或订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><block a:for="{{$root.l0}}" a:for-item="dateitem" a:for-index="index" a:key="index"><block a:if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="label"><text class="t1">{{dateitem.$orig.date}}</text></view><view class="item" data-url="{{'maidannewdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{dateitem.$orig.datelist}}" a:for-item="item" a:for-index="index1" a:key="index1"><view class="left"><view class="f2"><view class="t2">{{"支付会员："+item.nickname}}</view><text class="t2">{{"支付时间："+item.paytime}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><block a:if="{{item.paynum}}"><text class="t2">{{"支付单号："+item.paynum}}</text></block></view></view><view class="right"><view><view class="money" style="{{'color:'+(dateitem.m0)+';'}}">{{"￥"+item.money}}</view><block a:if="{{canrefund&&item.refund_money>0}}"><view class="refund-money">{{"已退:￥"+item.refund_money}}</view></block></view><image class="more" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="081dab3c-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="081dab3c-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="081dab3c-3" onVueInit="__l"></loading></block><popmsg vue-id="081dab3c-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>