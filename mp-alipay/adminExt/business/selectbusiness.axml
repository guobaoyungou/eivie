<view class="container"><block a:if="{{isload}}"><block><view class="ind_business"><view class="ind_buslist" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['selectBusiness',['$event']]]]]}}" onTap="__e"><view class="ind_busbox "><view class="flex1 flex-row flex-y-center"><view class="ind_buspic flex0"><image src="{{item.$orig.logo}}"></image></view><view style="flex:1;"><view class="bus_title">{{item.$orig.name}}</view><view class="bus_address">地址：<text class="x1">{{item.$orig.province+item.$orig.city+item.$orig.district+item.$orig.address}}</text></view></view><view class="status flex-y-center"><block a:if="{{item.$orig.is_open==1}}"><view>营业中</view></block><block a:else><view>休息中</view></block><image class="image" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="ind_bottom"><view class="v1"><text class="t1">申请时间：</text>{{item.m0}}</view></view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="119463a0-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="119463a0-2" onVueInit="__l"></nodata></block></view></view></block></block><block a:if="{{loading}}"><loading vue-id="119463a0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="119463a0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><wxxieyi vue-id="119463a0-5" onVueInit="__l"></wxxieyi></view>