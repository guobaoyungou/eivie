<view><block a:if="{{isload}}"><block><view class="container"><view class="topbg"><image class="image" src="{{pre_url+'/static/img/collage_teambg.png'}}"></image></view><view class="topbox" data-url="{{'product?id='+product.id+'&teampid='+teamid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="left"><image src="{{product.pic}}"></image></view><view class="right"><view class="f1">{{product.name}}</view><view class="f2"><block a:if="{{!product.collage_type}}"><view class="t1">{{product.teamnum+"人团"}}</view></block></view><view class="f3"><view class="t1">￥</view><view class="t2">{{product.sell_price}}</view><view class="t3">{{product.sales+"人已拼"}}</view></view></view></view><view class="teambox"><view class="userlist"><view class="item" a:for="{{userlist}}" a:for-item="item" a:for-index="index" a:key="index"><image class="f1" src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image><block a:if="{{item.tuanzhang==1}}"><text class="f2">团长</text></block><block a:if="{{item.nickname!=''}}"><text>{{item.nickname}}</text></block><block a:else><view style="height:40rpx;"></view></block></view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="4499dc84-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="4499dc84-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="4499dc84-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>