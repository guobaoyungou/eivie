<view class="container"><block a:if="{{isload}}"><block><view class="view-show"><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{(('nav_left')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block a:for="{{data}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" data-root-item-id="{{item.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name}}</view></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="{{(('detail-list')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollIntoView="{{scrollToViewId}}" scrollWithAnimation="{{animation}}" scroll-y="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" onScroll="__e"><view class="classification-detail-item" a:for="{{data}}" a:for-item="detail" a:for-index="index" a:key="index"><view class="head" data-id="{{detail.id}}" id="{{'detail-'+detail.id}}"><view class="txt">{{detail.name}}</view></view><view class="detail"><view class="detail-item" style="{{((itemIndex+1)%3===0?'margin-right: 0':'')}}" data-id="{{item.id}}" form-type="submit" data-event-opts="{{[['tap',[['addClass',['$0'],[[['data','',index],['child','',itemIndex]]]]]]]}}" catchTap="__e" a:for="{{detail.child}}" a:for-item="item" a:for-index="itemIndex" a:key="itemIndex"><image class="img" src="{{item.pic}}"></image><view class="txt">{{item.name}}</view></view></view></view></scroll-view></view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="520e7644-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="520e7644-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="520e7644-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>