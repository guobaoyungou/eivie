<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="apply_box"><view class="apply_item"><view>视频号ID<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="channels" placeholder="请输入视频号ID" value="{{info.channels}}"/></view></view></view><view style="padding:30rpx 0;"><button class="set-btn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">确 定</button></view></form></block></block><block a:if="{{loading}}"><loading vue-id="3910e9c6-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="3910e9c6-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="3910e9c6-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>