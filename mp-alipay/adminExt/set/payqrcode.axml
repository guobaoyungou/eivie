<view class="container"><block a:if="{{isload}}"><block><block a:if="{{data&&data.url_h5}}"><view class="row"><view class="title">链接</view><view>{{data.url_h5}}</view><view class="btn" style="{{'background:'+($root.m0)+';'}}" data-url="{{'copy::'+data.url_h5}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">复制</view></view></block><block a:if="{{data&&data.qrcode_h5}}"><view class="row"><view class="title">收款码</view><image style="width:60%;" src="{{data.qrcode_h5}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="btn" style="{{'background:'+($root.m1)+';'}}" data-pic="{{data.qrcode_h5}}" data-event-opts="{{[['tap',[['savpic',['$event']]]]]}}" onTap="__e">下载</view></view></block><block a:if="{{data&&data.qrcode_wx}}"><view class="row"><view class="title">收款码</view><image style="width:60%;" src="{{data.qrcode_wx}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="btn" style="{{'background:'+($root.m2)+';'}}" data-pic="{{data.qrcode_wx}}" data-event-opts="{{[['tap',[['savpic',['$event']]]]]}}" onTap="__e">下载</view></view></block><block a:if="{{data&&data.qrcode_design}}"><view class="row"><view class="title">收款码设计</view><image style="width:60%;" src="{{data.qrcode_design}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image><view class="btn" style="{{'background:'+($root.m3)+';'}}" data-pic="{{data.qrcode_design}}" data-event-opts="{{[['tap',[['savpic',['$event']]]]]}}" onTap="__e">下载</view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="5b74bd7c-1" onVueInit="__l"></loading></block><popmsg vue-id="5b74bd7c-2" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="5b74bd7c-3" onVueInit="__l"></wxxieyi></view>