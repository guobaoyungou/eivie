<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view></view><view class="dp-product-item"><view class="item" style="width:48%;margin:15rpx  1%;" data-url="{{'detail?type=1&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.price+''}}<text style="font-size:24rpx;">/小时</text></text></view></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="72dc2adc-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="72dc2adc-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="72dc2adc-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="72dc2adc-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="72dc2adc-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>