<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" onSubmit="__e"><view class="address-add"><view class="linkitem"><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#757575;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" onInput="__e"/></view><view class="linkitem"><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#757575;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" onInput="__e"/></view></view><view class="buydata"><view class="bcontent"><view class="btitle">产品信息</view><view class="product"><view class="item flex"><view class="img" data-url="{{'product?id='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{product.pic}}"></image></view><view class="info flex1"><view class="f1">{{product.title}}</view><view class="f3"><text style="font-weight:bold;">{{"￥"+product.price}}</text></view></view></view></view><view class="price"><text class="f1">价格</text><text class="f2">{{"¥"+product.price+'/小时'}}</text></view></view><view class="bcontent2"><block a:if="{{userinfo.leveldk_money>0}}"><view class="price"><text class="f1">{{$root.m0+"折扣("+userinfo.discount+"折)"}}</text><text class="f2">{{"-¥"+userinfo.leveldk_money}}</text></view></block><view class="price"><view class="f1">{{$root.m1}}</view><block a:if="{{couponCount>0}}"><view data-event-opts="{{[['tap',[['showCouponList',['$event']]]]]}}" class="f2" onTap="__e"><text style="{{'color:#fff;padding:4rpx 16rpx;font-weight:normal;border-radius:8rpx;font-size:24rpx;'+('background:'+($root.m2)+';')}}">{{couponrid!=0?couponList[couponkey].couponname:couponCount+'张可用'}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block a:else><text class="f2" style="color:#999;">{{"无可用"+$root.m3}}</text></block></view><block a:if="{{opt.type==1}}"><view class="price"><view class="f1" style="flex:1;">预约开始时间</view><view class="choose f2"><view data-event-opts="{{[['tap',[['toStartYuyue',['$event']]]]]}}" class="choosetime" onTap="__e"><block a:if="{{start_time!=''}}"><text>{{start_time}}</text></block><block a:else><text>请选预约开始时间</text></block></view></view></view></block><block a:if="{{opt.type==1}}"><view class="price"><view class="f1" style="flex:1;">预约结束时间</view><view class="choose f2"><view class="choosetime"><block a:if="{{end_time}}"><text>{{end_time}}</text></block></view></view></view></block><view class="buynum flex flex-y-center"><view class="flex1">购买时长(小时)：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" onInput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" onTap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><block a:if="{{opt.type==2}}"><view class="price"><view class="f1" style="flex:1;">结束时间</view><view class="choose f2"><view class="choosetime"><block a:if="{{end_time}}"><text>{{end_time}}</text></block></view></view></view></block></view></view><view style="width:100%;height:182rpx;"></view><view class="footer flex"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}</text></view><block a:if="{{issubmit}}"><button class="op" style="background:#999;">确认提交</button></block><block a:else><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" form-type="submit">确认提交</button></block></view></form><block a:if="{{couponvisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal coupon-modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+$root.m6}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><couponlist vue-id="30b50828-1" couponlist="{{couponList}}" choosecoupon="{{true}}" selectedrid="{{couponrid}}" data-event-opts="{{[['^chooseCoupon',[['chooseCoupon']]]]}}" onChooseCoupon="__e" onVueInit="__l"></couponlist></view></view></view></block><block a:if="{{yuyuevisible}}"><view class="picker-time"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="picker-hide" onTap="__e"></view><view class="picker-module"><picker-view class="picker-view" value="{{value}}" data-event-opts="{{[['change',[['bindChange',['$event']]]]]}}" onChange="__e"><picker-view-column><view class="flex-xy-center" a:for="{{years}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}</view></picker-view-column><picker-view-column><view class="flex-xy-center" a:for="{{hour}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}</view></picker-view-column><picker-view-column><view class="flex-xy-center" a:for="{{min}}" a:for-item="item" a:for-index="index" a:key="index">{{item}}</view></picker-view-column></picker-view><view class="picker-opt flex-xy-center"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="picker-btn" style="{{'background:'+('linear-gradient(-90deg,'+$root.m7+' 0%,rgba('+$root.m8+',0.8) 100%)')+';'}}" onTap="__e">取消</view><view data-event-opts="{{[['tap',[['getTime',['$event']]]]]}}" class="picker-btn" style="{{'background:'+('linear-gradient(-90deg,'+$root.m9+' 0%,rgba('+$root.m10+',0.8) 100%)')+';'}}" onTap="__e">确定</view></view></view></view></block></block></block><block a:if="{{loading}}"><loading vue-id="30b50828-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="30b50828-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="30b50828-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>