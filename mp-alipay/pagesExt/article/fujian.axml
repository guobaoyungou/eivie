<view class="container"><block a:if="{{isload}}"><block><block a:if="{{datalist.length>0}}"><view class="zybox"><view class="zy_list" data-type="{{item.type}}" data-url="{{item.url}}" data-event-opts="{{[['tap',[['openFile',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index"><view class="zy_left  flex-y-center "><block a:if="{{item.type=='pdf'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/pdf.png'}}"></image></block><block a:else><block a:if="{{item.type=='xlsx'||item.type=='xls'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/excel.png'}}"></image></block><block a:else><block a:if="{{item.type=='doc'||item.type=='docx'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/word.png'}}"></image></block><block a:else><block a:if="{{item.type=='ppt'||item.type=='pptx'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/ppt.png'}}"></image></block><block a:else><block a:if="{{item.type=='mp4'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/mp4.png'}}"></image></block><block a:else><block a:if="{{item.type=='mp3'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/mp3.png'}}"></image></block><block a:else><block a:if="{{item.type=='zip'||item.type=='rar'||item.type=='7z'}}"><image class="image zy_image" src="{{pre_url+'/static/img/article/zip.png'}}"></image></block><block a:else><image class="image zy_image" src="{{pre_url+'/static/img/article/png.png'}}"></image></block></block></block></block></block></block></block></view><view class="zy_content flex-y-center">{{''+item.name+''}}</view><view class="flex-y-center f1" style="justify-content:center;"><block a:if="{{look_auth=='0'}}"><image class="image suo_image" src="{{pre_url+'/static/img/article/suo.png'}}"></image></block><block a:else><button class="btn_yl"><block a:if="{{item.type=='zip'||item.type=='rar'||item.type=='7z'}}"><text>下载</text></block><block a:else><text>预览</text></block></button></block></view></view></view></block></block></block><block a:if="{{nodata}}"><nodata vue-id="6dfa1d98-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="6dfa1d98-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="6dfa1d98-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="6dfa1d98-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6dfa1d98-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>