<view class="container"><view class="box2"><view class="header"><view class="f2" id="box2_title">{{title}}</view><view data-event-opts="{{[['tap',[['subpinglun',['$event']]]]]}}" class="f3" onTap="__e">发表</view></view><textarea style="width:100%;height:50vh;" placeholder="写评论..." id="editcontent" data-event-opts="{{[['input',[['setcontent',['$event']]]]]}}" value="{{content}}" onInput="__e"></textarea><view style="height:100rpx;"></view><view class="bottom notabbarbot"><view data-event-opts="{{[['tap',[['showface',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/emote.png'}}"></image></view></view><block a:if="{{faceshow}}"><wxface onSelectface="__e" vue-id="b4f429b4-1" data-event-opts="{{[['^selectface',[['selectface']]]]}}" onVueInit="__l"></wxface></block></view></view>