<view class="container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索本页" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><block a:if="{{isload}}"><block><view class="article_list"><view class="article-itemlist" data-url="{{'/pagesExt/article/fujian?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="id"><view class="article-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="article-info"><view class="p1">{{item.name}}</view><block><view class="p3">{{''+item.subname+''}}</view></block><view class="p2"><text class="flex1" style="overflow:hidden;">{{item.createtime}}</text></view></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="52c5bd9e-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="52c5bd9e-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="52c5bd9e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="52c5bd9e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="52c5bd9e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>