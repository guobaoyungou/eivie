<block a:if="{{isload}}"><view class="container"><view class="main flex-y-center"><block a:if="{{showtype=='png'}}"><image class="img" style="width:100%;" src="{{fujianpic}}" role="img" mode="widthFix" data-url="{{fujianpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></block><block a:else><block a:if="{{showtype=='mp3'}}"><view class="play video"><view class="play-left"><image hidden="{{!(playshow)}}" src="{{pre_url+'/static/img/video_icon.png'}}" data-url="{{fujianpic}}" data-event-opts="{{[['tap',[['play',['$event']]]]]}}" onTap="__e"></image><image hidden="{{!(!playshow)}}" src="{{pre_url+'/static/img/play.png'}}" data-event-opts="{{[['tap',[['pauseaudio',['$event']]]]]}}" onTap="__e"></image><text>{{nowtime}}</text></view><view class="play-right"><slider class="slider" style="margin-top:30rpx;" block-size="16" min="{{0}}" max="{{time}}" value="{{currentTime}}" activeColor="#595959" data-event-opts="{{[['change',[['sliderChange',['$event']]]],['changing',[['sliderChanging',['$event']]]]]}}" onChange="__e" onChanging="__e"></slider></view><view class="play-end"><text>{{duration}}</text></view></view></block><block a:else><video class="video" style="z-index:100;" id="video" autoplay="{{true}}" src="{{fujianpic}}"></video></block></block><block a:if="{{down_auth=='1'}}"><view class="save"><button data-event-opts="{{[['tap',[['savevideo',['$event']]]]]}}" class="btn_save" onTap="__e"><block a:if="{{showtype=='mp3'}}"><text>保存到手机</text></block><block a:else><text>保存至手机相册</text></block></button></view></block></view><wxxieyi vue-id="2cbaa132-1" onVueInit="__l"></wxxieyi></view></block>