<view><block a:if="{{isload}}"><block><view class="container"><view class="header"><text class="title">{{detail.name}}</text><view class="artinfo"><text class="t1">{{detail.createtime}}</text></view><view style="padding:8rpx 0;"><dp vue-id="e530355e-1" pagecontent="{{pagecontent}}" onVueInit="__l"></dp></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="e530355e-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="e530355e-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e530355e-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>