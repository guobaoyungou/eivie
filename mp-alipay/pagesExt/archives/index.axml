<view class="container"><block a:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{item.createtime}}</text></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="42e92a34-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="42e92a34-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="42e92a34-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="42e92a34-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="42e92a34-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>