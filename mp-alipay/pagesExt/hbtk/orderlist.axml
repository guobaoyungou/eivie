<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="755ca65a-1" itemdata="{{['全部','未核销','已核销']}}" itemst="{{['all','1','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="content" style="border-bottom:none;"><view data-url="{{'orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><view class="t4 flex"><view><view class="t3"><text class="x1 flex1">{{item.price==0||item.price==null?'免费':'支付金额：￥'+item.price}}</text></view><view class="t2"><text>{{"已邀请"+item.yqnum+"人"}}</text></view></view><block a:if="{{item.status==1}}"><view class="btn2">待核销</view></block><block a:if="{{item.status==2}}"><view class="btn2">已核销</view></block></view></view></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="755ca65a-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="755ca65a-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="755ca65a-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="755ca65a-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="755ca65a-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>