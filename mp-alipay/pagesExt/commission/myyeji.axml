<view><block a:if="{{isload}}"><block><view class="banner" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"></view><view class="contentdata"><view class="form-box"><view class="form-item flex"><view class="f2" style="line-height:30px;"><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{start_time1}}</view></picker><view style="padding:0 10rpx;color:#333;">到</view><picker mode="date" value="{{end_time1}}" data-event-opts="{{[['change',[['bindEndTime1Change',['$event']]]]]}}" onChange="__e"><view class="picker">{{end_time1}}</view></picker></view><view data-event-opts="{{[['tap',[['search',['$event']]]]]}}" class="data_btn2" style="{{('background:'+$root.m2+';border:0')}}" onTap="__e">查询</view></view></view><view class="data"><view class="data_module flex"><view class="flex1"><view class="data_lable">查询业绩(元)</view><view class="data_value">{{yeji}}</view></view></view></view></view><view style="width:100%;height:20rpx;"></view></block></block><block a:if="{{loading}}"><loading vue-id="f29c2936-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="f29c2936-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f29c2936-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>