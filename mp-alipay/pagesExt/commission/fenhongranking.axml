<block a:if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank_notext.png'}}" mode="widthFix"></image><view class="title"><view class="t1">{{sysset.fenhong_rank_title||'分红排行榜'}}</view><view class="t2">{{sysset.fenhong_rank_desc||'历史分红累积榜单'}}</view></view><view class="content"><view class="top"><view class="t1">{{"我的："+totalcommission}}</view></view><view class="tab"><view class="t1">排名</view><view class="t2">姓名</view><view class="t3" style="{{'color:'+($root.m1)+';'}}">累计</view></view><view class="itembox"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><block a:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block a:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3">{{''+item.sumcommission}}</text></view></block></view></view></view><block a:if="{{nodata}}"><nodata vue-id="cc7a0bd6-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="cc7a0bd6-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="cc7a0bd6-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="cc7a0bd6-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="cc7a0bd6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block></block>