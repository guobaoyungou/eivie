<block a:if="{{isload==1}}"><view class="container"><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1" style="margin-bottom:10rpx;">{{item.remark}}</text><block a:if="{{item.cardno}}"><text class="t1">{{"卡号："+item.cardno}}</text></block><block a:else><text class="t1">{{"兑换码："+item.code}}</text></block><text class="t2">{{"兑换时间："+item.createtime}}</text></view></view></block><block a:if="{{nodata}}"><nodata vue-id="5c680d57-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="5c680d57-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="5c680d57-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="5c680d57-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5c680d57-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view></block>