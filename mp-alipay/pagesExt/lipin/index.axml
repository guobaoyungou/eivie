<view class="container"><block a:if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><view class="title">{{"请输入"+(lipinset.dhmtxt||'兑换码')+"进行兑换"}}</view><block a:if="{{lipinset.needno==1}}"><block><view class="inputdiv"><input id="cardno" type="text" name="cardno" placeholder-style="color:#666;" placeholder="请输入您的卡号" value="{{cardno}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao2',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view><view class="inputdiv"><input id="dhcode" type="text" name="dhcode" placeholder-style="color:#666;" placeholder="请输入您的密码" value="{{dhcode}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view></block></block><block a:else><block><view class="inputdiv"><input id="dhcode" type="text" name="dhcode" placeholder-style="color:#666;" placeholder="请输入您的兑换码" value="{{dhcode}}"/><block a:if="{{platform!='h5'&&lipinset.scanshow==1}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" onTap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view></block></block><button class="btn" style="{{'background-color:'+($root.m0)+';'}}" form-type="submit">立即兑换</button><view class="f0" data-url="dhlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>查看兑换记录</text></view></form><view class="qd_guize"><view class="guize_txt"><parse vue-id="686c8805-1" content="{{lipinset.guize}}" onVueInit="__l"></parse></view></view></block></block><block a:if="{{loading}}"><loading vue-id="686c8805-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="686c8805-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="686c8805-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="686c8805-5" onVueInit="__l"></wxxieyi></view>