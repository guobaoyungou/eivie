<view class="container"><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><block a:if="{{item.status_text}}"><text class="t2">{{item.status_text}}</text></block><text class="t2">{{item.signdate}}</text></view><view class="f2"><text class="t1">{{"+"+item.score}}</text></view></view></view><block a:if="{{nomore}}"><nomore vue-id="70327840-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="70327840-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="70327840-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="70327840-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="70327840-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>