<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form"><view class="form-item"><input class="input" type="text" placeholder="请输入手机号" placeholder-style="color:#BBBBBB;font-size:28rpx" name="tel" value="" data-event-opts="{{[['input',[['telinput',['$event']]]]]}}" onInput="__e"/></view><block a:if="{{needsms}}"><view class="form-item"><input class="input" type="text" placeholder="请输入验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="smscode" value=""/><view data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" class="code" onTap="__e">{{smsdjs||'获取验证码'}}</view></view></block></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block a:if="{{loading}}"><loading vue-id="7c439f38-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="7c439f38-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7c439f38-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>