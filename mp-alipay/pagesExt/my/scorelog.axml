<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}<block a:if="{{set.member_score_withdraw}}"><view class="btn" data-url="/pagesB/my/memberscorewithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></block></view><view class="f2">{{myscore}}<block a:if="{{scoreTransfer}}"><view class="btn-mini" data-url="/pagesExt/my/scoreTransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转赠</view></block></view><view class="item flex-bt flex-y-center"><block a:if="{{scoreWithdraw}}"><view><view class="label">{{"允提"+$root.m2+''}}<view class="btn" data-url="/pagesExt/my/scoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">提现</view></view><view class="value">{{myscore2}}</view></view></block><block a:if="{{score_freeze>0}}"><view><view class="label flex-y-center" data-url="/pagesB/my/scorefreezelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{"冻结"+$root.m3+''}}<image class="right-image" src="{{pre_url+'/static/imgsrc/commission_dw.png'}}"></image></view><view class="value" style="margin-top:20rpx;">{{score_freeze}}</view></view></block></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block a:else><block><text class="t2">{{item.score}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="574016cb-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="574016cb-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="574016cb-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="574016cb-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="574016cb-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>