<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form"><view class="form-item"><input class="input" type="text" placeholder="请输入昵称" placeholder-style="color:#BBBBBB;font-size:28rpx" name="nickname" value=""/></view></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block a:if="{{loading}}"><loading vue-id="135d4fca-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="135d4fca-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="135d4fca-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>