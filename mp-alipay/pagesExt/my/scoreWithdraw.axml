<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e"><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"允提"+$root.m1}}</view><view class="f2">{{myscore}}</view></view><view class="content2"><view class="item2"><view class="f1">提现数量</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="integral" value="" placeholder="请输入提现数量" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" onInput="__e"/></view></view><view class="item4"><text style="margin-right:10rpx;">{{$root.m2+"提现到"+$root.m3+"比例为：1："+score_to_money_percent}}</text><block a:if="{{score_to_money_min_money>0}}"><text>{{",最低兑换金额"+score_to_money_min_money+"元"}}</text></block></view></view><button class="btn" style="{{'background:'+($root.m4)+';'}}" form-type="submit">{{"提现到"+$root.m5}}</button><view class="text-center" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>{{"返回"+$root.m6+"中心"}}</text></view></form></block></block><block a:if="{{loading}}"><loading vue-id="2753a4ef-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="2753a4ef-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar></view>