<view class="container"><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form"><block a:if="{{haspwd==1}}"><view class="form-item"><text class="label">原密码</text><input class="input" type="text" placeholder="输入您的原密码" placeholder-style="font-size:28rpx;color:#BBBBBB" name="oldpaypwd" value="" password="true"/></view></block><view class="form-item"><text class="label">新密码</text><input class="input" type="text" placeholder="输入您的新密码" placeholder-style="font-size:28rpx;color:#BBBBBB" name="paypwd" value="" password="true"/></view><view class="form-item"><text class="label">确认新密码</text><input class="input" type="text" placeholder="再次输入新密码" placeholder-style="font-size:28rpx;color:#BBBBBB" name="repaypwd" value="" password="true"/></view></view><view style="width:94%;margin:0 3%;padding:20rpx;color:#BBBBBB;">{{"注：用于"+$root.m0+"支付等敏感操作时输入，请妥善保管"}}</view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" form-type="submit">确 认</button></form></block></block><block a:if="{{loading}}"><loading vue-id="226530c8-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="226530c8-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="226530c8-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>