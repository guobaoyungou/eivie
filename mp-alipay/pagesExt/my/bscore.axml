<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="flex1"><view class="f1">{{"商家"+$root.m1}}</view><view class="f2">{{mybscore}}</view></view><view class="flex1"><view class="f1">{{"平台"+$root.m2}}</view><view class="f2" data-url="scorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{myscore}}</view></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'bscorelog?bid='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1"><image style="width:60rpx;height:60rpx;border-radius:10rpx;margin-right:10rpx;" src="{{item.logo}}"></image><text class="t1">{{item.name}}</text></view><view class="f2"><view class="t1">{{item.score}}<text>{{$root.m3}}</text></view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block a:if="{{nodata}}"><nodata vue-id="02ff5066-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="02ff5066-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="02ff5066-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="02ff5066-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="02ff5066-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>