<view class="container"><block a:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1+"（"+bname+"）"}}</view><view class="f2">{{mybscore}}</view></view><view class="content" id="datalist"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m2}}</text></view><view class="f2"><block a:if="{{item.$orig.score>0}}"><block><text class="t1">{{"+"+item.$orig.score}}</text></block></block><block a:else><block><text class="t2">{{item.$orig.score}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="f3e78d52-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="f3e78d52-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="f3e78d52-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="f3e78d52-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f3e78d52-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>