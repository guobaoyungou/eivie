<view style="{{('background:'+bgcolor)}}"><image class="banner" src="{{pre_url+'/static/images/video_bg.png'}}" mode="widthFix"></image><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="page"><view class="title">今日播报</view><view class="textarea"><textarea class="textarea_module" placeholder="请粘贴分享链接" data-event-opts="{{[['input',[['__set_model',['','video_url','$event',[]]]]]]}}" value="{{video_url}}" onInput="__e"></textarea></view><block a:if="{{!end_time}}"><view class="freight" style="{{('background:'+bgcolor)}}"><view class="f1">支付方式</view><view class="freight-ul"><view style="width:100%;overflow-y:hidden;overflow-x:scroll;white-space:nowrap;"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><view class="freight-li" style="{{(pay_way==item.$orig.type?'color:'+item.m0+';background:rgba('+item.m1+',0.2)':'')}}" data-type="{{item.$orig.type}}" data-totalpay="{{item.$orig.num}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changePayway',['$event']]]]]}}" onTap="__e">{{item.$orig.name+''}}</view></block></view></view><block a:for="{{pay_ways}}" a:for-item="item" a:for-index="idx2" a:key="idx2"><block a:if="{{pay_way==item.type}}"><view class="freighttips">{{item.desc}}</view></block></block></view></block><block a:if="{{end_time}}"><view class="freight"><view class="freighttips">{{"使用有效期截止："+end_time}}</view></view></block><button class="btn" form-type="submit">去水印解析<block a:if="{{total_pay>0&&pay_way!='free'}}"><text class="btn_tip">{{"(消费"+total_pay+pay_type+")"}}</text></block></button><view class="sustain"><view class="sustain_title">支持平台</view><view class="sustain_module"><view a:for="{{cats}}" a:for-item="item" a:for-index="index"><image class="sustain_image" src="{{item.pic}}" mode="widthFix"></image><view class="sustain_text">{{item.name}}</view></view></view></view></view></form></view>