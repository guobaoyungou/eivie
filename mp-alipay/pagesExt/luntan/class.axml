<view style="width:100%;height:100%;background-color:#fff;"><block a:if="{{isload}}"><block><view style="width:700rpx;margin:0 auto;"><view class="topsearch flex-y-center" data-url="list?cpid=0&displaytype=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><block a:if="{{clist&&clist.length>0}}"><view class="list_view"><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="list_content" style="{{(index%2==0?'margin-right:40rpx':'')}}" data-url="{{'list?cpid='+item.id+'&displaytype='+item.display_type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view style="width:330rpx;height:330rpx;border-radius:8rpx;overflow:hidden;"><image style="width:330rpx;height:330rpx;" src="{{item.pic}}" mode="widthFix"></image></view><view style="line-height:60rpx;font-size:28rpx;">{{item.name}}</view></view></block><block a:if="{{nodata}}"><nodata vue-id="32e8bbe3-1" onVueInit="__l"></nodata></block></view></block><block a:if="{{nomore}}"><nomore vue-id="32e8bbe3-2" onVueInit="__l"></nomore></block></view></block></block><block a:if="{{loading}}"><loading vue-id="32e8bbe3-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="32e8bbe3-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="32e8bbe3-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>