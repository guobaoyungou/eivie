<view style="width:100%;height:100%;"><block a:if="{{isload}}"><block><block a:if="{{cpid>0}}"><view style="width:100%;background:#fff;padding:20rpx 0;overflow:hidden;"><view style="display:inline-block;line-height:70rpx;padding:10rpx 20rpx;" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="cname" style="{{(cid==item.$orig.id?'color:#fff;background-color:'+item.m0:'color:#000;background-color:#f4f4f4')}}" data-cid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeCid',['$event']]]]]}}" onTap="__e">{{''+item.$orig.name+''}}</view></view></view></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" onTap="__e"><image style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/del.png'}}"></image></view></view><view class="search-history-list"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" onTap="__e" a:for="{{history_list}}" a:for-item="item" a:for-index="index" a:key="index">{{item+''}}</view><block a:if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/tanhao.png'}}"></image>暂无记录</view></block></view></view><block a:if="{{datalist&&datalist.length>0}}"><view class="container2" style="border-top:10rpx solid #f4f4f4;"><view class="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="top"><image class="f1" src="{{item.headimg}}"></image><view class="f2"><view class="t1">{{item.nickname}}</view><view class="t2">{{item.showtime}}</view></view></view><view class="con"><view class="f1"><text style="white-space:pre-wrap;">{{item.content}}</text></view><block a:if="{{item.pics}}"><view class="f2"><image style="height:auto;" src="{{pic}}" mode="widthFix" a:for="{{item.pics}}" a:for-item="pic" a:for-index="idx" a:key="idx"></image></view></block><block a:if="{{item.video}}"><video class="video" id="video" src="{{item.video}}" data-event-opts="{{[['tap',[['playvideo',['$event']]]]]}}" catchTap="__e"></video></block></view><view class="bot"><view class="f1"><image style="margin-top:0;" src="{{pre_url+'/static/img/lt_read.png'}}"></image>{{item.readcount}}</view><view class="f1" style="margin-left:60rpx;"><image src="{{pre_url+'/static/img/lt_pinglun.png'}}"></image>{{item.plcount}}</view><view class="f2"></view><block a:if="{{sysset.cansave}}"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savecontent',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_save.png'}}"></image>保存</view></block><view class="f3" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['zan',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/lt_like'+(item['iszan']==0?'':'2')+'.png'}}"></image>{{item.zan}}</view></view></view></block><block a:if="{{nomore}}"><nomore vue-id="8249e922-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="8249e922-2" onVueInit="__l"></nodata></block></view></view></block><view class="{{(('covermy')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" data-url="{{'/activity/luntan/fatie?cid='+cpid+'&displaytype='+displaytype}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/lt_fatie.png'}}"></image></view></block></block><block a:if="{{loading}}"><loading vue-id="8249e922-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="8249e922-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="8249e922-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="8249e922-6" onVueInit="__l"></wxxieyi></view>