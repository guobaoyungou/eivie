<view class="container"><block a:if="{{isload}}"><block><block a:if="{{!shop_order_exchange_product}}"><dd-tab vue-id="6aaa625e-1" itemdata="{{['全部','审核中','已同意','驳回']}}" itemst="{{['all','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><block a:if="{{shop_order_exchange_product}}"><dd-tab vue-id="6aaa625e-2" itemdata="{{['全部','审核中','已同意','驳回','换货完成']}}" itemst="{{['all','1','2','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab></block><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="head"><block a:if="{{item.binfo}}"><block><block a:if="{{item.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block a:else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></block></block><view class="flex1"></view><block a:if="{{item.refund_status==0}}"><text class="st3">取消</text></block><block a:if="{{item.refund_status==1}}"><text class="st0">审核中</text></block><block a:if="{{item.refund_status==2}}"><text class="st4">通过</text></block><block a:if="{{item.refund_status==3}}"><text class="st2">驳回</text></block><block a:if="{{item.refund_status==4}}"><block><block a:if="{{!item.isexpress}}"><text class="st2">审核通过,待退货</text></block><block a:else><text class="st2">审核通过,已寄回</text></block></block></block><block a:if="{{shop_order_exchange_product&&item.refund_status==5}}"><text class="st2">商家已收货</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==6}}"><text class="st2">商家已驳回</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==7}}"><text class="st2">商家已寄出</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==8}}"><text class="st2" style="color:green;">换货完成</text></block></view><block a:for="{{item.prolist}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item2.sell_price}}</text><text class="x2">{{"×"+item2.refund_num}}</text></view></view></view></block><view class="bottom"><text style="margin-right:10rpx;">{{item.refund_type_label}}</text><block a:if="{{item.refund_status==0}}"><text style="color:grey;">{{'申请退款￥'+item.refund_money}}</text></block><block a:if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block a:if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block a:if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block><block a:if="{{item.refund_status==4}}"><block><block a:if="{{!item.isexpress}}"><text style="color:red;">审核通过,待退货</text></block><block a:else><text style="color:red;">审核通过,已寄回</text></block></block></block><block a:if="{{shop_order_exchange_product&&item.refund_status==5}}"><text style="color:red;">商家已收货</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==6}}"><text style="color:red;">商家已驳回</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==7}}"><text style="color:red;">商家已寄出</text></block><block a:if="{{shop_order_exchange_product&&item.refund_status==8}}"><text style="color:green;">换货完成</text></block></view><view class="op"><view class="btn2" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">详情</view><block a:if="{{item.refund_status==1||item.refund_status==4||item.refund_status==6}}"><block><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">取消</view></block></block><block a:if="{{shop_order_exchange_product&&item.refund_status==7}}"><block><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toExchangeConfirm',['$event']]]]]}}" onTap="__e">确认收货</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="6aaa625e-3" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="6aaa625e-4" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="6aaa625e-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="6aaa625e-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="6aaa625e-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>