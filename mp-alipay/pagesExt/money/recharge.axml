<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.money}}</view><view class="f3" data-url="/pagesExt/money/moneylog?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><text>充值记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view><block a:if="{{mdlist.length>0}}"><view data-event-opts="{{[['tap',[['selectmd',['$event']]]]]}}" class="mendian" onTap="__e">{{"门店："+mdlist[mdkey].name}}</view></block></view><view class="content2"><block a:if="{{caninput==1||giveset.length>0}}"><view class="item2"><view class="f1">{{"充值金额("+$root.m2+")"}}</view></view></block><block a:if="{{caninput==1}}"><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="请输入充值金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" onInput="__e"/></view></view></block></block><block a:if="{{giveset.length>0}}"><view class="giveset"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.$orig.money>0}}"><view class="{{(('item')+' '+(moneyduan==item.$orig.money?'active':''))}}" style="{{(moneyduan==item.$orig.money?'background:'+item.m3:'')}}" data-money="{{item.$orig.money}}" data-event-opts="{{[['tap',[['selectgiveset',['$event']]]]]}}" onTap="__e"><text class="t1">{{(caninput==1?'满':'充')+item.$orig.money+item.m4}}</text><block a:if="{{item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠"+item.$orig.give+item.m5+"+"+item.$orig.give_score+item.m6}}</text></block><block a:else><block a:if="{{item.$orig.give&&!item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give+item.m7}}</text></block><block a:else><block a:if="{{!item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give_score+item.m8}}</text></block></block></block></view></block></block></view></block><block a:if="{{recharge_minimum&&recharge_minimum>0}}"><view class="item2"><view class="f1">{{"最低充值"+recharge_minimum+"元"}}</view></view></block><block a:if="{{shuoming}}"><view style="padding:20rpx 30rpx;line-height:42rpx;"><parse vue-id="5f65c4dc-1" content="{{shuoming}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" onNavigate="__e" onVueInit="__l"></parse></view></block></view><view class="op"><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m9)+';'}}" onTap="__e">去支付</view></view><block a:if="{{transfer}}"><view class="op"><view class="btn" style="{{'background:'+($root.m10)+';'}}" data-url="rechargeToMember" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转账</view></view></block></block></block><block a:if="{{selectmdDialogShow}}"><view class="popup__container"><view class="popup__overlay"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择门店</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideSelectmdDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['selectmdRadioChange',['$event']]]]]}}" onTap="__e" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="flex1">{{item.$orig.name}}</view><view style="color:#999;font-size:24rpx;margin-right:10rpx;">{{item.$orig.juli?' 距离:'+item.$orig.juli+'千米':''}}</view><view class="radio" style="{{(index==mdkey?'background:'+item.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></view></block><block a:if="{{loading}}"><loading vue-id="5f65c4dc-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="5f65c4dc-3" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="5f65c4dc-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>