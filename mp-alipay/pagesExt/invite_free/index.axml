<view class="container"><dd-tab vue-id="77ecd44a-1" itemdata="{{['免单中','待免单','已免单']}}" itemst="{{['2','1','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><block a:if="{{isload}}"><block><view style="width:100%;height:100rpx;"></view><view class="order-content"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'/pagesExt/order/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><block a:for="{{item.prolist}}" a:for-item="item2" a:for-index="idx" a:key="idx"><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text></view></view></block><block a:if="{{st==2||st==3}}"><view class="bottom" style="text-align:right;"><text style="text-decoration:line-through;color:red;">{{"￥"+item.totalprice}}</text><text style="margin-left:10rpx;">本次免单金额</text><block a:if="{{st==3}}"><block><block a:if="{{item.status==4}}"><text class="st4" style="color:red;">免单失败</text></block></block></block></view></block><block a:else><view class="bottom" style="text-align:right;">总金额<text style="color:red;">{{"￥"+item.totalprice}}</text></view></block></view></block><block a:if="{{st==2&&(!datalist||datalist.length<=0)}}"><block><view style="width:700rpx;margin:0 auto;border-radius:12rpx;border:2rpx solid #eee;overflow:hidden;text-align:center;line-height:60rpx;background-color:#fff;padding:20rpx;margin-top:10rpx;margin-bottom:20rpx;"><view style="text-align:center;line-height:80rpx;">暂无免单</view></view></block></block></view><block a:if="{{st!=2}}"><block><block a:if="{{nomore}}"><nomore vue-id="77ecd44a-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="77ecd44a-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{st==2&&set&&set.status==1}}"><block><view style="width:700rpx;margin:0 auto;border-radius:12rpx;border:2rpx solid #eee;overflow:hidden;text-align:center;line-height:60rpx;background-color:#fff;padding:20rpx;"><view style="width:328rpx;float:left;"><view>邀请好友进度</view><view class="canvas_view" style="{{(canvas_status?'display:block':'display:none')}}"><canvas style="width:200rpx;height:200rpx;" canvas-id="hycirclefCanvas" id="hycirclefCanvas"></canvas></view><view>{{"已邀请:"+now_num+"/"+all_num+"人"}}</view></view><view style="width:328rpx;float:left;"><view>累计金额进度</view><view class="canvas_view" style="{{(canvas_status?'display:block':'display:none')}}"><canvas style="width:200rpx;height:200rpx;" canvas-id="moneycirclefCanvas" id="moneycirclefCanvas"></canvas></view><view>{{"累计金额:"+now_money+"/"+all_money}}</view></view></view><view data-event-opts="{{[['tap',[['changegz',['$event']]]]]}}" style="width:700rpx;margin:0 auto;border-radius:12rpx;border:2rpx solid #eee;overflow:hidden;text-align:left;line-height:60rpx;background-color:#fff;padding:20rpx;margin-top:20rpx;" onTap="__e"><text>免单规则</text><text style="float:right;">></text></view><view style="width:700rpx;margin:0 auto;border-radius:12rpx;border:2rpx solid #eee;overflow:hidden;text-align:center;line-height:60rpx;background-color:#fff;padding:20rpx;margin-top:20rpx;margin-bottom:20rpx;"><view style="text-align:left;">我邀请的好友</view><block a:if="{{hylist}}"><block><scroll-view class="{{(menuindex>-1?'tabbarbot':'')}}" style="width:100%;max-height:500rpx;" scrollWithAnimation="{{animation}}" scroll-y="true"><view style="padding-bottom:20rpx;border-bottom:2rpx solid #eee;" a:for="{{hylist}}" a:for-item="item" a:for-index="index" a:key="index"><view style="overflow:hidden;"><image style="width:50rpx;height:50rpx;border-radius:50%;overflow:hidden;float:left;margin-top:4rpx;" src="{{item.headimg}}"></image><text style="float:left;margin-left:10rpx;">{{item.nickname}}</text></view><view style="overflow:hidden;text-align:left;"><view style="width:25%;float:left;"><view>加入时间</view><view style="font-size:22rpx;line-height:30rpx;">{{item.createtime}}</view></view><view style="width:25%;float:left;"><view>加购</view><view style="font-size:22rpx;line-height:30rpx;">{{item.cart_num}}</view></view><view style="width:25%;float:left;"><view>下单</view><view style="font-size:22rpx;line-height:30rpx;">{{item.order_num}}</view></view><view style="width:25%;float:left;white-space:pre-wrap;"><view>金额</view><view style="font-size:22rpx;line-height:30rpx;">{{item.order_money}}</view></view></view></view></scroll-view></block></block><block a:else><block><view style="text-align:center;line-height:80rpx;">暂无信息</view></block></block></view></block></block></block></block><block a:if="{{open_gz}}"><block><view data-event-opts="{{[['tap',[['changegz',['$event']]]]]}}" style="width:100%;height:100%;background-color:#000;position:fixed;opacity:0.5;z-index:99;top:0;" onTap="__e"></view><view style="width:700rpx;margin:0 auto;position:fixed;top:10%;left:25rpx;z-index:100;"><view style="background-color:#fff;border-radius:20rpx;overflow:hidden;width:100%;padding:10rpx 20rpx;"><scroll-view class="{{(menuindex>-1?'tabbarbot':'')}}" style="width:100%;height:800rpx;min-height:200rpx;" scrollWithAnimation="{{animation}}" scroll-y="true"><parse vue-id="77ecd44a-4" content="{{set.shuoming}}" onVueInit="__l"></parse></scroll-view></view><view data-event-opts="{{[['tap',[['changegz',['$event']]]]]}}" style="width:80rpx;height:80rpx;line-height:80rpx;text-align:center;font-size:30rpx;background-color:#fff;margin:0 auto;border-radius:50%;margin-top:20rpx;" onTap="__e">X</view></view></block></block><block a:if="{{loading}}"><loading vue-id="77ecd44a-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="77ecd44a-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="77ecd44a-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>