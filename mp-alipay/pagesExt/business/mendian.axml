<view class="container"><block a:if="{{isload}}"><block><view class="content"><map class="{{(isshowlist?'map-class-list':'map-class')}}" id="maps" latitude="{{latitude}}" longitude="{{longitude}}" markers="{{markers}}" scale="{{mapScale}}" enable-zoom="true" enable-satellite="{{maptype}}"></map></view><view class="content1"><view data-event-opts="{{[['tap',[['mendianToggle',['$event']]]]]}}" class="toggle" onTap="__e"><image class="{{(isshowlist?'toggle-icon':'toggle-icon up')}}" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view><block a:if="{{isshowlist}}"><view class="mendian-box"><block a:for="{{mendianlist}}" a:for-item="mendian" a:for-index="index" a:key="index"><view class="mendian-info"><view class="b1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image src="{{mendian.pic}}"></image></view><view class="b2"><view class="t1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">{{mendian.name}}</view><view class="t2 flex-y-center"><view class="mendian-distance">{{mendian.distance}}</view><block a:if="{{mendian.address||mendian.area}}"><block><view class="line"></view><view class="mendian-address">{{''+(mendian.address?mendian.address:mendian.area)}}</view></block></block></view></view><view class="b3"></view></view></block></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="71b8be8f-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="71b8be8f-2" opt="{{opt}}" index="3" onVueInit="__l"></dp-tabbar><popmsg vue-id="71b8be8f-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="71b8be8f-4" onVueInit="__l"></wxxieyi></view>