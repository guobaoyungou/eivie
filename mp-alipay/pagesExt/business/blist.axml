<view class="container"><block a:if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索你感兴趣的商家" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['search',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="search-navbar"><view class="search-navbar-item" style="{{(field=='juli'?'color:'+$root.m0:'')}}" data-field="juli" data-order="asc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e">距离最近</view><view class="search-navbar-item" style="{{(field=='comment_score'?'color:'+$root.m1:'')}}" data-field="comment_score" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e">评分排序</view><view class="search-navbar-item" data-field="sales" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e"><text style="{{(field=='sales'?'color:'+$root.m2:'')}}">{{showviewnum?'浏览排序':'销量排序'}}</text><text class="iconfont iconshangla" style="{{(field=='sales'&&order=='asc'?'color:'+$root.m3:'')}}"></text><text class="iconfont icondaoxu" style="{{(field=='sales'&&order=='desc'?'color:'+$root.m4:'')}}"></text></view><view data-event-opts="{{[['tap',[['showDrawer',['showRight']]]]]}}" class="search-navbar-item flex-x-center flex-y-center" catchTap="__e">筛选<text class="{{('iconfont iconshaixuan '+(showfilter?'active':''))}}"></text></view></view></view><uni-drawer vue-id="25d0c097-1" mode="right" width="{{280}}" ref="__r" data-ref="showRight" data-event-opts="{{[['^change',[['change',['$event','showRight']]]]]}}" onChange="__e" onVueInit="__l"><view class="filter-scroll-view"><scroll-view class="filter-scroll-view-box" scroll-y="true"><view class="search-filter"><view class="filter-title">筛选</view><view class="filter-content-title">商家分类</view><scroll-view style="max-height:66vh;height:auto;" scroll-y="{{true}}"><view class="search-filter-content"><view class="filter-item" style="{{(catchecid=='all'?'color:'+$root.m5+';background:rgba('+$root.m6+',0.1)':'')}}" data-cid="all" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchTap="__e">全部</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="filter-item" style="{{(catchecid==item.$orig.id?'color:'+item.m7+';background:rgba('+item.m8+',0.1)':'')}}" data-cid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchTap="__e">{{item.$orig.name}}</view></block></view></scroll-view><view class="search-filter-btn"><view data-event-opts="{{[['tap',[['filterReset',['$event']]]]]}}" class="btn btn-class" onTap="__e">重置</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="btn2 btn-class" style="{{'background:'+($root.m9)+';'}}" onTap="__e">确定</view></view></view></scroll-view></view></uni-drawer><view class="ind_business"><block a:if="{{show_style==0}}"><view class="ind_buslist" id="datalist"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view data-url="{{item.$orig.tourl?item.$orig.tourl:'/pagesExt/business/index?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="ind_busbox flex1 flex-row"><view class="ind_buspic flex0"><image src="{{item.$orig.logo}}"></image></view><view class="flex1" style="width:70%;"><view style="display:flex;justify-content:space-between;align-items:center;"><view class="bus_title">{{item.$orig.name}}</view><block a:if="{{show_maidanscoredk&&item.$orig.maidanscoredk_text!=''}}"><view class="bus_sales" style="margin:0 10rpx;color:#FF9C00;">{{item.$orig.maidanscoredk_text}}</view></block><block a:if="{{showviewnum}}"><view class="bus_sales">{{"浏览："+item.$orig.viewnum}}</view></block><block a:else><view class="bus_sales"><block a:if="{{show_sales==1}}"><text>{{"销量："+item.$orig.sales}}</text></block></view></block></view><view class="bus_score"><view style="display:flex;align-items:center;"><image class="img" src="{{pre_url+'/static/img/star'+(item.$orig.comment_score>item2?'2native':'')+'.png'}}" a:for="{{[0,1,2,3,4]}}" a:for-item="item2" a:for-index="index2"></image><view class="txt">{{item.$orig.comment_score+"分"}}</view></view><block a:if="{{item.$orig.turnover_show==1}}"><view class="bus_sales" style="{{'color:'+(item.m10)+';'}}">{{"营业额："+item.$orig.turnover}}</view></block></view><block a:if="{{item.$orig.reward_member==1}}"><view class="reward_member" style="{{'color:'+(item.m11)+';'}}">{{"打赏："+item.$orig.reward_member_bili}}</view></block><block a:if="{{item.$orig.address}}"><view class="bus_address" data-latitude="{{item.$orig.latitude}}" data-longitude="{{item.$orig.longitude}}" data-company="{{item.$orig.name}}" data-address="{{item.$orig.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image><text class="x1">{{item.$orig.address}}</text><text class="x2">{{item.$orig.juli}}</text></view></block><block a:if="{{item.$orig.tel}}"><view class="bus_address" data-phone="{{item.$orig.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="x1">{{"联系电话："+item.$orig.tel}}</text></view></block><block a:if="{{item.$orig.activity_time&&item.$orig.activity_time_status==1}}"><view class="bus_address" style="{{'color:'+(item.m12)+';'}}"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/kaishi.png'}}"></image>活动时间：<text class="x1">{{item.$orig.activity_time}}</text></view></block><view class="ratio-list flex"><block a:if="{{item.$orig.rate_back&&item.$orig.rate_back>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m13)+';'+('border-color:'+(item.m14)+';')}}"><view class="label" style="{{'background-color:'+(item.m15)+';'}}">返</view><view class="t1">{{item.$orig.rate_back+"%"}}</view></view></block><block a:if="{{item.$orig.scoredkmaxpercent&&item.$orig.scoredkmaxpercent>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m16)+';'+('border-color:'+(item.m17)+';')}}"><view class="label" style="{{'background-color:'+(item.m18)+';'}}">积</view><view class="t1">{{item.$orig.scoredkmaxpercent+"%"}}</view></view></block><block a:if="{{item.m19}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m20)+';'+('border-color:'+(item.m21)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m22)+';'+('white-space:'+('nowrap')+';')+('width:'+('120rpx')+';')}}">{{item.m23}}</view><view class="t1">{{item.$orig.activecoin_bili+"%"}}</view></view></block><block a:if="{{item.m24}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m25)+';'+('border-color:'+(item.m26)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m27)+';'+('white-space:'+('nowrap')+';')+('width:'+('120rpx')+';')}}">{{item.m28}}</view><view class="t1">{{item.$orig.newscore_ratio+"%"}}</view></view></block><block a:if="{{item.m29}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m30)+';'+('border-color:'+(item.m31)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m32)+';'+('width:'+('120rpx')+';')}}">{{item.m33}}</view><view class="t1">{{item.$orig.newscore_pack_ratio+"%"}}</view></view></block><block a:if="{{item.m34}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m35)+';'+('border-color:'+(item.m36)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m37)+';'+('white-space:'+('nowrap')+';')+('width:'+('120rpx')+';')}}">{{item.m38}}</view><view class="t1">{{item.$orig.subsidy_ratio+"%"}}</view></view></block></view><block a:if="{{item.$orig.queue_free_rate_back>0}}"><view class="flex queue-free"><view class="queue-free-ratio flex" style="{{'color:'+(item.m39)+';'+('border-color:'+(item.m40)+';')}}"><view class="icon-div" style="{{'background-color:'+(item.m41)+';'}}"><image class="icon" src="{{pre_url+'/static/img/qianbao.png'}}"></image></view>{{'最高排队补贴 '+item.$orig.queue_free_rate_back+'%'}}</view></view></block><block a:if="{{item.$orig.dedamount_maxdkpercent&&item.$orig.dedamount_maxdkpercent>0}}"><view class="flex queue-free" style="justify-content:flex-start;"><view class="queue-free-ratio flex" style="{{'color:'+(item.m42)+';'+('border-color:'+(item.m43)+';')}}"><view class="icon-div" style="{{'background-color:'+(item.m44)+';'}}"><image class="icon" src="{{pre_url+'/static/img/qianbao.png'}}"></image></view>{{'抵扣 '+item.$orig.dedamount_maxdkpercent+'%'}}</view></view></block><block a:if="{{type&&type=='businessexpert'}}"><view style="width:100%;display:flex;justify-content:flex-end;"><view class="chooseit" style="{{('background-color:'+$root.m45)}}" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" catchTap="__e">选择</view></view></block><block a:if="{{showtype==0}}"><block><view class="currentScroll" style="width:510rpx;overflow-x:scroll;"><block a:if="{{item.$orig.prolist.length>0||item.$orig.restaurantProlist&&item.$orig.restaurantProlist.length>0}}"><view class="prolist"><view class="product" data-url="{{'/pages/shop/product?id='+item2.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{item.$orig.prolist}}" a:for-item="item2" a:for-index="index2"><image class="f1" src="{{item2.pic}}"></image><view class="f2">{{"￥"+item2.sell_price}}</view></view><block a:if="{{item.$orig.restaurantProlist&&item.$orig.restaurantProlist.length>0}}"><block><view class="product" data-url="{{'/restaurant/takeaway/product?id='+item3.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{item.$orig.restaurantProlist}}" a:for-item="item3" a:for-index="index3" a:key="index3"><image class="f1" src="{{item3.pic}}"></image><view class="f2">{{"￥"+item3.sell_price}}</view></view></block></block></view></block></view></block></block><block a:if="{{showtype==1}}"><block><block a:if="{{item.$orig.prolist.length>0||item.$orig.restaurantProlist&&item.$orig.restaurantProlist.length>0}}"><view class="prolist2"><view class="product" data-url="{{'/pages/shop/product?id='+item2.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e" a:for="{{item.$orig.prolist}}" a:for-item="item2" a:for-index="index2"><image class="f1" src="{{item2.pic}}"></image><view class="f2">{{"￥"+item2.sell_price}}</view><block a:if="{{item2.market_price}}"><view class="f3">{{"￥"+item2.market_price}}</view></block><view class="f4">{{"已售"+item2.sales+"件"}}</view><view class="f5" style="{{'background:'+('rgba('+item.m46+',0.1)')+';'+('color:'+(item.m47)+';')}}" data-proid="{{item2.id}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchTap="__e"><text class="iconfont icon_gouwuche"></text></view></view></view></block></block></block></view></view></view><block a:if="{{(setfirstbuy||setlastbuy)&&type=='buylog'}}"><view class="op"><view class="ops"><block a:if="{{setfirstbuy&&item.$orig.id!=firstbuy_bid}}"><view class="btn" data-bid="{{item.$orig.id}}" data-type="firstbuy" data-event-opts="{{[['tap',[['setFirstBuyBusiness',['$event']]]]]}}" catchTap="__e">设为默认店铺</view></block><block a:if="{{setlastbuy&&item.$orig.id!=lastbuy_bid}}"><view class="btn" data-bid="{{item.$orig.id}}" data-type="lastbuy" data-event-opts="{{[['tap',[['setFirstBuyBusiness',['$event']]]]]}}" catchTap="__e">设为常用店铺</view></block></view></view></block></block><block a:if="{{nomore}}"><nomore vue-id="25d0c097-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="25d0c097-3" onVueInit="__l"></nodata></block></view></block><block a:for="{{$root.l2}}" a:for-item="item" a:for-index="index" a:key="id"><block a:if="{{show_style==1}}"><view class="busbox2" data-url="{{'/pagesA/business/businessindex?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="new_blist"><view class="f1"><image class="image" src="{{item.$orig.logo}}" mode="aspectFill"></image></view><view class="f2"><view class="t1">{{item.$orig.name}}</view><view class="t2"><image class="image" src="{{pre_url+'/static/img/telphone.png'}}" mode="widthFix"></image>{{item.$orig.tel}}</view><view class="t2"><image class="image" src="{{pre_url+'/static/img/position.png'}}" mode="widthFix"></image><text class="text">{{item.$orig.address}}</text></view><block a:if="{{item.$orig.reward_member==1}}"><view class="t2" style="{{'color:'+(item.m48)+';'}}">{{"打赏："+item.$orig.reward_member_bili}}</view></block></view><view class="f3"><image class="image" src="{{pre_url+'/static/img/calltel.png'}}" data-phone="{{item.$orig.tel}}" mode="widthFix" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchTap="__e"></image><view style="color:#EC4149;font-size:26rpx;margin-top:10rpx;">{{item.$orig.juli}}</view></view></view></view></block></block></view><block a:if="{{buydialogShow}}"><buydialog vue-id="25d0c097-4" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" onAddcart="__e" onBuydialogChange="__e" onVueInit="__l"></buydialog></block></block></block><block a:if="{{loading}}"><loading vue-id="25d0c097-5" onVueInit="__l"></loading></block><dp-tabbar vue-id="25d0c097-6" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="25d0c097-7" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="25d0c097-8" onVueInit="__l"></wxxieyi></view>