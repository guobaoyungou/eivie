<view class="container"><block a:if="{{isload}}"><block><view class="search-container" data-url="/pagesExt/business/blist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商家</view></view></view><view class="content-container"><view class="nav_left"><scroll-view style="height:100%;" scroll-y="{{true}}"><view class="{{('nav_left_items '+(curIndex==-1?'active':''))}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>全部</view><block a:for="{{clist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="{{('nav_left_items '+(curIndex==index?'active':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" onTap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.name}}</view></block></scroll-view></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrollToLower',[['scrolltolower',['$event']]]]]}}" onScrollToLower="__e"><view class="item" data-url="{{'/pagesExt/business/index?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><image class="logo" src="{{item.$orig.logo}}"></image><view class="detail"><view class="f1">{{item.$orig.name}}</view><block a:if="{{show_business_tel==1&&item.$orig.tel}}"><view class="f2"><block a:if="{{item.$orig.tel}}"><block>电话：<text style="font-weight:bold;">{{item.$orig.tel}}</text></block></block></view></block><view class="f4">地址：<text style="font-weight:bold;">{{item.$orig.address}}</text></view><block a:if="{{item.$orig.activity_time&&item.$orig.activity_time_status==1}}"><view class="f4" style="{{'color:'+(item.m2)+';'}}">活动时间：<text class="x1">{{item.$orig.activity_time}}</text></view></block><view class="ratio-list flex"><block a:if="{{item.$orig.rate_back&&item.$orig.rate_back>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m3)+';'+('border-color:'+(item.m4)+';')}}"><view class="label" style="{{'background-color:'+(item.m5)+';'}}">返</view><view class="t1">{{item.$orig.rate_back+"%"}}</view></view></block><block a:if="{{item.$orig.scoredkmaxpercent&&item.$orig.scoredkmaxpercent>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m6)+';'+('border-color:'+(item.m7)+';')}}"><view class="label" style="{{'background-color:'+(item.m8)+';'}}">积</view><view class="t1">{{item.$orig.scoredkmaxpercent+"%"}}</view></view></block></view><block a:if="{{item.$orig.juli}}"><view class="f3">{{"距离："+item.$orig.juli}}</view></block><block a:if="{{item.$orig.show_maidan==1}}"><view class="f1" style="justify-content:flex-end;display:flex;"><view class="tomaidan" style="{{'background:'+('linear-gradient(90deg,'+item.m9+' 0%, rgba('+item.m10+',0.8) 100%)')+';'}}" data-url="{{'/pagesB/maidan/pay?bid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">在线买单</view></view></block></view></view><block a:if="{{nomore}}"><nomore vue-id="1a1a31b6-1" text="没有更多商家了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="1a1a31b6-2" text="暂无相关商家" onVueInit="__l"></nodata></block></scroll-view></view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="1a1a31b6-3" loadstyle="left:62.5%" onVueInit="__l"></loading></block><dp-tabbar vue-id="1a1a31b6-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="1a1a31b6-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="1a1a31b6-6" onVueInit="__l"></wxxieyi></view>