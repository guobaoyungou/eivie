<view><block a:if="{{isload}}"><block><block a:if="{{info.id&&info.status==2}}"><view style="color:red;padding:10rpx 30rpx;margin-top:20rpx;">{{"审核不通过："+info.reason+"，请修改后再提交"}}</view></block><block a:if="{{info.id&&info.status==0}}"><view style="color:red;padding:10rpx 30rpx;margin-top:20rpx;">您已提交申请，请等待审核</view></block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="apply_box"><view class="apply_item"><view>联系人姓名<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="linkman" placeholder="请填写姓名" value="{{info.linkman}}"/></view></view><view class="apply_item"><view>联系人电话<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="linktel" placeholder="请填写手机号码" value="{{info.linktel}}"/></view></view><block a:if="{{bset.pid_input_status&&bset.pid_input_status==1}}"><view class="apply_item"><view>推荐人ID<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="business_pid" placeholder="请填写推荐人ID" data-event-opts="{{[['input',[['__set_model',['','business_pid','$event',[]]]]]]}}" value="{{business_pid}}" onInput="__e"/></view></view></block></view><view class="apply_box"><view class="apply_item"><view>商家名称<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="name" placeholder="请输入商家名称" value="{{info.name}}"/></view></view><view class="apply_item"><view>商家描述<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="desc" placeholder="请输入商家描述" value="{{info.desc}}"/></view></view><view class="apply_item"><view>主营类目<text style="color:red;">*</text></view><view><picker value="{{cindex}}" range="{{cateArr}}" data-event-opts="{{[['change',[['cateChange',['$event']]]]]}}" onChange="__e"><view class="picker">{{cateArr[cindex]}}</view></picker></view></view><view class="apply_item"><view>店铺坐标<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['locationSelect',['$event']]]]]}}" class="flex-y-center" onTap="__e"><input type="text" readonly="{{true}}" placeholder="请选择坐标" name="zuobiao" value="{{latitude?latitude+','+longitude:''}}"/></view></view><view class="apply_item"><view>店铺地址<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="address" placeholder="请输入商家详细地址" value="{{address}}"/></view></view><input style="position:fixed;left:-200%;" type="text" hidden="true" name="latitude" value="{{latitude}}"/><input style="position:fixed;left:-200%;" type="text" hidden="true" name="longitude" value="{{longitude}}"/><view class="apply_item"><view>客服电话<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="tel" placeholder="请填写客服电话" value="{{info.tel}}"/></view></view><block a:if="{{queue_free_set.show_rate_back==1}}"><view class="apply_item"><view>{{$root.m0+$root.m1+"(%)"}}</view><view class="flex-y-center"><input type="text" name="rate_back" placeholder="请填写比例" value="{{queue_free_set.rate_back}}"/></view></view></block><block a:if="{{active_coin==1}}"><view><view class="apply_item"><view>让利比例(%)</view><view class="flex-y-center"><input type="text" name="activecoin_ratio" placeholder="请填写比例" value="{{info.activecoin_ratio}}"/></view></view><block a:if="{{showBusinessActivecoinRatio}}"><view class="apply_item"><view>让利到消费者比例(%)</view><view class="flex-y-center"><input type="text" name="business_activecoin_ratio" placeholder="请填写比例" value="{{info.business_activecoin_ratio}}"/></view></view></block><block a:if="{{showMemberActivecoinRatio}}"><view class="apply_item"><view>让利到商家比例(%)</view><view class="flex-y-center"><input type="text" name="member_activecoin_ratio" placeholder="请填写比例" value="{{info.member_activecoin_ratio}}"/></view></view></block></view></block><block a:if="{{new_score==1}}"><view><view class="apply_item"><view>{{$root.m2+"让利比例(%)"}}</view><view class="flex-y-center"><input type="text" name="newscore_ratio" placeholder="请填写比例" value="{{info.newscore_ratio}}"/></view></view><block a:if="{{showMemberNewscoreRatio}}"><view class="apply_item"><view>{{$root.m3+"让利到消费者(%)"}}</view><view class="flex-y-center"><input type="text" name="member_newscore_ratio" placeholder="请填写比例" value="{{info.member_newscore_ratio}}"/></view></view></block><block a:if="{{showBusinessNewscoreRatio}}"><view class="apply_item"><view>{{$root.m4+"让利到商家(%)"}}</view><view class="flex-y-center"><input type="text" name="business_newscore_ratio" placeholder="请填写比例" value="{{info.business_newscore_ratio}}"/></view></view></block></view></block><block a:if="{{showSubsidyRatio}}"><view class="apply_item"><view>让利比例(%)</view><view class="flex-y-center"><input type="text" name="feepercent" placeholder="请填写比例" value="{{info.feepercent}}"/></view></view></block><view class="apply_item" style="line-height:50rpx;"><textarea name="content" placeholder="请输入商家简介" value="{{info.content}}"></textarea></view></view><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>商家logo<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{pic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>{{"商家照片("+min_bpic_num+"-"+max_bpic_num+"张)"}}<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{pics}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{pics.length<max_bpic_num}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view><block a:if="{{!bset.zhengmingtype}}"><block><block a:if="{{!bset.nearby}}"><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>证明材料<text style="color:red;"></text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="layui-imgbox" a:for="{{zhengming}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="zhengming" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="zhengming" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></view><input type="text" hidden="true" name="zhengming" maxlength="-1" value="{{$root.g2}}"/></view></block></block></block><block a:if="{{bset.zhengmingtype}}"><block><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>证明材料<text style="color:red;"></text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><view style="marigin-bottom:20rpx;" a:for="{{formfields.content}}" a:for-item="item" a:for-index="idx" a:key="idx"><block a:if="{{item.showtype&&item.showtype==1}}"><view style="margin-bottom:20rpx;margin-right:8rpx;width:200rpx;"><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view><block a:if="{{editorFormdata[idx]}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgzdy',['$event']]]]]}}" onTap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="widthFix" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view><view style="color:#B2B5BE;">{{item.val1?item.val1:item.val2}}</view></view></block></view></view></view></block></block><block a:if="{{show_custom_field}}"><block><block a:if="{{show_custom_field}}"><view class="apply_box custom_field"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="idx" a:key="idx"><block a:if="{{!item.$orig.showtype}}"><view class="dp-form-item"><view>{{item.$orig.val1}}<block a:if="{{item.$orig.val3==1}}"><text style="color:red;">*</text></block></view><view class="flex-y-center"><block a:if="{{item.$orig.key=='input'||item.$orig.key=='realname'||item.$orig.key=='usercard'}}"><block><block a:if="{{item.$orig.val5}}"><text style="margin-right:10rpx;">{{item.$orig.val5}}</text></block><input class="input" type="{{item.$orig.input_type}}" name="{{'form'+idx}}" placeholder="{{item.$orig.val2}}" placeholder-style="font-size:30rpx;color:#B2B5BE" data-formidx="{{'form'+idx}}" data-event-opts="{{[['input',[['setfield',['$event']]]]]}}" value="{{editorFormdata[idx]}}" onInput="__e"/></block></block><block a:if="{{item.$orig.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.$orig.val2}}" placeholder-style="font-size:30rpx;color:#B2B5BE" data-formidx="{{'form'+idx}}" data-event-opts="{{[['input',[['setfield',['$event']]]]]}}" value="{{editorFormdata[idx]}}" onInput="__e"></textarea></block></block><block a:if="{{item.$orig.key=='radio'||item.$orig.key=='sex'}}"><block><radio-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" onChange="__e"><label class="flex-y-center" a:for="{{item.$orig.val2}}" a:for-item="item1" a:for-index="idx1" a:key="id"><radio class="radio" style="transform:scale(0.8);" value="{{item1}}" checked="{{editorFormdata[idx]&&editorFormdata[idx]==item1?true:false}}"></radio>{{item1+''}}</label></radio-group></block></block><block a:if="{{item.$orig.key=='checkbox'}}"><block><checkbox-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" onChange="__e"><label class="flex-y-center" a:for="{{item.l0}}" a:for-item="item1" a:for-index="idx1" a:key="id"><checkbox class="checkbox" style="transform:scale(0.8);" value="{{item1.$orig}}" checked="{{item1.m5?true:false}}"></checkbox>{{item1.$orig+''}}</label></checkbox-group></block></block><block a:if="{{item.$orig.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" range="{{item.$orig.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.$orig.val2[editorFormdata[idx]]}}</view></block><block a:else><view style="color:#b2b5be;">请选择</view></block></picker></block></block><block a:if="{{item.$orig.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" start="{{item.$orig.val2[0]}}" end="{{item.$orig.val2[1]}}" range="{{item.$orig.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view style="color:#b2b5be;">请选择</view></block></picker></block></block><block a:if="{{item.$orig.key=='date'||item.$orig.key=='birthday'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" start="{{item.$orig.val2[0]}}" end="{{item.$orig.val2[1]}}" range="{{item.$orig.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" onChange="__e"><block a:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block a:else><view style="color:#b2b5be;">请选择</view></block></picker></block></block><block a:if="{{item.$orig.key=='region'}}"><block><uni-data-picker vue-id="{{'20043c2e-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" placeholder="{{editorFormdata[idx]||'请选择省市区'}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['^change',[['onchange']]]]}}" onChange="__e" onVueInit="__l"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{regiondata?regiondata:editorFormdata[idx]}}"/></block></block><block a:if="{{item.$orig.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;"><block a:if="{{editorFormdata[idx]}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-close" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgzdy',['$event']]]]]}}" onTap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="dp-form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="widthFix" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view></block><block a:else><view class="dp-form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" onTap="__e"></view></block></view></block></block></view></view></block></block></view></block><view style="display:none;">{{test}}</view></block></block><block a:if="{{showunpwd&&showunpwd==1}}"><view class="apply_box"><view><view class="apply_item" style="border:none;"><view>登录账号<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="un" placeholder="请设置登录账号" autocomplete="off" value="{{info.un}}"/></view></view><view style="border-bottom:1px solid #eee;color:#999;margin-top:-20rpx;padding-bottom:10rpx;font-size:24rpx;"><block a:if="{{bset.nearby}}"><text>如需开通商城功能请联系后台</text></block></view></view><view class="apply_item"><view>登录密码<text style="color:red;">*</text></view><view class="flex-y-center"><input type="password" name="pwd" placeholder="请设置登录密码" autocomplete="off" value="{{info.pwd}}"/></view></view><view class="apply_item"><view>确认密码<text style="color:red;">*</text></view><view class="flex-y-center"><input type="password" name="repwd" placeholder="请再次设置登录密码" value="{{info.repwd}}"/></view></view></view></block><block a:if="{{bset.xieyi_show==1}}"><block><block a:if="{{!info.id||info.status==2}}"><view class="flex-y-center" style="margin-left:20rpx;color:#999;"><checkbox-group data-event-opts="{{[['change',[['isagreeChange',['$event']]]]]}}" onChange="__e"><label class="flex-y-center"><checkbox value="1" checked="{{isagree}}"></checkbox>阅读并同意</label></checkbox-group><text data-event-opts="{{[['tap',[['showxieyiFun',['$event']]]]]}}" style="color:#666;" onTap="__e">《商户入驻协议》</text></view></block></block></block><view style="padding:30rpx 0;"><block a:if="{{!info.id||info.status==2}}"><button class="set-btn" style="{{('background:linear-gradient(90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')}}" form-type="submit"><block a:if="{{bset.deposit&&bset.deposit>0}}"><text style="margin-right:20rpx;">{{$root.m8+bset.deposit}}</text></block>提交申请</button></block></view></form><view style="width:100%;height:100%;position:fixed;top:0;left:0;z-index:99;background:rgba(0,0,0,0.7);" id="xieyi" hidden="{{!showxieyi}}"><view style="width:90%;margin:0 auto;height:85%;margin-top:10%;background:#fff;color:#333;padding:5px 10px 50px 10px;position:relative;border-radius:2px;"><view style="overflow:scroll;height:100%;"><parse vue-id="20043c2e-2" content="{{bset.xieyi}}" onVueInit="__l"></parse></view><view data-event-opts="{{[['tap',[['hidexieyi',['$event']]]]]}}" style="position:absolute;z-index:9999;bottom:10px;left:0;right:0;margin:0 auto;text-align:center;" onTap="__e">已阅读并同意</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="20043c2e-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="20043c2e-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="20043c2e-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="20043c2e-6" onVueInit="__l"></wxxieyi></view>