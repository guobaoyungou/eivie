<view class="container"><block a:if="{{isload}}"><block><view class="recordList"><view class="ListItem" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><image class="firendAvatar" src="{{item.$orig.headimg}}"></image><view class="info"><text class="styleText">{{item.$orig.nickname}}</text><text>{{"于 "+item.m0+" 查看了我的"+mingpiantext}}</text><block a:if="{{item.$orig.applysee}}"><view style="display:flex;justify-content:space-between;align-items:center;margin-top:20rpx;"><view>申请查看更多内容</view><view style="display:flex;width:230rpx;justify-content:space-between;align-items:center;"><block a:if="{{item.$orig.applysee==-1}}"><view>已驳回</view></block><block a:if="{{item.$orig.applysee==2}}"><view style="color:green;">已通过</view></block><block a:if="{{item.$orig.applysee==1}}"><view class="checkaddfields" data-url="{{'/pagesB/mingpian/checkapplylog?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去审核</view></block><block a:if="{{item.$orig.applysee==2}}"><view class="checkaddfields" data-url="{{'/pagesB/mingpian/checkapplylog?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去编辑</view></block></view></view></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="61c69ee4-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="61c69ee4-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="61c69ee4-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="61c69ee4-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="61c69ee4-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>