<view class="container"><view class="item" a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="product-item2" data-url="{{'index?id='+item.$orig.mpid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><view class="data" style="{{'background:'+(item.$orig.info.bgpic?'url('+item.$orig.info.bgpic+')':'#fff')+';'+('background-size:'+('100%')+';')}}"><view class="data_info" style="{{(field_list2?'':'border:0;margin:0')}}"><image class="data_head _img" src="{{item.$orig.info.headimg}}" alt></image><view><view class="data_name">{{item.$orig.info.realname}}</view><block a:if="{{item.$orig.info.touxian1}}"><view class="data_text">{{item.$orig.info.touxian1}}</view></block><block a:if="{{item.$orig.info.touxian2}}"><view class="data_text">{{item.$orig.info.touxian2}}</view></block><block a:if="{{item.$orig.info.touxian3}}"><view class="data_text">{{item.$orig.info.touxian3}}</view></block></view></view><view class="data_list" a:for="{{item.l0}}" a:for-item="item2" a:for-index="index2"><block a:if="{{index2=='tel'}}"><image src="{{item2.m0}}" alt class="_img"></image></block><block a:else><block a:if="{{index2=='weixin'}}"><image src="{{pre_url+'/static/img/weixin.png'}}" alt class="_img"></image></block><block a:else><block a:if="{{index2=='address'}}"><image src="{{item2.m1}}" alt class="_img"></image></block><block a:else><image src="{{item2.$orig.icon}}" alt class="_img"></image></block></block></block>{{''+item.$orig.info[index2]+''}}</view></view></view><view class="foot"><text class="flex1">{{"收藏时间："+item.m2}}</text><text class="btn" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['favoritedel',['$event']]]]]}}" onTap="__e">取消收藏</text></view></view><block a:if="{{nomore}}"><nomore vue-id="db01b8a0-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="db01b8a0-2" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="db01b8a0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="db01b8a0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="db01b8a0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>