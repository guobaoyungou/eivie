<view><block a:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" onSubmit="__e"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;">{{"请选择"+mingpiantext+"背景"}}</view><block a:if="{{show_background_category==1}}"><block><dd-tab vue-id="79979802-1" itemdata="{{bgdata.category_name}}" itemst="{{bgdata.category_key_arr}}" st="{{bgcid}}" data-event-opts="{{[['^changetab',[['changebgcategory']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><scroll-view class="scroll-view" scroll-x="true"><block a:if="{{bgcid!=-1}}"><view class="bglist flex"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index"><block a:if="{{item.$orig.type==0}}"><view data-event-opts="{{[['tap',[['selectBg',['$0'],[[['this_bglist','',index,'id']]]]]]]}}" class="bg" style="{{'background-color:'+(item.$orig.bgcolor)+';'}}" onTap="__e"><block a:if="{{item.$orig.id==bgid}}"><view class="mengceng"><view class="mc"><view class="checked" style="{{'color:'+(item.m0)+';'}}">✔</view></view></view></block></view></block><block a:else><view data-event-opts="{{[['tap',[['selectBg',['$0'],[[['this_bglist','',index,'id']]]]]]]}}" class="bg" onTap="__e"><view class="bgpic"><image class="bgpic" src="{{item.$orig.bgpic}}" mode="widthFix"></image></view><block a:if="{{item.$orig.id==bgid}}"><view class="mengceng" style="z-index:10;"><view class="mc"><view class="checked" style="{{'color:'+(item.m1)+';'}}">✔</view></view></view></block></view></block></block></view></block></scroll-view></block></block><block a:if="{{iscustom==1}}"><block><view class="f2" style="flex-wrap:wrap;"><view class="layui-imgbox" a:for="{{bgpic}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="bgpic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{bgpic.length<=mingpian_banner_length}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="bgpic" data-pernum="1" data-event-opts="{{[['tap',[['uploadbgpic',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="bgpic" maxlength="-1" value="{{$root.g0}}"/></block></block></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;"><text style="color:red;padding-right:6rpx;">*</text>请上传个人照片（上传正方形照片）</view><view class="f2"><view class="layui-imgbox" a:for="{{headimg}}" a:for-item="item" a:for-index="index" a:key="index"><view class="layui-imgbox-close" data-index="{{index}}" data-field="headimg" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" onTap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view></view><block a:if="{{headimg.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="headimg" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" onTap="__e"></view></block></view><input type="text" hidden="true" name="headimg" maxlength="-1" value="{{$root.g1}}"/></view></view><view class="form-box"><view class="form-item"><view class="f1"><text style="color:red;padding-right:6rpx;">*</text>请输入姓名</view><view class="f2"><input type="text" name="realname" placeholder-style="color:#888" value="{{info.realname}}"/></view></view><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;"><text style="color:red;padding-right:6rpx;">*</text>请添加头衔(最多添加3个)</view><view class="f2"><input style="text-align:left;" type="text" name="touxian1" placeholder="公司名称+职务，如：某科技有限公司|总经理" placeholder-style="color:#888" value="{{info.touxian1}}"/></view><view class="f2" style="margin-top:10rpx;"><input style="text-align:left;" type="text" name="touxian2" placeholder="公司名称+职务，如：某科技有限公司|总经理" placeholder-style="color:#888" value="{{info.touxian2}}"/></view><view class="f2" style="margin-top:10rpx;"><input style="text-align:left;" type="text" name="touxian3" placeholder="公司名称+职务，如：某科技有限公司|总经理" placeholder-style="color:#888" value="{{info.touxian3}}"/></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;">联系信息<text style="font-size:24rpx;color:#888;">{{"(前三项将显示在"+mingpiantext+"封面上)"}}</text></view></view><block a:for="{{field_list}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{item.isshow==1}}"><block><view class="form-item"><view class="f1"><text style="color:red;padding-right:6rpx;">{{item.required==1?'*':' '}}</text>{{"请输入"+item.name}}</view><view class="f2"><block a:if="{{item.isadd&&item.isadd=='1'}}"><input type="text" name="{{index}}" placeholder-style="color:#888" value="{{addfields?addfields[index]:''}}"/></block><block a:else><input type="text" name="{{index}}" placeholder-style="color:#888" value="{{index=='address'?address:info[index]}}"/></block></view><block a:if="{{index=='address'}}"><view data-event-opts="{{[['tap',[['selectzuobiao',['$event']]]]]}}" class="f3" style="color:#58e;font-size:24rpx;margin-left:6rpx;" onTap="__e">选择位置</view></block></view></block></block></block><input name="latitude" hidden="true" value="{{latitude}}"/><input name="longitude" hidden="true" value="{{longitude}}"/></view><view class="form-box"><view class="form-item flex-col"><text>个人简介</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" onTap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" onTap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" onTap="__e">+视频</view></view><view><block a:for="{{pagecontent}}" a:for-item="setData" a:for-index="index" a:key="index"><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" onTap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" onTap="__e">下移</view><block a:if="{{setData.temp=='text'}}"><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailEdit',['$event']]]]]}}" onTap="__e">编辑</view></block><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" onTap="__e">删除</view></view><view class="detailbox"><block a:if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'79979802-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-notice></block></block><block a:if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'79979802-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-banner></block></block><block a:if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'79979802-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-search></block></block><block a:if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'79979802-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-text></block></block><block a:if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'79979802-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-title></block></block><block a:if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'79979802-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-dhlist></block></block><block a:if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'79979802-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-line></block></block><block a:if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'79979802-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-blank></block></block><block a:if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'79979802-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-menu></block></block><block a:if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'79979802-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-map></block></block><block a:if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'79979802-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cube></block></block><block a:if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'79979802-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-picture></block></block><block a:if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'79979802-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-pictures></block></block><block a:if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'79979802-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-video></block></block><block a:if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'79979802-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}" onVueInit="__l"></dp-shop></block></block><block a:if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'79979802-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-product></block></block><block a:if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'79979802-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-collage></block></block><block a:if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'79979802-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-kanjia></block></block><block a:if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'79979802-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-seckill></block></block><block a:if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'79979802-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-scoreshop></block></block><block a:if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'79979802-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-coupon></block></block><block a:if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'79979802-23-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-article></block></block><block a:if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'79979802-24-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-business></block></block><block a:if="{{setData.temp=='liveroom'}}"><block><dp-liveroom vue-id="{{'79979802-25-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-liveroom></block></block><block a:if="{{setData.temp=='button'}}"><block><dp-button vue-id="{{'79979802-26-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-button></block></block><block a:if="{{setData.temp=='hotspot'}}"><block><dp-hotspot vue-id="{{'79979802-27-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-hotspot></block></block><block a:if="{{setData.temp=='cover'}}"><block><dp-cover vue-id="{{'79979802-28-'+index}}" params="{{setData.params}}" data="{{setData.data}}" onVueInit="__l"></dp-cover></block></block><block a:if="{{setData.temp=='richtext'}}"><block><dp-richtext vue-id="{{'79979802-29-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-richtext></block></block><block a:if="{{setData.temp=='form'}}"><block><dp-form vue-id="{{'79979802-30-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-form></block></block><block a:if="{{setData.temp=='userinfo'}}"><block><dp-userinfo vue-id="{{'79979802-31-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}" onVueInit="__l"></dp-userinfo></block></block></view></view></block></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;">自定义分享标题(不填写则按框中内容显示)</view><view class="f2"><input style="text-align:left;" type="text" name="sharetitle" placeholder="{{'您好，这是我的'+mingpiantext+'，望惠存！'}}" placeholder-style="color:#888" value="{{info.sharetitle}}"/></view></view></view><button class="savebtn" form-type="submit">提交</button><view style="height:50rpx;"></view></form><block a:if="{{bglistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeBglistDialog',['$event']]]]]}}" class="popup__overlay" catchTap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+mingpiantext+"背景图"}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeBglistDialog',['$event']]]]]}}" catchTap="__e"></image></view><view class="popup__content"><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="$orig"><view class="clist-item flex-y-center" data-pic="{{item.$orig}}" data-event-opts="{{[['tap',[['bgChange',['$event']]]]]}}" onTap="__e"><view class="flex1"><image class="clist-image _img" src="{{item.$orig}}" mode="widthFix"></image></view><block a:if="{{mingpian_banner}}"><view class="radio" style="{{(item.m2?'background:'+item.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></block><block a:else><view class="radio" style="{{($root.g2==item.$orig?'background:'+item.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></block></view></block></view></view></view></block><uni-popup vue-id="79979802-32" id="dialogDetailtxt" type="dialog" ref="__r" data-ref="dialogDetailtxt" onVueInit="__l"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请输入文本内容</text></view><view class="uni-dialog-content"><scroll-view class="uni-dialog-scroll" scroll-y="true"><view><textarea placeholder="请输入文本内容" auto-height="{{true}}" data-event-opts="{{[['input',[['catcheDetailtxt',['$event']]]]]}}" value="{{edit_text}}" onInput="__e"></textarea></view></scroll-view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-dialog-button" onTap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['dialogDetailtxtConfirm',['$event']]]]]}}" class="uni-dialog-button uni-border-left" onTap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-popup-dialog__close" onTap="__e"><label class="uni-popup-dialog__close-icon  _span"></label></view></view></uni-popup></block></block><view style="display:none;">{{test}}</view><block a:if="{{loading}}"><loading vue-id="79979802-33" onVueInit="__l"></loading></block><popmsg vue-id="79979802-34" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="79979802-35" onVueInit="__l"></wxxieyi></view>