<view class="container"><block a:if="{{isload}}"><block><view class="recordList"><view class="ListItem" a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><image class="firendAvatar" src="{{item.$orig.headimg}}"></image><view class="info"><text class="styleText">{{item.$orig.nickname}}</text><text>{{"于 "+item.m0+" 收藏了我的"+mingpiantext}}</text></view></view></view><block a:if="{{nomore}}"><nomore vue-id="340682d8-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="340682d8-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="340682d8-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="340682d8-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="340682d8-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>