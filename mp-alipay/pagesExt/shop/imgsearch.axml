<view class="container"><block a:if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view hidden="{{!(history_show)}}" class="search-history"><block a:if="{{info.banner}}"><view class="topimg" style="{{('background-image:url('+info.banner+');background-size:100% 100%;')}}"></view></block><view data-event-opts="{{[['tap',[['uploadImg',['$event']]]]]}}" class="centerimg" onTap="__e"><block a:if="{{info.image_search_pic}}"><image src="{{info.image_search_pic}}"></image></block><block a:else><image src="{{pre_url+'/static/img/camera2.png'}}"></image></block><view class="title">以图搜索</view></view></view></view><ksp-cropper vue-id="fe4f9254-1" mode="free" width="{{200}}" height="{{140}}" maxWidth="{{1024}}" maxHeight="{{1024}}" url="{{imgurl}}" data-event-opts="{{[['^cancel',[['oncancel']]],['^ok',[['onok']]]]}}" onCancel="__e" onOk="__e" onVueInit="__l"></ksp-cropper></block></block><block a:if="{{loading}}"><loading vue-id="fe4f9254-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="fe4f9254-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="fe4f9254-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="fe4f9254-5" onVueInit="__l"></wxxieyi></view>