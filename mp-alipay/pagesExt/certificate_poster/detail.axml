<view class="container"><block a:if="{{isload}}"><block><view style="padding-top:50rpx;padding-left:20rpx;padding-right:20rpx;display:flex;align-items:center;"><image class="sjew-img" src="{{poster}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e"></image></view><block a:if="{{info.explain}}"><view style="padding:40rpx 20rpx;"><parse vue-id="79511556-1" content="{{info.explain}}" onVueInit="__l"></parse></view></block><view class="sjew-he"></view><view class="{{(('sjew-bottom')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="sjew-bottom-content"><view data-event-opts="{{[['tap',[['saveImage',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m0)+';'}}" onTap="__e">保存证书</view><view class="sjew-bot-a2" style="{{'background:'+($root.m1)+';'}}" data-url="{{poster}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e">{{"查看"+certificate_text}}</view></view></view></block></block><block a:if="{{loading}}"><loading vue-id="79511556-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="79511556-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="79511556-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="79511556-5" onVueInit="__l"></wxxieyi></view>