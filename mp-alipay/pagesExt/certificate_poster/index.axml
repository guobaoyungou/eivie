<view class="container"><block a:if="{{isload}}"><block><block a:if="{{set.header_text}}"><view><parse vue-id="7ef4eca0-1" content="{{set.header_text}}" onVueInit="__l"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" onSubmit="__e"><block a:if="{{set&&set.query_type=='id_card'}}"><view class="title">{{"请输入身份证号查询"+certificate_text}}</view></block><block a:if="{{set&&set.query_type=='tel'}}"><view class="title">{{"请输入手机号查询"+certificate_text}}</view></block><view class="inputdiv"><block a:if="{{set&&set.query_type=='id_card'}}"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入您的身份证号" value="{{tel}}"/></block><block a:if="{{set&&set.query_type=='tel'}}"><input type="text" name="tel2" placeholder-style="color:#666;" placeholder="请输入您的手机号" value="{{tel2}}"/></block></view><button class="btn" form-type="submit">查询</button></form><block a:if="{{set.footer_text}}"><view><parse vue-id="7ef4eca0-2" content="{{set.footer_text}}" onVueInit="__l"></parse></view></block></block></block><block a:if="{{loading}}"><loading vue-id="7ef4eca0-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="7ef4eca0-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="7ef4eca0-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>