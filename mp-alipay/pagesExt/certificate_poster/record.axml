<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><view class="item" data-url="{{'detail?tel='+item.tel+'&posterid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"姓名："+item.realname}}</text><text class="t2">{{"身份证号："+item.tel}}</text></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="e7e0bd56-1" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="e7e0bd56-2" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="e7e0bd56-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="e7e0bd56-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="e7e0bd56-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>