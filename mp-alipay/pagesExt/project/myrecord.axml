<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="2141da95-1" itemdata="{{['全部','通过','待审核','驳回']}}" itemst="{{['all','1','0','-1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="content" id="datalist"><view class="item" data-url="{{'record?id='+item.id+'&pid='+item.pid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"提交时间："+item.createtime}}</text></view><view class="f2"><block a:if="{{item.status==0}}"><text class="t1" style="color:#333;">待审核</text></block><block a:if="{{item.status==1}}"><text class="t1" style="color:green;">已通过</text></block><block a:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></view></block></block><block a:if="{{nodata}}"><nodata vue-id="2141da95-2" onVueInit="__l"></nodata></block><block a:if="{{nomore}}"><nomore vue-id="2141da95-3" onVueInit="__l"></nomore></block><block a:if="{{loading}}"><loading vue-id="2141da95-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="2141da95-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2141da95-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>