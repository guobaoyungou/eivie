<block a:if="{{isload}}"><view class="data-v-5241567a"><view class="screen data-v-5241567a"><view class="screen_module data-v-5241567a"><scroll-view class="screen_content data-v-5241567a" scroll-x="true"><view data-event-opts="{{[['tap',[['dateClick',[index]]]]]}}" class="{{((('screen_item')+' '+'data-v-5241567a')+' '+(dateIndex==index?'screen_active':''))}}" onTap="__e" a:for="{{datelist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="screen_text data-v-5241567a">{{item.date}}</view><view class="screen_text data-v-5241567a">{{item.week}}</view></view></scroll-view><view data-event-opts="{{[['tap',[['alertClick',['$event']]]]]}}" class="screen_opt data-v-5241567a" onTap="__e"><image src="data:image/png;base64," alt class="data-v-5241567a"></image><view class="data-v-5241567a">筛选</view></view></view></view><view class="module data-v-5241567a" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="module_data data-v-5241567a" data-url="{{'product?id='+item.id+'&dateIndex='+dateIndex}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e"><image class="module_img data-v-5241567a" src="{{item.pic}}" alt></image><view class="module_content data-v-5241567a"><view class="module_title data-v-5241567a">{{item.name}}</view><block a:if="{{item.workerinfo}}"><view class="module_item data-v-5241567a">{{item.workerinfo.realname+" "+(item.workerinfo.dengji||'')+''}}<block a:if="{{item.startime&&item.endtime}}"><view class="module_time data-v-5241567a">{{item.starttime+"~"+item.endtime}}</view></block></view></block><view class="module_item data-v-5241567a">{{"报名费"+item.sell_price+"元"}}</view></view><block a:if="{{item.yuyue_model&&item.yuyue_model==2}}"><view class="data-v-5241567a"><view class="module_btn data-v-5241567a">预约</view></view></block><block a:else><view class="data-v-5241567a"><block a:if="{{item.isend}}"><view class="module_btn module_end data-v-5241567a">已结束</view></block><block a:else><block a:if="{{item.leftnum>0}}"><view class="module_btn data-v-5241567a">预约</view></block><block a:else><view class="module_btn module_end data-v-5241567a">满员</view></block></block></view></block></view><view class="module_num data-v-5241567a"><view class="module_lable data-v-5241567a"><view class="data-v-5241567a">当前</view><view class="data-v-5241567a">预约</view></view><view class="module_view data-v-5241567a"><block class="data-v-5241567a" a:for="{{item.yyorderlist}}" a:for-item="item2" a:for-index="index2"><image src="{{item2.headimg}}" class="data-v-5241567a"></image></block></view><block a:if="{{!item.yuyue_model||item.yuyue_model==1}}"><view class="data-v-5241567a"><block a:if="{{item.leftnum>0}}"><view class="module_tag data-v-5241567a">{{"剩余"+item.leftnum+"个名额"}}</view></block><block a:else><view class="module_tag module_end data-v-5241567a">满员</view></block></view></block></view></view><block a:if="{{alertState}}"><view class="alert data-v-5241567a"><view data-event-opts="{{[['tap',[['alertClick',['$event']]]]]}}" class="alert_none data-v-5241567a" onTap="__e"></view><view class="alert_module data-v-5241567a"><view class="alert_opt data-v-5241567a"><view class="alert_table data-v-5241567a"><view class="{{((('alert_view')+' '+'data-v-5241567a')+' '+(filterType==0?'alert_active':''))}}" data-type="{{0}}" data-event-opts="{{[['tap',[['changefilterType',['$event']]]]]}}" catchTap="__e">课程</view><view class="{{((('alert_view')+' '+'data-v-5241567a')+' '+(filterType==1?'alert_active':''))}}" data-type="{{1}}" data-event-opts="{{[['tap',[['changefilterType',['$event']]]]]}}" catchTap="__e">时段</view></view><view data-event-opts="{{[['tap',[['filterClean',['$event']]]]]}}" class="alert_cancel data-v-5241567a" catchTap="__e">清空</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="alert_btn data-v-5241567a" catchTap="__e">确认</view></view><block a:if="{{filterType==0}}"><scroll-view class="alert_box data-v-5241567a" scroll-y="true"><view class="{{(((('alert_item')+' '+'')+' '+'data-v-5241567a')+' '+(cachecid==item.id?'alert_current':''))}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['changecid',['$event']]]]]}}" catchTap="__e" a:for="{{clist}}" a:for-item="item" a:for-index="index">{{item.name}}</view></scroll-view></block><block a:if="{{filterType==1}}"><scroll-view class="alert_box data-v-5241567a" scroll-y="true"><view class="{{(((('alert_item')+' '+'')+' '+'data-v-5241567a')+' '+(cachetimerange==index?'alert_current':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changetimerange',['$event']]]]]}}" catchTap="__e" a:for="{{timerangelist}}" a:for-item="item" a:for-index="index">{{item.rangestr}}</view></scroll-view></block></view></view></block></view></block>