<view><block><block a:if="{{isload}}"><view class="container nodiydata"><view class="bg-red" style="{{'background:'+($root.m0)+';'}}"></view><view class="topcontent"><view class="logo"><image class="img" src="{{info.headimg}}"></image></view><view class="title">{{info.realname+''}}<text style="{{'margin-left:10rpx;font-size:28rpx;'+('color:'+($root.m1)+';')}}">{{info.dengji||''}}</text></view><view class="desc">{{''+info.desc+''}}</view></view><block a:if="{{info.content}}"><view class="contentbox"><view class="cp_detail" style="padding:20rpx;"><parse vue-id="777f5a10-1" content="{{info.content}}" onVueInit="__l"></parse></view></view></block></view></block></block><block a:if="{{loading}}"><loading vue-id="777f5a10-2" onVueInit="__l"></loading></block><dp-tabbar vue-id="777f5a10-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="777f5a10-4" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>