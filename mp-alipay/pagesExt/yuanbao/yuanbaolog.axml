<view class="container"><block a:if="{{isload}}"><block><view class="myyuanbao" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{myyuanbao}}<block a:if="{{yuanbaoTransfer}}"><view class="btn-mini" data-url="/pagesExt/yuanbao/yuanbaoTransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">转账</view></block></view></view><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block a:if="{{item.yuanbao>0}}"><block><text class="t1">{{"+"+item.yuanbao}}</text></block></block><block a:else><block><text class="t2">{{item.yuanbao}}</text></block></block></view></view></block><block a:if="{{nodata}}"><nodata vue-id="d8f55d3a-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="d8f55d3a-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="d8f55d3a-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="d8f55d3a-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="d8f55d3a-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>