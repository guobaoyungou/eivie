<view class="container"><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" onSubmit="__e" onReset="formReset"><view class="form-item"><text class="label">退款原因</text><view class="input-item"><textarea placeholder="请输入退款原因" placeholder-style="color:#999;" name="reason"></textarea></view></view><button class="ref-btn" form-type="submit">确定</button></form><block a:if="{{loading}}"><loading vue-id="2f82a7c7-1" onVueInit="__l"></loading></block><dp-tabbar vue-id="2f82a7c7-2" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="2f82a7c7-3" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>