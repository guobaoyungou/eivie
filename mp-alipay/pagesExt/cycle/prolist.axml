<view class="container"><block a:if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e" onInput="__e"/></view><view data-event-opts="{{[['tap',[['searchbtn',['$event']]]]]}}" class="search-btn" onTap="__e"><block a:if="{{!history_show&&productlisttype=='itemlist'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-cascades.png'}}"></image></block><block a:if="{{!history_show&&productlisttype=='item2'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-list.png'}}"></image></block><block a:if="{{history_show}}"><text>搜索</text></block></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" onTap="__e"><image style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/del.png'}}"></image></view></view><view class="search-history-list"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" onTap="__e" a:for="{{history_list}}" a:for-item="item" a:for-index="index" a:key="index">{{item+''}}</view><block a:if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/tanhao.png'}}"></image>暂无记录</view></block></view></view><view hidden="{{!(!history_show)}}" class="search-navbar"><view class="search-navbar-item" style="{{(!field||field=='sort'?'color:'+$root.m0:'')}}" data-field="sort" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e">综合</view><view class="search-navbar-item" style="{{(field=='sales'?'color:'+$root.m1:'')}}" data-field="sales" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e">销量</view><view class="search-navbar-item" data-field="sell_price" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchTap="__e"><text style="{{(field=='sell_price'?'color:'+$root.m2:'')}}">价格</text><text class="iconfont iconshangla" style="{{(field=='sell_price'&&order=='asc'?'color:'+$root.m3:'')}}"></text><text class="iconfont icondaoxu" style="{{(field=='sell_price'&&order=='desc'?'color:'+$root.m4:'')}}"></text></view><view data-event-opts="{{[['tap',[['showDrawer',['showRight']]]]]}}" class="search-navbar-item flex-x-center flex-y-center" catchTap="__e">筛选<text class="{{('iconfont iconshaixuan '+(showfilter?'active':''))}}"></text></view></view><uni-drawer vue-id="27eb07be-1" mode="right" width="{{280}}" ref="__r" data-ref="showRight" data-event-opts="{{[['^change',[['change',['$event','showRight']]]]]}}" onChange="__e" onVueInit="__l"><view class="filter-scroll-view" style="max-height:100%;padding-bottom:110rpx;overflow:hidden auto;"><view class="filter-scroll-view-box"><view class="search-filter"><view class="filter-title">筛选</view><block a:if="{{!bid||bid<=0}}"><block><view class="filter-content-title">商品分类</view><view class="search-filter-content"><view class="filter-item" style="{{(catchecid==oldcid?'color:'+$root.m5+';background:rgba('+$root.m6+',0.1)':'')}}" data-cid="{{oldcid}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchTap="__e">全部</view><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="filter-item" style="{{(catchecid==item.$orig.id?'color:'+item.m7+';background:rgba('+item.m8+',0.1)':'')}}" data-cid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchTap="__e">{{item.$orig.name}}</view></block></view></block></block><block a:else><block><view class="filter-content-title">商品分类</view><view class="search-filter-content"><view class="filter-item" style="{{(catchecid2==oldcid2?'color:'+$root.m9+';background:rgba('+$root.m10+',0.1)':'')}}" data-cid2="{{oldcid2}}" data-event-opts="{{[['tap',[['cate2Click',['$event']]]]]}}" catchTap="__e">全部</view><block a:for="{{$root.l1}}" a:for-item="item" a:for-index="index" a:key="index"><view class="filter-item" style="{{(catchecid2==item.$orig.id?'color:'+item.m11+';background:rgba('+item.m12+',0.1)':'')}}" data-cid2="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cate2Click',['$event']]]]]}}" catchTap="__e">{{item.$orig.name}}</view></block></view></block></block><block a:for="{{$root.l3}}" a:for-item="item" a:for-index="index"><view class="filter-content-title">{{item.$orig.name}}</view><view class="search-filter-content"><view class="filter-item" style="{{(catcheparams[item.$orig.name]==''?'color:'+item.m13+';background:rgba('+item.m14+',0.1)':'')}}" data-paramkey="{{item.$orig.name}}" data-paramval data-event-opts="{{[['tap',[['paramClick',['$event']]]]]}}" catchTap="__e">全部</view><block a:for="{{item.l2}}" a:for-item="item2" a:for-index="index" a:key="index"><view class="filter-item" style="{{(catcheparams[item.$orig.name]==item2.$orig?'color:'+item2.m15+';background:rgba('+item2.m16+',0.1)':'')}}" data-paramkey="{{item.$orig.name}}" data-paramval="{{item2.$orig}}" data-event-opts="{{[['tap',[['paramClick',['$event']]]]]}}" catchTap="__e">{{item2.$orig}}</view></block></view></block><view class="search-filter-btn"><view data-event-opts="{{[['tap',[['filterReset',['$event']]]]]}}" class="btn" onTap="__e">重置</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="btn2" style="{{'background:'+($root.m17)+';'}}" onTap="__e">确定</view></view></view></view></view></uni-drawer></view><view class="product-container"><block a:if="{{datalist&&datalist.length>0}}"><block><block a:if="{{productlisttype=='item2'}}"><dp-cycle-item vue-id="27eb07be-2" data="{{datalist}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-cycle-item></block><block a:if="{{productlisttype=='itemlist'}}"><dp-cycle-itemlist vue-id="27eb07be-3" data="{{datalist}}" menuindex="{{menuindex}}" onVueInit="__l"></dp-cycle-itemlist></block></block></block><block a:if="{{nomore}}"><nomore vue-id="27eb07be-4" text="没有更多商品了" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="27eb07be-5" text="没有查找到相关商品" onVueInit="__l"></nodata></block><block a:if="{{loading}}"><loading vue-id="27eb07be-6" onVueInit="__l"></loading></block></view></block></block><view style="display:none;">{{test}}</view><block a:if="{{loading}}"><loading vue-id="27eb07be-7" onVueInit="__l"></loading></block><dp-tabbar vue-id="27eb07be-8" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" onGetmenuindex="__e" onVueInit="__l"></dp-tabbar><popmsg vue-id="27eb07be-9" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg><wxxieyi vue-id="27eb07be-10" onVueInit="__l"></wxxieyi></view>