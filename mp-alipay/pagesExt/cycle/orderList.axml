<view class="container"><block a:if="{{isload}}"><block><dd-tab vue-id="786472dd-1" itemdata="{{['全部','待付款','待发货','已发货','已完成','退款']}}" itemst="{{['all','0','1','2','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" onChangetab="__e" onVueInit="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" onConfirm="__e"/></view></view><view class="order-content"><block a:for="{{$root.l0}}" a:for-item="item" a:for-index="index" a:key="index"><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><view class="head"><text class="flex1">{{"订单号："+item.$orig.ordernum}}</text><block a:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block a:if="{{item.$orig.status==1}}"><block><block><block a:if="{{item.$orig.freight_type!=1}}"><text class="st1">待发货</text></block><block a:if="{{item.$orig.freight_type==1}}"><text class="st1">待取货</text></block></block></block></block><block a:if="{{item.$orig.status==2&&item.$orig.freight_type==1}}"><text class="st2">已取货</text></block><block a:if="{{item.$orig.status==2&&(item.$orig.freight_type==2||item.$orig.freight_type==0)}}"><text class="st2">已发货</text></block><block a:if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block a:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e"><image src="{{item.$orig.propic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.proname}}</text><text class="t2">{{item.$orig.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item.$orig.sell_price}}</text><text class="x2">{{"×"+item.$orig.qsnum+"期"}}</text></view></view></view><view class="bottom"><text>{{"共"+item.$orig.qsnum+"期，每期"+item.$orig.num+"件商品 实付:￥"+item.$orig.totalprice+''}}</text><block a:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block a:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><block a:if="{{item.g0}}"><block><view class="btn2" data-url="{{'/pagesExt/order/invoice?type=collage&orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">发票</view></block></block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" onTap="__e">详情</view><block a:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchTap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去付款</view></block></block><block a:if="{{item.$orig.status==1}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toCycleList',['$event']]]]]}}" onTap="__e">配送周期</view></block></block><block a:if="{{item.$orig.status==2}}"><block><block a:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toCycleList',['$event']]]]]}}" onTap="__e">配送周期</view></block></block><block a:if="{{item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchTap="__e">删除订单</view></block></block></view></view></block></view><block a:if="{{nomore}}"><nomore vue-id="786472dd-2" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="786472dd-3" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="786472dd-4" onVueInit="__l"></loading></block><dp-tabbar vue-id="786472dd-5" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="786472dd-6" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>