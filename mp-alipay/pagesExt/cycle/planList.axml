<view class="data-v-36660ca6"><block a:if="{{isload}}"><view class="page data-v-36660ca6"><view class="body data-v-36660ca6"><block a:if="{{state=='2'}}"><view class="body_progress data-v-36660ca6"><view class="data-v-36660ca6" a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{index==0}}"><view class="{{(('data-v-36660ca6')+' '+(item.status==2?'progress_active':''))}}"><view class="progress_tag data-v-36660ca6"></view></view></block><block a:if="{{index!=0}}"><view class="{{(('data-v-36660ca6')+' '+(item.status==2?'progress_active':''))}}"><view class="progress_line data-v-36660ca6"></view><view class="progress_tag data-v-36660ca6"></view></view></block></view></view></block><block a:if="{{state=='1'}}"><view class="body_progress data-v-36660ca6"><view class="data-v-36660ca6" a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{index==0}}"><view class="data-v-36660ca6"><view class="progressC_tag data-v-36660ca6"></view></view></block><block a:if="{{index!=0}}"><view class="data-v-36660ca6"><view class="progressC_line data-v-36660ca6"></view><view class="progressC_tag data-v-36660ca6"></view></view></block></view></view></block><view class="body_module data-v-36660ca6"><block a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{state=='2'}}"><view class="{{((('body_list')+' '+'data-v-36660ca6')+' '+(item.status==2?'list_active':item.status==3?'collect_active':''))}}"><view class="body_data data-v-36660ca6"><view class="body_title data-v-36660ca6" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" catchTap="__e">{{item.title}}<image class="body_icon _img data-v-36660ca6" src="{{pre_url+'/static/img/week/week_detail.png'}}" alt></image></view><block a:if="{{detail.freight_type==0||detail.freight_type==2}}"><view class="body_text data-v-36660ca6">{{"配送日:\n\t\t\t\t\t\t\t"+item.cycle_date}}</view></block><block a:else><block a:if="{{detail.freight_type==1}}"><view class="body_text data-v-36660ca6">{{"取货日: "+item.cycle_date}}</view></block></block></view><view class="body_state data-v-36660ca6">{{''+(item.status==0?'待支付':item.status==1&&detail.freight_type==2?'待配送':item.status==1&&detail.freight_type==0?'待发货':item.status==2&&detail.freight_type==2?'配送中':item.status==2&&detail.freight_type==0?'已发货':item.status==1&&detail.freight_type==1?'待取货':'已完成')+''}}</view></view></block></block><block a:for="{{dataList}}" a:for-item="item" a:for-index="index" a:key="index"><block a:if="{{state=='1'}}"><view class="{{(((('body_item')+' '+'flex-bt')+' '+'data-v-36660ca6')+' '+(item.status==2?'list_active':item.status==3?'collect_active':''))}}"><text class="data-v-36660ca6">{{item.title}}</text><text class="data-v-36660ca6">{{item.cycle_date}}</text></view></block></block></view></view></view></block></view>