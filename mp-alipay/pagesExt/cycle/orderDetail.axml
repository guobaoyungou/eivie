<block a:if="{{isload}}"><view class="data-v-051a4343"><block a:if="{{detail.refund_status==1||detail.refund_status==1}}"><view class="banner data-v-051a4343"><image class="banner_img _img data-v-051a4343" src="{{pre_url+'/static/img/week/week_banner.png'}}" alt></image><image class="banner_icon _img data-v-051a4343" src="{{pre_url+'/static/img/week/week_icon.png'}}" alt></image><block a:if="{{detail.refund_status==1}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343">退款中</view><view class="banner_text data-v-051a4343">等待平台审核中</view></view></block><block a:if="{{detail.refund_status==2}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343">退款成功</view><view class="banner_text data-v-051a4343">审核通过，已退款</view></view></block></view></block><block a:else><view class="banner data-v-051a4343"><image class="banner_img _img data-v-051a4343" src="{{pre_url+'/static/img/week/week_banner.png'}}" alt></image><image class="banner_icon _img data-v-051a4343" src="{{pre_url+'/static/img/week/week_icon.png'}}" alt></image><block a:if="{{detail.status==0}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343">待支付</view></view></block><block a:if="{{detail.status==1}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343"><block a:if="{{detail.freight_type==1}}"><text class="data-v-051a4343">待取货</text></block><block a:else><text class="data-v-051a4343">待发货</text></block></view><view class="banner_text data-v-051a4343"><view class="t1 data-v-051a4343">{{(detail.paytype=='货到付款'?'已选择'+codtxt:'已成功付款')+''}}<block a:if="{{detail.freight_type!=1}}"><text class="data-v-051a4343">，我们会尽快为您配送</text></block></view></view></view></block><block a:if="{{detail.status==2}}"><view class="banner_data data-v-051a4343"><block a:if="{{detail.freight_type==1}}"><view class="banner_title data-v-051a4343">已取货</view></block><block a:else><view class="banner_title data-v-051a4343">已发货</view></block><block a:if="{{detail.status==0}}"><view class="banner_text data-v-051a4343">具体发货信息请查看每期订单</view></block></view></block><block a:if="{{detail.status==3}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343">已完成</view></view></block><block a:if="{{detail.status==4}}"><view class="banner_data data-v-051a4343"><view class="banner_title data-v-051a4343">已关闭</view></view></block></view></block><view class="body data-v-051a4343"><view class="address data-v-051a4343"><view class="img data-v-051a4343"><image src="{{pre_url+'/static/img/address3.png'}}" class="data-v-051a4343"></image></view><view class="info data-v-051a4343"><text class="t1 data-v-051a4343" user-select="true" selectable="true">{{detail.linkman+" "+detail.tel}}</text><block a:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2 data-v-051a4343" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block a:if="{{detail.freight_type==1}}"><text class="t2 data-v-051a4343" data-storeinfo="{{storeinfo}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" onTap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address+''}}</text></block></view></view><view class="body_module data-v-051a4343"><image class="body_img _img data-v-051a4343" src="{{detail.propic}}" alt></image><view class="body_data data-v-051a4343"><view class="body_name data-v-051a4343">{{''+detail.proname+''}}</view><view class="body_text data-v-051a4343">{{''+detail.ggname+" | "+detail.pspl}}<block a:if="{{detail.every_day}}"><text class="data-v-051a4343">{{","+detail.every_day}}</text></block></view><view class="body_price flex flex-bt flex-y-bottom data-v-051a4343"><text class="data-v-051a4343">{{"￥"+detail.sell_price}}</text></view></view></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">订单号</text><text class="data-v-051a4343">{{detail.ordernum}}</text></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">下单时间</text><text class="data-v-051a4343">{{detail.createtime}}</text></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">配送期数</text><text class="data-v-051a4343">{{"共 "+detail.qsnum+" 期"}}</text></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">每期数量</text><text class="data-v-051a4343">{{"共 "+detail.num+" 件"}}</text></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">配送计划</text><block a:if="{{detail.status==4}}"><view class="body_time data-v-051a4343"><view class="data-v-051a4343">{{detail.start_date+"起"}}<block a:if="{{detail.every_day}}"><text style="margin-left:10rpx;" class="data-v-051a4343">{{detail.every_day}}</text></block><block a:else><text style="margin-left:10rpx;" class="data-v-051a4343">{{detail.pspl}}</text></block></view></view></block><block a:else><view class="body_time data-v-051a4343" data-url="{{'/pagesExt/cycle/planList?id='+detail.id}}" data-event-opts="{{[['tap',[['toPlanDetail',['$event']]]]]}}" onTap="__e"><view class="data-v-051a4343">{{detail.start_date+"起"}}<block a:if="{{detail.every_day}}"><text style="margin-left:10rpx;" class="data-v-051a4343">{{detail.every_day}}</text></block><block a:else><text style="margin-left:10rpx;" class="data-v-051a4343">{{detail.pspl}}</text></block></view><image src="{{pre_url+'/static/img/week/week_detail.png'}}" alt class="_img data-v-051a4343"></image></view></block></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">配送方式</text><text class="data-v-051a4343">{{detail.freight_text}}</text></view><view class="body_list data-v-051a4343"><text class="data-v-051a4343">商品总金额</text><text class="body_color data-v-051a4343">{{"￥"+detail.product_price}}</text></view><block a:if="{{detail.leveldk_money>0}}"><view class="body_list data-v-051a4343"><text class="data-v-051a4343">会员折扣</text><text class="body_color data-v-051a4343">{{"-￥"+detail.leveldk_money}}</text></view></block><block a:if="{{detail.coupon_money>0}}"><view class="body_list data-v-051a4343"><text class="data-v-051a4343">优惠券抵扣</text><text class="body_color data-v-051a4343">{{"-￥"+detail.coupon_money}}</text></view></block><view class="body_list data-v-051a4343"><text class="data-v-051a4343">实付金额</text><text class="body_color data-v-051a4343">{{"￥"+detail.totalprice}}</text></view><block a:if="{{detail.status==4}}"><view class="body_list data-v-051a4343"><text class="data-v-051a4343">订单状态</text><text class="data-v-051a4343">已关闭</text></view></block><block a:if="{{detail.refund_status>0}}"><view class="body_list data-v-051a4343"><text class="t1 data-v-051a4343">退款状态</text><block a:if="{{detail.refund_status==1}}"><text class="t2 body_color data-v-051a4343">{{"审核中,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==2}}"><text class="t2 body_color data-v-051a4343">{{"已退款,¥"+detail.refund_money}}</text></block><block a:if="{{detail.refund_status==3}}"><text class="t2 body_color data-v-051a4343">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block a:if="{{detail.formdata.length>0}}"><view class="orderinfo data-v-051a4343"><view class="item data-v-051a4343" a:for="{{detail.formdata}}" a:for-item="item" a:for-index="__i0__" a:key="*this"><text class="t1 data-v-051a4343">{{item[0]}}</text><block a:if="{{item[2]=='upload'}}"><view class="t2 data-v-051a4343"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" onTap="__e" class="data-v-051a4343"></image></view></block><block a:else><text class="t2 data-v-051a4343" user-select="true" selectable="true">{{item[1]}}</text></block></view></view></block></view><block a:if="{{detail.refund_status!=1}}"><view class="opt data-v-051a4343"><view class="opt_module data-v-051a4343"><block a:if="{{detail.status==0}}"><view class="opt_btn data-v-051a4343" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" onTap="__e">关闭订单</view></block><block a:if="{{detail.status==0}}"><view class="opt_btn data-v-051a4343" style="background:#FF9900;color:#fff;border:none;" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" onTap="__e">去支付</view></block><block a:if="{{detail.status==4}}"><view class="opt_btn data-v-051a4343" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" onTap="__e">删除订单</view></block><block a:if="{{detail.status==3&&detail.iscomment==0&&shopset.comment==1}}"><view class="opt_btn data-v-051a4343" data-url="{{'comment?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">去评价</view></block><block a:if="{{detail.status==3&&detail.iscomment==1}}"><view class="opt_btn data-v-051a4343" data-url="{{'comment?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">查看评价</view></block><block a:if="{{(detail.status==1||detail.status==2)&&(detail.refund_status==3||detail.refund_status==0)}}"><view class="flex flex-x-bottom data-v-051a4343" style="width:100%;"><view class="opt_btn data-v-051a4343" data-url="{{'refund?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchTap="__e">申请退款</view></view></block></view></view></block></view></block>