<view class="container"><block a:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+type_name}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{money}}</view></view><view class="content"><view class="item" a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block a:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block a:else><text class="t2">{{item.money}}</text></block></view></view></view><block a:if="{{nomore}}"><nomore vue-id="f681eaf8-1" onVueInit="__l"></nomore></block><block a:if="{{nodata}}"><nodata vue-id="f681eaf8-2" onVueInit="__l"></nodata></block></block></block><block a:if="{{loading}}"><loading vue-id="f681eaf8-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="f681eaf8-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="f681eaf8-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>