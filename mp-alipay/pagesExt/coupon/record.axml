<view class="container"><block a:if="{{isload}}"><block><view class="content" id="datalist"><block a:for="{{datalist}}" a:for-item="item" a:for-index="index" a:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view></view></block><block a:if="{{nodata}}"><nodata vue-id="33921106-1" onVueInit="__l"></nodata></block></view><block a:if="{{nomore}}"><nomore vue-id="33921106-2" onVueInit="__l"></nomore></block></block></block><block a:if="{{loading}}"><loading vue-id="33921106-3" onVueInit="__l"></loading></block><dp-tabbar vue-id="33921106-4" opt="{{opt}}" onVueInit="__l"></dp-tabbar><popmsg vue-id="33921106-5" ref="__r" data-ref="popmsg" onVueInit="__l"></popmsg></view>