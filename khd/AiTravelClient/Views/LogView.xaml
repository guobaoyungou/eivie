<UserControl x:Class="AiTravelClient.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AiTravelClient.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">
    
    <UserControl.Resources>
        <converters:LogLevelToColorConverter x:Key="LogLevelToColor"/>
        <converters:LogLevelToTextConverter x:Key="LogLevelToText"/>
    </UserControl.Resources>
    
    <Grid Margin="{StaticResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="系统日志" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,20"/>
        
        <!-- 工具栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：过滤器 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="日志级别：" 
                              VerticalAlignment="Center" 
                              Margin="0,0,10,0"
                              Style="{StaticResource BodyTextStyle}"/>
                    
                    <ComboBox ItemsSource="{Binding LogLevels}"
                             SelectedItem="{Binding SelectedLogLevel}"
                             Width="120"
                             VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource LogLevelToText}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="搜索：" 
                              VerticalAlignment="Center" 
                              Margin="20,0,10,0"
                              Style="{StaticResource BodyTextStyle}"/>
                    
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                            Width="200"
                            VerticalAlignment="Center"
                            Style="{StaticResource StandardTextBoxStyle}"/>
                </StackPanel>
                
                <!-- 右侧：操作按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <CheckBox Content="自动滚动" 
                             IsChecked="{Binding AutoScroll}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                    
                    <Button Content="刷新" 
                           Command="{Binding RefreshLogsCommand}"
                           Style="{StaticResource TextButtonStyle}"/>
                    
                    <Button Content="清空" 
                           Command="{Binding ClearLogsCommand}"
                           Style="{StaticResource TextButtonStyle}"/>
                    
                    <Button Content="导出" 
                           Command="{Binding ExportLogsCommand}"
                           Style="{StaticResource TextButtonStyle}"/>
                    
                    <Button Content="打开文件夹" 
                           Command="{Binding OpenLogFolderCommand}"
                           Style="{StaticResource TextButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 日志列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <ListView ItemsSource="{Binding FilteredLogItems}"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="时间" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FormattedTime}" 
                                              FontSize="{StaticResource FontSizeSmall}"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="级别" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding LevelIcon}" 
                                                  FontSize="14" 
                                                  Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding LevelText}" 
                                                  FontSize="{StaticResource FontSizeSmall}"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding Level, Converter={StaticResource LogLevelToColor}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="消息" Width="650">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}" 
                                              TextWrapping="Wrap"
                                              FontSize="{StaticResource FontSizeSmall}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="WARN">
                                <Setter Property="Background" Value="#FFF3E0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="INFO">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>
    </Grid>
</UserControl>
