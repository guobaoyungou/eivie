<UserControl x:Class="AiTravelClient.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PageMargin}" HorizontalAlignment="Center" MaxWidth="600">
            <!-- Logo区域 -->
            <Border Background="White" 
                   Width="128" Height="128" 
                   CornerRadius="64"
                   Margin="0,40,0,30"
                   HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" 
                                    ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>
                <TextBlock Text="📷" 
                          FontSize="64" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
            </Border>
            
            <!-- 应用信息 -->
            <TextBlock Text="{Binding AppName}" 
                      Style="{StaticResource TitleTextStyle}"
                      TextAlignment="Center"
                      Margin="0,0,0,10"/>
            
            <TextBlock Text="{Binding AppVersion}" 
                      Style="{StaticResource SubtitleTextStyle}"
                      TextAlignment="Center"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,0,0,5"/>
            
            <TextBlock Text="{Binding Copyright}" 
                      Style="{StaticResource SecondaryTextStyle}"
                      TextAlignment="Center"
                      Margin="0,0,0,40"/>
            
            <!-- 系统信息卡片 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="系统信息" 
                              Style="{StaticResource SubtitleTextStyle}"
                              Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="设备ID：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceId}" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="操作系统：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding OSVersion}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text=".NET版本：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DotNetVersion}" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="CPU：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CpuInfo}" Style="{StaticResource BodyTextStyle}" TextWrapping="Wrap"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="内存：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding MemorySize}" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="运行时长：" Style="{StaticResource BodyTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding RunningTime}" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- 操作按钮 -->
            <StackPanel>
                <Button Content="复制设备ID" 
                       Command="{Binding CopyDeviceIdCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,10"/>
                
                <Button Content="检查更新" 
                       Command="{Binding CheckUpdateCommand}"
                       Style="{StaticResource PrimaryButtonStyle}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,10"/>
                
                <Button Content="查看许可协议" 
                       Command="{Binding ViewLicenseCommand}"
                       Style="{StaticResource TextButtonStyle}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,10"/>
                
                <Button Content="技术支持" 
                       Command="{Binding OpenSupportUrlCommand}"
                       Style="{StaticResource TextButtonStyle}"
                       HorizontalAlignment="Stretch"/>
            </StackPanel>
            
            <!-- 底部公司信息 -->
            <TextBlock Text="{Binding CompanyName}" 
                      Style="{StaticResource SecondaryTextStyle}"
                      TextAlignment="Center"
                      Margin="0,40,0,40"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
