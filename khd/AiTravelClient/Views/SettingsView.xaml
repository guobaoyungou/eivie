<UserControl x:Class="AiTravelClient.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="{StaticResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="系统设置" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,20"/>
        
        <!-- 选项卡内容 -->
        <TabControl Grid.Row="1">
            <!-- 服务器配置 -->
            <TabItem Header="服务器配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="API服务器地址" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <TextBlock Text="请求超时时间（秒）" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding Timeout}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <TextBlock Text="网络重试次数" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding RetryTimes}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <Button Content="测试连接" 
                               Command="{Binding TestConnectionCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               HorizontalAlignment="Left"
                               Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 设备配置 -->
            <TabItem Header="设备配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="设备ID（只读）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding DeviceId}" 
                                IsReadOnly="True"
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <TextBlock Text="设备名称" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding DeviceName}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <TextBlock Text="设备编码" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding DeviceCode}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="应用ID" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Aid}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="5,0">
                                <TextBlock Text="商家ID" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Bid}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="门店ID" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Mdid}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="注册设备" 
                                   Command="{Binding RegisterDeviceCommand}"
                                   Style="{StaticResource SuccessButtonStyle}"/>
                            
                            <Button Content="注销设备" 
                                   Command="{Binding UnregisterDeviceCommand}"
                                   Style="{StaticResource DangerButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 监控配置 -->
            <TabItem Header="监控配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="监控路径列表" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="添加路径" 
                                       Command="{Binding AddWatchPathCommand}"
                                       Style="{StaticResource PrimaryButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                        
                        <ListBox ItemsSource="{Binding WatchPaths}" 
                                Height="150"
                                Margin="0,10,0,0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" 
                                               Content="移除"
                                               Command="{Binding DataContext.RemoveWatchPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource TextButtonStyle}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="轮询间隔（秒）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ScanInterval}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="文件稳定时间（秒）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FileStableTime}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                        
                        <TextBlock Text="允许的扩展名（逗号分隔）" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding AllowedExtensions}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                        
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="最小文件大小（KB）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MinFileSize}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="最大文件大小（MB）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MaxFileSize}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 上传配置 -->
            <TabItem Header="上传配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="并发上传数" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ConcurrentUploads}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="最大队列长度" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MaxQueueSize}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                        
                        <CheckBox Content="自动上传" 
                                 IsChecked="{Binding AutoUpload}"
                                 Margin="0,15,0,0"
                                 FontSize="{StaticResource FontSizeNormal}"/>
                        
                        <TextBlock Text="最大重试次数" Style="{StaticResource BodyTextStyle}" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding MaxRetry}" 
                                Style="{StaticResource StandardTextBoxStyle}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 心跳配置 -->
            <TabItem Header="心跳配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="心跳间隔（秒）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding HeartbeatInterval}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="心跳超时（秒）" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding HeartbeatTimeout}" Style="{StaticResource StandardTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- 底部按钮栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="保存配置" 
                   Command="{Binding SaveConfigCommand}"
                   Style="{StaticResource PrimaryButtonStyle}"/>
            
            <Button Content="重置配置" 
                   Command="{Binding ResetConfigCommand}"
                   Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
        
        <!-- 错误提示 -->
        <TextBlock Grid.Row="2" 
                  Text="{Binding ErrorMessage}"
                  Foreground="{StaticResource ErrorBrush}"
                  FontSize="{StaticResource FontSizeSmall}"
                  Margin="0,10,0,0"
                  TextWrapping="Wrap"
                  Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</UserControl>
