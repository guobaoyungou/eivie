<!DOCTYPE html>
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>场景编辑</title>
  <meta name="renderer" content="webkit">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=0">
  {include file="public/css"/}
  <style>
  .layui-imgbox .layui-imgbox-close{z-index: 6;}
  </style>
</head>
<body>
  <div class="layui-fluid">
    <div class="layui-row layui-col-space15">
      <div class="layui-card layui-col-md12">
        <div class="layui-card-header">
          {if empty($info['id'])}<i class="fa fa-plus"></i> 添加场景{else}<i class="fa fa-pencil"></i> 编辑场景{/if}
          <i class="layui-icon layui-icon-close" style="font-size:18px;font-weight:bold;cursor:pointer;float:right;" onclick="closeself()"></i>
        </div>
        <div class="layui-card-body" pad15>
          <div class="layui-form form-label-w7" lay-filter="">
            <input type="hidden" name="id" value="{$info.id|default='0'}">
            
            <div class="layui-form-item">
              <label class="layui-form-label">场景名称：</label>
              <div class="layui-input-inline" style="width: 400px;">
                <input type="text" name="name" value="{$info.name|default=''}" lay-verify="required" lay-verType="tips" autocomplete="off" class="layui-input" placeholder="请输入场景名称">
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">场景分类：</label>
              <div class="layui-input-inline">
                <select name="category" lay-verify="required">
                  <option value="">请选择分类</option>
                  <option value="风景" {if $info.category=='风景'}selected{/if}>风景</option>
                  <option value="人物" {if $info.category=='人物'}selected{/if}>人物</option>
                  <option value="创意" {if $info.category=='创意'}selected{/if}>创意</option>
                  <option value="节日" {if $info.category=='节日'}selected{/if}>节日</option>
                  <option value="古风" {if $info.category=='古风'}selected{/if}>古风</option>
                  <option value="现代" {if $info.category=='现代'}selected{/if}>现代</option>
                </select>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">封面图：</label>
              <button style="float:left;" type="button" class="layui-btn layui-btn-primary" upload-input="cover" upload-preview="coverPreview" onclick="uploader(this)">上传图片</button>
              <div class="layui-form-mid layui-word-aux" style="margin-left:10px;">建议尺寸：400×400像素</div>
              <div id="coverPreview" class="picsList-class-padding">
                <div class="layui-imgbox imgbox-required">
                  <a {if $info.cover}style="display: block;"{else}style="display: none;"{/if} class="layui-imgbox-close" href="javascript:void(0)" onclick="$(this).parent().find('img').attr('src','').hide();getpicsval('cover','coverPreview');$(this).hide();" title="删除"><i class="layui-icon layui-icon-close-fill-opaque"></i></a>
                  <div class="layui-imgbox">
                    <div class="layui-imgbox-img">
                      <img src="{$info.cover}"/>
                    </div>
                    <input autocomplete='off' type="text" id="cover" name="cover" value="{$info.cover}" lay-verify="required" style="cursor:default;">
                  </div>
                </div>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">背景图：</label>
              <button style="float:left;" type="button" class="layui-btn layui-btn-primary" upload-input="background_url" upload-preview="backgroundPreview" onclick="uploader(this)">上传图片</button>
              <div class="layui-form-mid layui-word-aux" style="margin-left:10px;">建议尺寸：1920×1080像素</div>
              <div id="backgroundPreview" class="picsList-class-padding">
                <div class="layui-imgbox imgbox-required">
                  <a {if $info.background_url}style="display: block;"{else}style="display: none;"{/if} class="layui-imgbox-close" href="javascript:void(0)" onclick="$(this).parent().find('img').attr('src','').hide();getpicsval('background_url','backgroundPreview');$(this).hide();" title="删除"><i class="layui-icon layui-icon-close-fill-opaque"></i></a>
                  <div class="layui-imgbox">
                    <div class="layui-imgbox-img">
                      <img src="{$info.background_url}"/>
                    </div>
                    <input autocomplete='off' type="text" id="background_url" name="background_url" value="{$info.background_url}" lay-verify="required" style="cursor:default;">
                  </div>
                </div>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">场景描述：</label>
              <div class="layui-input-block" style="width: 600px;">
                <textarea name="desc" placeholder="请输入场景描述（选填）" class="layui-textarea" style="min-height: 80px;">{$info.desc}</textarea>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">提示词（中文）：</label>
              <div class="layui-input-block" style="width: 600px;">
                <textarea name="prompt" placeholder="请输入AI生成的提示词（必填）" lay-verify="required" class="layui-textarea" style="min-height: 100px;">{$info.prompt}</textarea>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">提示词（英文）：</label>
              <div class="layui-input-block" style="width: 600px;">
                <textarea name="prompt_en" placeholder="请输入英文提示词（选填）" class="layui-textarea" style="min-height: 100px;">{$info.prompt_en}</textarea>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">负面提示词：</label>
              <div class="layui-input-block" style="width: 600px;">
                <textarea name="negative_prompt" placeholder="请输入负面提示词，排除不想要的元素（选填）" class="layui-textarea" style="min-height: 80px;">{$info.negative_prompt}</textarea>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">视频提示词：</label>
              <div class="layui-input-block" style="width: 600px;">
                <textarea name="video_prompt" placeholder="请输入图生视频专用提示词（选填）" class="layui-textarea" style="min-height: 80px;">{$info.video_prompt}</textarea>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">AI模型：</label>
              <div class="layui-input-inline">
                <select name="model_id">
                  <option value="">请选择AI模型</option>
                  {volist name="models" id="model"}
                  <option value="{$model.id}" {if isset($info.model_id) AND $info.model_id==$model.id}selected{/if}>{$model.name|default="未命名模型"}</option>
                  {/volist}
                </select>
              </div>
              <div class="layui-form-mid layui-word-aux">如无可选模型，请先在AI模型管理中添加</div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">宽高比：</label>
              <div class="layui-input-inline">
                <input type="radio" name="aspect_ratio" value="1:1" title="1:1" {if empty($info.aspect_ratio) OR $info.aspect_ratio=='1:1'}checked{/if}>
                <input type="radio" name="aspect_ratio" value="3:4" title="3:4" {if isset($info.aspect_ratio) AND $info.aspect_ratio=='3:4'}checked{/if}>
                <input type="radio" name="aspect_ratio" value="16:9" title="16:9" {if isset($info.aspect_ratio) AND $info.aspect_ratio=='16:9'}checked{/if}>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">排序权重：</label>
              <div class="layui-input-inline">
                <input type="text" name="sort" value="{$info.sort|default='0'}" lay-verify="number" class="layui-input" placeholder="数字越大越靠前">
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">标签：</label>
              <div class="layui-input-inline" style="width: 400px;">
                <input type="text" name="tags" value="{$info.tags}" class="layui-input" placeholder="多个标签用逗号分隔">
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">是否启用：</label>
              <div class="layui-input-inline">
                <input type="radio" name="status" value="1" title="启用" {if $info['status']==1 OR empty($info['id'])}checked{/if}>
                <input type="radio" name="status" value="0" title="禁用" {if isset($info['id']) AND $info['id']>0 AND $info['status']==0}checked{/if}>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">是否公共场景：</label>
              <div class="layui-input-inline">
                <input type="checkbox" name="is_public" value="1" lay-skin="switch" lay-text="是|否" {if $info.is_public==1}checked{/if}>
              </div>
            </div>
            
            <div class="layui-form-item">
              <label class="layui-form-label">是否推荐：</label>
              <div class="layui-input-inline">
                <input type="checkbox" name="is_recommend" value="1" lay-skin="switch" lay-text="是|否" {if $info.is_recommend==1}checked{/if}>
              </div>
            </div>
            
            <div class="layui-form-item">
              <div class="layui-input-block" style="margin-left:130px;">
                <button class="layui-btn" lay-submit lay-filter="formsubmit">提 交</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {include file="public/js"/}
  <script>
  layui.form.on('submit(formsubmit)', function(obj){
    var field = obj.field;
    var index = layer.load();
    $.post("{:url('scene_edit')}", field, function(data){
      layer.close(index);
      dialog(data.msg, data.status);
      if(data.status == 1){
        setTimeout(function(){
          parent.layer.closeAll();
          parent.tableIns.reload();
        }, 1000)
      }
    })
    return false;
  })
  </script>
  {include file="public/copyright"/}
</body>
</html>