<view class="container"><block qq:if="{{isload}}"><block><view class="search-container" data-url="{{'/carhailing/prolist?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商品</view></view></view><view class="order-tab"><view class="order-tab2"><block qq:for="{{clist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="{{['item '+(curTopIndex==index?'on':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view></block></block></view></view><view class="content-container"><view class="nav_left"><view class="{{['nav_left_items '+(curIndex==-1?'active':'')]}}" style="{{'color:'+(curIndex==-1?$root.m1:'#333')+';'}}" data-index="-1" data-id="{{clist[curTopIndex].id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m2)+';'}}"></view>全部</view><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index2" qq:key="index2"><block><view class="{{['nav_left_items '+(curIndex==index2?'active':'')]}}" style="{{'color:'+(curIndex==index2?item.m3:'#333')+';'}}" data-index="{{index2}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m4)+';'}}"></view>{{item.$orig.name}}</view></block></block></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><view class="product-itemlist module"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="item"><view class="module_data" data-url="{{'product?id='+item.id+''}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="module_img" src="{{item.pic}}" alt></image><view class="module_content"><view class="module_title">{{item.name}}</view><block qq:if="{{item.cid!=2}}"><view class="module_item"><block qq:if="{{item.cid==1}}"><text>租车</text></block><block qq:else><text>包车</text></block>费用：<text class="txt-yel">{{"￥"+item.sell_price+" /天"}}</text></view></block><block qq:else><view class="module_item">拼车费用：<text class="txt-yel">{{"￥"+item.sell_price+" /人"}}</text></view></block></view></view></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="51fac56d-1" text="没有更多商品了" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="51fac56d-2" text="没有查找到相关商品" bind:__l="__l"></nodata></block></scroll-view></view></view></view></block></block><block qq:if="{{buydialogShow}}"><buydialog vue-id="51fac56d-3" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e" bind:__l="__l"></buydialog></block><block qq:if="{{showLinkStatus}}"><view class="posterDialog linkDialog"><view class="main"><view data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><view class="title">{{lx_name}}</view><block qq:if="{{lx_bid>0}}"><view class="row"><view class="f1">店铺名称</view><view class="f2" data-url="{{'/pagesExt/business/index?id='+lx_bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{lx_bname}}<image class="image" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block qq:if="{{lx_tel}}"><view class="row"><view class="f1">联系电话</view><view class="f2" style="{{'color:'+($root.m5)+';'}}" data-url="{{'tel::'+lx_tel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{lx_tel}}<image class="copyicon" src="{{pre_url+'/static/img/copy.png'}}" data-text="{{lx_tel}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" catchtap="__e"></image></view></view></block></view></view></view></block><block qq:if="{{loading}}"><loading vue-id="51fac56d-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="51fac56d-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="51fac56d-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>