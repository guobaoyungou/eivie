<view class="container"><block qq:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+type_name}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{money}}</view></view><view class="content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block qq:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block qq:else><text class="t2">{{item.money}}</text></block></view></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="dea8e4bc-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="dea8e4bc-2" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="dea8e4bc-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="dea8e4bc-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="dea8e4bc-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>