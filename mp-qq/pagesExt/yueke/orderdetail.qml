{'/pagesExt/pay/pay?id='+detail.balance_pay_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">支付尾款</view></block></block></block><block qq:if="{{detail.status==3||detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除订单</view></block></block><block qq:if="{{detail.product&&detail.product.yuyue_model==2}}"><block><view class="btn2" data-url="{{'/pagesB/yueke/studyrecord?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">学习记录</view></block></block></view></block></block><block qq:if="{{loading}}"><loading vue-id="574d8af9-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="574d8af9-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="574d8af9-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>