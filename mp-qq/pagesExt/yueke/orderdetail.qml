<view class="container"><block qq:if="{{isload}}"><block><view class="ordertop flex" style="{{('background:url('+pre_url+'/static/img/orderbg.png);background-size:100%')}}"><block qq:if="{{detail.status==0}}"><view class="f1 "><view class="t1">等待买家付款</view><block qq:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block qq:if="{{detail.status==1}}"><view class="f1"><view class="t2">订单已付款</view></view></block><block qq:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block qq:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block><view class="orderx"><image src="{{pre_url+'/static/img/orderx.png'}}"></image></view></view><view class="orderinfo orderinfotop"><view class="title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block qq:if="{{detail.yy_time.length>4}}"><view class="item"><text class="t1">预约时间</text><text class="t2">{{detail.yy_time}}</text></view></block></view><block qq:if="{{detail.formdata.length>0}}"><view class="orderinfo"><block qq:for="{{detail.formdata}}" qq:for-item="item" qq:for-index="__i0__" qq:key="*this"><view class="item"><text class="t1">{{item[0]}}</text><block qq:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block qq:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view class="product"><view class="title">课程信息</view><view class="content"><view data-url="{{'product?id='+detail.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{detail.propic}}"></image