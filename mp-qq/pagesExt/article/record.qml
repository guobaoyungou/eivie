<view class="container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索本页" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block qq:if="{{isload}}"><block><view class="article_list"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="article-itemlist" data-url="{{'/pagesExt/article/fujian?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="article-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="article-info"><view class="p1">{{item.name}}</view><block><view class="p3">{{''+item.subname+''}}</view></block><view class="p2"><text class="flex1" style="overflow:hidden;">{{item.createtime}}</text></view></view></view></block></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="b055e170-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="b055e170-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="b055e170-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="b055e170-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b055e170-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>