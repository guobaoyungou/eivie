<view class="container"><view class="comment"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><image class="t1" src="{{item.headimg}}"></image><view class="t2">{{item.nickname}}</view><view class="flex1"></view><view class="t3"><block qq:for="{{[0,1,2,3,4]}}" qq:for-item="item2" qq:for-index="index2" qq:key="index2"><image class="img" src="{{pre_url+'/static/img/star'+(item.score>item2?'2native':'')+'.png'}}"></image></block></view></view><view style="color:#777;font-size:22rpx;">{{item.createtime}}</view><view class="f2"><text class="t1">{{item.content}}</text><view class="t2"><block qq:if="{{item.content_pic!=''}}"><block><block qq:for="{{item.content_pic}}" qq:for-item="itemp" qq:for-index="index" qq:key="index"><block><view data-url="{{itemp}}" data-urls="{{item.content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></block></view><text class="t3">{{"规格："+item.ggname}}</text></view><block qq:if="{{item.reply_content}}"><view class="f3"><view class="arrow"></view><view class="t1">{{"商家回复："+item.reply_content}}</view></view></block></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="19bf154c-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="19bf154c-2" text="暂无评价~" bind:__l="__l"></nodata></block><block qq:if="{{loading}}"><loading vue-id="19bf154c-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="19bf154c-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="19bf154c-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>