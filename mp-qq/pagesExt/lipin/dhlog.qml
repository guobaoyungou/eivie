<block qq:if="{{isload==1}}"><view class="container"><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><text class="t1" style="margin-bottom:10rpx;">{{item.remark}}</text><block qq:if="{{item.cardno}}"><text class="t1">{{"卡号："+item.cardno}}</text></block><block qq:else><text class="t1">{{"兑换码："+item.code}}</text></block><text class="t2">{{"兑换时间："+item.createtime}}</text></view></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="0b3d646f-1" bind:__l="__l"></nodata></block></view><block qq:if="{{nomore}}"><nomore vue-id="0b3d646f-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="0b3d646f-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="0b3d646f-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="0b3d646f-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>