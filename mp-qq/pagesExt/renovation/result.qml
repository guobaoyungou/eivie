<block qq:if="{{isload}}"><view class="container"><block qq:if="{{info.banner}}"><image style="width:100%;height:auto;display:table;" src="{{info.banner}}" mode="widthFix"></image></block><view class="content" style="{{'background:'+('linear-gradient(180deg,'+info.bgcolor+' 0%,rgba('+info.bgcolorrgb.red+','+info.bgcolorrgb.green+','+info.bgcolorrgb.blue+',0) 100%)')+';'}}"><view class="result"><view class="result_table"><block qq:for="{{table}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view data-event-opts="{{[['tap',[['tableClick',[index]]]]]}}" class="{{['item',tableIndex==index?'active':'']}}" bindtap="__e">{{''+item.lable+''}}<block qq:if="{{tableIndex!=index}}"><text>{{item.value}}</text></block></view></block></view><view class="result_module"><view class="result_data"><view class="result_chart"><canvas style="width:220rpx;height:220rpx;" canvas-id="canvas1" id="canvas1"></canvas><view class="result_num">{{''+table[tableIndex].value+''}}</view></view><view class="result_content"><block qq:for="{{cdata}}" qq:for-item="item" qq:for-index="index"><view class="result_item"><view class="result_tag" style="{{'background:'+(item.color)+';'}}"></view><view class="result_title">{{item.title}}</view><view class="result_price">{{item.pricew[tableIndex]}}</view></view></block></view></view><block qq:for="{{cdata}}" qq:for-item="item" qq:for-index="index"><block><view class="result_list" data-index="{{index}}" data-event-opts="{{[['tap',[['showitems',['$event']]]]]}}" bindtap="__e"><view>{{item.title}}</view><view class="result_more"><text>{{"￥"+item.price[tableIndex]}}</text><image src="{{pre_url+'/static/img/renovation_calculator/result_'+(item.showitems?'s':'h')+'.png'}}" alt></image></view></view><block qq:if="{{item.showitems}}"><view class="result_option"><block qq:for="{{item.items}}" qq:for-item="item2" qq:for-index="index2"><view class="item"><text>{{item2.title}}</text><text>{{item2.price[tableIndex]}}</text></view></block></view></block></block></block><view class="result_notice">*该报价来自系统估算，实际以量房为准</view></view></view></view><view class="qd_guize"><view class="guize_txt"><parse vue-id="95869f82-1" content="{{info.description}}" bind:__l="__l"></parse></view></view><view style="display:none;">{{test}}</view></view></block>