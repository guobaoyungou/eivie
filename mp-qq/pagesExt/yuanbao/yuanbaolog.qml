<view class="container"><block qq:if="{{isload}}"><block><view class="myyuanbao" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{myyuanbao}}<block qq:if="{{yuanbaoTransfer}}"><view class="btn-mini" data-url="/pagesExt/yuanbao/yuanbaoTransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账</view></block></view></view><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block qq:if="{{item.yuanbao>0}}"><block><text class="t1">{{"+"+item.yuanbao}}</text></block></block><block qq:else><block><text class="t2">{{item.yuanbao}}</text></block></block></view></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="febd223a-1" bind:__l="__l"></nodata></block></view><block qq:if="{{nomore}}"><nomore vue-id="febd223a-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="febd223a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="febd223a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="febd223a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>