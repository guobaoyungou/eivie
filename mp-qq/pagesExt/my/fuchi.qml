<view class="container"><block qq:if="{{isload}}"><block><view class="content"><block qq:if="{{st==0}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after+"元"}}</text></view><view class="f2"><block qq:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block qq:else><text class="t2">{{item.money}}</text></block></view></view></block></block></block><block qq:if="{{st==1}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block qq:if="{{item.status==0}}"><text class="t1">审核中</text></block><block qq:if="{{item.status==1}}"><text class="t1">已审核</text></block><block qq:if="{{item.status==2}}"><text class="t2">已驳回</text></block><block qq:if="{{item.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="21145010-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="21145010-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="21145010-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="21145010-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="21145010-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>