.container{overflow:hidden}.form{width:94%;margin:20rpx 3%;border-radius:5px;padding:20rpx 20rpx;padding:14rpx 3%;background:#fff}.form-item{display:flex;align-items:center;width:100%;border-bottom:1px #ededed solid;height:100rpx;line-height:100rpx}.form-item:last-child{border:0}.form-item .label{color:#8b8b8b;font-weight:700;width:200rpx}.form-item .input{flex:1;color:#000}.set-btn{width:90%;margin:60rpx 5%;height:96rpx;line-height:96rpx;border-radius:48rpx;color:#fff;font-weight:700}