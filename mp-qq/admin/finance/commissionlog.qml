<view><block qq:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block qq:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{$root.m1+"明细（共"+count+"条）"}}</text></view><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><image class="t1" src="{{item.$orig.headimg}}"></image><text class="t2">{{item.$orig.nickname}}</text></view><view class="f2"><block qq:if="{{item.$orig.commission>0}}"><text class="t1" style="color:#000;">{{"+"+item.$orig.commission+"元"}}</text></block><block qq:else><text class="t1">{{item.$orig.commission+"元"}}</text></block><text class="t2">{{item.m2}}</text><text class="t3">{{"备注："+item.$orig.remark}}</text></view></view></block></view></block><block qq:if="{{nodata}}"><nodata vue-id="6a3aa720-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="6a3aa720-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="6a3aa720-3" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="6a3aa720-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>