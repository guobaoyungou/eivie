<view class="container"><block qq:if="{{isload}}"><block><view class="head-bg"><view class="text-center _h1">{{detail.name}}</view><block qq:if="{{detail.status==2&&order.status!=3}}"><view class="title flex _h2"><image class="image" src="{{pre_url+'/static/img/admin/fork.png'}}"></image><view>用餐中</view></view></block><block qq:else><block qq:if="{{detail.status==0}}"><view class="title flex _h2"><image class="image" src="{{pre_url+'/static/img/admin/fork.png'}}"></image><view>空闲中</view></view></block><block qq:else><block qq:if="{{order.status==3}}"><view class="title flex _h2"><image class="image" src="{{pre_url+'/static/img/admin/fork.png'}}"></image><view>已结算，待清台</view></view></block><block qq:else><block qq:if="{{detail.status==3}}"><view class="title flex _h2"><image class="image" src="{{pre_url+'/static/img/admin/fork.png'}}"></image><view>清台中</view></view></block></block></block></block></view><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><block qq:if="{{detail.status==0}}"><view class="card-view"><view class="card-wrap"><view class="card-title">餐桌信息</view><view class="info-item"><view class="t1">桌台</view><view class="t2">{{detail.name}}</view></view><view class="info-item"><view class="t1">座位数</view><view class="t2">{{detail.seat}}</view></view></view><view class="card-wrap"><view class="card-title ">用餐信息</view><view class="info-item"><view class="t1">人数</view><view class="t2"><picker value="{{nindex}}" range="{{numArr}}" name="renshu" data-event-opts="{{[['change',[['numChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{numArr[nindex]}}</view></picker></view></view><view class="info-item"><view class="t1">顾客姓名</view><view class="t2"><input type="text" data-name="linkman" name="linkman" placeholder="选填"/></view></view><view class="info-item"><view class="t1">手机号</view><view class="t2"><input type="number" data-name="tel" name="tel" placeholder="选填"/></view></view><view class="info-item info-textarea"><view class=" remark"><view class="t1">备注</view><view><textarea data-name="message" name="message" placeholder="如您有其他需求请填写" placeholder-style="color:#ABABABFF"></textarea></view></view></view></view></view></block><view class="btn-view button-sp-area"><block qq:if="{{detail.status==0}}"><button type="primary" form-type="submit">开始用餐</button></block></view></form><block qq:if="{{detail.status==2}}"><view class="card-view"><view class="card-wrap"><view class="content"><block qq:if="{{orderGoodsSum==0&&order.status==0}}"><view class="item" data-url="{{'/restaurant/shop/index?type=admin&tableId='+detail.id+'&bid='+detail.bid+'&orderid='+order.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/dish.png'}}"></image><text class="t3">点餐</text></view></block><block qq:if="{{orderGoodsSum>0&&order.status==0}}"><view class="item" data-url="{{'/restaurant/shop/index?type=admin&tableId='+detail.id+'&bid='+detail.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/dish.png'}}"></image><text class="t3">加菜</text></view></block><block qq:if="{{orderGoodsSum>0&&order.status==0}}"><view data-event-opts="{{[['tap',[['toSettle',['$event']]]]]}}" class="item" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/money.png'}}"></image><text class="t3">结算</text></view></block><block qq:if="{{order.status==0}}"><view class="item" data-url="{{'tableWaiter?operate=change&origin='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/change.png'}}"></image><text class="t3">换桌</text></view></block><view data-event-opts="{{[['tap',[['clean',['$event']]]]]}}" class="item" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/clean.png'}}"></image><text class="t3">清台</text></view><block qq:if="{{order.status==0}}"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="item" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/admin/close.png'}}"></image><text class="t3">关闭</text></view></block></view></view><view class="card-wrap"><view class="card-title">餐桌信息</view><view class="info-item"><view class="t1">桌台</view><view class="t2">{{detail.name}}</view></view><view class="info-item"><view class="t1">人数/座位数</view><view class="t2">{{order.renshu+"/"+detail.seat}}</view></view><block qq:if="{{order.tea_fee}}"><view class="info-item"><view class="t1">{{detail.tea_fee_text}}</view><view class="t2">{{"￥"+order.tea_fee}}</view></view></block><view class="info-item"><view class="t1">客户信息</view><view class="t2"><block qq:if="{{!$root.m0}}"><text>{{order.linkman+''}}</text></block><block qq:if="{{!$root.m1}}"><text>{{order.tel}}</text></block></view></view><view class="info-item"><view class="t1">时间</view><view class="t2">{{$root.m2}}</view></view><block qq:if="{{!$root.m3}}"><view class="info-item info-textarea"><view class="t1">备注信息</view><view class="t2">{{order.message}}</view></view></block></view><block qq:if="{{detail.timing_fee_type&&detail.timing_fee_type>0}}"><view class="card-wrap"><view class="card-title">计时收费</view><block qq:if="{{detail.is_start==0}}"><image class="img" src="{{pre_url+'/static/img/admin/start.png'}}" data-status="{{1}}" data-event-opts="{{[['tap',[['startpause',['$event']]]]]}}" bindtap="__e"></image></block><block qq:else><image class="img" src="{{pre_url+'/static/img/admin/pause.png'}}" data-status="{{0}}" data-event-opts="{{[['tap',[['startpause',['$event']]]]]}}" bindtap="__e"></image></block><block qq:for="{{detail.timing_log}}" qq:for-item="item" qq:for-index="index"><block qq:if="{{detail.timing_log.length>0}}"><view class="info-item" style="justify-content:center;"><view class="t1">{{item.start_time+" ~ "+item.end_time}}</view><view class="t2" style="flex:0.3;">{{item.num+" 分钟"}}</view></view></block></block><view class="info-item info-textarea"><view class="t1">{{detail.timing_fee_text}}</view><view class="t2">{{"￥"+detail.timing_money}}</view></view></view></block><block qq:if="{{orderGoods.length>0}}"><view class="card-wrap card-goods"><view class="flex"><view class="card-title">{{"已点菜品("+orderGoodsSum+")"}}</view><view class="flex1"></view><block qq:if="{{order.status==0}}"><view class="btn-text" data-url="{{'shoporderEdit?id='+order.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">修改菜品</view></block></view><block qq:for="{{orderGoods}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="info-item"><view class="t1"><view style="line-height:60rpx;">{{item.name}}<block qq:if="{{item.ggname}}"><text>{{"["+item.ggname+(item.jltitle?item.jltitle:'')+"]"}}</text></block></view><block qq:if="{{item.ggtext&&item.ggtext.length}}"><view class="flex-col"><block qq:for="{{item.ggtext}}" qq:for-item="item2" qq:for-index="index"><block><text class="ggtext">{{item2}}</text></block></block></view></block></view><view class="t2">x<text>{{item.num}}<block qq:if="{{item.product_type&&item.product_type==1}}"><text style="font-size:20rpx;">斤</text></block></text></view><view class="t3">{{"￥"+item.real_totalprice}}</view></view></block><view class="info-item"><view class="t1">合计</view><view class="t2">{{"x"+orderGoodsSum}}</view><view class="t3">{{"￥"+order.totalprice}}</view></view></view></block><block qq:else><view class="card-wrap"><view class="info-item"><view class="t1">还未点菜</view></view></view></block></view></block><view class="btn-view button-sp-area mb"><block qq:if="{{detail.status==3}}"><button type="primary" data-event-opts="{{[['tap',[['cleanOver',['$event']]]]]}}" bindtap="__e">清理完成</button></block></view><view class="btn-view button-sp-area mb"><button class="btn-default" type="default" data-url="tableWaiter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">返回餐桌列表</button></view></block></block><uni-popup class="vue-ref" vue-id="3279b3f2-1" id="searchmember" type="dialog" data-ref="searchmember" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title" style="margin-bottom:10rpx;"><text class="uni-dialog-title-text">下单会员</text></view><view class="sc-item flex-xy-center"><input class="uni-input" type="text" placeholder="请输入手机号或会员编号" data-event-opts="{{[['input',[['__set_model',['','member_keyword','$event',[]]]]]]}}" value="{{member_keyword}}" bindinput="__e"/><button data-event-opts="{{[['tap',[['searchMember',['$event']]]]]}}" class="btn-mini" bindtap="__e">搜索</button></view><block qq:if="{{search_member&&search_member.id>0}}"><view class="sc-item flex-y-center"><view class="head-img"><image src="{{search_member.headimg}}"></image></view><view style="margin-left:20rpx;line-height:50rpx;"><view>{{search_member.nickname}}</view><view>{{$root.m4+"编号："+search_member.id}}</view></view></view></block><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['toWaiterPay',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">跳过</text></view><view data-event-opts="{{[['tap',[['updateorder',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text ">确定</text></view></view></view></uni-popup><block qq:if="{{loading}}"><loading vue-id="3279b3f2-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="3279b3f2-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>