ew></block><block qq:if="{{form.payset==1}}"><block><view class="item"><text class="t1">付款金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype}}</text></view><view class="item"><text class="t1">付款状态</text><block qq:if="{{detail.paystatus==1&&detail.isrefund==0}}"><text class="t2" style="color:green;">已付款</text></block><block qq:if="{{detail.paystatus==1&&detail.isrefund==1}}"><text class="t2" style="color:red;">已退款</text></block><block qq:if="{{detail.paystatus==0}}"><text class="t2" style="color:red;">未付款</text></block></view><block qq:if="{{detail.paystatus>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block></block></block></view><view style="width:100%;height:160rpx;"></view><view class="bottom notabbarbot"><block qq:if="{{detail.status>0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['jindu',['$event']]]]]}}" bindtap="__e">查看进度</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" bindtap="__e">删除</view></view><uni-popup class="vue-ref" vue-id="f415c26a-1" id="dialogSetst2" type="dialog" data-ref="dialogSetst2" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('f415c26a-2')+','+('f415c26a-1')}}" mode="input" title="驳回原因" value="{{detail.reason}}" placeholder="请输入驳回原因" data-event-opts="{{[['^confirm',[['setst2confirm']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup></block></block><block qq:if="{{ishowjindu}}"><view class="modal"><view class="modal_jindu"><view data-event-opts="{{[['tap',[['closejd',['$event']]]]]}}" class="close" bindtap="__e"><image src="{{pre_url+'/static/img/close.png'}}"></image></view><block qq:if="{{jdlist.length>0}}"><block><block qq:for="{{jdlist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view cla