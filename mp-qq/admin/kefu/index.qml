<view><block qq:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block qq:if="{{datalist&&datalist.length>0}}"><view class="content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item" data-url="{{'message?mid='+item.mid}}" data-mid="{{item.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]],['longpress',[['showdel',['$event']]]]]}}" bindtap="__e" bindlongpress="__e"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><block qq:if="{{item.msgtype=='image'}}"><text class="x2">[图片]</text></block><block qq:else><block qq:if="{{item.msgtype=='voice'}}"><text class="x2">[语音]</text></block><block qq:else><block qq:if="{{item.msgtype=='video'}}"><text class="x2">[小视频]</text></block><block qq:else><block qq:if="{{item.msgtype=='music'}}"><text class="x2">[音乐]</text></block><block qq:else><block qq:if="{{item.msgtype=='news'}}"><text class="x2">[图文]</text></block><block qq:else><block qq:if="{{item.msgtype=='link'}}"><text class="x2">[链接]</text></block><block qq:else><block qq:if="{{item.msgtype=='miniprogram'}}"><text class="x2">[小程序]</text></block><block qq:else><block qq:if="{{item.msgtype=='location'}}"><text class="x2">[地理位置]</text></block><block qq:else><text class="x2">{{item.content}}</text></block></block></block></block></block></block></block></block><text class="x3">{{item.showtime}}</text></view></view><block qq:if="{{item.noreadcount>0}}"><view class="unread">{{item.noreadcount}}</view></block></view></block></block></view></block><block qq:if="{{nomore}}"><nomore vue-id="2b89cb84-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="2b89cb84-2" bind:__l="__l"></nodata></block><view class="tabbar"><view class="tabbar-bot"></view><view class="tabbar-bar" style="background-color:#ffffff;"><block qq:if="{{auth_data.member}}"><view class="tabbar-item" data-url="../member/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/member.png?v=1'}}"></image></view><view class="tabbar-text">{{$root.m1}}</view></view></block><block qq:if="{{auth_data.zixun}}"><view class="tabbar-item" data-url="../kefu/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/zixun2.png?v=1'}}"></image></view><view class="tabbar-text active">咨询</view></view></block><block qq:if="{{auth_data.finance}}"><view class="tabbar-item" data-url="../finance/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/finance.png?v=1'}}"></image></view><view class="tabbar-text">财务</view></view></block><view class="tabbar-item" data-url="../index/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="tabbar-image-box"><image class="tabbar-icon" src="{{pre_url+'/static/img/admin/my.png?v=1'}}"></image></view><view class="tabbar-text">我的</view></view></view></view><popmsg class="vue-ref" vue-id="2b89cb84-3" data-ref="popmsg" bind:__l="__l"></popmsg></block></block><block qq:if="{{loading}}"><loading vue-id="2b89cb84-4" bind:__l="__l"></loading></block></view>