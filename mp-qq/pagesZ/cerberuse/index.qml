<view class="container"><block qq:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="dp-product-item"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="item" style="width:48%;margin:15rpx  1%;" data-url="{{'detail?type=1&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.price+''}}<text style="font-size:24rpx;">/小时</text></text></view></view></view></view></block></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="24bd024a-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="24bd024a-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="24bd024a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="24bd024a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="24bd024a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>