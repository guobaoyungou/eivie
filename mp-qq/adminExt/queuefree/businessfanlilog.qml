<view class="container"><block qq:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的返利</view><view class="f2">{{totalmoney}}</view></view><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.ordernum}}</view><view class="flex1"></view></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"类型："+item.typename}}</text></view><view class="detail">金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{"￥"+item.money}}</text></view><view class="detail">状态：<block qq:if="{{item.status==1}}"><text class="t1" style="color:green;">已完成</text></block><block qq:else><text class="t1" style="color:orange;">已退还</text></block></view><view class="detail"><text class="t1">{{"创建时间："+item.createtime}}</text></view></view><block qq:if="{{nodata}}"><nodata vue-id="{{'418b72e2-1-'+index}}" bind:__l="__l"></nodata></block></view></block><block qq:if="{{nomore}}"><nomore vue-id="418b72e2-2" bind:__l="__l"></nomore></block></block></block><uni-popup class="vue-ref" vue-id="418b72e2-3" type="center" data-ref="popupMiandan" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-miandan-content"><view class="popup-miandan-price flex"><view class="price-num-text popup-color-text">{{totalmoney}}</view><view class="right-text popup-color-text">元</view></view><view class="popup-leiji-miandan popup-color-text">累计返现金额</view><image src="{{pre_url+'/static/img/miandanpopupbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupMiandanclose',['$event']]]]]}}" class="popupMiandan-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup><fireworks vue-id="418b72e2-4" fireworksShow="{{fireworksShow}}" bind:__l="__l"></fireworks><block qq:if="{{loading}}"><loading vue-id="418b72e2-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="418b72e2-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="418b72e2-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>