<view><block qq:if="{{isload}}"><view class="container" id="datalist"><view><view class="info-item" style="line-height:40rpx;"><view class="t1" style="width:200rpx;">云音响管理</view><view style="display:flex;flex-wrap:wrap;justify-content:space-between;"><view class="btn2" data-url="edit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加唱单宝音响</view><block qq:if="{{customs.sound_mqlinks}}"><view class="btn2" data-url="editmqlinks" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加劢领云喇叭</view></block><block qq:if="{{customs.sound_yuzhi}}"><view class="btn2" data-url="edityuzhi" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加语智云喇叭</view></block></view></view><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="info-item2" data-id="{{item.id}}" data-device_brand="{{item.device_brand}}" data-event-opts="{{[['tap',[['gotoedit',['$event']]]]]}}" bindtap="__e"><view><view class="t1">{{"名称："+item.name}}</view><view class="t2">{{"终端号："+item.device_sn}}</view><view class="t2">{{"厂商："+item.device_brand_name}}</view><view class="t2">{{"添加时间："+item.createtime}}</view><view class="t2">状态：<block qq:if="{{item.status==1}}"><text style="color:green;">显示</text></block><block qq:else><text style="color:red;">隐藏</text></block></view></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view></view></block><block qq:if="{{nomore}}"><nomore vue-id="54ad4fed-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="54ad4fed-2" bind:__l="__l"></nodata></block></view>