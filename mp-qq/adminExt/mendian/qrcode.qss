.container{width:100%;padding:30rpx;text-align:center}.row{margin-top:30rpx;padding:20rpx;border-radius:20rpx;word-break:break-all;background-color:#fff}.title{margin:20rpx 0;font-size:32rpx;font-weight:700}.btn{margin:16rpx auto 0;width:270rpx;height:70rpx;line-height:70rpx;text-align:center;color:#fff;border-radius:12rpx}