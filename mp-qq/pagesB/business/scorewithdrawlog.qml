<view class="container"><block qq:if="{{isload}}"><block><dd-tab vue-id="aa6de0c4-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="listrow"><view class="item"><view class="f1"><text class="t1">{{"提现"+$root.m0+"："+item.score}}<text class="money" style="{{'color:'+($root.m1)+';'}}">{{"(￥"+item.money+")"}}</text></text><text class="t2">{{item.showtime}}</text></view><view class="f3"><block qq:if="{{item.status==0}}"><text class="st0">审核中</text></block><block qq:if="{{item.status==1}}"><text class="st1">已审核</text></block><block qq:if="{{item.status==2}}"><text class="st2">已驳回</text></block><block qq:if="{{item.status==3}}"><text class="st3">已打款</text></block></view></view><block qq:if="{{item.status==2&&item.reason}}"><view class="tips">{{item.reason}}</view></block></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="aa6de0c4-2" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="aa6de0c4-3" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="aa6de0c4-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="aa6de0c4-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="aa6de0c4-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>