<view class="container"><view style="width:100%;height:100%;"><block qq:if="{{detail.ctype==0}}"><view class="images-box"><image src="{{detail.url}}" show-menu-by-longpress="{{true}}" mode="widthFix"></image></view></block><block qq:else><block qq:if="{{detail.ctype==1}}"><view><video class="video" style="height:88vh;" id="video" autoplay="{{true}}" src="https://image.wxx1.com/upload/1/20210826/a8ff20404b7ce6762ec83a450ea247ad.mp4" show-loading="{{true}}" data-event-opts="{{[['pause',[['pause',['$event']]]]]}}" bindpause="__e"></video></view></block></block></view><view class="bottom-share"><view class="share-box"><image class="img" src="{{pre_url+'/static/img/download.png'}}" data-event-opts="{{[['tap',[['download',['$event']]]]]}}" bindtap="__e"></image><text>{{"保存"+(detail.ctype==1?'视频':'海报')}}</text></view><block qq:if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="share-box" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/weixin.png'}}"></image><text>分享好友</text></view></block><block qq:else><block qq:if="{{$root.m1=='mp'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="share-box" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/weixin.png'}}"></image><text>分享好友</text></view></block><block qq:else><block qq:if="{{$root.m2!='h5'}}"><button class="share-box remove-button" open-type="share"><image class="img" src="{{pre_url+'/static/img/weixin.png'}}"></image><text>分享给好友</text></button></block></block></block></view></view>