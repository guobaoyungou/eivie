<view class="container"><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索你感兴趣的鱼塘" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view></view><view class="content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="product-item2" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><text class="iconfont icondingwei" style="color:#888;"></text><block qq:if="{{item.address}}"><text class="t2" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.name}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchtap="__e">{{item.address}}</text></block></view><view class="p2"><image class="img-tel" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="t2" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchtap="__e">{{item.tel}}</text></view></view><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view></view></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="1dce2db2-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="1dce2db2-2" bind:__l="__l"></nodata></block><block qq:if="{{loading}}"><loading vue-id="1dce2db2-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1dce2db2-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1dce2db2-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>