<view class="container"><block qq:if="{{isload}}"><block><view style="width:100%;height:10rpx;"></view><view class="order-content"><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time==''}}"><text class="st3">待预约</text></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><text class="st1">待上课</text></block><block qq:if="{{item.$orig.status==1}}"><text class="st3">上课中</text></block><block qq:if="{{item.$orig.status==2}}"><text class="st4">已完成</text></block><block qq:if="{{item.$orig.status==3}}"><text class="st4">已退款</text></block></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{$root.m0+"："+item.$orig.workerinfo.realname+" "+(item.$orig.workerinfo.dengji||'')}}</text><block qq:if="{{item.$orig.start_study_time}}"><text class="t2">{{"开课时间："+item.$orig.start_study_time}}</text></block><block qq:if="{{item.$orig.hx_time}}"><text class="t2">{{"结束时间："+item.$orig.hx_time}}</text></block></view><block qq:if="{{item.$orig.comment}}"><view class="comment"><text class="t2">{{item.m1+"点评："+item.$orig.comment}}</text></view></block></view><view class="op"><block qq:if="{{item.$orig.status==1}}"><view class="btn1" style="{{'background:'+(item.m2)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" bindtap="__e">上课完成</view></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" bindtap="__e">取消</view></block></view></view></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="1b9e03b5-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="1b9e03b5-2" text="暂无学习记录" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="1b9e03b5-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1b9e03b5-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1b9e03b5-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>