<view class="container"><block qq:if="{{isload}}"><block><view style="width:100%;height:10rpx;"></view><view class="order-content"><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block qq:if="{{item.$orig.status==4}}"><text class="st3">待预约</text></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time==''}}"><text class="st3">待预约</text></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><text class="st1">待上课</text></block><block qq:if="{{item.$orig.status==1}}"><text class="st0">上课中</text></block><block qq:if="{{item.$orig.status==2}}"><text class="st4">已完成</text></block><block qq:if="{{item.$orig.status==3}}"><text class="st4">已退款</text></block></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{"顾客："+item.$orig.member.nickname}}</text><block qq:if="{{item.$orig.start_study_time}}"><text class="t2">{{"开课时间："+item.$orig.start_study_time}}</text></block></view><block qq:if="{{item.$orig.comment}}"><view class="comment"><text class="t2">{{item.m0+"点评："+item.$orig.comment}}</text></view></block></view><view class="op"><block qq:if="{{item.$orig.status==2&&item.$orig.comment==''}}"><view class="btn1" style="{{'background:'+(item.m1)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['commentopen',['$event']]]]]}}" bindtap="__e">点评</view></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['gotoclass',['$event']]]]]}}" bindtap="__e">开始上课</view></block><block qq:if="{{item.$orig.status==0&&item.$orig.start_study_time==''||item.$orig.status==4}}"><view class="btn2" data-url="{{'workeryueke?orderid='+item.$orig.orderid+'&id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">约课</view></block></view></view></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="70b705b7-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="70b705b7-2" bind:__l="__l"></nodata></block><uni-popup class="vue-ref" vue-id="70b705b7-3" id="popupcomment" type="dialog" maskClick="{{false}}" data-ref="popupcomment" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">点评</text></view><view class="uni-dialog-content"><textarea class="uni-dialog-input" placeholder="请输入您的评价" data-event-opts="{{[['input',[['__set_model',['','comment','$event',[]]],['setcomment',['$event']]]]]}}" value="{{comment}}" bindinput="__e"></textarea></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['commentclose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['subcomment',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup></block></block><block qq:if="{{loading}}"><loading vue-id="70b705b7-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="70b705b7-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="70b705b7-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>