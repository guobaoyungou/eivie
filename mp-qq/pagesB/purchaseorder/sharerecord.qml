<view class="container"><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view></view><view class="content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="product-item2" data-url="{{'posterpurchaseorder?orderid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view class="f1">{{item.ordernum}}</view></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p3" style="margin-top:10rpx;"><text class="t2">数量：</text><text class="t2">{{item.totalnum}}</text></view><view class="p3"><text class="t2">有效天数：</text><text class="t2">{{item.validity_day}}</text></view><view class="p3"><text class="t2">失效日期：</text><text class="t2">{{item.expiring_date}}</text></view><view class="p3"><text class="t2">创建时间：</text><text class="t2">{{item.createtime}}</text></view><view class="p3"><text class="t2">备注：</text><text class="t2">{{item.remark}}</text></view></view><view class="op"><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['purchaseOrderRemarkOpen',['$event']]]]]}}" catchtap="__e">备注</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchtap="__e">删除记录</view><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['purchaseOrderSetOpen',['$event']]]]]}}" catchtap="__e">修改有效期</view></view></view></view></block></view><uni-popup class="vue-ref" vue-id="6bf3ff56-1" id="purchaseOrderSet" type="dialog" mask-click="{{false}}" data-ref="purchaseOrderSet" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">设置</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center form-item"><view class="form-label">有效期：</view><input class="text-input" type="number" data-event-opts="{{[['input',[['inputChange',['$event']]]]]}}" value="{{editday}}" bindinput="__e"/><view class="form-label" style="margin-left:10rpx;">天</view></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['purchaseOrderSetClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['toedit',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><uni-popup class="vue-ref" vue-id="6bf3ff56-2" id="purchaseOrderRemark" type="dialog" mask-click="{{false}}" data-ref="purchaseOrderRemark" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">备注</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center form-item"><input type="text" placeholder="请输入备注" data-event-opts="{{[['input',[['inputChangeRemark',['$event']]]]]}}" value="{{remark}}" bindinput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['purchaseOrderRemarkClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['toeditRemark',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><block qq:if="{{nomore}}"><nomore vue-id="6bf3ff56-3" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="6bf3ff56-4" bind:__l="__l"></nodata></block><block qq:if="{{loading}}"><loading vue-id="6bf3ff56-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="6bf3ff56-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="6bf3ff56-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>