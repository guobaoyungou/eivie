<view class="container"><block qq:if="{{isload}}"><block><view class="message-list"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><block qq:if="{{item.formatTime}}"><view class="message-time">{{item.formatTime}}</view></block><block qq:if="{{item.isreply==1}}"><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'}}"><image class="message-avatar" mode="aspectFill" src="{{item.uheadimg}}"></image><view class="message-text-left"><view class="arrow-box arrow-left"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-white.png'}}"></image></view><view class="message-text"><parse vue-id="{{'6f12f26e-1-'+index}}" content="{{item.content}}" bind:__l="__l"></parse></view></view></view></block><block qq:else><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'+('justify-content:'+('flex-end')+';')}}"><view class="message-text-right"><view class="arrow-box arrow-right"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-green.png'}}"></image></view><view class="message-text"><parse vue-id="{{'6f12f26e-2-'+index}}" content="{{item.content}}" bind:__l="__l"></parse></view></view><image class="message-avatar" mode="aspectFill" src="{{item.headimg}}"></image></view></block></block></block></view><view class="input-box notabbarbot" id="input-box"><view class="input-form"><image class="pic-icon" src="{{pre_url+'/static/img/msg-pic.png'}}" data-event-opts="{{[['tap',[['sendimg',['$event']]]]]}}" bindtap="__e"></image><input class="input" confirmHold="{{true}}" confirmType="send" cursor-spacing="20" type="text" maxlength="-1" data-event-opts="{{[['confirm',[['sendMessage',['$event']]]],['focus',[['onInputFocus',['$event']]]],['input',[['messageChange',['$event']]]]]}}" value="{{message}}" bindconfirm="__e" bindfocus="__e" bindinput="__e"/><image class="face-icon" src="{{pre_url+'/static/img/face-icon.png'}}" data-event-opts="{{[['tap',[['toggleFaceBox',['$event']]]]]}}" bindtap="__e"></image><block qq:if="{{trimMessage}}"><button data-event-opts="{{[['tap',[['sendMessage',['$event']]]]]}}" class="send-button-active" style="{{'background:'+($root.m0)+';'}}" bindtap="__e">发送</button></block></view><block qq:if="{{faceshow}}"><wxface bind:selectface="__e" vue-id="6f12f26e-3" data-event-opts="{{[['^selectface',[['selectface']]]]}}" bind:__l="__l"></wxface></block></view><view class="{{['anit '+(msgtipsShow==1?'show':msgtipsShow==2?'hide':'')]}}" data-url="{{'index?bid='+msgtips.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{msgtips.unickname+"："+msgtips.content}}</view></block></block><block qq:if="{{loading}}"><loading vue-id="6f12f26e-4" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="6f12f26e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>