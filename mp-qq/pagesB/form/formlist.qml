<view class="container"><block qq:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的活动" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><dd-tab vue-id="4ef5efd4-1" itemdata="{{['全部','未开始','进行中','已结束']}}" itemst="{{['all','0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="article_list"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="article-itemlist" data-url="{{item.listpage_tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="article-pic"><image class="image" src="{{item.listpage_pic}}" mode="widthFix"></image></view><view class="article-info"><view class="p1">{{item.listpage_title}}</view><block qq:if="{{item.listpage_description}}"><block><block qq:if="{{item.listpage_description}}"><view class="p3">{{item.listpage_description}}</view></block></block></block><view class="p2"><text class="flex1" style="overflow:hidden;">{{item.starttime}}</text><text style="overflow:hidden;color:#f50;">{{item.count+"人已报名"}}</text></view></view></view></block></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="4ef5efd4-2" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="4ef5efd4-3" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="4ef5efd4-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="4ef5efd4-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4ef5efd4-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>