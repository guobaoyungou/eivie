<view class="container"><block qq:if="{{isload}}"><block><view class="top"><block qq:if="{{data.bg_type==1}}"><view class="cardbg"><image src="{{data.background_pic_url}}"></image></view></block><block qq:else><view class="cardbg" style="{{('background: '+data.color)}}"></view></block><view class="hyk flex"><view class="f1"><image src="{{data.logo_url}}"></image></view><view class="f2"><text class="t1">{{data.brand_name}}</text><text class="t2">{{data.title}}</text></view></view></view><view style="height:100rpx;"></view><view class="center1"><view data-event-opts="{{[['tap',[['showqrcode',['$event']]]]]}}" class="f1" bindtap="__e"><image src="{{pre_url+'/static/img/membercard/codeicon.png'}}"></image><text class="t1">分享二维码</text></view><view data-event-opts="{{[['tap',[['showsharelog',['$event']]]]]}}" class="f1" bindtap="__e"><image src="{{pre_url+'/static/img/membercard/logicon.png'}}"></image><text class="t1">分享记录</text></view></view><block qq:if="{{isshowcode}}"><view class="showcode"><view class="t1">识别图中二维码，领取会员卡</view><view class="code"><image src="{{info.sharecode}}"></image></view></view></block><block qq:if="{{isshowsharelog}}"><view class="center2"><view class="title">{{'我的分享记录 共邀请好友'+info.tjcount+"人"}}</view><block qq:if="{{info.tjcount>0}}"><block><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index"><block qq:if="{{sharelog}}"><view class="item"><view class="headimg"><image src="{{item.$orig.headimg}}"></image><view class="f1"><view class="t1">{{item.$orig.nickname}}</view><view class="t2">{{item.m0}}</view></view></view><view class="kkimg"><image src="{{pre_url+'/static/img/membercard/kkimg.png'}}"></image></view></view></block></block></block></block><block qq:else><block><view style="text-align:center;color:#999;">暂无邀请记录</view></block></block></view></block><view class="center3"><view class="title"><view>邀请好友<text style="color:#D0735A;">开卡</text>即可得到奖励</view><view style="color:#999;font-size:24rpx;" data-url="{{'jiangli?id='+data.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看我的奖励<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view><view class="item"><block qq:if="{{data.parent_givescore>0}}"><view class="score"><view class="f1"><image src="{{pre_url+'/static/img/membercard/integral.png'}}"></image></view><view class="f2"><text class="t1">{{data.parent_givescore}}</text><text>{{$root.m1}}</text></view></view></block><block qq:if="{{data.parent_givemoney>0}}"><view class="score"><view class="f1"><image src="{{pre_url+'/static/img/membercard/coupon2.png'}}"></image></view><view class="f2"><text class="t1">{{data.parent_givemoney}}</text><text>{{$root.m2}}</text></view></view></block></view><block qq:for="{{data.parent_couponList}}" qq:for-item="item" qq:for-index="index"><block qq:if="{{data.parent_give_coupon}}"><block><view class="cooupondesc"><image class="cimg" src="{{pre_url+'/static/img/membercard/coupon_bg.png'}}" mode="widthFix"></image><view class="coupon"><view class="f1"><image src="{{pre_url+'/static/img/membercard/coupon_icon.png'}}" mode="widthFix"></image><text class="t1">{{item}}</text></view><text class="t2">X 1</text></view></view></block></block></block></view><view data-event-opts="{{[['tap',[['showrule',['$event']]]]]}}" class="rule" bindtap="__e"><label>活动规则</label><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view><view class="detail"><view class="title">会员卡详情</view><view class="content"><view class="itembox"><view class="item"><label>特权说明</label><text class="t1">{{data.prerogative}}</text></view><view class="item"><label>联系电话</label><text class="t2" data-url="{{'tel::'+data.service_phone}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{data.service_phone}}</text></view><view class="item"><label>使用说明</label><text class="t1">{{data.description}}</text></view></view></view></view><view style="height:200rpx;"></view><view class="bottom"><button data-url="{{data.ret_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">进入会员卡</button><block qq:if="{{$root.m3}}"><button class="btn" data-cardid="{{data.id}}" data-event-opts="{{[['tap',[['share',['$event']]]]]}}" catchtap="__e">立即分享</button></block></view><block qq:if="{{isshowshare}}"><view class="sharemodal"><view class="hands"><image src="{{pre_url+'/static/img/membercard/m-hand.png'}}" mode="widthFix"></image></view><view class="image"><image src="{{pre_url+'/static/img/membercard/m-share.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['closeshare',['$event']]]]]}}" class="title" catchtap="__e">跳过</view></view></block><block qq:if="{{isshowrule}}"><view class="modal_wrap" id="modal_wrap"><view class="modal_box"><view class="modal_title"><view class="_i"></view><text class="title">活动规则</text></view><view class="content">{{''+data.rule+''}}</view><view data-event-opts="{{[['tap',[['closerule',['$event']]]]]}}" class="close_btn" catchtap="__e">X</view></view></view></block></block></block></view>