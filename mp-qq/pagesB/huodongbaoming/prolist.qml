ype:0}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.name}}</text></view><view class="p2"><view class="t1" style="{{'color:'+($root.m6)+';'}}">{{item.sell_price}}<text style="font-size:24rpx;padding-left:2px;">元</text></view></view><view class="p3"><block qq:if="{{item.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.sales+"件"}}</text></view></block></view></view></view></block></view><block qq:if="{{nomore}}"><nomore vue-id="9a28be90-1" text="没有更多活动了" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="9a28be90-2" text="暂无相关活动" bind:__l="__l"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view><block qq:if="{{buydialogShow}}"><buydialog vue-id="9a28be90-3" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e" bind:__l="__l"></buydialog></block></block></block><block qq:if="{{loading}}"><loading vue-id="9a28be90-4" loadstyle="left:62.5%" bind:__l="__l"></loading></block><dp-tabbar vue-id="9a28be90-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="9a28be90-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>