<view><block qq:if="{{isload}}"><block><block qq:if="{{datalist.length>0}}"><view class="initials-list-wrap"><scroll-view class="scroll-list" scroll-y="{{true}}" scroll-into-view="{{scrollViewId}}"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view><view class="letter" id="{{item.zimu}}">{{item.zimu}}</view><view class="con" data-city="{{item.city}}" data-event-opts="{{[['tap',[['search',['$event']]]]]}}" bindtap="__e"><view class="list-item">{{''+item.city}}</view></view></view></block></scroll-view><view class="{{['letter-list-bar',(touchmove)?'active':'']}}"><block qq:for="{{letterList}}" qq:for-item="item" qq:for-index="index" qq:key="index"><text data-event-opts="{{[['tap',[['letterSelect',[index]]]]]}}" class="{{['text',(touchmoveIndex==index)?'active':'']}}" catchtap="__e">{{''+item+''}}</text></block></view><block qq:if="{{touchmove}}"><view class="letter-alert">{{letterList[touchmoveIndex]+''}}</view></block></view></block><block qq:if="{{nomore}}"><nomore vue-id="7275a40f-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="7275a40f-2" text bind:__l="__l"></nodata></block><dp-chat-tabbar vue-id="7275a40f-3" currentIndex="2" bind:__l="__l"></dp-chat-tabbar></block></block><popmsg class="vue-ref" vue-id="7275a40f-4" data-ref="popmsg" bind:__l="__l"></popmsg><block qq:if="{{loading}}"><loading vue-id="7275a40f-5" bind:__l="__l"></loading></block></view>