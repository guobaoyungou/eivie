<view class="container"><block qq:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的提现积分</view><view class="f2">{{myscore}}</view></view><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block qq:if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block qq:else><block><text class="t2">{{item.score}}</text></block></block></view></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="732d2e9e-1" bind:__l="__l"></nodata></block></view><block qq:if="{{nomore}}"><nomore vue-id="732d2e9e-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="732d2e9e-3" bind:__l="__l"></loading></block></view>