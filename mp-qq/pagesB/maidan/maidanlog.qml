<view class="container"><block qq:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item" data-url="{{'maidandetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.paytime}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><block qq:if="{{canrefund&&item.refund_money>0}}"><text class="t2">{{"退款金额：￥"+item.refund_money}}</text></block><block qq:if="{{item.mendian_name&&item.mdid>0}}"><text class="t2">{{"所属门店："+item.mendian_name}}</text></block></view><view class="f2"><text class="t1">{{"-￥"+item.money}}</text></view></view></block></block></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="3caaaadc-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="3caaaadc-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="3caaaadc-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="3caaaadc-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="3caaaadc-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>