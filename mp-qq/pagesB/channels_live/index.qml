<view class="page" style="{{'background:'+(bgcolor==''?'#FA5C01':bgcolor)+';'}}"><view class="page-box" style="{{'background-image:'+('url('+bgpic+')')+';'}}"><view class="head-box"><view class="logo-box"><image class="logo" src="{{channels.headimg}}" alt="{{channels.nickname}}"></image></view><view class="head-title"><view class="title" style="{{'color:'+(fontcolor)+';'}}">{{channels.nickname}}</view></view><view class="head-desc" style="{{'color:'+(fontcolor)+';'}}">{{setData.desc}}</view><view class="bgcolor"></view><view data-event-opts="{{[['tap',[['openChannels']]]]}}" class="button-channels" style="{{'background-image:'+('url('+pre_url+'/static/img/channels_live/button_sph.png)')+';'}}" bindtap="__e"></view></view><view class="content-box"><block qq:if="{{$root.m0}}"><view class="live-box empty">暂无数据</view></block><block qq:else><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="live-box"><view class="live-title">{{item.$orig.content}}</view><view class="live-content flex-bt"><view class="live-time" style="{{('background: url('+pre_url+'/static/img/channels_live/time_icon.png) no-repeat;background-size:32rpx;background-position: left;')}}">{{item.m1+"开播"}}</view><block qq:if="{{item.$orig.reserve_status==1}}"><view data-event-opts="{{[['tap',[['reserveChannelsLive',['$0','$1'],[[['liveList','',index,'noticeId']],[['liveList','',index,'id']]]]]]]}}" class="live-reservation opacity" style="{{('background: url('+pre_url+'/static/img/channels_live/bg_bottom.png) no-repeat 100%;background-size: 100%;')}}" bindtap="__e">已预约</view></block><block qq:else><block qq:if="{{item.$orig.live_status==3}}"><view class="live-reservation" style="{{('background: url('+pre_url+'/static/img/channels_live/tmbg_bottom.png) no-repeat 100%;color: #E83612;background-size: 100%;')}}" data-id data-event-opts="{{[['tap',[['gotoLive',['$event']]]]]}}" bindtap="__e">直播中</view></block><block qq:else><view data-event-opts="{{[['tap',[['reserveChannelsLive',['$0','$1'],[[['liveList','',index,'noticeId']],[['liveList','',index,'id']]]]]]]}}" class="live-reservation" style="{{('background: url('+pre_url+'/static/img/channels_live/bg_bottom.png) no-repeat 100%;background-size: 100%;')}}" bindtap="__e">预约直播</view></block></block></view></view></block></block></view><view data-event-opts="{{[['tap',[['changerule',['$event']]]]]}}" class="rule-title flex-y-center" bindtap="__e">规则</view><block qq:if="{{showrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changerule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{setData.guize}}</text></view></view></view></view></block></view><block qq:if="{{loading}}"><loading vue-id="6c283df6-1" bind:__l="__l"></loading></block></view>