<view class="container"><block qq:if="{{isload}}"><block><view class="exchange-list"><block qq:for="{{fert_types}}" qq:for-item="item" qq:for-index="index" qq:key="id"><block qq:if="{{item.score>0}}"><view class="exchange-item"><view class="item-left"><image class="item-logo" src="{{item.logo}}" mode="aspectFill"></image><view class="item-info"><text class="item-name">{{item.name}}</text><text class="item-owned">{{"当前持有: "+(item.num||0)}}</text><text class="item-owned">{{"所需"+farm_textset['美宝']+": "+(item.score||0)}}</text></view></view><view class="item-right"><text class="exchange-btn" data-type="{{item.type}}" data-name="{{item.name}}" data-score="{{item.score}}" data-event-opts="{{[['tap',[['openExchangePopup',['$event']]]]]}}" bindtap="__e">兑换</text><text class="exchange-btn" data-url="{{'/pagesD/farm/fertlog?st='+item.type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看明细</text></view></view></block></block></view><block qq:if="{{nodata}}"><nodata vue-id="70ea4688-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="70ea4688-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="70ea4688-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="70ea4688-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="70ea4688-5" data-ref="popmsg" bind:__l="__l"></popmsg><uni-popup class="vue-ref" vue-id="70ea4688-6" type="center" data-ref="exchangePopup" bind:__l="__l" vue-slots="{{['default']}}"><view class="exchange-popup"><view class="popup-title">{{"兑换"+selectedItem.name}}</view><view class="popup-content"><view class="score-info"><text class="info-label">单价:</text><text class="info-value">{{selectedItem.score+farm_textset['美宝']}}</text></view><view class="quantity-selector"><text class="selector-label">兑换数量:</text><view class="selector-control"><text data-event-opts="{{[['tap',[['decreaseQuantity',['$event']]]]]}}" class="control-btn" bindtap="__e">-</text><input class="quantity-input" type="number" data-event-opts="{{[['input',[['__set_model',['','exchangeQuantity','$event',[]]]]]]}}" value="{{exchangeQuantity}}" bindinput="__e"/><text data-event-opts="{{[['tap',[['increaseQuantity',['$event']]]]]}}" class="control-btn" bindtap="__e">+</text></view></view><view class="total-score"><text class="total-label">总计:</text><text class="total-value">{{totalScore+farm_textset['美宝']}}</text></view></view><view class="popup-actions"><text data-event-opts="{{[['tap',[['closeExchangePopup',['$event']]]]]}}" class="action-btn cancel" bindtap="__e">取消</text><text data-event-opts="{{[['tap',[['confirmExchange',['$event']]]]]}}" class="action-btn confirm" bindtap="__e">确认兑换</text></view></view></uni-popup></view>