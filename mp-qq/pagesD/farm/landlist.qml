<view class="container"><block qq:if="{{isload}}"><block><view class="top-nav"><view class="{{['nav-item',st==2?'active':'']}}" data-status="2" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>全部</text></view><view class="{{['nav-item',st==1?'active':'']}}" data-status="1" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>已种植</text></view><view class="{{['nav-item',st==0?'active':'']}}" data-status="0" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>未种植</text></view></view><block><view class="farm-list"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="item"><text class="num">{{item.sort+"号"}}</text><view class="media"><image class="icon" style="max-width:100rpx;" src="{{item.logo}}" mode="widthFix"></image><text class="label">{{item.name}}</text><text class="label" style="font-size:16rpx;">{{"(ID:"+item.id+")"}}</text></view><block qq:if="{{item.tree_status==1}}"><block><view class="progress-bar"><image class="background" src="{{pre_url+'/static/img/farm/jdt_bg.png'}}" mode="widthFix"></image><view class="inner"><view class="clip-box" style="{{'width:'+(item.tree_progress+'%')+';'+('background-image:'+('url('+pre_url+'/static/img/farm/jdt.png)')+';')}}"></view></view></view><text class="progress">{{item.tree_progress+"%"}}</text></block></block><block qq:if="{{item.tree_status!=1}}"><block><view class="progress-bar"></view></block></block><block qq:if="{{item.tree_status==1}}"><text class="button" data-url="{{'/pagesD/farm/landdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">进入</text></block><block qq:else><text class="button" data-id="{{item.id}}" data-event-opts="{{[['tap',[['addtree',['$event']]]]]}}" bindtap="__e">种植</text></block></view></block></view></block><block qq:if="{{nodata}}"><nodata vue-id="d32a016a-1" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="d32a016a-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="d32a016a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="d32a016a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d32a016a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>