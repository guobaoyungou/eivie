.bg-view{width:100%;height:40vh;border-radius:0rpx 0rpx 120rpx 120rpx;overflow:hidden}.bg-view image{width:100%;height:100%}.content-view{width:94%;border-radius:16rpx;background:#fff;position:relative;top:-110rpx;left:50%;-webkit-transform:translateX(-50%);transform:translateX(-50%);box-shadow:0rpx 0rpx 10rpx 0rpx rgba(0,0,0,.3);padding:60rpx 0rpx}.content-view .info-view{width:100%;justify-content:center;margin-bottom:20rpx}.content-view .info-view .head-img{width:58rpx;height:58rpx;border-radius:10rpx;overflow:hidden}.content-view .info-view .head-img image{width:100%;height:100%}.content-view .info-view .name-view{font-size:34rpx;font-weight:700;color:#000;padding-left:20rpx}.content-view .price-view{justify-content:center;font-size:80rpx;font-weight:700;color:#e4c130;margin-top:20rpx}.tisp-text{text-align:center;font-size:26rpx;color:#e4c130;justify-content:center}.icon-class{width:34rpx;height:34rpx}.icon-class image{width:100%;height:100%}.hb-log{font-size:28rpx;color:#1e67c1;position:absolute;left:50%;-webkit-transform:translateX(-50%);transform:translateX(-50%);bottom:calc(30rpx + env(safe-area-inset-bottom))}