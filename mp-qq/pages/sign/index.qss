page{background:#f4f4f4}.qd_head{width:100%;position:relative}.qdbg{width:100%;height:940rpx}.myscore{position:absolute;top:60rpx;width:100%;display:flex;color:#fff;flex-direction:column;align-items:center;z-index:2}.myscore .f1{font-size:56rpx;font-weight:700}.myscore .f2{font-size:32rpx}.signlog{position:absolute;top:50rpx;right:20rpx;color:#fff;font-size:28rpx;z-index:2}.qd_head .signbtn{position:absolute;top:760rpx;width:100%;display:flex;flex-direction:column;align-items:center;z-index:2}.qd_head .signbtn .btn{width:440rpx;height:80rpx;border-radius:40rpx;font-size:32rpx;font-weight:700;color:#fff}.qd_head .signbtn .btn2{width:440rpx;height:80rpx;background:#fcb0b0;border-radius:40rpx;font-size:32rpx;font-weight:700;color:#fff}.qd_head .signbtn .signtip{color:#999;margin-top:16rpx}.btn-a{text-align:center;margin-top:18rpx}.qd_head2{padding-bottom:20rpx;background-position:50%;background-repeat:no-repeat;background-size:cover}.qd_head2 .calendar{padding-top:300rpx;width:96%;margin:0 2%}.qd_head2 .signbtn{top:136rpx}.qd_head2 .signbtn .signtip{color:#fff}.qd_guize{width:100%;margin:0;padding-bottom:20rpx}.qd_guize .gztitle{width:100%;text-align:center;font-size:32rpx;color:#656565;font-weight:700;height:100rpx;line-height:100rpx}.guize_txt{box-sizing:border-box;padding:0 30rpx;line-height:42rpx}.paiming{width:94%;margin:0 3%;background:#fff;border-radius:10px;padding:20rpx 20rpx}.paiming .item{line-height:80rpx;border-bottom:1px dashed #eee}.paiming .item:last-child{border:0}.paiming .item .f1{flex:1;display:flex;flex-direction:column}.paiming .item .f1 .t1{color:#000;font-size:30rpx;word-break:break-all;overflow:hidden;text-overflow:ellipsis}.paiming .item .f1 .t2{color:#666}.paiming .item .f1 .t3{color:#666}.paiming .item .f2{flex:1;text-align:right;font-size:30rpx}.paiming .item .f2 .t1{color:#03bc01}.paiming .item .f2 .t2{color:#000}