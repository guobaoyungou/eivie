.loading-wrap{position:fixed;width:64rpx;height:64rpx;left:50%;top:38%;z-index:99999;text-align:center;margin-left:-32rpx;border-radius:35rpx}.loading-img{width:64rpx;height:64rpx;position:absolute;-webkit-animation:loading .8s linear 0s infinite;animation:loading .8s linear 0s infinite;left:0;top:0}.loading-img0{width:64rpx;height:64rpx;position:absolute;-webkit-animation:loading .8s linear 0s infinite;animation:loading .8s linear 0s infinite;left:0;top:0}.loading-img1{width:64rpx;height:64rpx;position:absolute;-webkit-animation:loading .8s ease 0s infinite;animation:loading .8s ease 0s infinite;left:0;top:0}@keyframes loading{0%{-webkit-transform:rotate(0);transform:rotate(0)}100%{-webkit-transform:rotate(1turn);transform:rotate(1turn)}}@-webkit-keyframes loading{0%{-webkit-transform:rotate(0);transform:rotate(0)}100%{-webkit-transform:rotate(1turn);transform:rotate(1turn)}}