.buydialog-mask{position:fixed;top:0;left:0;width:100%;background:rgba(0,0,0,.5);bottom:0;z-index:10}.buydialog{position:fixed;width:100%;left:0;bottom:0;background:#fff;z-index:11;border-radius:20rpx 20rpx 0 0}.buydialog .close{position:absolute;top:0;right:0;padding:20rpx;z-index:12}.buydialog .close .image{width:30rpx;height:30rpx}.buydialog .title{width:94%;position:relative;margin:0 3%;padding:20rpx 0;border-bottom:0;height:190rpx}.buydialog .title .img{width:160rpx;height:160rpx;position:absolute;top:20rpx;border-radius:10rpx;border:0 #e5e5e5 solid;background-color:#fff}.buydialog .title .price{padding-left:180rpx;width:100%;font-size:36rpx;height:70rpx;color:#fc4343;overflow:hidden}.buydialog .title .price .t1{font-size:26rpx}.buydialog .title .price .t2{font-size:26rpx;text-decoration:line-through;color:#aaa}.buydialog .title .choosename{padding-left:180rpx;width:100%;font-size:24rpx;height:42rpx;line-height:42rpx;color:#888}.buydialog .title .stock{padding-left:180rpx;width:100%;font-size:24rpx;height:42rpx;line-height:42rpx;color:#888}.buydialog .guigelist{width:94%;position:relative;margin:0 3%;padding:0 0 10px 0;border-bottom:0}.buydialog .guigelist .name{height:70rpx;line-height:70rpx}.buydialog .guigelist .item{font-size:30rpx;color:#333;flex-wrap:wrap}.buydialog .guigelist .item2{display:flex;align-items:center;min-height:40rpx;height:auto;margin-bottom:4px;border:0;border-radius:4rpx;padding:10rpx 40rpx;color:#666;margin-right:10rpx;font-size:26rpx;background:#f4f4f4}.buydialog .guigelist .on{color:#fc4343;background:rgba(252,67,67,.1);font-weight:700}.buydialog .buynum{width:94%;position:relative;margin:0 3%;padding:10px 0 10px 0}.buydialog .addnum{font-size:30rpx;color:#666;width:auto;display:flex;align-items:center}.buydialog .addnum .plus{width:48rpx;height:36rpx;background:#f6f8f7;display:flex;align-items:center;justify-content:center}.buydialog .addnum .minus{width:48rpx;height:36rpx;background:#f6f8f7;display:flex;align-items:center;justify-content:center}.buydialog .addnum .img{width:24rpx;height:24rpx}.buydialog .addnum .input{flex:1;width:70rpx;border:0;text-align:center;color:#2b2b2b;font-size:24rpx}.buydialog .op{width:90%;margin:20rpx 5%;border-radius:36rpx;overflow:hidden;display:flex;margin-top:100rpx}.buydialog .addcart{flex:1;height:72rpx;line-height:72rpx;color:#fff;border-radius:0;border:none;font-size:28rpx;font-weight:700}.buydialog .tobuy{flex:1;height:72rpx;line-height:72rpx;color:#fff;border-radius:0;border:none;font-size:28rpx;font-weight:700}.buydialog .nostock{flex:1;height:72rpx;line-height:72rpx;background:#aaa;color:#fff;border-radius:0;border:none}