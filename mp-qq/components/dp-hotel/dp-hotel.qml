<view class="dp-kanjia" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><view class="dp-hotel-item"><view class="hotels-list"><block qq:for="{{$root.l0}}" qq:for-item="item" qq:for-index="index"><block><view class="hotels-options" data-url="{{'/hotel/index/hoteldetails?id='+item.$orig.hotelid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="hotel-img"><image src="{{item.$orig.pic}}"></image></view><view class="hotel-info"><block qq:if="{{params.showname==1}}"><view class="hotel-title">{{item.$orig.name}}</view></block><view class="hotel-address">{{item.$orig.address}}</view><block qq:if="{{params.showtag==1&&item.$orig.tag.length>0}}"><view class="hotel-characteristic"><block qq:for="{{item.$orig.tag}}" qq:for-item="items" qq:for-index="indexs"><block><view class="characteristic-options" style="{{('background:rgba('+item.m0+',0.05);color:'+item.m1)}}">{{items}}</view></block></block></view></block><view class="hotel-but-view"><view class="make-info"><block qq:if="{{params.showprice==1}}"><block><block qq:if="{{item.$orig.min_daymoney}}"><view class="hotel-price" style="{{'color:'+(item.m2)+';'}}"><view class="hotel-price-num">{{item.$orig.min_daymoney+item.m3}}</view><view>/晚起</view></view></block><block qq:else><view class="hotel-price" style="{{'color:'+(item.m4)+';'}}"><view>￥</view><view class="hotel-price-num">{{item.$orig.sell_price}}</view><view>起</view></view></block></block></block><block qq:if="{{params.showsales==1}}"><view class="hotel-text">{{item.$orig.sales+"人预定"}}</view></block></view><view class="hotel-make" style="{{('background:rgba('+$root.m5+',0.8);color:#FFF')}}">预约</view></view></view></view></block></block></view></view></view>