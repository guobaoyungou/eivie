<view class="dp-business" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('font-size:'+(params.fontsize*2+'rpx')+';')}}"><block qq:for="{{data}}" qq:for-item="item" qq:for-index="index" qq:key="id"><view class="busbox"><view class="businfo" data-url="{{'/pagesA/formdata/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1" style="width:140rpx;height:140rpx;"><image class="image" style="border-radius:12rpx;" lazy-load="true" lazy-load-margin="0" src="{{item.logo}}"></image></view><view class="f2"><view class="title">{{item.title}}</view><block qq:if="{{item.address}}"><view class="address" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.title}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchtap="__e"><image style="width:26rpx;height:26rpx;margin-right:20rpx;float:left;margin-top:4rpx;" src="{{pre_url+'/static/img/b_addr.png'}}" class="_img"></image>{{item.address+''}}</view></block><block qq:if="{{item.tel}}"><view class="address" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchtap="__e"><image style="width:26rpx;height:26rpx;margin-right:20rpx;float:left;margin-top:4rpx;" src="{{pre_url+'/static/img/b_tel.png'}}" class="_img"></image>{{item.tel+''}}</view></block></view><view style="width:140rpx;text-align:center;line-height:142rpx;font-size:24rpx;" data-url="{{'/pagesA/formdata/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看信息</view></view></view></block></view>