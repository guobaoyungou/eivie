ck qq:else><view style="font-size:28rpx;color:#686868;">请选择级别</view></block></view></view><view class="yejilabel"><block><block qq:if="{{userlevel}}"><view class="t1">{{$root.m0+"业绩："+(is_end==1?userinfo.team_yeji_total:'计算中')+" 元"}}</view></block></block></view></view></block><block qq:if="{{st==3}}"><view class="content"><view class="topsearch flex-y-center sx"><text class="t1">代理区域：</text><view class="t2">{{''+userinfo.areafenhong_adr+''}}</view></view></view></block><block qq:if="{{st==2||st==3}}"><view class="content"><view class="date-search"><view class="flex-bt"><view data-event-opts="{{[['tap',[['setDate',[1]]]]]}}" class="date-btn" style="{{(selectedDateRange==1?'color:#fff;background-color:'+$root.m1:'')}}" bindtap="__e">今日</view><view data-event-opts="{{[['tap',[['setDate',[2]]]]]}}" class="date-btn" style="{{(selectedDateRange==2?'color:#fff;background-color:'+$root.m2:'')}}" bindtap="__e">近七日</view><view data-event-opts="{{[['tap',[['setDate',[3]]]]]}}" class="date-btn" style="{{(selectedDateRange==3?'color:#fff;background-color:'+$root.m3:'')}}" bindtap="__e">近30日</view><view data-event-opts="{{[['tap',[['toSelectDate',['$event']]]]]}}" class="date-btn" style="{{(selectedDateRange==4?'color:#fff;background-color:'+$root.m4:'')}}" bindtap="__e">自定义</view></view><block qq:if="{{sdate&&edate}}"><view class="show-search-date">{{sdate+" / "+edate}}</view></block></view></view></block><block qq:if="{{datalist&&datalist.length>0&&st==1}}"><view class="content"><view class="label"><text class="t1">成员信息</text></view><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" bindtap="__e"><image src="{{item.headimg}}" mode="widthFix"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.id+")"}}</text><text class="x2">{{item.createtime}}</text><text class="x2">{{"等级："+item.levelname}}</text><block qq:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block></view></view><view class="f2"><block qq:if="{{userlevel&&userlevel.team_yeji==1}}"><text class="t4">{{$root.m5+"业绩："+item.teamyeji}}</text></block><block qq:if="{{userlevel&&userlevel.team_self_yeji==1}}"><text class="t4">{{"个人业绩："+item.selfyeji}}</text></block><block qq:if="{{userlevel&&userlevel.team_down_total==1}}"><text class="t4">{{$root.m6+"人数："+item.team_down_total+" 人"}}</text></block></view></view></block></block></view></block><block qq:if="{{orderlist&&orderlist.length>0&&(st==2||st==3)}}"><view class="content"><view class="label"><text class="t1">订单信息</text><text class="t2">分红</text></view><block qq:for="{{orderlist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><view class="t2"><text class="x1">{{item.title}}</text><text class="x2">{{"订单编号："+item.ordernum}}</text><text class="x2">{{item.createtime}}</text></view></view><view class="f2"><text class="t4">{{"订单金额："+item.totalprice}}</text><text class="t1">{{"+"+item.commission}}</text></view></view></block></block></view></block><block qq:if="{{levelDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择级别</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><view class="pstime-item" data-id="0" data-name="全部" data-event-opts="{{[['tap',[['levelRadioChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">全部</view><view class="radio" style="{{('')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block qq:for="{{allLevel}}" qq:for-item="item" qq:for-index="index" qq: