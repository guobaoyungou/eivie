<view class="container"><block qq:if="{{isload}}"><block><dd-tab vue-id="1732ad5a-1" itemdata="{{['全部','未提现','待审核','已提现','已驳回']}}" itemst="{{['all','0','1','3','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="list-item"><view class="item-row highlight"><view>{{"押金: "+item.money}}</view><block qq:if="{{item.istx&&item.status==0}}"><view><button class="btn-mini2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['tixian',['$event']]]]]}}" bindtap="__e">提现</button></view></block></view><view class="item-row"><view class="column"><text>{{"订单号: "+item.ordernum}}</text><text>{{"下单时间: "+item.createtime}}</text><block qq:if="{{item.status==0}}"><text style="color:black;">{{"押金状态: "+item.status_name}}</text></block><block qq:if="{{item.status==1}}"><text style="color:orange;">{{"押金状态: "+item.status_name}}</text></block><block qq:if="{{item.status==2}}"><text style="color:red;">{{"押金状态: "+item.status_name}}</text></block><block qq:if="{{item.status==3}}"><text style="color:green;">{{"押金状态: "+item.status_name}}</text></block><block qq:if="{{item.status==2&&item.reason}}"><text>{{"驳回原因: "+item.reason}}</text></block></view></view><view class="item-row"><block qq:if="{{item.diff}}"><text class="time">{{item.diff+"后可提现"}}</text></block></view></view></block></block></view><block qq:if="{{nodata}}"><nodata vue-id="1732ad5a-2" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="1732ad5a-3" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="1732ad5a-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="1732ad5a-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1732ad5a-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>