<view><block qq:if="{{isload}}"><block><view class="container"><block qq:if="{{bobaolist&&bobaolist.length>0}}"><view class="bobaobox"><swiper style="position:relative;height:54rpx;width:450rpx;" autoplay="true" interval="{{5000}}" vertical="true"><block qq:for="{{bobaolist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><swiper-item class="flex-y-center" data-url="{{item.tourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="width:400rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:22rpx;"><text style="padding-right:2px;">{{"第"+item.cycles+"期 中奖用户："}}</text><text style="padding-right:4px;">{{item.nickname}}</text></view></swiper-item></block></swiper></view></block><block qq:if="{{data.guize}}"><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" bindtap="__e">活动规则</button></block><view class="topbg"><block qq:if="{{data.bgpic}}"><image class="image" src="{{data.bgpic}}"></image></block><block qq:else><image class="image" src="{{pre_url+'/static/img/collage_teambg.png'}}"></image></block></view><block qq:for="{{data.product}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="{{['topbox',(index===0)?'first-topbox':'']}}" data-url="{{'/pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><image src="{{item.pic}}"></image></view><view class="right"><view class="f1">{{item.name}}</view><view class="f3" style="{{'color:'+($root.m0)+';'}}"><view class="t1">￥</view><view class="t2">{{item.sell_price}}</view></view></view></view></block><block qq:if="{{data.userlist}}"><view class="teambox"><view class="h2" style="{{'background:'+('rgba('+$root.m1+',0.2)')+';'+('color:'+($root.m2)+';')}}">{{"第"+data.cycles+"期 开奖活动"}}</view><view class="t1" style="{{('color:'+$root.m3+';text-align: center;')}}">{{data.custom_text}}</view><view class="userlist"><block qq:for="{{data.userlist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><image class="f1" src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image></view></block></view><view class="join-text"><view>仅剩<text class="join-te1">{{data.surplus}}</text>个名额</view></view><button data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="join-btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" bindtap="__e">邀请好友下单</button></view></block><block qq:if="{{winning}}"><view class="teambox"><view class="h2" style="{{'background:'+('rgba('+$root.m6+',0.2)')+';'+('color:'+($root.m7)+';')}}">{{"第"+data.cycles+"期 开奖结果"}}</view><view class="winning" style="text-align:center;"><view><image class="headimg" src="{{winning.member.headimg}}"></image></view><view>{{''+winning.member.nickname+''}}</view></view><view class="tb0"><view class="tr"><view class="td">奖品图片</view><view class="td">奖品名称</view></view><block qq:for="{{winning.award}}" qq:for-item="v" qq:for-index="k" qq:key="k"><view class="tr"><view class="td td2 flex-xy-center"><block qq:if="{{v.pic}}"><image class="td-img" src="{{v.pic}}" mode="widthFix"></image></block></view><block qq:if="{{v.type==3}}"><view class="td td2">{{v.name}}</view></block><block qq:else><view class="td td2">{{v.name+v.value}}</view></block></view></block></view></view></block></view><block qq:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block qq:if="{{$root.m8=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block qq:else><block qq:if="{{$root.m9=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block qq:else><block qq:if="{{$root.m10!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block qq:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><block qq:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule" style="{{'background:'+($root.m11)+';'}}"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{data.guize}}</text></view></view></view></view></block></block></block><block qq:if="{{loading}}"><loading vue-id="84678cac-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="84678cac-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="84678cac-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>