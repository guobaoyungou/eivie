<block qq:if="{{isload==1}}"><view class="container"><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><text class="t1" style="margin-bottom:10rpx;">{{item.remark}}</text><text class="t1">{{"兑换码："+item.code}}</text><block qq:if="{{item.total_take_times>1}}"><text class="t1">{{"总提货次数："+item.total_take_times+"次"}}</text></block><block qq:if="{{item.total_take_times>1}}"><text class="t1">{{"已提货次数："+item.take_times+"次"}}</text></block><text class="t2">{{"兑换时间："+item.createtime}}</text></view></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="92dafac0-1" bind:__l="__l"></nodata></block></view><block qq:if="{{nomore}}"><nomore vue-id="92dafac0-2" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="92dafac0-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="92dafac0-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="92dafac0-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>