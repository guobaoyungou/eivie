<view class="container"><block qq:if="{{isload}}"><block><view class="recorddetail"><view class="item"><text class="t1">标题：</text><text class="t2">{{$root.m0+"报销记录"}}</text></view><view class="item-pics"><view class="t1">已上传发票截图</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block qq:for="{{invoicepic}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="layui-imgbox"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view><view class="item-pics"><view class="t1">已上传现场消费照片</view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block qq:for="{{consumepic}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="layui-imgbox"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view><view class="item-pics"><view class="t1">OCR发票信息</view><view style="padding-bottom:20rpx;"><block qq:for="{{detail.invoice_data}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="layui-text">{{'发票编号：'+item.invoice_number+''}}</view></block></view></view><view class="item"><view class="t1">发票真伪</view><block qq:if="{{detail.authenticity==0}}"><text class="t2 red">发票存疑</text></block><block qq:if="{{detail.authenticity==1}}"><text class="t2 green">发票为真</text></block><block qq:if="{{detail.authenticity==-1}}"><text class="t2" style="color:#a0a0a0;">待辩真伪</text></block></view><view class="item"><text class="t1">提交人：</text><text class="t2"><view style="width:100rpx;height:100rpx;"><block qq:if="{{detail.userinfo.headimg}}"><image style="width:100%;height:100%;" src="{{detail.userinfo.headimg}}" mode></image></block></view>{{''+detail.userinfo.nickname+''}}</text></view><view class="item"><text class="t1">{{$root.m1+"ID："}}</text><text class="t2">{{detail.mid}}</text></view><view class="item"><text class="t1">提交时间：</text><text class="t2">{{detail.createtime}}</text></view><block qq:if="{{detail.status>0}}"><view class="item"><text class="t1">审核时间：</text><text class="t2">{{detail.operatetime}}</text></view></block><view class="item"><text class="t1">审核状态：</text><block qq:if="{{detail.status==0}}"><text class="t2 red">待审核</text></block><block qq:if="{{detail.status==1}}"><text class="t2 green">已通过</text></block><block qq:if="{{detail.status==2}}"><text class="t2 yellow">已驳回</text></block><block qq:if="{{detail.status==3}}"><text class="t2">已关闭</text></block></view><view class="item"><text class="t1">打款状态：</text><block qq:if="{{detail.payment_status==0}}"><text class="t2">未打款</text></block><block qq:if="{{detail.payment_status==1}}"><text class="t2 red">待打款</text></block><block qq:if="{{detail.payment_status==2}}"><text class="t2 green">已打款</text></block><block qq:if="{{detail.payment_status==3}}"><text class="t2">已关闭</text></block></view><block qq:if="{{detail.deduct_score}}"><view class="item"><text class="t1">{{"扣除"+$root.m2+"："}}</text><text class="t2">{{detail.deduct_score}}</text></view></block><block qq:if="{{detail.money}}"><view class="item"><text class="t1">打款金额：</text><text class="t2">{{detail.money}}</text></view></block><block qq:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因：</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block></view><view style="width:100%;height:160rpx;"></view><view class="bottom"><block qq:if="{{detail.status==0&&detail.payment_status==0}}"><block><view data-event-opts="{{[['tap',[['pass',[1]]]]]}}" class="btn2" bindtap="__e">通过</view><view data-event-opts="{{[['tap',[['nopassPopup',['$event']]]]]}}" class="btn2" bindtap="__e">驳回</view></block></block><block qq:if="{{detail.status==1&&detail.payment_status==1}}"><block><view data-event-opts="{{[['tap',[['nopassPopup',['$event']]]]]}}" class="btn2" bindtap="__e">驳回</view><view data-event-opts="{{[['tap',[['dakuan',['$event']]]]]}}" class="btn2" bindtap="__e">已打款</view></block></block><block qq:if="{{detail.payment_status<2}}"><block><view class="btn2" data-url="{{'adminedit?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">编辑</view><view data-event-opts="{{[['tap',[['pass',[3]]]]]}}" class="btn2" bindtap="__e">关闭</view></block></block></view><uni-popup class="vue-ref" vue-id="1ccb0140-1" id="dialogNopass" type="dialog" data-ref="dialogNopass" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('1ccb0140-2')+','+('1ccb0140-1')}}" mode="input" title="确定要驳回申请吗？" placeholder="请输入驳回原因" data-event-opts="{{[['^confirm',[['nopass']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup></block></block><block qq:if="{{loading}}"><loading vue-id="1ccb0140-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1ccb0140-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1ccb0140-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="1ccb0140-6" bind:__l="__l"></wxxieyi></view>