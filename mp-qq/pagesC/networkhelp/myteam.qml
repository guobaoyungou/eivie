<view class="container"><block qq:if="{{isload}}"><block><block><dd-tab vue-id="4fdc9ae5-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block qq:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text></view><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><image src="{{item.headimg}}" mode="widthFix"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.mid+")"}}</text><text class="x2">{{"等级："+item.level_name}}</text><block qq:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block qq:if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block></view></view></view></block></block></view></block></block></block><block qq:if="{{nodata}}"><nodata vue-id="4fdc9ae5-2" bind:__l="__l"></nodata></block><block qq:if="{{nomore}}"><nomore vue-id="4fdc9ae5-3" bind:__l="__l"></nomore></block><block qq:if="{{loading}}"><loading vue-id="4fdc9ae5-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="4fdc9ae5-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4fdc9ae5-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>