.wrap{background:#fff;padding:30rpx;height:auto}.top{margin-top:60rpx;padding:50rpx;justify-content:space-between}.top .f1 .t1{display:block;color:#fff;font-size:44rpx}.top .f1 .t2{font-size:26rpx;color:hsla(0,0%,100%,.8);margin-top:30rpx;display:block}.content{background:#fff;padding:80rpx;border-radius:20rpx}.content .c_1{justify-content:space-between;padding:0 80rpx}.content .c_1 .f2 text{display:block}.content .c_1 .f2 .t1{font-size:64rpx;font-weight:700;color:#222;text-align:center}.content .c_1 .f2 .t2{color:#93949e;font-size:24rpx;margin-top:20rpx}.content .list1{line-height:60rpx}.content .list1 .t3{font-size:26rpx;color:#222}.content .list1 .t4{display:inline-block;margin-left:40rpx;color:#93949e}.content .c_2{margin-top:50rpx}.aginbtn{margin-top:80rpx;text-align:center;color:#fff;border-radius:40rpx;height:88rpx;line-height:88rpx;font-size:32rpx}.top .score{width:160rpx;height:160rpx}.bottom .btn2{background-color:rgba(255,0,0,.3);width:240rpx;color:#ff5347;margin-top:50rpx;height:88rpx;text-align:center;font-weight:700;font-size:32rpx;line-height:88rpx;border-radius:40rpx}.bottom .btn3{background-color:#eee;width:240rpx;color:#222;margin-top:50rpx;height:88rpx;text-align:center;font-weight:700;font-size:32rpx;line-height:88rpx;border-radius:40rpx;margin-left:30rpx}.score .t1{color:#fff;font-size:64rpx;font-weight:700;text-align:center;display:inline-block;margin-left:30rpx;margin-top:20rpx}.score .t2{color:hsla(0,0%,100%,.8)}