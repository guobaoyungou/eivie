<view class="container"><block qq:if="{{isload}}"><block><dd-tab vue-id="bdcd2bf8-1" itemdata="{{['消费明细','还款记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block qq:if="{{st==0}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block qq:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block qq:else><text class="t2">{{item.money}}</text></block></view></view></block></block></block><block qq:if="{{st==1}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{"还款金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block qq:if="{{item.status==0}}"><text class="t1">还款失败</text></block><block qq:if="{{item.status==1}}"><text class="t2">还款成功</text></block></view></view></block></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="bdcd2bf8-2" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="bdcd2bf8-3" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="bdcd2bf8-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="bdcd2bf8-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="bdcd2bf8-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>