<view class="container"><block qq:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{myxiaofei}}</view></view><view class="content" id="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block qq:if="{{item.commission>0}}"><block><text class="t1">{{"+"+item.commission}}</text></block></block><block qq:else><block><text class="t2">{{item.commission}}</text></block></block></view></view></block></block><block qq:if="{{nodata}}"><nodata vue-id="4ef05f6a-1" bind:__l="__l"></nodata></block></view><block qq:if="{{nomore}}"><nomore vue-id="4ef05f6a-2" bind:__l="__l"></nomore></block></block></block><block qq:if="{{loading}}"><loading vue-id="4ef05f6a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="4ef05f6a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4ef05f6a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>