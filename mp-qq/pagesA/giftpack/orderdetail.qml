<view class="container"><block qq:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block qq:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view></view></block><block qq:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view></view></block><block qq:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已核销</view></view></block><block qq:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="orderinfo"><view class="item" data-url="{{'list?gbid='+detail.gbid+'&bid='+detail.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">礼包</text><text class="t2" user-select="true" selectable="true">{{detail.proname}}</text></view></view><view class="product"><view class="box"><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+detail.giftid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{detail.pic}}"></image></view><view class="detail" style="display:block;"><view><text class="t1">{{detail.name}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.sell_price}}</text></view><view class="t4">{{"赠送积分："+detail.givescore}}</view><view class="t5">赠送优惠券：<block qq:for="{{couponlist}}" qq:for-item="item" qq:for-index="index"><block><view>{{item.name}}</view></block></block></view></view></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block qq:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block qq:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block qq:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">核销完成时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.sell_price}}</text></view><view class="item"><text class="t1">订单状态</text><block qq:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block qq:if="{{detail.status==1}}"><text class="t2">已付款</text></block></view></view></block></block><block qq:if="{{loading}}"><loading vue-id="4049d7d7-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="4049d7d7-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4049d7d7-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>