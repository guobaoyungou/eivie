<view class="container"><block qq:if="{{isload}}"><block><dd-tab vue-id="12c5a9da-1" itemdata="{{['全部','待验货','返款中','已返款']}}" itemst="{{['all','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view style="width:94%;margin:0rpx 3%;padding:10rpx;background-color:#fff;display:flex;justify-content:space-between;line-height:70rpx;"><view>{{'总待返金额:￥'+inmoney+''}}</view><view>{{'总已返金额:￥'+endmoney+''}}</view></view><view class="order-content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="order-box" data-url="{{'handDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head" style="justify-content:space-between;"><block qq:if="{{item.binfo}}"><block><view class="f1">{{"回寄单号 "+item.hand_ordernum}}</view></block></block><block qq:if="{{item.status==0}}"><text class="st0">待验货</text></block><block qq:if="{{item.status==1&&item.issend==0}}"><text class="st4">已验货,待返款</text></block><block qq:if="{{item.status==1&&item.issend==1}}"><text class="st4">已验货,已返款</text></block></view><block qq:for="{{item.prolist}}" qq:for-item="item2" qq:for-index="idx" qq:key="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><text class="t2">{{"手工费："+item2.hand_fee}}</text><text class="t2">{{"回寄数量："+item2.hand_num}}</text></view></view></block></block><block qq:if="{{item.status==1}}"><view class="bottom"><text class="t2">{{"总计返款：￥"+item.totalmoney}}</text><block qq:if="{{item.issend==0}}"><text style="color:red;margin-left:10rpx;">待返款</text></block><block qq:if="{{item.issend==1}}"><text style="color:grey;margin-left:10rpx;">已返款</text></block></view></block><view class="op"><view class="btn2" data-url="{{'handDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view></view></view></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="12c5a9da-2" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="12c5a9da-3" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="12c5a9da-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="12c5a9da-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="12c5a9da-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>