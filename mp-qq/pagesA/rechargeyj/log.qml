<view class="container"><block qq:if="{{isload}}"><block><dd-tab vue-id="f0347faa-1" itemdata="{{['业绩明细','提现记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block qq:if="{{st==0}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><block qq:if="{{item.remark}}"><text class="t2">{{item.remark}}</text></block><block qq:if="{{item.money>0}}"><text class="t2">{{"充值金额："+item.money}}</text></block><text class="t2">{{item.createtime}}</text></view><view class="f2"><block qq:if="{{item.get_yj>0}}"><text class="t1">{{"+"+item.get_yj}}</text></block><block qq:else><text class="t2">{{item.get_yj}}</text></block></view></view></block></block></block><block qq:if="{{st==1}}"><block><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现业绩："+item.rechargeyj_money}}</text><text class="t1">{{"金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block qq:if="{{item.status==0}}"><text class="t1">审核中</text></block><block qq:if="{{item.status==1}}"><text class="t1">已审核</text></block><block qq:if="{{item.status==2}}"><text class="t2">已驳回</text></block><block qq:if="{{item.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="f0347faa-2" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="f0347faa-3" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="f0347faa-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="f0347faa-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f0347faa-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>