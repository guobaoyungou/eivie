<view class="container"><block qq:if="{{isload}}"><block><view class="order-content"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="order-box" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head" style="justify-content:space-between;"><block qq:if="{{item.ordernum}}"><view class="f1">{{"订单号:"+item.ordernum}}</view></block><block qq:else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></view><block qq:for="{{item.prolist}}" qq:for-item="item2" qq:for-index="idx" qq:key="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.pic}}" mode="aspectFill"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><block><block qq:if="{{item2.product_type&&item2.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item2.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item2.real_total_weight+"斤"}}</text></view></block><block qq:else><view class="t3"><text class="x1 flex1">{{'￥'+item2.sell_price+''}}</text><text class="x2">{{"×"+item2.num}}</text></view></block></block></view></view></block></block><block qq:if="{{item.mid||item.nickname}}"><view class="bottom" style="display:flex;"><block qq:if="{{item.mid}}"><view>{{"ID:"+item.mid}}</view></block><block qq:if="{{item.nickname}}"><view style="margin-left:10rpx;">{{item.nickname}}</view></block></view></block><view class="bottom"><view>{{'共计'+item.procount+"件商品 实付:￥"+item.totalprice+''}}</view></view><block qq:if="{{item.tips!=''}}"><view class="bottom"><text style="color:red;">{{item.tips}}</text></view></block></view></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="6729fcc2-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="6729fcc2-2" bind:__l="__l"></nodata></block></block></block><block qq:if="{{loading}}"><loading vue-id="6729fcc2-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="6729fcc2-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="6729fcc2-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>