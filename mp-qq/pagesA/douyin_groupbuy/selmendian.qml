<view><block qq:if="{{isload}}"><block><view style="width:100%;background-color:#fff;padding:10rpx 0;"><view class="wc"><view class="head_mdname">{{'当前门店：'+mdname+''}}</view><view class="head_search"><image class="search_img" src="/static/xinxixie/search.png"></image><input style="height:80rpx;line-height:80rpx;width:100%;" placeholder="搜索门店" placeholder-style="line-height: 80rpx;color:#8282A7" data-event-opts="{{[['input',[['searchdata',['$event']]]]]}}" bindinput="__e"/></view></view></view><view style="margin-top:20rpx;"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index"><block><view class="list_wc" data-mdid="{{item.id}}" data-mdname="{{item.name}}" data-mdlng="{{item.longitude}}" data-mdlat="{{item.latitude}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" bindtap="__e"><view class="list_img"><image style="width:200rpx;height:200rpx;" src="{{item.pic}}"></image></view><view style="width:440rpx;"><view class="list_title">{{''+item.name+''}}</view><view class="list_local"><image class="local_img" src="/static/xinxixie/local2.png"></image>{{''+item.area+item.address+''}}</view><block qq:if="{{item.tel}}"><view class="list_local" style="white-space:nowrap;text-overflow:ellipsis;overflow:hidden;" data-phone="{{item.tel?item.tel:''}}"><image class="local_img" src="/static/xinxixie/tel2.png"></image>{{''+item.tel+''}}</view></block><view style="margin-top:10rpx;font-size:24rpx;">{{''+item.len+''}}</view><view style="width:150rpx;line-height:70rpx;text-align:center;color:#333;border-radius:70rpx;position:absolute;right:20rpx;bottom:40rpx;border:2rpx solid #eee;" data-mdid="{{item.id}}" data-mdname="{{item.name}}" data-mdlng="{{item.longitude}}" data-mdlat="{{item.latitude}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" catchtap="__e">选择</view></view></view></block></block><block qq:if="{{nomore}}"><nomore vue-id="1a149fa9-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="1a149fa9-2" bind:__l="__l"></nodata></block></view></block></block><block qq:if="{{loading}}"><loading vue-id="1a149fa9-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1a149fa9-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1a149fa9-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>