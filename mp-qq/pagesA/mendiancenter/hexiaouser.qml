<view><block qq:if="{{isload}}"><block><block qq:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"核销员列表（共"+count+"人）"}}</text></view><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2">{{''+item.nickname+''}}</view></view><view class="f2">已核销订单:<text style="color:red;">{{item.hxnum}}</text></view><view class="f3 btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" bindtap="__e">删除</view></view></block></block></view></block><block qq:if="{{nomore}}"><nomore vue-id="4bdb8a57-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="4bdb8a57-2" bind:__l="__l"></nodata></block><view class="btn-add" style="{{'background:'+($root.m0)+';'}}" data-url="{{'addhexiao?mdid='+mdid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加核销员</view></block></block><popmsg class="vue-ref" vue-id="4bdb8a57-3" data-ref="popmsg" bind:__l="__l"></popmsg><block qq:if="{{loading}}"><loading vue-id="4bdb8a57-4" bind:__l="__l"></loading></block></view>