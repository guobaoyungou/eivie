<view><block qq:if="{{isload}}"><block><view class="container"><view class="datalist"><block qq:for="{{datalist}}" qq:for-item="item" qq:for-index="index" qq:key="index"><block><view class="collage-product" data-url="{{'/activity/shortvideo/detail?id='+item.vid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2" style="display:flex;color:#888;"><view style="width:100%;">次数：<text style="color:#000;">{{item.num}}</text></view><view style="width:100%;">进度：<text style="color:#000;">{{item.jindu+"%"}}</text></view></view></view></view></block></block></view><block qq:if="{{nomore}}"><nomore vue-id="55120d9a-1" bind:__l="__l"></nomore></block><block qq:if="{{nodata}}"><nodata vue-id="55120d9a-2" bind:__l="__l"></nodata></block></view></block></block><block qq:if="{{loading}}"><loading vue-id="55120d9a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="55120d9a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="55120d9a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>