<block tt:if="{{isload}}"><view style="{{'display:flex;flex-direction:column;'+('background:'+(params.bgcolor)+';')}}" class="data-v-24fcad7a"><block tt:if="{{params.showdate==1}}"><view class="screen data-v-24fcad7a"><view class="screen_module data-v-24fcad7a"><view class="screen_content data-v-24fcad7a" scroll-x="true"><block tt:for="{{datelist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view data-event-opts="{{[['tap',[['dateClick',[index]]]]]}}" class="{{((('screen_item')+' '+'data-v-24fcad7a')+' '+(dateIndex==index?'screen_active':''))}}" bindtap="__e"><view class="screen_text data-v-24fcad7a">{{item.date}}</view><view class="screen_text data-v-24fcad7a">{{item.week}}</view></view></block></view></view></view></block><block tt:else><view style="width:100%;height:40rpx;" class="data-v-24fcad7a"></view></block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="module data-v-24fcad7a"><view class="module_data data-v-24fcad7a" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" bindtap="__e"><image class="module_img data-v-24fcad7a" src="{{item.pic}}" alt></image><view class="module_content data-v-24fcad7a"><view class="module_title data-v-24fcad7a">{{item.name}}</view><block tt:if="{{item.feature}}"><view class="module_item data-v-24fcad7a">{{item.feature}}</view></block><block tt:if="{{item.cid!=2}}"><view class="module_item data-v-24fcad7a"><block tt:if="{{item.cid==1}}"><text class="data-v-24fcad7a">租车</text></block><block tt:else><text class="data-v-24fcad7a">包车</text></block>费用：<text class="txt-yel data-v-24fcad7a">{{"￥"+item.sell_price}}</text>/天</view></block><block tt:else><view class="module_item data-v-24fcad7a">拼车费用：<text class="txt-yel data-v-24fcad7a">{{"￥"+item.sell_price}}</text>/人</view></block></view><block tt:if="{{item.cid==2}}"><view class="data-v-24fcad7a"><block tt:if="{{item.yystatus==0&&item.leftnum>0}}"><view data-event-opts="{{[['tap',[['feiyuyue',['$event']]]]]}}" class="module_btn module_end data-v-24fcad7a" catchtap="__e">非预约时间</view></block><block tt:else><block class="data-v-24fcad7a"><block tt:if="{{item.leftnum>0}}"><view class="module_btn data-v-24fcad7a">预约</view></block><block tt:else><view class="module_btn module_end data-v-24fcad7a">满员</view></block></block></block></view></block><block tt:else><block tt:if="{{item.cid==1}}"><view class="data-v-24fcad7a"><view class="module_btn  data-v-24fcad7a">租车</view></view></block><block tt:else><view class="data-v-24fcad7a"><view class="module_btn  data-v-24fcad7a">包车</view></view></block></block></view><block tt:if="{{item.cid==2}}"><view class="module_num data-v-24fcad7a"><view class="module_lable data-v-24fcad7a"><view class="data-v-24fcad7a">当前</view><view class="data-v-24fcad7a">预约</view></view><view class="module_view data-v-24fcad7a"><block tt:for="{{item.yyorderlist}}" tt:for-item="item2" tt:for-index="index2"><block class="data-v-24fcad7a"><image src="{{item2.headimg}}" class="data-v-24fcad7a"></image></block></block></view><block tt:if="{{item.leftnum>0}}"><view class="module_tag data-v-24fcad7a">{{"剩余"+item.leftnum+"个名额"}}</view></block><block tt:else><view class="module_tag module_end data-v-24fcad7a">满员</view></block></view></block></view></block><block tt:if="{{alertState}}"><view class="alert data-v-24fcad7a"><view data-event-opts="{{[['tap',[['alertClick',['$event']]]]]}}" class="alert_none data-v-24fcad7a" bindtap="__e"></view><view class="alert_module data-v-24fcad7a"><view class="alert_opt data-v-24fcad7a"><view class="alert_table data-v-24fcad7a"><view class="{{((('alert_view')+' '+'data-v-24fcad7a')+' '+(filterType==0?'alert_active':''))}}" data-type="{{0}}" data-event-opts="{{[['tap',[['changefilterType',['$event']]]]]}}" catchtap="__e">类别</view><view class="{{((('alert_view')+' '+'data-v-24fcad7a')+' '+(filterType==1?'alert_active':''))}}" data-type="{{1}}" data-event-opts="{{[['tap',[['changefilterType',['$event']]]]]}}" catchtap="__e">时段</view></view><view data-event-opts="{{[['tap',[['filterClean',['$event']]]]]}}" class="alert_cancel data-v-24fcad7a" catchtap="__e">清空</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="alert_btn data-v-24fcad7a" catchtap="__e">确认</view></view><block tt:if="{{filterType==0}}"><scroll-view class="alert_box data-v-24fcad7a" scroll-y="true"><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index"><view class="{{(((('alert_item')+' '+'')+' '+'data-v-24fcad7a')+' '+(cachecid==item.id?'alert_current':''))}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['changecid',['$event']]]]]}}" catchtap="__e">{{item.name}}</view></block></scroll-view></block><block tt:if="{{filterType==1}}"><scroll-view class="alert_box data-v-24fcad7a" scroll-y="true"><block tt:for="{{timerangelist}}" tt:for-item="item" tt:for-index="index"><view class="{{(((('alert_item')+' '+'')+' '+'data-v-24fcad7a')+' '+(cachetimerange==index?'alert_current':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changetimerange',['$event']]]]]}}" catchtap="__e">{{item.rangestr}}</view></block></scroll-view></block></view></view></block></view></block>