<scroll-view class="wxface-dialog" id="facedialog" scroll-y="true"><block tt:for="{{facelist}}" tt:for-item="item" tt:for-index="index"><block tt:if="{{index!=24&&index!=35}}"><view class="wxface-face-item" data-face="{{item}}" data-event-opts="{{[['tap',[['selectface',['$event']]]]]}}" bindtap="__e"><image class="wxface-face-image" src="{{pre_url+'/static/chat/wxface/'+index+'.png'}}"></image></view></block></block></scroll-view>