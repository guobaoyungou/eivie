<block tt:if="{{!scroll}}"><view class="dd-tab" style="{{(isfixed?'position:fixed;':'')}}"><block tt:for="{{itemdata}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m0)+';'}}"></view></view></block></view></block><block tt:else><view class="dd-tab2" style="{{(isfixed?'position:fixed;':'')}}"><scroll-view scroll-x="true"><block tt:if="{{ismoney}}"><view class="dd-tab2-content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block tt:if="{{showstatus[index]}}"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item.$orig}}<view class="after" style="{{'background:'+(color1?color1:item.m1)+';'}}"></view></view></block></block></view></block><block tt:else><view class="dd-tab2-content"><block tt:for="{{itemdata}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{(('item')+' '+(st==itemst[index]?'on':''))}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m2)+';'}}"></view></view></block></view></block></scroll-view></view></block>