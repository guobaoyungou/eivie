<view class="dp-wxad" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block tt:if="{{params.adtype=='banner'}}"><ad unit-id="{{params.unitid}}"></ad></block><block tt:if="{{params.adtype=='video'}}"><ad unit-id="{{params.unitid}}" ad-type="video" ad-theme="white"></ad></block><block tt:if="{{params.adtype=='custom'}}"><ad-custom vue-id="3c649bd6-1" unit-id="{{params.unitid}}" bind:__l="__l"></ad-custom></block></view>