<transition vue-id="43db5da1-1" name="{{transition}}" class="data-v-47321aa9" bind:__l="__l" vue-slots="{{['default']}}"><block tt:if="{{isShow}}"><view class="{{(((('calendar-tz')+' '+'_div')+' '+'data-v-47321aa9')+' '+(isFixed&&'fixed'))}}"><slot name="header"></slot><view class="week-number _div data-v-47321aa9"><block tt:for="{{weekList}}" tt:for-item="item" tt:for-index="index" tt:key="index"><label style="{{'color:'+((index==0||index==weekList.length-1)&&themeColor)+';'}}" class="_span data-v-47321aa9">{{item}}</label></block></view><block tt:if="{{title}}"><view class="tips _p data-v-47321aa9">{{title}}</view></block><view class="content _div data-v-47321aa9" id="scrollWrap"><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="con _div data-v-47321aa9" id="{{item.$orig.year+''+item.$orig.month}}"><view class="_h3 data-v-47321aa9">{{item.$orig.year+'年'+item.$orig.month+'月'}}</view><label class="month-bg _span data-v-47321aa9" style="{{'color:'+(getBetweenColor)+';'}}">{{item.$orig.month}}</label><view class="each-month _ul data-v-47321aa9"><block tt:for="{{item.l0}}" tt:for-item="day" tt:for-index="idx" tt:key="idx"><view data-event-opts="{{[['tap',[['chooseDate',['$0','$1','$2'],[[['calendar','',index],['dayList','',idx]],[['calendar','',index,'month']],[['calendar','',index,'year']]]]]]]}}" class="{{(((('each-day')+' '+'_li')+' '+'data-v-47321aa9')+' '+day.m0)}}" style="{{'background:'+(day.m1)+';'}}" bindtap="__e"><block tt:if="{{mode!=4}}"><view class="{{((('_div')+' '+'data-v-47321aa9')+' '+day.m2)}}" style="{{'background:'+(day.m3)+';'}}"><view class="day _p data-v-47321aa9">{{day.$orig?day.$orig:''}}</view><block tt:if="{{day.m4}}"><view class="recent _p data-v-47321aa9"><view class="_i data-v-47321aa9">{{day.m5}}</view></view></block></view></block><block tt:else><view class="{{((('_div')+' '+'data-v-47321aa9')+' '+day.m6)}}"><view class="day _p data-v-47321aa9">{{day.$orig?day.$orig:''}}</view><view class="r