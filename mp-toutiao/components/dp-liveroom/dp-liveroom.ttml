<view class="dp-liveroom" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><view class="dp-liveroom-liveroom"><block tt:for="{{data}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="item" style="{{'margin-right:'+(index%2==0?'2%':'0')+';'}}" data-url="{{'plugin-private://wx2b03c6e691cd7370/pages/live-player-plugin?room_id='+item.roomId}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="bgpic"><image class="image" src="{{item.coverImg}}" mode="widthFix"></image></view><block tt:if="{{item.status=='0'}}"><view class="f1"><view class="t1">预告</view><view class="t2">{{item.showtime}}</view></view></block><block tt:if="{{item.status=='1'}}"><view class="f2"><image class="t1" src="{{pre_url+'/static/img/liveing.gif'}}"></image><view class="t2">直播中</view></view></block><block tt:if="{{item.status=='2'}}"><view class="f3"><view class="t1">已结束</view></view></block><view class="f10"><view class="title">{{item.name}}</view></view></view></block></view></view>