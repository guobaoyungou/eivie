<view style="width:100%;"><view class="dp-product-itemlist"><block tt:for="{{data}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="item" data-url="{{'/activity/yuyue/product?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block tt:if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block tt:if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><block tt:if="{{showprice!='0'}}"><view class="p2"><view class="t1" style="{{'color:'+($root.m0)+';'}}">{{item.sell_price}}<text style="font-size:24rpx;padding-left:4rpx;">{{"元/"+item.danwei}}</text></view></view></block><view class="p3"><block tt:if="{{showsales=='1'&&item.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.sales}}</text></view></block></view></view></view></block></view><block tt:if="{{buydialogShow}}"><buydialog vue-id="02eb7ffb-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e" bind:__l="__l"></buydialog></block></view>