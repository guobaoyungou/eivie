<block tt:if="{{isload}}"><view><view class="content"><block tt:if="{{djs>0}}"><view class="djs">{{djs}}</view></block><block tt:else><view class="djs"><text class="t1">已阅</text></view></block><view class="bottom"><block tt:if="{{sharegive.isanswer}}"><view class="tips">请浏览<text class="t1">{{djs?djs:0}}</text>秒并回答问题在分享</view></block><block tt:else><view class="tips">请浏览<text class="t1">{{djs?djs:0}}</text>秒后在分享</view></block><view class="btnbox"><block tt:if="{{sharegive.isanswer}}"><view data-event-opts="{{[['tap',[['toanswer',['$event']]]]]}}" class="btn1" style="{{'background-color:'+($root.m0)+';'}}" bindtap="__e">回答问题</view></block><block tt:if="{{$root.m1}}"><button data-event-opts="{{[['tap',[['toshare',['$event']]]]]}}" class="{{('btn2 '+(sharegive.isanswer?'btn3':''))}}" style="{{'background-color:'+($root.m2)+';'}}" catchtap="__e"><image src="{{pre_url+'/static/img/share_white.png'}}"></image>我要分享</button></block><block tt:else><button class="{{('btn2 '+(sharegive.isanswer?'btn3':''))}}" style="{{'background-color:'+($root.m3)+';'}}" open-type="share" data-callback="sharegive" data-id="{{sharegive.id}}" data-isanswer="{{isanswer}}"><image src="{{pre_url+'/static/img/share_white.png'}}"></image>我要分享</button></block></view></view></view><block tt:if="{{showanswer}}"><view class="modal"><view class="question"><view data-event-opts="{{[['tap',[['toclosed',['$event']]]]]}}" class="close" bindtap="__e"><image class="buydialog-canimg" src="{{pre_url+'/static/img/close.png'}}"></image></view><block tt:if="{{!is_right}}"><block><view class="title">{{'题目：'+tkdata.title+''}}</view><block tt:if="{{tkdata.rightcount==1}}"><block><view class="option_group"><block tt:for="{{tkdata.option}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{('option flex '+(index==currentindex?'on':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" bindtap="__e">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item}}</view></view></block></view></block></block><block tt:if="{{tkdata.rightcount>1}}"><block><view class="option_group"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{('option flex '+(item.g0!=-1?'on':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" catchtap="__e">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item.$orig}}</view></view></block></view></block></block><view class="bottoms flex"><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m4)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" catchtap="__e">提交</button></view></block></block><block tt:if="{{is_right==1}}"><view class="right_content"><view class="right-image"><image src="{{pre_url+'/static/img/share_right.png'}}"></image><text class="t1">回答正确</text></view><block tt:if="{{hasnum<nums}}"><view class="bottoms flex"><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m5)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['toanswer',['$event']]]]]}}" bindtap="__e">下一题</button></view></block><block tt:else><block tt:if="{{rightnums>=nums}}"><view class="end">答题完成，立即分享赚取奖励吧</view></block><block tt:else><block tt:if="{{rightnums<nums}}"><view class="end">未正确完成所有题目，请再接再励！</view></block></block></block></view></block><block tt:if="{{is_right==2}}"><view class="right_content"><view class="right-image"><image src="{{pre_url+'/static/img/share_error.png'}}"></image><text class="t1">回答错误</text><text class="t2">{{"正确答案："+right_options}}</text></view><block tt:if="{{hasnum<nums}}"><view class="bottoms flex"><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m6)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['toanswer',['$event']]]]]}}" bindtap="__e">下一题</button></view></block><block tt:else><view class="end">未正确完成所有题目，请再接再励！</view></block></view></block></view></view></block><block tt:if="{{loading}}"><loading vue-id="2254e781-1" bind:__l="__l"></loading></block></view></block>