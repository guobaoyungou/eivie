<view><view class="{{(('mask')+' '+((showPicker)?'maskShow':''))}}" catchtouchmove="__e" data-event-opts="{{[['tap',[['hide',['$event']],['',['$event']]]],['touchmove',[['',['$event']]]]]}}" catchtap="__e"></view><view class="{{(('cpicker-content')+' '+((showPicker)?'cpickerShow':''))}}"><view class="city-head" catchtouchmove="__e" data-event-opts="{{[['tap',[['',['$event']]]],['touchmove',[['',['$event']]]]]}}" catchtap="__e"><view class="city-head-title">{{headtitle}}</view><block tt:if="{{rightIcon}}"><text data-event-opts="{{[['tap',[['hide',['self']]]]]}}" class="rightIcon iconfont icon-quxiao" bindtap="__e"></text></block></view><scroll-view class="nav-bar" id="nav-bar" scroll-x="true" scroll-with-animation="true" scroll-left="{{scrollLeft}}"><block tt:for="{{tabbars}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{(('nav-item')+' '+((index===tabCurrentIndex)?'current':''))}}" id="{{'tab'+index}}" data-event-opts="{{[['tap',[['changeTab',[index]]]]]}}" bindtap="__e"><text class="nav-bar-title">{{item.text}}</text></view></block></scroll-view><view class="city_content"><scroll-view class="panel-scroll-box" scroll-y="{{enableScroll}}" cscrollTop="{{scrollTop}}" current="{{tabCurrentIndex}}" scroll-top="{{scrollTop}}"><block tt:for="{{showData}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view data-event-opts="{{[['tap',[['changCity',['$0','$1'],['tabCurrentIndex',[['showData','',index]]]]]]]}}" class="flex-row-c-c" bindtap="__e"><block tt:if="{{tabbars[tabCurrentIndex].value==item.value}}"><icon class="ischeck" type="success_no_circle" id="{{'show'+tabCurrentIndex}}" size="14" color="#00B1B7"></icon></block><text class="city-text">{{item.text}}</text></view></block></block></scroll-view></view></view></view>