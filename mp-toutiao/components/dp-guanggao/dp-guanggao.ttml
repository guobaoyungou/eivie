<view><block tt:if="{{guanggaotype!=3&&(guanggaopic||param.unitid)&&guanggaostatus=='1'&&hasLaunchedad}}"><block><view data-event-opts="{{[['touchmove',[['',['$event']]]]]}}" class="{{((('advert')+' '+'flex-xy-center')+' '+(param.ggcover=='1'?'advert_cover':''))}}" catchtouchmove="__e"><view class="advert_module"><block tt:if="{{guanggaotype=='1'}}"><block><block tt:if="{{guanggaotype=='1'&&param.ggcover=='1'&&param.ggskip=='1'&&param.skiptype!=2}}"><image class="advert_close_img" src="{{pre_url+'/static/img/close2.png'}}" alt data-event-opts="{{[['tap',[['guanggaoClick',['$event']]]]]}}" bindtap="__e"></image></block><image class="advert_poster" src="{{guanggaopic}}" data-url="{{guanggaourl}}" mode="{{param.ggcover=='1'?'acceptFill':'widthFix'}}" alt data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image></block></block><block tt:if="{{guanggaotype=='4'}}"><block><dp-wxad vue-id="5eb877ea-1" params="{{param}}" bind:__l="__l"></dp-wxad></block></block><block tt:if="{{(guanggaotype=='1'||guanggaotype=='4')&&param.ggcover!='1'&&param.ggskip=='1'}}"><view data-event-opts="{{[['tap',[['guanggaoClick',['$event']]]]]}}" class="advert_close advert_close_bottom flex-xy-center" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}" alt></image></view></block></view></view><block tt:if="{{guanggaotype=='2'}}"><view class="{{(('advert_video')+' '+(param.ggcover=='1'?'advert_cover':''))}}"><block tt:if="{{guanggaotype=='2'&&param.ggcover=='1'&&param.ggskip=='1'&&param.skiptype!=2}}"><text data-event-opts="{{[['tap',[['guanggaoClick',['$event']]]]]}}" class="advert_close_txt" bindtap="__e">跳过</text></block><video class="dp-guanggao-video" style="{{'max-width:100%;height:850rpx;'+('height:'+(windowHeight+'px')+';')+('width:'+('100%')+';')}}" src="{{guanggaopic}}" show-mute-btn="{{true}}" play-btn-position="center" object-fit="{{param.ggcover==1?'cover':''}}" controls="{{false}}" autoplay="{{true}}" loop="{{false}}" show-center-play-btn="{{cpbtn}}" data-event-opts="{{[['ended',[['playend',['$event']]]]]}}" bindended="__e"></video><block tt:if="{{isend}}"><view data-event-opts="{{[['tap',[['guanggaoClick',['$event']]]]]}}" class="advert_close advert_close_top flex-xy-center" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}" alt></image></view></block></view></block><block tt:if="{{(param.showgg=='2'||param.showgg=='1'&&param.ggcover=='1')&&param.ggskip=='1'&&param.skiptype==2}}"><view data-event-opts="{{[['tap',[['guanggaoClick',['$event']]]]]}}" class="dp-bottom-close-btn" bindtap="__e"><view class="dp-ggskip-btn">跳过</view></view></block></block></block></view>