.form-item{width:100%;background:#fff;padding:32rpx 20rpx}.form-item .label{width:100%;height:60rpx;line-height:60rpx}.form-item .input-item{width:100%}.form-item textarea{width:100%;height:200rpx;border:1px #eee solid;padding:20rpx}.form-item input{width:100%;border:1px #eee solid;padding:0 10rpx;height:80rpx;line-height:80rpx}.form-item .mid{height:80rpx;line-height:80rpx;padding:0 20rpx}.ref-btn{width:90%;margin:0 5%;height:40px;line-height:40px;text-align:center;color:#fff;font-size:16px;border-radius:8px;border:none;background:#ff8758}