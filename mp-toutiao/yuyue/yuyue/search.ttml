<view class="container"><block tt:if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view><view data-event-opts="{{[['tap',[['searchbtn',['$event']]]]]}}" class="search-btn" bindtap="__e"><block tt:if="{{!history_show&&productlisttype=='itemlist'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-cascades.png'}}"></image></block><block tt:if="{{!history_show&&productlisttype=='item2'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-list.png'}}"></image></block><block tt:if="{{history_show}}"><text>搜索</text></block></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" bindtap="__e"><image style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/del.png'}}"></image></view></view><view class="search-history-list"><block tt:for="{{history_list}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" bindtap="__e">{{item+''}}</view></block><block tt:if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/tanhao.png'}}"></image>暂无记录</view></block></view></view></view><view class="product-container"><block tt:if="{{datalist&&datalist.length>0}}"><block><block tt:if="{{productlisttype=='item2'}}"><dp-yuyue-item vue-id="6fff6bab-1" data="{{datalist}}" bind:__l="__l"></dp-yuyue-item></block><block tt:if="{{productlisttype=='itemlist'}}"><dp-yuyue-itemlist vue-id="6fff6bab-2" data="{{datalist}}" bind:__l="__l"></dp-yuyue-itemlist></block></block></block><block tt:if="{{nomore}}"><nomore vue-id="6fff6bab-3" text="没有更多商品了" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="6fff6bab-4" text="没有查找到相关商品" bind:__l="__l"></nodata></block><block tt:if="{{loading}}"><loading vue-id="6fff6bab-5" bind:__l="__l"></loading></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="6fff6bab-6" bind:__l="__l"></loading></block><dp-tabbar vue-id="6fff6bab-7" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="6fff6bab-8" data-ref="popmsg" bind:__l="__l"></popmsg></view>