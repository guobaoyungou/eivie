<view class="container"><block tt:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="form-content"><view class="form-item flex-bt"><view class="label">施工前<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><block tt:for="{{service_before_pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_before_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_before_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></view></view><view class="form-item flex-bt"><view class="label">施工中<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><block tt:for="{{service_pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></view></view><view class="form-item flex-bt"><view class="label">完成施工<text style="color:red;">*</text></view><view class="flex content_picpreview" style="flex-wrap:wrap;padding-top:20rpx;"><block tt:for="{{service_finish_pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="service_finish_pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="service_finish_pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></view></view></view><button class="btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">提交</button><view style="padding-top:30rpx;"></view><view style="display:none;">{{txt}}</view></form></block></block><block tt:if="{{loading}}"><loading vue-id="22ebfc69-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="22ebfc69-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="22ebfc69-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>