<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="order-tab"><view class="order-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">全部<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view></block></block></view></view><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="content flex" data-id="{{item.id}}"><view class="f1" data-url="{{'peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="headimg"><image src="{{item.headimg}}"></image></view><view class="text1"><text class="t1">{{item.realname+''}}</text><block tt:if="{{item.typename}}"><text class="t2">{{item.typename+''}}</text></block><view class="text2">{{item.jineng}}</view><view class="text3 flex"><view class="t4">服务<text>{{''+item.totalnum}}</text>次</view><view class="t5">评分<text>{{item.comment_score}}</text></view></view></view></view><view><view class="yuyue" style="{{'background:'+($root.m2)+';'}}" data-url="{{'/yuyue/yuyue/peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">预约</view></view></view></block><block tt:if="{{nodata}}"><nodata vue-id="f7f19d62-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="f7f19d62-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="f7f19d62-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="f7f19d62-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f7f19d62-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="f7f19d62-6" bind:__l="__l"></wxxieyi></view>