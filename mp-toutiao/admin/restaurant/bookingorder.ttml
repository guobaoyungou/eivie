<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="5032eabc-1" itemdata="{{['全部','待付款','待审核','已完成','退款']}}" itemst="{{['all','0','1','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="请输入预订人姓名或手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box" data-url="{{'bookingorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view><text class="bold">{{item.linkman}}</text>{{item.tel}}</view><view class="flex1"></view><block tt:if="{{item.status==0}}"><text class="st0">待付款</text></block><block tt:if="{{item.status==1&&item.check_status==0}}"><text class="st0">待审核</text></block><block tt:if="{{item.status==1&&item.check_status==-1}}"><text class="st4">驳回</text></block><block tt:if="{{item.status==2}}"><text class="st2">待收货</text></block><block tt:if="{{item.status==3}}"><text class="st3">已完成</text></block><block tt:if="{{item.status==4}}"><text class="st4">已关闭</text></block></view><view class="h60">{{"预定时间："+item.booking_time}}</view><block tt:for="{{item.prolist}}" tt:for-item="item2" tt:for-index="idx" tt:key="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view data-url="{{'/restaurant/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item2.sell_price}}</text><text class="x2">{{"×"+item2.num}}</text></view></view></view></block></block><view class="bottom"><text>{{'桌号：'+item.tableName+" 实付:￥"+item.totalprice}}</text><block tt:if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block tt:if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block tt:if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="5032eabc-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="5032eabc-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="5032eabc-4" bind:__l="__l"></loading></block></view>