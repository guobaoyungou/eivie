<view class="container"><block tt:if="{{isload}}"><block><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{('item '+(curTopIndex==-1?'on':''))}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">全部</view><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('item '+(curTopIndex==index?'on':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}</view></block></block></view></view><view class="shop-box"><block tt:for="{{contentList}}" tt:for-item="item" tt:for-index="__i0__" tt:key="*this"><view class="shop-item"><image class="shop-img" src="{{item.pic?item.pic:logo}}" mode="aspectFill"></image><view class="f2 flex-col flex1"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="desc">{{"人数："+item.seat}}</view><view class="desc">{{"预定费："+item.booking_fee+" 最低消费："+item.limit_fee}}</view></view><view class="f3 button" data-url="{{'booking?bid='+opt.bid+'&tableId='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">预定</view></view></block></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="fb7a3644-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="fb7a3644-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>