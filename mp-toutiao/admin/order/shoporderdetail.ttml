<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+(shopset.order_detail_toppic?shopset.order_detail_toppic:pre_url+'/static/img/ordertop.png')+');background-size:100%')}}"><block tt:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block tt:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block tt:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block tt:if="{{detail.freight_type!=1}}"><view class="t2">请尽快发货</view></block><block tt:if="{{detail.freight_type==1}}"><view class="t2">待提货</view></block></view></block><block tt:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block tt:if="{{detail.freight_type!=3}}"><view class="t2">{{"发货信息："+detail.express_com+" "+detail.express_no}}</view></block></view></block><block tt:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block tt:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><view class="t1"><text user-select="true" selectable="true">{{detail.linkman}}</text><block tt:if="{{detail.tel}}"><text style="margin-left:20rpx;" data-url="{{'tel:'+detail.tel}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{detail.tel}}</text></block></view><block tt:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block tt:if="{{detail.product_thali}}"><text class="t2">{{"学生姓名："+detail.product_thali_student_name}}</text></block><block tt:if="{{detail.product_thali}}"><text class="t2">{{"学校信息："+detail.product_thali_school}}</text></block><block tt:if="{{detail.freight_type==1}}"><text class="t2" data-address="{{storeinfo.address}}" data-latitude="{{storeinfo.latitude}}" data-longitude="{{storeinfo.longitude}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address}}</text></block><block tt:if="{{detail.worknum}}"><view class="t2">{{"工号："+detail.worknum}}</view></block></view></view><block tt:if="{{detail.usegiveorder&&detail.usegiveorder==1}}"><view class="orderinfo"><view class="title">赠好友</view><view class="item"><view class="t1">领取状态</view><block tt:if="{{detail.giveordermid>0}}"><view class="t2" style="color:green;">已领取</view></block><block tt:else><view class="t2" style="color:red;">未领取</view></block></view><block tt:if="{{detail.giveordermid>0&&detail.givemember}}"><block><view class="item"><text class="t1">好友信息</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.givemember.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.givemember.nickname+"(ID:"+detail.giveordermid+")"}}</text></view></block></block></view></block><view class="product"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="box"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.ggname}}</text><block tt:if="{{item.$orig.product_type&&item.$orig.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item.$orig.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item.$orig.real_total_weight+"斤"}}</text></view></block><block tt:else><view class="t3"><text class="x1 flex1">{{'￥'+item.$orig.sell_price+''}}<block tt:if="{{item.m0}}"><text>{{"+"+item.$orig.freezemoney_price+item.m1}}</text></block></text><text class="x2">{{"×"+item.$orig.num}}</text></view></block><block tt:if="{{shopset.show_shd_remark==1&&item.$orig.shd_remark}}"><text class="t2" style="height:auto;">{{"备注："+item.$orig.shd_remark}}</text></block><block tt:if="{{(detail.status==1||detail.status==2)&&detail.is_quanyi==1&&item.$orig.hexiao_code}}"><block><view class="btn3" style="position:absolute;top:46rpx;right:0rpx;" data-id="{{item.$orig.id}}" data-num="{{item.$orig.hexiao_num_total}}" data-hxnum="{{item.$orig.hexiao_num_used}}" data-hexiao_code="{{item.$orig.hexiao_code}}" data-event-opts="{{[['tap',[['showhxqr2',['$event']]]]]}}" catchtap="__e">权益核销</view></block></block></view></view><block tt:if="{{item.$orig.glassrecord}}"><view class="glassitem"><view class="gcontent"><view class="glassheader">{{''+item.$orig.glassrecord.name+"\n\t\t\t\t\t\t\t"+(item.$orig.glassrecord.nickname?item.$orig.glassrecord.nickname:'')+"\n\t\t\t\t\t\t\t"+(item.$orig.glassrecord.check_time?item.$orig.glassrecord.check_time:'')+"\n\t\t\t\t\t\t\t"+item.$orig.glassrecord.typetxt+''}}<block tt:if="{{item.$orig.glassrecord.double_ipd==0}}"><text class="pdl10">{{item.$orig.glassrecord.ipd?'PD'+item.$orig.glassrecord.ipd:''}}</text></block><block tt:else><text class="pdl10">{{"PD R"+item.$orig.glassrecord.ipd_right+" L"+item.$orig.glassrecord.ipd_left}}</text></block></view><view class="glassrow bt"><view class="grow">{{'R '+item.$orig.glassrecord.degress_right+"/"+(item.$orig.glassrecord.ats_right?item.$orig.glassrecord.ats_right:'0.00')+"*"+(item.$orig.glassrecord.ats_zright?item.$orig.glassrecord.ats_zright:'0')+''}}<block tt:if="{{item.$orig.glassrecord.type==3}}"><text class="pdl10">{{"ADD+"+(item.$orig.glassrecord.add_right?item.$orig.glassrecord.add_right:0)}}</text></block></view><view class="grow">{{'L '+item.$orig.glassrecord.degress_left+"/"+(item.$orig.glassrecord.ats_left?item.$orig.glassrecord.ats_left:'0.00')+"*"+(item.$orig.glassrecord.ats_zleft?item.$orig.glassrecord.ats_zleft:'0')+''}}<block tt:if="{{item.$orig.glassrecord.type==3}}"><text class="pdl10">{{"ADD+"+(item.$orig.glassrecord.add_left?item.$orig.glassrecord.add_left:0)}}</text></block></view></view><block tt:if="{{item.$orig.glassrecord.remark}}"><view class="glassrow">{{item.$orig.glassrecord.remark}}</view></block></view></view></block></view></block><block tt:if="{{detail.crk_givenum&&detail.crk_givenum>0}}"><view style="color:#f60;line-height:70rpx;">{{"+随机赠送"+detail.crk_givenum+"件"}}</view></block></view><block tt:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><block tt:if="{{detail.mid>0}}"><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m2+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view></block><block tt:if="{{detail.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2" user-select="true" selectable="true">{{detail.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block tt:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block tt:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block tt:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><block tt:if="{{detail.issource&&detail.source&&detail.source=='supply_zhenxin'}}"><view class="item"><text class="t1">商品来源</text><text class="t2">甄新汇选</text></view></block><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block tt:if="{{$root.m3}}"><view class="item"><text class="t1">{{$root.m4}}</text><text class="t2 red">{{detail.total_freezemoney_price}}</text></view></block><block tt:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m5+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block tt:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block tt:if="{{detail.invoice_money>0}}"><view class="item"><text class="t1">发票费用</text><text class="t2 red">{{"+¥"+detail.invoice_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block tt:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block tt:if="{{detail.up_floor_fee&&detail.up_floor_fee>0}}"><view class="item"><text class="t1">上楼费</text><text class="t2 red">{{"+¥"+detail.up_floor_fee}}</text></view></block><block tt:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block tt:if="{{detail.wxtc_status_name}}"><view class="item"><text class="t1">配送状态</text><text class="t2">{{detail.wxtc_status_name}}</text></view></block><block tt:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m6+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block tt:if="{{detail.water_coupon_money&&detail.water_coupon_money>0}}"><view class="item"><text class="t1">{{$root.m7+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.water_coupon_money}}</text></view></block><block tt:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m8+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><block tt:if="{{detail.dec_money>0}}"><view class="item"><text class="t1">{{$root.m9+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.dec_money}}</text></view></block><block tt:if="{{detail.silvermoneydec&&detail.silvermoneydec>0}}"><view class="item"><text class="t1">{{$root.m10+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.silvermoneydec}}</text></view></block><block tt:if="{{detail.goldmoneydec&&detail.goldmoneydec>0}}"><view class="item"><text class="t1">{{$root.m11+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.goldmoneydec}}</text></view></block><block tt:if="{{detail.discount_rand_money>0}}"><view class="item"><text class="t1">随机立减</text><text class="t2 red">{{"-¥"+detail.discount_rand_money}}</text></view></block><block tt:if="{{detail.dedamount_dkmoney&&detail.dedamount_dkmoney>0}}"><view class="item"><text class="t1">抵扣金抵扣</text><text class="t2 red">{{"-¥"+detail.dedamount_dkmoney}}</text></view></block><block tt:if="{{detail.shopscoredk_money>0}}"><view class="item"><text class="t1">{{$root.m12+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.shopscoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text><block tt:if="{{$root.m13}}"><text>{{'+ '+detail.total_freezem