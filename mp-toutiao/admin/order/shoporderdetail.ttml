-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><block tt:if="{{$root.m16}}"><view class="bottom notabbarbot"><block tt:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundnopass',['$event']]]]]}}" bindtap="__e">退款驳回</view></block><block tt:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundpass',['$event']]]]]}}" bindtap="__e">退款通过</view></block><block tt:if="{{detail.status==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['closeOrder',['$event']]]]]}}" bindtap="__e">关闭订单</view></block><block tt:if="{{detail.status==0&&detail.bid==0&&!detail.isdygroupbuy&&detail.order_admin_payorder_switch==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['ispay',['$event']]]]]}}" bindtap="__e">改为已支付</view></block><block tt:if="{{detail.status==1&&!detail.hidefahuo&&shopset.send_show}}"><block><block tt:if="{{detail.product_type==2}}"><view class="btn2" data-url="{{'weightOrderFahuo?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发货</view></block><block tt:if="{{detail.product_type!=2&&detail.can_fahuo==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['fahuo',['$event']]]]]}}" bindtap="__e">发货</view></block></block></block><block tt:if="{{(detail.status==1||detail.status==2)&&detail.freight_type==1&&detail.is_quanyi==0&&shopset.hexiao_show}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" bindtap="__e">核销</view></block><block tt:if="{{detail.wx_express_intracity&&detail.freight_type==2}}"><block><view class="btn2" style="width:190rpx;" data-