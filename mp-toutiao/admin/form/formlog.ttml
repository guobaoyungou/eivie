<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="191c4d7c-1" itemdata="{{['全部','待确认','已确认','已驳回','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-url="{{'formdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.title}}</text><text class="t2">{{"提交时间："+item.createtime}}</text><block tt:if="{{item.paynum}}"><text class="t2" user-select="true" selectable="true">{{item.paynum}}</text></block></view><view class="f2"><block tt:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待确认</text></block><block tt:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block tt:if="{{item.status==1}}"><text class="t1" style="color:green;">已确认</text></block><block tt:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="191c4d7c-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="191c4d7c-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="191c4d7c-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="191c4d7c-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="191c4d7c-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>