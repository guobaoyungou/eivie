<view><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="apply_box"><view class="apply_item"><view>商家名称<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="name" disabled="{{true}}" placeholder="请输入商家名称" value="{{info.name}}"/></view></view><view class="apply_item"><view>商家描述<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="desc" placeholder="请输入商家描述" value="{{info.desc}}"/></view></view><view class="apply_item"><view>店铺坐标<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" disabled="{{true}}" placeholder="请选择坐标" name="zuobiao" data-event-opts="{{[['tap',[['locationSelect',['$event']]]]]}}" value="{{latitude?latitude+','+longitude:''}}" bindtap="__e"/></view><input type="text" hidden="true" name="latitude" value="{{latitude}}"/><input type="text" hidden="true" name="longitude" value="{{longitude}}"/></view><view class="apply_item"><view>店铺地址<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="address" placeholder="请输入商家详细地址" value="{{address}}"/></view></view><view class="apply_item"><view>客服电话<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="tel" placeholder="请填写客服电话" value="{{info.tel}}"/></view></view><block tt:if="{{new_score==1}}"><view><view class="apply_item"><view>让利比例(%)</view><view class="flex-y-center"><input type="text" name="newscore_ratio" placeholder="请填写比例" value="{{info.newscore_ratio}}"/></view></view><block tt:if="{{showBusinessNewscoreRatio}}"><view class="apply_item"><view>让利到商家比例(%)</view><view class="flex-y-center"><input type="text" name="business_newscore_ratio" placeholder="请填写比例" value="{{info.business_newscore_ratio}}"/></view></view></block><block tt:if="{{showMemberNewscoreRatio}}"><view class="apply_item"><view>让利到消费者比例(%)</view><view class="flex-y-center"><input type="text" name="member_newscore_ratio" placeholder="请填写比例" value="{{info.member_newscore_ratio}}"/></view></view></block><block tt:if="{{$root.m0}}"><view class="flex-y-center">{{''+new_score_log_str+''}}</view></block></view></block><block tt:if="{{showSubsidyRatio}}"><view class="apply_item"><view>让利比例(%)</view><view class="flex-y-center"><input type="text" name="feepercent" placeholder="请填写比例" value="{{info.feepercent}}"/></view></view></block></view><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>商家主图<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block tt:for="{{pic}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="logo" maxlength="-1" value="{{$root.g0}}"/></view><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>商家照片(3-5张)<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block tt:for="{{pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pics.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view><view class="apply_box"><view class="apply_item" style="border-bottom:0;"><view>营业时间<text style="color:red;">*</text></view></view><view class="flex-col" style="flex-wrap:wrap;padding-bottom:20rpx;"><view class="flex-y-center"><picker mode="time" value="{{start_hours}}" data-event-opts="{{[['change',[['bindStartHoursChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_hours}}</view></picker><view style="padding:0 30rpx;color:#222;">到</view><picker mode="time" value="{{end_hours}}" data-event-opts="{{[['change',[['bindEndHoursChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_hours}}</view></picker></view><view class="flex-y-center"><picker mode="time" value="{{start_hours2}}" data-event-opts="{{[['change',[['bindStartHours2Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_hours2}}</view></picker><view style="padding:0 30rpx;color:#222;">到</view><picker mode="time" value="{{end_hours2}}" data-event-opts="{{[['change',[['bindEndHours2Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_hours2}}</view></picker></view><view class="flex-y-center"><picker mode="time" value="{{start_hours3}}" data-event-opts="{{[['change',[['bindStartHours3Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_hours3}}</view></picker><view style="padding:0 30rpx;color:#222;">到</view><picker mode="time" value="{{end_hours3}}" data-event-opts="{{[['change',[['bindEndHours3Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_hours3}}</view></picker></view></view><view class="apply_item"><view>打烊后接单<text style="color:red;">*</text></view><view class="flex-y-center"><radio-group class="radio-group" name="end_buy_status"><label><radio value="1" checked="{{info.end_buy_status==1?true:false}}"></radio>开启</label><label><radio value="0" checked="{{info.end_buy_status==0?true:false}}"></radio>关闭</label></radio-group></view></view><view class="apply_item"><view>店铺状态<text style="color:red;">*</text></view><view class="flex-y-center"><radio-group class="radio-group" name="is_open"><label><radio value="1" checked="{{info.is_open==1?true:false}}"></radio>营业</label><label><radio value="0" checked="{{info.is_open==0?true:false}}"></radio>休息</label></radio-group></view></view><block tt:if="{{info.canset_paymoney_givepercent}}"><block><view class="apply_item"><view>让利比例(%)</view><view class="flex-y-center"><input type="text" name="paymoney_givepercent" placeholder="请填写让利比例" value="{{info.paymoney_givepercent}}"/></view></view><block tt:if="{{info.paymoney_givepercent2>=0}}"><view class="apply_item" style="color:red;"><view>待审核让利比例(%)</view><view class="flex-y-center"><input type="text" disabled="{{true}}" value="{{info.paymoney_givepercent2}}"/></view></view></block></block></block></view><view style="padding:30rpx 0;"><button class="set-btn" style="{{('background:linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')}}" form-type="submit">确 定</button></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="688163e0-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="688163e0-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="688163e0-3" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="688163e0-4" bind:__l="__l"></wxxieyi></view>