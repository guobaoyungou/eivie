<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="title">管理员登录</view><view class="loginform"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-tel.png'}}"></image><input class="input" type="text" placeholder="请输入登录账号" placeholder-style="font-size:30rpx;color:#B2B5BE" name="username" value="{{username}}" data-event-opts="{{[['input',[['__set_model',['','username','$event',[]]]]]]}}" bindinput="__e"/></view><block tt:if="{{logintype==1&&(smslogin==0||smslogin==1)}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-pwd.png'}}"></image><input class="input" type="text" placeholder="请输入密码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="password" value="" password="{{true}}"/></view></block><block tt:if="{{logintype==2||smslogin==2}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="请输入短信验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="sms_code" value=""/><button class="mini-btn" style="{{'color:'+(smsdjs?'#999':$root.m0)+';'}}" type="default" size="mini" disabled="{{!!smsdjs}}" data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" bindtap="__e">{{''+(smsdjs||'获取验证码')+''}}</button></view></block><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="请输入验证码" placeholder-style="font-size:30rpx;color:#B2B5BE" name="captcha" value=""/><image style="width:240rpx;height:80rpx;" src="{{pre_url+'/?s=/ApiIndex/captcha&aid='+aid+'&session_id='+session_id+'&t='+randt}}" data-event-opts="{{[['tap',[['regetcaptcha',['$event']]]]]}}" bindtap="__e"></image></view><block tt:if="{{forgetpwd}}"><view style="height:50rpx;"><text style="color:#B2B5BE;float:right;padding:20rpx 0 20rpx 20rpx;" data-url="/adminExt/set/forgetPwd" data-opentype="redirect" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">忘记密码</text></view></block><button class="form-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" form-type="submit">登录</button><block tt:if="{{smslogin==1}}"><view data-event-opts="{{[['tap',[['switchLoginType',['$event']]]]]}}" class="switch-login-type" style="{{'color:'+($root.m3)+';'}}" bindtap="__e">{{''+(logintype==1?'短信登录':'密码登录')+''}}</view></block></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="35efc717-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="35efc717-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="35efc717-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>