<view><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item"><view data-event-opts="{{[['tap',[['showExplain',['1']]]]]}}" class="f1" bindtap="__e"><text style="color:red;">*</text>出水口编号<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="f2"><input type="number" name="outlet_num" placeholder="出水口编号" placeholder-style="color:#888" value="{{outlet_num}}"/></view></view></view><view class="form-box dkdiv-item flex-y-center"><view class="form-item"><view class="f1"><label style="color:red;" class="_span">*</label>积分抵扣设置</view><view class="f2"><radio-group class="radio-group" name="scoredkmaxpercent_type" data-event-opts="{{[['change',[['scoredkmaxpercentTtypeChange',['$event']]]]]}}" bindchange="__e"><label><radio value="0" checked="{{scoredkmaxpercent_type==0?true:false}}"></radio>跟随系统</label><label style="margin-left:20rpx;"><radio value="1" checked="{{scoredkmaxpercent_type==1?true:false}}"></radio>独立设置</label></radio-group></view></view></view><block tt:if="{{scoredkmaxpercent_type==1}}"><view class="form-box"><view class="form-item"><view data-event-opts="{{[['tap',[['showExplain',['4']]]]]}}" class="f1" bindtap="__e"><text style="color:red;">*</text>积分抵扣%<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="f2"><input type="text" name="scoredkmaxpercent" placeholder="积分抵扣百分比" placeholder-style="color:#888" data-event-opts="{{[['input',[['__set_model',['','scoredkmaxpercent','$event',[]]],['changsetggname',['$event']]]]]}}" value="{{scoredkmaxpercent}}" bindinput="__e"/></view></view></view></block><view class="form-box"><view class="form-item"><view data-event-opts="{{[['tap',[['showExplain',['2']]]]]}}" class="f1" bindtap="__e"><text style="color:red;">*</text>出水口单价<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="f2"><input type="text" name="outlet_price" placeholder="出水口单价（元/升）" placeholder-style="color:#888" data-event-opts="{{[['input',[['__set_model',['','outlet_price','$event',[]]],['changsetggname',['$event']]]]]}}" value="{{outlet_price}}" bindinput="__e"/></view></view></view><view class="form-box"><view class="form-item flex-col"><view data-event-opts="{{[['tap',[['showExplain',['3']]]]]}}" class="f1" bindtap="__e"><text style="color:red;">*</text>打水套餐<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="flex-col"><view class="ggcontent"><view class="t2"><block tt:for="{{price_combo}}" tt:for-item="ggitem" tt:for-index="index2" tt:key="index2"><view class="ggname" data-index2="{{index2}}" data-dashui_amount="{{ggitem.dashui_amount}}" data-title="{{ggitem.dashui_title}}" data-event-opts="{{[['tap',[['addggname',['$event']]]]]}}" catchtap="__e">{{ggitem.dashui_title}}<image class="close" data-index2="{{index2}}" src="{{pre_url+'/static/img/ico-del.png'}}" data-event-opts="{{[['tap',[['delggname',['$event']]]]]}}" catchtap="__e"></image></view></block><view class="ggnameadd" data-index2="-1" data-event-opts="{{[['tap',[['addggname',['$event']]]]]}}" catchtap="__e">+</view></view></view></view></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form><uni-popup class="vue-ref" vue-id="69de1b12-1" id="dialogInput" type="dialog" data-ref="dialogInput" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('69de1b12-2')+','+('69de1b12-1')}}" mode="input" title="请输入套餐价格（元）" placeholder="请输入套餐价格（元）" value="{{dashui_amount}}" data-event-opts="{{[['^confirm',[['setggname']]],['^input',[['__set_model',['','dashui_amount','$event',[]]]]]]}}" bind:confirm="__e" bind:input="__e" bind:__l="__l"></uni-popup-dialog></uni-popup></block></block><block tt:if="{{loading}}"><loading vue-id="69de1b12-3" bind:__l="__l"></loading></block></view>