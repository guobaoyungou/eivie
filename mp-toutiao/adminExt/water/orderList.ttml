<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="70aa95c0-1" itemdata="{{['全部','打水中','已结束']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><block tt:if="{{item.iscd==0}}"><text class="st2">打水中</text></block><block tt:if="{{item.iscd==1}}"><text class="st3">已结束</text></block></view><view class="content"><view class="detail"><view class="t1">{{"设备编号："+item.deviceId}}</view><view class="t1">{{"设备地址："+item.location}}</view><view class="t1">{{"出水口："+item.outlet_num}}</view><view class="t1">{{"支付时间："+item.paytime}}</view></view></view><view class="content"><view class="detail"><view>{{"订单金额:￥"+item.product_price}}</view><view>{{"实付金额:￥"+item.totalprice}}</view><view>{{"退款金额:￥"+item.refund_money}}</view><block tt:if="{{item.scoredk_money>0}}"><view>{{"积分抵扣:￥"+item.scoredk_money}}</view></block><block tt:if="{{item.coupon_money>0}}"><view>{{"优惠券抵扣:￥"+item.coupon_money}}</view></block></view></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="70aa95c0-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="70aa95c0-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="70aa95c0-4" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="70aa95c0-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>