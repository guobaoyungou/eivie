<view class="container"><block tt:if="{{isload}}"><block><view class="ind_business"><view class="ind_buslist" id="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view data-url="{{'index?bid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox "><view class="flex1 flex-row flex-y-center"><view class="ind_buspic flex0"><image src="{{item.$orig.logo}}"></image></view><view style="flex:1;"><view class="bus_title">{{item.$orig.name}}</view><view class="bus_address">地址：<text class="x1">{{item.$orig.province+item.$orig.city+item.$orig.district+item.$orig.address}}</text></view></view><view class="status flex-y-center" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toEditBusiness',['$event']]]]]}}" bindtap="__e"><block tt:if="{{item.$orig.status==0}}"><text style="color:orange;">待审核</text></block><block tt:else><block tt:if="{{item.$orig.status==1}}"><text style="color:green;">营业中</text></block><block tt:else><block tt:if="{{item.$orig.status==2}}"><text style="color:red;">已驳回</text></block><block tt:else><text>已过期</text></block></block></block><image class="image" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="ind_bottom"><view class="v1"><text class="t1">申请时间：</text>{{item.m0}}</view><block tt:if="{{item.$orig.status==2}}"><block><view class="v1  flex-bt"><view class="t1">拒绝原因：<text style=";">{{item.$orig.reason}}</text></view><view class="delete" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['deleteBusiness',['$event']]]]]}}" bindtap="__e">删除</view></view></block></block><block tt:else><block tt:if="{{item.$orig.status==1}}"><block><view class="v1">营业状态：<block tt:if="{{item.$orig.is_open==1}}"><text class="t1">营业中</text></block><block tt:else><text>休息中</text></block></view></block></block></block></view></view></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="73d241e0-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="73d241e0-2" bind:__l="__l"></nodata></block><view style="height:170rpx;"></view><button data-event-opts="{{[['tap',[['toAddBusiness',['$event']]]]]}}" class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')}}" bindtap="__e">创建商户</button></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="73d241e0-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="73d241e0-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><wxxieyi vue-id="73d241e0-5" bind:__l="__l"></wxxieyi></view>