<view class="container"><block tt:if="{{isload}}"><block><view class="ind_business"><view class="ind_buslist" id="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['selectBusiness',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox "><view class="flex1 flex-row flex-y-center"><view class="ind_buspic flex0"><image src="{{item.$orig.logo}}"></image></view><view style="flex:1;"><view class="bus_title">{{item.$orig.name}}</view><view class="bus_address">地址：<text class="x1">{{item.$orig.province+item.$orig.city+item.$orig.district+item.$orig.address}}</text></view></view><view class="status flex-y-center"><block tt:if="{{item.$orig.is_open==1}}"><view>营业中</view></block><block tt:else><view>休息中</view></block><image class="image" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="ind_bottom"><view class="v1"><text class="t1">申请时间：</text>{{item.m0}}</view></view></view></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="119cf7a9-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="119cf7a9-2" bind:__l="__l"></nodata></block></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="119cf7a9-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="119cf7a9-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><wxxieyi vue-id="119cf7a9-5" bind:__l="__l"></wxxieyi></view>