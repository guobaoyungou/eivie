<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="32a21861-1" itemdata="{{['全部','待审核','已审核','已驳回']}}" itemst="{{['all','0','1','2']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-url="{{'withdrawdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="headimg"><image src="{{item.$orig.headimg}}"></image></view><view class="f1"><text class="t1">{{"社区名称："+item.$orig.xqname}}</text><view class="t3">提现金额：<text class="t3_3" style="{{'color:'+($root.m0)+';'}}">{{item.$orig.money}}</text>元</view><text class="t2">{{item.m1}}</text></view><view class="op"><block tt:if="{{item.$orig.status==0}}"><view class="st0">待审核</view></block><block tt:if="{{item.$orig.status==1}}"><view class="st1">已审核</view></block><block tt:if="{{item.$orig.status==2}}"><view class="st2">已驳回</view></block><block tt:if="{{item.$orig.status==3}}"><view class="st3">已打款</view></block></view><button class="btn" style="{{('background:rgba('+$root.m2+',0.9)')}}" data-id="{{item.$orig.id}}">查看详情</button></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="32a21861-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="32a21861-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="32a21861-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="32a21861-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="32a21861-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>