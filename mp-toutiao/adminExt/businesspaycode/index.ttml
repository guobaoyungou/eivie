<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{data}}"><view class="row"><view class="title">{{data.name}}</view><image style="width:60%;" src="{{data.maidan_paycode_url}}" data-url="{{data.maidan_paycode_url}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="edit-paycode" data-url="{{'set?bid='+data.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">编辑二维码</view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="0948a148-1" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="0948a148-2" data-ref="popmsg" bind:__l="__l"></popmsg></view>