<view class="container"><block tt:if="{{isload}}"><block><form autocomplete="off" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="content2"><block><view class="item2"><view class="f1">对方ID</view></view><view class="item3"><block tt:if="{{member_info.id}}"><view class="member-info"><view class="info-view flex-y-center"><block tt:if="{{member_info.headimg}}"><image class="head-img" src="{{member_info.headimg}}"></image></block><block tt:else><image class="head-img" src="{{pre_url+'/static/img/wxtx.png'}}"></image></block><view class="member-text-view"><view class="member-nickname">{{member_info.nickname}}</view><view class="member-id">{{"ID："+member_info.id}}</view></view></view><view data-event-opts="{{[['tap',[['switchMember',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m0)+';'}}" bindtap="__e">切换</view></view></block><block tt:else><view class="member-info"><input class="input" type="number" name="mid" placeholder="请输入对方ID" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['memberInput',['$event']]]]]}}" value="{{mid}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['changeQuery',['$0'],['mid']]]]]}}" class="query-button" style="{{'color:'+($root.m1)+';'}}" bindtap="__e">查询</view></view></block></view><view class="item4" style="height:1rpx;"></view></block><view class="item2"><view class="f1">转账金额</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="money" value="" placeholder="请输入转账金额" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><block tt:if="{{paycheck}}"><view class="item2"><view class="f1">支付密码</view></view></block><block tt:if="{{paycheck}}"><view class="item3"><view class="f2"><input class="input" type="password" name="paypwd" value="" placeholder="请输入支付密码" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['getpwd',['$event']]]]]}}" bindinput="__e"/></view></view></block><view class="item4"><text class="{{(mid>0?'redtxt':'')}}" style="margin-right:10rpx;">{{"您的当前"+$root.m2+"："+mymoney+'，转账后不可退回'}}</text></view></view><button class="btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">转账</button><view class="text-center" style="margin-top:40rpx;line-height:60rpx;" data-url="/admin/finance/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>返回财务首页</text></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="d6178f64-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="d6178f64-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>