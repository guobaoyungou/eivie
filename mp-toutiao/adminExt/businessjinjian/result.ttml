<view class="body"><block tt:if="{{isload}}"><block><view class="container"><block><view class="box box-tips result-box"><view class="tips-status"><block tt:if="{{form.status=='APPLYMENT_STATE_FINISHED'}}"><image src="{{pre_url+'/static/img/success_1.png'}}" mode="widthFix"></image></block><block tt:else><image src="{{pre_url+'/static/img/error2.png'}}" mode="widthFix"></image></block></view><view class="status-text">{{form.status_msg}}</view><block tt:if="{{form.mchid_id}}"><view class="time-text mb0">{{"商户号："+form.mchid_id}}</view></block><view class="time-text">{{"提交时间："+$root.m0}}</view><block tt:if="{{form.status=='APPLYMENT_STATE_EDITTING'||form.status==''||form.status=='APPLYMENT_STATE_REJECTED'}}"><view class="back-to-edit-btn"><button class="edit-btn" style="{{('color:'+$root.m1+';border:1px solid '+$root.m2)}}" data-url="wxjinjian" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">返回编辑</button></view></block></view><block tt:if="{{form.reason}}"><view class="box box-tips"><view class="form-title"><view class="strip" style="{{'background:'+($root.m3)+';'}}"></view><view class="title">驳回原因</view></view><view class="form-reason">{{''+form.reason+''}}</view></view></block><block tt:if="{{form.sign_url_qrcode}}"><view class="box box-tips"><view class="form-title"><view class="strip" style="{{'background:'+($root.m4)+';'}}"></view><view class="title">签约二维码</view></view><view class="qrcode-box"><view class="qrcode"><image src="{{form.sign_url_qrcode}}" mode="widthFix"></image></view><view class="qrcode-tips">请管理员用微信扫描上面二维码进行签约验证</view></view></view></block></block><view class="form-opt"><block tt:if="{{form.ali_status=='-1'||form.wx_status=='APPLYMENT_STATE_EDITTING'||form.wx_status=='APPLYMENT_STATE_REJECTED'}}"><button class="btn" style="{{'background:'+($root.m5)+';'}}" data-url="{{'apply?id='+form.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">修改</button></block></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="36dcad16-1" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="36dcad16-2" data-ref="popmsg" bind:__l="__l"></popmsg></view>