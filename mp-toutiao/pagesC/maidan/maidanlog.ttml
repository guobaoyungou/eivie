<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'maidandetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.paytime}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><block tt:if="{{canrefund&&item.refund_money>0}}"><text class="t2">{{"退款金额：￥"+item.refund_money}}</text></block></view><view class="f2"><text class="t1">{{"-￥"+item.money}}</text></view></view></block></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="c4448e44-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="c4448e44-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="c4448e44-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="c4448e44-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c4448e44-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>