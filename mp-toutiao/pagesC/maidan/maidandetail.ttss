.orderinfo{width:94%;margin:20rpx 3%;border-radius:5px;padding:20rpx 20rpx;padding:14rpx 3%;background:#fff}.orderinfo .item{display:flex;width:100%;padding:20rpx 0;border-bottom:1px dashed #ededed}.orderinfo .item:last-child{border-bottom:0}.orderinfo .item .t1{width:200rpx}.orderinfo .item .t2{flex:1;text-align:right}.orderinfo .item .red{color:red}