<block tt:if="{{isload}}"><view class="page-view"><view class="wc"><view style="display:flex;"><block tt:if="{{perform.pic}}"><view class="content-pic"><image style="width:100%;border-radius:10rpx 10rpx;" src="{{perform.pic}}" mode="widthFix"></image></view></block><view style="margin-left:10rpx;"><view class="content-title">{{perform.title}}</view><view class="content-title2">{{"日期："+perform.performDate}}</view><view class="content-title2">{{"时间："+perform.performTime}}</view></view></view></view><view class="wc"><view style="width:100%;display:flex;justify-content:space-between;"><view style="width:50%;">座位</view><view style="width:50%;">票价</view></view><block tt:if="{{selseats}}"><block><block tt:for="{{selseats}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view style="{{'width:100%;padding:20rpx 0;'+(index>0?'border-top:2rpx dashed #ddd':'')}}"><view style="display:flex;justify-content:space-between;"><view style="width:50%;">{{item.fname}}</view><view style="width:50%;">{{item.price+"元"}}</view></view><view style="line-height:80rpx;"><view class="peisong-item"><view style="width:150rpx;">真实姓名</view><input class="peisong-item-input" data-index="{{index}}" data-field="realName" placeholder="请输入真实姓名" placeholder-style="line-height: 80rpx;height: 80rpx" data-event-opts="{{[['input',[['inputSeat',['$event']]]]]}}" value="{{item.realName}}" bindinput="__e"/></view><view class="peisong-item"><view style="width:150rpx;">证件类型</view><picker style="width:100%;line-height:80rpx;height:80rpx;border-bottom:2rpx solid #f1f1f1;" data-index="{{index}}" value="{{item.type}}" range="{{typedata}}" data-event-opts="{{[['change',[['seatPickerChange',['$event']]]]]}}" bindchange="__e"><view style="display:flex;justify-content:flex-start;align-items:center;width:100%;"><block tt:if="{{item.typename}}"><view style="display:inline-block;width:100%;">{{item.typename}}</view></block><block tt:else><view style="color:#BBBBBB;width:100%;">请选择证件类型</view></block><image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view><view class="peisong-item"><view style="width:150rpx;">证件号码</view><input class="peisong-item-input" data-index="{{index}}" data-field="certNo" placeholder="请输入证件号码" placeholder-style="line-height: 80rpx;height: 80rpx" data-event-opts="{{[['input',[['inputSeat',['$event']]]]]}}" value="{{item.certNo}}" bindinput="__e"/></view></view></view></block></block></block></view><view class="wc"><view class="peisong-item"><view style="font-weight:bold;font-size:32rpx;">配送方式</view></view><view style="margin:20rpx 0;">上门自取<block tt:if="{{perform.addreass}}"><text>{{"："+perform.addreass}}</text></block></view><view style="line-height:80rpx;"><view class="peisong-item"><view style="width:150rpx;">联系人</view><input class="peisong-item-input" style="line-height:80rpx;width:100%;" name="linkName" placeholder="请输入联系人姓名" placeholder-style="line-height: 80rpx;height: 80rpx" data-event-opts="{{[['input',[['inputLinkName',['$event']]]]]}}" value="{{linkName}}" bindinput="__e"/></view><view class="peisong-item"><view style="width:150rpx;">联系电话</view><input class="peisong-item-input" style="line-height:80rpx;width:100%;" name="tel" placeholder="请输入联系人电话" placeholder-style="line-height: 80rpx;height: 80rpx" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view><block tt:if="{{needcert}}"><block><view class="peisong-item"><view style="width:150rpx;">证件类型</view><picker style="width:100%;line-height:80rpx;height:80rpx;border-bottom:2rpx solid #f1f1f1;" value="{{type}}" range="{{typedata}}" data-event-opts="{{[['change',[['bindPickerChange',['$event']]]]]}}" bindchange="__e"><view style="display:flex;justify-content:flex-start;align-items:center;width:100%;"><block tt:if="{{typename}}"><view style="display:inline-block;width:100%;">{{typename}}</view></block><block tt:else><view style="color:#BBBBBB;width:100%;">请选择证件类型</view></block><image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view><view class="peisong-item"><view style="width:150rpx;">证件号码</view><input class="peisong-item-input" style="line-height:80rpx;width:100%;" name="certNo" placeholder="请输入联系人证件号码" placeholder-style="line-height: 80rpx;height: 80rpx" data-event-opts="{{[['input',[['inputCertNo',['$event']]]]]}}" value="{{certNo}}" bindinput="__e"/></view></block></block></view></view><view style="width:100%;height:182rpx;"></view><view class="footer  notabbarbot"><view style="display:flex;align-items:center;"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:32rpx;">{{"￥"+totalprice}}</text></view><button data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" bindtap="__e">提交订单</button></view></view><block tt:if="{{loading}}"><loading vue-id="3faf8ac4-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="3faf8ac4-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="3faf8ac4-3" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>