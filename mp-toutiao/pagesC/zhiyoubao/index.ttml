<block tt:if="{{isload}}"><view class="page-view"><view class="top-view flex-col"><scroll-view style="height:676rpx;width:100%;position:relative;padding-bottom:20rpx;" scroll-y="{{true}}"><calendar vue-id="e5d55690-1" is-show="{{true}}" isFixed="{{false}}" between-start="{{betweenStart}}" between-end="{{betweenEnd}}" initMonth="24" ys-num="{{ysNum}}" choose-type="{{chooseType}}" start-date="{{startDate}}" end-date="{{endDate}}" tip-data="{{tipData}}" mode="{{mode}}" showhas="{{true}}" dayPerforms="{{dayPerforms}}" themeColor="{{$root.m0}}" data-event-opts="{{[['^callback',[['getCalendar']]]]}}" bind:callback="__e" bind:__l="__l"></calendar></scroll-view></view><block tt:if="{{datalist&&datalist.length>0}}"><view style="width:95%;margin:20rpx auto;"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="content" data-url="{{'detail?id='+item.id+'&playDate='+playDate}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="display:flex;"><block tt:if="{{item.pic}}"><view class="content-pic"><image style="width:100%;border-radius:10rpx 10rpx;height:auto;min-height:0;" src="{{item.pic}}" mode="widthFix"></image></view></block><view style="margin-left:10rpx;"><view class="content-title">{{item.title}}</view><view class="content-title2">{{"日期："+item.performDate}}</view><view class="content-title2">{{"时间："+item.performTime}}</view><view class="title2" style="{{('color:'+$root.m1)}}"><block tt:if="{{item.price>=0}}"><text>{{"￥"+item.price+"起"}}</text></block><block tt:else><text>暂无价格</text></block></view></view></view></view></block></view></block><block tt:if="{{nodata}}"><nodata vue-id="e5d55690-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="e5d55690-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="e5d55690-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="e5d55690-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="e5d55690-6" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>