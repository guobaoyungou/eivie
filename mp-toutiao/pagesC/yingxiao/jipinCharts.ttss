.pyramid-container{width:94%;margin:0 auto}.zwk{width:127rpx;color:#888}.text-center{margin-top:80rpx;width:80%;border:1px solid #f5f5f5;border-radius:40rpx;height:80rpx;line-height:80rpx;background:#eb6d45;color:#fff;text-align:center}.user-container1{width:100%;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.user-container2{width:50%;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.user-container3{width:25%;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.user-name1{width:100%;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;color:#000;font-size:32rpx;text-align:center;margin-top:5rpx;font-weight:700}.de-img-view{width:100%;height:55rpx;margin-top:40rpx}.de-img-view image{width:100%;height:100%}.pyramid{width:100%;margin-top:80rpx;border-radius:36rpx;background:#fff;position:relative;padding:60rpx 20rpx 40rpx}.pyramid-title-view{background-color:#3b3b3b;color:#fff001;font-size:40rpx;font-weight:700;padding:18rpx 0rpx;border-radius:46rpx;position:absolute;left:50%;top:-40rpx;-webkit-transform:translateX(-50%);transform:translateX(-50%);width:380rpx;text-align:center}.level{display:flex;justify-content:space-around;width:100%;margin-top:20rpx}.user-container{display:flex;flex-direction:column;align-items:center}.avatar{width:105rpx;height:105rpx;border-radius:50%}.k-avatar{width:105rpx;height:105rpx;border-radius:50%;border:1px #888 solid;text-align:center;line-height:105rpx;font-size:24rpx}.user-name{text-align:center;font-size:24rpx;color:#959494}.arrow-container{display:flex;justify-content:space-around;width:100%;margin-top:-25rpx}.arrow{width:60rpx;height:60rpx}.contribution{font-size:22rpx;color:#fff001;white-space:nowrap;background:#fb484c;padding:5rpx 16rpx;border-radius:20rpx;margin-top:10rpx;text-align:center}.user-info-view{background:#fff;margin-top:30rpx;border-radius:36rpx;padding:30rpx;position:relative;overflow:hidden}.user-info-view .user-top-view{width:100%;border-bottom:1px #ebeaea solid;justify-content:space-between;padding-bottom:25rpx}.user-info-view .user-top-view .info-view{flex:1}.tab-options{width:43%;text-align:center;padding:12rpx;border-radius:30rpx;background-color:#e3e3e3;color:#484848;font-size:26rpx}.tab-options-active{background:#fb484c;color:#fff}.activity-list-view{width:100%;margin-top:10rpx}.activity-list-view .active-options{align-items:center;border-bottom:1px #ebeaea solid;padding:20rpx 0rpx;flex:1}.activity-list-view .active-options .active-image{width:200rpx;height:200rpx;border-radius:14rpx;overflow:hidden}.activity-list-view .active-options .active-image image{width:100%;height:100%}.activity-list-view .active-options .active-info-list{margin-left:30rpx;flex:1;height:180rpx;justify-content:space-between}.active-info-list .active-name{font-size:26rpx;color:#000;font-weight:700;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:2}.active-info-list .active-price{font-size:26rpx;color:#fb484c;white-space:nowrap;font-weight:700;margin-top:5rpx}.active-info-list .active-fun-view .fun-class{font-size:22rpx;padding:5rpx 25rpx;border-radius:20px;color:#fff}.active-info-list .active-fun-view .invite-friends{background:#fb484c}.active-info-list .active-fun-view .view-details{background-color:#3b3b3b}.activity-description{width:100%;margin-top:10rpx}.activity-text-view{width:100%;border:1px #ebeaea solid;border-radius:30rpx;justify-content:flex-start;height:auto;margin-top:10rpx;margin-bottom:10rpx}.activity-text-view .title-view{border-radius:30rpx;background-color:#3b3b3b;color:#fff;width:190rpx;text-align:center;height:100%;padding:12rpx 0rpx;font-size:26rpx}.activity-text-view .info-text{flex:1;margin-left:30rpx}.activity-text-view .info-text .info-title-text{font-size:26rpx;color:#000;font-weight:700}.activity-text-view .info-text .neirong-text{color:#888}.info-title-text-last{font-size:26rpx;color:#000;font-weight:700;white-space:nowrap}.info-text-last{padding:4rpx 0rpx}.select-view{height:190rpx;border-left:1px #d1d1d1 solid;margin-left:25rpx}.select-view .select-view-options{width:50rpx;height:50rpx;border-radius:50%;border:1px #fb484c solid;margin-left:30rpx}.select-view .select-view-options .tag-icon{background:#fb484c;width:30rpx;height:30rpx;border-radius:50%}