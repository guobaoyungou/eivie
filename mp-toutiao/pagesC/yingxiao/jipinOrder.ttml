<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="16b58ec8-1" itemdata="{{['全部','未完成','已完成']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入活动名称/订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="list-item"><view class="item-row highlight"><view>{{"序号: "+item.num}}</view><view><button class="btn-mini2" data-url="{{'jipinCharts?id='+item.id}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">关系图</button></view></view><view class="item-row"><view class="column"><text>{{"所属活动: "+item.collage_jipin_name}}</text><text>{{"订单号: "+item.ordernum}}</text><text>{{"订单商品: "+item.goods_name}}</text><text>{{"时间: "+item.createtime}}</text><block tt:if="{{item.status==0}}"><text style="color:#2D66FC;">{{"状态: "+item.status_name}}</text></block><block tt:if="{{item.status==1}}"><text style="color:#888;">{{"状态: "+item.status_name}}</text></block><block tt:if="{{item.status==1}}"><text style="color:#888;">{{"出局时间："+item.outtime}}</text></block></view></view><view class="item-row"><block tt:if="{{item.diff}}"><text class="time">{{item.diff+"后可提现"}}</text></block></view></view></block></block></view><block tt:if="{{nodata}}"><nodata vue-id="16b58ec8-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="16b58ec8-3" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="16b58ec8-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="16b58ec8-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="16b58ec8-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>