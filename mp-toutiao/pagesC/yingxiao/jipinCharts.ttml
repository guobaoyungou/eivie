<view class="pyramid-container"><block tt:if="{{isload}}"><block><view class="pyramid flex-col flex-y-center"><view class="pyramid-title-view">{{"活动"+(set.hdct==1?'已成团':'进行中')}}</view><block tt:if="{{datalist}}"><view class="level level-1"><view class="user-container user-container1"><image class="avatar" src="{{datalist.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist.gxz}}</text></block><text class="user-name1">{{datalist.nickname}}</text><text class="user-name">{{"团号："+datalist.num}}</text><block tt:if="{{datalist.mid>0}}"><text class="user-name">{{"ID："+datalist.mid}}</text></block></view></view></block><view class="arrow-container"><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image></view><view class="level level-2"><block tt:if="{{datalist2_a}}"><view class="user-container user-container2"><image class="avatar" src="{{datalist2_a.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist2_a.gxz}}</text></block><text class="user-name1">{{datalist2_a.nickname}}</text><text class="user-name">{{"团号："+datalist2_a.num}}</text><block tt:if="{{datalist2_a.mid>0}}"><text class="user-name">{{"ID："+datalist2_a.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container2"><view class="k-avatar">空位</view></view></block><block tt:if="{{datalist2_b}}"><view class="user-container user-container2"><image class="avatar" src="{{datalist2_b.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist2_b.gxz}}</text></block><text class="user-name1">{{datalist2_b.nickname}}</text><text class="user-name">{{"团号："+datalist2_b.num}}</text><block tt:if="{{datalist2_b.mid>0}}"><text class="user-name">{{"ID："+datalist2_b.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container2"><view class="k-avatar">空位</view></view></block></view><view class="arrow-container"><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image></view><view class="level level-3"><block tt:if="{{datalist3_a}}"><view class="user-container user-container3"><image class="avatar" src="{{datalist3_a.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist3_a.gxz}}</text></block><text class="user-name1">{{datalist3_a.nickname}}</text><text class="user-name">{{"团号："+datalist3_a.num}}</text><block tt:if="{{datalist3_a.mid>0}}"><text class="user-name">{{"ID："+datalist3_a.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container3"><view class="k-avatar">空位</view></view></block><block tt:if="{{datalist3_b}}"><view class="user-container user-container3"><image class="avatar" src="{{datalist3_b.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist3_b.gxz}}</text></block><text class="user-name1">{{datalist3_b.nickname}}</text><text class="user-name">{{"团号："+datalist3_b.num}}</text><block tt:if="{{datalist3_b.mid>0}}"><text class="user-name">{{"ID："+datalist3_b.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container3"><view class="k-avatar">空位</view></view></block><block tt:if="{{datalist3_c}}"><view class="user-container user-container3"><image class="avatar" src="{{datalist3_c.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist3_c.gxz}}</text></block><text class="user-name1">{{datalist3_c.nickname}}</text><text class="user-name">{{"团号："+datalist3_c.num}}</text><block tt:if="{{datalist3_c.mid>0}}"><text class="user-name">{{"ID："+datalist3_c.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container3"><view class="k-avatar">空位</view></view></block><block tt:if="{{datalist3_d}}"><view class="user-container user-container3"><image class="avatar" src="{{datalist3_d.headimg}}"></image><block tt:if="{{yx_collage_jipin_optimize&&set.gxz==1}}"><text class="contribution">{{"贡献值："+datalist3_d.gxz}}</text></block><text class="user-name1">{{datalist3_d.nickname}}</text><text class="user-name">{{"团号："+datalist3_d.num}}</text><block tt:if="{{datalist3_d.mid>0}}"><text class="user-name">{{"ID："+datalist3_d.mid}}</text></block></view></block><block tt:else><view class="user-container zwk user-container3"><view class="k-avatar">空位</view></view></block></view><view class="de-img-view"><image src="{{pre_url+'/static/img/jipinde.png'}}"></image></view></view><block tt:if="{{yx_collage_jipin_optimize}}"><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><block tt:if="{{set.auto_new==1}}"><view class="info-view flex flex-y-center" style="justify-content:space-between;"><view data-event-opts="{{[['tap',[['changeTab',[0]]]]]}}" class="{{((tabIndex==0?'tab-options-active':'')+' '+'tab-options')}}" bindtap="__e">活动说明</view><view data-event-opts="{{[['tap',[['changeTab',[1]]]]]}}" class="{{((tabIndex==1?'tab-options-active':'')+' '+'tab-options')}}" bindtap="__e">更换复购</view></view></block><block tt:else><view class="info-view flex flex-y-center" style="justify-content:space-between;"><view data-event-opts="{{[['tap',[['changeTab',[0]]]]]}}" class="{{((tabIndex==0?'tab-options-active':'')+' '+'tab-options')}}" style="width:60%;margin-left:21%;" bindtap="__e">活动说明</view></view></block></view><block tt:if="{{tabIndex==0}}"><view class="activity-description flex-col"><block tt:if="{{set.content}}"><view><rich-text style="word-wrap:break-word;" nodes="{{set.content}}"></rich-text></view></block><block tt:else><view style="text-align:center;display:block;color:#959494;margin-top:20rpx;">暂无数据~</view></block></view></block><block tt:else><view class="activity-list-view flex-col"><block tt:if="{{shop_product.length>0}}"><view><block tt:for="{{shop_product}}" tt:for-item="item" tt:for-index="index"><block><view class="flex active-options"><view class="active-image" data-url="{{'pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.pic}}"></image></view><view class="flex flex-y-center" style="flex:1;"><view class="active-info-list flex-col"><view class="active-name" data-url="{{'pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">{{item.name}}</view><view class="active-price" data-url="{{'pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">{{"￥"+item.sell_price+"元"}}</view><view class="active-fun-view flex flex-y-center"><block tt:if="{{set.invite_land==1}}"><block><block tt:if="{{$root.m0=='app'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" catchtap="__e">邀请好友</view></block><block tt:else><block tt:if="{{$root.m1=='mp'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchtap="__e">邀请好友</view></block><block tt:else><block tt:if="{{$root.m2=='h5'}}"><view class="fun-class invite-friends" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" catchtap="__e">邀请好友</view></block><block tt:else><button class="btn2 fun-class invite-friends" style="line-height:32rpx;" open-type="share" data-id="{{item.collage_jipin_id}}" data-name="{{item.collage_jipin_name}}" data-pic="{{item.pic}}">邀请好友</button></block></block></block></block></block><block tt:if="{{set.invite_land==0}}"><view class="fun-class invite-friends" data-url="/activity/commission/poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">邀请好友</view></block><view class="fun-class view-details" style="margin-left:20rpx;" data-url="{{'pages/shop/product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看详情</view></view></view><view class="select-view flex flex-y-center flex-x-center" data-index="{{index}}" data-proid="{{item.id}}" data-oid="{{datalist.id}}" data-status="{{datalist.status}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="flex flex-y-center flex-x-center select-view-options"><block tt:if="{{item.isfg}}"><view class="tag-icon"></view></block></view></view></view></view></block></block></view></block><block tt:else><view class="flex active-options" style="text-align:center;display:block;color:#959494;">暂无数据~</view></block></view></block></view></block><block tt:if="{{nodata}}"><nodata vue-id="c09001a2-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="c09001a2-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="c09001a2-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="c09001a2-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c09001a2-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>