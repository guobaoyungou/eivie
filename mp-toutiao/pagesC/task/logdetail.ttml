<view class="view-width"><block tt:if="{{isload}}"><block><view class="tasklist"><view><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="task-item"><view style="width:60rpx;height:60rpx;border-radius:50% 50%;overflow:hidden;"><image style="width:100%;height:100%;" src="{{item.$orig.pic}}"></image></view><view style="width:400rpx;"><view>{{item.$orig.name}}</view><view style="font-size:26rpx;color:#8E8E8E;">{{''+item.$orig.shortcontent+''}}</view><view style="font-size:26rpx;"><block tt:if="{{item.$orig.givescore>0}}"><text style="{{('color:'+item.m0)}}">{{'+'+item.$orig.givescore+item.m1}}</text></block><block tt:if="{{item.$orig.givecouponid>0&&item.$orig.givecouponname}}"><text style="{{(item.$orig.givescore>0?'margin-left: 10rpx;color:'+item.m2:'color:'+item.m3)}}">{{'+'+item.$orig.givecouponname+item.m4}}</text></block></view></view><block tt:if="{{item.$orig.status==0}}"><view class="opt" style="{{('background-color: rgba('+item.m5+',0.75)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去完成</view></block><block tt:if="{{item.$orig.status==1}}"><view class="opt" style="{{('background-color: rgba('+item.m6+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">已完成</view></block><block tt:if="{{item.$orig.status==-2}}"><view class="opt" style="{{('background-color: rgba('+item.m7+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">已失效</view></block><block tt:if="{{item.$orig.status==-1}}"><view class="opt" style="{{('background-color: rgba('+item.m8+',0.45)')}}" data-url="{{'detail?type=2&detailid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">已关闭</view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="7eeb51f0-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="7eeb51f0-2" bind:__l="__l"></nomore></block></view><view style="width:100%;height:20rpx;"></view></block></block><block tt:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><scroll-view class="content" scroll-y="true"><view style="padding:0 20rpx;"><parse vue-id="7eeb51f0-3" content="{{set.content}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" bind:navigate="__e" bind:__l="__l"></parse></view></scroll-view></view></view></block><popmsg class="vue-ref" vue-id="7eeb51f0-4" data-ref="popmsg" bind:__l="__l"></popmsg><block tt:if="{{loading}}"><loading vue-id="7eeb51f0-5" bind:__l="__l"></loading></block></view>