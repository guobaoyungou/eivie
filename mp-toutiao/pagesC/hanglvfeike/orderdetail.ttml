<view class="container"><block tt:if="{{isload}}"><block><view class="page-bg-view" style="{{'background-image:'+('linear-gradient('+$root.m0+' 30%,transparent)')+';'}}"></view><block tt:if="{{detail.status==0}}"><view class="head"><view class="head-title">等待付款</view><block tt:if="{{detail.ischange&&detail.ischange==1}}"><block><view class="head-title2">改签通过未付款的订单会失效或被关闭，请尽快付款</view></block></block><block tt:else><block><view class="head-title2">未付款订单会失效或被关闭，请尽快付款</view></block></block><block tt:if="{{djs}}"><view class="head-title2">剩余时间：<text style="color:red;">{{djs}}</text></view></block></view></block><view class="hangban-info-view flex flex-y-center"><view class="logo-view"><block tt:if="{{detail.flightdata&&detail.flightdata.airlinePic}}"><image src="{{pre_url+'/static/img/planeticket/jipaiologo.png'}}"></image></block><block tt:else><image src="{{pre_url+'/static/img/planeticket/jipaiologo.png'}}"></image></block></view><view class="flex-col"><view class="hangban-name">{{detail.airlineName+detail.flightNo}}</view><view class="hangban-time">{{detail.fromDate+" "+detail.week}}</view></view></view><block tt:if="{{detail.flightdata}}"><view class="hangban-top-view"><view class="address-info-view flex flex-y-center"><view class="address-name-view flex-col flex-xy-center"><view class="depart-name">{{detail.flightdata.deparAirportName+detail.flightdata.departTerminal}}</view><view class="depart-time">{{detail.flightdata.departTime}}</view></view><view class="location-icon flex-col flex-y-center"><block tt:if="{{detail.flightdata.stopname}}"><view class="stop-tag">停</view></block><image src="{{pre_url+'/static/img/planeticket/info_icon.png'}}" mode="widthFix"></image><block tt:if="{{detail.flightdata.stopname}}"><view style="font-size:24rpx;text-align:center;color:#676767;">{{detail.flightdata.stopname}}</view></block><view class="travel-time">{{detail.flightdata.flightTime}}</view></view><view class="address-name-view flex-col flex-xy-center"><view class="depart-name">{{detail.flightdata.arriveAirportName+detail.flightdata.arriveTerminal}}</view><view class="depart-time">{{detail.flightdata.arriveTime}}</view></view></view><view class="divider-view"></view><view class="supplement-view flex"><view>{{''+detail.flightdata.planeCName}}<block tt:if="{{detail.planeTypeName}}"><text>{{'('+detail.flightdata.planeTypeName+")"}}</text></block></view><block tt:if="{{detail.flightdata.mealsname}}"><view style="padding:0rpx 15rpx;">|</view></block><block tt:if="{{detail.flightdata.mealsname}}"><view>{{detail.flightdata.mealsname}}</view></block><block tt:if="{{!detail.ischange&&detail.status>=0&&detail.status<=3||detail.ischange&&detail.status>0&&detail.status<=3}}"><view data-event-opts="{{[['tap',[['getguize',['$event']]]]]}}" style="width:160rpx;display:flex;align-items:center;" bindtap="__e"><text style="padding:0rpx 15rpx;">|</text><text style="{{'color:'+($root.m1)+';'}}">退改规则</text><image style="width:28rpx;height:28rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view></view></block><block tt:if="{{ordergoods}}"><view class="product"><block tt:if="{{detail.tipmsg}}"><view class="tips-text">{{detail.tipmsg}}</view></block><block tt:for="{{ordergoods}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="box"><view class="book-person-view flex flex-y-center"><view class="left-info-view flex-col "><view class="left-topinfo flex flex-y-center"><view class="name-view">{{item.name}}</view><view>{{item.cardNo}}</view></view><block tt:if="{{item.status==4}}"><view class="status-view flex flex-y-center"><view style="color:#bbb;">已关闭</view></view></block><view class="status-view flex flex-y-center" style="justify-content:space-between;"><block tt:if="{{item.refund_status!=0}}"><view style="display:flex;margin-right:20rpx;"><view style="color:#8D8D8D;font-weight:bold;">退款状态：</view><block tt:if="{{item.refund_status==1}}"><text style="color:#ff8758;">审核中</text></block><block tt:if="{{item.refund_status==2}}"><text style="color:green;">已审核</text></block><block tt:if="{{item.refund_status==3}}"><text style="color:red;">已退款</text></block><block tt:if="{{item.refund_status==4}}"><text style="color:#bbb;">已驳回</text></block></view></block><block tt:if="{{item.change_status!=0}}"><view style="display:flex;"><text style="color:#8D8D8D;font-weight:bold;">改签状态：</text><block tt:if="{{item.change_status==1}}"><text style="color:#ff8758;">待审核</text></block><block tt:if="{{item.change_status==2}}"><text style="color:green;">已审核</text></block><block tt:if="{{item.change_status==3}}"><text style="color:#999;">已完成</text></block><block tt:if="{{item.change_status==-1}}"><text style="color:#bbb;">已取消</text></block><block tt:if="{{item.change_status==-2}}"><text style="color:#bbb;">已驳回</text></block></view></block></view><block tt:if="{{item.totalprice>=0}}"><view class="status-view"><view><text style="color:#8D8D8D;font-weight:bold;">费用：</text><text style="color:red;">{{"￥"+item.totalprice}}</text></view><view style="color:#333;margin-top:10rpx;"><block tt:if="{{!detail.ischange}}"><block><block tt:if="{{item.taxFee>0||item.fuelFee>0||item.serveprice>0}}"><view class="t1" style="display:flex;flex-wrap:wrap;font-size:26rpx;margin-top:10rpx;">(<block tt:if="{{item.price>0}}"><view style="margin-right:10rpx;">票价<text style="color:red;">{{"￥"+item.price}}</text></view></block><block tt:if="{{item.taxFee>0}}"><view style="margin-right:10rpx;">+ 机建费<text style="color:red;">{{"￥"+item.taxFee}}</text></view></block><block tt:if="{{item.fuelFee>0}}"><view style="margin-right:10rpx;">+ 燃油费<text style="color:red;">{{"￥"+item.fuelFee}}</text></view></block><block tt:if="{{item.serveprice>0}}"><view>+ 服务费<text style="color:red;">{{"￥"+item.serveprice}}</text></view></block>)</view></block></block></block><block tt:else><block><block tt:if="{{item.upgradeFee>0||item.changeFee>0||item.serveprice>0}}"><view class="t1" style="display:flex;flex-wrap:wrap;font-size:26rpx;margin-top:10rpx;">(<block tt:if="{{item.upgradeFee>0}}"><view style="margin-right:10rpx;">+ 升舱费<text style="color:red;">{{"￥"+item.upgradeFee}}</text></view></block><block tt:if="{{item.changeFee>0}}"><view style="margin-right:10rpx;">+ 手续费<text style="color:red;">{{"￥"+item.changeFee}}</text></view></block><block tt:if="{{item.serveprice>0}}"><view>+ 服务费<text style="color:red;">{{"￥"+item.serveprice}}</text></view></block>)</view></block></block></block></view></view></block></view></view></view></block></view></block><view class="orderinfo"><view class="item"><text class="t1">机票类型</text><text class="t2"><block tt:if="{{!detail.ischange}}"><block>普通机票</block></block><block tt:else><block>改签机票</block></block></text></view><view class="item"><text class="t1">联系人</text><text class="t2">{{detail.contacts}}</text></view><view class="item"><text class="t1">联系电话</text><text class="t2">{{detail.mobile}}</text></view><view class="item flex-bt"><text class="t1">订单编号</text><view class="ordernum-info flex-bt"><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text><view class="btn-class" style="{{'background-color:'+($root.m2)+';'}}" data-text="{{detail.ordernum}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" bindtap="__e">复制</view></view></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block tt:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.paytypeid}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><view class="item"><text class="t1">实付款</text><block tt:if="{{detail.ischange&&detail.status==0&&detail.change_status==1}}"><text class="t2 red">审核中</text></block><block tt:else><text class="t2 red">{{"￥"+detail.totalprice+''}}</text></block></view><view class="item"><text class="t1">订单状态</text><block tt:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block tt:if="{{detail.status==1}}"><text class="t2">待出票</text></block><block tt:if="{{detail.status==2}}"><text class="t2">已出票</text></block><block tt:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block tt:if="{{detail.refund_money>0}}"><block><view class="item"><view class="t1">退款金额</view><view class="t2 red">{{'已退款,¥'+detail.refund_money+''}}</view></view></block></block><block tt:if="{{detail.change_status!=0}}"><block><view class="item"><view class="t1">改签状态</view><block tt:if="{{detail.change_status==1}}"><view class="t2" style="color:#ff8758;">改签待审核</view></block><block tt:if="{{detail.change_status==2}}"><view class="t2" style="color:green;">改签已审核</view></block><block tt:if="{{detail.change_status==3}}"><view class="t2" style="color:#999;">改签已完成</view></block><block tt:if="{{detail.change_status==-1}}"><view class="t2" style="color:#bbb;">改签已取消</view></block><block tt:if="{{detail.change_status==-2}}"><view class="t2" style="color:#bbb;">改签已驳回</view></block></view></block></block><block tt:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block tt:if="{{linktel}}"><view class="btn2" data-phone="{{linktel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" bindtap="__e">联系客服</view></block><block tt:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-ischange="{{detail.ischange}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" bindtap="__e"><block tt:if="{{detail.ischange}}"><text>取消改签</text></block><block tt:else><text>关闭订单</text></block></view><block tt:if="{{detail.canpay}}"><view class="btn1" style="{{'background:'+($root.m3)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block></block></block><block tt:if="{{detail.canchange}}"><view class="btn2" data-url="{{'change?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">改签</view></block><block tt:if="{{detail.canrefund}}"><view class="btn2" data-url="{{'refund?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">退款</view></block><block tt:if="{{detail.refundcount>0}}"><view class="btn2" data-url="{{'refundlist?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">售后详情</view></block><block tt:if="{{$root.g0}}"><block><view class="btn2" data-url="{{'invoice?type=shop&orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发票</view></block></block><block tt:if="{{detail.ischange&&detail.showold&&detail.change_oldorderid>0}}"><view class="btn2" data-url="{{'orderlist?orderid='+detail.change_oldorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">改签前订单</view></block><block tt:if="{{detail.ischange&&detail.showoriginal&&detail.change_original_orderid>0}}"><view class="btn2" data-url="{{'orderlist?orderid='+detail.change_original_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">最初订单</view></block></view></block></block><uni-popup class="vue-ref" vue-id="a2f3a0a2-1" id="popup" type="bottom" data-ref="popup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup__content" style="bottom:0;padding-top:0;padding-bottom:0;max-height:86vh;background-color:#fff;border-radius:16rpx 16rpx;overflow:hidden;"><dd-tab vue-id="{{('a2f3a0a2-2')+','+('a2f3a0a2-1')}}" itemdata="{{['产品说明','行李规定','退改规则']}}" itemst="{{['0','1','2']}}" st="{{st2}}" showstatus="{{showstatus2}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab2']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><scroll-view style="height:auto;max-height:calc(86vh - 130rpx);" scrollIntoView="{{intoviewid}}" scrollWithAnimation="{{true}}" scroll-y="{{true}}"><block tt:if="{{guize}}"><view style="padding:0 20rpx;"><view class="popup_title" id="scrollid0">产品说明</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m4+',0.4)')}}">票价/其他说明</view><block tt:if="{{guize.baoxiaocontent}}"><view style="border-top:2rpx solid #f1f1f1;"><view style="display:flex;align-items:center;"><view class="popup-item-title">报销凭证</view><view class="popup-item-content">{{''+guize.baoxiaocontent+''}}</view></view></view></block><block tt:if="{{guize.pricecontent}}"><view style="border-top:2rpx solid #f1f1f1;"><view style="display:flex;align-items:center;"><view class="popup-item-title">价格说明</view><view class="popup-item-content">{{''+guize.pricecontent+''}}</view></view></view></block></view><view class="popup_title" id="scrollid1">行李规定</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m5+',0.4)')}}">托运/手提行李</view><block tt:if="{{guize.checkedluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">托运行李</view><view class="popup-item-content">{{''+guize.checkedluggage+''}}</view></view></block><block tt:if="{{guize.cabinluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">手提行李</view><view class="popup-item-content">{{''+guize.cabinluggage+''}}</view></view></block><block tt:if="{{guize.infantluggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">婴儿行李</view><view class="popup-item-content">{{''+guize.infantluggage+''}}</view></view></block><block tt:if="{{guize.luggage}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">其他说明</view><view class="popup-item-content">{{''+guize.luggage+''}}</view></view></block></view><view class="popup_title" id="scrollid2">退改规则</view><view style="border:2rpx solid #f1f1f1;border-radius:8rpx 8rpx;"><view style="{{('padding: 20rpx;background:rgba('+$root.m6+',0.4)')}}">退改费用/规则</view><block tt:if="{{guize.refundStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">退改费</view><view class="popup-item-content"><block tt:if="{{guize.refundStipulate.rules&&guize.refundStipulate.rules.length>0}}"><block><block tt:for="{{guize.refundStipulate.rules}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view>{{''+item.txt+" ￥"+item.charge+'/人'}}</view></block></block></block><block tt:else><block><block tt:if="{{guize.refundStipulate.comment}}"><view>{{guize.refundStipulate.comment}}</view></block></block></block></view></view></block><block tt:if="{{guize.changeStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">同舱改签票</view><view class="popup-item-content"><block tt:if="{{guize.changeStipulate.rules&&guize.changeStipulate.rules.length>0}}"><block><block tt:for="{{guize.changeStipulate.rules}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view>{{''+item.txt+" ￥"+item.charge+'/人'}}</view></block></block></block><block tt:else><block><block tt:if="{{guize.changeStipulate.comment}}"><view>{{guize.changeStipulate.comment}}</view></block></block></block></view></view></block><block tt:if="{{guize.modifyStipulate}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">签转</view><view class="popup-item-content">{{''+guize.modifyStipulate+''}}</view></view></block><block tt:if="{{guize.othercontent}}"><view style="display:flex;align-items:center;border-top:2rpx solid #f1f1f1;"><view class="popup-item-title">其他说明</view><view class="popup-item-content">{{''+guize.othercontent+''}}</view></view></block></view></view></block><view style="width:100%;height:auto;max-height:10vh;"></view></scroll-view></view></uni-popup><block tt:if="{{loading}}"><loading vue-id="a2f3a0a2-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="a2f3a0a2-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="a2f3a0a2-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="a2f3a0a2-6" bind:__l="__l"></wxxieyi></view>