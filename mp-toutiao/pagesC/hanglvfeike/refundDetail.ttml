<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop_refund.jpg);background-size:100%')}}"><block tt:if="{{detail.refund_status==0}}"><view class="f1"><view class="t1">已取消</view></view></block><block tt:if="{{detail.refund_status==1}}"><view class="f1"><view class="t1">审核中</view></view></block><block tt:if="{{detail.refund_status==2}}"><view class="f1"><view class="t1">已审核</view></view></block><block tt:if="{{detail.refund_status==3}}"><view class="f1"><view class="t1">已通过</view></view></block><block tt:if="{{detail.refund_status==4}}"><block><view class="t1">已驳回</view></block></block></view><block tt:if="{{detail.refundusers&&detail.refundusers.length>0}}"><view class="product"><block tt:for="{{detail.refundusers}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="content"><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.cardNo}}</text></view></view></block></view></block><view class="orderinfo"><view class="item"><text class="t1">售后单编号</text><text class="t2" user-select="true" selectable="true">{{detail.refund_ordernum}}</text></view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true" data-url="{{'detail?id='+detail.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{detail.ordernum}}</text></view><view class="item"><text class="t1">申请时间</text><text class="t2">{{detail.createtime}}</text></view></view><view class="orderinfo"><view class="item"><text class="t1">退款状态</text><block tt:if="{{detail.refund_status==0}}"><text class="t2 grey">已取消</text></block><block tt:if="{{detail.refund_status==1}}"><text class="t2 red">审核中</text></block><block tt:if="{{detail.refund_status==2}}"><text class="t2 red">已审核</text></block><block tt:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已通过￥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==4}}"><text class="t2 red">已驳回</text></block></view><view class="item"><text class="t1">原因</text><text class="t2">{{detail.refund_reason}}</text></view><block tt:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2">{{detail.refund_checkremark}}</text></view></block><block tt:if="{{detail.refund_pics}}"><view class="item"><text class="t1">图片</text><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><block tt:for="{{detail.refund_pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view></block></block><block tt:if="{{loading}}"><loading vue-id="8243e5fa-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="8243e5fa-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="8243e5fa-3" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="8243e5fa-4" bind:__l="__l"></wxxieyi></view>