<block tt:if="{{isload}}"><view class="page-view"><view class="top-view flex-col"><block tt:if="{{headlist&&headlist.length>0}}"><view class="time-view flex flex-y-center"><view class="time-left-view flex"><scroll-view style="flex:1;white-space:nowrap;" scroll-x="{{true}}"><block tt:for="{{headlist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view style="display:inline-block;width:20%;"><view class="{{((item.issel?'time-options-active':'')+' '+'time-options flex-col')}}" data-index="{{index}}" data-daytime="{{item.daytime}}" data-event-opts="{{[['tap',[['changeTime',['$event']]]]]}}" bindtap="__e"><view class="time-title">{{item.week}}</view><view class="time-num">{{item.daystr}}</view><view class="time-title"><block tt:if="{{item.price>=0}}"><text>{{"￥"+item.price}}</text></block><block tt:else><text>查看</text></block></view></view></view></block></block></scroll-view></view><view class="time-right-view flex flex-y-center flex-x-center"><image class="rili-icon" src="{{pre_url+'/static/img/planeticket/rili.png'}}" data-event-opts="{{[['tap',[['toSelectDate',['$0',1],['fromDate']]]]]}}" bindtap="__e"></image></view></view></block></view><view class="jipiao-list-view flex-col"><block tt:if="{{datalist&&datalist.length>0}}"><block><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><block tt:if="{{item.$orig.showstatus}}"><view class="jipiao-options flex-col" style="position:relative;"><block tt:if="{{item.$orig.minSalePrice<=minprice}}"><view class="minpirce-wc"><view class="minpirce-title">今日低价</view></view></block><view style="position:relative;"><view class="info-view flex" data-index="{{index}}" data-index2="{{-1}}" data-event-opts="{{[['tap',[['goprice',['$event']]]]]}}" bindtap="__e"><block tt:if="{{item.$orig.airlinePic}}"><view class="info-touxiang"><image src="{{item.$orig.airlinePic}}"></image></view></block><view class="info-details-view flex flex-y-center"><view class="location-view flex-col"><view class="location-time">{{item.$orig.departTime}}</view><view class="location-name">{{item.$orig.deparAirportName+item.$orig.departTerminal}}</view></view><view class="location-icon"><block tt:if="{{item.$orig.stopname}}"><view class="stop-tag">停</view></block><image src="{{pre_url+'/static/img/planeticket/jiantou.png'}}" mode="widthFix"></image><block tt:if="{{item.$orig.stopname}}"><view style="font-size:24rpx;text-align:center;color:#676767;">{{item.$orig.stopname}}</view></block></view><view class="location-view flex-col"><view class="location-time">{{item.$orig.arriveTime}}</view><view class="location-name">{{item.$orig.arriveAirportName+item.$orig.arriveTerminal}}</view></view></view><view class="price-view flex-col flex-y-center"><view class="price-num flex flex-y-center"><view style="font-size:24rpx;">￥</view><view style="font-size:38rpx;">{{item.$orig.minSalePrice}}</view></view><view class="price-name">{{''+item.$orig.levelname+''}}</view></view></view><view class="jipiao-introduce" data-index="{{index}}" data-index2="{{-1}}" data-event-opts="{{[['tap',[['goprice',['$event']]]]]}}" bindtap="__e">{{''+item.$orig.airlineName+item.$orig.no+"| "+item.$orig.planeCName+" ("+item.$orig.planeTypeName+") | "+item.$orig.flightTime+''}}</view><block tt:if="{{item.$orig.sharedata&&item.$orig.sharedata.length>0}}"><block><view class="shared-selling-view flex-col"><view class="shared-title flex flex-y-center"><image class="feiji-icon" src="{{pre_url+'/static/img/planeticket/feiji.png'}}"></image><view class="title-text-view">{{"此航班还有"+item.$orig.sharename+"等"}}<text style="{{('color:'+item.m0)}}">共享</text>售卖</view></view><block tt:for="{{item.$orig.sharedata}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><block><view class="sell-options flex" style="{{(index2>=2&&!item.$orig.showmore?'display:none':'display:flex')}}" data-index="{{index}}" data-index2="{{index2}}" data-event-opts="{{[['tap',[['goprice',['$event']]]]]}}" catchtap="__e"><view class="sell-left-view flex flex-y-center"><block tt:if="{{item2.airlinePic}}"><view class="sell-touxiang"><image src="{{item2.airlinePic}}"></image></view></block><view class="sell-name">{{''+item.$orig.airlineName+" "+item.$orig.no+''}}</view></view><view class="flex flex-y-center"><view class="sell-price">{{"￥"+item.$orig.minSalePrice}}</view><image class="jiantou-icon" src="{{pre_url+'/static/img/planeticket/arrowright2.png'}}"></image></view></view></block></block><block tt:if="{{item.$orig.sharenum>2&&!item.$orig.showmore}}"><view class="more-view flex" data-index="{{index}}" data-event-opts="{{[['tap',[['goshowmore',['$event']]]]]}}" catchtap="__e"><view>展开更多共享</view><image src="{{pre_url+'/static/img/location/down-grey.png'}}"></image></view></block><block tt:if="{{item.$orig.sharenum>2&&item.$orig.showmore}}"><view class="more-view flex" data-index="{{index}}" data-event-opts="{{[['tap',[['goshowmore',['$event']]]]]}}" catchtap="__e"><view>收起更多共享</view><image src="{{pre_url+'/static/img/location/up-grey.png'}}"></image></view></block></view></block></block></view></view></block></block></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="3c77a0ec-1" text="暂无航班信息" bind:__l="__l"></nodata></block></view><view style="width:100%;height:90rpx;"></view><view style="position:fixed;bottom:0;left:0;width:100%;display:flex;justify-content:space-around;background-color:#fff;padding:20rpx;"><view style="display:flex;align-items:center;" data-field="price" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e"><view style="{{(field=='price'?'color:'+$root.m1:'')}}">价格</view><view><view class="iconfont iconshangla" style="{{(field=='price'&&order=='asc'?'color:'+$root.m2:'')}}"></view><view class="iconfont icondaoxu" style="{{(field=='price'&&order=='desc'?'color:'+$root.m3:'')}}"></view></view></view><view style="display:flex;align-items:center;" data-field="time" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e"><view style="{{(field=='time'?'color:'+$root.m4:'')}}">出发时间</view><view><view class="iconfont iconshangla" style="{{(field=='time'&&order=='asc'?'color:'+$root.m5:'')}}"></view><view class="iconfont icondaoxu" style="{{(field=='time'&&order=='desc'?'color:'+$root.m6:'')}}"></view></view></view><view data-event-opts="{{[['tap',[['showDrawer',['showRight']]]]]}}" catchtap="__e">筛选<text class="{{('iconfont iconshaixuan '+(showfilter?'active':''))}}"></text></view></view><uni-drawer class="vue-ref" vue-id="3c77a0ec-2" mode="right" width="{{280}}" data-ref="showRight" data-event-opts="{{[['^change',[['change',['$event','showRight']]]]]}}" bind:change="__e" bind:__l="__l" vue-slots="{{['default']}}"><scroll-view class="filter-scroll-view filter-page" scroll-y="true"><view class="filter-scroll-view-box"><view class="search-filter" style="padding-bottom:150rpx;"><view class="filter-title">筛选</view><block tt:if="{{departTimes&&departTimes.length>0}}"><block><view class="filter-content-title">起飞时间</view><view class="search-filter-content"><view class="filter-item" style="{{(seldepartTimes2===''?'color:'+$root.m7+';background:rgba('+$root.m8+',0.1)':'')}}" data-item="all" data-event-opts="{{[['tap',[['departTimesClick',['$event']]]]]}}" catchtap="__e">全部</view><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="filter-item" style="{{(seldepartTimes2==item.$orig?'color:'+item.m9+';background:rgba('+item.m10+',0.1)':'')}}" data-item="{{item.$orig}}" data-event-opts="{{[['tap',[['departTimesClick',['$event']]]]]}}" catchtap="__e">{{item.$orig}}</view></block></block></view></block></block><block tt:if="{{planeTypes&&planeTypes.length>0}}"><block><view class="filter-content-title">机型</view><view class="search-filter-content"><view class="filter-item" style="{{(selplaneTypes2===''?'color:'+$root.m11+';background:rgba('+$root.m12+',0.1)':'')}}" data-item="all" data-event-opts="{{[['tap',[['planeTypesClick',['$event']]]]]}}" catchtap="__e">全部</view><block tt:for="{{$root.l2}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="filter-item" style="{{(selplaneTypes2==item.$orig.type?'color:'+item.m13+';background:rgba('+item.m14+',0.1)':'')}}" data-item="{{item.$orig.type}}" data-event-opts="{{[['tap',[['planeTypesClick',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block></block><block tt:if="{{airlines&&airlines.length>0}}"><block><view class="filter-content-title">航空公司</view><view class="search-filter-content"><view class="filter-item" style="{{(selairlines2===''?'color:'+$root.m15+';background:rgba('+$root.m16+',0.1)':'')}}" data-item="all" data-event-opts="{{[['tap',[['airlinesClick',['$event']]]]]}}" catchtap="__e">全部</view><block tt:for="{{$root.l3}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="filter-item" style="{{(selairlines2==item.$orig.code?'color:'+item.m17+';background:rgba('+item.m18+',0.1)':'')}}" data-item="{{item.$orig.code}}" data-event-opts="{{[['tap',[['airlinesClick',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block></block><view class="search-filter-btn"><view data-event-opts="{{[['tap',[['filterReset',['$event']]]]]}}" class="btn" bindtap="__e">重置</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="btn2" style="{{'background:'+($root.m19)+';'}}" bindtap="__e">确定</view></view></view></view></scroll-view></uni-drawer><block tt:if="{{loading}}"><loading vue-id="3c77a0ec-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="3c77a0ec-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="3c77a0ec-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>