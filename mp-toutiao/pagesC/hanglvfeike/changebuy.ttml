<block tt:if="{{isload}}"><view class="page-view"><view style="background-color:#fff;padding:20rpx;"><view style="display:flex;align-items:center;margin:25rpx 0;justify-content:space-between;"><view><view style="font-weight:bold;font-size:32rpx;text-align:center;">{{''+changesdata.departAirport+changesdata.departTerminal+" - "+changesdata.arriveAirport+changesdata.arriveTerminal+" "+changeTime+" "+week+''}}</view></view></view></view><view style="background-color:#fff;border-radius:10rpx 10rpx;padding:20rpx;margin:20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="font-weight:bold;font-size:32rpx;">改签人员<block tt:if="{{changesdata&&changesdata.showstock}}"><text style="font-size:24rpx;">{{"(剩"+changesdata.stock+"张)"}}</text></block></view></view><block tt:if="{{userdata&&userdata.length>0}}"><view style="padding:20rpx 0;"><block tt:for="{{userdata}}" tt:for-item="item2" tt:for-index="index" tt:key="index"><view style="display:flex;align-items:center;"><view style="margin-left:20rpx;"><view>{{item2.name}}</view><view style="color:#999;">{{item2.typename+" "+item2.usercard}}</view></view></view></block></view></block><view style="line-height:80rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">改签原因</view><textarea style="width:100%;border:2rpx solid #f1f1f1;border-radius:4rpx;padding:10rpx;" placeholder="请输入改签原因" placeholder-style="color:#999;padding: 10rpx;" name="reason" data-event-opts="{{[['input',[['inputReason',['$event']]]]]}}" bindinput="__e"></textarea></view></view></view><block tt:if="{{changesdata.showFee||changesdata.showchildFee}}"><view style="background-color:#fff;border-radius:10rpx 10rpx;padding:20rpx;margin:20rpx;"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="font-weight:bold;font-size:32rpx;">费用明细</view></view><block tt:if="{{changesdata.showFee}}"><view style="line-height:80rpx;"><block tt:if="{{changesdata.gqFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">手续费</view><view style="{{('color:'+$root.m0)}}">{{"￥"+changesdata.gqFee+"/人"}}</view></view></block><block tt:if="{{changesdata.upgradeFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">升舱费</view><view style="{{('color:'+$root.m1)}}">{{"￥"+changesdata.upgradeFee+"/人"}}</view></view></block><block tt:if="{{changesdata.allFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">总收费</view><view style="{{('color:'+$root.m2)}}">{{"￥"+changesdata.allFee+"/人"}}</view></view></block></view></block><block tt:if="{{changesdata.showchildFee}}"><view style="line-height:80rpx;"><block tt:if="{{changesdata.childGqFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童手续费</view><view style="{{('color:'+$root.m3)}}">{{"￥"+changesdata.childGqFee+"/人"}}</view></view></block><block tt:if="{{changesdata.childUpgradeFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童升舱费</view><view style="{{('color:'+$root.m4)}}">{{"￥"+changesdata.childUpgradeFee+"/人"}}</view></view></block><block tt:if="{{changesdata.childAllFee>0}}"><view style="display:flex;justify-content:space-between;align-items:center;"><view style="width:150rpx;">儿童总费用</view><view style="{{('color:'+$root.m5)}}">{{"￥"+changesdata.childAllFee+"/人"}}</view></view></block></view></block></view></block><block tt:if="{{xieyidata&&xieyidata.length>0}}"><view style="width:100%;height:290rpx;"></view></block><block tt:else><view style="width:100%;height:182rpx;"></view></block><view class="footer  notabbarbot"><view style="display:flex;align-items:center;padding:20rpx 0;"><button data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="op" style="{{'width:50%;'+('background:'+('linear-gradient(-90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';')}}" bindtap="__e">确定申请改签</button></view></view><block tt:if="{{loading}}"><loading vue-id="8f5c42d0-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="8f5c42d0-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="8f5c42d0-3" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>