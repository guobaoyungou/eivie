<view class="container"><block tt:if="{{isload}}"><block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="list-item"><view class="item-row" style="margin-bottom:40rpx;"><view><block tt:if="{{activity.business}}"><text class="tag" style="{{'background-color:'+($root.m0)+';'}}">{{activity.business+"免单"}}</text></block><block tt:else><text class="tag" style="{{'background-color:'+($root.m1)+';'}}">平台免单</text></block></view><view style="font-weight:bold;">{{"第 "+item.ranking+"名"}}</view><block tt:if="{{item.status==0}}"><view style="font-weight:bold;">{{"到达 "+item.opennum+"人开奖"}}</view></block><block tt:else><view style="font-weight:bold;"><block tt:if="{{item.is_winner}}"><text style="color:red;">已中奖</text></block><block tt:else><text style="color:grey;">未中奖</text></block></view></block></view><view class="item-row-text"><text>活动名称</text>{{"："+item.name}}</view><view class="item-row-text"><text>订单号</text>{{"："+item.ordernum}}</view><view class="item-row-text"><text>消费金额</text>{{"："+item.consumption_amt}}</view><view class="item-row-text"><text>参与用户</text>{{"："+item.nickname}}</view><view class="item-row-text"><text>排队时间</text>{{"："+item.createtime}}</view><block tt:if="{{item.mdname}}"><view class="item-row-text"><text>所在门店</text>{{"："+item.mdname}}</view></block></view></block></view><block tt:if="{{nodata}}"><nodata vue-id="d7003d72-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="d7003d72-2" bind:__l="__l"></nomore></block></block></block><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" style="{{'background-color:'+($root.m2)+';'}}" bindtap="__e">活动规则</button><block tt:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule" style="{{'background-color:'+($root.m3)+';'}}"><view class="h2">活动规则</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><block tt:if="{{activity.hd&&activity.hd.guize}}"><text decode="true" space="true">{{activity.hd.guize}}</text></block></view></view></view></view></block><block tt:if="{{loading}}"><loading vue-id="d7003d72-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="d7003d72-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d7003d72-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>