.product-container{width:100%;margin-top:20rpx;font-size:26rpx;padding:0 24rpx}.right-btn{float:right;height:60rpx;line-height:60rpx;width:120rpx;text-align:center;color:#fff;border-radius:4rpx 4rpx;font-size:26rpx;margin-right:10rpx}.dp-product-item2{margin-bottom:12rpx;padding:20rpx;width:100%;border-bottom:1rpx solid #f6f6f6;background-color:#fff}.dp-product-itemlist2{height:auto;position:relative;overflow:hidden;padding:0;display:flex;flex-wrap:wrap}.dp-product-itemlist2 .item{width:100%;display:inline-block;position:relative;background:#fff;display:flex;border-radius:10rpx;align-items:center}.dp-product-itemlist2 .product-pic{width:30%;height:0;overflow:hidden;background:#fff;padding-bottom:30%;position:relative;border-radius:4px}.dp-product-itemlist2 .product-pic .image{position:absolute;top:0;left:0;width:100%;height:auto}.dp-product-itemlist2 .product-pic .saleimg{position:absolute;width:120rpx;height:auto;top:-6rpx;left:-6rpx}.dp-product-itemlist2 .product-info{width:70%;padding:6rpx 10rpx 5rpx 20rpx;position:relative}.dp-product-itemlist2 .product-info .p1{color:#323232;font-weight:700;font-size:28rpx;line-height:36rpx;display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden;height:72rpx;word-break:break-all}.dp-product-itemlist2 .product-info .p2{margin-top:10rpx;overflow:hidden}.dp-product-itemlist2 .product-info .p2 .t1{font-size:36rpx}.dp-product-itemlist2 .product-info .p2 .t2{margin-left:10rpx;font-size:24rpx;color:#aaa;text-decoration:line-through}.dp-product-itemlist2 .product-info .p2 .t3{margin-left:10rpx;font-size:24rpx;color:#888}.dp-product-itemlist2 .product-info .p3{display:flex;align-items:center;overflow:hidden;margin-top:10rpx}.dp-product-itemlist2 .product-info .p3-1{font-size:20rpx;height:30rpx;line-height:30rpx;text-align:right;color:#999}.dp-product-itemlist2 .product-info .p4{width:48rpx;height:48rpx;border-radius:50%;position:absolute;display:relative;bottom:6rpx;right:4rpx;text-align:center}.dp-product-itemlist2 .product-info .p4 .icon_gouwuche{font-size:28rpx;height:48rpx;line-height:48rpx}.dp-product-itemlist2 .product-info .p4 .img{width:100%;height:100%}.dp-product-itemlist2 .product-info .p2 .t1-m{font-size:32rpx;padding-left:8rpx}.dp-product-itemlist2 .product-info .p5{font-size:24rpx;font-weight:700;margin:6rpx 0}.dp-product-itemlist2 .product-info .p6{font-size:24rpx;display:flex;flex-wrap:wrap;margin-top:6rpx}.dp-product-itemlist2 .product-info .p6-m{text-align:center;padding:6rpx 10rpx;border-radius:6rpx;margin:6rpx}.dp-product-itemlist2 .binfo{padding-top:6rpx;display:flex;align-items:center;min-width:0}.dp-product-itemlist2 .binfo .t1{width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;flex-shrink:0}.dp-product-itemlist2 .binfo .t2{color:#666;font-size:26rpx;font-weight:400;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.dp-product-itemlist2 .couponitem{width:100%;font-size:24rpx;color:#333;display:flex;align-items:center}.dp-product-itemlist2 .couponitem .f1{flex:1;display:flex;flex-wrap:nowrap;overflow:hidden}.dp-product-itemlist2 .couponitem .f1 .t{margin-right:10rpx;border-radius:3px;font-size:22rpx;height:40rpx;line-height:40rpx;padding-right:10rpx;flex-shrink:0;overflow:hidden}.right-btn{float:right;height:60rpx;line-height:60rpx;width:120rpx;text-align:center;color:#fff;border-radius:4rpx 4rpx;font-size:26rpx}.bottom-wc{padding:0 20rpx;display:flex;justify-content:space-between;background-color:#fff;align-items:center;position:fixed;bottom:0;left:0;width:100%;height:110rpx}.bottom-btn{width:45%;height:60rpx;line-height:60rpx;text-align:center;color:#fff;border-radius:4rpx 4rpx}