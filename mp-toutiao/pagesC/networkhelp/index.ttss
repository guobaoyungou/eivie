page{background-color:#f6f6f6}.container{padding-bottom:100rpx}.score-card{background-color:#f44;color:#fff;border-radius:20rpx;padding:30rpx;margin:20rpx}.score-title{text-align:center;font-size:32rpx;margin-bottom:10rpx}.score-value{text-align:center;font-size:60rpx;font-weight:700;margin-bottom:20rpx}.score-info-row{display:flex;justify-content:space-between;margin-top:10rpx}.score-info-item{display:flex;width:48%;background-color:#fff;border-radius:10rpx;padding:20rpx 20rpx}.content{width:100;padding:20rpx;height:auto;border-radius:20rpx;background:#f44;margin:15rpx;height:100%;padding-bottom:100rpx}.info-label{font-size:24rpx;color:#000}.info-value{font-size:24rpx;flex:1;text-align:right;color:red}.divider{height:20rpx;background-color:#f6f6f6;margin:20rpx 0}.level-tabs{display:flex;padding:20rpx;color:#fff}.tab-item{flex:1;text-align:center;font-size:28rpx;padding:10rpx 0;position:relative}.tab-item.active{font-weight:700}.tab-item.active::after{content:"";position:absolute;bottom:0;left:50%;-webkit-transform:translateX(-50%);transform:translateX(-50%);width:40rpx;height:4rpx;background-color:#fff;border-radius:2rpx}.user-info{display:flex;justify-content:flex-start;padding:20rpx;background:#fff;margin-top:20rpx;border-radius:20rpx}.user-count{font-size:28rpx;color:#333}.user-type{font-size:28rpx;color:#f30;margin-left:20rpx;border-bottom:1px solid #f30}.level-item{display:flex;justify-content:space-between;align-items:center;padding:30rpx 15rpx;border-bottom:1rpx solid #eee;margin-top:20rpx;border-radius:20rpx;background:#fff}.level-left{display:flex;flex-direction:row;align-items:center;position:relative}.level-line{width:6rpx;height:80rpx;margin-right:15rpx;border-radius:3rpx}.level-tag{display:inline-block;padding:4rpx 12rpx;border-radius:10rpx;font-size:18rpx;color:#fff;margin-left:10rpx;width:-webkit-fit-content;width:fit-content}.creator{background-color:#f90}.no-creator{border:1px solid red;color:red}.one-star{background-color:#f60}.two-star{background-color:#f30}.three-star{background-color:red}.four-star{background-color:#c00}.five-star{background-color:#900}.six-star{background-color:#600}.level-name{font-size:30rpx;font-weight:700;color:#333}.level-content{display:flex;flex-direction:column;flex:1}.level-header{display:flex;flex-direction:row;align-items:center}.level-condition{font-size:26rpx;color:#666;margin-top:10rpx}.level-right{display:flex;align-items:center}.level-action{font-size:26rpx;color:#999}