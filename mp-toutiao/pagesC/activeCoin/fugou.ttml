<view class="container"><block tt:if="{{isload}}"><block><view class="user-info-view flex-col"><block tt:if="{{true}}"><view class="activity-list-view flex-col"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index"><block><view class="flex active-options"><view class="active-image"><image src="{{item.$orig.pic}}"></image></view><view class="active-info-list flex-col"><view class="active-name">{{item.$orig.name}}</view><view class="active-fun-view flex flex-y-center"><block><view class="fun-class invite-friends" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchtap="__e">邀请好友</view><view class="fun-class view-details" style="margin-left:25rpx;" data-url="{{'pages/shop/product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看详情</view></block></view></view><view class="set-fugou"><view class="item" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setfugou',['$event']]]]]}}" catchtap="__e"><view class="radio" style="{{(auto_fugou==item.$orig.id?'background:'+item.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></view></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="b2592226-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="b2592226-2" bind:__l="__l"></nodata></block><block tt:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block tt:if="{{$root.m1!='h5'}}"><button class="f1" open-type="share" data-id="{{share_set_id}}"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block tt:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></view></block></view><view style="width:100%;height:100rpx;"></view></block></block><block tt:if="{{loading}}"><loading vue-id="b2592226-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="b2592226-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b2592226-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>