<block tt:if="{{isload}}"><view><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放积分</view><view class="points-num">{{total_data.have_release}}</view></view><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{total_data.green_score}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{total_data.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日价值</view><view class="num-text">{{total_data.green_score_price}}</view></view></view></view><view class="list-title-view">{{'释放'+$root.m1+'日记'}}</view><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index"><block><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark+":"+item.dec_score}}</view><view class="time-text">{{item.create_time}}</view></view><view class="price-view">{{item.green_score_value}}</view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="42ff30d4-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="42ff30d4-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="42ff30d4-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="42ff30d4-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="42ff30d4-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block>