<block tt:if="{{isload}}"><view><view class="schedule-view flex-x-center"><view class="schedule-options flex-col"><view class="{{((signstatus>=1?'active-class':'')+' '+'num-text')}}">1</view><view class="tips-text">注册企业会员</view></view><view class="dashed-line" style="{{'border:'+(''+signstatus==true?'1px dashed #a9000e':'1px dashed #b3b3b3')+';'}}"></view><view class="schedule-options flex-col"><view class="{{((signstatus==2?'active-class':'')+' '+'num-text')}}">2</view><view class="tips-text">签约开户</view></view></view><block tt:if="{{signstatus==1}}"><block><view class="form-view"><view class="form-item" style="display:block;height:auto;border:0;"><view style="display:flex;align-items:center;"><view class="label">会员名称</view><input style="flex:1;" placeholder="请输入会员名称" name="bizUserId" data-field="bizUserId" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.bizUserId}}" bindinput="__e"/></view><view style="color:red;line-height:50rpx;">仅支持英文数字符号，不支持汉字</view></view><view class="form-item"><view class="label">企业名称</view><input style="flex:1;" placeholder="请输入企业名称" name="companyName" data-field="companyName" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.companyName}}" bindinput="__e"/></view></view><block tt:if="{{showone}}"><view class="form-view"><view class="form-item"><view class="label">企业地址</view><input style="flex:1;" placeholder="请输入企业地址" name="companyAddress" data-field="companyAddress" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.companyAddress}}" bindinput="__e"/></view><view class="form-item" style="display:block;height:auto;"><view style="display:flex;align-items:center;"><view class="label">企业性质</view><view style="flex:1;text-align:left;"><picker style="width:100%;" value="{{info.comproperty}}" range="{{compropertys}}" data-event-opts="{{[['change',[['pickerComproperty',['$event']]]]]}}" bindchange="__e"><view class="picker"><view>{{compropertys[info.comproperty]}}</view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view><view style="color:red;line-height:50rpx;width:100%;">个体工商户性质，企业名称里不能含有‘公司’</view></view><view class="form-item" style="display:block;height:auto;"><view style="display:flex;align-items:center;"><view class="label">认证类型</view><view style="flex:1;text-align:left;"><picker style="width:100%;" value="{{info.authType}}" range="{{authTypes}}" data-event-opts="{{[['change',[['pickerAuthType',['$event']]]]]}}" bindchange="__e"><view class="picker"><view>{{authTypes[info.authType]}}</view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view></view><block tt:if="{{info.authType==2}}"><view class="form-item"><view class="label">统一社会信用</view><input style="flex:1;" placeholder="请输入统一社会信用" name="uniCredit" data-field="uniCredit" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.uniCredit}}" bindinput="__e"/></view></block><block tt:if="{{info.authType==1}}"><block><view class="form-item"><view class="label">营业执照号</view><input style="flex:1;" placeholder="请输入营业执照号" name="businessLicense" data-field="businessLicense" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.businessLicense}}" bindinput="__e"/></view><view class="form-item"><view class="label">组织机构代码</view><input style="flex:1;" placeholder="请输入组织机构代码" name="organizationCode" data-field="organizationCode" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.organizationCode}}" bindinput="__e"/></view><view class="form-item"><view class="label">税务登记证</view><input style="flex:1;" placeholder="请输入税务登记证" name="taxRegister" data-field="taxRegister" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.taxRegister}}" bindinput="__e"/></view></block></block></view></block><block tt:if="{{showtwo}}"><view class="form-view"><view class="form-item"><view class="label">银行预留手机</view><input style="flex:1;" type="text" placeholder="请输入银行预留手机" name="phone" data-field="phone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.phone}}" bindinput="__e"/></view><view class="form-item"><view class="label">联系电话</view><input style="flex:1;" type="text" placeholder="请输入联系电话" name="telephone" data-field="telephone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.telephone}}" bindinput="__e"/></view><view class="form-item"><view class="label">法人姓名</view><input style="flex:1;" type="text" placeholder="请输入法人姓名" name="legalName" data-field="legalName" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.legalName}}" bindinput="__e"/></view><view class="form-item" style="display:block;height:auto;"><view style="display:flex;align-items:center;"><view class="label">法人证件类型</view><view style="flex:1;text-align:left;"><picker style="width:100%;" value="{{identityTypeindex}}" range="{{identityTypes}}" range-key="name" data-event-opts="{{[['change',[['pickerIdentityType',['$event']]]]]}}" bindchange="__e"><view class="picker"><view>{{identityTypes[identityTypeindex]['name']}}</view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view></view><view class="form-item"><view class="label">法人证件号码</view><input style="flex:1;" type="text" placeholder="请输入法人证件号码" name="legalIds" data-field="legalIds" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.legalIds}}" bindinput="__e"/></view><view class="form-item"><view class="label">法人手机号</view><input style="flex:1;" type="text" placeholder="请输入法人手机号" name="legalPhone" data-field="legalPhone" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.legalPhone}}" bindinput="__e"/></view></view></block><block tt:if="{{showthree}}"><view class="form-view"><view class="form-item" style="display:block;height:auto;"><view style="display:flex;align-items:center;"><view class="label">账户类型</view><view style="flex:1;text-align:left;"><picker style="width:100%;" value="{{info.acctType}}" range="{{acctTypes}}" data-event-opts="{{[['change',[['pickerAcctType',['$event']]]]]}}" bindchange="__e"><view class="picker"><view>{{acctTypes[info.acctType]}}</view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view></view><view class="form-item"><view class="label">企业对公户</view><input style="flex:1;" type="text" placeholder="请输入企业对公户" name="accountNo" data-field="accountNo" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.accountNo}}" bindinput="__e"/></view><view class="form-item"><view class="label">开户行名称</view><input style="flex:1;" type="text" placeholder="请输入开户行名称" name="parentBankName" data-field="parentBankName" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.parentBankName}}" bindinput="__e"/></view><view class="form-item"><view class="label">开户行支行</view><input style="flex:1;" type="text" placeholder="请输入开户行支行" name="bankName" data-field="bankName" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.bankName}}" bindinput="__e"/></view><view class="form-item"><view class="label">支行行号</view><input style="flex:1;" type="text" placeholder="请输入支行行号" name="unionBank" data-field="unionBank" data-event-opts="{{[['input',[['setField',['$event']]]]]}}" value="{{info.unionBank}}" bindinput="__e"/></view></view></block></block></block><view class="but-view"><block tt:if="{{signstatus==1}}"><button data-event-opts="{{[['tap',[['getReg',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" bindtap="__e">注册</button></block><block tt:if="{{signstatus==2&&showAnew}}"><button data-event-opts="{{[['tap',[['goAnew',['$event']]]]]}}" class="set-btn" style="{{'border:'+('2rpx solid '+$root.m2)+';'+('color:'+($root.m3)+';')+('margin:'+('0 20rpx 0 0')+';')}}" bindtap="__e">重新申请</button></block><block tt:if="{{signstatus==2}}"><button data-event-opts="{{[['tap',[['goSigning',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" bindtap="__e">去开户</button></block></view><view style="width:100%;height:40rpx;"></view></view></block>