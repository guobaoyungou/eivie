<view class="container"><block tt:if="{{isload}}"><block><view class="view-show"><view class="search-container" data-url="{{'/pages/shop/search?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商品</view></view></view><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{(('nav_left')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block tt:for="{{data}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" data-root-item-id="{{item.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name+''}}</view></block></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="{{(('detail-list')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollIntoView="{{scrollToViewId}}" scrollWithAnimation="{{animation}}" scroll-y="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" bindscroll="__e"><view class="classification-detail-item"><view class="head"><view class="txt">品牌</view></view><view class="detail"><block tt:for="{{brandlist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="detail-item" style="{{((index+1)%3===0?'margin-right: 0':'')}}" data-id="{{item.id}}" form-type="submit" data-event-opts="{{[['tap',[['gotoCatproductPage',['$event']]]]]}}" catchtap="__e"><view class="txt">{{item.name}}</view></view></block></view></view><block tt:if="{{nodata}}"><nodata vue-id="4a163932-1" bind:__l="__l"></nodata></block></scroll-view></view></view></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="4a163932-2" loadstyle="left:62.5%" bind:__l="__l"></loading></block><dp-tabbar vue-id="4a163932-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4a163932-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>