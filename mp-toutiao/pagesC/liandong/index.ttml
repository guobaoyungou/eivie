<view><block tt:if="{{isload}}"><block><view class="container"><view class="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="collage-product" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><view class="t1">活动人数<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.total_num}}</text>人</view></view><view class="p2 flex flex-y-center"><view class="fun-class invite-friends" data-url="{{'/pagesC/liandong/team?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看活动</view><view class="fun-class invite-friends" data-id="{{item.id}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchtap="__e">邀请好友</view></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="8276d23c-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="8276d23c-2" bind:__l="__l"></nodata></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="8276d23c-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="8276d23c-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="8276d23c-5" data-ref="popmsg" bind:__l="__l"></popmsg><block tt:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block tt:if="{{$root.m0!='h5'}}"><button class="f1" open-type="share" data-id="{{share_active_id}}"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block tt:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></view>