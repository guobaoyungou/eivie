<view class="container"><block tt:if="{{isload}}"><block><view class="topfix"><view class="tongji flex-y-center " style="{{'background:'+(color1)+';'}}"><view><view class="price">{{total_num}}</view><view>总成团次数</view></view><view><view class="price">{{total_commission}}</view><view>成团奖励金额</view></view></view><dd-tab vue-id="5ecd2148-1" itemdata="{{['进行中','已成团']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></view><view style="margin-top:300rpx;"></view><view class="coupon-list"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="coupon" data-url="{{'detail?tid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="pt_left"><view class="pt_left-content"><block tt:if="{{item.pic}}"><image style="width:100%;max-height:200rpx;border-radius:4rpx;" src="{{item.pic}}" mode="widthFix"></image></block></view></view><view style="width:2rpx;height:100rpx;background-color:#eee;"></view><view class="pt_right"><view class="title">{{item.name}}</view><view class="t3" style="font-size:24rpx;padding:20rpx 0;"><block tt:if="{{st==0}}"><view class="shortcontent">{{item.tuannum+"号团，已拼"+item.num+"人，还差"+item.unnum+"人成团"}}</view></block><block tt:else><view class="shortcontent">{{item.tuannum+"号团，已拼"+item.num+"人"}}</view></block></view><view class="p2" style="padding-bottom:20rpx;"><progress class="my-progress" percent="{{item.percent}}" stroke-width="6" border-radius="10" show-info="{{true}}" font-size="{{14}}" activeColor="#fb743b"></progress></view><block tt:if="{{st==0}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" data-index="{{index}}" data-proid="{{item.proid}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchtap="__e">邀请好友</button></block></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="5ecd2148-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="5ecd2148-3" bind:__l="__l"></nodata></block><block tt:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block tt:if="{{$root.m2=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block tt:else><block tt:if="{{$root.m3}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block tt:else><block tt:if="{{$root.m4!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block tt:if="{{showposter}}"><view class="posterDialog" style="z-index:99;"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="5ecd2148-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="5ecd2148-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5ecd2148-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>