<view><block tt:if="{{isload}}"><block><view class="pyramid-container"><view class="pyramid"><view class="level level-1"><block tt:if="{{list[0]}}"><view class="user-container"><image class="avatar" src="{{list[0].headimg?list[0].headimg:pre_url+'/static/img/touxiang.png'}}"></image><text class="user-name">{{list[0].nickname}}</text><text class="user-name">{{"贡献值："+list[0].num}}</text><text class="user-name">{{$root.m0}}</text></view></block><block tt:else><view class="user-container"><image class="avatar" src="{{pre_url+'/static/img/touxiang.png'}}"></image></view></block></view><view class="arrow-container"><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image></view><view class="level level-2"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view><block tt:if="{{list[index+1]}}"><view class="user-container"><image class="avatar" src="{{list[index+1].headimg?list[index+1].headimg:pre_url+'/static/img/touxiang.png'}}"></image><text class="user-name">{{list[index+1].nickname}}</text><text class="user-name">{{"贡献值："+list[index+1].num}}</text><text class="user-name">{{item.m1}}</text></view></block><block tt:else><view class="user-container"><image class="avatar" src="{{pre_url+'/static/img/touxiang.png'}}"></image></view></block></view></block></view><view class="arrow-container"><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/left.png'}}"></image><image class="arrow" src="{{pre_url+'/static/img/right.png'}}"></image></view><view class="level level-3"><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view><block tt:if="{{list[3+index]}}"><view class="user-container"><image class="avatar" src="{{list[3+index].headimg?list[3+index].headimg:pre_url+'/static/img/touxiang.png'}}"></image><text class="user-name">{{list[3+index].nickname}}</text><text class="user-name">{{"贡献值："+list[3+index].num}}</text><text class="user-name">{{item.m2}}</text></view></block><block tt:else><view class="user-container"><image class="avatar" src="{{pre_url+'/static/img/touxiang.png'}}"></image></view></block></view></block></view></view><view class="progress-info"><view class="progress-container"><image class="progress-img" src="{{pre_url+'/static/img/redpacket-3.png'}}"></image><block tt:if="{{info.id}}"><text class="progress-text">{{info.status==0?'进行中':'已成团'}}</text></block></view></view><view class="pyramidinfo"><view class="info-row"><text class="info-item">队伍号</text><text class="info-item">{{info.tuannum}}</text></view><view class="info-row"><text class="info-item">开始时间</text><block tt:if="{{info.createtime}}"><text class="info-item">{{$root.m3}}</text></block></view><view class="info-row"><text class="info-item">支付金额</text><text class="info-item">{{info.totalprice}}</text></view><view class="info-row"><text class="info-item">状态</text><block tt:if="{{info.id}}"><text class="info-item">{{info.status==0?'进行中':'已成团'}}</text></block></view><view class="info-row"><text class="info-item">奖金</text><text class="info-item">{{$root.m4+info.commission+"+"+$root.m5+info.score}}</text></view><view class="info-row"><text class="info-item">成团奖励者</text><text class="info-item">{{tmember.nickname}}</text></view></view></view><view class="button-container"><button class="btn" data-url="{{'orderproduct?tid='+tid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">拼团商品</button><button data-event-opts="{{[['tap',[['gotofutou',['$event']]]]]}}" class="btn" bindtap="__e">复投商品</button></view></block></block><block tt:if="{{loading}}"><loading vue-id="c08c402e-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="c08c402e-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c08c402e-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>