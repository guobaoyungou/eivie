<view><view class="content-view"><view class="top-view"><view class="flex-y-center"><text class="text1">{{product.title}}</text></view><view class="tisp-text">{{'有效时间：'+product.yxq+''}}</view><view class="tisp-text">{{'配送方式：'+product.deliver_type_name+''}}</view><view class="tisp-text" style="line-height:34rpx;">{{'套餐说明：'+product.desc+''}}</view></view><view class="list-view flex-col"><view class="list-view-title flex-y-center"><view class="text1">套餐商品</view></view><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index"><block><view class="shop-options flex-bt"><view class="radio" style="{{(item.$orig.checked?'background:'+item.m0+';border:0':'')}}" data-index="{{index}}" data-index2="{{index}}" data-event-opts="{{[['tap',[['changeradio2',['$event']]]]]}}" catchtap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><image class="shop-image" src="{{item.$orig.pic}}" data-url="{{'pages/shop/product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="shop-info-view" data-url="{{'pages/shop/product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="shop-title">{{item.$orig.name}}</view><view class="shop-tisp"></view><view class="shop-tisp" style="color:red;">{{"￥"+item.$orig.sell_price}}</view></view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$0'],[[['cartlist','',index,'id']]]]]]]}}" class="minus" bindtap="__e">-</view><input class="i input" type="number" data-gid="{{item.$orig.id}}" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{guige_num[item.$orig.id]}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$0'],[[['cartlist','',index,'id']]]]]]]}}" class="plus" bindtap="__e">+</view></view></view></block></block></view><view style="width:100%;height:180rpx;"></view></view><view class="but-class"><view class="but-content"><view class="but-left-info flex-col"><view class="info1"><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="radio" style="{{(allchecked?'background:'+$root.m1+';border:0':'')}}" catchtap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view data-event-opts="{{[['tap',[['changeradioAll',['$event']]]]]}}" class="text0" catchtap="__e">全选</view><text class="text1" style="margin-left:40rpx;">总价：￥</text><text class="text2">{{price_total}}</text></view></view><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="quedingbut" bindtap="__e">确定</view></view></view><button class="covermy" style="{{('background:'+$root.m2)}}" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的订单</button></view>