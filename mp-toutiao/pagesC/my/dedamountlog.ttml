<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{pid<=0}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的抵扣金</view><view class="item flex-bt flex-y-center"><view class="value">{{mydedamount}}</view></view></view></block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block tt:if="{{item.dedamount>0}}"><text style="color:green;">{{"+"+item.dedamount}}</text></block><block tt:else><text style="color:red;">{{item.dedamount}}</text></block></view><block tt:if="{{pid<=0&&item.dedamount>0}}"><view class="t2" style="color:#000;">{{"剩余变动金额："+item.dedamount2}}</view></block></view><view class="f1"><view class="t2">{{"来源："+item.bname}}</view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view><block tt:if="{{pid<=0&&item.dedamount>0}}"><view class="f1"><view class="btn2" style="margin:0 auto;" data-url="{{'dedamountlog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看变动金额使用记录</view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="0e69614a-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="0e69614a-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="0e69614a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="0e69614a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="0e69614a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>