<view><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入商品名称搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block tt:if="{{datalist&&datalist.length>0}}"><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><image src="{{item.pic}}"></image><view class="t2" style="width:540rpx;"><view class="x1 flex-y-center">{{'可用天数：'+(item.day?item.day:0)+'天'}}</view><text class="x2">{{"滤芯名称："+item.name}}</text><block tt:if="{{item.txing}}"><view class="x1 flex-y-center" style="margin-top:10rpx;"><button class="btn-mini2" data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">立即更换</button><button class="btn-mini2" style="margin-left:60rpx;" data-tel="{{item.tel}}" data-event-opts="{{[['tap',[['callMendian',['$event']]]]]}}" bindtap="__e">联系客服</button></view></block></view></view></view></block></block></view></block><block tt:if="{{nomore}}"><nomore vue-id="ecad9074-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="ecad9074-2" bind:__l="__l"></nodata></block></block></block><popmsg class="vue-ref" vue-id="ecad9074-3" data-ref="popmsg" bind:__l="__l"></popmsg><block tt:if="{{loading}}"><loading vue-id="ecad9074-4" bind:__l="__l"></loading></block></view>