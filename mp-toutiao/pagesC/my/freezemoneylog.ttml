<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{pid<=0}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}</view><view class="item flex-bt flex-y-center"><view class="value">{{myfreezemoney}}</view></view></view></block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block tt:if="{{item.freezemoney>0}}"><text style="color:green;">{{"+"+item.freezemoney}}</text></block><block tt:else><text style="color:red;">{{item.freezemoney}}</text></block></view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="a5cb53ee-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="a5cb53ee-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="a5cb53ee-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="a5cb53ee-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="a5cb53ee-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>