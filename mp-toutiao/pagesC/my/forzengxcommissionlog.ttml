<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的冻结'+$root.m1+''}}</view><view class="f2">{{myforzengxcommission}}</view></view><dd-tab vue-id="d53f40f0-1" itemdata="{{['全部','释放中','已结束']}}" itemst="{{['all','0','1']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><view class="t1">{{"总冻结"+$root.m2+"："+item.commission}}</view><view class="t1">{{"未解冻"+$root.m3+"："+item.commission2}}</view><block tt:if="{{item.showsendmonth}}"><block><view class="t1">{{"总释放月数："+item.sendmonth}}</view><view class="t1">{{"已释放月数："+item.sendmonth2}}</view></block></block><view class="t1">状态：<block tt:if="{{item.status==1}}"><text>已结束</text></block><block tt:if="{{item.status==0}}"><text style="color:green;">释放中</text></block></view><view class="t2">{{item.createtime}}</view></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="d53f40f0-2" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="d53f40f0-3" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="d53f40f0-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="d53f40f0-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d53f40f0-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>