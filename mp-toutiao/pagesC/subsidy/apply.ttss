.container2{width:100%;padding:20rpx;background:#fff;height:100vh}.form-box{width:710rpx;margin:0 auto;padding:2rpx 24rpx 0 24rpx;background:#fff;border-radius:10rpx}.form-item{line-height:100rpx;display:flex;justify-content:space-between;border-bottom:1px solid #eee}.form-item .f1{color:#222;width:150rpx;flex-shrink:0}.form-item .f2{display:flex;align-items:center;flex:1}.form-item input{width:100%;border:none;color:#111;font-size:28rpx}.form-desc{margin-top:20rpx;font-size:26rpx;line-height:45rpx}.savebtn{width:90%;height:96rpx;line-height:96rpx;text-align:center;border-radius:48rpx;color:#fff;font-weight:700;margin:0 5%;margin-top:60rpx;border:none}