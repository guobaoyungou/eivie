<view><block tt:if="{{isload&&is_show}}"><block><view class="content-view"><scroll-view scroll-y="{{true}}"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index"><block><view class="options-view flex flex-y-center flex-bt"><view class="user-info flex"><image src="{{pre_url+'/static/img/vehicle/chelianglist.png'}}"></image><view class="user-info-right flex flex-col"><view class="name-text">{{item.$orig.car_num}}</view><view class="release-time">{{"录入时间："+item.m0}}</view></view></view><view data-event-opts="{{[['tap',[['editCar',['$0'],[[['lists','',index,'id']]]]]]]}}" class="edit-but" bindtap="__e"><image src="{{pre_url+'/static/img/editicon.png'}}"></image></view><view data-event-opts="{{[['tap',[['editTime',['$0'],[[['lists','',index,'id']]]]]]]}}" class="edit-time-but" bindtap="__e"><image src="{{pre_url+'/static/img/vehicle/settime.png'}}"></image></view></view></block></block></scroll-view></view><view style="width:100%;height:calc(230rpx + env(safe-area-inset-bottom));"></view><view class="{{(('pageBottom-class')+' '+(menuindex>-1?'tabbarbot':'notabbarbot2'))}}"><button data-event-opts="{{[['tap',[['addCar',['$event']]]]]}}" class="pageBottom-but" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">添加</button></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="1a3c2223-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="1a3c2223-2" bind:__l="__l"></nodata></block><dp-tabbar vue-id="1a3c2223-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar></view>