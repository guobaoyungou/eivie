<view class="container"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="product-item2" data-url="{{'/pagesExt/mingpian/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="data" style="{{'background:'+(item.bgpic?'url('+item.bgpic+')':'#fff')+';'+('background-size:'+('100% 100%')+';')}}"><view class="data_info" style="{{(field_list2?'':'border:0;margin:0')}}"><image class="data_head _img" src="{{item.headimg}}" alt></image><view><view class="data_name">{{item.realname}}</view><block tt:if="{{item.touxian1}}"><view class="data_text">{{item.touxian1}}</view></block><block tt:if="{{item.touxian2}}"><view class="data_text">{{item.touxian2}}</view></block><block tt:if="{{item.touxian3}}"><view class="data_text">{{item.touxian3}}</view></block></view></view><block tt:for="{{field_list2}}" tt:for-item="item2" tt:for-index="index2"><view class="data_list"><block tt:if="{{index2=='tel'}}"><image src="{{pre_url+'/static/images/tel.png'}}" alt class="_img"></image></block><block tt:else><block tt:if="{{index2=='weixin'}}"><image src="{{pre_url+'/static/images/weixin.png'}}" alt class="_img"></image></block><block tt:else><block tt:if="{{index2=='address'}}"><image src="{{pre_url+'/static/images/address.png'}}" alt class="_img"></image></block><block tt:else><image src="{{item2.icon}}" alt class="_img"></image></block></block></block>{{''+item[index2]+''}}</view></block></view></view></view></block><block tt:if="{{nomore}}"><nomore vue-id="e4713016-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="e4713016-2" bind:__l="__l"></nodata></block><block tt:if="{{loading}}"><loading vue-id="e4713016-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="e4713016-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="e4713016-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>