<view style="width:100%;height:auto;min-height:100%;"><block><view class="content" style="{{('background-image:url('+bgpic+');background-repeat: no-repeat;background-size:100% 100%;')}}"><block tt:if="{{notices&&notices.length>0}}"><view class="bobaobox"><swiper style="position:relative;height:54rpx;width:450rpx;" autoplay="true" interval="{{5000}}" vertical="true"><block tt:for="{{notices}}" tt:for-item="item" tt:for-index="index" tt:key="index"><swiper-item class="flex-y-center"><image style="width:40rpx;height:40rpx;border:1px solid rgba(255,255,255,0.7);border-radius:50%;margin-right:4px;" src="{{item.headimg}}"></image><view style="width:400rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:22rpx;"><text style="padding-right:2px;">{{item.nickname}}</text><text style="padding-right:4px;">{{item.showtime}}</text><text>{{item.msg}}</text></view></swiper-item></block></swiper></view></block><block tt:if="{{set.desc}}"><view data-event-opts="{{[['tap',[['changeshortcontent',['$event']]]]]}}" class="shortcontent" bindtap="__e">{{$root.m0+"规则"}}</view></block><view style="width:100%;clear:both;height:230rpx;"></view><view class="centercontent" style="{{('background-image:url('+centerpic+');background-repeat: no-repeat;background-size:100% 100%;')}}"><view style="color:#A1351D;text-align:center;margin-top:34rpx;"><text>{{"我的"+$root.m1}}</text></view><view style="text-align:center;font-weight:bold;"><text style="color:#FE0000;font-size:60rpx;">{{member.gold}}</text></view><block tt:if="{{set.show_bonus_pool==1}}"><view style="text-align:center;color:#A1351D;margin-top:10rpx;"><text>{{"总"+$root.m2+"："+set.bonus_pool_total}}</text></view></block><block tt:if="{{set.show_gold_price==1}}"><view style="text-align:center;color:#A1351D;margin-top:10rpx;"><text>{{$root.m3+"价格："+set.gold_price}}</text></view></block><view style="width:100%;position:absolute;bottom:150rpx;left:0;"><view class="optred"><view class="optred1" style="{{('background-image:url('+btnpic+');background-size:100% 100%;background-repeat: no-repeat;')}}" data-url="/pagesC/bonuspoolgold/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="line-height:72rpx;">{{set.withdraw_btn_text}}</view></view><view class="optred1" style="{{('background-image:url('+btnpic+') ;background-repeat: no-repeat;background-size:100% 100%;')}}" data-url="{{set.buy_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="line-height:72rpx;">{{set.buy_btn_text}}</view></view></view></view></view><view class="join"><view class="jointitle">{{$root.m4+"明细"}}</view><scroll-view style="width:660rpx;margin:0 auto;height:410rpx;" scroll-y="true"><block tt:for="{{logs}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block tt:if="{{logs}}"><block><view class="joincontent"><view style="width:80%;display:flex;align-items:center;"><view class="joinname" style="width:100%;">{{item.createtime+" "+item.remark}}</view></view><view class="jointip" style="width:20%;"><text style="font-size:30rpx;">{{item.value}}</text></view></view></block></block></block></scroll-view></view><view style="width:100%;clear:both;height:60rpx;"></view></view></block><block tt:if="{{showshortcontent}}"><block><view style="width:100%;height:100%;background-color:#000;position:fixed;opacity:0.5;z-index:99;top:0;"></view><view style="width:700rpx;margin:0 auto;position:fixed;top:10%;left:25rpx;z-index:100;"><scroll-view style="background-color:#fff;border-radius:20rpx;overflow:hidden;width:100%;height:900rpx;padding:20rpx;" scroll-y="true"><parse vue-id="3f6d3dc0-1" content="{{set.desc}}" bind:__l="__l"></parse></scroll-view><view data-event-opts="{{[['tap',[['changeshortcontent',['$event']]]]]}}" style="width:60rpx;height:60rpx;line-height:60rpx;text-align:center;font-size:30rpx;background-color:#fff;margin:0 auto;border-radius:50%;margin-top:20rpx;" bindtap="__e">X</view></view></block></block><block tt:if="{{loading}}"><loading vue-id="3f6d3dc0-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="3f6d3dc0-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="3f6d3dc0-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>