<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;"></text>{{userinfo.gold}}</view><view class="f1">{{"当前"+$root.m2+"价值："+set.gold_price}}</view><view class="f3" data-url="/pagesC/bonuspoolgold/goldlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{$root.m3+"记录"}}</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">兑换数量</view></view><view class="item3"><view class="f2"><input class="input" type="digit" name="withdraw_num" placeholder="请输入兑换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{withdraw_num}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['allwithdraw',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m4)+';'}}" bindtap="__e">全部</view></view></view><view class="tips-box"><view class="item4 tips"><block tt:if="{{set.cash_fee>0}}"><text>{{"兑换手续费"+set.cash_fee+'%'}}</text></block></view></view></view><view class="withdrawtype"><view class="f1">选择兑换方式：</view><view class="f2"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index"><block><view class="item" data-paytype="{{item.$orig.type}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1">{{item.$orig.name}}</view><view class="radio" style="{{(paytype==item.$orig.type?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" bindtap="__e">立即兑换</button></form><block tt:if="{{set.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><textarea value="{{set.withdraw_desc}}"></textarea></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="806f3b16-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="806f3b16-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="806f3b16-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>