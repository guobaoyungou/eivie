<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{mygold}}<view class="btn-mini" data-url="/pagesC/bonuspoolgold/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换</view></view><view class="f1">{{"当前每个"+$root.m2+"价值"+set.gold_price+"元"}}</view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="list-item"><view class="item-row" data-url="{{'/pagesB/my/greenscorelog?jilu_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="column"><text>{{"金币数量: "+item.value}}</text><text>{{"剩余数量: "+item.remain}}</text></view><view class="column"><text>{{"获取价格: "+item.gold_price}}</text></view></view><view class="item-row highlight"><text>{{"可提取金额: "+item.gold_value}}</text></view><view class="item-row"><text class="time">{{item.remark+" "+item.createtime}}</text></view></view></block></block></view><block tt:if="{{nodata}}"><nodata vue-id="37a234b7-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="37a234b7-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="37a234b7-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="37a234b7-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="37a234b7-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>