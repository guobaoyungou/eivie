<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:if="{{st==0}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.date}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block tt:else><text class="t1">{{item.num}}</text></block></view></view></block></block></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="7732e44e-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="7732e44e-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="7732e44e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="7732e44e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7732e44e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>