<view><block tt:if="{{isload}}"><block><view class="container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入商品名称" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="datalist flex"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="collage-product" data-url="{{linktype+'?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image><block tt:if="{{item.show_teamnum==1}}"><view class="desc"><block tt:if="{{item.gua_num>0}}"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text></block><block tt:else><text style="line-height:80rpx;">{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text></block><block tt:if="{{item.linktype==1}}"><view><block tt:if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==1}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block><block tt:if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==2}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_score+"积分"}}</text></block><block tt:if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==3}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_commission+"元佣金"}}</text></block><block tt:if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==4}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"优惠券"}}</text></block></view></block><block tt:else><view><block tt:if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block></view></block></view></block></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block tt:if="{{item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view><view class="p3"><view class="t1"><text class="team_text">{{item.teamnum+"人拼"}}</text>已拼成<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.sales}}</text>件</view></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="19a133bc-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="19a133bc-2" bind:__l="__l"></nodata></block></view><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的拼团</button></block></block><block tt:if="{{loading}}"><loading vue-id="19a133bc-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="19a133bc-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="19a133bc-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>