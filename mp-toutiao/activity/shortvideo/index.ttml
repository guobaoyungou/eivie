<view class="container"><block tt:if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的视频" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block tt:if="{{clist.length>0}}"><dd-tab vue-id="8f8eae7e-1" itemdata="{{cnamelist}}" itemst="{{cidlist}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></block></view><view class="content" style="{{(clist.length>0?'margin-top:190rpx':'margin-top:100rpx')}}"><block tt:if="{{sysset.list_type==1}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item2" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="image" src="{{item.coverimg}}" mode="widthFix"></image></view><view class="f2"><view class="t1">{{item.name}}</view><view class="t2">{{item.description}}</view><view class="t3">{{"播放量 "+item.view_num+''}}<text style="padding:0 20rpx;">·</text>{{'点赞数 '+item.zan_num}}</view><view class="t4"><image class="touxiang" src="{{item.binfo.logo}}"></image>{{item.binfo.name}}</view></view></view></block></block></block><block tt:else><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" style="{{(index%2==0?'margin-right:2%':'')}}"><image class="ff" mode="widthFix" src="{{item.coverimg}}" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="f2"><view class="t1"><image class="touxiang" src="{{item.binfo.logo}}"></image></view><view class="t2"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_playnum.png'}}"></image>{{item.view_num}}</view><view class="t3"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_likenum.png'}}"></image>{{item.zan_num}}</view></view></view></block></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="8f8eae7e-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><view class="item" style="display:block;"><nodata vue-id="8f8eae7e-3" bind:__l="__l"></nodata></view></block><block tt:if="{{sysset.can_upload==1}}"><view class="{{(('covermy')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" data-url="{{'uploadvideo?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/shortvideo_uploadbtn.png'}}"></image></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="8f8eae7e-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="8f8eae7e-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="8f8eae7e-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>