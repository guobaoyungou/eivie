<view><block tt:if="{{isload}}"><block><view class="container2"><block tt:if="{{sysset.pic}}"><image style="width:100%;height:auto;" src="{{sysset.pic}}" mode="widthFix" data-url="{{sysset.picurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image></block><block tt:if="{{clist.length>0}}"><view class="navbox"><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="nav_li" style="cursor:pointer;" data-url="{{'ltlist?cid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.pic}}"></image><view>{{item.name}}</view></view></block></block></view></block></view><view style="display:flex;width:100%;height:16rpx;background:#F7F7F7;"></view><view class="container2"><view class="listtitle">最新动态</view><view class="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="top"><image class="f1" src="{{item.headimg}}"></image><view class="f2"><view class="t1">{{item.nickname}}</view><view class="t2">{{item.showtime}}</view></view></view><view class="con"><block tt:if="{{item.form}}"><block><block tt:for="{{item.form.formcontent}}" tt:for-item="subitem" tt:for-index="sindex" tt:key="sindex"><block tt:if="{{item.form['form'+sindex]}}"><view class="dp-form-item"><block tt:if="{{subitem.key!='upload'&&subitem.key!='upload_pics'}}"><block><view>{{item.form['form'+sindex]}}</view></block></block><block tt:if="{{subitem.key=='upload_pics'||subitem.key=='upload'}}"><block><view class="flex"><block tt:for="{{item.form['form'+sindex]}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><block tt:if="{{item2}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-img"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="heightFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" catchtap="__e"></image></view></view></block></block></view></block></block></view></block></block></block></block><block tt:if="{{item.luntan_content_ueditor}}"><view class="f1"><rich-text style="word-wrap:break-word;" nodes="{{item.content}}"></rich-text></view></block><block tt:else><view class="f1"><text style="white-space:pre-wrap;">{{item.content}}</text></view></block><block tt:if="{{item.pics}}"><view class="f2"><block tt:for="{{item.pics}}" tt:for-item="pic" tt:for-index="idx" tt:key="idx"><image src="{{pic}}"></image></block></view></block><block tt:if="{{item.video}}"><video class="video" id="video" src="{{item.video}}" data-event-opts="{{[['tap',[['playvideo',['$event']]]]]}}" catchtap="__e"></video></block></view><block tt:if="{{item.isshowphone}}"><view class="phone"><view class="f1"><label class="t1">姓名：</label>{{item.name}}</view><block tt:if="{{isphoneother}}"><block><block tt:if="{{item.mobile}}"><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block><block tt:if="{{item.qq}}"><view class="f1"><label class="t1">QQ：</label>{{item.qq}}</view></block><block tt:if="{{item.wechat}}"><view class="f1"><label class="t1">微信号：</label>{{item.wechat}}</view></block></block></block><block tt:else><block><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block></block></view></block><view class="bot"><view class="f1"><image style="margin-top:0;" src="{{pre_url+'/static/img/lt_read.png'}}"></image>{{item.readcount}}</view><view class="f1" style="margin-left:60rpx;"><image src="{{pre_url+'/static/img/lt_pinglun.png'}}"></image>{{item.plcount}}</view><block tt:if="{{need_call&&item.mobile}}"><view class="f1" style="margin-left:60rpx;" data-phone="{{item.mobile}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchtap="__e"><image style="width:30rpx;height:30rpx;margin-top:0;" src="{{pre_url+'/static/img/mobile.png'}}"></image></view></block><view class="f2"></view><block tt:if="{{sysset.cansave}}"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savecontent',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/lt_save.png'}}"></image>保存</view></block><view class="f3" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['zan',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/lt_like'+(item['iszan']==0?'':'2')+'.png'}}"></image>{{item.zan}}</view></view></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="1126ffa4-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="1126ffa4-2" bind:__l="__l"></nodata></block></view></view><view class="{{((('covermy-view')+' '+'flex-col')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view class="covermy" data-url="pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/lt_gohome.png'}}"></image></view><block tt:if="{{sysset&&sysset.sendcheck!=2}}"><view class="covermy" data-url="fatie" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/lt_fatie2.png'}}"></image></view></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="1126ffa4-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="1126ffa4-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="1126ffa4-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="1126ffa4-6" bind:__l="__l"></wxxieyi></view>