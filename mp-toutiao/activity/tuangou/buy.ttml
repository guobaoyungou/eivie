.val3==1}}"><text style="color:red;">*</text></block></view><block tt:if="{{item.$orig.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.$orig.val2}}" placeholder-style="font-size:28rpx"/></block></block><block tt:if="{{item.$orig.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.$orig.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block tt:if="{{item.$orig.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+idx}}"><block tt:for="{{item.$orig.val2}}" tt:for-item="item1" tt:for-index="idx1" tt:key="id"><label class="flex-y-center"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></block></radio-group></block></block><block tt:if="{{item.$orig.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form'+idx}}"><block tt:for="{{item.$orig.val2}}" tt:for-item="item1" tt:for-index="idx1" tt:key="id"><label class="flex-y-center"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></block></checkbox-group></block></block><block tt:if="{{item.$orig.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="" range="{{item.$orig.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.$orig.val2[editorFormdata[idx]]}}</view></block><block tt:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block tt:if="{{item.$orig.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.$orig.val2[0]}}" end="{{item.$orig.val2[1]}}" range="{{item.$orig.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{editorFor