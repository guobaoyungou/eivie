<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" bindsubmit="__e"><block tt:if="{{needaddress==0}}"><view class="address-add"><view class="linkitem"><block tt:if="{{contact_require==1}}"><label style="color:red;">*</label></block><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" bindinput="__e"/></view><view class="linkitem"><block tt:if="{{contact_require==1}}"><label style="color:red;">*</label></block><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view></view></block><block tt:else><view class="address-add flex-y-center" data-url="{{'/pagesB/address/address?fromPage=buy&type='+(havetongcheng==1?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="img" src="{{pre_url+'/static/img/address.png'}}"></image></view><block tt:if="{{address.name}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel}}</view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block tt:else><view class="f2 flex1">请选择收货地址</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><view class="buydata"><view class="btitle"><image class="img" src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{business.name}}</view><view class="bcontent"><view class="product"><view class="item flex"><view class="img" data-url="{{'product?id='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{product.pic}}"></image></view><view class="info flex1"><view class="f1">{{product.name}}</view><view class="f3">{{"￥"+product.sell_price}}<block tt:if="{{buytype!=1}}"><text class="collage_icon">团购</text></block>{{'× '+num}}</view></view></view></view><view class="freight"><view class="f1">配送方式</view><view class="freight-ul"><view class="flex" style="width:100%;overflow-y:hidden;overflow-x:scroll;"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="idx2" tt:key="idx2"><block><view class="freight-li" style="{{(freightkey==idx2?'color:'+item.m0+';background:rgba('+item.m1+',0.2)':'')}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeFreight',['$event']]]]]}}" bindtap="__e">{{item.$orig.name}}</view></block></block></view></view><block tt:if="{{freightList[freightkey].minpriceset==1&&freightList[freightkey].minprice>0&&freightList[freightkey].minprice*1>product_price*1}}"><view class="freighttips">{{"满"+freightList[freightkey].minprice+"元起送，还差"+$root.g0+"元"}}</view></block><block tt:if="{{freightList[freightkey].isoutjuli==1}}"><view class="freighttips">超出配送范围</view></block></view><block tt:if="{{freightList[freightkey].pstimeset==1}}"><view class="price"><view class="f1">{{(freightList[freightkey].pstype==1?'取货':'配送')+"时间"}}</view><view data-event-opts="{{[['tap',[['choosePstime',['$event']]]]]}}" class="f2" bindtap="__e">{{pstimetext==''?'请选择时间':pstimetext}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view></block><block tt:if="{{freightList[freightkey].pstype==1}}"><view class="storeitem"><view class="panel"><view class="f1">取货地点</view><view class="f2" data-freightkey="{{freightkey}}" data-storekey="{{freightList[freightkey].storekey}}" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" bindtap="__e"><text class="iconfont icondingwei"></text>{{freightList[freightkey].storedata[freightList[freightkey].storekey].name}}</view></view><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><block><block tt:if="{