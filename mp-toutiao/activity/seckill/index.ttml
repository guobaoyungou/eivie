<view class="container"><block tt:if="{{isload}}"><block><view class="navbg" style="{{('background: linear-gradient(45deg,'+$root.m0+' 0%, rgba('+$root.m1+',0.8) 100%);')}}"></view><view class="nav"><scroll-view scroll-x="true" scroll-left="{{top_bar_scroll}}"><view class="f1"><block tt:for="{{navlist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('item '+(selected==index?'active':''))}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e"><view class="t3">{{item.seckill_date_m}}</view><view class="t1">{{item.showtime}}</view><block tt:if="{{item.active==-1}}"><view class="t2">已结束</view></block><block tt:if="{{item.active==0}}"><view class="t2">已开抢</view></block><block tt:if="{{item.active==1}}"><view class="t2">抢购中</view></block><block tt:if="{{item.active==2}}"><view class="t2">即将开始</view></block></view></block></block></view></scroll-view></view><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><image class="f1" mode="widthFix" src="{{item.$orig.pic}}" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="f2"><text class="t1">{{item.$orig.name}}</text><view class="t2" style="{{'color:'+($root.m2)+';'}}"><progress class="progress" percent="{{item.$orig.salepercent}}" backgroundColor="#FFD1C9" activeColor="#FF3143" border-radius="3"></progress><text class="x2">{{item.$orig.salepercent+"%"}}</text></view><view class="t3"><text class="x1" style="{{'color:'+($root.m3)+';'}}"><block tt:if="{{item.$orig.usd_sellprice>0}}"><block><text style="font-size:24rpx;">$</text>{{item.$orig.usd_sellprice+''}}<text style="font-size:26rpx;"><text style="font-size:24rpx;">￥</text>{{item.$orig.sell_price}}</text></block></block><block tt:else><block><text style="font-size:24rpx;">￥</text>{{item.$orig.sell_price+''}}</block></block></text><text class="x2">{{"￥"+item.$orig.market_price}}</text><block tt:if="{{item.$orig.starttime<nowtime&&(item.$orig.seckill_time_length>0?item.$orig.seckill_time_length:seckill_duration*3600)+item.$orig.starttime*1>nowtime}}"><button class="x3" style="{{'background:'+('linear-gradient(90deg,'+item.m4+' 0%,rgba('+item.m5+',0.8) 100%)')+';'}}" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">立即抢购</button></block><block tt:else><block tt:if="{{item.$orig.starttime*1+(item.$orig.seckill_time_length>0?item.$orig.seckill_time_length:seckill_duration*3600)<nowtime}}"><button class="x3 xx1" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去看看</button></block><block tt:else><button class="x3" style="{{'background:'+(item.m6)+';'}}" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">抢先看看</button></block></block></view></view></view></block><block tt:if="{{nodata}}"><view class="item" style="display:block;"><nodata vue-id="053affe5-1" bind:__l="__l"></nodata></view></block><block tt:if="{{nomore}}"><nomore vue-id="053affe5-2" bind:__l="__l"></nomore></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="053affe5-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="053affe5-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="053affe5-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>