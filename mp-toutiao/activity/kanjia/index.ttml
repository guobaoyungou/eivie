<view class="container"><block tt:if="{{isload}}"><block><view class="banner"><image src="{{pic}}" mode="widthFix"></image></view><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="product-item2" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><block tt:for="{{item.joinlist}}" tt:for-item="join" tt:for-index="index2" tt:key="index2"><view class="t1"><image src="{{join.headimg}}"></image></view></block><block tt:if="{{item.saleing>7}}"><view class="t1"><image src="{{pre_url+'/static/img/moreuser.png'}}"></image></view></block><view class="t2">{{item.saleing+"人正在参加"}}</view></view><view class="p3"><view class="t1"><text class="x1"><text style="font-size:22rpx;">最低￥</text>{{item.min_price}}</text><text class="x2">{{"￥"+item.sell_price}}</text></view><button class="t2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" bindtap="__e">去砍价</button></view></view></view></block></block><block tt:if="{{nomore}}"><nomore vue-id="5e80ba36-1" textcolor="#faa" linecolor="#f66" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="5e80ba36-2" bind:__l="__l"></nodata></block><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的订单</button></block></block><block tt:if="{{loading}}"><loading vue-id="5e80ba36-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="5e80ba36-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5e80ba36-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>