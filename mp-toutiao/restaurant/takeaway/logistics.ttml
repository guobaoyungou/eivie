<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{express_com=='同城配送'}}"><block><block tt:if="{{psorder.status!=0&&psorder.status!=4}}"><map class="map" longitude="{{binfo.longitude}}" latitude="{{binfo.latitude}}" scale="14" markers="{{[{id:0,latitude:binfo.latitude,longitude:binfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_business.png',width:'44',height:'54'},{id:0,latitude:orderinfo.latitude,longitude:orderinfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_kehu.png',width:'44',height:'54'},{id:0,latitude:psuser.latitude,longitude:psuser.longitude,iconPath:pre_url+'/static/img/peisong/marker_qishou.png',width:'44',height:'54'}]}}"></map></block><block tt:else><map class="map" longitude="{{binfo.longitude}}" latitude="{{binfo.latitude}}" scale="14" markers="{{[{id:0,latitude:binfo.latitude,longitude:binfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_business.png',width:'44',height:'54'},{id:0,latitude:orderinfo.latitude,longitude:orderinfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_kehu.png',width:'44',height:'54'}]}}"></map></block><view class="order-box"><view class="head"><block tt:if="{{type=='express_wx'}}"><block><block tt:if="{{psorder.order_status==101}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>分配骑手</view></block><block tt:else><block tt:if="{{psorder.order_status==102}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>骑手赶往店家</view></block><block tt:else><block tt:if="{{psorder.order_status==201}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>骑手到店</view></block><block tt:else><block tt:if="{{psorder.order_status==202}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>取货成功</view></block><block tt:else><block tt:if="{{psorder.order_status==301}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>配送中</view></block><block tt:else><block tt:if="{{psorder.order_status==302}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已送达</view></block><block tt:else><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>配送中</view></block></block></block></block></block></block></block></block><block tt:else><block><block tt:if="{{psorder.status==4}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已送达</view></block><block tt:else><block tt:if="{{psorder.leftminute>0}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image><text class="t1">{{psorder.leftminute+"分钟内"}}</text>送达</view></block><block tt:else><block tt:if="{{psorder.yujitime>0}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已超时<text class="t1" style="margin-left:10rpx;">{{-psorder.leftminute+"分钟"}}</text></view></block><block tt:else><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>配送中</view></block></block></block></block></block><view class="flex1"></view><view class="f2"><text class="t1">{{orderinfo.freight_price}}</text>元</view></view><view class="content" style="border-bottom:0;"><block tt:if="{{type=='express_wx'}}"><block><block tt:if="{{psuser.latitude}}"><view class="f1"><view class="t1"><text class="x1">{{psorder.juli}}</text><text class="x2">{{psorder.juli_unit}}</text></view><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view><view class="t3"><text class="x1">{{psorder.juli2}}</text><text class="x2">{{psorder.juli2_unit}}</text></view></view></block></block></block><block tt:else><block><view class="f1" style="{{(psorder.psid==0?'justify-content: center;':'')}}"><view class="t1"><text class="x1">{{psorder.juli}}</text><text class="x2">{{psorder.juli_unit}}</text></view><block tt:if="{{psorder.psid>0}}"><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view></block><block tt:if="{{psorder.psid>0}}"><view class="t3"><text class="x1">{{psorder.juli2}}</text><text class="x2">{{psorder.juli2_unit}}</text></view></block></view></block></block><view class="f2"><view class="t1">{{binfo.name}}</view><view class="t2">{{binfo.address}}</view><view class="t3">{{orderinfo.address}}</view></view><view data-event-opts="{{[['tap',[['daohang',['$event']]]]]}}" class="f3" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/ps_daohang.png'}}"></image></view></view></view><view class="orderinfo"><view class="box-title">{{"商品清单("+orderinfo.procount+")"}}</view><block tt:for="{{prolist}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="item"><text class="t1 flex1">{{item.name+" "+item.ggname}}</text><text class="t2 flex0">{{"￥"+item.sell_price+" ×"+item.num+''}}</text></view></block></view><block tt:if="{{psorder.status!=0}}"><view class="orderinfo"><view class="box-title">配送信息</view><block tt:if="{{psuser.realname}}"><view class="item"><text class="t1">配送员</text><text class="t2"><text style="font-weight:bold;">{{psuser.realname}}</text>{{"("+psuser.tel+")"}}</text></view></block><block tt:if="{{psorder.starttime}}"><view class="item"><text class="t1">接单时间</text><text class="t2">{{$root.m0}}</text></view></block><block tt:if="{{psorder.daodiantime}}"><view class="item"><text class="t1">到店时间</text><text class="t2">{{$root.m1}}</text></view></block><block tt:if="{{psorder.quhuotime}}"><view class="item"><text class="t1">取货时间</text><text class="t2">{{$root.m2}}</text></view></block><block tt:if="{{psorder.endtime}}"><view class="item"><text class="t1">送达时间</text><text class="t2">{{$root.m3}}</text></view></block></view></block><view class="orderinfo"><view class="box-title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{orderinfo.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{$root.m4}}</text></view><view class="item"><text class="t1">支付时间</text><text class="t2">{{$root.m5}}</text></view><view class="item"><text class="t1">支付方式</text><text class="t2">{{orderinfo.paytype}}</text></view><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+orderinfo.product_price}}</text></view><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+orderinfo.totalprice}}</text></view><view class="item"><text class="t1">备注</text><text class="t2 red">{{orderinfo.message?orderinfo.message:'无'}}</text></view></view><view style="width:100%;height:120rpx;"></view><view class="bottom"><block tt:if="{{psorder.status!=0&&psuser.tel}}"><view class="f1" data-tel="{{psuser.tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel1.png'}}"></image>联系配送员</view></block><block tt:if="{{psorder.status!=0}}"><view class="f2" data-tel="{{binfo.tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel2.png'}}"></image>联系商家</view></block><block tt:if="{{psorder.psid>0&&psorder.status==4}}"><view class="btn1" data-url="{{'commentps?id='+psorder.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">评价配送员</view></block></view></block></block><block tt:else><block><view class="expressinfo"><view class="head"><view class="f1"><image src="{{pre_url+'/static/img/feiji.png'}}"></image></view><view class="f2"><view class="t1">快递公司：<text style="color:#333;" user-select="true" selectable="true">{{express_com}}</text></view><view class="t2">快递单号：<text style="color:#333;" user-select="true" selectable="true">{{express_no}}</text></view></view></view><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="{{('item '+(index==0?'on':''))}}"><view class="f1"><image src="{{'/static/img/dot'+(index==0?'2':'1')+'.png'}}"></image></view><view class="f2"><text class="t2">{{item.time}}</text><text class="t1">{{item.context}}</text></view></view></block><block tt:if="{{nodata}}"><nodata vue-id="442d1a18-1" text="暂未查找到物流信息" bind:__l="__l"></nodata></block></view></view></block></block></block></block><block tt:if="{{loading}}"><loading vue-id="442d1a18-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="442d1a18-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>