<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="content"><block tt:if="{{restaurant_book_date==0}}"><view class="info-item"><view class="t1">{{textset['就餐']+"日期"}}</view><view data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" class="t2" bindtap="__e"><input style="height:96rpx;" type="text" placeholder="请选择时间" name="time" disabled="true" value="{{chooseTimeStr}}"/></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}" data-event-opts="{{[['tap',[['chooseTime',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:if="{{restaurant_book_date==1}}"><view class="info-item"><view class="t1">{{textset['就餐']+"日期"}}</view><view class="t2"><picker class="picker" mode="date" value="" start="{{$root.m0}}" end="2030-12-31" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{chooseTimeStr}}"><view>{{chooseTimeStr}}</view></block><block tt:else><view>请选择日期</view></block></picker></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><view class="info-item"><view class="t1">人数</view><view class="t2"><picker value="{{nindex}}" range="{{numArr}}" name="renshu" data-event-opts="{{[['change',[['numChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{numArr[nindex]}}</view></picker></view><image class="t3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="info-item"><view class="t1">{{textset['餐桌']}}</view><view class="t2" data-url="{{'tableList?bid='+opt.bid}}" data-event-opts="{{[['tap',[['selectTable',['$event']]]]]}}" bindtap="__e"><input type="text" placeholder="请选择" value="{{tableName}}"/></view><image class="t3" data-url="{{'tableList?bid='+opt.bid}}" src="{{pre_url+'/static/img/arrowright.png'}}" data-event-opts="{{[['tap',[['selectTable',['$event']]]]]}}" bindtap="__e"></image></view></view><view class="content"><view class="info-item"><view class="t1">您的姓名</view><view class="t2"><input type="text" data-name="linkman" name="linkman" placeholder="请输入姓名" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{linkman}}" bindinput="__e"/></view></view><view class="info-item"><view class="t1">手机号</view><view class="t2"><input type="number" data-name="tel" name="tel" placeholder="请输入手机号" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view></view></view><view class="content"><view class=" remark"><view class="t1">{{textset['订餐']+"备注"}}</view><view><textarea data-name="message" name="message" placeholder="如您有其他需求请填写" placeholder-style="color:#ABABABFF" data-event-opts="{{[['input',[['input',['$event']]]]]}}" value="{{message}}" bindinput="__e"></textarea></view></view></view><block tt:if="{{is_book_order==1}}"><view style="padding:30rpx 0;"><button class="set-btn" style="background:#FE5B07;" form-type="submit">继续点餐</button></view></block><block tt:else><view style="padding:30rpx 0;"><button class="set-btn" style="background:#FE5B07;" form-type="submit">{{"立即"+textset['订座']}}</button></view></block></form><block tt:if="{{pstimeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择时间</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideTimeDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block tt:for="{{timeArr}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['timeRadioChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.title}}</view><view class="radio" style="{{('')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="685a891e-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="685a891e-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>