<view class="container"><block tt:if="{{isload}}"><block><view class="address-add flex-y-center"><view class="f1">桌台信息</view><block tt:if="{{tableinfo.id}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{tableinfo.name}}<text style="font-size:24rpx;font-weight:normal;color:#666;margin-left:10rpx;">{{tableinfo.seat+"人桌"}}</text></view></view></block><block tt:else><view class="f2 flex1">请扫描桌台二维码</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block tt:for="{{$root.l1}}" tt:for-item="buydata" tt:for-index="index" tt:key="index"><view class="buydata"><view class="buystatus flex flex-y-center"><view class="leftline" style="{{'background-color:'+($root.m0)+';'}}"></view>待下单</view><view class="bcontent"><view class="product"><block tt:for="{{buydata.l0}}" tt:for-item="item" tt:for-index="index2" tt:key="index2"><block tt:if="{{index2<4||waitordershowall==true}}"><view class="item "><view class="flex"><view class="img" data-url="{{'product?id='+item.$orig.product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.$orig.product.pic}}"></image></view><view class="info flex1" style="position:relative;"><view class="f1">{{item.$orig.product.name}}</view><block tt:if="{{item.$orig.guige.name}}"><view class="f2">{{"规格："+item.$orig.guige.name+item.$orig.jldata.jltitle+''}}<block tt:if="{{item.$orig.jldata.njltitle}}"><text>{{"（"+item.$orig.jldata.njltitle+")"}}</text></block></view></block><block tt:if="{{item.$orig.guige.ggtext&&item.$orig.guige.ggtext.length>0}}"><view class="f2"><block tt:for="{{item.$orig.guige.ggtext}}" tt:for-item="gitem" tt:for-index="index"><view>{{gitem}}</view></block></view></block><view class="f3"><text style="font-weight:bold;">{{'￥'+item.g0+''}}</text><text style="padding-left:20rpx;">{{'× '+item.$orig.num}}</text><block tt:if="{{item.$orig.product.product_type&&item.$orig.product.product_type==1}}"><text style="font-size:20rpx;">斤</text></block></view><block tt:if="{{item.$orig.product.select_type=='kx'||item.$orig.product.select_type=='bx'}}"><view class="tip"><block tt:if="{{item.$orig.product.select_type=='kx'}}"><text>可选</text></block><block tt:if="{{item.$orig.product.select_type=='bx'}}"><text>必选</text></block></view></block><block tt:if="{{item.$orig.product.select_type=='kx'}}"><view class="prodel" data-key="{{index2}}" data-bid="{{index}}" data-event-opts="{{[['tap',[['prodel',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/del.png'}}"></image>删除</view></block></view></view><view class=" flex-y-center" style="color:#999999;"><view>备注：</view><input class="flex1" type="text" placeholder="请输入您的口味或要求" data-index="{{index}}" data-index2="{{index2}}" placeholder-style="color:#cdcdcd;font-size:24rpx" data-event-opts="{{[['input',[['inputgoodsremark',['$event']]]]]}}" bindinput="__e"/></view></view></block></block><block tt:if="{{waitordershowall==false&&buydata.$orig.prodata.length>4}}"><view data-event-opts="{{[['tap',[['doWaitorderShowAll',['$event']]]]]}}" class="storeviewmore" bindtap="__e">- 查看更多 -</view></block></view></view></view></block><block tt:for="{{$root.l3}}" tt:for-item="buydata" tt:for-index="index"><view class="buydata"><view class="buystatus flex flex-y-center"><view class="leftline" style="{{'background-color:'+($root.m1)+';'}}"></view>已下单</view><view class="bcontent"><view class="product"><block tt:for="{{buydata.l2}}" tt:for-item="item" tt:for-index="index2" tt:key="index2"><block tt:if="{{index2<4||ordershowall==true}}"><view class="item"><view class="flex"><view class="img" data-url="{{'product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.$orig.pic}}"></image></view><view class="info flex1"><view class="f1">{{item.$orig.name}}</view><block tt:if="{{item.$orig.ggname}}"><view class="f2">{{"规格："+item.$orig.ggname}}<block tt:if="{{item.$orig.jltitle}}"><text>{{item.$orig.jltitle}}</text></block></view></block><block tt:if="{{item.$orig.ggtext&&item.$orig.ggtext.length>0}}"><view class="f2"><block tt:for="{{item.$orig.ggtext}}" tt:for-item="gitem" tt:for-index="index"><view>{{gitem}}</view></block></view></block><view class="f3"><text style="font-weight:bold;">{{'￥'+(!item.m2?item.g1:item.$orig.sell_price)+''}}</text><text style="padding-left:20rpx;">{{'× '+item.$orig.num}}</text><block tt:if="{{item.$orig.product_type&&item.$orig.product_type==1}}"><text style="font-size:20rpx;">斤</text></block></view></view></view><block tt:if="{{item.$orig.remark}}"><view style="color:#999999;">{{"备注："+item.$orig.remark}}</view></block></view></block></block><block tt:if="{{ordershowall==false&&buydata.$orig.prodata.length>4}}"><view data-event-opts="{{[['tap',[['doOrderShowAll',['$event']]]]]}}" class="storeviewmore" bindtap="__e">- 查看更多 -</view></block></view></view></view></block><view style="width:100%;height:182rpx;"></view><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="btn" bindtap="__e">继续点餐</view><view data-event-opts="{{[['tap',[['toBuy',['$event']]]]]}}" class="btn " style="{{'background-color:'+($root.m3)+';'+('border-color:'+($root.m4)+';')+('color:'+('#fff')+';')}}" bindtap="__e">现在下单</view></view></block></block><block tt:if="{{loading}}"><loading vue-id="51fd675a-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="51fd675a-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>