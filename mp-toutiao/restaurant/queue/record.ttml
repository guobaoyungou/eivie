<view class="container"><block tt:if="{{isload}}"><block><view class="content" id="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.$orig.queue_no}}</text><text class="t2">{{item.$orig.cname}}</text><text class="t2">{{item.m0}}</text></view><view class="f2"><block tt:if="{{item.$orig.status==0}}"><text class="t1">排队中</text></block><block tt:if="{{item.$orig.status==1}}"><text class="t2">已叫号</text></block><block tt:if="{{item.$orig.status==2}}"><text class="t3">已过号</text></block><block tt:if="{{item.$orig.status==3}}"><text class="t3">已取消</text></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="2113b042-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="2113b042-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="2113b042-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="2113b042-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar></view>