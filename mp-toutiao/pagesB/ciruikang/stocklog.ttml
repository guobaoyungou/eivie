<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的库存</view><view class="f2">{{mynum}}</view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><image style="width:50rpx;height:50rpx;border-radius:50% 50%;margin-right:10rpx;" src="{{item.headimg}}"></image><text class="t1">{{item.nickname}}</text></view><view class="f2"><block><text class="t1">{{item.allnum}}</text></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="fe9d5e38-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="fe9d5e38-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="fe9d5e38-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="fe9d5e38-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="fe9d5e38-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>