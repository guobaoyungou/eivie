<view><block tt:if="{{isload}}"><block><block tt:if="{{datalist.length>0}}"><view class="initials-list-wrap"><scroll-view class="scroll-list" scroll-y="{{true}}" scroll-into-view="{{scrollViewId}}"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view><view class="letter" id="{{item.zimu}}">{{item.zimu}}</view><view class="con" data-city="{{item.city}}" data-event-opts="{{[['tap',[['search',['$event']]]]]}}" bindtap="__e"><view class="list-item">{{''+item.city}}</view></view></view></block></scroll-view><view class="{{(('letter-list-bar')+' '+((touchmove)?'active':''))}}"><block tt:for="{{letterList}}" tt:for-item="item" tt:for-index="index" tt:key="index"><text data-event-opts="{{[['tap',[['letterSelect',[index]]]]]}}" class="{{(('text')+' '+((touchmoveIndex==index)?'active':''))}}" catchtap="__e">{{''+item+''}}</text></block></view><block tt:if="{{touchmove}}"><view class="letter-alert">{{letterList[touchmoveIndex]+''}}</view></block></view></block><block tt:if="{{nomore}}"><nomore vue-id="477f5480-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="477f5480-2" text bind:__l="__l"></nodata></block><dp-chat-tabbar vue-id="477f5480-3" currentIndex="2" bind:__l="__l"></dp-chat-tabbar></block></block><popmsg class="vue-ref" vue-id="477f5480-4" data-ref="popmsg" bind:__l="__l"></popmsg><block tt:if="{{loading}}"><loading vue-id="477f5480-5" bind:__l="__l"></loading></block></view>