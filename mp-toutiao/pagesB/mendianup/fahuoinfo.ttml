<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="lists"><view class="t1">{{item.name}}</view><view><view class="t2">{{"规格: "+item.ggname}}</view><view class="t3 flex"><text>{{"件数: "+item.num}}</text><block tt:if="{{item.refund_num&&item.refund_num>0}}"><text>{{"退款件数: "+item.refund_num}}</text></block></view></view></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="62e75cbf-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="62e75cbf-2" bind:__l="__l"></nodata></block><view class="bottom"><block tt:if="{{datainfo.status==0}}"><view data-event-opts="{{[['tap',[['shouhuo',['$event']]]]]}}" class="btn2" bindtap="__e">收货</view></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="62e75cbf-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="62e75cbf-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="62e75cbf-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>