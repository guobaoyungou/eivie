<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="125f9b88-1" itemdata="{{['图片','视频']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="content-container"><view class="nav_left"><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('nav_left_items '+(curIndex==index?'active':''))}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name+''}}</view></block></block></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><view class="product-itemlist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><block tt:if="{{item.ctype==0}}"><image class="image" src="{{item.url}}" mode="widthFix"></image></block><block tt:else><block tt:if="{{item.ctype==1}}"><image class="image" src="{{item.cover}}" mode="widthFix"></image></block></block></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="125f9b88-2" text="没有更多商品了" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="125f9b88-3" text="暂无相关商品" bind:__l="__l"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="125f9b88-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="125f9b88-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="125f9b88-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>