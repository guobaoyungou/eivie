<block tt:if="{{isload}}"><view><view class="schedule-view flex-x-center"><view class="schedule-options flex-col"><view class="num-text active-class" style="{{'background:'+($root.m0)+';'}}">1</view><view class="tips-text">填写微信号</view><view style="text-align:center;color:#9E9E9E;font-size:24rpx;line-height:50rpx;">请输入正确的微信号</view></view><view class="dashed-line" style="border:2rpx solid #f1f1f1;"></view><view class="schedule-options flex-col"><view class="num-text" style="{{(imgurl?'background:'+$root.m1:'')}}">2</view><view class="tips-text" style="{{(imgurl?'':'color: #9E9E9E;')}}">绑定分享员</view><view style="text-align:center;color:#9E9E9E;font-size:24rpx;line-height:50rpx;">识别二维码接受邀请</view></view></view><view class="form-view"><view class="form-title">填写微信号</view><view class="form-item"><view class="label">微信号</view><input style="background-color:#f9f9f9;height:90rpx;line-height:90rpx;padding:0 20rpx;" placeholder="请输入微信号" placeholder-style="height: 90rpx;line-height: 90rpx;padding: 0 20rpx" data-event-opts="{{[['input',[['__set_model',['','weixin','$event',[]]]]]]}}" value="{{weixin}}" bindinput="__e"/><view style="color:#D81E06;line-height:50rpx;font-size:26rpx;display:flex;align-items:center;"><image style="width:30rpx;height:30rpx;margin-right:20rpx;" src="{{pre_url+'/static/img/workorder/ts.png'}}"></image>必须是真实的微信号，不能是手机号</view></view><block tt:if="{{imgurl}}"><block><view style="margin-top:20rpx;"><view class="form-title">保存二维码，用微信扫一扫识别二维码，接受邀请</view><view class="form-item"><view style="width:600rpx;height:600rpx;margin:0 auto;"><image style="width:100%;height:100%;" src="{{imgurl}}" data-url="{{imgurl}}" data-urls="{{imgurls}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view><view style="display:flex;justify-content:space-between;margin:100rpx auto;"><button data-event-opts="{{[['tap',[['hasBand',['$event']]]]]}}" class="set-btn" style="{{('margin:0;border:2rpx solid '+$root.m2+';color:'+$root.m3)}}" bindtap="__e">确定已绑定</button><button data-event-opts="{{[['tap',[['goBand',['$event']]]]]}}" class="set-btn" style="{{'margin:'+('0')+';'+('background:'+($root.m4)+';')}}" bindtap="__e">重新生成</button></view></block></block><block tt:else><block><button data-event-opts="{{[['tap',[['goBand',['$event']]]]]}}" class="set-btn" style="{{'background:'+($root.m5)+';'}}" bindtap="__e">立即提交</button></block></block></view><view class="form-view"><view class="form-title">提示</view><view class="form-item" style="line-height:50rpx;margin-top:20rpx;"><view>1.绑定分享员期间，请勿关闭页面</view><view>2.根据页面提示操作即可完成绑定</view></view></view><view style="width:100%;height:40rpx;"></view></view></block>