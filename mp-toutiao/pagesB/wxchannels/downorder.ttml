<view class="container"><block tt:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{$root.m0+"（"+count+"）"}}</text><text class="t2">{{"预计：+"+commissionyj+"元"}}</text></view><dd-tab vue-id="7125f724-1" itemdata="{{['所有订单','待付款','已付款','已完成','退款/售后']}}" itemst="{{['0','10','20','100','5']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></view><view style="margin-top:190rpx;"></view><block tt:if="{{datalist&&datalist.length>0}}"><block><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-show="{{item.$orig.order_info?1:0}}" data-url="{{'/pagesExt/order/detail?id='+item.$orig.order_info.id+'&fromfenxiao=1'}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" bindtap="__e"><view class="f1 flex" style="justify-content:flex-start;"><image class="img" src="{{item.$orig.headimg}}"></image><view class="t1"><block tt:if="{{item.$orig.nickname}}"><view>{{''+item.$orig.nickname+''}}</view></block><view>{{''+item.$orig.ordernum+"("+item.$orig.dengji+')'}}</view></view><block tt:if="{{item.$orig.dannum&&item.$orig.dannum>0}}"><view style="color:#a55;margin-left:30rpx;">{{'第'+item.$orig.dannum+'单'}}</view></block></view><view class="f2"><view class="t1 flex"><view class="x1 flex"><image class="img" src="{{item.$orig.pic}}"></image><view style="margin-left:20rpx;"><view class="x1t" style="line-height:50rpx;">{{item.$orig.name}}</view><view class="x1t">{{'下单时间：'+item.$orig.createtime}}</view></view></view><view>{{"共"+item.$orig.num+"件"}}</view></view><view class="t2 flex"><view>{{"实付金额：￥"+item.$orig.totalprice}}</view><view>预估佣金：<text style="color:#ff6600;">{{item.$orig.commission}}</text></view><view><block tt:if="{{item.$orig.status==20||item.$orig.status==21||item.$orig.status==30}}"><text class="dior-sp6 yfk">已付款</text></block><block tt:if="{{item.$orig.status==10}}"><text class="dior-sp6 dfk">待付款</text></block><block tt:if="{{item.$orig.status==100}}"><text class="dior-sp6 ywc">已完成</text></block><block tt:if="{{item.$orig.status==200||item.$orig.status==250}}"><text class="dior-sp6 ygb">已关闭</text></block><block tt:if="{{item.$orig.finish_aftersale_sku_cnt>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view><block tt:if="{{item.$orig.order_info}}"><view class="t3 flex"><view data-event-opts="{{[['tap',[['logistics',['$0'],[[['datalist','',index,'order_info']]]]]]]}}" class="btn2" style="{{('border:solid 2rpx '+item.m1+';color:'+item.m2)}}" catchtap="__e">查看物流</view></view></block></view></view></block></view><uni-popup class="vue-ref" vue-id="7125f724-2" id="dialogSelectExpress" type="dialog" data-ref="dialogSelectExpress" bind:__l="__l" vue-slots="{{['default']}}"><block tt:if="{{express_content}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><block tt:for="{{express_content}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="sendexpress-item" style="display:flex;border-bottom:1px solid #f5f5f5;padding:20rpx 0;" data-url="{{'/pagesExt/order/logistics?express_com='+item.express_com+'&express_no='+item.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.express_com+" - "+item.express_no}}</view><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view></block></uni-popup></block></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="7125f724-3" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="7125f724-4" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="7125f724-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="7125f724-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7125f724-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>