<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="e1b2ebfc-1" itemdata="{{['余额明细','提现记录']}}" itemst="{{['0','2']}}" st="{{st}}" isfixed="{{true}}" color1="#06A051" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block tt:if="{{st==0}}"><block><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block tt:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block tt:else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></block></block><block tt:if="{{st==2}}"><block><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m1}}</text></view><view class="f3"><block tt:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block tt:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block tt:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block tt:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="e1b2ebfc-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="e1b2ebfc-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="e1b2ebfc-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="e1b2ebfc-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="e1b2ebfc-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>