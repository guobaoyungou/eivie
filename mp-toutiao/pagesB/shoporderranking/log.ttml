<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{'月份时间：'+item.month+''}}</view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="c37b1b02-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="c37b1b02-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="c37b1b02-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="c37b1b02-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c37b1b02-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>