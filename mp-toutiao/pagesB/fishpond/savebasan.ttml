<view class="container"><view class="basan"><view class="seat_params"><view class="seat"><image class="seat-img" src="{{pre_url+'/static/img/fishpond/seat_kexuan.png'}}"></image>空闲</view><view class="seat"><image class="seat-img" src="{{pre_url+'/static/img/fishpond/seat_yishou.png'}}"></image>使用中</view><view class="seat"><image class="seat-img" src="{{pre_url+'/static/img/fishpond/seat_yixuan.png'}}"></image>已选择</view><view class="seat"><image class="seat-img" src="{{pre_url+'/static/img/fishpond/seat_suozuo.png'}}"></image>锁座</view></view><view class="tips-text flex-x-center"><text>请在下方选择位置</text></view><view class="basan-seat flex-wp"><block tt:for="{{basan}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="seat-box" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectBasan',['$event']]]]]}}" bindtap="__e"><block tt:if="{{item.status==2}}"><image src="{{pre_url+'/static/img/fishpond/seat_yishou.png'}}" mode></image></block><block tt:else><block tt:if="{{item.status==1}}"><image src="{{pre_url+'/static/img/fishpond/seat_yixuan.png'}}" mode></image></block><block tt:else><block tt:if="{{item.status==3}}"><image src="{{pre_url+'/static/img/fishpond/seat_suozuo.png'}}" mode></image></block><block tt:else><image src="{{pre_url+'/static/img/fishpond/seat_kexuan.png'}}" mode></image></block></block></block><text class="basan-name">{{item.name}}</text></view></block></view><view class="op"><block><button class="tobuy" style="{{'background:'+($root.m0)+';'}}" data-type="1" data-event-opts="{{[['tap',[['subSave',['$event']]]]]}}" bindtap="__e">确定</button></block></view></view></view>