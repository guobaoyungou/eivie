<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="61bb7170-1" itemdata="{{['全部','待付款','已完成','退款']}}" itemst="{{['all','0','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><block tt:if="{{item.$orig.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.binfo.name}}</view></block><block tt:else><view>{{"订单号："+item.$orig.ordernum}}</view></block><view class="flex1"></view><block tt:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block tt:if="{{item.$orig.status==1}}"><text class="st1">使用中</text></block><block tt:if="{{item.$orig.status==3}}"><text class="st3">已到期</text></block><block tt:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.$orig.propic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.proname}}</text><text class="t2">{{item.$orig.ggname}}</text><text class="t2">{{item.$orig.basan}}</text><view class="t3"><text class="x1 flex1">{{'￥'+item.$orig.sell_price+''}}</text><text class="x2">{{"×"+item.$orig.basan_sum}}</text></view></view></view><view class="bottom"><text>{{"共计"+item.$orig.num+"件商品 实付:"}}<block tt:if="{{showprice_dollar&&item.$orig.usd_totalprice}}"><text>{{"$"+item.$orig.usd_totalprice+''}}</text></block>{{'￥'+item.$orig.totalprice}}</text><block tt:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block tt:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block tt:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><block tt:if="{{item.g0}}"><block><view class="btn2" data-url="{{'/pagesExt/order/invoice?type=seckill&orderid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发票</view></block></block><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block tt:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block></block><block tt:if="{{item.$orig.status==1}}"><block><view class="btn2" data-url="{{'savebasan?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">更换位置</view><block tt:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block></block></block><block tt:if="{{item.$orig.status==2}}"><block><block tt:if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block><block tt:if="{{item.$orig.freight_type!=3&&item.$orig.freight_type!=4}}"><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+item.$orig.express_com+'&express_no='+item.$orig.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看物流</view></block><view class="btn1" style="{{'background:'+(item.m1)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" catchtap="__e">确认收货</view></block></block><block tt:if="{{item.$orig.status==3||item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchtap="__e">删除订单</view></block></block></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="61bb7170-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="61bb7170-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="61bb7170-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="61bb7170-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="61bb7170-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>