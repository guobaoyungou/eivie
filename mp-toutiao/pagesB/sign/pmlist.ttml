<view class="container"><view class="qd_guize"><view class="gztitle">— 第<text class="t2">{{bonuscount}}</text>期 奖励排名 —</view><view class="desc">前10名奖励排行榜</view><view class="paiming"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item flex"><view class="f1"><image class="headimg" src="{{item.headimg}}"></image><text class="t1">{{item.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+item.money+''}}</text><text class="t2">元</text></view></view></block></view><block tt:if="{{userinfo.money}}"><view class="item item2 flex"><view class="f1"><image class="headimg" src="{{userinfo.headimg}}"></image><text class="t1">{{userinfo.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+userinfo.money+''}}</text><text class="t2">元</text></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="201c10fb-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="201c10fb-2" bind:__l="__l"></nodata></block><block tt:if="{{loading}}"><loading vue-id="201c10fb-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="201c10fb-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="201c10fb-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>