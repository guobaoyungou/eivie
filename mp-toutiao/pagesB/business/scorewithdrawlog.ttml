<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="a34b47de-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="listrow"><view class="item"><view class="f1"><text class="t1">{{"提现"+$root.m0+"："+item.score}}<text class="money" style="{{'color:'+($root.m1)+';'}}">{{"(￥"+item.money+")"}}</text></text><text class="t2">{{item.showtime}}</text></view><view class="f3"><block tt:if="{{item.status==0}}"><text class="st0">审核中</text></block><block tt:if="{{item.status==1}}"><text class="st1">已审核</text></block><block tt:if="{{item.status==2}}"><text class="st2">已驳回</text></block><block tt:if="{{item.status==3}}"><text class="st3">已打款</text></block></view></view><block tt:if="{{item.status==2&&item.reason}}"><view class="tips">{{item.reason}}</view></block></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="a34b47de-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="a34b47de-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="a34b47de-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="a34b47de-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="a34b47de-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>