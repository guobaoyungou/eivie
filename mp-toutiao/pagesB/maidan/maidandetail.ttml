<view class="container"><block tt:if="{{isload}}"><block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2">{{detail.ordernum}}</text></view><block tt:if="{{detail.paynum}}"><view class="item"><text class="t1">支付流水</text><text class="t2">{{detail.paynum}}</text></view></block><block tt:if="{{mendian}}"><view class="item"><text class="t1">付款门店</text><text class="t2">{{mendian.name}}</text></view></block><view class="item"><text class="t1">付款金额</text><text class="t2">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">实付金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.paymoney}}</text></view><block tt:if="{{detail.canrefund}}"><view class="item"><text class="t1">退款金额</text><text class="t2" style="color:#ff9b00;">{{"￥"+detail.refund_money}}</text></view></block><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype}}</text></view><view class="item"><text class="t1">状态</text><block tt:if="{{detail.status==1}}"><text class="t2" style="color:green;">已付款</text></block><block tt:else><text class="t2" style="color:red;">未付款</text></block></view><block tt:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.disprice>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2">{{"-￥"+detail.disprice}}</text></view></block><block tt:if="{{detail.scoredk>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2">{{"-￥"+detail.scoredk}}</text></view></block><block tt:if="{{detail.couponrid}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2">{{"-￥"+detail.couponmoney}}</text></view></block><block tt:if="{{couponrecord}}"><view class="item"><text class="t1">{{$root.m3+"名称"}}</text><text class="t2">{{couponrecord.couponname}}</text></view></block><block tt:if="{{dec_money}}"><view class="item"><text class="t1">{{$root.m4+"名称"}}</text><text class="t2">{{dec_money}}</text></view></block><block tt:if="{{detail.dedamount_dkmoney&&detail.dedamount_dkmoney>0}}"><view class="item"><text class="t1">抵扣金</text><text class="t2">{{"-￥"+detail.dedamount_dkmoney}}</text></view></block><block tt:if="{{detail.combine_money&&detail.combine_money>0}}"><view class="item"><text class="t1">{{$root.m5+"已付"}}</text><text class="t2 red">{{"-¥"+detail.combine_money}}</text></view></block><block tt:if="{{detail.shopscoredk_money&&detail.shopscoredk_money>0}}"><view class="item"><text class="t1">{{$root.m6+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.shopscoredk_money}}</text></view></block><block tt:if="{{detail.paytypeid==2&&detail.combine_wxpay&&detail.combine_wxpay>0}}"><view class="item"><text class="t1">微信已付</text><text class="t2 red">{{"-¥"+detail.combine_wxpay}}</text></view></block><block tt:if="{{(detail.paytypeid==3||detail.paytypeid>=302&&detail.paytypeid<=330)&&detail.combine_alipay&&detail.combine_alipay>0}}"><view class="item"><text class="t1">支付宝已付</text><text class="t2 red">{{"-¥"+detail.combine_alipay}}</text></view></block><view class="item"><text class="t1">订单备注</text><text class="t2">{{detail.remark}}</text></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="88f287f0-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="88f287f0-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="88f287f0-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>