<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view><uni-datetime-picker vue-id="39948cab-1" type="datetimerange" rangeSeparator="~" value="{{datetimerange}}" data-event-opts="{{[['^change',[['timeChange']]],['^input',[['__set_model',['','datetimerange','$event',[]]]]]]}}" bind:change="__e" bind:input="__e" bind:__l="__l"></uni-datetime-picker></view><view class="total">合计补货：<text style="color:red;margin-right:10rpx;">{{total_stock}}</text>件</view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><view class="t1">柜子名称：<text style="color:#1e88e5;">{{item.device_name}}</text></view><view class="t1">柜子编号：<text style="color:#333;">{{''+item.device_no}}</text></view><view class="t1">补货时间：<text style="color:#333;">{{''+item.createtime}}</text></view><view class="t1">小计补货：<text style="color:red;margin-right:10rpx;">{{item.total_stock}}</text>件</view><view class="t1"><text style="color:#1e88e5;">补货商品明细：</text></view><block tt:for="{{item.goodsdata}}" tt:for-item="item2" tt:for-index="index"><block><view class="t2 flex flex-bt"><view>{{item2.proname+"["+item2.ggname+"]"}}</view><view style="color:#333;">{{"x"+item2.add_stock}}</view></view></block></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="39948cab-2" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="39948cab-3" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="39948cab-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="39948cab-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="39948cab-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>