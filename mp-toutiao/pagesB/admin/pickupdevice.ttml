<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'pickupdevicegoods?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/imgsrc/pickup_device.png'}}" mode="widthFix"></image><view class="f1"><view class="title">{{item.$orig.name}}</view><view class="t1"><text>柜子编号：</text>{{item.$orig.device_no}}</view><view class="t1"><text>格子总数：</text>{{item.$orig.goods_lane}}</view><view class="t1"><text>柜子地址：</text>{{item.$orig.address}}</view><view class="flex" style="justify-content:flex-end;"><block tt:if="{{item.$orig.lack_stock>0}}"><button class="btn" style="{{'background:'+(item.m0)+';'}}">补货</button></block></view></view><view class="status"><block tt:if="{{device_status==1}}"><text>在线</text></block><block tt:else><text style="color:#fff;">离线</text></block></view><block tt:if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">{{"缺货: "+item.$orig.lack_stock}}</view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="2ffd7d40-1" bind:__l="__l"></nodata></block></view><view class="bottom-view"><view class="bottom flex "><view class="button" style="{{'background:'+($root.m1)+';'}}" data-url="pickupdeviceaddstock" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">补货统计</view><view class="button" style="{{'background:'+($root.m2)+';'}}" data-url="pickupdeviceaddstocklog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">补货清单</view></view></view><block tt:if="{{nomore}}"><nomore vue-id="2ffd7d40-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="2ffd7d40-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="2ffd7d40-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="2ffd7d40-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>