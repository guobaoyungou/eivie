<view class="container"><block tt:if="{{isload}}"><block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><view class="t1">柜子名称：<text style="color:#1e88e5;">{{item.name}}</text></view><view class="t1">柜子编号：<text style="color:#333;">{{''+item.device_no}}</text></view><view class="t1">待补货总数：<text style="color:red;margin-right:10rpx;">{{item.lack_stock}}</text>件</view><view class="t1"><text style="color:#1e88e5;">补货商品明细：</text></view><block tt:for="{{item.goods}}" tt:for-item="item2" tt:for-index="index"><block><view class="t2 flex flex-bt"><view>{{item2.proname+"["+item2.ggname+"]"}}</view><view style="color:#333;">{{"x"+item2.lack_stock}}</view></view></block></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="bf292f2a-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="bf292f2a-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="bf292f2a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="bf292f2a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="bf292f2a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>