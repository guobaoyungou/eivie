<view><block tt:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{deposit}}</view><block tt:if="{{deposit_refund}}"><view class="f3"><block tt:if="{{refund_status==1}}"><text>审核中</text></block><block tt:if="{{refund_status!=1&&deposit>0}}"><text data-event-opts="{{[['tap',[['depositRefund']]]]}}" bindtap="__e">退款申请</text></block></view></block></view><block tt:if="{{datalist&&datalist.length>0}}"><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m2}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block tt:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block tt:else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></view></block><block tt:if="{{nodata}}"><nodata vue-id="c17361e8-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="c17361e8-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="c17361e8-3" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="c17361e8-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>