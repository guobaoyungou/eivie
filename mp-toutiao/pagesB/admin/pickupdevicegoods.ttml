<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><image class="img" src="{{item.$orig.pic}}"></image><view class="f1"><view class="title">{{"柜门编号-"+item.$orig.goods_lane}}</view><view class="t1"><text>商品信息：</text>{{item.$orig.proname+"["+item.$orig.ggname+"]"}}</view><view class="t1"><text>近期补货：</text>{{item.$orig.add_time}}</view><view class="flex" style="justify-content:flex-end;"><block tt:if="{{item.$orig.lack_stock>0}}"><button data-event-opts="{{[['tap',[['addstock',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+(item.m0)+';'}}" bindtap="__e">补货</button></block><button data-event-opts="{{[['tap',[['openBox',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">开门</button></view></view><block tt:if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">待补货</view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="29a74b84-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="29a74b84-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="29a74b84-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="29a74b84-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="29a74b84-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>