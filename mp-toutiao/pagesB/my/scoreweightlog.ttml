<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的积分权</view><view class="f2">{{myscoreweight}}</view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item-moudle" style="background-color:#FFFFFF;"><view>{{item.remark}}</view><view class="item"><view><text class="t2">{{item.createtime}}</text></view><view class="f2"><block tt:if="{{item.score_weight>0}}"><block><text class="t1" style="color:#03bc01;">{{"+"+item.score_weight}}</text></block></block><block tt:else><block><text class="t2">{{item.score_weight}}</text></block></block></view></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="024bd5aa-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="024bd5aa-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="024bd5aa-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="024bd5aa-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="024bd5aa-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>