<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remarks}}</text><text class="t2">{{item.$orig.create_time}}</text><block tt:if="{{item.$orig.score>0}}"><text class="t3">{{"消耗"+item.m0+"："+item.$orig.score}}</text></block></view><view class="f2"><text class="t1">{{item.$orig.num}}</text></view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="7b7b5794-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="7b7b5794-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="7b7b5794-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="7b7b5794-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7b7b5794-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>