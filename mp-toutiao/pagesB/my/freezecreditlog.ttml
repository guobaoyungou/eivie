<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{freeze_credit}}<block tt:if="{{canExchange==1}}"><view class="btn-mini" data-url="/pagesB/my/freezeexchange" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换</view></block></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block tt:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="897f1e7e-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="897f1e7e-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="897f1e7e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="897f1e7e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="897f1e7e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>