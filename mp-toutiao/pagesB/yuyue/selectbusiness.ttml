<view class="container"><block tt:if="{{isload}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="content " data-id="{{item.id}}" data-name="{{item.name}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchtap="__e"><view class="flex" style="justify-content:space-between;"><view class="f1"><view class="headimg"><block tt:if="{{item.logo}}"><image src="{{item.logo}}"></image></block><block tt:else><image src="{{pre_url+'/static/img/touxiang.png'}}"></image></block></view><view class="text1"><text class="t1">{{item.name+''}}</text></view></view><view class="yuyue">选择</view></view><view>{{''+item.address+''}}</view></view></block><block tt:if="{{nodata}}"><nodata vue-id="0e915958-1" bind:__l="__l"></nodata></block><view style="height:140rpx;"></view></block></block><block tt:if="{{loading}}"><loading vue-id="0e915958-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="0e915958-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="0e915958-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>