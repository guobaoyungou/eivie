<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="form"><view class="form-item"><text class="label">姓 名</text><input class="input" type="text" placeholder="请输入姓名" placeholder-style="font-size:28rpx;color:#BBBBBB" name="name" value="{{name}}"/></view><block tt:if="{{showCompany}}"><view class="form-item"><text class="label">公 司</text><input class="input" type="text" placeholder="请输入公司或单位名称" placeholder-style="font-size:28rpx;color:#BBBBBB" name="company" value="{{company}}"/></view></block><view class="form-item"><text class="label">手机号</text><input class="input" type="number" placeholder="请输入手机号" placeholder-style="font-size:28rpx;color:#BBBBBB" name="tel" value="{{tel}}"/></view><block tt:if="{{type==1}}"><view class="form-item"><text class="label flex0">选择位置</text><text data-event-opts="{{[['tap',[['selectzuobiao',['$event']]]]]}}" class="flex1" style="{{'text-align:right;'+(area?'':'color:#BBBBBB')}}" bindtap="__e">{{area?area:'请选择您的位置'}}</text></view></block><block tt:else><view class="form-item"><text class="label flex1">所在地区</text><uni-data-picker vue-id="239d96ec-1" localdata="{{items}}" border="{{false}}" placeholder="{{regiondata||'请选择省市区'}}" data-event-opts="{{[['^change',[['regionchange']]]]}}" bind:change="__e" bind:__l="__l"></uni-data-picker></view></block><view class="form-item"><text class="label">{{$root.m0}}</text><input class="input" type="text" placeholder="{{'请输入'+$root.m1}}" placeholder-style="font-size:28rpx;color:#BBBBBB" name="address" value="{{address}}"/></view><block tt:if="{{type!=1}}"><view class="item flex-y-center"><view class="f2 flex-y-center flex1"><textarea style="width:85%;font-size:24rpx;margin:20rpx 0;height:100rpx;padding:4rpx 10rpx;" id="addressxx" placeholder="粘贴地址信息，可自动识别并填写，如：张三，188********，广东省 东莞市 xx区 xx街道 xxxx" placeholder-style="font-size:24rpx;color:#BBBBBB" data-event-opts="{{[['input',[['setaddressxx',['$event']]]]]}}" bindinput="__e"></textarea><view data-event-opts="{{[['tap',[['shibie',['$event']]]]]}}" style="width:15%;text-align:center;" bindtap="__e">识别</view></view></view></block><block tt:if="{{is_show_floor&&type==1&&opt.isfloor==1}}"><block><view class="form-item"><text class="label">楼层</text><input class="input" type="number" placeholder="请输入楼层,例如:6" placeholder-style="font-size:28rpx;color:#BBBBBB" name="floor" value="{{floor}}"/></view><view class="form-item"><text class="label">房号</text><input class="input" type="text" placeholder="请输入房号,例如601" placeholder-style="font-size:28rpx;color:#BBBBBB" name="room" value="{{room}}"/></view><view class="form-item"><view class="label flex flex-y-center" style="width:240rpx;">是否有电梯<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}" data-event-opts="{{[['tap',[['showExplain',['$event']]]]]}}" bindtap="__e"></image></view><view class="switch-view flex"><view data-event-opts="{{[['tap',[['switchChange',[0]]]]]}}" class="switch-options" style="{{'background:'+(have_dianti==0?'rgba('+$root.m2+',0.2)':'')+';'+('border-color:'+(have_dianti==0?$root.m3:'')+';')+('color:'+(have_dianti==0?$root.m4:'')+';')}}" bindtap="__e">否</view><view data-event-opts="{{[['tap',[['switchChange',[1]]]]]}}" class="switch-options" style="{{'background:'+(have_dianti==1?'rgba('+$root.m5+',0.2)':'')+';'+('border-color:'+(have_dianti==1?$root.m6:'')+';')+('color:'+(have_dianti==1?$root.m7:'')+';')}}" bindtap="__e">是</view></view></view></block></block></view><block tt:if="{{product_thali}}"><view class="form"><view class="form-item"><text class="label">学生姓名</text><input class="input" style="width:650rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" type="text" placeholder="请输入学生姓名" placeholder-style="font-size:28rpx;color:#BBBBBB" name="product_thali_student_name" value="{{product_thali_student_name}}"/></view><block tt:if="{{schooldata&&!schoolAreaText}}"><view class="form-item"><text class="label flex1" style="white-space:nowrap;">学校信息</text><picker range="{{schoolArea}}" range-key="name" data-event-opts="{{[['change',[['PickerSchoolArea',['$event']]]]]}}" bindchange="__e"><view class="flex1 schooldata-class">{{schooldata}}</view></picker></view></block><block tt:else><view class="form-item"><text class="label flex1">学校区域</text><picker range="{{schoolArea}}" range-key="name" data-event-opts="{{[['change',[['PickerSchoolArea',['$event']]]]]}}" bindchange="__e"><block tt:if="{{schoolAreaText}}"><view class="picker-select">{{schoolAreaText}}</view></block><block tt:else><view class="picker-placeholder">请选择区域</view></block></picker></view></block><block tt:if="{{schoolList.length&&schoolAreaText}}"><view class="form-item"><text class="label flex1">学校信息</text><picker range="{{schoolList}}" range-key="name" data-event-opts="{{[['change',[['PickerSchoolList',['$event']]]]]}}" bindchange="__e"><block tt:if="{{schoolText}}"><view class="picker-select">{{schoolText}}</view></block><block tt:else><view class="picker-placeholder">请选择学校</view></block></picker></view></block><block tt:if="{{studentGradeList.length&&schoolText}}"><view class="form-item"><text class="label flex1">学生年级</text><picker range="{{studentGradeList}}" range-key="name" data-event-opts="{{[['change',[['PickerStudentGrade',['$event']]]]]}}" bindchange="__e"><block tt:if="{{studentGradeText}}"><view class="picker-select">{{studentGradeText}}</view></block><block tt:else><view class="picker-placeholder">请选择学生年级</view></block></picker></view></block><block tt:if="{{studentClassList.length&&studentGradeText}}"><view class="form-item"><text class="label flex1">学生班级</text><picker range="{{studentClassList}}" range-key="name" data-event-opts="{{[['change',[['PickerstudentClass',['$event']]]]]}}" bindchange="__e"><block tt:if="{{studentClassText}}"><view class="picker-select">{{studentClassText}}</view></block><block tt:else><view class="picker-placeholder">请选择学生班级</view></block></picker></view></block></view></block><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m8+' 0%,rgba('+$root.m9+',0.8) 100%)')}}" form-type="submit">保 存</button></form></block></block><block tt:if="{{loading}}"><loading vue-id="239d96ec-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="239d96ec-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="239d96ec-4" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="239d96ec-5" bind:__l="__l"></wxxieyi></view>