<view class="container"><block tt:if="{{isload}}"><block><view class="message-list"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><block tt:if="{{item.formatTime}}"><view class="message-time">{{item.formatTime}}</view></block><block tt:if="{{item.isreply==1}}"><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'}}"><image class="message-avatar" mode="aspectFill" src="{{item.uheadimg}}"></image><view class="message-text-left"><view class="arrow-box arrow-left"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-white.png'}}"></image></view><view class="message-text"><parse vue-id="{{'465bca46-1-'+index}}" content="{{item.content}}" bind:__l="__l"></parse></view></view></view></block><block tt:else><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'+('justify-content:'+('flex-end')+';')}}"><view class="message-text-right"><view class="arrow-box arrow-right"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-green.png'}}"></image></view><view class="message-text"><parse vue-id="{{'465bca46-2-'+index}}" content="{{item.content}}" bind:__l="__l"></parse></view></view><image class="message-avatar" mode="aspectFill" src="{{item.headimg}}"></image></view></block></block></block></view><view class="input-box notabbarbot" id="input-box"><view class="input-form"><image class="pic-icon" src="{{pre_url+'/static/img/msg-pic.png'}}" data-event-opts="{{[['tap',[['sendimg',['$event']]]]]}}" bindtap="__e"></image><input class="input" confirmHold="{{true}}" confirmType="send" cursor-spacing="20" type="text" maxlength="-1" data-event-opts="{{[['confirm',[['sendMessage',['$event']]]],['focus',[['onInputFocus',['$event']]]],['input',[['messageChange',['$event']]]]]}}" value="{{message}}" bindconfirm="__e" bindfocus="__e" bindinput="__e"/><image class="face-icon" src="{{pre_url+'/static/img/face-icon.png'}}" data-event-opts="{{[['tap',[['toggleFaceBox',['$event']]]]]}}" bindtap="__e"></image><block tt:if="{{trimMessage}}"><button data-event-opts="{{[['tap',[['sendMessage',['$event']]]]]}}" class="send-button-active" style="{{'background:'+($root.m0)+';'}}" bindtap="__e">发送</button></block></view><block tt:if="{{faceshow}}"><wxface bind:selectface="__e" vue-id="465bca46-3" data-event-opts="{{[['^selectface',[['selectface']]]]}}" bind:__l="__l"></wxface></block></view><view class="{{('anit '+(msgtipsShow==1?'show':msgtipsShow==2?'hide':''))}}" data-url="{{'index?bid='+msgtips.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{msgtips.unickname+"："+msgtips.content}}</view></block></block><block tt:if="{{loading}}"><loading vue-id="465bca46-4" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="465bca46-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>