<view><block tt:if="{{isload}}"><block><view class="container"><view class="content-view" style="{{'background-image:'+('url('+pre_url+'/static/imgsrc/collage/bg.png)')+';'}}"><view class="title-view paddimg-around"><view class="left-img"><image src="{{pre_url+'/static/imgsrc/collage/titlelog.png'}}"></image></view><view class="time-view">活动倒计时：<view class="djstime-view" id="djstime"><text class="djsspan">{{djshour}}</text>:<text class="djsspan">{{djsmin}}</text>:<text class="djsspan">{{djssec}}</text></view></view></view><view class="content-options"><view class="title-view">{{''+product.name+''}}</view><view class="bot-list-view"><block tt:for="{{product.jieti_data}}" tt:for-item="item" tt:for-index="index"><block><view class="list-class"><view class="left-view"><view class="icon-view"><image src="{{pre_url+'/static/imgsrc/collage/listicon.png'}}"></image></view><view class="text-view"><view style="color:#242424;margin-right:30rpx;">{{"满"+item.teamnum+"人"}}</view><view style="color:#88827F;">{{"团长送"+item.goodsname}}</view></view></view><view class="keshi-text">{{"课时:"+item.goodsnum}}</view></view></block></block></view></view><view class="content-options" style="padding:0rpx 30rpx;"><view class="title-bg-view" style="{{'background-image:'+('url('+pre_url+'/static/imgsrc/collage/titbg.png)')+';'}}">拼团详情</view><view class="shuju-view"><view class="shuju-options-view"><view class="num-class">{{product.view_num}}</view><view class="text-num">已浏览</view></view><view class="shuju-options-view"><view class="num-class">{{product.ordernum}}</view><view class="text-num">已报名</view></view><view class="shuju-options-view"><view class="num-class">{{product.share_num}}</view><view class="text-num">已分享</view></view></view><view class="browsing-history"><view style="white-space:nowrap;">浏览记录</view><view class="view-class-view"><view class="touxiang-view"><block tt:for="{{view_history}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="avater-view"><image src="{{item.headimg}}"></image></view></block></block><view style="width:15rpx;"></view></view><view class="avater-view"><image src="{{pre_url+'/static/imgsrc/collage/genduo.png'}}"></image></view></view></view></view><view class="content-options" style="padding:0rpx 30rpx;"><view class="title-bg-view" style="{{'background-image:'+('url('+pre_url+'/static/imgsrc/collage/titbg.png)')+';'}}">拼团人员</view><view class="details-view"><block tt:for="{{userlist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block tt:if="{{userlist.length>0}}"><block><view class="details-view-options"><view class="img-view"><image src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image></view><view class="name-text">{{item.nickname}}</view></view></block></block></block></view><view class="tips-text">{{'当前'+team.num+'人在拼单，可以直接参与'}}</view></view><view class="content-options" style="padding:0rpx 30rpx;"><view class="title-bg-view" style="{{'background-image:'+('url('+pre_url+'/static/imgsrc/collage/titbg.png)')+';'}}">拼团介绍</view><view class="jieshao-view"><dp vue-id="63c4f36f-1" pagecontent="{{pagecontent}}" bind:__l="__l"></dp></view></view><view style="height:180rpx;"></view><view class="but-view"><view class="kefu-view" data-phone="{{shopset.tel}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/imgsrc/collage/lianxi.png'}}"></image><view>联系商家</view></view><view class="right-view"><block tt:if="{{team.status==1&&haveme==0&&team.haveorder==0}}"><view class="button-class kt" data-btntype="2" data-event-opts="{{[['tap',[['buydialogShow',['$event']]]]]}}" bindtap="__e">我要开团</view></block><block tt:if="{{team.haveorder==1}}"><view data-event-opts="{{[['tap',[['toOrderlist',['$event']]]]]}}" class="button-class kt" bindtap="__e">拼团订单</view></block><block tt:if="{{team.haveorder==1}}"><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="button-class ct" bindtap="__e"><text>邀请好友参团</text></view></block><block tt:if="{{team.status==1&&haveme==0&&team.haveorder==0}}"><view class="button-class ct" data-btntype="3" data-event-opts="{{[['tap',[['handleShowJt',['$event']]]]]}}" bindtap="__e">我要参团</view></block></view></view></view></view><block tt:if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block tt:if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block tt:else><block tt:if="{{$root.m1=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block tt:else><block tt:if="{{$root.m2!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><view hidden="{{buydialogHidden}}"><view class="buydialog-mask"><view class="buydialog"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="buydialog-canimg" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title"><image class="img" src="{{guigelist[ks].pic?guigelist[ks].pic:product.pic}}" data-url="{{guigelist[ks].pic?guigelist[ks].pic:product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="price"><text class="t1">￥</text>{{guigelist[ks].sell_price+''}}<block tt:if="{{guigelist[ks].market_price>guigelist[ks].sell_price}}"><text class="t2">{{"￥"+guigelist[ks].market_price}}</text></block></view><view class="choosename">{{"已选规格: "+guigelist[ks].name}}</view><view class="stock">{{"剩余"+guigelist[ks].stock+"件"}}</view></view><block tt:for="{{guigedata}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="guigelist flex-col"><view class="name">{{item.title}}</view><view class="item flex flex-wp"><block tt:for="{{item.items}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><block><view class="{{('item2 '+(ggselected[item.k]==item2.k?'on':''))}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" bindtap="__e">{{item2.title}}</view></block></block></view></view></block><block tt:if="{{!product.collage_type}}"><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="f2 flex flex-y-center"><text data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus flex-x-center" bindtap="__e">-</text><input class="flex-x-center" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" bindinput="__e"/><text data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus flex-x-center" bindtap="__e">+</text></view></view></block><block><button class="tobuy" data-type="{{btntype}}" data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" bindtap="__e">确 定</button></block></view></view></view><block tt:if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><block tt:if="{{showJt}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleShowJt',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="jt_tab"><view class="x1" style="{{'background-color:'+(jt_st==1?$root.m3:'')+';'+('color:'+(jt_st==1?'#fff':$root.m4)+';')+('border-color:'+($root.m5)+';')}}" data-type="1" data-event-opts="{{[['tap',[['changeKh',['$event']]]]]}}" bindtap="__e">老客户</view><view class="x2" style="{{'background-color:'+(jt_st==2?$root.m6:'')+';'+('color:'+(jt_st==2?'#fff':$root.m7)+';')+('border-color:'+($root.m8)+';')}}" data-type="2" data-event-opts="{{[['tap',[['changeKh',['$event']]]]]}}" bindtap="__e">新客户</view></view><block tt:if="{{jt_st==1||jt_st==2}}"><view class="btnlist"><block tt:if="{{jt_st==1||jt_st==2}}"><view class="tocart" style="{{'background:'+($root.m9)+';'}}" data-btntype="2" data-event-opts="{{[['tap',[['buydialogShow',['$event']]]]]}}" bindtap="__e"><text>我要开团</text></view></block><block tt:if="{{jt_st==2}}"><view class="tobuy" style="{{'background:'+($root.m10)+';'}}" data-btntype="3" data-event-opts="{{[['tap',[['buydialogShow',['$event']]]]]}}" bindtap="__e"><text>我要参团</text></view></block></view></block></view></view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="63c4f36f-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="63c4f36f-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="63c4f36f-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>