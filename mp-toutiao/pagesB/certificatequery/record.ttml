<view class="container"><block tt:if="{{isload}}"><block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-url="{{'detail?tel='+item.tel+'&posterid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"姓名："+item.realname}}</text><text class="t2">{{"性别："+item.sex}}</text><block tt:if="{{item.id_card}}"><text class="t2">{{"身份证号："+item.id_card}}</text></block><block tt:if="{{item.tel}}"><text class="t2">{{"手机号："+item.tel}}</text></block><text class="t2">{{"证书编号："+item.certificate_no}}</text><text class="t2">{{"工种："+item.type}}</text><text class="t2">{{"等级："+item.certificate_level}}</text><text class="t2">{{"发证日期："+item.start_time}}</text></view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="7689e04e-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="7689e04e-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="7689e04e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="7689e04e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7689e04e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>