<view class="container"><block tt:if="{{isload}}"><block><view class="view-show"><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{(('nav_left')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{(('nav_left_items')+' '+(index===currentActiveIndex?'active':''))}}" style="{{'color:'+(index===currentActiveIndex?item.m0:'#333')+';'}}" data-root-item-id="{{item.$orig.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.$orig.name+''}}</view></block></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="detail-list" scroll-y="true" show-scrollbar="{{false}}" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><block tt:for="{{$root.l1}}" tt:for-item="detail" tt:for-index="indexs" tt:key="indexs"><view class="classification-detail-item"><view class="head" data-id="{{detail.$orig.id}}" id="{{'detail-'+detail.$orig.id}}"><view class="txt">{{detail.$orig.name}}</view><view class="show-all" data-id="{{detail.$orig.id}}" data-event-opts="{{[['tap',[['gotoCatproductPage',['$event']]]]]}}" bindtap="__e">更多<text class="iconfont iconjiantou"></text></view></view><view class="product-itemlist"><block tt:for="{{detail.$orig.child}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="item" data-url="{{'/activity/kecheng/product?id='+item.id+'&bid='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.name}}</text></view><view class="p2" style="{{'color:'+(detail.m2)+';'}}"><text class="t1"><block tt:if="{{item.price<=0}}"><text>免费</text></block><block tt:else><text><text style="font-size:20rpx;padding-right:1px;">￥</text>{{item.price+''}}</text></block></text><block tt:if="{{item.market_price>0}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view></view></block></view></view></block><block tt:if="{{nodata}}"><nomore vue-id="b9b95dc4-1" text="没有更多分类了" bind:__l="__l"></nomore></block></scroll-view></view></view></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="b9b95dc4-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="b9b95dc4-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b9b95dc4-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>