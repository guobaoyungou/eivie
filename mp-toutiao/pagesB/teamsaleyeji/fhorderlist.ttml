<view class="container"><block tt:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{"分红订单（"+ordercount+"）"}}</text></view><dd-tab vue-id="52e06768-1" itemdata="{{['待结算','已结算']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></view><view style="margin-top:190rpx;"></view><block tt:if="{{datalist&&datalist.length>0}}"><block><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1 flex-y-center"><text>{{item.$orig.ordernum}}</text><text class="flex1"></text><text style="font-size:24rpx;color:#999;">{{item.$orig.fhname}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.$orig.name+" ×"+item.$orig.num}}</text><text class="x2" style="{{'font-size:28rpx;'+('color:'+($root.m0)+';')}}">{{"￥"+item.$orig.real_totalprice}}</text><text class="x2">{{item.m1}}</text><view class="x3"><image src="{{item.$orig.headimg}}"></image>{{item.$orig.nickname}}</view></view><view class="t2"><block tt:if="{{item.$orig.status==1||item.$orig.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block tt:if="{{item.$orig.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block tt:if="{{item.$orig.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block tt:if="{{item.$orig.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block tt:if="{{item.$orig.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block><view style="width:100%;height:20rpx;"></view></view></block></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="52e06768-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="52e06768-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="52e06768-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="52e06768-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="52e06768-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>