<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="f387bf38-1" itemdata="{{[$root.m0+'明细','提现记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block tt:if="{{st==0}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after+"元"}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block tt:else><text class="t2">{{item.money}}</text></block></view></view></block></block></block><block tt:if="{{st==1}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block tt:if="{{item.status==0}}"><text class="t1">审核中</text></block><block tt:if="{{item.status==1}}"><text class="t1">已审核</text></block><block tt:if="{{item.status==2}}"><text class="t2">已驳回</text></block><block tt:if="{{item.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="f387bf38-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="f387bf38-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="f387bf38-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="f387bf38-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f387bf38-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>