<view><block tt:if="{{isload}}"><block><view class="detail"><parse vue-id="000302ce-1" content="{{detail.content}}" bind:__l="__l"></parse></view><view class="itembox"><view class="title">工单列表</view><block tt:if="{{detail.pid>0||detail.pid==0&&detail.id==id&&ispcate==1}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index"><view class="item" data-url="{{'/pagesB/workorder/index?cateid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{item.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></block><block tt:else><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index2"><view class="category"><view class="cate"><view class="img" data-id="{{item.id}}" data-index="{{index2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/workorder/'+(curIndex2==index2?'down':'up')+'.png?v1'}}" mode="widthFix"></image></view><view>{{item.name}}</view></view><block tt:for="{{item.list}}" tt:for-item="subitem" tt:for-index="subindex"><block tt:if="{{curIndex2==index2}}"><view class="item" style="padding-left:50rpx;margin-top:10rpx;" data-url="{{'/pagesB/workorder/index?cateid='+subitem.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{subitem.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></view></block></block></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="000302ce-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="000302ce-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="000302ce-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>