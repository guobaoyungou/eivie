<block tt:if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank2.png'}}" mode="widthFix"></image><view class="content"><view class="top"><view class="t1">{{"我的"+$root.m1+"："+totalscore}}</view></view><view class="tab"><view class="t1">排名</view><view class="t2">姓名</view><view class="t3" style="{{'color:'+($root.m2)+';'}}">{{"累计"+$root.m3}}</view></view><view class="itembox"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><block tt:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block tt:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3">{{''+item.sumscore}}</text></view></block></block></view></view></view><block tt:if="{{nodata}}"><nodata vue-id="0d102690-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="0d102690-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="0d102690-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="0d102690-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="0d102690-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block></block>