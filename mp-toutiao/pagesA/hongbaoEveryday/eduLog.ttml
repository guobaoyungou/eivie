<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的额度</view><view class="f2">{{hongbao_everyday_edu}}</view></view><block tt:if="{{scoreWithdraw}}"><view class="myscore" style="{{'background:'+($root.m1)+';'}}"><view class="f1">{{"允提"+$root.m2}}</view><view class="f2">{{myscore2}}<view class="btn-mini" data-url="/pagesExt/my/scoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></view></view></block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block tt:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="09ae18f6-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="09ae18f6-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="09ae18f6-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="09ae18f6-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="09ae18f6-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>