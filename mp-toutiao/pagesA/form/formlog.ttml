<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="b3078bc8-1" itemdata="{{['全部','待确认','已确认','已驳回','待支付']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-url="{{'formdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.title}}</text><block tt:for="{{item.formcontent}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><block tt:if="{{!item2.hidden&&item2.val12&&item2.key!='upload'&&item2.key!='upload_file'&&item2.key!='upload_video'&&item2.key!='upload_pics'}}"><text class="{{(('t2')+' '+(item2.key=='separate'?'title':''))}}">{{''+item2.val1+"："+item['form'+index2]+''}}<block tt:if="{{item.show_distance&&item2.key=='map'}}"><view class="t2" data-latitude="{{item.adr_lat}}" data-longitude="{{item.adr_lon}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e"><image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image>{{'距离您'+item.distance+''}}</view></block></text></block></block><block tt:if="{{item.custom_number}}"><text class="t2">{{item.custom_number_text+"："+item.custom_number}}</text></block><text class="t2">{{"提交时间："+item.createtime}}</text></view><view class="f2"><block tt:if="{{item.status==0&&(!item.payorderid||item.paystatus==1)}}"><text class="t1" style="color:#88e;">待确认</text></block><block tt:if="{{item.status==0&&item.payorderid&&item.paystatus==0}}"><text class="t1" style="color:red;">待支付</text></block><block tt:if="{{item.status==1}}"><text class="t1" style="color:green;">已确认</text></block><block tt:if="{{item.status==2}}"><text class="t1" style="color:red;">已驳回</text></block></view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="b3078bc8-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="b3078bc8-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="b3078bc8-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="b3078bc8-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b3078bc8-6" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="b3078bc8-7" bind:__l="__l"></wxxieyi></view>