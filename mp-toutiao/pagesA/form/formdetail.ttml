<view class="container" style="{{(form.form_query==1&&form.form_query_bgcolor?'min-height:100vh;background-color:'+form.form_query_bgcolor:'')}}"><block tt:if="{{isload}}"><block><view class="orderinfo" style="{{(form.form_query==1&&form.form_query_bgcolor?'background-color:'+form.form_query_bgcolor+';color:'+form.form_query_txtcolor+'!important':'')}}"><block tt:if="{{form.show_name==1}}"><view class="item"><text class="t1">标题</text><text class="t2">{{detail.title}}</text></view></block><block tt:for="{{formcontent}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><block tt:if="{{!item.hidden&&item.val12}}"><view class="item"><text class="{{(('t1')+' '+(item.key=='separate'?'title':''))}}">{{item.val1}}</text><block tt:if="{{item.key!='upload'&&item.key!='upload_file'&&item.key!='upload_video'&&item.key!='upload_pics'}}"><text class="t2">{{''+detail['form'+index]+''}}</text></block><block tt:if="{{item.key=='upload'}}"><view class="t2"><image style="width:50px;" src="{{detail['form'+index]}}" mode="widthFix" data-url="{{detail['form'+index]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:if="{{item.key=='upload_file'}}"><view class="t2" style="overflow:hidden;white-space:pre-wrap;word-wrap:break-word;color:#4786BC;">{{''+detail['form'+index]+''}}</view></block><block tt:if="{{item.key=='upload_video'}}"><view class="t2"><video style="width:80%;height:300rpx;margin-top:20rpx;" src="{{detail['form'+index]}}"></video></view></block></view></block><block tt:if="{{item.key=='map'&&detail.show_distance}}"><view class="item" data-latitude="{{detail.adr_lat}}" data-longitude="{{detail.adr_lon}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e"><text class="t1"></text><view class="t2">{{'距离您'+detail.distance+''}}<image style="width:26rpx;height:26rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/b_addr.png'}}"></image>点击导航</view></view></block><block tt:if="{{item.key=='upload_pics'}}"><view class="t2"><block tt:for="{{detail['form'+index]}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><block><image style="width:50px;margin-right:10rpx;" src="{{item2}}" mode="widthFix" data-url="{{item2}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></block></block></view></block></block></block><block tt:if="{{detail.is_other_fee==1}}"><view class="feebox"><text class="title">费用明细</text><view class="feelist"><block tt:for="{{detail.fee_items}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="feeitem"><view>{{item.name}}</view><view class="price">{{"￥"+item.money}}</view></view></block></view></view></block><block tt:if="{{form.show_time==1}}"><view class="item"><text class="t1">提交时间</text><text class="t2">{{detail.createtime}}</text></view></block><block tt:if="{{form.show_audit==1}}"><view class="item"><text class="t1">审核状态</text><block tt:if="{{detail.status==0&&(!detail.payorderid||detail.paystatus==1)}}"><text class="t2" style="color:#88e;">待确认</text></block><block tt:if="{{detail.status==0&&detail.payorderid&&detail.paystatus==0}}"><text class="t2" style="color:red;">待支付</text></block><block tt:if="{{detail.status==1}}"><text class="t2" style="color:green;">已确认</text></block><block tt:if="{{detail.status==2}}"><text class="t2" style="color:red;">已驳回</text></block></view></block><block tt:if="{{detail.status==2}}"><view class="item"><text class="t1">驳回原因</text><text class="t2" style="color:red;">{{detail.reason}}</text></view></block><block tt:if="{{detail.payorderid}}"><block><block tt:if="{{detail.yx_order_discount_rand&&detail.discount_rand_money>0}}"><view class="item"><text class="t1">随机立减</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"-￥"+detail.discount_rand_money}}</text></view></block><view class="item"><text class="t1">付款金额</text><text class="t2" style="font-size:32rpx;color:#e94745;">{{"￥"+detail.money}}</text></view><view class="item"><text class="t1">付款方式</text><text class="t2">{{detail.paytype||''}}</text></view><view class="item"><text class="t1">付款状态</text><block tt:if="{{detail.paystatus==1&&detail.isrefund==0}}"><text class="t2" style="color:green;">已付款</text></block><block tt:if="{{detail.paystatus==1&&detail.isrefund==1}}"><text class="t2" style="color:red;">已退款</text></block><block tt:if="{{detail.paystatus==0}}"><text class="t2" style="color:red;">未付款</text></block></view><block tt:if="{{detail.paystatus>0&&detail.paytime}}"><view class="item"><text class="t1">付款时间</text><text class="t2">{{detail.paytime}}</text></view></block></block></block><block tt:if="{{form.hxqrcode_status==1&&(form.payset==0||detail.paystatus==1)}}"><block><view class="item"><text class="t1">核销状态</text><block tt:if="{{detail.hexiao_status==0}}"><text class="t2" style="color:#88e;">待核销</text></block><block tt:if="{{detail.hexiao_status==1}}"><text class="t2" style="color:green;">已核销</text></block></view><block tt:if="{{detail.hexiao_status==0}}"><view class="item flex-col flex-y-center"><view>核销码</view><image style="width:250rpx;height:250rpx;" src="{{hexiaoqr}}" data-url="{{hexiaoqr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></block></block></view><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><block tt:if="{{opt.op!='view'}}"><view class="bottom notabbarbot"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除</view><block tt:if="{{detail.fromurl&&detail.edit_status}}"><view class="btn2" data-url="{{detail.fromurl+'&fromrecord='+detail.id+'&type=edit'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{detail.edit_name?detail.edit_name:'编辑'}}</view></block><block tt:if="{{detail.fromurl&&detail.againsubmit}}"><view class="btn2" data-url="{{detail.fromurl+'&fromrecord='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{againname}}</view></block><block tt:if="{{detail.payorderid&&detail.paystatus==0}}"><block><view class="btn1" style="{{'background:'+($root.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block></block></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="7a7bc5ae-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="7a7bc5ae-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7a7bc5ae-3" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="7a7bc5ae-4" bind:__l="__l"></wxxieyi></view>