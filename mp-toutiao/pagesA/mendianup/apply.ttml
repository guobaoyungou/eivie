<view><block tt:if="{{isload}}"><block><block tt:if="{{info.id&&info.check_status==2}}"><view style="color:red;padding:10rpx 30rpx;margin-top:20rpx;">{{"审核不通过："+info.reason+"，请修改后再提交"}}</view></block><block tt:else><block tt:if="{{info.id&&info.check_status==0&&info.status==1}}"><view style="color:red;padding:10rpx 30rpx;margin-top:20rpx;">您已提交申请，请等待审核</view></block><block tt:else><block tt:if="{{info.id&&info.check_status==0}}"><view style="color:red;padding:10rpx 30rpx;margin-top:20rpx;">您已提交申请，请等待审核</view></block></block></block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="apply_box"><view class="apply_item"><view>{{$root.m0+"名称"}}<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="name" placeholder="{{'请填写'+$root.m1+'名称'}}" value="{{info.name}}"/></view></view><view class="apply_item"><view>联系电话<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="tel" placeholder="请填写手机号码" value="{{info.tel}}"/></view></view></view><view class="apply_box"><block tt:if="{{!mendian_up}}"><block><view class="apply_item" style="border-bottom:0;"><view>{{$root.m2+"主图"}}<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block tt:for="{{pic}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/><view class="apply_item" style="border-bottom:0;"><view>{{$root.m3+"图片"}}<text style="color:red;">*</text></view></view><view class="flex" style="flex-wrap:wrap;padding-bottom:20rpx;"><block tt:for="{{pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pics.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></block></block><block tt:if="{{mendian_up}}"><block><view class="apply_item"><view>{{$root.m4+"地址"}}<text style="color:red;">*</text></view><view class="flex-y-center"><text data-event-opts="{{[['tap',[['toggleMaskLocation',['$event']]]]]}}" class="cell-tip" bindtap="__e"><text class="choose-text">{{addressByPcrs}}</text><text class="iconfont icon-xiangxia"></text></text></view></view><view class="apply_item"><view>社区名称<text style="color:red;">*</text></view><view class="flex-y-center"><input class="input" type="text" placeholder="请输入社区名称" placeholder-style="font-size:28rpx;color:#BBBBBB" name="xqname" value="{{info.xqname}}"/></view></view></block></block><block tt:else><block><view class="apply_item1"><view style="line-height:100rpx;">门店地址<text style="color:red;">*</text></view><view class="flex-y-center"><uni-data-picker vue-id="574d0d67-1" localdata="{{items}}" border="{{false}}" placeholder="{{regiondata||'请选择省市区'}}" data-event-opts="{{[['^change',[['regionchange']]]]}}" bind:change="__e" bind:__l="__l"></uni-data-picker></view></view></block></block><view class="apply_item"><view>详细位置<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['selectzuobiao',['$event']]]]]}}" class="flex-y-center" bindtap="__e"><input type="text" placeholder="请选择坐标" value="{{latitude?latitude+','+longitude:''}}"/></view></view><view class="apply_item"><view>详细地址<text style="color:red;">*</text></view><view class="flex-y-center"><input class="input" type="text" placeholder="{{'请输入'+$root.m5}}" placeholder-style="font-size:28rpx;color:#BBBBBB" name="address" value="{{address}}"/></view></view><block tt:if="{{!mendian_up}}"><block><view class="apply_item"><view>{{$root.m6+"简介"}}</view><view class="flex-y-center"><input type="text" name="subname" placeholder="{{$root.m7+'简介'}}" value="{{info.subname}}"/></view></view></block></block><input style="position:fixed;left:-200%;" type="text" hidden="true" name="latitude" value="{{latitude}}"/><input style="position:fixed;left:-200%;" type="text" hidden="true" name="longitude" value="{{longitude}}"/></view><block tt:if="{{!mendian_up}}"><view class="apply_box"><view class="apply_item"><view>设置登录账号<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="un" placeholder="请填写登录账号" autocomplete="off" value="{{info.un}}"/></view></view><view class="apply_item"><view>设置登录密码<text style="color:red;">*</text></view><view class="flex-y-center"><input type="password" name="pwd" placeholder="请填写登录密码" autocomplete="off" value="{{info.pwd}}"/></view></view><view class="apply_item"><view>确认密码<text style="color:red;">*</text></view><view class="flex-y-center"><input type="password" name="repwd" placeholder="请再次填写密码"/></view></view></view></block><view style="padding:30rpx 0;"><block tt:if="{{!info.id||info.check_status==2}}"><button class="set-btn" style="{{('background:linear-gradient(90deg,'+$root.m8+' 0%,rgba('+$root.m9+',0.8) 100%)')}}" form-type="submit">提交申请</button></block></view></form></block></block><block tt:if="{{fwlistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择服务类目</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="id"><block><view class="clist-item" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['fwcidsChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m10?'background:'+item.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block tt:for="{{item.l0}}" tt:for-item="item2" tt:for-index="index2" tt:key="id"><block><view class="clist-item" style="padding-left:80rpx;" data-id="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['fwcidsChange',['$event']]]]]}}" bindtap="__e"><block tt:if="{{item.$orig.child.length-1==index2}}"><view class="flex1">{{"└ "+item2.$orig.name}}</view></block><block tt:else><view class="flex1">{{"├ "+item2.$orig.name}}</view></block><view class="radio" style="{{(item2.m12?'background:'+item2.m13+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></block></block></view></view></view></block><gk-city class="vue-ref" vue-id="574d0d67-2" headtitle="{{headtitle}}" provincedata="{{provincedata}}" data="{{selfData}}" mode="cityPicker" pickerSize="{{4}}" data-ref="cityPicker" data-event-opts="{{[['^funcvalue',[['getpickerParentValue']]]]}}" bind:funcvalue="__e" bind:__l="__l"></gk-city><block tt:if="{{loading}}"><loading vue-id="574d0d67-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="574d0d67-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="574d0d67-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="574d0d67-6" bind:__l="__l"></wxxieyi></view>