<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+(shopset.order_detail_toppic?shopset.order_detail_toppic:pre_url+'/static/img/ordertop.png')+');background-size:100%')}}"><block tt:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block tt:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block tt:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block tt:if="{{detail.freight_type!=1}}"><view class="t2">请尽快发货</view></block><block tt:if="{{detail.freight_type==1}}"><view class="t2">待提货</view></block></view></block><block tt:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block tt:if="{{detail.freight_type!=3}}"><view class="t2">{{"发货信息："+detail.express_com+" "+detail.express_no}}</view></block></view></block><block tt:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block tt:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block><block tt:if="{{detail.status==8}}"><view class="f1"><view class="t1">订单已到达代收点</view></view></block></view><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><view class="t1"><text user-select="true" selectable="true">{{detail.linkman}}</text><block tt:if="{{detail.tel}}"><text style="margin-left:20rpx;" data-url="{{'tel:'+detail.tel}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{detail.tel}}</text></block></view><block tt:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block tt:if="{{detail.freight_type==1}}"><text class="t2" data-address="{{storeinfo.address}}" data-latitude="{{storeinfo.latitude}}" data-longitude="{{storeinfo.longitude}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address}}</text></block></view></view><view class="product"><block tt:for="{{prolist}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="box"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.ggname}}</text><block tt:if="{{item.product_type&&item.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item.real_total_weight+"斤"}}</text></view></block><block tt:else><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></block></view></view></view></block></view><block tt:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><block tt:if="{{detail.mid>0}}"><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view></block><block tt:if="{{detail.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2" user-select="true" selectable="true">{{detail.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block tt:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block tt:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block tt:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block tt:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m1+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block tt:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block tt:if="{{detail.invoice_money>0}}"><view class="item"><text class="t1">发票费用</text><text class="t2 red">{{"+¥"+detail.invoice_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block tt:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block tt:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block tt:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block tt:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><block tt:if="{{detail.dec_money>0}}"><view class="item"><text class="t1">{{$root.m4+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.dec_money}}</text></view></block><block tt:if="{{detail.discount_rand_money>0}}"><view class="item"><text class="t1">随机立减</text><text class="t2 red">{{"-¥"+detail.discount_rand_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block tt:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block tt:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block tt:if="{{detail.status==2}}"><text class="t2">已发货</text></block><block tt:if="{{detail.status==8}}"><text class="t2">待提货</text></block><block tt:if="{{detail.status==3}}"><text class="t2">已收货</text></block><block tt:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block tt:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block tt:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block tt:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason||'暂无'}}</text></view></block><block tt:if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block tt:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block tt:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block></view><block tt:if="{{detail.checkmemid}}"><view class="orderinfo"><view class="item"><text class="t1">所选会员</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.checkmember.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.checkmember.nickname}}</text></view></view></block><block tt:if="{{detail.formdata.length>0}}"><view class="orderinfo"><block tt:for="{{detail.formdata}}" tt:for-item="item" tt:for-index="__i0__" tt:key="*this"><view class="item"><text class="t1">{{item[0]}}</text><block tt:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view style="width:100%;height:160rpx;"></view><view class="bottom notabbarbot"><block tt:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundnopass',['$event']]]]]}}" bindtap="__e">退款驳回</view></block><block tt:if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundpass',['$event']]]]]}}" bindtap="__e">退款通过</view></block><block tt:if="{{detail.status==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['closeOrder',['$event']]]]]}}" bindtap="__e">关闭订单</view></block><block tt:if="{{detail.status==0&&detail.bid==0&&!detail.isdygroupbuy}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['ispay',['$event']]]]]}}" bindtap="__e">改为已支付</view></block><block tt:if="{{detail.status==1&&!detail.hidefahuo}}"><block><block tt:if="{{detail.product_type==2}}"><view class="btn2" data-url="{{'weightOrderFahuo?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发货</view></block></block></block><block tt:if="{{detail.status==2&&detail.freight_type==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['shouhuo',['$event']]]]]}}" bindtap="__e">收货</view></block><block tt:if="{{(detail.status==1||detail.status==2||detail.status==8)&&(detail.freight_type==1||detail.freight_type==5)}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" bindtap="__e">核销</view></block><block tt:if="{{detail.status==1&&detail.canpeisong}}"><block><block tt:if="{{detail.express_wx_status}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisongWx',['$event']]]]]}}" bindtap="__e">即时配送</view></block><block tt:else><block tt:if="{{detail.myt_status}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisongMyt',['$event']]]]]}}" bindtap="__e">麦芽田配送</view></block><block tt:else><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['peisong',['$event']]]]]}}" bindtap="__e">配送</view></block></block></block></block><block tt:if="{{(detail.status==2||detail.status==3)&&detail.express_com}}"><block><block tt:if="{{detail.express_type=='express_wx'}}"><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+detail.express_com+'&express_no='+detail.express_no+'&type=express_wx'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">订单跟踪</view></block><block tt:else><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+detail.express_com+'&express_no='+detail.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><block tt:if="{{detail.psid==-2}}"><text>订单跟踪</text></block><block tt:else><text>查物流</text></block></view></block></block></block><block tt:if="{{detail.status==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['changePrice',['$event']]]]]}}" bindtap="__e">改价</view></block><block tt:if="{{detail.status==2&&detail.freight_type==10}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['fahuo',['$event']]]]]}}" bindtap="__e">修改物流</view></block><block tt:if="{{detail.status==4}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" bindtap="__e">删除</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setremark',['$event']]]]]}}" bindtap="__e">设置备注</view></view><uni-popup class="vue-ref" vue-id="760c77dc-1" id="dialogSetremark" type="dialog" data-ref="dialogSetremark" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('760c77dc-2')+','+('760c77dc-1')}}" mode="input" title="设置备注" value="{{detail.remark}}" placeholder="请输入备注" data-event-opts="{{[['^confirm',[['setremarkconfirm']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup><uni-popup class="vue-ref" vue-id="760c77dc-3" id="dialogChangePrice" type="dialog" data-ref="dialogChangePrice" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('760c77dc-4')+','+('760c77dc-3')}}" mode="input" title="修改价格" value="{{detail.totalprice}}" placeholder="请输入价格" data-event-opts="{{[['^confirm',[['changePriceConfirm']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup><uni-popup class="vue-ref" vue-id="760c77dc-5" id="dialogExpress" type="dialog" data-ref="dialogExpress" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-ti