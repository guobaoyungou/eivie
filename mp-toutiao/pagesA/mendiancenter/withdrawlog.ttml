<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m0}}</text></view><view class="f3"><block tt:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block tt:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block tt:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block tt:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="d9729c3e-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="d9729c3e-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="d9729c3e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="d9729c3e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d9729c3e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>