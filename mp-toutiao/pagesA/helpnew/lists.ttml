<view><view class="content-view"><view class="banner-view"><image src="{{pic}}" mode="widthFix"></image></view><view class="bottom-view flex-col"><view class="search-view"><image class="search-image" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input type="text" placeholder="搜索问题相关关键词..." placeholder-style="font-size:28rpx;color: rgba(130, 130, 167, 0.8);" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" bindconfirm="__e"/></view><view class="list-view"><view class="shaixuan-view"><view data-event-opts="{{[['tap',[['changeSelect',['$event']]]]]}}" class="{{((selectType?'xial-view-active-no':'xial-view-active')+' '+'xial-view')}}" bindtap="__e"><image src="{{pre_url+'/static/img/xiangshang.png'}}"></image></view><scroll-view style="white-space:nowrap;width:90%;height:100%;margin-left:20rpx;" scroll-x="{{true}}"><view data-event-opts="{{[['tap',[['changeWenti',[0]]]]]}}" class="{{((cid==0?'wenti-title-active':'')+' '+'wenti-title')}}" bindtap="__e">全部问题</view><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index"><block><view data-event-opts="{{[['tap',[['changeWenti',['$0'],[[['clist','',index,'id']]]]]]]}}" class="{{((item.id==cid?'wenti-title-active':'')+' '+'wenti-title')}}" bindtap="__e">{{item.name}}</view></block></block></scroll-view><view class="{{((selectType?'search-view-active':'search-view-active-no')+' '+'select-view')}}"><scroll-view style="width:100%;padding:10rpx 20rpx;height:400rpx;" scroll-y="{{true}}"><block tt:for="{{cidlist}}" tt:for-item="item" tt:for-index="index"><block><view data-event-opts="{{[['tap',[['changeChild',['$0'],[[['cidlist','',index,'id']]]]]]]}}" class="{{((item.id==child_id?'select-view-wenti-active':'')+' '+'select-view-wenti')}}" bindtap="__e">{{item.name}}</view></block></block></scroll-view></view></view><view class="option-list-view"><scroll-view style="width:100%;height:60vh;padding-bottom:100rpx;" scroll-y="{{true}}"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index"><block><view class="list-option" data-url="{{'/pagesA/helpnew/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="list-text-view"><view class="text-view">{{item.name}}</view><block tt:if="{{item.is_hot==1}}"><view class="hot-view">热</view></block></view><view class="left-icon"><image src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="4c7a2f44-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="4c7a2f44-2" bind:__l="__l"></nomore></block></scroll-view></view></view></view></view></view>