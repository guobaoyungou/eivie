<block tt:if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank.png'}}" mode="widthFix"></image><view class="content"><view class="top"><view class="t1">{{"数据统计日期： "+region_ctime}}</view></view><view class="tabsort"><block tt:if="{{$root.m1}}"><view class="{{('t1 '+(1==sorttype?'on':''))}}" style="width:30%;" data-sorttype="{{1}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" bindtap="__e">订单金额<block tt:if="{{1==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m2)}}"></view></block></view></block><block tt:if="{{$root.m3}}"><view class="{{('t1 '+(2==sorttype?'on':''))}}" style="width:30%;" data-sorttype="{{2}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" bindtap="__e">订单数量<block tt:if="{{2==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m4)}}"></view></block></view></block></view><view class="tab1"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('t1 '+(index==ranktype?'on':''))}}" style="{{'color:'+(index==ranktype?item.m5:'')+';'}}" data-ranktype="{{index}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" bindtap="__e">{{''+item.$orig+''}}<block tt:if="{{index==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m6)}}"></view></block></view></block></block></view><view class="tab"><view class="t1">排名</view><view class="t2">{{ranktype==3?'用户':'区域名'}}</view><block tt:if="{{sorttype==1}}"><view class="t3" style="{{'color:'+($root.m7)+';'}}">订单金额</view></block><block tt:if="{{sorttype==2}}"><view class="t3" style="{{'color:'+($root.m8)+';'}}">订单数量</view></block></view><view class="itembox"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><block tt:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block tt:else><view class="t1">{{index+1}}</view></block><block tt:if="{{ranktype==3}}"><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></block><block tt:else><view class="t2"><text style="margin-left:32rpx;"></text>{{''+item.title}}</view></block><block tt:if="{{sorttype==1}}"><text class="t3">{{''+item.totalprice}}</text></block><block tt:if="{{sorttype==2}}"><text class="t3">{{''+item.num}}</text></block></view></block></block></view></view></view><block tt:if="{{nodata}}"><nodata vue-id="77583064-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="77583064-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="77583064-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="77583064-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="77583064-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block></block>