<view><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的证书" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/><button data-event-opts="{{[['tap',[['searchConfirm',['$event']]]]]}}" class="search-btn" bindtap="__e">搜索</button></view></view><block tt:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="list"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['viewDetail',['$event']]]]]}}" bindtap="__e"><view class="info"><view class="p1">{{"证书名称："+item.cname}}</view><view class="p1 flex"><view class="row-l">{{"联  系 人："+item.name}}</view><view class="row-r">{{"联系方式："+item.tel}}</view></view></view></view></block></view></view></block><block tt:if="{{nodata}}"><nodata vue-id="7dc6484f-1" bind:__l="__l"></nodata></block></block></block></view>