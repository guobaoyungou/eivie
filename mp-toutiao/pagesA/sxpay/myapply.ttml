<view class="body"><block tt:if="{{isload}}"><block><view class="header" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}">随行付入驻记录</view><view class="container"><block><view class="box"><view class="form-title">主体类型</view><view class="form-item"><radio-group class="flex-sb" style="width:100%;padding:0 50rpx;" name="subject_type" data-field="subject_type" data-event-opts="{{[['change',[['itemChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{form.subject_type=='SUBJECT_TYPE_INDIVIDUAL'}}"><label><radio style="transform:scale(0.8);" value="SUBJECT_TYPE_INDIVIDUAL" checked="{{form.subject_type=='SUBJECT_TYPE_INDIVIDUAL'?true:false}}" disabled="{{true}}"></radio>个体户</label></block><block tt:if="{{form.subject_type=='SUBJECT_TYPE_ENTERPRISE'}}"><label><radio style="transform:scale(0.8);" value="SUBJECT_TYPE_ENTERPRISE" checked="{{form.subject_type=='SUBJECT_TYPE_ENTERPRISE'?true:false}}" disabled="{{true}}"></radio>企业</label></block><block tt:if="{{form.subject_type=='SUBJECT_TYPE_MICRO'}}"><label><radio style="transform:scale(0.8);" value="SUBJECT_TYPE_MICRO" checked="{{form.subject_type=='SUBJECT_TYPE_MICRO'?true:false}}" disabled="{{true}}"></radio>个人</label></block></radio-group></view></view><block tt:if="{{form.subject_type!='SUBJECT_TYPE_MICRO'}}"><view class="box"><view class="form-title">营业执照信息</view><view class="form-item"><view class="form-label">营业执照照片</view><view class="form-value form-upload"><block tt:if="{{form.business_license_copy}}"><view class="imgitem"><image src="{{form.business_license_copy}}" data-url="{{form.business_license_copy}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view><view class="form-item"><view class="form-label">统一社会信用代码</view><view class="form-value">{{''+form.business_license_number+''}}</view></view><view class="form-item"><view class="form-label">企业名称</view><view class="form-value">{{''+form.business_merchant_name+''}}</view></view><view class="form-item"><view class="form-label">经营者/法人姓名</view><view class="form-value">{{''+form.business_legal_person+''}}</view></view></view></block><view class="box"><view class="form-title">经营者/法人身份证</view><view class="form-item"><view class="form-label">身份证人像面</view><view class="form-value form-upload"><block tt:if="{{form.identity_id_card_copy}}"><view class="imgitem"><image src="{{form.identity_id_card_copy}}" data-url="{{form.identity_id_card_copy}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view><view class="form-item"><view class="form-label">身份证国徽面</view><view class="form-value form-upload"><block tt:if="{{form.identity_id_card_national}}"><view class="imgitem"><image src="{{form.identity_id_card_national}}" data-url="{{form.identity_id_card_national}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view><view class="form-item"><view class="form-label">身份证姓名</view><view class="form-value">{{''+form.identity_id_card_name+''}}</view></view><view class="form-item"><view class="form-label">身份证号码</view><view class="form-value">{{''+form.identity_id_card_number+''}}</view></view><view class="form-item"><view class="form-label">身份证有效期</view><view class="form-value"><block tt:if="{{form.identity_id_card_valid_time_cq.length>0}}"><text></text></block><block tt:else><text>{{form.identity_id_card_valid_time1+" ~ "+form.identity_id_card_valid_time2}}</text></block></view></view><view class="form-item"><view class="form-label">联系人手机号</view><view class="form-value">{{''+form.contact_mobile+''}}</view></view><view class="form-item"><view class="form-label">联系人邮箱</view><view class="form-value">{{''+form.contact_email+''}}</view></view></view><view class="box"><view class="form-title">经营资料</view><view class="form-item"><view class="form-label">商户简称</view><view class="form-value">{{''+form.merchant_shortname+''}}</view></view><view class="form-item"><view class="form-label">客服电话</view><view class="form-value">{{''+form.service_phone+''}}</view></view><view class="form-item"><view class="form-label">经营类目</view><view class="form-value">{{''+category_name+''}}</view></view><view class="form-item"><view class="form-label">经营地区</view><view class="form-value">{{''+$root.g0+''}}</view></view><view class="form-item"><view class="form-label">经营详细地址</view><view class="form-value">{{''+form.store_street+''}}</view></view><view class="form-item"><view class="form-label">门头照</view><view class="form-value form-upload"><block tt:if="{{form.store_entrance_pic}}"><view class="imgitem"><image src="{{form.store_entrance_pic}}" data-url="{{form.store_entrance_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view><view class="form-item"><view class="form-label">内景照</view><view class="form-value form-upload"><block tt:if="{{form.indoor_pic}}"><view class="imgitem"><image src="{{form.indoor_pic}}" data-url="{{form.indoor_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view><view class="form-item"><view class="form-label">其他资料照片</view><view class="form-value form-upload"><view class="imgbox"><block tt:for="{{store_other_pics}}" tt:for-item="pic" tt:for-index="pindex"><block tt:if="{{store_other_pics.length>0}}"><block><view class="imgitem-pics"><image src="{{pic}}" data-url="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></block></block></view></view></view></view><view class="box"><view class="form-title">结算银行账户</view><view class="form-item"><view class="form-label">账户类型</view><view class="form-value"><block tt:if="{{form.jiesuan_bank_account_type=='BANK_ACCOUNT_TYPE_CORPORATE'}}"><text>对公银行账户</text></block><block tt:if="{{form.jiesuan_bank_account_type=='BANK_ACCOUNT_TYPE_PERSONAL'}}"><text>个人银行账户</text></block></view></view><block tt:if="{{form.jiesuan_bank_account_type=='BANK_ACCOUNT_TYPE_CORPORATE'}}"><view class="form-item"><view class="form-label">开户许可证</view><view class="form-value form-upload"><block tt:if="{{form.account_license_pic}}"><view class="imgitem"><image src="{{form.account_license_pic}}" data-url="{{form.account_license_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view></block><block tt:if="{{form.jiesuan_bank_account_type=='BANK_ACCOUNT_TYPE_PERSONAL'}}"><view class="form-item"><view class="form-label">银行卡卡号面</view><view class="form-value form-upload"><block tt:if="{{form.bank_card_pic}}"><view class="imgitem"><image src="{{form.bank_card_pic}}" data-url="{{form.bank_card_pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></view></block><view class="form-item"><view class="form-label">开户名称/持卡人姓名</view><view class="form-value">{{''+form.jiesuan_account_name+''}}</view></view><view class="form-item"><view class="form-label">开户银行</view><view class="form-value">{{''+form.jiesuan_account_bank+''}}</view></view><view class="form-item"><view class="form-label">开户银行地区</view><view class="form-value">{{''+$root.g1+''}}</view></view><view class="form-item"><view class="form-label">所属分支行</view><view data-event-opts="{{[['tap',[['showModal',['branch_bank']]]]]}}" class="form-value" bindtap="__e">{{''+form.jiesuan_bank_name+''}}</view></view><view class="form-item"><view class="form-label">银行账号</view><view class="form-value">{{''+form.jiesuan_account_number+''}}</view></view><view class="form-item"><view class="form-label">结算费率</view><view class="form-value"><text>{{set.feepercent}}</text></view></view><view class="form-item"><view class="form-label">结算时间</view><view class="form-value"><text>{{set.duration}}</text></view></view></view><view class="box box-tips"><view class="form-title">入驻审核</view><view class="form-item"><view class="form-label">状态</view><view class="form-value"><block tt:if="{{form.taskStatusTxt}}"><view class="st_tag">{{form.taskStatusTxt}}</view></block><block tt:if="{{form.suggestion}}"><view class="st_tips">{{form.suggestion}}</view></block></view></view><view class="form-item"><view class="form-label">修改状态</view><view class="form-value"><block tt:if="{{form.taskStatus_edit_txt}}"><view class="st_tag">{{form.taskStatus_edit_txt}}</view></block><block tt:if="{{form.suggestion_edit}}"><view class="st_tips">{{form.suggestion_edit}}</view></block></view></view><view class="form-item"><view class="form-label">复核状态</view><view class="form-value"><block tt:if="{{form.suggestion2Txt}}"><view class="st_tag">{{form.suggestion2Txt}}</view></block><block tt:if="{{form.suggestion2}}"><view class="st_tips">{{form.suggestion2}}</view></block></view></view></view></block><view class="form-opt"><block tt:if="{{form.taskStatus=='0'||form.taskStatus=='1'}}"><button class="btn btn0">{{form.taskStatus==0?'审核中':'已提交'}}</button></block><block tt:if="{{form.taskStatus=='-1'||form.taskStatus=='2'}}"><button class="btn" style="{{'background:'+($root.m2)+';'}}" data-url="{{'apply?id='+form.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">修改</button></block></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="4c16025a-1" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="4c16025a-2" data-ref="popmsg" bind:__l="__l"></popmsg></view>