<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{show_rebate}}"><view class="container-top"><view class="top-content"><text class="t1">{{"еҫ…иҝ”"+$root.m0+"пјҡ"+info.un_send_money+''}}</text><text class="t1">{{"е·Іиҝ”"+$root.m1+"пјҡ"+info.send_money+''}}</text></view><view class="top-content"><text class="t1">{{"еҫ…иҝ”"+$root.m2+"пјҡ"+info.un_send_commission+''}}</text><text class="t1">{{"е·Іиҝ”"+$root.m3+"пјҡ"+info.send_commission+''}}</text></view><view class="top-content"><text class="t1">{{"еҫ…иҝ”"+$root.m4+"пјҡ"+info.un_send_score+''}}</text><text class="t1">{{"е·Іиҝ”"+$root.m5+"пјҡ"+info.send_score+''}}</text></view></view></block><dd-tab class="{{(show_rebate?'container-tab':'')}}" vue-id="79da06b4-1" itemdata="{{['е…ЁйғЁ','иҝӣиЎҢдёӯ','е·Із»“жқҹ']}}" itemst="{{['all','1','2']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="{{(show_rebate?'height:260rpx;width:100%;':'height:100rpx;width:100%;')}}"></view><view class="order-content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box" data-url="{{'recordlog?cashback_id='+item.cashback_id+'&pro_id='+item.pro_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image><view class="head-title">{{"жҙ»еҠЁеҗҚз§°пјҡ"+item.name}}</view></view><text class="st0">{{item.status}}</text></view><view class="content flex-col"><block tt:if="{{item.cashback_money_max>0}}"><view class="flex-y-center option-content">{{"йўқеәҰ:"+item.cashback_money_max}}</view></block><block tt:else><view class="flex-y-center option-content">йўқеәҰпјҡдёҚйҷҗ</view></block><view class="flex-y-center option-content">{{"е·Іиҝ”"+item.back_type_name+"пјҡ"+item.cashback_num}}</view><view class="flex-y-center option-content"><view class="progress-box"><progress percent="{{item.progress}}" show-info="{{true}}" stroke-width="5" activeColor="#ff8758" border-radius="50"></progress></view></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="79da06b4-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="79da06b4-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="79da06b4-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="79da06b4-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="79da06b4-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>