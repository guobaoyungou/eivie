<view><block tt:if="{{isload}}"><block><view class="container" style="{{'background-color:'+(set.bgcolor)+';'}}"><view class="banner"><view class="swiper"><image src="{{set.banner}}" mode="widthFix" background-size="cover"></image></view><view class="datalist"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="collage-product" data-url="{{'product?id='+item.$orig.pro_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><text class="mark">{{"第"+item.$orig.cycles+"轮"}}</text><image src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.name}}</view><view class="p2" style="padding-top:20rpx;"><progress percent="{{item.$orig.percent}}" stroke-width="6" border-radius="10" activeColor="#fb743b"></progress></view><view class="p2"><view class="p2-1">{{'总需'+item.$orig.score_total+item.$orig.wallet_name+'，还剩余'}}<text class="t1" style="{{'color:'+($root.m0)+';'}}">{{item.$orig.remain}}</text>{{''+item.$orig.wallet_name+''}}</view></view><view class="p3"><view class="t1">市场价￥<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.$orig.market_price}}</text></view><block tt:if="{{item.$orig.can_join==1}}"><view data-event-opts="{{[['tap',[['buydialogShow',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="t2" style="{{'border-color:'+(item.m1)+';'+('color:'+(item.m2)+';')}}" bindtap="__e"><text class="x2" style="{{'background-color:'+(item.m3)+';'}}">去参与</text></view></block><block tt:if="{{item.$orig.can_join==0}}"><view class="t2" style="{{'border-color:'+('gray')+';'+('color:'+(item.m4)+';')}}"><text class="x2" style="background:gray;">去参与</text></view></block></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="15f27d5d-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="15f27d5d-2" bind:__l="__l"></nodata></block></view><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" bindtap="__e">活动规则</button><button class="coverrecord" data-url="myprize" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">开奖记录</button><button class="covermy">{{"我的"+$root.m5+member.score}}</button><block tt:if="{{product_givetongzheng==1}}"><button class="covermy2">{{"我的"+$root.m6+member.tongzheng}}</button></block><block tt:if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{set.guize}}</text></view></view></view></view></block><view hidden="{{buydialogHidden}}"><view class="buydialog-mask"><view class="{{(('buydialog')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title"><image class="img" src="{{detail.pic}}" data-url="{{detail.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="price">{{"消耗"+select_wallet}}<text class="t1">￥</text>{{pay_score}}</view><view class="stock">每注<text class="t1" style="color:red;">{{"￥"+detail.usescore}}</text>{{select_wallet}}</view><view class="choosename">{{detail.name}}</view><view class="stock">{{"最高可投"+detail.join_max_num+"注"}}</view></view><view class="buynum flex flex-y-center"><view class="flex1">投注数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><view class="op"><button class="tobuy" style="{{'background:'+($root.m7)+';'}}" data-type="1" data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" bindtap="__e">确定</button></view></view></view></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="15f27d5d-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="15f27d5d-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="15f27d5d-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>