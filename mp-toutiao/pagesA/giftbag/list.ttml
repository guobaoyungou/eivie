<view><block tt:if="{{isload}}"><block><view class="container"><view class="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="collage-product" data-url="{{'detail?id='+item.id+'&gbid='+gbid+'&bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3" style="position:relative;bottom:0;"><text class="t1" style="{{'color:'+($root.m0)+';'+('font-size:'+('28rpx')+';')}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')+('position:'+('absolute')+';')+('right:'+('0')+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">详情</text></view></view><block tt:if="{{item.shortdesc}}"><view class="p1" style="margin-top:10rpx;">{{item.shortdesc}}</view></block></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="ecb37748-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="ecb37748-2" bind:__l="__l"></nodata></block></view><view class="notabbarbot" style="width:100%;height:110rpx;box-sizing:content-box;"></view><view class="{{((('bottombar')+' '+'flex-row')+' '+(menuindex>-1?'tabbarbot':'notabbarbot'))}}"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m4)+';'+('margin:'+('0 auto')+';')}}" bindtap="__e"><text>立即领取</text></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="ecb37748-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="ecb37748-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="ecb37748-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>