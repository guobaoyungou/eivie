<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="28840714-1" itemdata="{{['全部','待付款','待核销','已核销']}}" itemst="{{['all','0','1','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><text class="flex1">{{"订单号："+item.$orig.ordernum}}</text><block tt:if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block tt:if="{{item.$orig.status==1}}"><text class="st1">待核销</text></block><block tt:if="{{item.$orig.status==3}}"><text class="st3">已核销</text></block><block tt:if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><view class="head" style="color:#000;" data-url="{{'list?gbid='+item.$orig.gbid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><text class="flex1">{{"礼包："+item.$orig.proname}}</text></view><block tt:for="{{item.$orig.prolist}}" tt:for-item="item2" tt:for-index="idx" tt:key="idx"><block><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view style="width:100%;display:flex;"><view data-url="{{'detail?id='+item2.proid+'&gbid='+item.$orig.gbid+'&bid='+item2.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item2.sell_price}}</text><text class="x2">{{"×"+item2.num}}</text></view></view></view><block tt:if="{{(item.$orig.status==1||item.$orig.status==2)&&item2.hexiao_code}}"><block><view style="width:100%;position:relative;"><view class="btn2" style="position:absolute;bottom:0;right:0;" data-id="{{item2.id}}" data-num="{{item2.num}}" data-hxnum="{{item2.hexiao_num}}" data-hexiao_code="{{item2.hexiao_code}}" data-event-opts="{{[['tap',[['showhxqr2',['$event']]]]]}}" catchtap="__e">核销码</view></view></block></block><block tt:if="{{item.$orig.status==3&&!item2.hexiao_code}}"><block><view style="width:100%;position:relative;"><view class="btn2" style="position:absolute;bottom:0;right:0;border:0;">已核销</view></view></block></block></view></block></block><view class="bottom"><text>{{"共计"+item.$orig.totalnum+"件 实付:￥"+item.$orig.totalprice}}</text><block tt:if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block tt:if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block tt:if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block tt:if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去付款</view></block></block><block tt:if="{{(item.$orig.status==1||item.$orig.status==2)&&item.$orig.hexiao_qr}}"><block><view class="btn2" data-hexiao_qr="{{item.$orig.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" catchtap="__e">核销码</view></block></block><block tt:if="{{item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchtap="__e">删除订单</view></block></block></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="28840714-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="28840714-3" bind:__l="__l"></nodata></block></block></block><uni-popup class="vue-ref" vue-id="28840714-4" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" bind:__l="__l" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block tt:if="{{loading}}"><loading vue-id="28840714-5" bind:__l="__l"></loading></block><dp-tabbar vue-id="28840714-6" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="28840714-7" data-ref="popmsg" bind:__l="__l"></popmsg></view>