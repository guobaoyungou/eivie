<view class="container"><block tt:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="orderinfo"><view class="item"><text class="t1">支付宝</text><text class="t2">{{detail.aliaccountname}}</text></view><view class="item"><text class="t1">支付宝账号</text><text class="t2">{{detail.aliaccount}}</text></view><view class="item"><text class="t1">开户行</text><text class="t2">{{detail.bankname}}</text></view><view class="item"><text class="t1">所属支行</text><text class="t2">{{detail.bankaddress}}</text></view><view class="item"><text class="t1">持卡人</text><text class="t2">{{detail.bankcarduser}}</text></view><view class="item"><text class="t1">银行卡</text><text class="t2">{{detail.bankcardnum}}</text></view></view><view class="form-content"><view class="form-item flex-col"><view class="label"><block tt:if="{{detail.mid==detail.nowmid&&detail.status==0}}"><text>上传付款凭证(最多三张)</text></block><block tt:else><text>付款凭证</text></block></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><block tt:for="{{pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><block tt:if="{{detail.status==0}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pics.length<3&&detail.status==0&&detail.mid==detail.nowmid}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view></view></view><block tt:if="{{detail.status==3}}"><block><view class="orderinfo"><view class="item"><text class="t1">异议内容</text><text class="t2">{{detail.objection_content}}</text></view></view><view class="form-content"><view class="form-item flex-col"><view class="label"><text>异议图片</text></view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><block tt:for="{{detail.objection_pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></view></block></block><block tt:if="{{detail.status==0&&detail.mid==detail.nowmid}}"><button class="btn" style="{{'background:'+($root.m0)+';'}}" form-type="submit">提交</button></block><block tt:if="{{detail.status==1&&detail.tomid==detail.nowmid}}"><button class="btn" style="{{'background:'+($root.m1)+';'}}" data-url="{{'objection?id='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提交异议</button></block><block tt:if="{{(detail.status==1||detail.status==3)&&detail.tomid==detail.nowmid}}"><button data-event-opts="{{[['tap',[['toCollect',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m2)+';'}}" bindtap="__e">确定收款</button></block><view style="padding-top:30rpx;"></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="02a7f6df-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="02a7f6df-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="02a7f6df-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>