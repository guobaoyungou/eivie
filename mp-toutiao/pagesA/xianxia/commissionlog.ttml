<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="42a05ecd-1" itemdata="{{['待打款','待确定','完成','异议']}}" itemst="{{['0','1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><block tt:if="{{datalist&&datalist.length>0}}"><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="title" style="line-height:40rpx;">奖励发放</view><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" bindtap="__e"><image src="{{item.$orig.headimg}}"></image><view class="t2" style="flex:1;"><text class="x1">{{item.$orig.nickname+"(ID:"+item.$orig.tomid+")"}}</text><text class="x1">{{"等      级："+item.$orig.levelname}}</text><block tt:if="{{item.$orig.tel}}"><text class="x1">{{"手  机 号："+item.$orig.tel}}</text></block><text class="x1">{{"产生时间："+item.$orig.createtime}}</text></view><view class="t2" style="{{('color:'+$root.m0)}}">{{"发放金额："+item.$orig.commission}}</view></view><view class="f2"><view class="t1">{{item.$orig.remark}}</view><block tt:if="{{item.$orig.status==0}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m1+' 0%,rgba('+item.m2+',0.8) 100%)')+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" bindtap="__e">发放奖励</button></block><block tt:if="{{item.$orig.status==1}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m3+' 0%,rgba('+item.m4+',0.8) 100%)')+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" bindtap="__e">查看详情</button></block></view></view></block></block></view></block><block tt:if="{{nomore}}"><nomore vue-id="42a05ecd-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="42a05ecd-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{showsend}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><block tt:if="{{loading}}"><loading vue-id="42a05ecd-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="42a05ecd-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="42a05ecd-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>