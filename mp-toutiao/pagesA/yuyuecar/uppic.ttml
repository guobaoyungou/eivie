<view class="container"><block tt:if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="form-content"><view class="form-item flex-col"><view class="label">上传图片(最少四张)</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><block tt:for="{{pics}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:if="{{pics.length<6}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m0)+';'}}" bindtap="__e">确定</button><view style="padding-top:30rpx;"></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="2eb6488a-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="2eb6488a-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="2eb6488a-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>