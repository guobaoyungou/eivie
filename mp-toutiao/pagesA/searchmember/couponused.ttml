<view class="container"><block tt:if="{{isload}}"><block><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="content flex" data-id="{{item.$orig.id}}"><view data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" class="item" bindtap="__e"><view class="f1"><view class="name">{{"次卡名称："+item.$orig.couponname}}</view><view class="f2"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{"使用时间："+item.m0}}</text></view></view></view></view></block><block tt:if="{{nodata}}"><nodata vue-id="b2c446ce-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="b2c446ce-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="b2c446ce-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="b2c446ce-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b2c446ce-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>