<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block tt:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view></view></block><block tt:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block tt:if="{{detail.freight_type!=1}}"><view class="t2">我们会尽快为您发货</view></block><block tt:if="{{detail.freight_type==1}}"><view class="t2">请尽快前往自提地点取货</view></block></view></block><block tt:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><text class="t2" user-select="true" selectable="true">{{"发货信息："+detail.express_com+" "+detail.express_no}}</text></view></block><block tt:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block tt:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><text class="t1" user-select="true" selectable="true">{{detail.linkman+" "+detail.tel}}</text><block tt:if="{{detail.freight_type!=1}}"><text class="t2" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block tt:if="{{detail.freight_type==1}}"><text class="t2" data-storeinfo="{{storeinfo}}" data-latitude="{{storeinfo.latitude}}" data-longitude="{{storeinfo.longitude}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" bindtap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address}}</text></block></view></view><block tt:for="{{prolist}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="product"><view class="content"><view data-url="{{'product?id='+item.gg_proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.gg_proname}}</text><view class="t2 flex flex-y-center flex-bt"><text>{{item.ggname}}</text><block tt:if="{{detail.status==3&&item.iscomment==0&&shopset.comment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去评价</view></block><block tt:if="{{detail.status==3&&item.iscomment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看评价</view></block></view><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></view></view></view></block><block tt:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><view class="flex-bt order-info-title"><text class="t1" style="color:#111;">发货信息</text><view class="btn-class" data-text="{{detail.freight_content}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" bindtap="__e">复制</view></view><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item flex-bt"><text class="t1">订单编号</text><view class="ordernum-info flex-bt"><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text><view class="btn-class" style="margin-left:20rpx;" data-text="{{detail.ordernum}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" bindtap="__e">复制</view></view></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block tt:if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block tt:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block tt:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block tt:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block tt:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block tt:if="{{detail.scoredk_money>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block tt:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block tt:if="{{detail.status==1}}"><block><block tt:if="{{detail.freight_type!=1}}"><text class="t2">待发货</text></block><block tt:if="{{detail.freight_type==1}}"><text class="t2">待提货</text></block></block></block><block tt:if="{{detail.status==2}}"><text class="t2">已发货</text></block><block tt:if="{{detail.status==3}}"><text class="t2">已收货</text></block><block tt:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block tt:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block tt:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block></view><block tt:if="{{detail.formdata.length>0}}"><view class="orderinfo"><block tt:for="{{detail.formdata}}" tt:for-item="item" tt:for-index="__i0__" tt:key="*this"><view class="item"><text class="t1">{{item[0]}}</text><block tt:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><block tt:if="{{detail.status!=3}}"><view class="bottom notabbarbot"><block tt:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" bindtap="__e">关闭订单</view><view class="btn1" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block></block><block tt:if="{{detail.status==1}}"><block><block tt:if="{{(detail.refund_status==0||detail.refund_status==3)&&shopset.refund==1}}"><view class="btn2" data-url="{{'refund?orderid='+detail.id+'&price='+detail.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">申请退款</view></block></block></block><block tt:if="{{detail.status==2||detail.status==3}}"><block><block tt:if="{{detail.freight_type!=3&&detail.freight_type!=4}}"><view class="btn2" data-url="{{'/pagesExt/order/logistics?express_com='+detail.express_com+'&express_no='+detail.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看物流</view></block></block></block><block tt:if="{{detail.status==2}}"><block><block tt:if="{{(detail.refund_status==0||detail.refund_status==3)&&shopset.refund==1}}"><view class="btn2" data-url="{{'refund?orderid='+detail.id+'&price='+detail.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">申请退款</view></block><view class="btn1" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" bindtap="__e">确认收货</view></block></block><block tt:if="{{$root.g0}}"><block></block></block><block tt:if="{{detail.buytype==1&&(detail.status==1||detail.status==2)&&detail.freight_type==1}}"><block><view data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" class="btn2" bindtap="__e">核销码</view></block></block><block tt:if="{{detail.status==3}}"><block><view class="btn2">已完成</view></block></block><block tt:if="{{detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除订单</view></block></block></view></block><uni-popup class="vue-ref" vue-id="4cbd9e1a-1" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" bind:__l="__l" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block><block tt:if="{{loading}}"><loading vue-id="4cbd9e1a-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="4cbd9e1a-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4cbd9e1a-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>