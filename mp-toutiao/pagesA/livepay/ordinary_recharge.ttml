<view><view class="top-view" style="{{'background-color:'+($root.m0)+';'}}"><view class="title-view flex-y-center flex-bt"><view class="title-left-view flex-y-center"><view class="title-left-icon flex-xy-center"><image src="{{typeData.imgurl}}"></image></view>{{typeData.text}}</view><view class="title-right-view flex-y-center"><uni-data-picker class="dp-header-picker" vue-id="aedafa90-1" localdata="{{arealist}}" popup-title="地区" placeholder="地区" data-event-opts="{{[['^change',[['areachange']]]]}}" bind:change="__e" bind:__l="__l" vue-slots="{{['default']}}"><view>{{locationCache.address?locationCache.address:'请选择定位'}}</view></uni-data-picker><image src="{{pre_url+'/static/img/hdsanjiao.png'}}"></image></view></view></view><view class="content-view"><view class="price-view flex-col"><view class="options-view flex-bt"><view class="options-title">缴费单位</view><block tt:if="{{!is_open}}"><view class="input-view" style="width:66%;"><picker style="width:115%;" value="{{pickerIndex}}" range="{{array}}" range-key="name" data-event-opts="{{[['change',[['bindPickerChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{array[pickerIndex].name}}</view></picker></view></block><block tt:else><view class="input-view"><view class="not-supported ">当前城市暂不支持</view></view></block><view class="icon-view flex-y-center" style="width:10rpx;"><block tt:if="{{!is_open}}"><image src="{{pre_url+'/static/img/goback.jpg'}}"></image></block></view></view><view class="options-view flex-bt"><view class="options-title">姓名</view><view class="input-view"><input class="uni-input" type="text" adjust-position="{{false}}" placeholder="请输入姓名" disabled="{{is_open}}" data-event-opts="{{[['input',[['__set_model',['','recharge_name','$event',[]]]]]]}}" value="{{recharge_name}}" bindinput="__e"/></view><view class="icon-view" style="font-size:24rpx;color:#6489fc;"></view></view><view class="options-view flex-bt"><view class="options-title">户号</view><view class="input-view"><input class="uni-input" type="number" adjust-position="{{false}}" placeholder="请输入户号" disabled="{{is_open}}" data-event-opts="{{[['input',[['__set_model',['','account_number','$event',[]]]]]]}}" value="{{account_number}}" bindinput="__e"/></view><view data-event-opts="{{[['tap',[['obtainaCcount',['$event']]]]]}}" class="icon-view" style="{{'color:'+($root.m1)+';'+('font-szie:'+('24rpx')+';')}}" bindtap="__e">获取户号</view></view><block tt:if="{{pageInfo.is_other_amount}}"><view class="options-view flex-bt"><view class="options-title">缴费金额</view><view class="input-view" style="width:61%;"><input class="uni-input" type="number" adjust-position="{{false}}" disabled="{{is_open}}" placeholder="{{jiaofeiplace}}" data-event-opts="{{[['input',[['__set_model',['','payment_amount','$event',[]]],['paymentInput',['$event']]]]]}}" value="{{payment_amount}}" bindinput="__e"/></view><view class="icon-view" style="width:50rpx;"></view></view></block><view class="fixed-money-view"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index"><block><view data-event-opts="{{[['tap',[['optionChange',['$0',index],[[['pageInfo.fixed_amount','',index]]]]]]]}}" class="options-view-s flex-col" style="{{'border-color:'+(index==optionIndex?item.m2:'')+';'}}" bindtap="__e"><view class="options-title" style="{{'color:'+(index==optionIndex?item.m3:'')+';'}}">{{item.$orig.money}}<text style="font-size:34rpx;margin-left:5rpx;">元</text></view><block tt:if="{{item.g0>0}}"><view class="preferential-price" style="{{'color:'+(index==optionIndex?item.m4:'')+';'}}">{{"优惠价 "+item.m5}}</view></block></view></block></block></view><button class="btn-class" style="{{'background-color:'+($root.m6)+';'}}" hover-class="btn-hover-class" disabled="{{is_open}}" data-event-opts="{{[['tap',[['nextChange']]]]}}" bindtap="__e">下一步</button></view><block tt:if="{{pageInfo.pay_des}}"><view class="recharge-text-view"><view class="recharge-title">充值说明</view><view style="width:100%;"><parse vue-id="aedafa90-2" content="{{pageInfo.pay_des}}" bind:__l="__l"></parse></view></view></block><block tt:if="{{pageInfo.pay_agreement}}"><view class="recharge-text-view"><view class="recharge-title">充值协议</view><view style="width:100%;"><parse vue-id="aedafa90-3" content="{{pageInfo.pay_agreement}}" bind:__l="__l"></parse></view></view></block></view><uni-popup class="vue-ref" vue-id="aedafa90-4" type="bottom" safe-area="{{false}}" data-ref="popup" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-class" style="{{'height:'+(menuindex>-1?'calc(550rpx +  env(safe-area-inset-bottom))':'500rpx')+';'}}"><view data-event-opts="{{[['tap',[['popupChangeClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="popup-title-view">{{pageInfo.type_name+"充值"}}</view><view class="popup-price-view flex-col"><view class="price-num flex-y-center"><text style="font-weight:bold;font-size:40rpx;">￥</text>{{''+$root.m7+''}}<block tt:if="{{$root.g1>0}}"><view class="price-num-tips" style="margin-top:5rpx;font-weight:normal;margin-left:15rpx;">{{'优惠：-'+$root.g2+''}}</view></block></view><view class="price-num-tips">{{pageInfo.type_name+"充值"+payment_amount+"元"}}</view></view><button class="btn-class" style="{{'background-color:'+($root.m8)+';'}}" hover-class="btn-hover-class" disabled="{{is_open}}" data-event-opts="{{[['tap',[['topay']]]]}}" bindtap="__e">确认付款</button></view></uni-popup><uni-popup class="vue-ref" vue-id="aedafa90-5" type="bottom" safe-area="{{false}}" data-ref="popupobtaina" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-class" style="{{'height:'+(menuindex>-1?'calc(530rpx +  env(safe-area-inset-bottom))':'480rpx')+';'}}"><view data-event-opts="{{[['tap',[['popupChangeClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="popup-title-view">快速获取户号</view><view class="quick-access"><view class="quick-access-title">1.查看缴费通知单</view><view class="quick-access-text">在纸质缴费/催费单上查户号</view></view><view class="quick-access"><view class="quick-access-title">2.查询通知短信</view><view class="quick-access-text">搜索由缴费单位发送的催费短信，短信中包含户号</view></view><view class="quick-access"><view class="quick-access-title">3.第三方平台查询账单</view><view class="quick-access-text">通过微信、支付宝、京东、抖音等平台查询账单金额</view></view></view></uni-popup><block tt:if="{{loading}}"><loading vue-id="aedafa90-6" bind:__l="__l"></loading></block><dp-tabbar vue-id="aedafa90-7" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar></view>