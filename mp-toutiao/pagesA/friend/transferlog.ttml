<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="4a7491ae-1" itemdata="{{[$root.m0+'明细',$root.m1+'明细']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.title}}</text><text class="t2">{{item.$orig.createtime}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block tt:if="{{item.$orig.num>0}}"><text class="t1" style="{{'color:'+(item.m2)+';'}}">{{"+"+item.$orig.num}}</text></block><block tt:else><text class="t2">{{item.$orig.num}}</text></block></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="4a7491ae-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="4a7491ae-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="4a7491ae-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="4a7491ae-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="4a7491ae-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>