<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center" style="{{'background:'+($root.m0)+';'}}"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="listbox"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="tr listitem"><view class="info flex" data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view><view class="title">{{"活动名称："+item.$orig.title}}</view><view class="td td2">{{"参加时间："+item.$orig.createtime}}</view><block tt:if="{{item.$orig.totalprice>0}}"><view class="td td2">{{"报名支付：￥"+item.$orig.totalprice}}</view></block><block tt:if="{{item.$orig.is_done}}"><view class="td td2">中奖奖品：<block tt:if="{{item.$orig.jxid>0}}"><text style="{{'color:'+(item.m1)+';'}}">{{item.$orig.jxmc}}</text></block><block tt:if="{{item.$orig.jxid==0}}"><text>未中奖</text></block></view></block><block tt:else><view>待开奖</view></block></view><view class="opt"><text data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看</text></view></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="35729c73-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="35729c73-2" bind:__l="__l"></nodata></block><view class="myrecord" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">首页</view></block></block><block tt:if="{{loading}}"><loading vue-id="35729c73-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="35729c73-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="35729c73-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>