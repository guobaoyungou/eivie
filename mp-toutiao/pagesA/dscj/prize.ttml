<view class="container" style="min-height:100vh;"><block tt:if="{{isload}}"><block><view class="activity"><view class="activity-amin"><view class="h2">中奖名单</view><view class="listbox"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="tr flex listitem"><view class="member"><view><image src="{{item.headimg}}"></image></view><view>{{item.nickname}}</view></view><view class="info"><view class="td td2">{{"中奖备注："+item.remark}}</view><view class="td td2">{{"中奖时间："+item.createtime}}</view><view class="td td2">{{"中奖奖品："+item.jxmc}}</view></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="10cf4d50-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="10cf4d50-2" bind:__l="__l"></nodata></block></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="10cf4d50-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="10cf4d50-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="10cf4d50-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>