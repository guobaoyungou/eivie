<view class="container"><block tt:if="{{isload}}"><block><view class="main"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'main?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="left"><view class="img"><image src="{{item.pic}}"></image></view><view class="info"><view class="title">{{item.name}}</view><view class="desc">{{item.desc}}</view></view></view><view class="opt">点击评测<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;font-size:26rpx;"></text></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="ee42229c-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="ee42229c-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="ee42229c-3" bind:__l="__l"></loading></block><popmsg class="vue-ref" vue-id="ee42229c-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>