<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><view class="f2">{{mytongzheng}}<block tt:if="{{tongzheng_transfer}}"><view class="btn-mini" data-url="/pagesA/my/tongzhengtransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账</view></block></view></view></view><view class="myscore" style="{{'background:'+($root.m2)+';'}}"><view class="f1">{{"待释放"+$root.m3}}</view><view class="f2">{{release_total}}</view><view class="f3" data-url="/pagesA/my/tongzhengorderlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>释放记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block tt:else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="b6477604-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="b6477604-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="b6477604-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="b6477604-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b6477604-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>