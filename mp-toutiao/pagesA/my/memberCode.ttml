<view><block tt:if="{{isload}}"><view class="main"><view class="cardtop" style="{{('background:rgba('+$root.m0+',0.2);')}}"><image src="{{userinfo.headimg}}"></image><text>{{userinfo.nickname}}</text></view><block tt:if="{{set.code_type==1||set.code_type==2}}"><view class="codeimg mt50"><image class="barcodeimg" src="{{userinfo.member_barcode_img}}"></image><view>{{userinfo.tel?userinfo.tel:userinfo.member_code}}</view></view></block><block tt:if="{{set.code_type==0||set.code_type==2}}"><view class="codeimg"><image src="{{userinfo.member_code_img}}"></image><view>{{userinfo.member_code}}</view></view></block><block tt:if="{{showmeberinfo&&tablist.length>0}}"><view class="moneybox"><block tt:for="{{tablist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="moneytab" data-url="{{item.path}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="txt">{{item.name}}</view><view class="money">{{item.tag+item.value}}</view></view></block></view></block><block tt:if="{{set.iswxpay==1}}"><view data-event-opts="{{[['tap',[['wxpay',['$event']]]]]}}" class="wxpay" bindtap="__e"><image class="wxicon" src="{{pre_url+'/static/img/wxpay2.png'}}"></image><text>使用微信支付</text></view></block></view></block><block tt:if="{{loading}}"><loading vue-id="c1fffa82-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="c1fffa82-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="c1fffa82-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>