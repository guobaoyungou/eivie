<view class="container"><block tt:if="{{isload}}"><block><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'/pagesA/my/tongzhengreleaselog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{"订单ID:"+item.orderid}}</text><text class="t2">{{"总数量："+item.tongzheng}}</text><text class="t2">{{"剩余："+item.remain}}</text><text class="t2">{{"状态："+item.status_str}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block><text class="t1">{{"已释放："+item.release_num}}</text></block></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="5bc50e82-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="5bc50e82-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="5bc50e82-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="5bc50e82-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5bc50e82-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>