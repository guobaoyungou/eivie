<view class="container"><block tt:if="{{isload}}"><block><view class="topbg" style="{{('background:url('+pre_url+'/static/img/lv-topbg.png) no-repeat;background-size:100%')}}"><view class="topinfo" style="{{('background:url('+pre_url+'/static/img/lv-top.png);background-size:100%')}}"><view class="info"><view class="nickname">{{frommember.nickname}}</view><view style="color:#fff;">分享了一个会员等级给您</view><view class="flex" style="margin-top:10rpx;"><view style="margin-right:10rpx;color:#fff;">售卖等级：</view><view class="user-level"><block tt:if="{{zslevel.icon}}"><image class="level-img" src="{{zslevel.icon}}"></image></block><view class="level-name">{{zslevel.name}}</view></view></view><view class="t3">{{"您的当前会员等级："+levelname}}</view></view><view class="set" data-url="set" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="fa fa-cog"></text></view></view><view class="price">价格：<view class="price_1">￥<text class="price_2">{{zslevel.apply_paymoney}}</text></view></view><view data-event-opts="{{[['tap',[['buy',['$event']]]]]}}" class="upbtn" style="{{('background:url('+pre_url+'/static/img/lv-upbtn.png) no-repeat;background-size:100%')}}" bindtap="__e">立即购买</view></view><view style="width:100%;height:20rpx;background-color:#f6f6f6;"></view><view class="explain"><view class="f1">— 等级特权 —</view><view class="f2"><parse vue-id="2ec3106b-1" content="{{zslevel.explain}}" bind:__l="__l"></parse></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="2ec3106b-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="2ec3106b-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="2ec3106b-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>