<view><block tt:if="{{isload}}"><block><view class="head" style="{{('background: '+color1)}}"></view><view style="width:700rpx;margin:0 auto;background-color:#fff;padding:20rpx;margin-top:-60rpx;border-radius:12rpx;"><view class="content_css"><view class="left">绑定旅行社：</view><view class="right" style="overflow:hidden;"><view style="width:380rpx;float:left;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{''+travel_name+''}}</view><block tt:if="{{apply_status<0}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scan" bindtap="__e"><image style="width:50rpx;height:50rpx;" src="{{pre_url+'/static/img/ico-scan.png'}}"></image></view></block></view></view><view class="content_css"><view class="left">真实姓名：</view><view class="right"><block tt:if="{{apply_status<0}}"><input style="line-height:80rpx;height:80rpx;" data-name="name" name="name" placeholder="请输入真实姓名" placeholder-style="line-height:80rpx;height:80rpx" data-event-opts="{{[['input',[['inputVal',['$event']]]]]}}" value="{{name}}" bindinput="__e"/></block><block tt:else><text>{{name}}</text></block></view></view><view class="content_css"><view class="left">手机号码：</view><view class="right"><block tt:if="{{apply_status<0}}"><input style="line-height:80rpx;height:80rpx;" data-name="tel" name="tel" placeholder="请输入手机号码" placeholder-style="line-height:80rpx;height:80rpx" data-event-opts="{{[['input',[['inputVal',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></block><block tt:else><text>{{tel}}</text></block></view></view><view class="content_css" style="border:0;"><view class="left">证件号码：</view><view class="right"><block tt:if="{{apply_status<0}}"><block><input style="line-height:80rpx;height:80rpx;" data-name="tour_id_number" name="tour_id_number" placeholder="请输入导游证件号码" placeholder-style="line-height:80rpx;height:80rpx" data-event-opts="{{[['input',[['inputVal',['$event']]]]]}}" value="{{tour_id_number}}" bindinput="__e"/></block></block><block tt:else><block><block tt:if="{{tour_id_number}}"><view>{{tour_id_number}}</view></block><block tt:else><view data-event-opts="{{[['tap',[['addCode',['$event']]]]]}}" style="display:inline-block;border-radius:6rpx;padding:0 20rpx;border:2rpx solid #ccc;height:60rpx;line-height:60rpx;" bindtap="__e">点击填写</view></block></block></block></view></view><block tt:if="{{apply_status==1&&code}}"><view class="content_css content_css2"><view class="left">优惠码：</view><view class="right"><text>{{code}}</text></view></view></block><block tt:if="{{apply_status==1}}"><view class="content_css content_css2"><view class="left">推广码：</view><view class="right" data-url="tuiguang" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="display:inline-block;border-radius:6rpx;padding:0 20rpx;border:2rpx solid #ccc;height:60rpx;line-height:60rpx;">点击查看</view></view></view></block><block tt:if="{{apply_status==-1&&reason}}"><view class="content_css content_css2"><view class="left">驳回原因：</view><view class="right"><text style="color:red;">{{reason}}</text></view></view></block><block tt:if="{{apply_status!=-2}}"><view class="content_css content_css2"><view class="left">审核状态：</view><view class="right"><block tt:if="{{apply_status==0}}"><text>审核中</text></block><block tt:if="{{apply_status==1}}"><text>已通过</text></block><block tt:if="{{apply_status==-1}}"><text style="color:red;">已驳回</text></block></view></view></block></view><block tt:if="{{apply_status<0}}"><view data-event-opts="{{[['tap',[['postdata',['$event']]]]]}}" class="btn" style="{{('background: '+color1)}}" bindtap="__e">提交</view></block><uni-popup class="vue-ref" vue-id="a7123dcc-1" id="dialogExpress1" type="dialog" data-ref="dialogExpress1" bind:__l="__l" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">导游证件号码</text></view><view class="uni-dialog-content"><view><view class="flex-y-center flex-x-center" style="margin:20rpx 20rpx;"><view style="font-size:28rpx;color:#555;">证件号码：</view><input style="border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;font-size:28rpx;" type="text" placeholder="请输入导游证件号码" data-event-opts="{{[['input',[['inputIdnumber',['$event']]]]]}}" bindinput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogExpress1Close',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmfahuo1',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup></block></block><dp-tabbar vue-id="a7123dcc-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><wxxieyi vue-id="a7123dcc-3" bind:__l="__l"></wxxieyi></view>