<view><block tt:if="{{isload}}"><block><view class="container"><view class="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="collage-product" data-url="{{'product?id='+item.id+'&trid='+trid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text></view></view><view class="p3"><view class="t1">已售<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.sales}}</text>件</view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">去购买</text></view></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="58aa0b94-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="58aa0b94-2" bind:__l="__l"></nodata></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="58aa0b94-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="58aa0b94-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="58aa0b94-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>