<view class="container"><block tt:if="{{isload}}"><block><view class="wc mendian_wc"><view style="width:100%;"><view class="mendian_name"><block tt:if="{{mendian_tip}}"><view>{{mendian_tip}}</view></block><block tt:else><view style="display:flex;align-items:center;"><image style="width:30rpx;height:30rpx;border-radius:4rpx;margin-right:10rpx;" src="{{mendian?mendian.pic:''}}"></image><view style="width:600rpx;text-overflow:ellipsis;white-space:nowrap;overflow:hidden;">{{mendian?mendian.name:'无门店'}}</view></view></block></view></view><view class="mendian_address" style="display:flex;justify-content:space-between;font-size:24rpx;"><view style="color:#3A4463;">门店地址</view><view style="width:500rpx;text-align:right;text-overflow:ellipsis;white-space:nowrap;overflow:hidden;" data-latitude="{{mendian.latitude}}" data-longitude="{{mendian.longitude}}" data-company="{{mendian.name}}" data-address="{{mendian.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e">{{''+(mendian?mendian.area+' '+mendian.address:'无')+''}}<image style="width:13rpx;height:20rpx;margin-left:10rpx;" src="/static/xinxixie/right.png"></image></view></view><block tt:if="{{mendian&&mendian.tel}}"><view class="mendian_tel"><view style="color:#3A4463;">电话咨询</view><view style="width:500rpx;text-align:right;text-overflow:ellipsis;white-space:nowrap;overflow:hidden;" data-phone="{{mendian?mendian.tel:''}}" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" bindtap="__e">{{''+(mendian?mendian.tel:'无')+''}}<image style="width:13rpx;height:20rpx;margin-left:10rpx;" src="/static/xinxixie/right.png"></image></view></view></block></view><block tt:for="{{list}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="wc" style="margin-bottom:20rpx;"><view style="display:flex;"><view style="width:130rpx;margin-right:20rpx;" data-url="{{'/pages/shop/product?id='+item.product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:130rpx;height:130rpx;border-radius:12rpx;" src="{{item.pic}}"></image></view><view style="width:540rpx;"><view style="display:flex;"><view style="width:380rpx;"><view style="font-size:28rpx;font-weight:bold;text-overflow:ellipsis;white-space:nowrap;overflow:hidden;">{{''+item.name+''}}</view><view style="font-size:28rpx;font-weight:bold;">{{'x'+item.num+''}}</view></view><view style="flex:1;"></view><view style="width:140rpx;text-align:right;word-wrap:break-word;"><text style="font-size:24rpx;color:#3A4463;">￥</text><text style="font-size:30rpx;color:#3A4463;font-weight:bold;">{{item.ggprice}}</text></view></view></view></view></view></block><view class="wc" style="margin-bottom:20rpx;"><view class="freight"><view class="f1">配送方式</view><view class="freight-ul"><view style="width:100%;overflow-y:hidden;overflow-x:scroll;white-space:nowrap;"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="idx2" tt:key="idx2"><block><view class="freight-li" style="{{(freightkey==idx2?'color:'+item.m0+';background:rgba('+item.m1+',0.2)':'')}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeFreight',['$event']]]]]}}" bindtap="__e">{{item.$orig.name+''}}</view></block></block></view></view><block tt:if="{{freightList[freightkey].isoutjuli==1}}"><view class="freighttips">超出配送范围</view></block><block tt:if="{{freightList[freightkey].desc}}"><view class="freighttips">{{freightList[freightkey].desc}}</view></block></view></view><block tt:if="{{freightList[freightkey].pstimeset==1}}"><view class="wc" style="margin-bottom:20rpx;"><view class="price"><view class="f1">{{(freightList[freightkey].pstype==1?'取货':'配送')+"时间"}}</view><view data-event-opts="{{[['tap',[['choosePstime',['$event']]]]]}}" class="f2" bindtap="__e">{{''+(pstimetext==''?'请选择时间':pstimetext)}}<text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view></view></block><block tt:if="{{needaddress==0}}"><view class="address-add"><view class="linkitem"><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" bindinput="__e"/></view><view class="linkitem"><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view></view></block><block tt:else><view class="address-add"><view class="flex-y-center" data-url="{{'/pagesB/address/'+(address.id?'address':'addressadd')+'?fromPage=buy&type='+(havetongcheng==1?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="img" src="{{pre_url+'/static/img/address.png'}}"></image></view><block tt:if="{{address.id}}"><view class="f2 flex1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block tt:if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block tt:else><view class="f2 flex1">请选择收货地址</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><view class="wc" style="margin-bottom:20rpx;"><view style="font-size:28rpx;color:#3A4463;line-height:50rpx;margin-top:20rpx;">备注消息</view><view><input style="width:100%;height:70rpx;line-height:70rpx;" placeholder="请输入备注消息" data-index="{{index}}" placeholder-style="color:#969699;line-height:70rpx" data-event-opts="{{[['input',[['inputMessage',['$event']]]]]}}" bindinput="__e"/></view></view><view class="wc" style="margin-bottom:20rpx;"><view class="price"><view class="f1">{{''+(freightList[freightkey].freight_price_txt||'运费')+''}}</view><text class="f2">{{"+¥"+freightList[freightkey].freight_price}}</text></view><view class="total_content"><view style="width:170rpx;">商品总价</view><view style="width:600rpx;text-align:right;">{{'￥'+product_price+''}}</view></view><view class="total_content"><view style="width:170rpx;">商品总数</view><view style="width:600rpx;text-align:right;">{{''+totalnum+'件'}}</view></view></view><view style="width:100%;height:110rpx;"></view><view class="footer flex notabbarbot"><view class="text1 flex1"><text style="margin-right:10rpx;color:#3A4463;font-size:26rpx;">合计</text><text style="font-weight:bold;font-size:32rpx;color:#F55726;">{{alltotalprice}}</text><text style="font-size:24rpx;">元</text></view><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" disabled="{{submitDisabled}}" data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" bindtap="__e">提交订单</button></view><block tt:if="{{pstimeDialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hidePstimeDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+(freightList[freightkey].pstype==1?'取货':'配送')+"时间"}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hidePstimeDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['pstimeRadioChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.$orig.title}}</view><view class="radio" style="{{(freight_time==item.$orig.value?'background:'+item.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="25d28860-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="25d28860-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="25d28860-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>