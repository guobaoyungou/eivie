<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop flex" style="{{('background:url('+pre_url+'/static/img/orderbg.png);background-size:100%')}}"><block tt:if="{{detail.status==0&&detail.refund_status==0}}"><view class="f1 "><view class="t1">等待买家付款</view><block tt:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block></view></block><block tt:if="{{detail.status==1&&detail.refund_status==0}}"><view class="f1"><view class="t2">订单已付款</view></view></block><block tt:if="{{detail.status==2&&detail.refund_status==0}}"><view class="f1"><view class="t2">订单进行中</view></view></block><block tt:if="{{detail.status==3&&detail.refund_status==0}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block tt:if="{{detail.status==4&&detail.refund_status==0}}"><view class="f1"><view class="t1">订单已取消</view></view></block><block tt:if="{{detail.refund_status==1}}"><view class="f1"><view class="t1">退款审核中</view></view></block><block tt:if="{{detail.refund_status==2}}"><view class="f1"><view class="t1">订单已退款</view></view></block><view class="orderx"><image src="{{pre_url+'/static/img/orderx.png'}}"></image></view></view><view class="orderinfo orderinfotop"><view class="title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><view class="item"><text class="t1" style="flex:0.6;">预约时间</text><text class="t2" style="flex:2;">{{detail.starttime+" 至 "+detail.endtime}}</text></view></view><block tt:if="{{detail.formdata.length>0}}"><view class="orderinfo"><block tt:for="{{detail.formdata}}" tt:for-item="item" tt:for-index="__i0__" tt:key="*this"><view class="item"><text class="t1">{{item[0]}}</text><block tt:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view class="product"><view class="title">产品信息</view><view class="content"><view data-url="{{'product?id='+detail.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{detail.pic}}"></image></view><view class="detail"><text class="t1">{{detail.title}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.price+''}}<text>/小时</text></text></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1">应付金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block tt:if="{{detail.leveldk_money>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block tt:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block tt:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block tt:if="{{detail.status==1}}"><text class="t2">已付款</text></block><block tt:if="{{detail.status==2}}"><text class="t2">进行中</text></block><block tt:if="{{detail.status==3}}"><text class="t2">已完成</text></block><block tt:if="{{detail.status==4}}"><text class="t2">已关闭</text></block><block tt:if="{{detail.refundCount}}"><text style="margin-left:8rpx;">{{"有退款("+detail.refundCount+")"}}</text></block></view><block tt:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block tt:if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block tt:if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block tt:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block tt:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block><block tt:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.paytypeid}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block tt:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">派单时间</text><text class="t2">{{detail.send_time}}</text></view></block><block tt:if="{{detail.status>1&&detail.addmoney>0}}"><view class="item"><text class="t1">补差价</text><text class="t2 red">{{"￥"+detail.addmoney}}</text></view></block><block tt:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">完成时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="title">客户信息</view><view class="item"><text class="t1">姓名</text><text class="t2">{{detail.linkman}}</text></view><view class="item"><text class="t1">手机号</text><text class="t2">{{detail.tel}}</text></view></view><block tt:if="{{detail.status>0}}"><view class="orderinfo "><view class="title">核销码</view><view class="item flex flex-x-center"><image src="{{detail.qrcode_url}}" mode="widthFix"></image></view></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block tt:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" bindtap="__e">关闭订单</view><block tt:if="{{detail.paytypeid!=5}}"><view class="btn1" style="{{'background:'+($root.m2)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block><block tt:if="{{detail.paytypeid==5}}"><view class="btn1" style="{{'background:'+($root.m3)+';'}}" data-url="{{'/pages/pay/transfer?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">上传付款凭证</view></block></block></block><block tt:if="{{detail.status==1&&detail.totalprice>0}}"><block><block tt:if="{{detail.paytypeid!='4'&&detail.refund_status==0||detail.refund_status==3}}"><block><view class="btn2" data-url="{{'refund?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">退款</view></block></block></block></block><block tt:if="{{detail.status==2}}"><block><block tt:if="{{detail.balance_pay_status==0&&detail.balance_price>0}}"><view class="btn1" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+detail.balance_pay_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">支付尾款</view></block></block></block><block tt:if="{{detail.status==3||detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除订单</view></block></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="7b8cc990-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="7b8cc990-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7b8cc990-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>