<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" bindsubmit="__e"><view class="address-add"><view class="linkitem"><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" bindinput="__e"/></view><view class="linkitem"><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx;" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view></view><view class="buydata"><view class="bcontent"><view class="btitle">约车信息</view><view class="product"><view class="item flex"><view class="img" data-url="{{'product?id='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{product.pic}}"></image></view><view class="info flex1"><view class="f1">{{product.name}}</view><view class="f3"><text style="font-weight:bold;">{{"￥"+product.sell_price}}</text></view></view></view></view><block tt:if="{{product.cid==2}}"><view class="price"><view class="f1">乘车日期</view><view class="f2">{{product.yy_date+''}}</view></view></block><block tt:if="{{product.cid==3}}"><view class="price"><view class="f1">预约时间</view><view class="f2">{{product.yy_date}}</view></view></block><view class="price"><text class="f1">价格</text><text class="f2">{{"¥"+product.sell_price+''}}<block tt:if="{{product.cid!='2'}}"><text>/天</text></block></text></view></view><view class="bcontent2"><block tt:if="{{userinfo.leveldk_money>0&&ykset.discount}}"><view class="price"><text class="f1">{{$root.m0+"折扣("+userinfo.discount+"折)"}}</text><text class="f2">{{"-¥"+userinfo.leveldk_money}}</text></view></block><block tt:if="{{product.is_coupon==1}}"><view class="price"><view class="f1">{{$root.m1}}</view><block tt:if="{{couponCount>0}}"><view data-event-opts="{{[['tap',[['showCouponList',['$event']]]]]}}" class="f2" bindtap="__e"><text style="{{'color:#fff;padding:4rpx 16rpx;font-weight:normal;border-radius:8rpx;font-size:24rpx;'+('background:'+($root.m2)+';')}}">{{couponrid!=0?couponList[couponkey].couponname:couponCount+'张可用'}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block tt:else><text class="f2" style="color:#999;">{{"无可用"+$root.m3}}</text></block></view></block><block tt:if="{{product.cid==3}}"><view class="price"><view class="f1" style="flex:2;">包车数量</view><view class="addnum f2"><view data-event-opts="{{[['tap',[['buynumminus',['$event']]]]]}}" class="minus" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['buynuminput',['$event']]]]]}}" value="{{buynum}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['buynumplus',['$event']]]]]}}" class="plus" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view></block><block tt:if="{{product.cid==1}}"><view class="price"><view class="f1" style="flex:1;">租车天数</view><view class="choose f2"><view data-event-opts="{{[['tap',[['toStartYuyue',['$event']]]]]}}" class="choosetime" bindtap="__e"><block tt:if="{{start_time!=''}}"><text>{{start_time}}</text></block><block tt:else><text>开始时间</text></block></view><block tt:if="{{difftext}}"><text class="difftext">{{difftext+''}}</text></block><block tt:else><text class="difftext">请选时间</text></block><view data-event-opts="{{[['tap',[['toEndYuyue',['$event']]]]]}}" class="choosetime" bindtap="__e"><block tt:if="{{end_time!=''}}"><text>{{end_time}}</text></block><block tt:else><text>结束时间</text></block></view></view></view></block><view style="display:none;">{{test}}</view><block tt:for="{{formdata}}" tt:for-item="item" tt:for-index="idx" tt:key="id"><view class="form-item"><view class="label">{{item.val1}}<block tt:if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block tt:if="{{item.key=='price'}}"><block><text class="f2" style="color:#999;">{{"￥"+item.val2}}</text></block></block><block tt:if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form_'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"/></block></block><block tt:if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form_'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block tt:if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form_'+idx}}"><block tt:for="{{item.val2}}" tt:for-item="item1" tt:for-index="idx1" tt:key="id"><label class="flex-y-center"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></block></radio-group></block></block><block tt:if="{{item.key=='checkbox'}}"><block><checkbox-group class="checkbox-group" name="{{'form_'+idx}}"><block tt:for="{{item.val2}}" tt:for-item="item1" tt:for-index="idx1" tt:key="id"><label class="flex-y-center"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></block></checkbox-group></block></block><block tt:if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form_'+idx}}" value="{{item.valdata}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['selectorPickerChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.val2[editorFormdata[idx]]}}</view></block><block tt:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block tt:if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form_'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block tt:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block tt:if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form_'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block tt:else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></block></block><block tt:if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form_'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block tt:if="{{editorFormdata[idx]}}"><view class="form-imgbox"><view class="layui-imgbox-close" style="z-index:2;" data-idx="{{idx}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block tt:else><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" bindtap="__e"></view></block></view></block></block></view></block></view><block tt:if="{{userinfo.score2money>0}}"><view class="scoredk flex"><checkbox-group data-event-opts="{{[['change',[['scoredk',['$event']]]]]}}" class="flex" style="width:100%;" bindchange="__e"><view class="f1"><view>{{userinfo.score*1+" "+$root.m4+'可抵扣'}}<text style="color:#e94745;">{{userinfo.scoredk_money*1}}</text>元</view><block tt:if="{{userinfo.scoredkmaxpercent>0&&userinfo.scoredkmaxpercent<=100}}"><view style="font-size:22rpx;color:#999;">{{"最多可抵扣订单金额的"+userinfo.scoredkmaxpercent+"%"}}</view></block></view><view class="f2">{{"使用"+$root.m5+'抵扣'}}<checkbox style="margin-left:6px;transform:scale(.8);" value="1"></checkbox></view></checkbox-group></view></block></view><view style="width:100%;height:182rpx;"></view><view class="footer flex"><view class="text1 flex1">总计：<text style="font-weight:bold;font-size:36rpx;">{{"￥"+totalprice}}</text></view><block tt:if="{{issubmit}}"><button class="op" style="background:#999;">确认提交</button></block><block tt:else><button class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';'}}" form-type="submit">确认提交</button></block></view></form><block tt:if="{{couponvisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal coupon-modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+$root.m8}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><couponlist vue-id="24daa40e-1" couponlist="{{couponList}}" choosecoupon="{{true}}" selectedrid="{{couponrid}}" data-event-opts="{{[['^chooseCoupon',[['chooseCoupon']]]]}}" bind:chooseCoupon="__e" bind:__l="__l"></couponlist></view></view></view></block><block tt:if="{{yuyuevisible}}"><view class="picker-time"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="picker-hide" bindtap="__e"></view><view class="picker-module"><picker-view class="picker-view" value="{{value}}" data-event-opts="{{[['change',[['bindChange',['$event']]]]]}}" bindchange="__e"><picker-view-column><block tt:for="{{years}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="flex-xy-center">{{item}}</view></block></picker-view-column><picker-view-column><block tt:for="{{hour}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="flex-xy-center">{{item}}</view></block></picker-view-column><picker-view-column><block tt:for="{{min}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="flex-xy-center">{{item}}</view></block></picker-view-column></picker-view><view class="picker-opt flex-xy-center"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="picker-btn" style="{{'background:'+('linear-gradient(-90deg,'+$root.m9+' 0%,rgba('+$root.m10+',0.8) 100%)')+';'}}" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['getTime',['$event']]]]]}}" class="picker-btn" style="{{'background:'+('linear-gradient(-90deg,'+$root.m11+' 0%,rgba('+$root.m12+',0.8) 100%)')+';'}}" bindtap="__e">确定</view></view></view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="24daa40e-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="24daa40e-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="24daa40e-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>