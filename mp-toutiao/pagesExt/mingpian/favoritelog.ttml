<view class="container"><block tt:if="{{isload}}"><block><view class="recordList"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="ListItem"><image class="firendAvatar" src="{{item.$orig.headimg}}"></image><view class="info"><text class="styleText">{{item.$orig.nickname}}</text><text>{{"于 "+item.m0+" 收藏了我的"+mingpiantext}}</text></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="33f55ac6-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="33f55ac6-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="33f55ac6-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="33f55ac6-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="33f55ac6-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>