radio{-webkit-transform:scale(.6);transform:scale(.6)}checkbox{-webkit-transform:scale(.6);transform:scale(.6)}.form-box{padding:2rpx 24rpx 0 24rpx;background:#fff;margin:24rpx;border-radius:10rpx}.form-item{line-height:100rpx;display:flex;justify-content:space-between;border-bottom:0 solid #eee}.form-item .f1{color:#222;width:250rpx;flex-shrink:0}.form-item .f2{display:flex;align-items:center;flex:1}.form-box .form-item:last-child{border:none}.form-box .flex-col{padding-bottom:20rpx}.form-item input{width:100%;border:1px solid #f1f1f1;color:#111;font-size:28rpx;height:70rpx;padding:0 10rpx;border-radius:6rpx}.form-item textarea{width:100%;min-height:200rpx;padding:20rpx 0;border:none}.form-item .upload_pic{margin:50rpx 0;background:#f3f3f3;width:90rpx;height:90rpx;text-align:center}.form-item .upload_pic image{width:32rpx;height:32rpx}.savebtn{width:90%;height:96rpx;line-height:96rpx;text-align:center;border-radius:48rpx;color:#fff;font-weight:700;margin:0 5%;margin-top:60rpx;border:none;background:#4a84ff}.layui-imgbox{margin-right:16rpx;margin-bottom:10rpx;font-size:24rpx;position:relative}.layui-imgbox-img{display:block;width:200rpx;height:200rpx;padding:2px;border:#d3d3d3 1px solid;background-color:#f6f6f6;overflow:hidden}.layui-imgbox-img>image{max-width:100%}.layui-imgbox-repeat{position:absolute;display:block;width:32rpx;height:32rpx;line-height:28rpx;right:2px;bottom:2px;color:#999;font-size:30rpx;background:#fff}.uploadbtn{position:relative;height:200rpx;width:200rpx}.clist-item{display:flex;border-bottom:1px solid #f5f5f5;padding:20rpx 30rpx}.clist-image{width:100%;display:block}.radio{flex-shrink:0;width:32rpx;height:32rpx;background:#fff;border:2rpx solid #bfbfbf;border-radius:50%;margin:0 30rpx 0 200rpx}.radio .radio-img{width:100%;height:100%;display:block}.freightitem{width:100%;height:60rpx;display:flex;align-items:center;margin-left:40rpx}.freightitem .f1{color:#666;flex:1}.detailop{display:flex;line-height:60rpx}.detailop .btn{border:1px solid #ccc;margin-right:10rpx;padding:0 16rpx;color:#222;border-radius:10rpx}.detaildp{position:relative;line-height:50rpx}.detaildp .op{width:100%;display:flex;justify-content:flex-end;font-size:24rpx;height:60rpx;line-height:60rpx;margin-top:10rpx}.detaildp .op .btn{background:rgba(0,0,0,.4);margin-right:10rpx;padding:0 10rpx;color:#fff}.detaildp .detailbox{border:2px dashed #00a0e9}.uni-popup-dialog{width:300px;border-radius:5px;background-color:#fff}.uni-dialog-title{display:flex;flex-direction:row;justify-content:center;padding-top:15px;padding-bottom:5px}.uni-dialog-title-text{font-size:16px;font-weight:500}.uni-dialog-content{display:flex;flex-direction:row;justify-content:center;align-items:center;padding:5px 15px 15px 15px}.uni-dialog-content-text{font-size:14px;color:#6e6e6e}.uni-dialog-button-group{display:flex;flex-direction:row;border-top-color:#f5f5f5;border-top-style:solid;border-top-width:1px}.uni-dialog-button{display:flex;flex:1;flex-direction:row;justify-content:center;align-items:center;height:45px}.uni-border-left{border-left-color:#f0f0f0;border-left-style:solid;border-left-width:1px}.uni-dialog-button-text{font-size:14px}.uni-button-color{color:#007aff}.uni-dialog-scroll{height:300rpx}.bglist{width:100%}.bglist .bg{min-width:32%;height:120rpx;margin-top:20rpx;border-radius:10rpx;overflow:hidden;margin-right:2%;position:relative}.scroll-view{width:100%;overflow-x:auto;white-space:nowrap}.bglist .bgpic{position:absolute;left:0;top:0;width:100%;height:120rpx}.bglist .bgpic image{width:100%}.mengceng{width:100%;height:120rpx;position:absolute;left:0;left:0}.mengceng .mc{width:100%;height:120rpx;background-color:rgba(0,0,0,.5);position:relative}.mengceng .checked{width:42rpx;height:42rpx;position:absolute;left:38%;top:34%;background-color:#fff;border-radius:50%;text-align:center;line-height:42rpx;font-weight:700}.layui-imgbox-close{z-index:10 !important}