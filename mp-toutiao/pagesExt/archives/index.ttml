<view class="container"><block tt:if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{item.createtime}}</text></view></view></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="42f1be3d-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="42f1be3d-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="42f1be3d-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="42f1be3d-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="42f1be3d-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>