.header{background-color:#fff;padding:10rpx 20rpx 0 20rpx;position:relative;display:flex;flex-direction:column}.header .title{width:100%;font-size:36rpx;color:#333;line-height:1.4;margin:10rpx 0;margin-top:20rpx;font-weight:700}.header .artinfo{width:100%;font-size:28rpx;color:#8c8c8c;font-style:normal;overflow:hidden;display:flex;margin:10rpx 0}.header .artinfo .t1{padding-right:8rpx}.header .artinfo .t2{color:#777;padding-right:8rpx}.header .artinfo .t3{text-align:right;flex:1}.header .subname{width:100%;font-size:28rpx;color:#888;border:1px dotted #ddd;border-radius:10rpx;margin:10rpx 0;padding:10rpx}