<view><block tt:if="{{isload}}"><block><view class="container"><view class="header"><text class="title">{{detail.name}}</text><view class="artinfo"><text class="t1">{{detail.createtime}}</text></view><view style="padding:8rpx 0;"><dp vue-id="e51f0d4c-1" pagecontent="{{pagecontent}}" bind:__l="__l"></dp></view></view></view></block></block><block tt:if="{{loading}}"><loading vue-id="e51f0d4c-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="e51f0d4c-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="e51f0d4c-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>