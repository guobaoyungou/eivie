<view class="container"><block tt:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+type_name}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{money}}</view></view><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block tt:else><text class="t2">{{item.money}}</text></block></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="f670c2e6-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="f670c2e6-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="f670c2e6-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="f670c2e6-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="f670c2e6-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>