<view class="container"><block tt:if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="flex1"><view class="f1">{{"商家"+$root.m1}}</view><view class="f2">{{mybscore}}</view></view><view class="flex1"><view class="f1">{{"平台"+$root.m2}}</view><view class="f2" data-url="scorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{myscore}}</view></view></view><view class="content" id="datalist"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-url="{{'bscorelog?bid='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image style="width:60rpx;height:60rpx;border-radius:10rpx;margin-right:10rpx;" src="{{item.logo}}"></image><text class="t1">{{item.name}}</text></view><view class="f2"><view class="t1">{{item.score}}<text>{{$root.m3}}</text></view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="02ee2854-1" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="02ee2854-2" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="02ee2854-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="02ee2854-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="02ee2854-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>