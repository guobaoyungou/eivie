.content{width:100%;margin:0}.content .item{width:94%;margin:20rpx 3%;background:#fff;border-radius:16rpx;padding:30rpx 30rpx;display:flex;align-items:center}.content .item:last-child{border:0}.content .item .f1{width:80%;display:flex;flex-direction:column}.content .item .f1 .t1{color:#000;font-size:30rpx;word-break:break-all;overflow:hidden;text-overflow:ellipsis}.content .item .f1 .t2{color:#666;margin-top:10rpx}.content .item .f1 .t3{color:#666}.content .item .f2{width:20%;font-size:32rpx;text-align:right}.content .item .f2 .t1{color:#03bc01}.content .item .f2 .t2{color:#000}.content .item .f3{flex:1;font-size:30rpx;text-align:right}.content .item .f3 .t1{color:#03bc01}.content .item .f3 .t2{color:#000}