<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{set.header_text}}"><view><parse vue-id="7ee3c48e-1" content="{{set.header_text}}" bind:__l="__l"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><block tt:if="{{set&&set.query_type=='id_card'}}"><view class="title">{{"请输入身份证号查询"+certificate_text}}</view></block><block tt:if="{{set&&set.query_type=='tel'}}"><view class="title">{{"请输入手机号查询"+certificate_text}}</view></block><view class="inputdiv"><block tt:if="{{set&&set.query_type=='id_card'}}"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入您的身份证号" value="{{tel}}"/></block><block tt:if="{{set&&set.query_type=='tel'}}"><input type="text" name="tel2" placeholder-style="color:#666;" placeholder="请输入您的手机号" value="{{tel2}}"/></block></view><button class="btn" form-type="submit">查询</button></form><block tt:if="{{set.footer_text}}"><view><parse vue-id="7ee3c48e-2" content="{{set.footer_text}}" bind:__l="__l"></parse></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="7ee3c48e-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="7ee3c48e-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7ee3c48e-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>