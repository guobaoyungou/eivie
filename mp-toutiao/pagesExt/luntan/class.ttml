<view style="width:100%;height:100%;background-color:#fff;"><block tt:if="{{isload}}"><block><view style="width:700rpx;margin:0 auto;"><view class="topsearch flex-y-center" data-url="list?cpid=0&displaytype=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block tt:if="{{clist&&clist.length>0}}"><view class="list_view"><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="list_content" style="{{(index%2==0?'margin-right:40rpx':'')}}" data-url="{{'list?cpid='+item.id+'&displaytype='+item.display_type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="width:330rpx;height:330rpx;border-radius:8rpx;overflow:hidden;"><image style="width:330rpx;height:330rpx;" src="{{item.pic}}" mode="widthFix"></image></view><view style="line-height:60rpx;font-size:28rpx;">{{item.name}}</view></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="32f14fec-1" bind:__l="__l"></nodata></block></view></block><block tt:if="{{nomore}}"><nomore vue-id="32f14fec-2" bind:__l="__l"></nomore></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="32f14fec-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="32f14fec-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="32f14fec-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>