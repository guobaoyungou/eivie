<view class="container"><view class="box2"><view class="header"><view class="f2" id="box2_title">{{title}}</view><view data-event-opts="{{[['tap',[['subpinglun',['$event']]]]]}}" class="f3" bindtap="__e">发表</view></view><textarea style="width:100%;height:50vh;" placeholder="写评论..." id="editcontent" data-event-opts="{{[['input',[['setcontent',['$event']]]]]}}" value="{{content}}" bindinput="__e"></textarea><view style="height:100rpx;"></view><view class="bottom notabbarbot"><view data-event-opts="{{[['tap',[['showface',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/emote.png'}}"></image></view></view><block tt:if="{{faceshow}}"><wxface bind:selectface="__e" vue-id="b4e301a2-1" data-event-opts="{{[['^selectface',[['selectface']]]]}}" bind:__l="__l"></wxface></block></view></view>