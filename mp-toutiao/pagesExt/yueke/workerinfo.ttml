<view><block><block tt:if="{{isload}}"><view class="container nodiydata"><view class="bg-red" style="{{'background:'+($root.m0)+';'}}"></view><view class="topcontent"><view class="logo"><image class="img" src="{{info.headimg}}"></image></view><view class="title">{{info.realname+''}}<text style="{{'margin-left:10rpx;font-size:28rpx;'+('color:'+($root.m1)+';')}}">{{info.dengji||''}}</text></view><view class="desc">{{''+info.desc+''}}</view></view><block tt:if="{{info.content}}"><view class="contentbox"><view class="cp_detail" style="padding:20rpx;"><parse vue-id="7787ee19-1" content="{{info.content}}" bind:__l="__l"></parse></view></view></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="7787ee19-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="7787ee19-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7787ee19-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>