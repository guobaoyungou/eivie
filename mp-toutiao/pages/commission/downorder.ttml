<view class="container"><block tt:if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{$root.m0+"（"+count+"）"}}</text><text class="t2">{{"预计：+"+commissionyj+"元"}}</text></view><dd-tab vue-id="7f468578-1" itemdata="{{['所有订单','待付款','已付款','已完成','退款/售后']}}" itemst="{{['0','1','2','3','5']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></view><view style="margin-top:190rpx;"></view><block tt:if="{{datalist&&datalist.length>0}}"><block><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1 flex"><text class="flex1">{{item.ordernum+"("+item.dengji+")"}}</text><block tt:if="{{item.dannum&&item.dannum>0}}"><text style="color:#a55;">{{"第"+item.dannum+"单"}}</text></block></view><view class="f2"><view class="t1"><text class="x1">{{item.name+" ×"+item.num}}</text><text class="x2">{{item.createtime}}</text><view class="x3"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></view><view class="t2"><text class="x1">{{"+"+item.commission}}</text><block tt:if="{{item.status==1||item.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block tt:if="{{item.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block tt:if="{{item.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block tt:if="{{item.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block tt:if="{{item.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block></view></block></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="7f468578-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="7f468578-3" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="7f468578-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="7f468578-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7f468578-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>