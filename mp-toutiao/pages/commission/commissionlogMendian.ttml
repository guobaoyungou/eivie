<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:if="{{st==0}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after+"元"}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block tt:else><text class="t2">{{item.money}}</text></block></view></view></block></block></block></view></block></block><block tt:if="{{nodata}}"><nodata vue-id="6558f4db-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="6558f4db-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="6558f4db-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="6558f4db-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="6558f4db-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>