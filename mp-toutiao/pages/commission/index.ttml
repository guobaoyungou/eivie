<view><block tt:if="{{isload}}"><block><view class="banner" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"><image src="{{userinfo.headimg}}" background-size="cover"></image><view class="info"><text class="nickname">{{userinfo.nickname}}</text><text>{{"推荐人："+(userinfo.pid>0?userinfo.pnickname:'无')}}</text></view></view><view class="contentdata"><view class="order"><view class="head"><text class="f1">{{"我的"+$root.m2}}</text><block tt:if="{{comwithdraw==1}}"><view class="f2" data-url="withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>立即提现</text><image src="/static/img/arrowright.png"></image></view></block><block tt:else><block tt:if="{{commission2money=='1'}}"><view data-event-opts="{{[['tap',[['tomoney',['$event']]]]]}}" class="f2" bindtap="__e"><text>{{"转到"+$root.m3+"账户"}}</text><image src="/static/img/arrowright.png"></image></view></block></block></view><view class="content"><view class="item" data-url="../order/shoporder?st=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">{{"￥"+userinfo.commission}}</text><text class="t3">{{(comwithdraw==1?'可提现':'剩余')+$root.m4}}</text></view><view class="item" data-url="../order/shoporder?st=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">{{"￥"+count3}}</text><text class="t3">{{"已提现"+$root.m5}}</text></view><view class="item" data-url="../order/shoporder?st=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">{{"￥"+userinfo.commission_yj}}</text><text class="t3">在路上</text></view></view></view><block tt:if="{{hasfenhong}}"><view class="order"><view class="head"><text class="f1">{{$root.m6}}</text><view class="f2" data-url="fenhong" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>查看详情</text><image src="/static/img/arrowright.png"></image></view></view><view class="content"><view class="item"><text class="t1">{{"￥"+userinfo.fenhong}}</text><text class="t3">累计获得</text></view><view class="item"><text class="t1">{{"￥"+userinfo.fenhong_yj}}</text><text class="t3">在路上</text></view><view class="item"></view></view></view></block><block tt:if="{{hasteamfenhong}}"><view class="order"><view class="head"><text class="f1">{{$root.m7}}</text><view class="f2" data-url="teamfenhong" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>查看详情</text><image src="/static/img/arrowright.png"></image></view></view><view class="content"><view class="item"><text class="t1">{{"￥"+userinfo.teamfenhong}}</text><text class="t3">累计获得</text></view><view class="item"><text class="t1">{{"￥"+userinfo.teamfenhong_yj}}</text><text class="t3">在路上</text></view><view class="item"></view></view></view></block><block tt:if="{{hasareafenhong}}"><view class="order"><view class="head"><text class="f1">{{$root.m8}}</text><view class="f2" data-url="areafenhong" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>查看详情</text><image src="/static/img/arrowright.png"></image></view></view><view class="content"><view class="item"><text class="t1">{{"￥"+userinfo.areafenhong}}</text><text class="t3">累计获得</text></view><view class="item"><text class="t1">{{"￥"+userinfo.areafenhong_yj}}</text><text class="t3">在路上</text></view><view class="item"></view></view></view></block><block tt:if="{{hasteamfenhong&&(teamnum_show==1||teamyeji_show==1)}}"><view class="order"><view class="head"><text class="f1">{{$root.m9}}</text><view class="f2" data-url="myteam" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>查看详情</text><image src="/static/img/arrowright.png"></image></view></view><view class="content"><block tt:if="{{teamnum_show==1}}"><view class="item"><text class="t1">{{userinfo.teamnum}}</text><text class="t3">团队总人数</text></view></block><view class="item"><block tt:if="{{teamyeji_show==1}}"><block><text class="t1">{{"￥"+userinfo.teamyeji}}</text><text class="t3">团队总业绩</text></block></block></view><view class="item"><block tt:if="{{gongxianfenhong_show==1}}"><block><text class="t1">{{"￥"+userinfo.gongxianfenhong}}</text><text class="t3">{{"预计"+(userinfo.gongxianfenhong_txt||'股东贡献量分红')}}</text></block></block></view></view></view></block><view class="list"><block tt:if="{{comwithdraw==1&&commission2money=='1'}}"><view data-event-opts="{{[['tap',[['tomoney',['$event']]]]]}}" class="item" bindtap="__e"><view class="f2">{{$root.m10+"转"+$root.m11}}</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><view class="item" data-url="myteam" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">{{$root.m12}}</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view><view class="item" data-url="downorder" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">{{$root.m13}}</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view><view class="item" data-url="commissionlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">{{$root.m14+"明细"}}</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view><view class="item" data-url="commissionrecord" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">{{$root.m15+"记录"}}</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view><view class="item" data-url="poster" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">分享海报</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view><block tt:if="{{showfenhong}}"><view class="item" data-url="fhorder" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">分红订单</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><block tt:if="{{showfenhong}}"><view class="item" data-url="fhlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">分红记录</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><block tt:if="{{showMendianOrder}}"><view class="item" data-url="orderMendian" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">服务订单</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><block tt:if="{{showMendianOrder}}"><view class="item" data-url="commissionlogMendian" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">服务佣金</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><block tt:if="{{showYeji}}"><view class="item" data-url="orderYeji" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">业绩统计</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block><block tt:if="{{set&&set.agent_card==1}}"><view class="item" data-url="/pagesExt/agent/cardEdit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f2">代理卡片</view><text class="f3"></text><image class="f4" src="/static/img/arrowright.png"></image></view></block></view></view><view style="width:100%;height:20rpx;"></view><uni-popup class="vue-ref" vue-id="965054c4-1" id="dialogInput" type="dialog" data-ref="dialogInput" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('965054c4-2')+','+('965054c4-1')}}" mode="input" title="{{$root.m16+'转'+$root.m17}}" value="" placeholder="请输入转入金额" data-event-opts="{{[['^confirm',[['tomonenyconfirm']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup></block></block><block tt:if="{{loading}}"><loading vue-id="965054c4-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="965054c4-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="965054c4-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>