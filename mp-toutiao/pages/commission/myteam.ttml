<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{userlevel&&userlevel.can_agent==2}}"><dd-tab vue-id="b7c7c13e-1" itemdata="{{['一级('+userinfo.myteamCount1+')','二级('+userinfo.myteamCount2+')']}}" itemst="{{['1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></block><block tt:if="{{userlevel&&userlevel.can_agent==3}}"><dd-tab vue-id="b7c7c13e-2" itemdata="{{['一级('+userinfo.myteamCount1+')','二级('+userinfo.myteamCount2+')','三级('+userinfo.myteamCount3+')']}}" itemst="{{['1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="/static/img/search_ico.png"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block tt:if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text><text class="t2">{{"来自TA的"+$root.m0}}</text></view><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><text class="x2">{{item.createtime}}</text><text class="x2">{{"等级："+item.levelname}}</text><block tt:if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block></view></view><view class="f2"><text class="t1">{{"+"+item.commission}}</text><view class="t3"><block tt:if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" bindtap="__e">{{"转"+$root.m1}}</view></block><block tt:if="{{userlevel&&userlevel.team_givescore==1}}"><view class="x1" data-id="{{item.id}}" data-event-opts="{{[['tap',[['givescoreshow',['$event']]]]]}}" bindtap="__e">{{"转"+$root.m2}}</view></block><block tt:if="{{userlevel&&userlevel.team_levelup==1}}"><view class="x1" data-id="{{item.id}}" data-levelid="{{item.levelid}}" data-levelsort="{{item.levelsort}}" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" bindtap="__e">升级</view></block></view></view></view></block></block></view></block><uni-popup class="vue-ref" vue-id="b7c7c13e-3" id="dialogmoneyInput" type="dialog" data-ref="dialogmoneyInput" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('b7c7c13e-4')+','+('b7c7c13e-3')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup><uni-popup class="vue-ref" vue-id="b7c7c13e-5" id="dialogscoreInput" type="dialog" data-ref="dialogscoreInput" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('b7c7c13e-6')+','+('b7c7c13e-5')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" bind:confirm="__e" bind:__l="__l"></uni-popup-dialog></uni-popup><block tt:if="{{dialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">升级</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="/static/img/close.png" data-event-opts="{{[['tap',[['showDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="sheet-item"><text class="item-text flex-item">{{item.$orig.name}}</text><view class="flex1"></view><block tt:if="{{item.$orig.id!=tempLevelid&&item.$orig.sort>tempLevelsort}}"><view style="{{'color:'+(item.m3)+';'}}" data-id="{{item.$orig.id}}" data-name="{{item.$orig.name}}" data-event-opts="{{[['tap',[['changeLevel',['$event']]]]]}}" bindtap="__e">选择</view></block><block tt:else><view style="color:#ccc;">选择</view></block></view></block></view></view></view></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="b7c7c13e-7" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="b7c7c13e-8" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="b7c7c13e-9" bind:__l="__l"></loading></block><dp-tabbar vue-id="b7c7c13e-10" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="b7c7c13e-11" data-ref="popmsg" bind:__l="__l"></popmsg></view>