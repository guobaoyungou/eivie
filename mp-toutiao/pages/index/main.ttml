<block tt:if="{{isload}}"><view class="container" style="{{'background-color:'+(pageinfo.bgcolor)+';'}}"><block><dp vue-id="1a139094-1" pagecontent="{{pagecontent}}" menuindex="{{menuindex}}" latitude="{{latitude}}" longitude="{{longitude}}" htsignatureurl="{{htsignatureurl}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" bind:getdata="__e" bind:__l="__l"></dp><dp-guanggao vue-id="1a139094-2" guanggaopic="{{guanggaopic}}" guanggaourl="{{guanggaourl}}" guanggaotype="{{guanggaotype}}" param="{{guanggaoparam}}" bind:__l="__l"></dp-guanggao><dp-tabbar vue-id="1a139094-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><block tt:if="{{isshare}}"><dp-sharegive vue-id="1a139094-4" sharegive="{{sharegive}}" data-event-opts="{{[['^toshare',[['toshare']]]]}}" bind:toshare="__e" bind:__l="__l"></dp-sharegive></block></block><popmsg class="vue-ref" vue-id="1a139094-5" data-ref="popmsg" bind:__l="__l"></popmsg><block tt:if="{{loading}}"><loading vue-id="1a139094-6" bind:__l="__l"></loading></block><wxxieyi vue-id="1a139094-7" bind:__l="__l"></wxxieyi></view></block>