<view class="container"><block tt:if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block tt:if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view><block tt:if="{{djs}}"><view class="t2">{{"剩余时间："+djs}}</view></block><block tt:if="{{detail.paytypeid==5}}"><view class="t2">转账汇款后请上传付款凭证</view></block></view></block><block tt:if="{{detail.status==1}}"><view class="f1"><view class="t1">{{detail.paytypeid==4?'已选择'+detail.paytype:'已成功付款'}}</view><block tt:if="{{detail.freight_type!=1}}"><view class="t2">我们会尽快为您发货</view></block><block tt:if="{{detail.freight_type==1}}"><view class="t2">请尽快前往自提地点取货</view></block></view></block><block tt:if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block tt:if="{{detail.freight_type!=3}}"><text class="t2" user-select="true" selectable="true">{{"发货信息："+detail.express_com+" "+detail.express_no}}</text></block></view></block><block tt:if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block tt:if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="address"><view class="img"><image src="/static/img/address3.png"></image></view><view class="info"><text class="t1" user-select="true" selectable="true">{{detail.linkman+" "+detail.tel}}</text><block tt:if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block tt:if="{{detail.freight_type==1}}"><text class="t2" data-storeinfo="{{storeinfo}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" bindtap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address+''}}</text></block></view></view><block tt:if="{{detail.bid>0}}"><view class="btitle flex-y-center" data-url="{{'/pagesExt/business/index?id='+detail.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:36rpx;height:36rpx;" src="{{detail.binfo.logo}}"></image><view class="flex1" style="padding-left:16rpx;" decode="true" space="true">{{detail.binfo.name}}</view></view></block><view class="product"><block tt:for="{{prolist}}" tt:for-item="item" tt:for-index="idx" tt:key="idx"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><view class="t2 flex flex-y-center flex-bt"><text>{{item.ggname}}</text><block tt:if="{{detail.status==3&&item.iscomment==0&&shopset.comment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去评价</view></block><block tt:if="{{detail.status==3&&item.iscomment==1}}"><view class="btn3" data-url="{{'comment?ogid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看评价</view></block></view><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></view></view></block></view><block tt:if="{{(detail.status==3||detail.status==2)&&(detail.freight_type==3||detail.freight_type==4)}}"><view class="orderinfo"><view class="item flex-col"><text class="t1" style="color:#111;">发货信息</text><text class="t2" style="text-align:left;margin-top:10rpx;padding:0 10rpx;" user-select="true" selectable="true">{{detail.freight_content}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block tt:if="{{detail.status>0&&detail.paytypeid!='4'&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block tt:if="{{detail.paytypeid}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block tt:if="{{detail.paytypeid=='5'}}"><block><block tt:if="{{pay_transfer_info.pay_transfer_account_name}}"><view class="item"><text class="t1">户名</text><text class="t2">{{pay_transfer_info.pay_transfer_account_name}}</text></view></block><block tt:if="{{pay_transfer_info.pay_transfer_account}}"><view class="item"><text class="t1">账户</text><text class="t2">{{pay_transfer_info.pay_transfer_account}}</text></view></block><block tt:if="{{pay_transfer_info.pay_transfer_bank}}"><view class="item"><text class="t1">开户行</text><text class="t2">{{pay_transfer_info.pay_transfer_bank}}</text></view></block><block tt:if="{{pay_transfer_info.pay_transfer_desc}}"><view class="item"><text class="text-min">{{pay_transfer_info.pay_transfer_desc}}</text></view></block><view class="item"><text class="t1">付款凭证审核</text><text class="t2">{{payorder.check_status_label}}</text></view><block tt:if="{{payorder.check_remark}}"><view class="item"><text class="t1">审核备注</text><text class="t2">{{payorder.check_remark}}</text></view></block></block></block><block tt:if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block tt:if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block tt:if="{{detail.disprice>0}}"><view class="item"><text class="t1">{{$root.m0+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block tt:if="{{detail.manjian_money>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><block tt:if="{{detail.invoice_money>0}}"><view class="item"><text class="t1">发票费用</text><text class="t2 red">{{"+¥"+detail.invoice_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block tt:if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block tt:if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block tt:if="{{detail.coupon_money>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block tt:if="{{detail.scoredk>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><block tt:if="{{detail.is_yuanbao_pay==1}}"><view class="item"><text class="t1">{{$root.m3}}</text><text class="t2 red">{{detail.total_yuanbao}}</text></view></block><view class="item"><text class="t1">订单状态</text><block tt:if="{{detail.status==0}}"><text class="t2">未付款</text></block><block tt:if="{{detail.status==1}}"><text class="t2">{{detail.paytypeid==4?'待发货':'已支付'}}</text></block><block tt:if="{{detail.status==2&&detail.express_isbufen==0}}"><text class="t2">已发货</text></block><block tt:if="{{detail.status==2&&detail.express_isbufen==1}}"><text class="t2">部分发货</text></block><block tt:if="{{detail.status==3}}"><text class="t2">已收货</text></block><block tt:if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block tt:if="{{detail.refundingMoneyTotal>0}}"><view class="item"><text class="t1">退款中</text><text class="t2 red" data-url="{{'refundlist?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{"¥"+detail.refundingMoneyTotal}}</text><text class="t3 iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block tt:if="{{detail.refundedMoneyTotal>0}}"><view class="item"><text class="t1">已退款</text><text class="t2 red" data-url="{{'refundlist?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{"¥"+detail.refundedMoneyTotal}}</text><text class="t3 iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block tt:if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block tt:if="{{detail.refund_status==1}}"><text class="t2 red">审核中</text></block><block tt:if="{{detail.refund_status==2}}"><text class="t2 red">已退款</text></block><block tt:if="{{detail.refund_status==3}}"><text class="t2 red">已驳回</text></block></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款</text><text class="t2 red">{{"¥"+detail.balance_price}}</text></view></block><block tt:if="{{detail.balance_price>0}}"><view class="item"><text class="t1">尾款状态</text><block tt:if="{{detail.balance_pay_status==1}}"><text class="t2">已支付</text></block><block tt:if="{{detail.balance_pay_status==0}}"><text class="t2">未支付</text></block></view></block></view><block tt:if="{{detail.checkmemid}}"><view class="orderinfo"><view class="item"><text class="t1">所选会员</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.checkmember.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.checkmember.nickname}}</text></view></view></block><block tt:if="{{detail.formdata.length>0}}"><view class="orderinfo"><block tt:for="{{detail.formdata}}" tt:for-item="item" tt:for-index="__i0__" tt:key="*this"><view class="item"><text class="t1">{{item[0]}}</text><block tt:if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block tt:else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><block tt:if="{{detail.freight_type==11}}"><view class="orderinfo"><view class="item"><text class="t1">发货地址</text><text class="t2">{{"¥"+detail.freight_content.send_address+" - "+detail.freight_content.send_tel}}</text></view><view class="item"><text class="t1">收货地址</text><text class="t2">{{"¥"+detail.freight_content.receive_address+" - "+detail.freight_content.receive_tel}}</text></view></view></block><view style="width:100%;height:160rpx;"></view><block tt:if="{{fromfenxiao==0}}"><view class="bottom notabbarbot"><block tt:if="{{detail.payaftertourl&&detail.payafterbtntext}}"><block><view style="position:relative;"><block tt:if="{{detail.payafter_username}}"><block><view class="btn2">{{detail.payafterbtntext}}</view></block></block><block tt:else><block><view class="btn2" data-url="{{detail.payaftertourl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{detail.payafterbtntext}}</view></block></block></view></block></block><block tt:if="{{detail.isworkorder==1}}"><block><view class="btn2" data-url="{{'/activity/workorder/index?type=1&id='+detail.id}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发起工单</view></block></block><block tt:if="{{detail.status==0}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" bindtap="__e">关闭订单</view><block tt:if="{{detail.paytypeid!=5}}"><view class="btn1" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/pages/pay/pay?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去付款</view></block><block tt:if="{{detail.paytypeid==5}}"><view class="btn1" style="{{'background:'+($root.m5)+';'}}" data-url="{{'/pages/pay/transfer?id='+detail.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">上传付款凭证</view></block></block></block><block tt:if="{{detail.status==1}}"><block><block tt:if="{{detail.paytypeid!='4'}}"><block><block tt:if="{{shopset.canrefund==1&&detail.refundnum<detail.procount}}"><view class="btn2" data-url="{{'refundSelect?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">退款</view></block></block></block><block tt:else><block></block></block></block></block><block tt:if="{{(detail.status==2||detail.status==3)&&detail.freight_type!=3&&detail.freight_type!=4}}"><block><block tt:if="{{detail.express_type=='express_wx'}}"><view class="btn2" data-express_type="{{detail.express_type}}" data-express_com="{{detail.express_com}}" data-express_no="{{detail.express_no}}" data-express_content="{{detail.express_content}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" bindtap="__e">订单跟踪</view></block><block tt:else><view class="btn2" data-express_type="{{detail.express_type}}" data-express_com="{{detail.express_com}}" data-express_no="{{detail.express_no}}" data-express_content="{{detail.express_content}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" bindtap="__e">查看物流</view></block></block></block><block tt:if="{{$root.g0}}"><block><view class="btn2" data-url="{{'invoice?type=shop&orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">发票</view></block></block><block tt:if="{{detail.status==2}}"><block><block tt:if="{{detail.paytypeid!='4'}}"><block><block tt:if="{{shopset.canrefund==1&&detail.refundnum<detail.procount}}"><view class="btn2" data-url="{{'refundSelect?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">退款</view></block></block></block><block tt:if="{{detail.paytypeid!='4'&&(detail.balance_pay_status==1||detail.balance_price==0)}}"><view class="btn1" style="{{'background:'+($root.m6)+';'}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" bindtap="__e">确认收货</view></block><block tt:if="{{detail.balance_pay_status==0&&detail.balance_price>0}}"><view class="btn1" style="{{'background:'+($root.m7)+';'}}" data-url="{{'/pages/pay/pay?id='+detail.balance_pay_orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">支付尾款</view></block></block></block><block tt:if="{{(detail.status==1||detail.status==2)&&detail.freight_type==1}}"><block><view data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" class="btn2" bindtap="__e">核销码</view></block></block><block tt:if="{{detail.refundCount}}"><view class="btn2" data-url="{{'refundlist?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">查看退款</view></block><block tt:if="{{detail.status==3||detail.status==4}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除订单</view></block></block><block tt:if="{{detail.bid>0&&detail.status==3}}"><block><block tt:if="{{iscommentdp==0}}"><view class="btn1" style="{{'background:'+($root.m8)+';'}}" data-url="{{'/pages/order/commentdp?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">评价店铺</view></block><block tt:if="{{iscommentdp==1}}"><view class="btn2" data-url="{{'/pages/order/commentdp?orderid='+detail.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看评价</view></block></block></block></view></block><uni-popup class="vue-ref" vue-id="a2b31fcc-1" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" bind:__l="__l" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="/static/img/close2.png"></image></view></view></uni-popup><uni-popup class="vue-ref" vue-id="a2b31fcc-2" id="dialogSelectExpress" type="dialog" data-ref="dialogSelectExpress" bind:__l="__l" vue-slots="{{['default']}}"><block tt:if="{{express_content}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><block tt:for="{{express_content}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="sendexpress" style="border-bottom:1px solid #f5f5f5;padding:20rpx 0;"><view class="sendexpress-item" style="display:flex;" data-url="{{'/pages/order/logistics?express_com='+item.express_com+'&express_no='+item.express_no}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="flex1" style="color:#121212;">{{item.express_com+" - "+item.express_no}}</view><image style="width:30rpx;height:30rpx;" src="/static/img/arrowright.png"></image></view><block tt:if="{{item.express_oglist}}"><view style="margin-top:20rpx;"><block tt:for="{{item.express_oglist}}" tt:for-item="item2" tt:for-index="index2" tt:key="index2"><view class="oginfo-item" style="display:flex;align-items:center;margin-bottom:10rpx;"><image style="width:50rpx;height:50rpx;margin-right:10rpx;flex-shrink:0;" src="{{item2.pic}}"></image><view class="flex1" style="color:#555;">{{item2.name+"("+item2.ggname+")"}}</view></view></block></view></block></view></block></view></block></uni-popup></block></block><block tt:if="{{loading}}"><loading vue-id="a2b31fcc-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="a2b31fcc-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="a2b31fcc-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>