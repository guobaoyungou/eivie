<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.back_type_name}}</text><block tt:if="{{item.remark}}"><text class="t2">{{item.send_day+item.remark}}</text></block><text class="t2">{{item.create_time}}</text></view><view class="f2"><text class="t1">{{"+"+item.cashback_num}}</text></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="56d4cc54-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="56d4cc54-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="56d4cc54-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="56d4cc54-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="56d4cc54-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>