<view class="container"><block tt:if="{{isload}}"><block><view class="topimg" style="{{'background:'+($root.m0)+';'}}"><image class="img" src="{{bgurl}}"></image></view><view class="topinfo"><view class="flex"><view class="myscore"><text class="t1" style="{{'color:'+($root.m1)+';'}}">{{score}}</text><text class="t2">{{"我的"+$root.m2}}</text></view><view class="scorelog" style="{{'color:'+($root.m3)+';'+('background:'+('rgba('+$root.m4+',0.2)')+';')}}" data-url="/pagesD/goldbean/log" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{$root.m5+"明细"}}<text class="iconfont iconjiantou"></text></view><view class="orderlog" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换记录<text class="iconfont iconjiantou"></text></view></view><view class="search-container"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="商品搜索..." placeholder-style="font-size:24rpx;color:#C2C2C2" type="text" confirm-type="search" data-event-opts="{{[['confirm',[['search',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view></view><block tt:if="{{clist.length>0}}"><block><view class="navbox"><block tt:for="{{clist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="nav_li" style="cursor:pointer;" data-url="{{item.url?item.url:'prolist?bid='+bid+'&cid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{item.pic}}"></image><view class="txt">{{item.name}}</view></view></block></block><view class="nav_li" data-url="{{'prolist?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/all.png'}}"></image><view class="txt">全部</view></view></view></block></block><view style="margin-top:20rpx;" id="datalist"><view class="dp-product"><view class="dp-product-normal-item"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" style="{{('width:49%;margin-right:'+(index%2==0?'2%':0))}}" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.name}}</view><view class="p2" style="color:#666;font-size:24rpx;"><block tt:if="{{item.$orig.sell_price>0}}"><block>{{"价值"+item.$orig.sell_price+"元"}}</block></block></view><view class="p2"><view class="t1" style="{{'color:'+($root.m6)+';'}}"><block tt:if="{{item.$orig.score_price>0}}"><block>{{item.$orig.score_price+item.m7}}</block></block><block tt:if="{{item.$orig.money_price>0}}"><block><block tt:if="{{item.$orig.score_price>0}}"><block>+</block></block>{{item.$orig.money_price+"元"}}</block></block></view></view><view class="p3">已兑换<text style="{{'color:'+($root.m8)+';'}}">{{''+item.$orig.sales+''}}</text>件</view><view class="p3 flex flex-x-bottom"><view class="button" style="{{'background:'+($root.m9)+';'}}">立即兑换</view></view></view></view></block></block></view></view><block tt:if="{{nomore}}"><nomore vue-id="ba84506a-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="ba84506a-2" bind:__l="__l"></nodata></block></view></block></block><block tt:if="{{loading}}"><loading vue-id="ba84506a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="ba84506a-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="ba84506a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>