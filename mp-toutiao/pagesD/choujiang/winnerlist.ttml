<view class="container"><block tt:if="{{isload}}"><block><view class="order-content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"中奖用户："+item.nickname}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"获得奖品："+item.award_name}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"参与时间："+item.createtime}}</view></view></view></view></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="d4e19890-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="d4e19890-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="d4e19890-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="d4e19890-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="d4e19890-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>