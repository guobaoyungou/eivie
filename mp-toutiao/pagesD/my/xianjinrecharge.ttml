<view class="container"><block tt:if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.xianjin}}</view><view class="f3" data-url="xianjinlog?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>充值记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><block tt:if="{{caninput==1||giveset.length>0}}"><view class="item2"><view class="f1">{{"充值金额("+$root.m2+")"}}</view></view></block><block tt:if="{{caninput==1}}"><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="请输入充值金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" bindinput="__e"/></view></view></block></block><block tt:if="{{giveset.length>0}}"><view class="giveset"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block tt:if="{{item.$orig.money>0}}"><view class="{{(('item')+' '+(moneyduan==item.$orig.money?'active':''))}}" style="{{(moneyduan==item.$orig.money?'background:'+item.m3:'')}}" data-money="{{item.$orig.money}}" data-event-opts="{{[['tap',[['selectgiveset',['$event']]]]]}}" bindtap="__e"><text class="t1">{{(caninput==1?'满':'充')+item.$orig.money+item.m4}}</text><block tt:if="{{item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠"+item.$orig.give+item.m5+"+"+item.$orig.give_score+item.m6}}</text></block><block tt:else><block tt:if="{{item.$orig.give&&!item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give+item.m7}}</text></block><block tt:else><block tt:if="{{!item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give_score+item.m8}}</text></block></block></block></view></block></block></view></block><block tt:if="{{recharge_minimum&&recharge_minimum>0}}"><view class="item2"><view class="f1">{{"最低充值"+recharge_minimum+"元"}}</view></view></block><block tt:if="{{shuoming}}"><view style="padding:20rpx 30rpx;line-height:42rpx;"><parse vue-id="5a12edc2-1" content="{{shuoming}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" bind:navigate="__e" bind:__l="__l"></parse></view></block></view><view class="op"><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m9)+';'}}" bindtap="__e">去支付</view></view><block tt:if="{{transfer}}"><view class="op"><view class="btn" style="{{'background:'+($root.m10)+';'}}" data-url="rechargeToMember" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账</view></view></block></block></block><block tt:if="{{loading}}"><loading vue-id="5a12edc2-2" bind:__l="__l"></loading></block><dp-tabbar vue-id="5a12edc2-3" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5a12edc2-4" data-ref="popmsg" bind:__l="__l"></popmsg></view>