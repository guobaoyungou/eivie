<view class="container"><block tt:if="{{isload}}"><block><block tt:if="{{showmyxianjin}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}</view><view class="item flex-bt flex-y-center"><view class="value">{{myxianjin}}</view></view></view></block><dd-tab vue-id="33058ed0-1" itemdata="{{[$root.m2+'明细','充值记录','提现记录']}}" itemst="{{['0','1','2']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="content" id="datalist"><block tt:if="{{st==0}}"><block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block tt:if="{{item.money>0}}"><text style="color:green;">{{"+"+item.money}}</text></block><block tt:else><text style="color:red;">{{item.money}}</text></block></view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block></block></block></block><block tt:if="{{st==1}}"><block><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item" style="display:flex;align-items:center;"><view class="f1"><text class="t1">{{"充值金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.$orig.createtime}}</text></view><block tt:if="{{item.$orig.money_recharge_transfer&&item.$orig.paytypeid==5}}"><view class="f3"><block tt:if="{{item.$orig.transfer_check==1}}"><view><block tt:if="{{item.$orig.payorder.check_status==1&&item.$orig.status==0}}"><text class="t2" style="line-height:60rpx;font-size:13px;">充值失败</text></block><block tt:if="{{item.$orig.payorder.check_status==2&&item.$orig.status==0}}"><text class="t2" style="line-height:60rpx;font-size:13px;">凭证被驳回</text></block><block tt:if="{{!item.$orig.payorder.check_status&&!item.$orig.payorder.paypics&&item.$orig.status==0}}"><text class="t2" style="line-height:60rpx;font-size:13px;">凭证待上传</text></block><block tt:if="{{!item.$orig.payorder.check_status&&item.$orig.payorder.paypics&&item.$orig.status==0}}"><text class="t2" style="line-height:60rpx;font-size:13px;">凭证审核中</text></block><block tt:if="{{(item.$orig.payorder.check_status==1||item.$orig.payorder.check_status==2)&&item.$orig.status==1}}"><text class="t1" style="line-height:60rpx;font-size:13px;">充值成功</text></block><text class="btn1" style="{{'background:'+(item.m3)+';'}}" data-url="{{'/pages/pay/transfer?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">付款凭证</text></view></block><block tt:else><view style="font-size:13px;"><block tt:if="{{item.$orig.transfer_check==0}}"><text>转账待审核</text></block><block tt:if="{{item.$orig.transfer_check==-1}}"><text>转账已驳回</text></block></view></block></view></block><block tt:else><view class="f3" style="font-size:13px;"><block tt:if="{{item.$orig.status==0}}"><text class="t2">充值失败</text></block><block tt:if="{{item.$orig.status==1}}"><text class="t1">充值成功</text></block></view></block></view></block></block></block><block tt:if="{{st==2}}"><block><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.$orig.createtime}}</text><block tt:if="{{item.$orig.status==2}}"><text class="t2">{{"驳回原因："+(item.$orig.reason||'无')}}</text></block></view><view class="f3"><block tt:if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block tt:if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block tt:if="{{item.$orig.status==4}}"><block><block tt:if="{{item.$orig.wx_state=='WAIT_USER_CONFIRM'||item.$orig.wx_state=='TRANSFERING'}}"><view data-event-opts="{{[['tap',[['confirm_shoukuan',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m4)+';'}}" bindtap="__e">确认收款</view></block><block tt:else><block tt:if="{{item.$orig.wx_state=='FAIL'}}"><view class="t1">转账失败</view></block><block tt:else><view class="t1">处理中</view></block></block></block></block><block tt:if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block tt:if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="33058ed0-2" bind:__l="__l"></nodata></block></view><block tt:if="{{nomore}}"><nomore vue-id="33058ed0-3" bind:__l="__l"></nomore></block></block></block><block tt:if="{{loading}}"><loading vue-id="33058ed0-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="33058ed0-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="33058ed0-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>