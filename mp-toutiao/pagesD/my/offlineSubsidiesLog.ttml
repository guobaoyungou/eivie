<view class="container"><block tt:if="{{isload}}"><block><view class="content"><block tt:if="{{st==0}}"><block><block tt:if="{{ly_type==6&&zhitui_num!='-1'}}"><view class="item"><view class="f1"><text class="t1">{{"当月直推新人"+zhitui_num+"个"}}</text></view></view></block><block tt:if="{{ly_type==1}}"><view class="item"><block tt:if="{{weisj!='-1'}}"><view class="f1"><text class="t1">{{"您还差"+weisj+"个升级奖励升级"}}<block tt:if="{{level_name}}"><text>{{"到["+level_name+"]"}}</text></block>，请继续努力</text></view></block><block tt:if="{{yisj!='-1'}}"><view class="f1"><text class="t1">{{"恭喜您，您已升级成为["+yisj+"]，剩下的钱自动转入爱心基金"}}</text></view></block></view></block><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t2">{{item.createtime}}</text><text class="t1">{{item.remark}}</text></view><view class="f2"><block tt:if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block tt:else><text class="t2">{{item.money}}</text></block></view></view></block></block></block></view><block tt:if="{{nomore}}"><nomore vue-id="7b4e2a79-1" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="7b4e2a79-2" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="7b4e2a79-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="7b4e2a79-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="7b4e2a79-5" data-ref="popmsg" bind:__l="__l"></popmsg></view>