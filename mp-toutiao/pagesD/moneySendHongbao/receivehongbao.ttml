<view><block tt:if="{{isload}}"><block><view class="bg-view"><image src="{{data.pic}}" mode="center"></image></view><view class="content-view"><view class="info-view flex flex-y-center"><view class="head-img"><image src="{{data.headimg}}"></image></view><view class="name-view">{{''+data.nickname+' 发出的红包'}}</view></view><view class="price-view flex flex-y-center"><view>{{data.money}}</view><view style="font-size:30rpx;margin-left:10rpx;margin-top:10rpx;">元</view></view><view data-event-opts="{{[['tap',[['torecord',['$event']]]]]}}" class="tisp-text flex flex-y-center" bindtap="__e"><view>{{"领取成功，红包已存入"+(data.receive_account==1?'佣金':$root.m0)}}</view><view class="icon-class"><image src="{{pre_url+'/static/img/redenvelope/jiantou.png'}}" data-event-opts="{{[['tap',[['torecord',['$event']]]]]}}" bindtap="__e"></image></view></view></view><view class="hb-log" data-url="hongbaolog?type=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">红包记录</view></block></block><block tt:if="{{loading}}"><loading vue-id="2d29ad92-1" bind:__l="__l"></loading></block></view>