<view class="page-content"><block tt:if="{{isload}}"><block><view class="top-switch-view flex flex-bt flex-y-center"><view class="hb-title">{{resEnvelopeType==2?'人均红包':'拼手气红包'}}</view><view data-event-opts="{{[['tap',[['changeSwitch',['$event']]]]]}}" class="switch-change-view" bindtap="__e">{{'切换为'+(resEnvelopeType==1?'人均':'拼手气')+'红包'}}</view></view><view class="options-view flex-bt flex-y-center"><view class="options-title flex-y-center"><view>{{resEnvelopeType==2?'人均金额':'总金额'}}</view><block tt:if="{{!resEnvelopeType}}"><image class="pin-icon" src="{{pre_url+'/static/img/pin.png'}}"></image></block></view><view class="options-input flex-y-center"><input class="input-class" type="digit" placeholder-class="placeholder-class" placeholder="0.00" data-event-opts="{{[['input',[['__set_model',['','money','$event',[]]],['computeMoney',['$event']]]]]}}" value="{{money}}" bindinput="__e"/><view class="unit">元</view></view></view><view class="options-view flex-bt flex-y-center"><view class="options-title flex-y-center">红包个数</view><view class="options-input flex-y-center"><input class="input-class" type="number" placeholder-class="placeholder-class" placeholder="0" data-event-opts="{{[['input',[['__set_model',['','num','$event',[]]],['computeMoney',['$event']]]]]}}" value="{{num}}" bindinput="__e"/><view class="unit">个</view></view></view><view class="options-view flex-bt flex-y-center"><view class="options-title flex-y-center">领取规则</view><view class="options-input flex-y-center"><checkbox-group data-event-opts="{{[['change',[['ruleChange',['$event']]]]]}}" class="uni-flex uni-row checkbox-group" style="flex-wrap:wrap;" bindchange="__e"><checkbox class="checkbox" style="transform:scale(0.8);" value="-1" checked="{{true}}">全部</checkbox><checkbox class="checkbox " style="transform:scale(0.8);" value="0">老用户</checkbox><checkbox class="checkbox " style="transform:scale(0.8);" value="1">新用户</checkbox></checkbox-group></view></view><view class="options-view flex-bt flex-y-center"><view class="options-title flex-y-center">过期日期</view><view class="options-input flex-y-center"><view class="flex-y-center"><picker mode="date" value="{{date}}" start="{{startDate}}" end="{{endDate}}" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{date}}"><view class="date-class">{{date}}</view></block><block tt:else><view class="placeholder-class">选择过期日期</view></block></picker><picker style="margin-left:20rpx;" mode="time" value="{{time}}" data-event-opts="{{[['change',[['bindTimeChange',['$event']]]]]}}" bindchange="__e"><block tt:if="{{time}}"><view class="uni-input">{{time}}</view></block><block tt:else><view class="placeholder-class">选择时间</view></block></picker></view><view class="cover-icon flex-xy-center"><image src="{{pre_url+'/static/img/lt_right_jiantou.png'}}"></image></view></view></view><view class="options-view flex-bt flex-y-center"><view class="options-title flex-y-center">红包封面</view><view class="options-input flex-y-center" data-url="hongbaocover" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="cover-img-view"><image src="{{pic}}" mode="scaleToFill"></image></view><view class="cover-icon flex-xy-center"><image src="{{pre_url+'/static/img/lt_right_jiantou.png'}}"></image></view></view></view><view class="page-but-view flex-col"><view class="price-view flex flex-y-center"><view style="font-size:50rpx;font-weight:normal;">￥</view><view>{{totalmoney>0?totalmoney:'0.00'}}</view></view><view data-event-opts="{{[['tap',[['sendHongbao',['$event']]]]]}}" class="but-class" style="{{'background-color:'+($root.m0)+';'}}" bindtap="__e">发红包</view></view><view class="hb-log" data-url="hongbaolog?type=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">红包记录</view></block></block><block tt:if="{{loading}}"><loading vue-id="c2611bda-1" bind:__l="__l"></loading></block></view>