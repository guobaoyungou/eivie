<view><view class="banner-view" style="{{'background-image:'+('url('+pre_url+'/static/img/watherbg.png)')+';'+('background-color:'+('#89c3f6')+';')}}"></view><view class="position-view"><view class="top-position-view flex flex-bt"><view class="flex flex-y-center"><view class="add-icon"><image src="{{pre_url+'/static/img/water/address_icon.png'}}"></image></view><view class="address-text">{{locationCache.street?locationCache.street:'北京市'}}</view></view><view class="flex flex-y-center nearby-water" data-url="{{'/pagesD/water/stationList?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view>附近水站</view><image class="more-icon" style="margin-top:3rpx;" src="{{pre_url+'/static/img/water/jiantou-bai.png'}}"></image></view></view><view class="pos-options-view water-volume"><view class="volume-top-view flex flex-bt flex-y-center"><view class="flex-col"><view class="title-size-1">打水量</view><view class="title-size-2">先选择打水量，再点击提交订单</view></view><view class="flex-y-center wenti-text" data-phone="{{linktel}}" data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" bindtap="__e"><image class="wenti-icon" src="{{pre_url+'/static/img/water/wenti.png'}}"></image>故障报修</view></view><view class="choose-volume-view flex" style="flex-wrap:wrap;"><block tt:for="{{waterOptions}}" tt:for-item="option" tt:for-index="__i0__" tt:key="id"><view data-event-opts="{{[['tap',[['changeVolume',['$0'],[[['waterOptions','id',option.id,'id']]]]]]]}}" class="{{((volumeIndex==option.id?'options-volume-active':'')+' '+'flex-col flex-xy-center options-volume')}}" bindtap="__e"><view class="volume-num">{{option.dashui_sheng}}</view><view class="price-text">{{"￥"+option.dashui_amount}}</view></view></block></view></view><view data-event-opts="{{[['tap',[['showCouponList',['$event']]]]]}}" class="pos-options-view coupon-view flex-bt" bindtap="__e"><view class="options-title">{{$root.m0}}</view><block tt:if="{{coupons.length>0}}"><block><block tt:for="{{coupons}}" tt:for-item="item" tt:for-index="index"><view class="couponname" style="{{'background:'+($root.m1)+';'}}">{{item.couponname}}</view></block></block></block><block tt:else><block><block tt:if="{{couponNum>0}}"><view class="coupon-choose-view flex-y-center">{{''+couponNum+"张可用"}}<image class="more-icon" style="width:24rpx;height:24rpx;margin-left:10rpx;" src="{{pre_url+'/static/img/water/jiantou.png'}}"></image></view></block><block tt:else><view class="coupon-choose-view flex-y-center" style="color:#999;">{{"无可用"+$root.m2}}</view></block></block></block></view><block tt:if="{{userinfo.score2money>0}}"><view class="pos-options-view coupon-view flex-bt"><checkbox-group data-event-opts="{{[['change',[['scoredk',['$event']]]]]}}" class="flex" style="width:100%;" bindchange="__e"><view class="options-title" style="margin-top:6rpx;">{{$root.m3+"抵扣"}}</view><view class="deduct-view flex flex-bt"><view class="flex flex-y-center"><view class="deduct-assistance">共</view><view class="deduct-price">{{userinfo.score}}</view><view class="deduct-assistance">，可抵</view><view class="deduct-price">{{userinfo.scoredk_money}}</view><view class="deduct-assistance">元</view><view data-event-opts="{{[['tap',[['showExplain']]]]}}" class="deduct-assistance" bindtap="__e"><image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view></view><view style="font-weight:normal;"><checkbox style="transform:scale(0.8);" value="1" checked="{{usescore}}"></checkbox></view></view></checkbox-group></view></block><block tt:if="{{pic_recharge}}"><view class="pos-options-view flex-col" style="margin-top:20rpx;height:127px;padding:0;" data-url="/pagesExt/money/recharge" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:100%;" src="{{pre_url+'/static/img/water/recharge.png'}}"></image></view></block><view class="pos-options-view flex-col" style="margin-top:20rpx;"><view class="options-title">温馨提示</view><view class="parse-view"><parse vue-id="5d01cbce-1" content="{{desc}}" bind:__l="__l"></parse></view></view></view><view style="width:100%;height:calc(30rpx + env(safe-area-inset-bottom));"></view><view class="bottom-but flex-bt"><view class="left-view flex-col"><view class="flex flex-y-center"><view style="font-size:24rpx;padding-right:5rpx;">总价:</view><view class="flex flex-y-center" style="color:#0074FE;font-weight:bold;"><view style="font-size:26rpx;">￥</view><view style="font-size:36rpx;padding:0rpx 5rpx;">{{show_price}}</view></view></view><view class="discount-num">{{"共优惠"+youhui+"元"}}</view></view><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="right-but flex flex-y-center " bindtap="__e">提交订单</view></view><block tt:if="{{showLinkStatus}}"><view class="posterDialog linkDialog"><view class="main"><view data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><view class="row"><view class="f1">联系电话</view><block tt:if="{{linktel}}"><view class="f2 flex-y-center flex-x-bottom" style="{{'width:100%;max-width:470rpx;'+('color:'+($root.m4)+';')}}" data-url="{{'tel::'+linktel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{''+linktel+''}}<block tt:if="{{linktel}}"><image class="copyicon" src="{{pre_url+'/static/img/copy.png'}}" data-text="{{linktel}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" catchtap="__e"></image></block></view></block><block tt:else><view class="f2 flex-y-center flex-x-bottom" style="width:100%;max-width:470rpx;">暂无联系电话</view></block></view></view></view></view></block><block tt:if="{{couponvisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal coupon-modal"><view class="popup__title"><text class="popup__title-text">{{"请选择"+$root.m5}}</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><couponlist vue-id="5d01cbce-2" couponlist="{{couponList}}" choosecoupon="{{true}}" selectedrids="{{couponrids}}" bid="{{bid}}" data-event-opts="{{[['^chooseCoupon',[['chooseCoupon']]]]}}" bind:chooseCoupon="__e" bind:__l="__l"></couponlist></view></view></view></block><block tt:if="{{loading}}"><loading vue-id="5d01cbce-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="5d01cbce-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5d01cbce-5" data-ref="popmsg" bind:__l="__l"></popmsg><wxxieyi vue-id="5d01cbce-6" bind:__l="__l"></wxxieyi></view>