<block tt:if="{{isload}}"><block><view class="container"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank_notext.png'}}" mode="widthFix"></image><view class="title"><view class="t1">每日收款排行榜</view><view class="t2">每日消费排行榜</view></view><view class="top"><view class="t1"><view class="label">我的排名</view><view class="value">{{my_ranking}}</view></view><view class="t2"><text style="color:#9e9e9e;">{{''+(ranktype==1?'累计收款':ranktype==2?'累计消费':'')+"："}}</text>{{my_order_price+''}}</view></view><view class="content"><block tt:if="{{rank_type.length>1}}"><view class="tab1"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{('t1 '+(item.$orig==ranktype?'on':''))}}" style="{{'color:'+(item.$orig==ranktype?item.m0:'')+';'}}" data-ranktype="{{item.$orig}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" bindtap="__e">{{(item.$orig==1?'商家收款':item.$orig==2?'会员消费':'')+''}}<block tt:if="{{item.$orig==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m1)}}"></view></block></view></block></block></view></block><view class="tab"><view class="t1">排名</view><view class="t2">{{ranktype==1?'商家':ranktype==2?'会员':''}}</view><view class="t3">{{ranktype==1?'商家收款':ranktype==2?'会员消费':''}}</view></view><view class="itembox"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" style="{{(index<3?'margin-top:20rpx':'')}}"><block tt:if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block tt:else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3" style="{{'color:'+($root.m2)+';'}}">{{''+item.order_price}}</text></view></block></block></view></view></view><block tt:if="{{nodata}}"><nodata vue-id="5b12b2b4-1" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="5b12b2b4-2" bind:__l="__l"></nomore></block><block tt:if="{{loading}}"><loading vue-id="5b12b2b4-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="5b12b2b4-4" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="5b12b2b4-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block></block>