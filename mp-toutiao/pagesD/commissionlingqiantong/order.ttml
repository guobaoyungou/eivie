<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="fa3b3a0a-1" itemdata="{{['收益明细','本金明细']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><block tt:if="{{st==2}}"><block><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="item-body"><view><view class="row"><text class="label">变后余额：</text><text>{{"￥"+item.$orig.after}}</text></view><view class="row"><text class="label">变动金额：</text><block tt:if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block tt:else><text class="t2">{{item.$orig.money}}</text></block></view><view class="row"><text class="label">创建时间：</text><text>{{item.m0}}</text></view><view class="row"><text class="label">备注：</text><text>{{item.$orig.remark}}</text></view></view></view></view></block></block></block><block tt:if="{{st==1}}"><block><block tt:for="{{$root.l1}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="item-header"><text class="t1">{{item.$orig.day+"天 "+item.$orig.rate+"%"}}</text><text class="t2" style="{{('background:'+(item.$orig.status==1?'#CACACA':'#7DD0BC'))}}">{{item.$orig.status_str}}</text></view><view class="item-body"><view><view class="row"><text class="label">起始本金：</text><text>{{"￥"+item.$orig.start_money}}</text></view><view class="row"><text class="label">累计本金：</text><text>{{"￥"+item.$orig.total_money}}</text></view><block tt:if="{{item.$orig.status==1}}"><block><view class="row"><text class="label">累计收益：</text><text>{{"￥"+item.$orig.yuji_income}}</text></view><view class="row"><text class="label">到期收益：</text><text>{{"￥"+item.$orig.daozhang_money}}</text></view></block></block><block tt:else><block><view class="row"><text class="label">预计收益：</text><text>{{"￥"+item.$orig.yuji_income}}</text></view></block></block><view class="row"><text class="label">创建时间：</text><text>{{item.m1}}</text></view><view class="row"><text class="label">到期时间：</text><text>{{item.m2}}</text></view></view></view></view></block></block></block><block tt:if="{{nodata}}"><nodata vue-id="fa3b3a0a-2" bind:__l="__l"></nodata></block><block tt:if="{{nomore}}"><nomore vue-id="fa3b3a0a-3" bind:__l="__l"></nomore></block><view style="height:20rpx;"></view></block></block><block tt:if="{{loading}}"><loading vue-id="fa3b3a0a-4" bind:__l="__l"></loading></block></view>