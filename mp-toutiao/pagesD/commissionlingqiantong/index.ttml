<view class="container"><block tt:if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的可转入"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.commission}}</view><view class="f3" data-url="order?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>收益明细</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">转入金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" placeholder="请输入转入金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" bindinput="__e"/></view></view><block tt:if="{{income_set.desc}}"><view class="withdraw_desc"><view class="title">说明：</view><text>{{income_set.desc}}</text></view></block></view><view class="withdrawtype"><view class="f1">选择转入周期：</view><view class="f2"><view class="item"><view class="t1">周期产品</view><view class="t1">收益率</view><view class="radio1 "></view></view><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="item" data-paytype="{{index}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1">{{item.$orig.day+"天"}}</view><view class="t1">{{item.$orig.rate+"%"}}</view><view class="radio" style="{{(paytype==index?'background:'+item.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></view></view><view style="height:120rpx;"></view><view class="fixed-bottom"><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m3)+';'}}" bindtap="__e">立即转入</button></view></form></block></block><block tt:if="{{loading}}"><loading vue-id="fb55d812-1" bind:__l="__l"></loading></block><dp-tabbar vue-id="fb55d812-2" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="fb55d812-3" data-ref="popmsg" bind:__l="__l"></popmsg></view>