<block tt:if="{{!loading}}"><block><view class="container"><view class="poster-title"><text>{{detail.name}}</text></view><view class="poster-content"><image class="poster-image" src="{{detail.url}}" mode="widthFix"></image></view><view class="footer-bar"><view class="footer-left"><block tt:if="{{$root.m0!='h5'}}"><button class="footer-btn footer-button" open-type="share"><image class="footer-icon filter" src="{{pre_url+'/static/img/lt_share.png'}}"></image><text>分享</text></button></block><view data-event-opts="{{[['tap',[['collect',['$event']]]]]}}" class="footer-btn" bindtap="__e"><block tt:if="{{is_collected==1}}"><image class="footer-icon" src="{{pre_url+'/static/img/material/collect_active.png'}}"></image></block><block tt:else><image class="footer-icon" src="{{pre_url+'/static/img/material/collect.png'}}"></image></block><text>收藏</text></view></view><view class="footer-right"><button data-event-opts="{{[['tap',[['download',['$event']]]]]}}" class="save-btn" bindtap="__e">保存到相册</button></view></view></view></block></block>