<block tt:if="{{isload}}"><block><view class="container"><view class="{{(('navigation')+' '+((showCustomNav)?'show':''))}}"><view class="custom-nav"><view class="nav-left-icon" data-url="/pagesD/material/collect" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></view><view class="nav-log-box"><image class="nav-logo" src="{{set.logo}}" mode="aspectFit"></image></view></view></view><view class="swiper-container"><swiper class="swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="{{5000}}" indicator-active-color="#ffffff" indicator-color="rgba(255,255,255,0.5)"><block tt:for="{{$root.l0}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block tt:if="{{set.pics&&set.pics.length>0}}"><block><swiper-item class="swiper-item"><block tt:if="{{!item.m0}}"><image src="{{item.$orig}}" mode="aspectFill"></image></block><block tt:else><video src="{{item.$orig}}" autoplay="{{true}}" loop="{{true}}" controls="{{false}}" show-play-btn="{{false}}" show-fullscreen-btn="{{true}}" show-center-play-btn="{{false}}" enable-progress-gesture="{{false}}" object-fit="cover" muted="{{true}}"></video></block></swiper-item></block></block></block></swiper></view><view style="height:450rpx;"></view><view class="content-container flex-bt" style="height:calc(150vh - (450rpx - 180rpx));"><view class="nav-left sticky"><block tt:for="{{navlist}}" tt:for-item="item" tt:for-index="parentIndex" tt:key="parentIndex"><block><view class="nav-header">{{item.name}}</view><block tt:for="{{item.children}}" tt:for-item="child" tt:for-index="childIndex" tt:key="childIndex"><block><view class="{{('nav-items '+(curParentIndex===parentIndex&&curChildIndex===childIndex?'active':''))}}" data-id="{{child.id}}" data-parent="{{parentIndex}}" data-child="{{childIndex}}" data-type="{{child.type}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e">{{''+child.name+''}}</view></block></block></block></block></view><view class="nav-right"><view class="classify-container"><block tt:if="{{classify&&classify.length>0}}"><view class="classify flex"><block tt:for="{{classify}}" tt:for-item="item" tt:for-index="index" tt:key="index"><block><view class="{{(('classify-item')+' '+(item.id===threeid?'active':''))}}" data-id="{{item.id}}" data-type="{{item.type}}" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" bindtap="__e">{{''+item.name+''}}</view></block></block></view></block></view><block tt:if="{{classtype==1}}"><view class="material-columns"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="material-item" data-url="{{'details?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="material-pic"><image class="image" src="{{item.url}}" mode="widthFix"></image></view><view class="material-name">{{item.name}}</view></view></block></view></block><block tt:if="{{classtype==4}}"><view class="imagetext"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="imagetext-item"><view style="padding:20rpx;"><view class="top flex-bt"><view class="head flex"><image class="f1" src="{{set.logo}}"></image><view class="f2"><view class="t1">{{set.name}}</view><view class="t2">{{item.createtime}}</view></view></view></view><view class="con"><view class="f1"><text class="{{((!item.showFullText)?'text-truncate':'')}}" style="white-space:pre-wrap;font-size:24rpx;">{{item.content}}</text></view><block tt:if="{{item.content&&item.content.length>100&&!item.showFullText}}"><view data-event-opts="{{[['tap',[['toggleFullText',[index]]]]]}}" class="view-more" bindtap="__e">查看全文</view></block><block tt:if="{{item.pics}}"><view class="f2"><block tt:for="{{item.pics}}" tt:for-item="pic" tt:for-index="idx" tt:key="idx"><view class="pic-box"><image src="{{pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImageReset',['$0',idx],[[['datalist','id',item.id,'pics']]]]]]]}}" bindtap="__e"></image></view></block></view></block></view></view><view class="bot flex-bt"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savepics',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/material/download.png'}}"></image></view><view class="f4" data-index="{{index}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/material/copy.png'}}"></image></view><view class="f4" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['collect',['$event']]]]]}}" catchtap="__e"><block tt:if="{{item.is_collected==1}}"><image src="{{pre_url+'/static/img/material/collect_active.png'}}"></image></block><block tt:else><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></block></view></view></view></block></view></block><block tt:if="{{nomore}}"><nomore vue-id="2b91868a-1" text="————End————" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="2b91868a-2" text="暂无相关素材" bind:__l="__l"></nodata></block></view></view><block tt:if="{{loading}}"><loading vue-id="2b91868a-3" bind:__l="__l"></loading></block><dp-tabbar vue-id="2b91868a-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="2b91868a-5" data-ref="popmsg" bind:__l="__l"></popmsg></view></block></block>