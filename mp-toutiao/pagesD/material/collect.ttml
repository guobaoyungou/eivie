<block tt:if="{{isload}}"><block><view class="container"><dd-tab vue-id="4367651c-1" itemdata="{{['图片','图文']}}" itemst="{{['1','4']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="item-list"><block tt:if="{{st==1}}"><view class="material-columns"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="material-item" data-url="{{'details?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="material-pic"><image class="image" src="{{item.url}}" mode="widthFix"></image></view><view class="material-name">{{item.name}}</view></view></block></view></block><block tt:if="{{st==4}}"><view class="imagetext"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="id"><view class="imagetext-item"><view style="padding:20rpx;"><view class="top flex-bt"><view class="head flex"><image class="f1" src="{{item.set_logo}}"></image><view class="f2"><view class="t1">{{item.set_name}}</view><view class="t2">{{item.createtime}}</view></view></view></view><view class="con"><view class="f1"><text class="{{((!item.showFullText)?'text-truncate':'')}}" style="white-space:pre-wrap;font-size:24rpx;">{{item.content}}</text></view><block tt:if="{{item.content&&item.content.length>100&&!item.showFullText}}"><view data-event-opts="{{[['tap',[['toggleFullText',[index]]]]]}}" class="view-more" bindtap="__e">查看全文</view></block><block tt:if="{{item.pics}}"><view class="f2"><block tt:for="{{item.pics}}" tt:for-item="pic" tt:for-index="idx" tt:key="idx"><view class="pic-box"><image src="{{pic}}" mode="widthFix" data-url="{{pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></view></block></view></view><view class="bot flex-bt"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savepics',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/material/download.png'}}"></image></view><view class="f4" data-index="{{index}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/material/copy.png'}}"></image></view><view class="f4" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['collect',['$event']]]]]}}" catchtap="__e"><block tt:if="{{item.is_collected==1}}"><image src="{{pre_url+'/static/img/material/collect_active.png'}}"></image></block><block tt:else><image src="{{pre_url+'/static/img/material/collect.png'}}"></image></block></view></view></view></block></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="4367651c-2" text="————End————" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="4367651c-3" text="暂无收藏内容" bind:__l="__l"></nodata></block></view></block></block>