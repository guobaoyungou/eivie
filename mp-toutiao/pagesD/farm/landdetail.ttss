.container{width:100%;min-height:100vh;padding:40rpx;box-sizing:border-box;background-size:cover;background-position:50%;background-attachment:fixed;display:flex;flex-direction:column;align-items:center;justify-content:space-between}.container .title-board{width:60%;position:relative}.container .title-board .background{width:100%}.container .title-board .text{position:absolute;inset:0;display:flex;flex-direction:row;align-items:center;justify-content:center;color:#fff;font-size:40rpx}.container .main{width:100%;display:flex;flex-direction:row;justify-content:space-between;gap:32rpx}.container .main .menu-box{width:20%;display:flex;flex-direction:column;align-items:center;gap:100rpx}.container .main .menu-box .item{width:100%;display:flex;flex-direction:column;align-items:center;position:relative}.container .main .menu-box .item .icon{width:70%}.container .main .menu-box .item .badge{position:absolute;top:-24rpx;right:6rpx;min-width:32rpx;height:32rpx;line-height:32rpx;padding:0 8rpx;background:linear-gradient(135deg,#f44,#f66);color:#fff;font-size:20rpx;font-weight:700;border-radius:16rpx;text-align:center;box-sizing:border-box;box-shadow:0 2rpx 8rpx rgba(255,68,68,.4);z-index:10}.container .main .menu-box .item .label{width:100%;background:linear-gradient(0deg,#ffdd2f,#fff283);padding:6rpx 0;margin-top:-10rpx;box-sizing:border-box;text-align:center;border-radius:20rpx;color:#a07235}.container .main .tree-box{position:relative;width:60%;display:flex;flex-direction:column;align-items:center;align-self:flex-end;margin-top:auto;margin-bottom:0;flex-shrink:0;min-height:-webkit-fit-content;min-height:fit-content}.container .main .tree-box .tree{width:100%;transition:-webkit-transform .6s ease;transition:transform .6s ease;transition:transform .6s ease,-webkit-transform .6s ease}@-webkit-keyframes scaleUp{0%{-webkit-transform:scale(1) translateY(.0001px);transform:scale(1) translateY(.0001px)}100%{-webkit-transform:scale(1.05) translateY(0);transform:scale(1.05) translateY(0)}}@keyframes scaleUp{0%{-webkit-transform:scale(1) translateY(.0001px);transform:scale(1) translateY(.0001px)}100%{-webkit-transform:scale(1.05) translateY(0);transform:scale(1.05) translateY(0)}}.container .main .tree-box .tree.grow{will-change:transform;-webkit-transform:translateZ(0);transform:translateZ(0);-webkit-transform-origin:center bottom;transform-origin:center bottom;-webkit-animation:scaleUp .6s cubic-bezier(.22,.61,.36,1);animation:scaleUp .6s cubic-bezier(.22,.61,.36,1)}.container .main .tree-box .water{position:absolute;width:20rpx;height:20rpx;background:#4fc3f7;border-radius:50%;bottom:200rpx;left:calc(50% - 30rpx);-webkit-animation:water-drop .6s linear forwards;animation:water-drop .6s linear forwards}@-webkit-keyframes water-drop{0%{-webkit-transform:translateY(0) scale(1);transform:translateY(0) scale(1);opacity:1}100%{-webkit-transform:translateY(100rpx) scale(.6);transform:translateY(100rpx) scale(.6);opacity:.1}}@keyframes water-drop{0%{-webkit-transform:translateY(0) scale(1);transform:translateY(0) scale(1);opacity:1}100%{-webkit-transform:translateY(100rpx) scale(.6);transform:translateY(100rpx) scale(.6);opacity:.1}}.container .main .tree-box .bottle{position:absolute;width:60rpx;bottom:160rpx;left:50%;transition:-webkit-transform .3s ease;transition:transform .3s ease;transition:transform .3s ease,-webkit-transform .3s ease}.container .main .tree-box .bottle.pour{-webkit-transform:rotate(-40deg);transform:rotate(-40deg)}.container .main .tree-box .fertilizer{width:28rpx;height:28rpx;background:#caa45a;border-radius:50%;position:absolute;bottom:260rpx;opacity:0;-webkit-animation:fertilizer-drop 1s ease-in-out infinite;animation:fertilizer-drop 1s ease-in-out infinite}.container .main .tree-box .fertilizer.f1{-webkit-animation-delay:0s;animation-delay:0s;left:calc(50% - 80rpx)}.container .main .tree-box .fertilizer.f2{-webkit-animation-delay:.1s;animation-delay:.1s;left:calc(50% - 36rpx)}.container .main .tree-box .fertilizer.f3{-webkit-animation-delay:.2s;animation-delay:.2s;left:calc(50% + 8rpx)}.container .main .tree-box .fertilizer.f4{-webkit-animation-delay:.3s;animation-delay:.3s;left:calc(50% + 52rpx)}@-webkit-keyframes fertilizer-drop{0%{opacity:0;-webkit-transform:translateX(-50%) translateY(0);transform:translateX(-50%) translateY(0)}20%{opacity:1}60%{-webkit-transform:translateX(-50%) translateY(160rpx);transform:translateX(-50%) translateY(160rpx)}80%{opacity:0}100%{opacity:0;-webkit-transform:translateX(-50%) translateY(0);transform:translateX(-50%) translateY(0)}}@keyframes fertilizer-drop{0%{opacity:0;-webkit-transform:translateX(-50%) translateY(0);transform:translateX(-50%) translateY(0)}20%{opacity:1}60%{-webkit-transform:translateX(-50%) translateY(160rpx);transform:translateX(-50%) translateY(160rpx)}80%{opacity:0}100%{opacity:0;-webkit-transform:translateX(-50%) translateY(0);transform:translateX(-50%) translateY(0)}}.container .main .tree-box .shovel{position:absolute;width:60rpx;bottom:280rpx;left:calc(50% - 80rpx);-webkit-animation:sweep 1s linear forwards;animation:sweep 1s linear forwards}@-webkit-keyframes sweep{0%{left:calc(50% - 80rpx);opacity:1}20%{opacity:1}60%{opacity:1}80%{opacity:1}100%{left:calc(50% + 70rpx);opacity:0}}@keyframes sweep{0%{left:calc(50% - 80rpx);opacity:1}20%{opacity:1}60%{opacity:1}80%{opacity:1}100%{left:calc(50% + 70rpx);opacity:0}}.container .main .tree-box .progress-bar{margin-top:10rpx;width:80%;position:relative}.container .main .tree-box .progress-bar .background{width:100%;display:block}.container .main .tree-box .progress-bar .inner{height:32rpx;position:absolute;inset:16% 4.3% 28% 4.3%}.container .main .tree-box .progress-bar .inner .clip-box{width:100%;height:100%;background-repeat:no-repeat;background-size:cover}.container .main .tree-box .progress-bar .progress-text{position:absolute;top:50%;left:50%;-webkit-transform:translate(-50%,-50%);transform:translate(-50%,-50%);z-index:10}.container .main .tree-box .progress-bar .progress-value{color:#fff;font-size:28rpx;font-weight:700;text-shadow:0 2rpx 4rpx rgba(0,0,0,.5),0 0 8rpx rgba(255,221,47,.6);white-space:nowrap}.container .empty-state{width:100%;display:flex;flex-direction:column;align-items:center}.container .empty-state .empty-land{width:100%;opacity:.6}.container .empty-state .plant-prompt{margin-top:20rpx;display:flex;flex-direction:row;align-items:center;gap:12rpx}.container .empty-state .plant-prompt .prompt-icon{font-size:40rpx}.container .empty-state .plant-prompt .prompt-text{font-size:28rpx;color:hsla(0,0%,100%,.8);text-shadow:0 2rpx 4rpx rgba(0,0,0,.3)}.container .empty-state .plant-btn{margin-top:50%;display:flex;flex-direction:row;align-items:center;gap:12rpx;padding:16rpx 48rpx;background:linear-gradient(135deg,#f5a623,#f8b739);border-radius:50rpx;box-shadow:0 6rpx 20rpx rgba(245,166,35,.4)}.container .empty-state .plant-btn .btn-text{font-size:32rpx;font-weight:700;color:#a07235;text-shadow:0 2rpx 4rpx rgba(0,0,0,.2)}.container .empty-state .plant-btn .btn-icon{font-size:28rpx;color:#a07235;font-weight:700}.container .prop-box{width:100%;display:flex;flex-direction:row;align-items:center;gap:16rpx}.container .prop-box .item{width:25%;display:flex;flex-direction:column;align-items:center;position:relative}.container .prop-box .item .icon{width:70%}.container .prop-box .item .badge{position:absolute;top:-22rpx;right:6rpx;min-width:32rpx;height:32rpx;line-height:32rpx;padding:0 8rpx;background:linear-gradient(135deg,#f44,#f66);color:#fff;font-size:20rpx;font-weight:700;border-radius:16rpx;text-align:center;box-sizing:border-box;box-shadow:0 2rpx 8rpx rgba(255,68,68,.4);z-index:10}.container .prop-box .item .label{width:100%;background:linear-gradient(0deg,#ffdd2f,#fff283);padding:6rpx 0;margin-top:-10rpx;box-sizing:border-box;text-align:center;border-radius:20rpx;color:#a07235}.container .prop-box .item .desc{color:#f9fdbc}.container .nwd-content{width:100%;display:flex;flex-direction:column;padding:40rpx;box-sizing:border-box}.container .nwd-content .header{width:100%;display:flex;flex-direction:row;align-items:center;justify-content:space-between;background:#eca043;color:#fff;padding:40rpx;box-sizing:border-box;border-radius:32rpx;font-size:40rpx}.container .nwd-content .middle{width:100%;display:flex;flex-direction:row;align-items:center;justify-content:space-around;padding:20rpx;box-sizing:border-box}.container .nwd-content .list{width:100%;display:flex;flex-direction:column}.container .nwd-content .list .item{width:100%;display:flex;flex-direction:row;align-items:center;background:#e4e4e4;padding:20rpx;box-sizing:border-box;border-radius:32rpx}.container .nwd-content .list .item + .item{margin-top:20rpx}.container .nwd-content .list .item .num{width:90rpx}.container .nwd-content .list .item .media{width:100rpx;display:flex;flex-direction:column;align-items:center}.container .nwd-content .list .item .media .icon{width:100%}.container .nwd-content .list .item .progress-bar{margin:0 10rpx;flex-grow:1;position:relative}.container .nwd-content .list .item .progress-bar .background{width:100%}.container .nwd-content .list .item .progress-bar .inner{position:absolute;inset:20% 4.3% 35% 4.3%}.container .nwd-content .list .item .progress-bar .inner .clip-box{width:100%;height:100%;background-repeat:no-repeat;background-size:cover}.container .nwd-content .list .item .progress{width:80rpx}.container .nwd-content .list .item .button{width:120rpx;background:#fd4a46;color:#fff;border-radius:99999rpx;text-align:center;padding:10rpx;box-sizing:border-box}.score-price{width:123px;top:1vh;left:35vw;position:relative;display:flex;justify-content:center;align-items:center;flex-direction:column}.dp-cover{height:auto;position:relative}.dp-cover-cover{position:fixed;z-index:99999;cursor:pointer;display:flex;align-items:center;justify-content:center;overflow:hidden}.member-card{position:absolute;top:250rpx;left:20rpx;display:flex;flex-direction:row;align-items:center;border-radius:50rpx;padding:12rpx 24rpx 12rpx 12rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.15);-webkit-backdrop-filter:blur(10rpx);backdrop-filter:blur(10rpx);gap:16rpx}.member-avatar{width:80rpx;height:80rpx;border-radius:50%;border:3rpx solid #f5a623;box-shadow:0 2rpx 8rpx rgba(245,166,35,.3);object-fit:cover}.member-info{display:flex;flex-direction:column;gap:8rpx}.member-name{font-size:28rpx;font-weight:700;color:#333;max-width:200rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.member-level{display:flex;flex-direction:row;align-items:center}.level-badge{background:linear-gradient(135deg,#f5a623,#f8b739);color:#fff;font-size:20rpx;font-weight:700;padding:4rpx 16rpx;border-radius:12rpx;box-shadow:0 2rpx 6rpx rgba(245,166,35,.3)}.xieyibox{width:100%;height:100%;position:fixed;top:0;left:0;z-index:99;background:rgba(0,0,0,.7)}.xieyibox-content{width:90%;margin:0 auto;height:60%;margin-top:20%;background:#fff;color:#333;padding:5px 10px 50px 10px;position:relative;border-radius:2px}