<view class="container"><block tt:if="{{isload}}"><block><dd-tab vue-id="131d6aac-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e" bind:__l="__l"></dd-tab><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">{{"我的"+fert_name}}</view><view class="value" style="margin-top:20rpx;">{{remain}}</view><block tt:if="{{show_buy}}"><view class="btn" data-url="/pagesD/farm/buy" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换</view></block></view></view><block tt:if="{{show_ljnum==1}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">累计获得</view><view class="value" style="margin-top:20rpx;">{{ljnum}}</view></view></view></block></view><view class="content"><block tt:for="{{datalist}}" tt:for-item="item" tt:for-index="index" tt:key="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后"+$root.m1+": "+item.after}}</text></view><view class="f2"><block tt:if="{{item.num>0}}"><text class="t1">{{"+"+item.num}}</text></block><block tt:else><text class="t2">{{item.num}}</text></block></view></view></block></view><block tt:if="{{nomore}}"><nomore vue-id="131d6aac-2" bind:__l="__l"></nomore></block><block tt:if="{{nodata}}"><nodata vue-id="131d6aac-3" bind:__l="__l"></nodata></block></block></block><block tt:if="{{loading}}"><loading vue-id="131d6aac-4" bind:__l="__l"></loading></block><dp-tabbar vue-id="131d6aac-5" opt="{{opt}}" bind:__l="__l"></dp-tabbar><popmsg class="vue-ref" vue-id="131d6aac-6" data-ref="popmsg" bind:__l="__l"></popmsg></view>