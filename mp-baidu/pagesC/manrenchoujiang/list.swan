<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="6740e032-1" itemdata="{{['待开奖','已开奖']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="coupon-list"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="coupon" data-url="{{'details?bid='+bid+'&rid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="pt_left"><view class="pt_left-content"><block s-if="{{item.pic}}"><image style="width:100%;max-height:200rpx;border-radius:4rpx;" src="{{item.pic}}" mode="widthFix"></image></block></view></view><view style="width:2rpx;height:100rpx;background-color:#eee;"></view><view class="pt_right"><view class="title" style="{{'color:'+($root.m0)+';'}}">{{item.proname}}</view><view class="t3" style="font-size:24rpx;padding:20rpx 0;"><block s-if="{{st==0}}"><view class="shortcontent">{{item.custom_text}}</view></block><block s-else><view class="shortcontent">{{"第"+item.cycles+"期开奖结果"}}</view></block></view><block s-if="{{st==0}}"><view class="p2" style="padding-bottom:20rpx;"><progress class="my-progress" percent="{{item.percent}}" stroke-width="6" border-radius="10" show-info="{{true}}" font-size="{{14}}" activeColor="#fb743b"></progress></view></block><block s-if="{{st==0}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" data-index="{{index}}" data-proid="{{item.proid}}" data-pic="{{item.pic}}" data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" catchtap="__e">邀请好友</button></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="6740e032-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="6740e032-3"></nodata></block><block s-if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block s-if="{{$root.m3=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m4}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m5!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block s-if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="6740e032-4"></loading></block><dp-tabbar vue-id="6740e032-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="6740e032-6" data-ref="popmsg"></popmsg></view>