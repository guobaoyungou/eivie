<view><block s-if="{{isload}}"><block><view class="container"><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;"></text></text><block s-if="{{item.market_price*1>item.sell_price*1}}"><text class="t2"></text></block></view></view><view class="p3"><view class="t1">商品数量<text style="font-size:28rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">查看详情</text></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="694d1107-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="694d1107-2"></nodata></block></view><button class="covermy" style="{{('background:'+$root.m4)}}" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的订单</button></block></block><block s-if="{{loading}}"><loading vue-id="694d1107-3"></loading></block><dp-tabbar vue-id="694d1107-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="694d1107-5" data-ref="popmsg"></popmsg></view>