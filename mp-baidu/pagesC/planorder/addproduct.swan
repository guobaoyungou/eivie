<view><view style="width:100%;padding:0 24rpx;"><view class="dp-product-itemlist"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="dp-product-item"><view data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" class="item" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><block s-if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><block s-if="{{item.$orig.sellpoint}}"><view class="p5" style="{{'color:'+(item.m0)+';'}}"><text>{{item.$orig.sellpoint}}</text></view></block><block s-if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m1)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m2}}</text></view></block><block s-if="{{item.$orig.show_cost&&item.$orig.price_type!=1}}"><view style="{{'color:'+(item.$orig.cost_color?item.$orig.cost_color:'#999')+';'+('font-size:'+('36rpx')+';')}}"><text style="font-size:24rpx;">{{item.$orig.cost_tag}}</text>{{item.$orig.cost_price}}</view></block><block s-if="{{(!item.$orig.show_sellprice||item.$orig.show_sellprice&&item.$orig.show_sellprice==true)&&(item.$orig.price_type!=1||item.$orig.sell_price>0)}}"><view class="p2"><view class="t1" style="{{'color:'+(item.$orig.price_color?item.$orig.price_color:item.m3)+';'}}"><text style="font-size:24rpx;padding-right:1px;">{{item.$orig.price_tag?item.$orig.price_tag:'￥'}}</text>{{item.$orig.sell_price+''}}<block s-if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block s-if="{{item.$orig.product_unit}}"><text style="font-size:24rpx;">{{"/"+item.$orig.product_unit}}</text></block><block s-if="{{item.m4}}"><text style="font-size:28rpx;">{{"+"+item.$orig.service_fee+item.m5}}</text></block><block s-if="{{item.$orig.product_type==2&&item.$orig.unit_price&&item.$orig.unit_price>0}}"><text class="t1-m" style="{{'color:'+(item.m6)+';'}}">{{'(约'+item.$orig.unit_price+'元/斤)'}}</text></block><block s-if="{{item.$orig.fwlist&&item.$orig.fwlist.length>0}}"><view class="p6"><block s-for="item.$orig.fwlist trackBy fwidx" s-for-item="fw" s-for-index="fwidx"><view class="p6-m" style="{{('background:rgba('+item.m7+',0.15);color:'+item.m8+';')}}">{{''+fw+''}}</view></block></view></block></view><block s-if="{{item.$orig.show_sellprice&&item.$orig.market_price*1>item.$orig.sell_price*1&&showprice=='1'}}"><view class="t2">{{"￥"+item.$orig.market_price}}</view></block><block s-if="{{item.$orig.addstatus<=0}}"><view class="right-btn" style="{{'background-color:'+(item.m9)+';'}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-type="one" data-event-opts="{{[['tap',[['addit',['$event']]]]]}}" catchtap="__e">上橱窗</view></block><block s-else><view class="right-btn" style="background-color:#ddd;">已添加</view></block></view></block><block s-if="{{item.$orig.commission>0}}"><view class="couponitem"><view class="f1"><view class="t" style="{{'background:'+('rgba('+item.m10+',0.1)')+';'+('color:'+(item.m11)+';')}}"><text>{{item.m12+item.$orig.commission+item.$orig.commission_desc}}</text></view></view></view></block></view></view></view></block></view><block s-if="{{nomore}}"><nomore style="width:100%;" vue-id="43e3ce26-1"></nomore></block><block s-if="{{nodata}}"><nodata style="width:100%;" vue-id="43e3ce26-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="43e3ce26-3"></loading></block><view style="width:100%;height:140rpx;clear:both;"></view><view class="{{['bottom-wc',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view>{{"共计"+count+"件商品"}}</view><view class="bottom-btn" style="{{'background-color:'+($root.m13)+';'}}" data-id data-index data-type="all" data-event-opts="{{[['tap',[['addit',['$event']]]]]}}" catchtap="__e">一键添加所有商品</view></view></view><dp-tabbar vue-id="43e3ce26-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="43e3ce26-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="43e3ce26-6"></wxxieyi></view>