<view class="container"><block s-if="{{isload}}"><block><view class="coupon-list"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="coupon" style="{{(!item.$orig.from_mid&&(item.$orig.isgive==1||item.$orig.isgive==2)?'padding-left:40rpx':'')}}" data-url="{{'coupondetail?rid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']],['gtdetail',['$0'],[[['datalist','',index,'type']]]]]]]}}" catchtap="__e"><view class="radiobox" data-index="{{index}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><block s-if="{{!item.$orig.from_mid&&(item.$orig.isgive==1||item.$orig.isgive==2)}}"><view class="radio" style="{{(item.$orig.checked?'background:'+item.m0+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></block></view><view class="pt_left"><view class="pt_left-content"><block s-if="{{item.$orig.type==1}}"><view class="f1" style="{{'color:'+(item.m1)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block s-if="{{item.$orig.type==10}}"><view class="f1" style="{{'color:'+(item.m2)+';'}}"><text class="t1">{{item.$orig.discount/10}}</text><text class="t0">折</text></view></block><block s-if="{{item.$orig.type==3}}"><view class="f1" style="{{'color:'+(item.m3)+';'}}"><text class="t1">{{item.$orig.limit_count}}</text><text class="t2">次</text></view></block><block s-if="{{item.$orig.type==5}}"><view class="f1" style="{{'color:'+(item.m4)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block s-if="{{item.$orig.type==6}}"><view class="f1" style="{{'color:'+(item.m5)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block s-if="{{item.$orig.type!=1&&item.$orig.type!=10&&item.$orig.type!=3&&item.$orig.type!=5&&item.$orig.type!=6}}"><block><view class="f1" style="{{'color:'+(item.m6)+';'}}">{{item.$orig.type_txt}}</view></block></block><block s-if="{{item.$orig.type==1||item.$orig.type==4||item.$orig.type==5||item.$orig.type==10||item.$orig.type==6}}"><view class="f2" style="{{'color:'+(item.m7)+';'}}"><block s-if="{{item.$orig.minprice>0}}"><text>{{"满"+item.$orig.minprice+"元可用"}}</text></block><block s-else><text>无门槛</text></block></view></block></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.$orig.couponname}}</view><block s-if="{{item.$orig.packrid&&item.$orig.num&&item.$orig.num>0}}"><view class="t1" style="{{'color:'+(item.m8)+';'}}">{{"共"+item.$orig.num+"张"}}</view></block><text class="t2" style="{{'background:'+('rgba('+$root.m9+',0.1)')+';'+('color:'+($root.m10)+';')}}">{{item.$orig.type_txt}}</text><block s-if="{{!item.$orig.from_mid&&(item.$orig.isgive==1||item.$orig.isgive==2)}}"><text class="t2" style="{{'background:'+('rgba('+item.m11+',0.1)')+';'+('color:'+(item.m12)+';')}}">可赠送</text></block><block s-if="{{item.$orig.type!=20}}"><view class="t3" style="{{(item.$orig.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"有效期至 "+item.$orig.endtime}}</view></block><block s-if="{{item.$orig.bid>0}}"><view class="t4">{{"适用商家："+item.$orig.bname}}</view></block></view><view><block s-if="{{item.$orig.isgive!=2&&item.$orig.status==0}}"><block><block s-if="{{item.$orig.type==1||item.$orig.type==10}}"><block><block s-if="{{item.m13}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m14+' 0%,rgba('+item.m15+',0.8) 100%)')+';'}}" data-url="{{'/pages/shop/prolist?cpid='+item.$orig.couponid+(item.$orig.bid?'&bid='+item.$orig.bid:'')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去使用</button></block><block s-if="{{item.$orig.fwtype==4}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m16+' 0%,rgba('+item.m17+',0.8) 100%)')+';'}}" data-url="{{'/activity/yuyue/prolist?cpid='+item.$orig.couponid+(item.$orig.bid?'&bid='+item.$orig.bid:'')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去使用</button></block></block></block><block s-else><block s-if="{{item.$orig.type==6}}"><block><block s-if="{{item.m18}}"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m19+' 0%,rgba('+item.m20+',0.8) 100%)')+';'}}" data-url="/hotel/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去使用</button></block></block></block><block s-else><block><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m21+' 0%,rgba('+item.m22+',0.8) 100%)')+';'}}" data-url="{{'coupondetail?rid='+item.$orig.id}}" data-event-opts="{{[['tap',[['gtdetail',['$0'],[[['datalist','',index,'type']]]],['goto',['$event']]]]]}}" catchtap="__e">去使用</button></block></block></block></block></block><block s-if="{{item.$orig.status==1}}"><image class="sygq" src="{{pre_url+'/static/img/ysy.png'}}"></image></block><block s-if="{{item.$orig.status==2}}"><image class="sygq" src="{{pre_url+'/static/img/ygq.png'}}"></image></block></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="38a60769-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="38a60769-2"></nodata></block><block s-if="{{checkednum>0}}"><view class="{{['giveopbox',menuindex>-1?'tabbarbot':'notabbarbot3']}}"><block s-if="{{rdata.is_direct_give}}"><block><button data-event-opts="{{[['tap',[['showDirectGiveShow',['$event']]]]]}}" class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m23+' 0%,rgba('+$root.m24+',0.8) 100%)')+';'}}" bindtap="__e">{{"转赠好友("+checkednum+"张)"}}</button></block></block><block s-else><block><block s-if="{{$root.m25=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m26+' 0%,rgba('+$root.m27+',0.8) 100%)')+';'}}" bindtap="__e">{{"转赠好友("+checkednum+"张)"}}</view></block><block s-else><block s-if="{{$root.m28=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m29+' 0%,rgba('+$root.m30+',0.8) 100%)')+';'}}" bindtap="__e">{{"转赠好友("+checkednum+"张)"}}</view></block><block s-else><block s-if="{{$root.m31=='h5'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m32+' 0%,rgba('+$root.m33+',0.8) 100%)')+';'}}" bindtap="__e">{{"转赠好友("+checkednum+"张)"}}</view></block><block s-else><button class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m34+' 0%,rgba('+$root.m35+',0.8) 100%)')+';'}}" open-type="share">{{"转赠好友("+checkednum+"张)"}}</button></block></block></block></block></block></view></block><view style="display:none;">{{test}}</view><block s-if="{{directGiveShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['showDirectGiveShow',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">- 转赠给好友 -</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['showDirectGiveShow',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content invoiceBox"><form report-submit="true" data-event-opts="{{[['submit',[['directGiveSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="orderinfo"><view class="item"><text class="t1">转赠ID</text><input class="t2" type="text" placeholder="请输入转增ID" placeholder-style="font-size:28rpx;color:#BBBBBB" name="tomid" value="{{tomid}}"/></view></view><button class="btn" style="{{'background:'+($root.m36)+';'}}" form-type="submit">确定</button><view style="padding-top:30rpx;"></view></form></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="38a60769-3"></loading></block><dp-tabbar vue-id="38a60769-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="38a60769-5" data-ref="popmsg"></popmsg></view>