<view class="container"><block s-if="{{isload}}"><block><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center"><view class="avatar-view"><image src="{{userinfo.headimg}}"></image></view><view style="padding-left:20rpx;flex:1;"><view class="user-name flex flex-y-center"><view>{{userinfo.nickname}}</view><view class="tuanzhang-tag flex flex-y-center">{{''+userinfo.levelname+''}}</view></view><view class="reference-name flex flex-y-center"><view class="reference-options">{{$root.m0+"ID："+userinfo.mid}}</view><block s-if="{{!$root.m1}}"><view class="reference-options">{{"邀请码："+userinfo.yqcode}}</view></block><view class="reference-options">{{"推荐人："+userinfo.pid_nickname}}</view></view></view></view></view><view class="rewards-view flex flex-y-center rewards-view-class1"><view class="flex-col flex-y-center" data-url="/activity/commission/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="rewards-top-title">去提现</view></view><view class="flex-col flex-y-center" data-url="/activity/commission/commissionlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="rewards-top-title">{{$root.m2+"明细"}}</view></view><block s-if="{{userinfo.can_agent>0}}"><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="flex-col flex-y-center" catchtap="__e"><view class="rewards-top-title">邀请好友</view></view></block><block s-if="{{userinfo.can_agent<=0}}"><view class="flex-col flex-y-center"><view class="rewards-top-title">无推广权限</view></view></block></view><view class="rewards-view flex flex-y-center rewards-view-class2"><view class="flex flex-y-center" style="justify-content:space-between;flex:1;margin-top:30rpx;"><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">{{"累计"+$root.m3+"(元)"}}</view><view class="rewards-price">{{userinfo.commission}}</view></view><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">{{$root.m4+$root.m5+"(个)"}}</view><view class="rewards-price">{{userinfo.tj_num}}</view></view><view class="flex-col flex-y-center rewards-options"><view class="rewards-text">{{"裂变"+$root.m6+"(个)"}}</view><view class="rewards-price">{{userinfo.team_num}}</view></view></view></view></view><view class="user-info-view flex-col" style="padding-bottom:15rpx;"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center" style="justify-content:space-between;">参团活动产品</view></view><view class="currentScroll" style="overflow-x:scroll;"><block s-if="{{prolist.length>0}}"><view class="prolist"><block s-for="prolist" s-for-item="item2" s-for-index="index2"><view class="product" data-url="{{'/pages/shop/product?id='+item2.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image class="f1" src="{{item2.pic}}"></image><view class="f2">{{"￥"+item2.sell_price}}</view></view></block></view></block></view></view><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['showdescFun',['$event']]]]]}}" bindtap="__e">活动说明</button><view class="user-info-view flex-col"><view class="user-top-view flex flex-y-center"><view class="info-view flex flex-y-center" style="justify-content:space-between;"><view data-event-opts="{{[['tap',[['changeTab',[0]]]]]}}" class="{{[st==0?'tab-options-active':'','tab-options']}}" bindtap="__e">{{$root.m7+$root.m8}}</view><view data-event-opts="{{[['tap',[['changeTab',[1]]]]]}}" class="{{[st==1?'tab-options-active':'','tab-options']}}" bindtap="__e">{{"裂变"+$root.m9}}</view></view></view><block><block s-if="{{datalist.length>0}}"><view class="activity-list-view flex-col"><block s-for="$root.l0" s-for-item="item" s-for-index="index"><block><view class="flex active-options"><view class="active-image"><image src="{{item.$orig.headimg}}"></image></view><view class="active-info-list flex-col"><view class="active-name flex flex-y-center"><view class="name-text">{{item.$orig.nickname}}</view><view class="tag-view">{{item.$orig.path_desc}}</view></view><view class="huiyuan-info flex"><view class="info-options">{{"会员ID："+item.$orig.id}}</view><block s-if="{{!item.m10}}"><view class="info-options">{{"会员邀请码："+item.$orig.yqcode}}</view></block></view><view class="list-view flex flex-x-center"><view class="list-view-options flex-col flex-x-center flex-y-center"><view class="options-title">会员等级</view><view class="options-num-text">{{item.$orig.levelname}}</view></view><view class="list-view-options flex-col flex-x-center flex-y-center"><view class="options-title">{{$root.m11+$root.m12+"(人)"}}</view><view class="options-num-text">{{item.$orig.downcount}}</view></view><view class="list-view-options flex-col flex-x-center flex-y-center" style="margin-right:13rpx;"><view class="options-title">{{"累计"+$root.m13+"(元)"}}</view><view class="options-num-text">{{item.$orig.totalcommission}}</view></view></view></view></view></block></block></view></block><block s-if="{{nodata}}"><nodata vue-id="5abaa27b-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="5abaa27b-2"></nomore></block></block></view></block></block><block s-if="{{loading}}"><loading vue-id="5abaa27b-3"></loading></block><dp-tabbar vue-id="5abaa27b-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5abaa27b-5" data-ref="popmsg"></popmsg><block s-if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block s-if="{{$root.m14!='h5'}}"><button class="f1" open-type="share" data-id="{{share_active_id}}"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block s-if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><block s-if="{{showdesc}}"><view class="xieyibox"><view class="xieyibox-content"><parse vue-id="5abaa27b-6" content="{{active.desc}}"></parse><view class="xieyibut-view flex-y-center"><view data-event-opts="{{[['tap',[['closeDesc',['$event']]]]]}}" class="but-class" style="{{'background:'+($root.m15)+';'}}" bindtap="__e">确定</view></view></view></view></block></view>