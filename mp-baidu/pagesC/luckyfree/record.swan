<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="list-item"><view class="item-row" style="margin-bottom:40rpx;"><view><block s-if="{{activity.business}}"><text class="tag" style="{{'background-color:'+($root.m0)+';'}}">{{activity.business+"免单"}}</text></block><block s-else><text class="tag" style="{{'background-color:'+($root.m1)+';'}}">平台免单</text></block></view><view style="font-weight:bold;">{{"第 "+item.ranking+"名"}}</view><block s-if="{{item.status==0}}"><view style="font-weight:bold;">{{"到达 "+item.opennum+"人开奖"}}</view></block><block s-else><view style="font-weight:bold;"><block s-if="{{item.is_winner}}"><text style="color:red;">已中奖</text></block><block s-else><text style="color:grey;">未中奖</text></block></view></block></view><view class="item-row-text"><text>活动名称</text>{{"："+item.name}}</view><view class="item-row-text"><text>订单号</text>{{"："+item.ordernum}}</view><view class="item-row-text"><text>消费金额</text>{{"："+item.consumption_amt}}</view><view class="item-row-text"><text>参与用户</text>{{"："+item.nickname}}</view><view class="item-row-text"><text>排队时间</text>{{"："+item.createtime}}</view><block s-if="{{item.mdname}}"><view class="item-row-text"><text>所在门店</text>{{"："+item.mdname}}</view></block></view></block></view><block s-if="{{nodata}}"><nodata vue-id="d701128e-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="d701128e-2"></nomore></block></block></block><button data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="coverguize" style="{{'background-color:'+($root.m2)+';'}}" bindtap="__e">活动规则</button><block s-if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule" style="{{'background-color:'+($root.m3)+';'}}"><view class="h2">活动规则</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><block s-if="{{activity.hd&&activity.hd.guize}}"><text decode="true" space="true">{{activity.hd.guize}}</text></block></view></view></view></view></block><block s-if="{{loading}}"><loading vue-id="d701128e-3"></loading></block><dp-tabbar vue-id="d701128e-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="d701128e-5" data-ref="popmsg"></popmsg></view>