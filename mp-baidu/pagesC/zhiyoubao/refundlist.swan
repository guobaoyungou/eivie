<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="64aed58c-1" itemdata="{{['全部','审核中','已审核','已通过','已驳回']}}" itemst="{{['all','1','2','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><block s-if="{{item.binfo}}"><block><block s-if="{{item.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block s-else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></block></block><view class="flex1"></view><block s-if="{{item.refund_status==0}}"><text class="st3">已取消</text></block><block s-if="{{item.refund_status==1}}"><text class="st0">审核中</text></block><block s-if="{{item.refund_status==2}}"><text class="st4" style="color:green;">已审核</text></block><block s-if="{{item.refund_status==3}}"><text class="st2">已通过</text></block><block s-if="{{item.refund_status==4}}"><text class="st2">已驳回</text></block></view><block s-for="item.refundgoods trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view class="detail"><text class="t1">{{item2.fname}}</text><text class="t2">{{item2.realName+" "+item2.certNo}}</text></view></view></block></block><block s-if="{{item.refund_status==3}}"><view class="bottom"><block s-if="{{item.refund_status==3}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block></view></block><view class="op"><view class="btn2" data-url="{{'refundDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block s-if="{{item.refund_status==1}}"><block><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">取消</view></block></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="64aed58c-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="64aed58c-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="64aed58c-4"></loading></block><dp-tabbar vue-id="64aed58c-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="64aed58c-6" data-ref="popmsg"></popmsg></view>