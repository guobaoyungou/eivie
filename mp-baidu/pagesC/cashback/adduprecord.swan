<view class="container"><block s-if="{{isload}}"><block><view class="topfix"><view class="tongji flex-y-center " style="{{'background:'+(color1)+';'}}"><view><view class="price">{{total_back_price}}</view><view>{{"待补"+money_text}}</view></view><view><view class="price">{{total_money}}</view><view>{{"已补"+money_text}}</view></view></view><dd-tab vue-id="72349a4d-1" itemdata="{{['补贴记录','待补记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></view><view style="margin-top:300rpx;"></view><view class="content"><block s-if="{{st==0}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="flex-bt flex-y-center"><view class="f1"><text class="t1"><block s-if="{{item.$orig.type==1&&item.$orig.cashback_name!=''}}"><text>{{item.$orig.cashback_name}}</text></block><block s-else><text>{{"补贴"+money_text}}</text></block>{{"："+item.$orig.money}}</text><text class="t2">{{item.$orig.createtime}}</text><block s-if="{{item.$orig.status==2}}"><text class="t2">{{"过期时间："+(item.$orig.expiretime||'')}}</text></block><block s-if="{{item.$orig.status==1}}"><text class="t2">{{"领取时间："+(item.$orig.collecttime||'')}}</text></block></view><view class="f3"><block s-if="{{item.$orig.status==0}}"><text class="t1" style="color:red;">待领取</text></block><block s-if="{{item.$orig.status==1}}"><text class="t1">已领取</text></block><block s-if="{{item.$orig.status==2}}"><text class="t2">已过期</text></block></view></view><block s-if="{{send_condition==false}}"><view class="flex-x-bottom"><block s-if="{{item.$orig.status==0}}"><view data-event-opts="{{[['tap',[['receiveinit',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m0)+';'}}" bindtap="__e">领取</view></block></view></block></view></block></block></block><block s-if="{{st==1}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item flex-xy-center"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后"+money_text+": "+item.after}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block s-else><text class="t2">{{item.money}}</text></block></view></view></block></block></block></view><block s-if="{{showvideo}}"><view class="video-container" style="height:100vh;"><block s-if="{{!showVideoClose&&this_play_seconds>0}}"><view class="close">{{this_play_seconds+"秒"}}</view></block><block s-if="{{showVideoClose}}"><view data-event-opts="{{[['tap',[['videoClose',['$event']]]]]}}" class="close" bindtap="__e">关闭</view></block><video class="video" style="height:100vh;" id="video" autoplay="{{true}}" controls="{{false}}" src="{{video_url}}" data-event-opts="{{[['timeupdate',[['timeupdate',['$event']]]],['ended',[['videoend',['$event']]]]]}}" bindtimeupdate="__e" bindended="__e"></video></view></block><block s-if="{{send_condition}}"><view data-event-opts="{{[['tap',[['handleSignin',['$event']]]]]}}" class="signing" style="{{(signing?'background-color:rgba(17,17,17,0.3)':'background-color:'+$root.m1)}}" bindtap="__e">{{signing?'已签到':'签到'}}</view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="72349a4d-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="72349a4d-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="72349a4d-4"></loading></block><dp-tabbar vue-id="72349a4d-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="72349a4d-6" data-ref="popmsg"></popmsg></view>