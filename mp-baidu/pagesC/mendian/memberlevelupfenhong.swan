<scroll-view class="pageContainer"><block s-if="{{isload}}"><view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入门店名称搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-if="{{isload}}"><view class="container nodiydata"><block s-for="data trackBy index" s-for-item="item" s-for-index="index"><view class="topcontent"><view class="logo"><image class="img" src="{{item.qrcode}}" data-url="{{item.qrcode}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><view class="title">{{"门店："+item.name}}</view><view class="flex" style="margin-top:40rpx;"><view class="tel" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%, rgba('+$root.m1+',0.8) 100%)')+';'}}"><view class="tel_online" data-url="{{'/activity/commission/fhlog?module=member_levelup&mdid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">分红数据</view></view><view class="tel1" style="{{'background:'+('linear-gradient(90deg,'+$root.m2+' 0%, rgba('+$root.m3+',0.8) 100%)')+';'}}"><view class="tel_online" data-url="{{'/pagesC/mendian/memberleveluplist?mdid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">扫码会员</view></view></view></view></block></view></block></view></block><popmsg class="vue-ref" vue-id="59bb00b4-1" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="59bb00b4-2"></loading></block><wxxieyi vue-id="59bb00b4-3"></wxxieyi></scroll-view>