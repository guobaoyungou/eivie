<view class="container"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="product-item2" data-url="{{'/pages/shop/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.$orig.product.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:22rpx;">￥</text>{{item.$orig.product.sell_price}}</text></view></view></view><view class="foot"><text class="flex1">{{"下单时间："+item.m1}}</text></view></view></block><block s-if="{{nodata}}"><nodata vue-id="2cb66fea-1"></nodata></block><block s-if="{{loading}}"><loading vue-id="2cb66fea-2"></loading></block><dp-tabbar vue-id="2cb66fea-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="2cb66fea-4" data-ref="popmsg"></popmsg></view>