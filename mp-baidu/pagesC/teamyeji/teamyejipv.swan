<view class="container"><block s-if="{{isload}}"><block><view class="content"><view class="topsearch flex-y-center sx"><text class="t1">日期筛选：</text><view data-event-opts="{{[['tap',[['toCheckDate',['$event']]]]]}}" class="body_data" style="min-width:200rpx;" bindtap="__e">{{''+(startDate?startDate:'点击选择日期')+(endDate?' 至 '+endDate:'')+''}}</view><view class="t_date"><block s-if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" bindtap="__e">清除</view></block></view></view><view class="yejilabel"><view class="t1 flex-bt" style="padding:10rpx;"><view>总群服务业绩</view><view>{{userinfo.teamyeji_pv}}</view></view><view class="t1 flex-bt" style="padding:10rpx;"><view>个群服务业绩</view><view>{{userinfo.my_teamyeji_pv}}</view></view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="65223bc4-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="65223bc4-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="65223bc4-3"></loading></block><dp-tabbar vue-id="65223bc4-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="65223bc4-5" data-ref="popmsg"></popmsg></view>