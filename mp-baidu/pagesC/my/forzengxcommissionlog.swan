<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的冻结'+$root.m1+''}}</view><view class="f2">{{myforzengxcommission}}</view></view><dd-tab vue-id="d540160c-1" itemdata="{{['全部','释放中','已结束']}}" itemst="{{['all','0','1']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><view class="t1">{{"总冻结"+$root.m2+"："+item.commission}}</view><view class="t1">{{"未解冻"+$root.m3+"："+item.commission2}}</view><block s-if="{{item.showsendmonth}}"><block><view class="t1">{{"总释放月数："+item.sendmonth}}</view><view class="t1">{{"已释放月数："+item.sendmonth2}}</view></block></block><view class="t1">状态：<block s-if="{{item.status==1}}"><text>已结束</text></block><block s-if="{{item.status==0}}"><text style="color:green;">释放中</text></block></view><view class="t2">{{item.createtime}}</view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="d540160c-2"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="d540160c-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="d540160c-4"></loading></block><dp-tabbar vue-id="d540160c-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="d540160c-6" data-ref="popmsg"></popmsg></view>