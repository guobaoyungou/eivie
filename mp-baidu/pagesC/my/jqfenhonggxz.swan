<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-item"><view class="item-row highlight"><view>{{"贡献值: "+item.gxz}}</view></view><view class="item-row"><view class="column"><text>{{"所属季度: "+item.jd}}</text><text>{{"所属时间: "+item.time}}</text></view></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="53ba7055-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="53ba7055-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="53ba7055-3"></loading></block><dp-tabbar vue-id="53ba7055-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="53ba7055-5" data-ref="popmsg"></popmsg></view>