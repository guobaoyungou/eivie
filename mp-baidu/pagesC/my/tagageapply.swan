<view class="container" style="{{(bgset&&bgset.bgcolor?'background-color:'+bgset.bgcolor:'')}}"><block s-if="{{errmsg==''&&isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><block s-if="{{aglevelCount>0&&!tagid}}"><view class="contentbox"><view class="form-item1"><view class="panel">请选择要申请的：</view><radio-group name="tagid" data-event-opts="{{[['change',[['changelevel',['$event']]]]]}}" bindchange="__e"><block s-for="aglevelList trackBy idx" s-for-item="item" s-for-index="idx"><block><label class="radio-item"><view class="flex1"><text style="font-weight:bold;">{{item.name}}</text></view><block s-if="{{item.id!=userlevel.id}}"><radio value="{{item.id+''}}"></radio></block></label></block></block></radio-group></view></view></block><block s-if="{{selectedLevel}}"><view class="contentbox"><view class="applytj"><view class="f1"><text>{{selectedLevel.name}}</text></view><view class="f2"><block s-if="{{bh_info}}"><view class="t4" style="color:red;font-size:26rpx;margin-bottom:20rpx;">{{bh_info}}</view></block><block s-if="{{selectedLevel.apply_formdata}}"><view class="t4">请填写申请资料</view></block></view></view><view class="applydata"><block s-for="selectedLevel.apply_formdata trackBy item.id" s-for-item="item" s-for-index="idx"><view class="form-item"><view class="label">{{item.val1}}<block s-if="{{item.val3==1}}"><text style="color:red;">*</text></block></view><block s-if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" data-key="{{idx}}" data-event-opts="{{[['input',[['inputchange',['$event']]]]]}}" bindinput="__e"/></block></block><block s-if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx"></textarea></block></block><block s-if="{{item.key=='radio'}}"><block><radio-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}"><block s-for="item.val2 trackBy item1.id" s-for-item="item1" s-for-index="idx1"><label class="flex-y-center"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></block></radio-group></block></block><block s-if="{{item.key=='checkbox'}}"><block><checkbox-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}"><block s-for="item.val2 trackBy item1.id" s-for-item="item1" s-for-index="idx1"><label class="flex-y-center"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></block></checkbox-group></block></block><block s-if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+item.val2[editorFormdata[idx]]}}</view></block><block s-else><view>请选择</view></block></picker></block></block><block s-if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block s-else><view>请选择</view></block></picker></block></block><block s-if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]}}"><view>{{editorFormdata[idx]}}</view></block><block s-else><view>请选择</view></block></picker></block></block><block s-if="{{item.key=='region'}}"><block><uni-data-picker vue-id="{{'65ac425f-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" styleData="width:100%" data-event-opts="{{[['^change',[['onchange']]]]}}" bind:change="__e"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{regiondata}}"/></block></block><block s-if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block s-if="{{editorFormdata[idx]}}"><view class="form-imgbox"><view class="layui-imgbox-close" style="z-index:2;" data-idx="{{idx}}" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-else><view class="form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 50rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" bindtap="__e"></view></block></view></block></block></view></block></view><button class="form-btn" form-type="submit">申 请</button></view></block></form><block s-if="{{nodata}}"><nodata vue-id="65ac425f-2" text="{{nots}}"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="65ac425f-3"></nomore></block></block></block><view style="display:none;">{{test}}</view><block s-if="{{errmsg!=''&&isload}}"><block><view class="zan-box"><view class="zan-text">{{errmsg}}</view></view></block></block><block s-if="{{loading}}"><loading vue-id="65ac425f-4"></loading></block><dp-tabbar vue-id="65ac425f-5" opt="{{opt}}"></dp-tabbar></view>