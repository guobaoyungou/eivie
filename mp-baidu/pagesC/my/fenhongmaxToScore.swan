<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1+"额度"}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.gudong_remain}}</view></view><view class="content2"><view class="item2"><view class="f1">转换额度</view></view><view class="item3"><view class="f1"></view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入转换额度" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><view class="tips-box"><view class="tips">{{'1'+$root.m2+"额度可转换"+sysset.fenhongmax_to_score_bili+$root.m3+''}}</view></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m4)+';'}}" bindtap="__e">立即转换</button></form></block></block><block s-if="{{loading}}"><loading vue-id="29f10986-1"></loading></block><dp-tabbar vue-id="29f10986-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="29f10986-3" data-ref="popmsg"></popmsg></view>