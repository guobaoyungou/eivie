<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入商品名称搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><image src="{{item.pic}}"></image><view class="t2" style="width:540rpx;"><view class="x1 flex-y-center">{{'可用天数：'+(item.day?item.day:0)+'天'}}</view><text class="x2">{{"滤芯名称："+item.name}}</text><block s-if="{{item.txing}}"><view class="x1 flex-y-center" style="margin-top:10rpx;"><button class="btn-mini2" data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">立即更换</button><button class="btn-mini2" style="margin-left:60rpx;" data-tel="{{item.tel}}" data-event-opts="{{[['tap',[['callMendian',['$event']]]]]}}" bindtap="__e">联系客服</button></view></block></view></view></view></block></block></view></block><block s-if="{{nomore}}"><nomore vue-id="ecae6590-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="ecae6590-2"></nodata></block></block></block><popmsg class="vue-ref" vue-id="ecae6590-3" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="ecae6590-4"></loading></block></view>