<view class="container"><block s-if="{{isload}}"><block><block s-if="{{pid<=0}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的抵扣金</view><view class="item flex-bt flex-y-center"><view class="value">{{mydedamount}}</view></view></view></block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block s-if="{{item.dedamount>0}}"><text style="color:green;">{{"+"+item.dedamount}}</text></block><block s-else><text style="color:red;">{{item.dedamount}}</text></block></view><block s-if="{{pid<=0&&item.dedamount>0}}"><view class="t2" style="color:#000;">{{"剩余变动金额："+item.dedamount2}}</view></block></view><view class="f1"><view class="t2">{{"来源："+item.bname}}</view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view><block s-if="{{pid<=0&&item.dedamount>0}}"><view class="f1"><view class="btn2" style="margin:0 auto;" data-url="{{'dedamountlog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看变动金额使用记录</view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="0e6a3666-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="0e6a3666-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="0e6a3666-3"></loading></block><dp-tabbar vue-id="0e6a3666-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0e6a3666-5" data-ref="popmsg"></popmsg></view>