<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><view style="width:200rpx;height:200rpx;"><image style="width:100%;height:100%;" src="{{item.qrcode}}" data-url="{{item.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><view class="t2" style="width:470rpx;"><block s-if="{{item.code}}"><view>{{"随机码："+item.code}}</view></block><view>{{"绑定时间："+item.bindtime}}</view><block s-if="{{canbindsound}}"><block><view style="display:flex;justify-content:space-between;align-items:center;margin:20rpx auto;" data-id="{{item.id}}" data-soundid="{{item.soundid}}" data-event-opts="{{[['tap',[['openSound',['$event']]]]]}}" bindtap="__e"><view>{{"绑定云音响："+item.soundname}}</view><view style="display:flex;align-items:center;"><text>去绑定</text><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></block><view class="unbind" data-id="{{item.id}}" data-event-opts="{{[['tap',[['unbind',['$event']]]]]}}" bindtap="__e">解绑</view></view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="0029bd88-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="0029bd88-2"></nomore></block></block></block><uni-popup class="vue-ref" vue-id="0029bd88-3" id="dialogSound" type="dialog" data-ref="dialogSound" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请选择云音响</text></view><view class="uni-dialog-content"><view class="flex-y-center flex-x-center" style="margin:20rpx 20rpx;"><view style="font-size:28rpx;color:#555;">云音响：</view><picker style="font-size:28rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;min-width:300rpx;" value="{{soundindex}}" range="{{sounds}}" range-key="name" mode="selector" data-event-opts="{{[['change',[['soundChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{soundindex>=0?sounds[soundindex]['name']:'请选择'}}</view></picker></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogSoundClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmSound',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><block s-if="{{loading}}"><loading vue-id="0029bd88-4"></loading></block><dp-tabbar vue-id="0029bd88-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0029bd88-6" data-ref="popmsg"></popmsg></view>