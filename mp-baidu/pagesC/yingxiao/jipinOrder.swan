<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="16b5243a-1" itemdata="{{['全部','未完成','已完成']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入活动名称/订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-item"><view class="item-row highlight"><view>{{"序号: "+item.num}}</view><view><button class="btn-mini2" data-url="{{'jipinCharts?id='+item.id}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">关系图</button></view></view><view class="item-row"><view class="column"><text>{{"所属活动: "+item.collage_jipin_name}}</text><text>{{"订单号: "+item.ordernum}}</text><text>{{"订单商品: "+item.goods_name}}</text><text>{{"时间: "+item.createtime}}</text><block s-if="{{item.status==0}}"><text style="color:#2D66FC;">{{"状态: "+item.status_name}}</text></block><block s-if="{{item.status==1}}"><text style="color:#888;">{{"状态: "+item.status_name}}</text></block><block s-if="{{item.status==1}}"><text style="color:#888;">{{"出局时间："+item.outtime}}</text></block></view></view><view class="item-row"><block s-if="{{item.diff}}"><text class="time">{{item.diff+"后可提现"}}</text></block></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="16b5243a-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="16b5243a-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="16b5243a-4"></loading></block><dp-tabbar vue-id="16b5243a-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="16b5243a-6" data-ref="popmsg"></popmsg></view>