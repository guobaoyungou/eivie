<view class="container"><block s-if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><block s-if="{{cardlist.length>0}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="top"><block s-if="{{item.$orig.status==1}}"><view class="cardbg" style="{{('background: '+item.m0)}}"></view></block><block s-else><view class="cardbg"></view></block><view class="hyk flex"><view class="f1"><image src="{{set.logo}}"></image></view><view class="f2"><text class="t1">{{set.name}}</text><text class="t2">{{item.$orig.card_no}}</text><block s-if="{{item.$orig.status==-1}}"><text class="t3">已挂失</text></block><block s-if="{{item.$orig.status==0}}"><text class="t3">停用</text></block></view></view><view class="fr"><view class="btn-mini" data-cardno="{{item.$orig.card_no}}" data-event-opts="{{[['tap',[['unbind',['$event']]]]]}}" catchtap="__e">解绑</view></view></view></block></block></block><block s-else><block><block s-if="{{set.bind_card_status==1}}"><block><view class="title">请扫码进行绑定</view><view class="inputdiv"><input id="cardno" type="text" name="cardno" placeholder-style="color:#666;" placeholder="请输入您的卡号" value="{{cardno}}"/><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" bindtap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></view><button class="btn" form-type="submit">绑 定</button></block></block></block></block></form></block></block><block s-if="{{loading}}"><loading vue-id="6c1a091d-1"></loading></block><dp-tabbar vue-id="6c1a091d-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="6c1a091d-3" data-ref="popmsg"></popmsg><wxxieyi vue-id="6c1a091d-4"></wxxieyi></view>