<view><block s-if="{{isload}}"><block><view class="form-box"><view class="form-item flex-col" style="{{(substatus==-1?'border:0':'')}}"><view class="f1">详情</view><view class="f2"><parse vue-id="69b185de-1" content="{{task.content}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" bind:navigate="__e"></parse></view></view><block s-if="{{substatus>=0}}"><view class="form-item flex-col" style="border:0;"><view class="f1">上传凭证</view><view class="f2" style="flex-wrap:wrap;"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><block s-if="{{substatus}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{substatus&&pics.length<picnum}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g0}}"/></view></block><block s-if="{{log}}"><block><view class="form-item" style="border:0;"><view class="f1">审核状态</view><view class="f2"><block s-if="{{log.status==-1}}"><view style="color:red;"><view>已驳回</view></view></block><block s-if="{{log.status==0}}"><view>审核中</view></block><block s-if="{{log.status==1}}"><view style="color:green;">已通过</view></block></view></view><block s-if="{{log.status==-1&&log.checkreason}}"><view style="color:red;">{{'驳回原因：'+log.checkreason+''}}</view></block></block></block><block s-if="{{substatus==1}}"><button data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" class="savebtn" style="{{('background-color:'+$root.m0)}}" bindtap="__e">提交</button></block><view style="height:20rpx;"></view></view><view style="height:40rpx;"></view></block></block><popmsg class="vue-ref" vue-id="69b185de-2" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="69b185de-3"></loading></block></view>