<view><block s-if="{{isload}}"><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="task"><view data-url="{{'logdetail?logid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view>{{'任务时间：'+item.$orig.daytime+''}}</view><view class="taskprogress">任务进度:<progress style="width:360rpx;margin-left:4rpx;" percent="{{item.$orig.taskprogress}}" show-info="{{true}}" stroke-width="4" border-radius="4"></progress></view><block s-if="{{item.$orig.status>=0&&(item.$orig.givescore>0||item.$orig.givecouponid>0&&item.$orig.givecouponname)}}"><view>完成奖励：<block s-if="{{item.$orig.givescore>0}}"><text>{{'+'+item.$orig.givescore+item.m0}}</text></block><block s-if="{{item.$orig.givecouponid>0&&item.$orig.givecouponname}}"><text style="{{(item.$orig.givescore>0?'margin-left: 10rpx;':'')}}">{{'+'+item.$orig.givecouponname+item.m1}}</text></block></view></block><view>任务状态：<block s-if="{{item.$orig.status==-1}}"><text style="color:#999;">已关闭</text></block><block s-if="{{item.$orig.status==0}}"><text>未完成</text></block><block s-if="{{item.$orig.status==1}}"><text style="color:green;">已完成</text></block></view></view><image class="imgback" src="{{pre_url+'/static/img/location/right-black.png'}}"></image></view></block><block s-if="{{nomore}}"><nomore vue-id="86a109aa-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="86a109aa-2"></nodata></block></view></block><block s-if="{{loading}}"><loading vue-id="86a109aa-3"></loading></block><dp-tabbar vue-id="86a109aa-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="86a109aa-5" data-ref="popmsg"></popmsg></view>