<view class="container"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="product-item2" data-url="{{'/pagesExt/mingpian/index?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="data" style="{{'background:'+(item.bgpic?'url('+item.bgpic+')':'#fff')+';'+('background-size:'+('100% 100%')+';')}}"><view class="data_info" style="{{(field_list2?'':'border:0;margin:0')}}"><image class="data_head _img" src="{{item.headimg}}" alt></image><view><view class="data_name">{{item.realname}}</view><block s-if="{{item.touxian1}}"><view class="data_text">{{item.touxian1}}</view></block><block s-if="{{item.touxian2}}"><view class="data_text">{{item.touxian2}}</view></block><block s-if="{{item.touxian3}}"><view class="data_text">{{item.touxian3}}</view></block></view></view><block s-for="field_list2" s-for-item="item2" s-for-index="index2"><view class="data_list"><block s-if="{{index2=='tel'}}"><image src="{{pre_url+'/static/images/tel.png'}}" alt class="_img"></image></block><block s-else><block s-if="{{index2=='weixin'}}"><image src="{{pre_url+'/static/images/weixin.png'}}" alt class="_img"></image></block><block s-else><block s-if="{{index2=='address'}}"><image src="{{pre_url+'/static/images/address.png'}}" alt class="_img"></image></block><block s-else><image src="{{item2.icon}}" alt class="_img"></image></block></block></block>{{''+item[index2]+''}}</view></block></view></view></view></block><block s-if="{{nomore}}"><nomore vue-id="e4720532-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="e4720532-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="e4720532-3"></loading></block><dp-tabbar vue-id="e4720532-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="e4720532-5" data-ref="popmsg"></popmsg></view>