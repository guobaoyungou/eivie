<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['topay',['$event']]]]]}}" bindsubmit="__e"><block s-if="{{needaddress==0}}"><view class="address-add"><view class="linkitem"><block s-if="{{contact_require==1||is_pingce}}"><label style="color:red;">*</label></block><text class="f1">联 系 人：</text><input class="input" type="text" placeholder="请输入您的姓名" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputLinkman',['$event']]]]]}}" value="{{linkman}}" bindinput="__e"/></view><block s-if="{{is_pingce}}"><view class="linkitem"><block s-if="{{contact_require==1||is_pingce}}"><label style="color:red;">*</label></block><text class="f1">性 别：</text><picker class="input" mode="selector" range="{{sexlist}}" data-event-opts="{{[['change',[['bindPickerChangeSex',['$event']]]]]}}" bindchange="__e"><block s-if="{{gender}}"><view>{{''+gender}}</view></block><block s-else><view>请选择</view></block></picker></view></block><view class="linkitem"><block s-if="{{contact_require==1||is_pingce}}"><label style="color:red;">*</label></block><text class="f1">联系电话：</text><input class="input" type="text" placeholder="请输入您的手机号" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputTel',['$event']]]]]}}" value="{{tel}}" bindinput="__e"/></view><block s-if="{{worknum_status}}"><view class="linkitem"><text class="f1">工号：</text><input class="input" type="number" placeholder="{{worknumtip}}" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputWorknum',['$event']]]]]}}" value="{{worknum}}" bindinput="__e"/></view></block><block s-if="{{is_pingce}}"><view class="linkitem"><block s-if="{{contact_require==1||is_pingce}}"><label style="color:red;">*</label></block><text class="f1">邮箱：</text><input class="input" type="text" placeholder="请输入您的邮箱" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputEmail',['$event']]]]]}}" value="{{pc