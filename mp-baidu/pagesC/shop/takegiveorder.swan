ock><block s-else><view>请选择</view></block></picker><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block><block s-if="{{is_pingce}}"><view class="linkitem"><text class="f1">班级：</text><input class="input" type="text" placeholder="请输入您的班级" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputClassName',['$event']]]]]}}" bindinput="__e"/></view></block></view></block><block s-else><view class="address-add flex-y-center"><view class="flex-y-center " style="flex:1;" data-url="{{'/pagesB/address/'+(address.id?'address':'addressadd')+'?fromPage=buy&source=shop&type='+(havetongcheng==1?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" style="width:66rpx;height:66rpx;margin-right:20rpx;" src="{{pre_url+'/static/img/address.png'}}"></image><block s-if="{{address.id}}"><view class="f2" style="flex:1;"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block s-if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address}}</view></view></block><block s-else><view class="f2 flex1">请选择收货地址</view></block><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block s-if="{{worknum_status}}"><view class="linkitem" style="margin:20rpx;line-height:50rpx;"><text class="f1" style="width:90rpx;margin-right:0;">工号：</text><input class="input" type="text" placeholder="{{worknumtip}}" placeholder-style="color:#626262;font-size:28rpx" data-event-opts="{{[['input',[['inputWorknum',['$event']]]]]}}" value="{{worknum}}" bindinput="__e"/></view></block><block s-if="{{needusercard}}"><view class="linkitem" style="margin:20rpx;line-height:50rpx;"><text class="f1" style="width:140rpx;margin-right:0;">身份证号：</text><input class="input" type="text" placeholder="{{usercardtip}}" placeholder-style="color:#626262;font-size:28rpx" data-ev