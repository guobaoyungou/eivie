<view class="container"><block s-if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><block s-if="{{ordergoods}}"><view class="form-content"><view class="product"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="content"><view class="radio" style="{{(item.$orig.issel?'border:0;background:'+item.m0:'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" bindtap="__e"><image class="radio-img" style="width:100%;height:100%;" mode="widthFix" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="detail" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" bindtap="__e"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.cardNo}}</text></view></view></block></view></view></block><button data-event-opts="{{[['tap',[['changeapply',['$event']]]]]}}" class="ref-btn" bindtap="__e">确定</button></form><block s-if="{{loading}}"><loading vue-id="dc8caf64-1"></loading></block><dp-tabbar vue-id="dc8caf64-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="dc8caf64-3" data-ref="popmsg"></popmsg></block></block></view>