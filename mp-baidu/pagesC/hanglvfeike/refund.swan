<view class="container"><block s-if="{{isload}}"><block><form report-submit="true" data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><block s-if="{{ordergoods}}"><view class="form-content"><view class="product"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="content"><view class="radio" style="{{(item.$orig.issel?'border:0;background:'+item.m0:'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" bindtap="__e"><image class="radio-img" style="width:100%;height:100%;" mode="widthFix" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="detail" data-index="{{index}}" data-event-opts="{{[['tap',[['chooseit',['$event']]]]]}}" bindtap="__e"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.cardNo}}</text></view></view></block></view></view></block><view class="form-item"><text class="label">退款原因</text><view class="input-item"><textarea style="width:100%;border:2rpx solid #f1f1f1;border-radius:4rpx;padding:10rpx;" placeholder="请输入退款原因" placeholder-style="color:#999;padding: 10rpx;" name="reason"></textarea></view></view><block s-if="{{showpic}}"><view class="form-item flex-col"><view class="label">上传图片</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="pics"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pics.length<3}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view></view></block><button class="ref-btn" form-type="submit">确定</button></form><block s-if="{{loading}}"><loading vue-id="c94e0cf4-1"></loading></block><dp-tabbar vue-id="c94e0cf4-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="c94e0cf4-3" data-ref="popmsg"></popmsg></block></block></view>