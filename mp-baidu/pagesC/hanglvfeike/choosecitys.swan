<view style="height:100%;background-color:#fff;"><block s-if="{{isload}}"><block><view style="width:750rpx;height:100%;"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索城市名称或拼音" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]],['focus',[['searchFocus',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e" bindfocus="__e"/><block s-if="{{searchshow}}"><view data-event-opts="{{[['tap',[['closeSearch',['$event']]]]]}}" class="camera" style="{{('background-image:url('+pre_url+'/static/img/ico-del.png)')}}" bindtap="__e"></view></block></view></view><view style="width:100%;height:100rpx;"></view><view style="width:100%;height:calc(100% - 100rpx);"><block s-if="{{letterlist&&letterlist.length>0}}"><scroll-view style="width:100%;height:100%;" scrollIntoView="{{intoviewid}}" scrollWithAnimation="{{animation}}" scroll-y="true"><view style="line-height:80rpx;font-size:28rpx;" id="letterpos"><view class="title" style="display:flex;justify-content:space-between;"><view>当前城市</view><view data-event-opts="{{[['tap',[['checkLocation',['$event']]]]]}}" style="{{('color:'+$root.m0)}}" bindtap="__e">重新定位</view></view><block s-if="{{poslist&&poslist.length>0}}"><view style="width:100%;padding:0 20rpx;"><block s-for="poslist trackBy index" s-for-item="item" s-for-index="index"><view class="hotname" style="background-color:#af1e24;color:#fff;border:0;" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" bindtap="__e">{{''+item.name+''}}</view></block></view></block></view><block s-if="{{hotlist&&hotlist.length>0}}"><view style="line-height:80rpx;font-size:28rpx;" id="letterhot"><view class="title">热门城市</view><block s-if="{{hotlist&&hotlist.length>0}}"><view style="width:100%;padding:0 20rpx;"><block s-for="hotlist trackBy index" s-for-item="item" s-for-index="index"><view class="hotname" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" bindtap="__e">{{''+item.name+''}}</view></block></view></block></view></block><block s-for="letterlist trackBy index" s-for-item="item" s-for-index="index"><view style="line-height:80rpx;font-size:28rpx;" id="{{'letter'+item.letter}}"><view class="title">{{item.letter}}</view><block s-if="{{item.childs&&item.childs.length>0}}"><view style="width:100%;padding:0 20rpx;"><block s-for="item.childs trackBy index2" s-for-item="item2" s-for-index="index2"><view class="hotname" data-name="{{item2.name}}" data-code="{{item2.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" bindtap="__e">{{''+item2.name+''}}</view></block></view></block></view></block></scroll-view></block></view><view style="position:fixed;right:0;top:20%;width:50rpx;text-align:center;font-size:24rpx;line-height:45rpx;"><block s-if="{{letterlist&&letterlist.length>0}}"><scroll-view scrollWithAnimation="{{animation}}" scroll-y="true"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view style="{{(index===currentActiveIndex?'color:'+item.m1:'')}}" data-letter="{{item.$orig.letter}}" data-index="{{index}}" data-event-opts="{{[['tap',[['toviewid',['$event']]]]]}}" bindtap="__e">{{''+item.$orig.letter+''}}</view></block></block></scroll-view></block></view><block s-if="{{searchshow}}"><view style="{{'background-color:#fff;position:fixed;top:80rpx;left:0;width:100%;border-top:2rpx solid #f1f1f1;line-height:80rpx;'+('height:'+('calc(100% + 80rpx)')+';')}}"><block s-for="searchlist trackBy index" s-for-item="item" s-for-index="index"><view class="cityname" id="{{'letter'+index}}"><view class="cityname-item" data-name="{{item.name}}" data-code="{{item.code}}" data-event-opts="{{[['tap',[['selit',['$event']]]]]}}" bindtap="__e">{{item.name+" "+item.code}}</view></view></block></view></block></view></block></block><block s-if="{{loading}}"><loading vue-id="03e1c8cf-1"></loading></block><dp-tabbar vue-id="03e1c8cf-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar></view>