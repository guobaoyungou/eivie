<block s-if="{{isload}}"><view><block s-if="{{showyejidata}}"><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view><block s-if="{{set.cashback_multiply_yeji_type==0}}"><view class="top-data-list flex flex-y-center"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日释放</view><view class="num-text">{{cashback_total.today_release}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">今日新增</view><view class="num-text">{{cashback_total.today_add}}</view></view></view></block></view></block><dd-tab vue-id="138291d8-1" itemdata="{{[$root.m1+'列表','已完成记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-item"><view class="item-row"><view class="column"><text>{{"发放数量: "+item.back_price}}</text><text>{{"剩余数量: "+item.remain}}</text></view><view class="column"><text>{{"释放数量: "+(item.have_send||0)}}</text><block s-if="{{showLastCircleYeji}}"><text>{{"上期业绩: "+(item.last_circle_yeji||0)}}</text></block></view></view><view class="item-row highlight"><block s-if="{{item.status!=2}}"><text>{{"上期释放: "+item.last_circle_send}}</text></block><block s-if="{{item.status==2}}"><text>已完成</text></block></view><view class="item-row"><text class="time">{{item.createtime}}</text><block><button class="btn-mini2" data-url="{{'/pagesC/releasePoints/ogdetails?og_id='+item.sog_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看明细</button></block></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="138291d8-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="138291d8-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="138291d8-4"></loading></block><dp-tabbar vue-id="138291d8-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="138291d8-6" data-ref="popmsg"></popmsg></view></block>