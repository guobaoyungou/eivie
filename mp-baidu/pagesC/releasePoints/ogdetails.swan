<block s-if="{{isload}}"><view><block s-if="{{showyejidata}}"><view class="top-view flex-col" style="{{'background:'+($root.m0)+';'}}"><block s-if="{{showHaveRelease}}"><view class="points-view flex-col"><view class="points-title-view flex"><image class="icon-class" src="{{pre_url+'/static/img/jifen-F.png'}}"></image>已释放</view><view class="points-num">{{cashback_total.have_release}}</view></view></block><block s-if="{{showRemainRelease||showLastCircleYeji||showNextCircleYeji}}"><view class="top-data-list flex flex-y-center"><block s-if="{{showRemainRelease}}"><view class="data-options flex-col"><view class="title-text">待释放</view><view class="num-text">{{cashback_total.remain_release}}</view></view></block><block s-if="{{showRemainRelease&&showLastCircleYeji}}"><view class="line-class"></view></block><block s-if="{{showLastCircleYeji}}"><view class="data-options flex-col"><view class="title-text">上期平台业绩</view><view class="num-text">{{cashback_total.last_circle_yeji}}</view></view></block><block s-if="{{showLastCircleYeji&&showNextCircleYeji}}"><view class="line-class"></view></block><block s-if="{{showNextCircleYeji}}"><view class="data-options flex-col"><view class="title-text">下期平台业绩</view><view class="num-text">{{cashback_total.next_circle_yeji}}</view></view></block></view></block></view></block><view class="list-title-view">释放日记</view><block s-for="datalist" s-for-item="item" s-for-index="index"><block><view class="options-view flex-bt"><view class="left-view flex-col"><view class="left-title">{{item.remark}}</view><view class="time-text">{{item.create_time}}</view></view><block s-if="{{item.is_yuji==1}}"><view class="price-view" style="color:green;">{{item.back_price}}</view></block><block s-else><view class="price-view">{{item.back_price}}</view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="1d06bfd4-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="1d06bfd4-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="1d06bfd4-3"></loading></block><dp-tabbar vue-id="1d06bfd4-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1d06bfd4-5" data-ref="popmsg"></popmsg></view></block>