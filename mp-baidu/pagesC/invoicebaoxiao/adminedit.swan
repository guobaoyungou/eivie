<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item"><view>发票真伪<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="authenticity" data-event-opts="{{[['change',[['authenticityChange',['$event']]]]]}}" bindchange="__e"><label><radio value="1" checked="{{info.authenticity==1?true:false}}"></radio>发票为真</label><label><radio value="-1" checked="{{info.authenticity==-1?true:false}}"></radio>发票存疑</label><label><radio value="0" checked="{{info.authenticity==0?true:false}}"></radio>待辩真伪</label></radio-group></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">扣除积分<text style="color:red;">*</text></view><view class="f2"><input type="digit" name="deduct_score" placeholder="请填写扣除积分" placeholder-style="color:#888" value="{{info.deduct_score}}"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">报销金额<text style="color:red;">*</text></view><view class="f2"><input type="digit" name="money" placeholder="请填写报销金额" placeholder-style="color:#888" value="{{info.money}}"/></view></view><view class="form-item"><view>支付方式<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="paytype" data-event-opts="{{[['change',[['paytypeChange',['$event']]]]]}}" bindchange="__e"><label><radio value="支付宝" checked="{{info.paytype=='支付宝'?true:false}}"></radio>支付宝</label><label><radio value="银行卡" checked="{{info.paytype=='银行卡'?true:false}}"></radio>银行卡</label><label><radio value="收款码" checked="{{info.paytype=='收款码'?true:false}}"></radio>收款码</label></radio-group></view></view></view><block s-if="{{info.paytype=='支付宝'}}"><view class="form-box"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">真实姓名<text style="color:red;">*</text></view><view class="f2"><input type="text" name="aliaccountname" placeholder="请填写真实姓名" placeholder-style="color:#888" value="{{info.aliaccountname}}"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">支付宝账号<text style="color:red;">*</text></view><view class="f2"><input type="text" name="aliaccount" placeholder="请填写支付宝账号" placeholder-style="color:#888" value="{{info.aliaccount}}"/></view></view></view></block><block s-if="{{info.paytype=='银行卡'}}"><view class="form-box"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">开户行<text style="color:red;">*</text></view><view class="f2"><picker class="picker" mode="selector" name="bankname" value="0" range="{{banklist}}" data-event-opts="{{[['change',[['bindBanknameChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{bankname}}"><view>{{bankname}}</view></block><block s-else><view>请选择开户行</view></block></picker></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">所属分支行<text style="color:red;">*</text></view><view class="f2"><input type="text" name="bankaddress" placeholder="请填写所属分支行" placeholder-style="color:#888" value="{{info.bankaddress}}"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">持卡人姓名<text style="color:red;">*</text></view><view class="f2"><input type="text" name="bankcarduser" placeholder="请填写持卡人姓名" placeholder-style="color:#888" value="{{info.bankcarduser}}"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">银行卡号<text style="color:red;">*</text></view><view class="f2"><input type="text" name="bankcardnum" placeholder="请填写银行卡号" placeholder-style="color:#888" value="{{info.bankcardnum}}"/></view></view></view></block><block s-if="{{info.paytype=='收款码'}}"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">微信收款码</view><view class="f2"><block s-for="wxpaycode trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="wxpaycode" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{wxpaycode.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="wxpaycode" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="wxpaycode" maxlength="-1" value="{{$root.g0}}"/></view><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">支付宝收款码</view><view class="f2"><block s-for="alipaycode trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="alipaycode" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{alipaycode.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="alipaycode" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="alipaycode" maxlength="-1" value="{{$root.g1}}"/></view></view></block><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form></block></block><block s-if="{{loading}}"><loading vue-id="0a1d66f9-1"></loading></block><popmsg class="vue-ref" vue-id="0a1d66f9-2" data-ref="popmsg"></popmsg><wxxieyi vue-id="0a1d66f9-3"></wxxieyi></view>