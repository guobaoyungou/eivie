<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="3036eb9d-1" itemdata="{{['全部','待审核','已通过','已驳回','已关闭']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'recorddetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><view class="t2"><text class="x1">报销记录</text><text class="x2">{{"记录编号："+item.id}}</text><text class="x2">{{"扣除"+$root.m0+"："+item.deduct_score}}</text><text class="x2">{{"打款金额："+item.money}}</text><text class="x2">{{"提交日期："+item.createtime}}</text></view></view><view class="f2"><block s-if="{{item.status==0}}"><text class="t1 red">待审核</text></block><block s-if="{{item.status==1}}"><text class="t1 green">已通过</text></block><block s-if="{{item.status==2}}"><text class="t1 yellow">已驳回</text></block><block s-if="{{item.status==1&&item.payment_status==2}}"><text class="t1 green">已打款</text></block><block s-if="{{item.status==3&&item.payment_status==3}}"><text class="t1">已关闭</text></block></view></view><block s-if="{{item.status==0}}"><view class="op"><view class="btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除</view></view></block></block></block></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="3036eb9d-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="3036eb9d-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="3036eb9d-4"></loading></block><dp-tabbar vue-id="3036eb9d-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="3036eb9d-6" data-ref="popmsg"></popmsg></view>