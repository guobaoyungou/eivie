<view><block s-if="{{isload}}"><block><view class="container"><view class="topbg"><image class="image" src="{{pre_url+'/static/img/collage_teambg.png'}}"></image></view><view class="topbox" data-url="{{'product?id='+product.id+'&teampid='+teamid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><image src="{{product.pic}}"></image></view><view class="right"><view class="f1">{{product.name}}</view><view class="f2"><block s-if="{{!product.collage_type}}"><view class="t1">{{product.teamnum+"人团"}}</view></block></view><view class="f3"><view class="t1">￥</view><view class="t2">{{product.sell_price}}</view><view class="t3">{{product.sales+"人已拼"}}</view></view></view></view><view class="teambox"><view class="userlist"><block s-for="userlist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><image class="f1" src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image><block s-if="{{item.tuanzhang==1}}"><text class="f2">团长</text></block><block s-if="{{item.nickname!=''}}"><text>{{item.nickname}}</text></block><block s-else><view style="height:40rpx;"></view></block></view></block></view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="44a205ff-1"></loading></block><dp-tabbar vue-id="44a205ff-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="44a205ff-3" data-ref="popmsg"></popmsg></view>