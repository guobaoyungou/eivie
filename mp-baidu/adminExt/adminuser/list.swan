<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入账号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"账号列表（共"+count+"人）"}}</text><view class="btn" data-url="edit" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加管理员</view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><view class="t2"><view class="x1 flex-y-center">{{''+item.un+''}}</view><block><text class="x2">{{"最后登录："+item.logintime}}</text><text class="x2">{{"加入时间："+item.createtime}}</text><block s-if="{{item.groupname}}"><text class="x2">{{"所属权限组："+item.groupname}}</text></block></block></view></view><block><view class="f2"><view class="btn" data-url="{{'edit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">编辑</view><block s-if="{{item.isadmin==0&&item.id!=userid}}"><view class="btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" bindtap="__e">删除</view></block></view></block></view></block></block></view></block><block s-if="{{nomore}}"><nomore vue-id="25673e65-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="25673e65-2"></nodata></block></block></block><popmsg class="vue-ref" vue-id="25673e65-3" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="25673e65-4"></loading></block></view>