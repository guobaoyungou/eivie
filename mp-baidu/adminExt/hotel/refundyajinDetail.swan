<view class="container"><block s-if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop_refund.jpg);background-size:100%')}}"><block s-if="{{detail.refund_status==0}}"><view class="f1"><view class="t1">已取消</view></view></block><block s-if="{{detail.refund_status==1}}"><view class="f1"><view class="t1">待审核</view></view></block><block s-if="{{detail.refund_status==2}}"><view class="f1"><view class="t1">审核通过，已退款</view></view></block><block s-if="{{detail.refund_status==-1}}"><view class="f1"><view class="t1">驳回</view></view></block></view><view class="product"><block s-for="prolist trackBy idx" s-for-item="item" s-for-index="idx"><view class="content"><view data-url="{{'/pages/shop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><text class="t2">{{item.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.refund_num}}</text></view></view></view></block></view><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view><view class="orderinfo"><view class="item"><text class="t1">退货单编号</text><text class="t2" user-select="true" selectable="true">{{detail.refund_ordernum}}</text></view><view class="item"><text class="t1">申请退款金额</text><text class="t2 red">{{"¥"+detail.refund_money}}</text></view><view class="item"><text class="t1">申请时间</text><text class="t2">{{detail.apply_time}}</text></view><block s-if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block s-if="{{detail.refund_status==0}}"><text class="t2 grey">已取消</text></block><block s-if="{{detail.refund_status==1}}"><text class="t2 red">待审核</text></block><block s-if="{{detail.refund_status==2}}"><text class="t2 red">已退款</text></block><block s-if="{{detail.refund_status==-1}}"><text class="t2 red">已驳回</text></block></view></block><block s-if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block s-if="{{order.status>0&&order.paytypeid!='4'&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block s-if="{{order.status>0&&order.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{order.paytype}}</text></view></block><block s-if="{{order.status>1&&order.daodian_time}}"><view class="item"><text class="t1">入住时间</text><text class="t2">{{order.daodian_time}}</text></view></block><block s-if="{{order.status==3&&order.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{order.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">订单状态</text><block s-if="{{order.status==0}}"><text class="t2">未付款</text></block><block s-if="{{order.status==1}}"><text class="t2">已付款</text></block><block s-if="{{order.status==2}}"><text class="t2">待入住</text></block><block s-if="{{order.status==3}}"><text class="t2">已入住</text></block><block s-if="{{order.status==4}}"><text class="t2">已完成</text></block></view></view><view style="width:100%;height:120rpx;"></view><view class="bottom"><block s-if="{{detail.refund_status==1}}"><block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundnopassShow',['$event']]]]]}}" bindtap="__e">驳回</view><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundpass',['$event']]]]]}}" bindtap="__e">退款通过</view></block></block></view><uni-popup class="vue-ref" vue-id="3c050c21-1" id="dialogSetremark" type="dialog" data-ref="dialogSetremark" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('3c050c21-2')+','+('3c050c21-1')}}" mode="input" title="确定要驳回申请吗？" value="{{detail.remark}}" placeholder="请输入备注" data-event-opts="{{[['^confirm',[['refundnopass']]]]}}" bind:confirm="__e"></uni-popup-dialog></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="3c050c21-3"></loading></block><dp-tabbar vue-id="3c050c21-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="3c050c21-5" data-ref="popmsg"></popmsg></view>