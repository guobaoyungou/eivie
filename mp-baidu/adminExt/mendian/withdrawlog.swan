<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="32a1add3-1" itemdata="{{['全部','待审核','已审核','已驳回']}}" itemst="{{['all','0','1','2']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'withdrawdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="headimg"><image src="{{item.$orig.headimg}}"></image></view><view class="f1"><text class="t1">{{"社区名称："+item.$orig.xqname}}</text><view class="t3">提现金额：<text class="t3_3" style="{{'color:'+($root.m0)+';'}}">{{item.$orig.money}}</text>元</view><text class="t2">{{item.m1}}</text></view><view class="op"><block s-if="{{item.$orig.status==0}}"><view class="st0">待审核</view></block><block s-if="{{item.$orig.status==1}}"><view class="st1">已审核</view></block><block s-if="{{item.$orig.status==2}}"><view class="st2">已驳回</view></block><block s-if="{{item.$orig.status==3}}"><view class="st3">已打款</view></block></view><button class="btn" style="{{('background:rgba('+$root.m2+',0.9)')}}" data-id="{{item.$orig.id}}">查看详情</button></view></block></view><block s-if="{{nomore}}"><nomore vue-id="32a1add3-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="32a1add3-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="32a1add3-4"></loading></block><dp-tabbar vue-id="32a1add3-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="32a1add3-6" data-ref="popmsg"></popmsg></view>