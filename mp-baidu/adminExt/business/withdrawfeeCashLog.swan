<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入用户昵称或订单号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{datalist&&datalist.length>0}}"><block><view class="content"><view class="item"><view class="left"><view class="f2"><view class="t2">{{"提现金额："+item.money}}</view><view class="t2">{{"现金支付比例："+item.withdrawfee_cash_rate+"%"}}</view><view class="t2">{{"支付会员："+item.nickname}}</view><text class="t2">{{"支付时间："+item.paytime}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><block s-if="{{item.paynum}}"><text class="t2">{{"支付单号："+item.paynum}}</text></block></view></view><view class="right"><view><view class="money" style="{{'color:'+($root.m0)+';'}}">{{"￥"+item.money}}</view></view></view></view></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="2cbe237c-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="2cbe237c-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="2cbe237c-3"></loading></block><popmsg class="vue-ref" vue-id="2cbe237c-4" data-ref="popmsg"></popmsg></view>