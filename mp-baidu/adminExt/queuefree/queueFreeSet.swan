<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><block s-if="{{set.activity_time_custom}}"><block><view class="form-item"><view>活动时间设置</view><view><radio-group class="radio-group" name="activity_time_status" data-event-opts="{{[['change',[['',['$event']]]]]}}" bindchange="__e"><label><radio value="0" checked="{{!info||info.activity_time_status==0?true:false}}"></radio>关闭</label><label><radio value="1" checked="{{info.activity_time_status==1?true:false}}"></radio>开启</label></radio-group></view></view><view class="form-item"><view class="f1">活动时间</view><view class="f2"><picker class="picker" mode="date" name="activity_time_start" value="{{info.activity_time_start}}" data-event-opts="{{[['change',[['activityTimeStartChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{info.activity_time_start}}"><view>{{info.activity_time_start}}</view></block><block s-else><view>请选择</view></block></picker><view style="padding:0 20rpx;">~</view><picker class="picker" mode="date" name="activity_time_end" value="{{info.activity_time_end}}" data-event-opts="{{[['change',[['activityTimeEndChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{info.activity_time_end}}"><view>{{info.activity_time_end}}</view></block><block s-else><view>请选择</view></block></picker></view></view></block></block><block s-if="{{set.business_own_mode_custom&&platform_set.business_own_mode_st==1}}"><block><view class="form-item"><radio-group data-event-opts="{{[['change',[['modechange',['$event']]]]]}}" bindchange="__e"><block s-for="modeitems trackBy index" s-for-item="item" s-for-index="index"><label class="flex" style="height:60rpx;line-height:60rpx;"><view><radio value="{{index}}" checked="{{index==mode}}"></radio></view><view>{{item}}</view></label></block></radio-group></view><block s-if="{{mode==1}}"><view class="form-item2"><view><view class="item flex-y-center"><text class="label">平均返最低金额：</text><view class="input-item flex-y-center"><input name="pj_min_money" type="digit" placeholder="0不限制，最低0.01元" placeholder-style="color:#999;" value="{{info.pj_min_money}}"/>元</view></view></view><view class="desc">根据自己的订单消费金额在整个订单当中的总金额占比，来进行分配,最新下单+最早下单不超过50%</view></view></block><block s-if="{{mode==2}}"><view class="form-item2"><view><view class="item flex-y-center"><text class="label">最新下单比例：</text><view class="input-item flex-y-center"><input name="new_order_ratio" type="digit" placeholder="请输入最新下单比例" placeholder-style="color:#999;" value="{{info.new_order_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">最早下单比例：</text><view class="input-item flex-y-center"><input name="old_order_ratio" type="digit" placeholder="请输入最早下单比例" placeholder-style="color:#999;" value="{{info.old_order_ratio}}"/>%</view></view></view><view class="desc">根据自己的订单消费金额在整个订单当中的总金额占比，来进行分配,最新下单+最早下单不超过50%</view></view></block><block s-if="{{mode==3}}"><view class="form-item2"><view><view class="item flex-y-center"><text class="label">平均补贴比例：</text><view class="input-item flex-y-center"><input name="pjmoney_pj_ratio" type="digit" placeholder="请输入最新下单比例" placeholder-style="color:#999;" value="{{info.pjmoney_pj_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">平均返最低金额：</text><view class="input-item flex-y-center"><input name="pjmoney_pj_min_money" type="digit" placeholder="请输入最早下单比例" placeholder-style="color:#999;" value="{{info.pjmoney_pj_min_money}}"/>元</view></view><view class="item flex-y-center"><text class="label">金额补贴比例：</text><view class="input-item flex-y-center"><input name="pjmoney_money_ratio" type="digit" placeholder="请输入金额补贴比例" placeholder-style="color:#999;" value="{{info.pjmoney_money_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">最新下单比例：</text><view class="input-item flex-y-center"><input name="pjmoney_new_order_ratio" type="digit" placeholder="请输入最新下单比例" placeholder-style="color:#999;" value="{{info.pjmoney_new_order_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">最早下单比例：</text><view class="input-item flex-y-center"><input name="pjmoney_old_order_ratio" type="digit" placeholder="请输入最早下单比例" placeholder-style="color:#999;" value="{{info.pjmoney_old_order_ratio}}"/>%</view></view></view><view class="desc">平均补贴+金额补贴必须等于 100%，最新下单+最早下单不超过50%</view></view></block><block s-if="{{mode==4}}"><view class="form-item2"><view><view class="item flex-y-center"><text class="label">固定比例：</text><view class="input-item flex-y-center"><input name="pjfixed_fixed_ratio" type="digit" placeholder="请输入固定比例" placeholder-style="color:#999;" value="{{info.pjfixed_fixed_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">平均返最低金额：</text><view class="input-item flex-y-center"><input name="pjfixed_pj_min_money" type="digit" placeholder="请输入最早下单比例" placeholder-style="color:#999;" value="{{info.pjfixed_pj_min_money}}"/>元</view></view></view><view class="desc">平均比例 = 总返利比例(%) - 固定比例(%)</view></view></block><block s-if="{{mode==5}}"><view class="form-item2"><view><view class="item flex-y-center"><text class="label">固定比例：</text><view class="input-item flex-y-center"><input name="today_fixed_ratio" type="digit" placeholder="请输入固定比例" placeholder-style="color:#999;" value="{{info.today_fixed_ratio}}"/>%</view></view><view class="item flex-y-center"><text class="label">今日平均比例：</text><view class="input-item flex-y-center"><input name="today_pj_ratio" type="digit" placeholder="请输入今日平均比例" placeholder-style="color:#999;" value="{{info.today_pj_ratio}}"/>元</view></view><view class="item flex-y-center"><text class="label">非今日平均：</text><view class="input-item flex-y-center"><input name="today_other_ratio" type="digit" placeholder="请输入非今日平均" placeholder-style="color:#999;" value="{{info.today_other_ratio}}"/>元</view></view></view><view class="desc">固定比例(%)+ 今日平均比例(%) + 非今日平均(%)  100%</view></view></block></block></block></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form></block></block><block s-if="{{loading}}"><loading vue-id="51447001-1"></loading></block></view>