<view><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><block s-if="{{status==2}}"><view class="form-options" style="padding:10rpx 0;color:red;">{{'文章未审核通过，驳回原因：'+info.reason+''}}</view></block><view class="form-view flex flex-col"><view class="form-options flex flex-bt flex-y-center"><view class="options-title">标题</view><view class="options-input"><input name="name" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章标题" value="{{info.name}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">描述</view><view class="options-input"><input name="subname" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章描述" value="{{info.subname}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">作者</view><view class="options-input"><input name="author" type="text" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章作者" value="{{info.author}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">分类</view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" bindtap="__e"><block s-if="{{cids.length>0}}"><text style="line-height:normal;">{{cnames}}</text></block><block s-else><text style="font-size:28rpx;color:#BFBFCB;">请选择</text></block></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">阅读量</view><view class="options-input"><input name="readcount" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入文章阅读量" value="{{info.readcount}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="options-title">序号</view><view class="options-input"><input name="sort" placeholder-style="font-size:28rpx;color: #BFBFCB;" placeholder="请输入序号" value="{{info.sort}}"/></view></view><view class="form-options flex flex-bt flex-y-center"><view class="option