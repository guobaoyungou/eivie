<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="7434f77d-1" itemdata="{{['全部','待付款','已付款','进行中','已完成','已取消']}}" itemst="{{['all','0','1','2','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><block s-if="{{item.$orig.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.binfo.name}}</view></block><block s-else><view>{{"订单号："+item.$orig.ordernum}}</view></block><view class="flex1"></view><block s-if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.$orig.status==1&&item.$orig.refund_status==0}}"><text class="st1">已付款</text></block><block s-if="{{item.$orig.status==1&&item.$orig.refund_status==1}}"><text class="st1">退款审核中</text></block><block s-if="{{item.$orig.status==2}}"><text class="st0">进行中</text></block><block s-if="{{item.$orig.status==3}}"><text class="st4">已完成</text></block><block s-if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.$orig.product.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.title}}</text><text class="t2"><text>{{'价格：￥'+item.$orig.price+' /小时'}}</text></text><block s-if="{{item.$orig.cid==1||item.$orig.cid==3}}"><text class="t2"><text>购买时长</text>{{'：x '+item.$orig.num+"小时"}}</text></block><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.$orig.totalprice}}</text></view></view></view><block s-if="{{item.$orig.refund_status!=0}}"><view class="bottom"><block s-if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block s-if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去付款</view></block></block><block s-if="{{item.$orig.status==1}}"><block><block s-if="{{item.$orig.totalprice==0}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">取消订单</view></block><block s-if="{{item.$orig.totalprice>0&&(item.$orig.refund_status==0||item.$orig.refund_status==3)}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block></block></block><block s-if="{{item.$orig.status==3||item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchtap="__e">删除订单</view></block></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="7434f77d-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="7434f77d-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="7434f77d-4"></loading></block><dp-tabbar vue-id="7434f77d-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7434f77d-6" data-ref="popmsg"></popmsg></view>