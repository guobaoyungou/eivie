<view class="container"><block s-if="{{isload}}"><block><form style="width:100%;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><view class="title">会员消费</view><view class="inputdiv"><input id="code" type="text" name="code" placeholder-style="color:#666;" placeholder="请输入会员码" value="{{code}}"/><block s-if="{{platform!='h5'}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="scanicon" bindtap="__e"><image src="{{pre_url+'/static/img/scan-icon2.png'}}"></image></view></block></view><button class="btn" form-type="submit">确定</button></form></block></block><popmsg class="vue-ref" vue-id="1ce815f3-1" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="1ce815f3-2"></loading></block><wxxieyi vue-id="1ce815f3-3"></wxxieyi></view>