<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">ID</view><view class="f2">{{info.id}}</view></view><view class="form-item"><view class="f1">昵称</view><view class="f2">{{info.nickname}}</view></view></view><view class="form-box"><view class="form-item flex-col"><text>详细介绍</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" bindtap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" bindtap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" bindtap="__e">+视频</view></view><view><block s-for="pagecontent trackBy index" s-for-item="setData" s-for-index="index"><block><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" bindtap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" bindtap="__e">下移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveEdit',['$event']]]]]}}" bindtap="__e">编辑</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" bindtap="__e">删除</view></view><view class="detailbox"><block s-if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'675ad5f6-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-notice></block></block><block s-if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'675ad5f6-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-banner></block></block><block s-if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'675ad5f6-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-search></block></block><block s-if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'675ad5f6-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}" selectable="{{true}}"></dp-text></block></block><block s-if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'675ad5f6-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-title></block></block><block s-if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'675ad5f6-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-dhlist></block></block><block s-if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'675ad5f6-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-line></block></block><block s-if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'675ad5f6-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-blank></block></block><block s-if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'675ad5f6-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-menu></block></block><block s-if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'675ad5f6-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-map></block></block><block s-if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'675ad5f6-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-cube></block></block><block s-if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'675ad5f6-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}" preview="{{true}}"></dp-picture></block></block><block s-if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'675ad5f6-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-pictures></block></block><block s-if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'675ad5f6-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-video></block></block><block s-if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'675ad5f6-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}"></dp-shop></block></block><block s-if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'675ad5f6-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}"></dp-product></block></block><block s-if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'675ad5f6-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-collage></block></block><block s-if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'675ad5f6-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-kanjia></block></block><block s-if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'675ad5f6-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-seckill></block></block><block s-if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'675ad5f6-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-scoreshop></block></block><block s-if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'675ad5f6-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-coupon></block></block><block s-if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'675ad5f6-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-article></block></block><block s-if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'675ad5f6-23-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-business></block></block><block s-if="{{setData.temp=='liveroom'}}"><block><dp-liveroom vue-id="{{'675ad5f6-24-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-liveroom></block></block><block s-if="{{setData.temp=='button'}}"><block><dp-button vue-id="{{'675ad5f6-25-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-button></block></block><block s-if="{{setData.temp=='hotspot'}}"><block><dp-hotspot vue-id="{{'675ad5f6-26-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-hotspot></block></block><block s-if="{{setData.temp=='cover'}}"><block><dp-cover vue-id="{{'675ad5f6-27-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-cover></block></block><block s-if="{{setData.temp=='richtext'}}"><block><dp-richtext vue-id="{{'675ad5f6-28-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-richtext></block></block><block s-if="{{setData.temp=='form'}}"><block><dp-form vue-id="{{'675ad5f6-29-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-form></block></block><block s-if="{{setData.temp=='userinfo'}}"><block><dp-userinfo vue-id="{{'675ad5f6-30-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-userinfo></block></block></view></view></block></block></view></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form><uni-popup class="vue-ref" vue-id="675ad5f6-31" id="dialogDetailtxt" type="dialog" data-ref="dialogDetailtxt" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请输入文本内容</text></view><view class="uni-dialog-content"><textarea placeholder="请输入文本内容" data-event-opts="{{[['input',[['catcheDetailtxt',['$event']]]]]}}" value="{{edit_index!=-1?pagecontent[edit_index].params.showcontent:''}}" bindinput="__e"></textarea></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['dialogDetailtxtConfirm',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-popup-dialog__close" bindtap="__e"><label class="uni-popup-dialog__close-icon  _span"></label></view></view></uni-popup></block></block><view style="display:none;">{{test}}</view><block s-if="{{loading}}"><loading vue-id="675ad5f6-32"></loading></block><popmsg class="vue-ref" vue-id="675ad5f6-33" data-ref="popmsg"></popmsg><wxxieyi vue-id="675ad5f6-34"></wxxieyi></view>