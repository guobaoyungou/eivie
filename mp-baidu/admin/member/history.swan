<view class="container"><block s-if="{{isload}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="product-item2" data-url="{{(item.$orig.type=='shop'?'/pages/':'/activity/')+item.$orig.type+'/product?id='+item.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><block s-if="{{item.$orig.product&&item.$orig.product.pic}}"><image src="{{item.$orig.product.pic}}" mode="widthFix"></image></block></view><block s-if="{{item.$orig.type=='scoreshop'}}"><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+(item.m0)+';'}}">{{item.$orig.product.score_price+item.m1}}</text><text class="t2">{{"市场价￥"+item.$orig.product.sell_price}}</text></view><view class="p3"><block s-if="{{item.$orig.product.sales>0}}"><text class="t1">已兑换<text style="font-size:24rpx;color:#f40;padding:0 2rpx;">{{item.$orig.product.sales}}</text>件</text></block><block s-else><block s-if="{{item.$orig.product.sellpoint}}"><text class="t2">{{item.$orig.product.sellpoint}}</text></block></block></view></view></block><block s-else><view class="product-info"><view class="p1">{{item.$orig.product.name}}</view><view class="p2"><text class="t1" style="{{'color:'+(item.m2)+';'}}"><text style="font-size:22rpx;">￥</text>{{item.$orig.product.sell_price}}</text><block s-if="{{item.$orig.product.market_price*1>item.$orig.product.sell_price*1}}"><text class="t2">{{"￥"+item.$orig.product.market_price}}</text></block></view><view class="p3"><block s-if="{{item.$orig.product.sales>0}}"><text class="t1">已售<text style="font-size:24rpx;color:#f40;padding:0 2rpx;">{{item.$orig.product.sales}}</text>件</text></block><block s-else><block s-if="{{item.$orig.product.sellpoint}}"><text class="t2">{{item.$orig.product.sellpoint}}</text></block></block></view></view></block></view><view class="foot"><text class="flex1">{{"浏览时间："+item.$orig.createtime}}</text></view></view></block></block></block><block s-if="{{nomore}}"><nomore vue-id="8d38abec-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="8d38abec-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="8d38abec-3"></loading></block><dp-tabbar vue-id="8d38abec-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="8d38abec-5" data-ref="popmsg"></popmsg></view>