<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">商品名称<text style="color:red;">*</text></view><view class="f2"><input type="text" name="name" placeholder="请填写商品名称" placeholder-style="color:#888" value="{{info.name}}"/></view></view><view class="form-item"><view class="f1">商品分类<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="f2" bindtap="__e"><block s-if="{{cids.length>0}}"><text style="line-height:normal;">{{cnames}}</text></block><block s-else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><block s-if="{{bid>0}}"><view class="form-item"><view class="f1">商家商品分类<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClist2Dialog',['$event']]]]]}}" class="f2" bindtap="__e"><block s-if="{{cids2.length>0}}"><text>{{cnames2}}</text></block><block s-else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><view class="form-item"><view class="f1">商品分组</view><view data-event-opts="{{[['tap',[['changeGlistDialog',['$event']]]]]}}" class="f2" bindtap="__e"><block s-if="{{gids.length>0}}"><text class="class-text-limit">{{gnames}}</text></block><block s-else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="form-item"><view class="f1">商品编码</view><view class="f2"><input type="text" name="procode" placeholder="请填写商品编码" placeholder-style="color:#888" value="{{info.procode}}"/></view><block s-if="{{$root.m0!='h5'}}"><view data-event-opts="{{[['tap',[['scanprocode',['$event']]]]]}}" style="width:70rpx;height:70rpx;margin-top:15rpx;" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/admin/saoyisao.png'}}"></image></view></block></view><view class="form-item"><view class="f1">商品卖点</view><view class="f2"><input type="text" name="sellpoint" placeholder="请填写商品卖点" placeholder-style="color:#888" value="{{info.sellpoint}}"/></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">商品主图<text style="color:red;">*</text></view><view class="f2"><block s-for="pic trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view><view class="form-item flex-col"><view class="f1">商品图片</view><view class="f2" style="flex-wrap:wrap;"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pics.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view></view><view class="form-box"><view class="form-item flex-col"><view class="f1">设置规格</view><view class="flex-col"><view class="ggtitle"><view class="t1">规格分组</view><view class="t2">规格名称</view></view><block s-for="guigedata trackBy index" s-for-item="gg" s-for-index="index"><view class="ggcontent"><view class="t1" data-index="{{index}}" data-title="{{gg.title}}" data-event-opts="{{[['tap',[['delgggroupname',['$event']]]]]}}" bindtap="__e">{{gg.title}}<image class="edit" src="{{pre_url+'/static/img/edit2.png'}}"></image></view><view class="t2"><block s-for="gg.items trackBy index2" s-for-item="ggitem" s-for-index="index2"><view class="ggname" data-index="{{index}}" data-index2="{{index2}}" data-title="{{ggitem.title}}" data-k="{{ggitem.k}}" data-event-opts="{{[['tap',[['delggname',['$event']]]]]}}" bindtap="__e">{{ggitem.title}}<image class="close" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="ggnameadd" data-index="{{index}}" data-event-opts="{{[['tap',[['addggname',['$event']]]]]}}" bindtap="__e">+</view></view></view></block><view class="ggcontent"><view data-event-opts="{{[['tap',[['addgggroupname',['$event']]]]]}}" class="ggadd" bindtap="__e">添加分组</view></view></view></view></view><block s-for="gglist trackBy index" s-for-item="item" s-for-index="index"><view class="form-box"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">规格</view><view class="f2" style="font-weight:bold;line-height:40rpx;">{{item.name}}</view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">市场价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="market_price" name="{{'market_price['+index+']'}}" placeholder="请填写市场价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.market_price}}" bindinput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">成本价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="cost_price" name="{{'cost_price['+index+']'}}" placeholder="请填写成本价" placeholder-style="color:#888" disabled="{{cost_bili_with_edit==0}}" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.cost_price}}" bindinput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">销售价（元）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="sell_price" name="{{'sell_price['+index+']'}}" placeholder="请填写销售价" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.sell_price}}" bindinput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">重量（克）</view><view class="f2"><input type="text" data-index="{{index}}" data-field="weight" name="{{'weight['+index+']'}}" placeholder="请填写重量" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.weight}}" bindinput="__e"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1" style="position:relative;">库存<block s-if="{{item.isstock_warning==1}}"><block><view class="stockwarning"><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/workorder/ts.png'}}"></image>库存不足</view></block></block></view><view class="f2"><input type="text" data-index="{{index}}" data-field="stock" name="{{'stock['+index+']'}}" placeholder="请填写库存" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.stock}}" bindinput="__e"/></view></view><block s-if="{{bid<=0||business_selfscore==1}}"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">{{"赠"+$root.m1+"(个)"}}</view><view class="f2"><input type="text" data-index="{{index}}" data-field="givescore" name="{{'givescore['+index+']'}}" placeholder="请填写赠送数量" placeholder-style="color:#888" data-event-opts="{{[['input',[['gglistInput',['$event']]]]]}}" value="{{item.givescore}}" bindinput="__e"/></view></view></block><view class="form-item"><view class="f1">规格图片</view><view class="f2" style="flex-wrap:wrap;margin-top:20rpx;margin-bottom:20rpx;"><block s-if="{{item.pic!=''}}"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-event-opts="{{[['tap',[['removeimg2',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item.pic}}" data-url="{{item.pic}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-else><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['uploadimg2',['$event']]]]]}}" bindtap="__e"></view></block></view></view></view></block><view class="form-box"><view class="form-item"><view class="f1">配送模板</view><view class="f2"><picker value="{{freightindex}}" range="{{freighttypeArr}}" data-event-opts="{{[['change',[['freighttypeChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{freighttypeArr[freightindex]}}</view></picker><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><block s-if="{{freightindex==1}}"><view class="form-item flex-col"><view class="f1">选择模板</view><view class="f2 flex-col"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="freightitem" style="width:100%;" data-index="{{index}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['changeFrieght',['$event']]]]]}}" bindtap="__e"><view class="f1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m2?'background:'+item.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></block><block s-if="{{freightindex==2}}"><view class="form-item flex-col"><view class="f1">发货信息</view><view class="f2 flex-col"><textarea style="height:160rpx;min-height:160rpx;font-size:28rpx;" name="freightdata" placeholder="请输入发货信息" placeholder-style="color:#888;font-size:28rpx" maxlength="-1" value="{{info.freightdata}}"></textarea></view></view></block><block s-if="{{freightindex==3}}"><view class="form-item flex-col" style="color:#999;">请在电脑端后台上传卡密信息</view></block></view><view class="form-box"><view class="form-item"><view class="f1">销量</view><view class="f2"><input type="text" name="sales" placeholder="请填写销量" placeholder-style="color:#888" value="{{info.sales}}"/></view><input type="text" hidden="true" name="oldsales" value="{{info.id?info.sales:'0'}}"/></view><view class="form-item"><view class="f1">起售数量</view><view class="f2"><input type="text" name="limit_start" placeholder="0表示不限制" placeholder-style="color:#888" value="{{info.limit_start}}"/></view></view><view class="form-item"><view class="f1">每人限购</view><view class="f2"><input type="text" name="perlimit" placeholder="0表示不限购" placeholder-style="color:#888" value="{{info.perlimit}}"/></view></view><view class="form-item"><view class="f1">序号</view><view class="f2"><input type="text" name="sort" placeholder="用于排序,越大越靠前" placeholder-style="color:#888" value="{{info.sort}}"/></view></view></view><block s-if="{{product_showset==1}}"><view class="form-box"><view class="form-item flex-col"><view class="f1">购买条件</view><view class="f2" style="line-height:30px;"><checkbox-group class="radio-group" name="gettj" data-event-opts="{{[['change',[['bindGettjChange',['$event']]]]]}}" bindchange="__e"><label><checkbox value="-1" checked="{{$root.m4?true:false}}"></checkbox>所有人</label><label><checkbox value="0" checked="{{$root.m5?true:false}}"></checkbox>关注用户</label><block s-for="$root.l1 trackBy item.$orig.id" s-for-item="item" s-for-index="__i0__"><label><checkbox value="{{''+item.$orig.id}}" checked="{{item.m6?true:false}}"></checkbox>{{''+item.$orig.name}}</label></block></checkbox-group></view></view></view></block><block s-if="{{product_showset==1}}"><view class="form-box"><view class="form-item flex-col"><view class="f1">显示条件</view><view class="f2" style="line-height:30px;"><checkbox-group class="radio-group" name="showtj"><label><checkbox value="-1" checked="{{$root.m7?true:false}}"></checkbox>所有人</label><label><checkbox value="-2" checked="{{$root.m8?true:false}}"></checkbox>未登录用户</label><label><checkbox value="0" checked="{{$root.m9?true:false}}"></checkbox>关注用户</label><block s-for="$root.l2 trackBy item.$orig.id" s-for-item="item" s-for-index="__i1__"><label><checkbox value="{{''+item.$orig.id}}" checked="{{item.m10?true:false}}"></checkbox>{{''+item.$orig.name}}</label></block></checkbox-group></view></view></view></block><view class="form-box"><view class="form-item"><view>状态<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="status" data-event-opts="{{[['change',[['bindStatusChange',['$event']]]]]}}" bindchange="__e"><label><radio value="1" checked="{{info.status==1?true:false}}"></radio>上架</label><label><radio value="0" checked="{{!info||info.status==0?true:false}}"></radio>下架</label><label><radio value="2" checked="{{info.status==2?true:false}}"></radio>上架时间</label><label><radio value="3" checked="{{info.status==3?true:false}}"></radio>上架周期</label></radio-group></view></view><block s-if="{{info.status==2}}"><view class="form-item flex-col"><view class="f1">上架时间</view><view class="f2" style="line-height:30px;"><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time1||'-选择日期-'}}</view></picker><picker mode="time" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker" style="padding-left:10rpx;">{{start_time2||'-选择时间-'}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">到</view><picker mode="date" value="{{end_time1}}" data-event-opts="{{[['change',[['bindEndTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_time1||'-选择日期-'}}</view></picker><picker mode="time" value="{{end_time2}}" data-event-opts="{{[['change',[['bindEndTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker" style="padding-left:10rpx;">{{end_time2||'-选择时间-'}}</view></picker></view></view></block><block s-if="{{info.status==3}}"><view class="form-item flex-col"><view class="f1">上架周期</view><view class="f2" style="line-height:30px;"><picker mode="time" value="{{start_hours}}" data-event-opts="{{[['change',[['bindStartHoursChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_hours||'-开始时间-'}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">到</view><picker mode="time" value="{{end_hours}}" data-event-opts="{{[['change',[['bindEndHoursChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_hours||'-结束时间-'}}</view></picker></view></view></block></view><block s-if="{{paramList.length>0}}"><view class="form-box"><view class="form-item" style="border-bottom:0;"><text>商品参数</text></view><block s-for="$root.l4" s-for-item="param" s-for-index="idx"><block><view class="form-item"><view class="f1">{{param.$orig.name}}<block s-if="{{param.$orig.is_required==1}}"><text style="color:red;">*</text></block></view><block s-if="{{param.$orig.type=='0'}}"><block><view class="f2"><input type="text" name="{{'form'+idx}}" placeholder="{{param.$orig.tips}}" placeholder-style="color:#888" data-formidx="{{'form'+idx}}" data-event-opts="{{[['input',[['setfield',['$event']]]]]}}" value="{{paramdata['form'+idx]}}" bindinput="__e"/></view></block></block><block s-if="{{param.$orig.type=='1'}}"><block><view class="f2" style="line-height:30px;"><picker class="picker" mode="selector" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" range="{{param.$orig.params}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view>{{''+param.$orig.params[editorFormdata[idx]]}}</view></block><block s-else><view>{{param.$orig.tips||'请选择'}}</view></block></picker></view></block></block><block s-if="{{param.$orig.type=='2'}}"><block><view class="f2" style="line-height:30px;"><checkbox-group class="flex" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" bindchange="__e"><block s-for="param.l3 trackBy item1.$orig.id" s-for-item="item1" s-for-index="idx1"><label class="flex-y-center"><checkbox class="checkbox" value="{{item1.$orig}}" checked="{{item1.m11?true:false}}"></checkbox>{{item1.$orig+''}}</label></block></checkbox-group></view></block></block></view></block></block></view></block><view class="form-box"><view class="form-item flex-col"><text>商品详情</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" bindtap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" bindtap="__e">+图片</view><view data-event-opts="{{[['tap',[['detailAddvideo',['$event']]]]]}}" class="btn" bindtap="__e">+视频</view></view><view><block s-for="pagecontent