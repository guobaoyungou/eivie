<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m0}}</text></view><view class="f3"><block s-if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block><block s-if="{{item.$orig.status==4}}"><block><block s-if="{{item.$orig.wx_state=='WAIT_USER_CONFIRM'||item.$orig.wx_state=='TRANSFERING'}}"><view data-event-opts="{{[['tap',[['confirm_shoukuan',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="btn1" style="{{'background:'+(item.m1)+';'}}" bindtap="__e">确认收款</view></block><block s-else><block s-if="{{item.$orig.state=='FAIL'}}"><view class="t1">转账失败</view></block><block s-else><view class="t1">处理中</view></block></block></block></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="480aeda7-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="480aeda7-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="480aeda7-3"></loading></block><dp-tabbar vue-id="480aeda7-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="480aeda7-5" data-ref="popmsg"></popmsg></view>