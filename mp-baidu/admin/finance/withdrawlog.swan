<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="tabcontent"><dd-tab vue-id="5cfc34d0-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></view><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'withdrawdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="t1" src="{{item.$orig.headimg}}"></image><text class="t2">{{item.$orig.nickname}}</text></view><view class="f2"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m1}}</text><text class="t2">{{"提现方式："+item.$orig.paytype}}</text></view><view class="f3"><block s-if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block><block s-if="{{item.$orig.status==4}}"><text class="t1">处理中</text></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="5cfc34d0-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="5cfc34d0-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="5cfc34d0-4"></loading></block><popmsg class="vue-ref" vue-id="5cfc34d0-5" data-ref="popmsg"></popmsg></view>