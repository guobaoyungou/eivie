<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">可提现余额</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.money}}</view><view class="f3" data-url="bwithdrawlog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>提现记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">提现金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入提现金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><block s-if="{{sysset.withdrawfee>0||sysset.withdrawmin>0}}"><view class="item4"><block s-if="{{sysset.withdrawmin>0}}"><text style="margin-right:10rpx;">{{"最低提现金额"+sysset.withdrawmin+'元'}}</text></block><block s-if="{{paytype=='通联支付银行卡'}}"><block><block s-if="{{sysset.yunstwithdrawfeetype&&sysset.yunstwithdrawfeetype==1&&sysset.yunstwithdrawfee>0}}"><text>{{'提现手续费'+sysset.yunstwithdrawfee+'元'}}</text></block><block s-else><block s-if="{{sysset.withdrawfee>0}}"><text>{{"提现手续费"+sysset.withdrawfee+'%'}}</text></block></block></block></block><block s-else><block><block s-if="{{sysset.withdrawfee>0}}"><text>{{"提现手续费"+sysset.withdrawfee+'%'}}</text></block></block></block></view></block></view><block s-if="{{sysset.smscode}}"><view class="content2"><view class="item2"><view class="f1">手机号</view></view><view class="item2 item-form"><input class="input" type="text" name="tel" placeholder="请输入手机号" placeholder-style="color:#999;" data-event-opts="{{[['input',[['__set_model',['','tel','$event',[]]]]]]}}" value="{{tel}}" bindinput="__e"/></view><view class="item2"><view class="f1">验证码</view></view><view class="item2 item-form"><input class="input" type="text" name="smscode" placeholder="请输入短信验证码" placeholder-style="color:#999;" data-event-opts="{{[['input',[['__set_model',['','smscode','$event',[]]]]]]}}" value="{{smscode}}" bindinput="__e"/><view><button class="mini-btn" style="{{'color:'+(smsdjs?'#999':$root.m1)+';'}}" type="default" size="mini" disabled="{{!!smsdjs}}" data-event-opts="{{[['tap',[['sendcode',['$event']]]]]}}" bindtap="__e">{{''+(smsdjs||'获取验证码')+''}}</button></view></view></view></block><view class="withdrawtype"><view class="f1">选择提现方式：</view><view class="f2"><block s-if="{{sysset.withdraw_weixin==1}}"><view class="item" data-paytype="微信钱包" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-weixin.png'}}"></image>微信钱包</view><view class="radio" style="{{(paytype=='微信钱包'?'background:'+$root.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block><block s-if="{{sysset.withdraw_aliaccount==1}}"><label class="item" data-paytype="支付宝" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝</view><view class="radio" style="{{(paytype=='支付宝'?'background:'+$root.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_bankcard==1}}"><label class="item" data-paytype="银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>银行卡</view><view class="radio" style="{{(paytype=='银行卡'?'background:'+$root.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_bankcard_allinpayYunst==1}}"><label class="item" data-paytype="通联支付银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>通联支付银行卡</view><view class="radio" style="{{(paytype=='通联支付银行卡'?'background:'+$root.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_huifu==1}}"><label class="item" data-paytype="汇付斗拱" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>汇付斗拱</view><view class="radio" style="{{(paytype=='汇付斗拱'?'background:'+$root.m6+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_huifu_dianzhang==1}}"><label class="item" data-paytype="店长汇付打款" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>店长汇付打款</view><view class="radio" style="{{(paytype=='店长汇付打款'?'background:'+$root.m7+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_business_admin_money==1}}"><label class="item" data-paytype="商家管理员余额" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>商家管理员余额</view><view class="radio" style="{{(paytype=='商家管理员余额'?'background:'+$root.m8+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block></view></view><button class="btn" style="{{'background:'+($root.m9)+';'}}" form-type="submit">立即提现</button><block s-if="{{can_edit_account==1}}"><block><block s-if="{{paytype=='支付宝'}}"><view style="width:100%;margin-top:40rpx;margin-bottom:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/admin/finance/txset" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">设置支付宝账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><block s-if="{{paytype=='银行卡'&&!sysset.withdraw_huifu&&!sysset.withdraw_huifu_dianzhang}}"><view style="width:100%;margin-top:40rpx;margin-bottom:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/admin/finance/txset" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">设置银行卡账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></block></block></form><block s-if="{{sysset.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{sysset.withdraw_desc}}</text></view></block></block></block><block s-if="{{loading}}"><loading vue-id="c2050544-1"></loading></block><dp-tabbar vue-id="c2050544-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="c2050544-3" data-ref="popmsg"></popmsg></view>