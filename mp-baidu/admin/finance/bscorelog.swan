<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f-row"><view class="f2"><text>{{myscore}}</text></view><view class="score-option"><block s-if="{{businessTransfer}}"><view class="btn-mini" data-url="/pagesA/score/transfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转入/转出</view></block><block s-if="{{scoreWithdraw}}"><view class="btn-mini" data-url="/pagesB/business/scorewithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></block></view></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block s-else><block><text class="t2">{{item.score}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="477585f6-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="477585f6-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="477585f6-3"></loading></block><dp-tabbar vue-id="477585f6-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="477585f6-5" data-ref="popmsg"></popmsg></view>