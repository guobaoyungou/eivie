<view class="container"><block s-if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block s-if="{{detail.status==0}}"><view class="f1"><view class="t1">等待买家付款</view></view></block><block s-if="{{detail.status==1}}"><view class="f1"><view class="t1">已成功付款</view></view></block><block s-if="{{detail.status==2}}"><view class="f1"><view class="t1">订单已发货</view><block s-if="{{detail.freight_type!=3}}"><view class="t2">{{"发货信息："+detail.express_com+" "+detail.express_no}}</view></block></view></block><block s-if="{{detail.status==3}}"><view class="f1"><view class="t1">订单已完成</view></view></block><block s-if="{{detail.status==4}}"><view class="f1"><view class="t1">订单已取消</view></view></block></view><view class="product"><view class="content"><view data-url="{{'/pagesExt/yueke/product?id='+detail.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{detail.propic}}"></image></view><view class="detail"><text class="t1">{{detail.proname}}</text><text class="t2">{{"教练："+workerinfo.realname+" "+(workerinfo.dengji||'')}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.product_price}}</text></view></view></view></view><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{detail.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{detail.mid}}</text></view></view><block s-if="{{detail.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2" user-select="true" selectable="true">{{detail.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block s-if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block s-if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{detail.paytype}}</text></view></block><block s-if="{{detail.status>1&&detail.send_time}}"><view class="item"><text class="t1">发货时间</text><text class="t2">{{detail.send_time}}</text></view></block><block s-if="{{detail.status==3&&detail.collect_time}}"><view class="item"><text class="t1">收货时间</text><text class="t2">{{detail.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+detail.product_price}}</text></view><block s-if="{{detail.disprice>0}}"><view class="item"><text class="t1">{{$root.m1+"折扣"}}</text><text class="t2 red">{{"-¥"+detail.leveldk_money}}</text></view></block><block s-if="{{detail.jianmoney>0}}"><view class="item"><text class="t1">满减活动</text><text class="t2 red">{{"-¥"+detail.manjian_money}}</text></view></block><view class="item"><text class="t1">配送方式</text><text class="t2">{{detail.freight_text}}</text></view><block s-if="{{detail.freight_type==1&&detail.freightprice>0}}"><view class="item"><text class="t1">服务费</text><text class="t2 red">{{"+¥"+detail.freight_price}}</text></view></block><block s-if="{{detail.freight_time}}"><view class="item"><text class="t1">{{(detail.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{detail.freight_time}}</text></view></block><block s-if="{{detail.couponmoney>0}}"><view class="item"><text class="t1">{{$root.m2+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.coupon_money}}</text></view></block><block s-if="{{detail.scoredk>0}}"><view class="item"><text class="t1">{{$root.m3+"抵扣"}}</text><text class="t2 red">{{"-¥"+detail.scoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+detail.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block s-if="{{detail.status==0}}"><text class="t2">未付款</text></block><block s-if="{{detail.status==1}}"><block><block s-if="{{detail.freight_type!=1}}"><text class="t2">待发货</text></block><block s-if="{{detail.freight_type==1}}"><text class="t2">待提货</text></block></block></block><block s-if="{{detail.status==2}}"><text class="t2">已发货</text></block><block s-if="{{detail.status==3}}"><text class="t2">已收货</text></block><block s-if="{{detail.status==4}}"><text class="t2">已关闭</text></block></view><block s-if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block s-if="{{detail.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+detail.refund_money}}</text></block><block s-if="{{detail.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+detail.refund_money}}</text></block><block s-if="{{detail.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block s-if="{{detail.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{detail.refund_reason}}</text></view></block><block s-if="{{detail.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{detail.refund_checkremark}}</text></view></block><block s-if="{{detail.isfuwu&&detail.fuwuendtime>0}}"><view class="item"><text class="t1">到期时间</text><text class="t2 red">{{$root.g0}}</text></view></block></view><view class="orderinfo"><view class="title">顾客信息</view><view class="item"><text class="t1">姓名</text><text class="t2">{{detail.linkman}}</text></view><view class="item"><text class="t1">手机号</text><text class="t2">{{detail.tel}}</text></view></view><block s-if="{{detail.formdata.length>0}}"><view class="orderinfo"><block s-for="detail.formdata trackBy index" s-for-item="item" s-for-index="__i0__"><view class="item"><text class="t1">{{item[0]}}</text><block s-if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block s-else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block><view style="width:100%;height:calc(160rpx + env(safe-area-inset-bottom));"></view><view class="bottom notabbarbot"><block s-if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundnopass',['$event']]]]]}}" bindtap="__e">退款驳回</view></block><block s-if="{{detail.refund_status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['refundpass',['$event']]]]]}}" bindtap="__e">退款通过</view></block><block s-if="{{detail.status==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['closeOrder',['$event']]]]]}}" bindtap="__e">关闭订单</view></block><block s-if="{{detail.status==0&&detail.bid==0}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['ispay',['$event']]]]]}}" bindtap="__e">改为已支付</view></block><block s-if="{{detail.status==1}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" bindtap="__e">完成订单</view></block><block s-if="{{detail.status==4}}"><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" bindtap="__e">删除</view></block><view class="btn2" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['setremark',['$event']]]]]}}" bindtap="__e">设置备注</view></view><uni-popup class="vue-ref" vue-id="545eceec-1" id="dialogSetremark" type="dialog" data-ref="dialogSetremark" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('545eceec-2')+','+('545eceec-1')}}" mode="input" title="设置备注" value="{{detail.remark}}" placeholder="请输入备注" data-event-opts="{{[['^confirm',[['setremarkconfirm']]]]}}" bind:confirm="__e"></uni-popup-dialog></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="545eceec-3"></loading></block><dp-tabbar vue-id="545eceec-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="545eceec-5" data-ref="popmsg"></popmsg></view>