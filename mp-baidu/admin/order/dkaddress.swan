<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="content" data-id="{{item.id}}" data-event-opts="{{[['tap',[['setdefault',['$0'],[[['datalist','',index]]]]]]]}}" catchtap="__e"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{item.tel}}</text><block s-if="{{item.company}}"><text class="t2">{{item.company}}</text></block><text class="flex1"></text></view><view class="f2">{{item.area+" "+item.address}}</view></view></block><block s-if="{{nodata}}"><nodata vue-id="aab2bd2e-1"></nodata></block><view style="height:140rpx;"></view></block></block><block s-if="{{loading}}"><loading vue-id="aab2bd2e-2"></loading></block><dp-tabbar vue-id="aab2bd2e-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="aab2bd2e-4" data-ref="popmsg"></popmsg></view>