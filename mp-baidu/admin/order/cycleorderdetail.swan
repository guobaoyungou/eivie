<block s-if="{{isload}}"><view class="data-v-1b828002"><block s-if="{{detail.refund_status==1||detail.refund_status==1}}"><view class="banner data-v-1b828002"><image class="banner_img _img data-v-1b828002" src="{{pre_url+'/static/img/week/week_banner.png'}}" alt></image><image class="banner_icon _img data-v-1b828002" src="{{pre_url+'/static/img/week/week_icon.png'}}" alt></image><block s-if="{{detail.refund_status==1}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002">退款中</view><view class="banner_text data-v-1b828002">等待平台审核中</view></view></block><block s-if="{{detail.refund_status==2}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002">退款成功</view><view class="banner_text data-v-1b828002">审核通过，已退款</view></view></block></view></block><block s-else><view class="banner data-v-1b828002"><image class="banner_img _img data-v-1b828002" src="{{pre_url+'/static/img/week/week_banner.png'}}" alt></image><image class="banner_icon _img data-v-1b828002" src="{{pre_url+'/static/img/week/week_icon.png'}}" alt></image><block s-if="{{detail.status==0}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002">待支付</view><block s-if="{{detail.status==0}}"><view class="banner_text data-v-1b828002">等待用户支付中</view></block></view></block><block s-if="{{detail.status==1}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002"><block s-if="{{detail.freight_type==1}}"><text class="data-v-1b828002">待取货</text></block><block s-else><text class="data-v-1b828002">待发货</text></block></view><view class="banner_text data-v-1b828002"><view class="t1 data-v-1b828002">{{(detail.paytype=='货到付款'?'已选择'+codtxt:'已成功付款')+''}}<block s-if="{{detail.freight_type!=1}}"><text class="data-v-1b828002">，我们会尽快为您配送</text></block></view></view></view></block><block s-if="{{detail.status==2}}"><view class="banner_data data-v-1b828002"><block s-if="{{detail.freight_type==1}}"><view class="banner_title data-v-1b828002">已取货</view></block><block s-else><view class="banner_title data-v-1b828002">已发货</view></block><block s-if="{{detail.status==0}}"><view class="banner_text data-v-1b828002">具体发货信息请查看每期订单</view></block></view></block><block s-if="{{detail.status==3}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002">已完成</view></view></block><block s-if="{{detail.status==4}}"><view class="banner_data data-v-1b828002"><view class="banner_title data-v-1b828002">已关闭</view></view></block></view></block><view class="body data-v-1b828002"><view class="address data-v-1b828002"><view class="img data-v-1b828002"><image src="{{pre_url+'/static/img/address3.png'}}" class="data-v-1b828002"></image></view><view class="info data-v-1b828002"><text class="t1 data-v-1b828002" user-select="true" selectable="true">{{detail.linkman+" "+detail.tel}}</text><block s-if="{{detail.freight_type!=1&&detail.freight_type!=3}}"><text class="t2 data-v-1b828002" user-select="true" selectable="true">{{"地址："+detail.area+detail.address}}</text></block><block s-if="{{detail.freight_type==1}}"><text class="t2 data-v-1b828002" data-storeinfo="{{storeinfo}}" user-select="true" selectable="true" data-event-opts="{{[['tap',[['openMendian',['$event']]]]]}}" bindtap="__e">{{"取货地点："+storeinfo.name+" - "+storeinfo.address+''}}</text></block></view></view><view class="body_module data-v-1b828002"><image class="body_img _img data-v-1b828002" src="{{detail.propic}}" alt></image><view class="body_data data-v-1b828002"><view class="body_name data-v-1b828002">{{''+detail.proname+''}}</view><view class="body_text data-v-1b828002">{{''+detail.ggname+" | "+detail.pspl}}<block s-if="{{detail.every_day}}"><text class="data-v-1b828002">{{","+detail.every_day}}</text></block></view><view class="body_price flex flex-bt flex-y-bottom data-v-1b828002"><text class="data-v-1b828002">{{"￥"+detail.sell_price}}</text></view></view></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">下单人</text><view class="data-v-1b828002"><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{detail.headimg}}" class="data-v-1b828002"></image><text style="height:80rpx;line-height:80rpx;" class="data-v-1b828002">{{detail.nickname}}</text></view></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">会员ID</text><text class="data-v-1b828002">{{detail.mid}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">订单号</text><text class="data-v-1b828002">{{detail.ordernum}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">下单时间</text><text class="data-v-1b828002">{{detail.createtime}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">配送期数</text><text class="data-v-1b828002">{{"共 "+detail.qsnum+" 期"}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">每期数量</text><text class="data-v-1b828002">{{"共 "+detail.num+" 件"}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">配送计划</text><view class="body_time data-v-1b828002" data-url="{{'cycleplanlist?id='+detail.id}}" data-event-opts="{{[['tap',[['toPlanDetail',['$event']]]]]}}" bindtap="__e"><view class="data-v-1b828002">{{detail.start_date+"起"}}<block s-if="{{detail.every_day}}"><text style="margin-left:10rpx;" class="data-v-1b828002">{{detail.every_day}}</text></block><block s-else><text style="margin-left:10rpx;" class="data-v-1b828002">{{detail.pspl}}</text></block></view><image src="{{pre_url+'/static/img/week/week_detail.png'}}" alt class="_img data-v-1b828002"></image></view></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">配送方式</text><text class="data-v-1b828002">{{detail.freight_text}}</text></view><view class="body_list data-v-1b828002"><text class="data-v-1b828002">商品总金额</text><text class="body_color data-v-1b828002">{{"￥"+detail.product_price}}</text></view><block s-if="{{detail.leveldk_money>0}}"><view class="body_list data-v-1b828002"><text class="data-v-1b828002">会员折扣</text><text class="body_color data-v-1b828002">{{"-￥"+detail.leveldk_money}}</text></view></block><block s-if="{{detail.coupon_money>0}}"><view class="body_list data-v-1b828002"><text class="data-v-1b828002">优惠券抵扣</text><text class="body_color data-v-1b828002">{{"-￥"+detail.coupon_money}}</text></view></block><view class="body_list data-v-1b828002"><text class="data-v-1b828002">实付金额</text><text class="body_color data-v-1b828002">{{"￥"+detail.totalprice}}</text></view><block s-if="{{detail.refund_status>0}}"><view class="body_list data-v-1b828002"><text class="t1 data-v-1b828002">退款状态</text><block s-if="{{detail.refund_status==1}}"><text class="t2 body_color data-v-1b828002">{{"审核中,¥"+detail.refund_money}}</text></block><block s-if="{{detail.refund_status==2}}"><text class="t2 body_color data-v-1b828002">{{"已退款,¥"+detail.refund_money}}</text></block><block s-if="{{detail.refund_status==3}}"><text class="t2 body_color data-v-1b828002">{{"已驳回,¥"+detail.refund_money}}</text></block></view></block><block s-if="{{detail.formdata.length>0}}"><view class="orderinfo data-v-1b828002"><block s-for="detail.formdata trackBy index" s-for-item="item" s-for-index="__i0__"><view class="item data-v-1b828002"><text class="t1 data-v-1b828002">{{item[0]}}</text><block s-if="{{item[2]=='upload'}}"><view class="t2 data-v-1b828002"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e" class="data-v-1b828002"></image></view></block><block s-else><text class="t2 data-v-1b828002" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></view></block></view></view></block>