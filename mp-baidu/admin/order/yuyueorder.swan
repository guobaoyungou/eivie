<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="6fe092e7-1" itemdata="{{['全部','待付款','派单中','待确认','已完成','已取消']}}" itemst="{{['all','0','1','2','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-if="{{checkstatus}}"><block><view style="display:flex;align-items:center;width:94%;margin:10rpx 3%;padding:6rpx 3%;"><view><label data-event-opts="{{[['tap',[['checkAll',['$event']]]]]}}" style="display:flex;align-items:center;margin-right:10rpx;" bindtap="__e"><checkbox class="radio" value="all" checked="{{checkall?true:false}}"></checkbox>全选</label></view><view class="btn2" data-type="1" data-event-opts="{{[['tap',[['peisong',['','more']]]]]}}" bindtap="__e">批量派单</view></view></block></block><block s-if="{{yytime_search}}"><block><view class="search-date flex-y-center sx"><text class="t1">预约日期：</text><view class="f2 flex" style="line-height:30px;"><picker mode="date" value="{{startDate}}" data-type="yy" data-event-opts="{{[['change',[['bindStartDateChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{startDate}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">至</view><picker mode="date" value="{{endDate}}" data-type="yy" data-event-opts="{{[['change',[['bindEndDateChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{endDate}}</view></picker><view class="t_date"><block s-if="{{startDate}}"><view class="x1" data-type="yy" data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" bindtap="__e">清除</view></block></view></view></view><view class="search-date flex-y-center sx"><text class="t1">完成日期：</text><view class="f2 flex" style="line-height:30px;"><picker mode="date" value="{{collectStartDate}}" data-type="collect" data-event-opts="{{[['change',[['bindStartDateChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{collectStartDate}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">至</view><picker mode="date" value="{{collectEndDate}}" data-type="collect" data-event-opts="{{[['change',[['bindEndDateChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{collectEndDate}}</view></picker><view class="t_date"><block s-if="{{collectStartDate}}"><view class="x1" data-type="collect" data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" bindtap="__e">清除</view></block></view></view></view></block></block><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box"><view class="head"><view style="display:flex;align-items:center;"><block s-if="{{checkstatus}}"><view><label style="display:flex;align-items:center;margin-right:10rpx;" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['checkChange',['$event']]]]]}}" bindtap="__e"><checkbox value="{{item.id}}" checked="{{item.checked?true:false}}"></checkbox></label></view></block><block s-if="{{item.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block s-else><view>{{"订单号："+item.ordernum}}</view></block></view><view class="flex1"></view><block s-if="{{item.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.status==1&&item.refund_status==0&&item.worker_orderid}}"><block><block s-if="{{item.worker.status==0}}"><text class="st1">待接单</text></block><block s-if="{{item.worker.status==1}}"><text class="st1">已接单</text></block><block s-if="{{item.worker.status==2}}"><text class="st2">服务中</text></block></block></block><block s-else><block s-if="{{item.status==1&&item.refund_status==0}}"><block><text class="st1">派单中</text></block></block></block><block s-if="{{item.status==1&&item.refund_status==1}}"><text class="st1">退款审核中</text></block><block s-if="{{item.status==2}}"><text class="st2">服务中</text></block><block s-if="{{item.status==3&&item.isconmement==0}}"><text class="st3">待评价</text></block><block s-if="{{item.status==3}}"><text class="st4">已完成</text></block><block s-if="{{item.status==4}}"><text class="st4">订单已关闭</text></block></view><view class="content" style="border-bottom:none;" data-url="{{'yuyueorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><block s-if="{{item.paidan_type==3}}"><view><image src="{{item.propic}}"></image></view></block><block s-else><view data-url="{{'product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.propic}}"></image></view></block><view class="detail"><text class="t1">{{item.proname}}</text><text class="t1">{{"预约日期："+item.yy_time}}</text><block s-if="{{yuyue_sign}}"><text class="t2">{{"服务地址："+item.area}}</text></block><block s-if="{{item.balance_price>0}}"><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.totalprice}}</text><block s-if="{{item.balance_price>0}}"><text class="x1 flex1">{{"尾款：￥"+item.balance_price}}</text></block></view></block><block s-else><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.totalprice}}</text><block s-if="{{item.showpaidanfee}}"><text class="x1 flex1">{{"含跑腿费：￥"+item.paidan_money}}</text></block></view></block></view></view><block s-if="{{item.send_time>0}}"><view class="bottom"><text>{{"派单时间："+item.senddate}}</text><block s-if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><view class="op"><block s-if="{{checkstatus&&item.status==1&&!item.worker_id&&!item.showlist}}"><view class="btn2" data-id="{{item.id}}" data-bid="item.bid" data-event-opts="{{[['tap',[['peisong',['$event']]]]]}}" bindtap="__e">派单</view></block><block s-if="{{yuyue_sign&&item.status==2&&item.addmoney>0&&item.addmoneyStatus==0}}"><view class="btn2" data-addprice="{{item.addmoney}}" data-addmoneyPayorderid="{{item.addmoneyPayorderid}}" data-orderid="{{item.id}}" data-event-opts="{{[['tap',[['update',['$event']]]]]}}" catchtap="__e">修改差价</view></block><view class="btn2" data-url="{{'yuyueorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view></view><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view></view></block></block></view><block s-if="{{showmodal}}"><view class="modal"><view class="addmoney"><view class="title">{{(addprice>0?'修改':'创建')+"补余款"}}</view><view class="item"><label class="label">金额：</label><input type="text" name="blance_price" placeholder="请输入补余款金额" placeholder-style="font-size:24rpx" data-event-opts="{{[['input',[['bindMoney',['$event']]]]]}}" value="{{addprice}}" bindinput="__e"/>元</view><view class="btn"><button data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" class="btn-cancel" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['addconfirm',['$event']]]]]}}" class="confirm" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" catchtap="__e">确定</button></view></view></view></block><block s-if="{{nomore}}"><nomore vue-id="6fe092e7-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="6fe092e7-3"></nodata></block></block></block><uni-popup class="vue-ref" vue-id="6fe092e7-4" id="dialogPeisong" type="dialog" data-ref="dialogPeisong" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请选择配送员</text></view><view class="uni-dialog-content"><view><picker style="font-size:24rpx;border:1px #eee solid;padding:10rpx;height:70rpx;border-radius:4px;flex:1;" value="{{index2}}" range="{{peisonguser2}}" data-event-opts="{{[['change',[['peisongChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{peisonguser2[index2]}}</view></picker></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogPeisongClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmPeisong',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup><block s-if="{{loading}}"><loading vue-id="6fe092e7-5"></loading></block><dp-tabbar vue-id="6fe092e7-6" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="6fe092e7-7" data-ref="popmsg"></popmsg></view>