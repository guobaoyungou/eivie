<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="79fb3860-1" itemdata="{{['全部','待付款','待发货','已发货','已完成','退款']}}" itemst="{{['all','0','1','2','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'cycleorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><text class="flex1">{{"订单号："+item.ordernum}}</text><block s-if="{{item.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.status==1}}"><block><block><block s-if="{{item.freight_type!=1}}"><text class="st1">待发货</text></block><block s-if="{{item.freight_type==1}}"><text class="st1">待取货</text></block></block></block></block><block s-if="{{item.status==2&&item.freight_type==1}}"><text class="st2">已取货</text></block><block s-if="{{item.status==2&&(item.freight_type==2||item.freight_type==0)}}"><text class="st2">已发货</text></block><block s-if="{{item.status==3}}"><text class="st3">已完成</text></block><block s-if="{{item.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><text class="t2">{{item.ggname}}</text><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.qsnum+"期"}}</text></view></view></view><view class="bottom"><text>{{"共"+item.qsnum+"期，每期"+item.num+"件商品 实付:￥"+item.totalprice+''}}</text><block s-if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="79fb3860-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="79fb3860-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="79fb3860-4"></loading></block><dp-tabbar vue-id="79fb3860-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="79fb3860-6" data-ref="popmsg"></popmsg></view>