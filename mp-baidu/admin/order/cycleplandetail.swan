<block s-if="{{isload}}"><view class="page data-v-03105abb"><view class="module data-v-03105abb"><view class="module_title data-v-03105abb"><view class="data-v-03105abb">{{"第"+detail.cycle_number+'期'}}<text class="module_num data-v-03105abb">{{detail.cycle_number+"/"+detail.order.qsnum}}</text></view><block s-if="{{(order.freight_type==0||order.freight_type==2)&&detail.status==2}}"><view class="btn2 data-v-03105abb" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" bindtap="__e">确认收货</view></block><block s-if="{{order.freight_type==1&&detail.status==1}}"><view class="btn_c data-v-03105abb" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['orderhexiao',['$event']]]]]}}" bindtap="__e">核销</view></block><block s-if="{{detail.status==1&&order.freight_type==2}}"><text class="module_state data-v-03105abb">待配送</text></block><block s-if="{{detail.status==1&&order.freight_type==0}}"><text class="module_state data-v-03105abb">待发货</text></block><block s-if="{{order.freight_type==2&&detail.status==2}}"><text class="module_state data-v-03105abb">配送中</text></block><block s-if="{{order.freight_type==1&&detail.status==1}}"><text class="module_state data-v-03105abb">待取货</text></block><block s-if="{{order.freight_type==0&&detail.status==2}}"><text class="module_state data-v-03105abb">已发货</text></block><block s-if="{{detail.status==3}}"><text class="module_state data-v-03105abb">已完成</text></block></view><block s-if="{{order.freight_type==2||order.freight_type==0}}"><view class="data-v-03105abb"><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">收货人</view><view class="module_text data-v-03105abb">{{''+order.linkman+''}}</view></view><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb"><block s-if="{{order.freight_type==1}}"><text class="data-v-03105abb">取货</text></block><block s-else><text class="data-v-03105abb">收货</text></block>日期</view><view class="module_text data-v-03105abb">{{''+detail.cycle_date+" / "+detail.week+''}}</view></view><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">收货地址</view><view class="module_text data-v-03105abb">{{''+order.area+order.address+''}}</view></view><block s-if="{{order.freight_type==0&&detail.status>1}}"><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">物流信息</view><view class="module_text data-v-03105abb"><view class="wl_btn data-v-03105abb" data-express_com="{{detail.express_com}}" data-express_no="{{detail.express_no}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" catchtap="__e">查看物流</view></view></view></block><block s-if="{{order.freight_type==2&&(detail.status==2||detail.status==3)}}"><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">配送信息</view><view class="module_text data-v-03105abb"><view class="wl_btn data-v-03105abb" data-express_com="{{detail.express_com}}" data-express_no="{{detail.express_no}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" catchtap="__e">查看配送信息</view></view></view></block></view></block><block s-else><block s-if="{{order.freight_type==1}}"><view class="data-v-03105abb"><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">取货人</view><view class="module_text data-v-03105abb">{{''+order.linkman+''}}</view></view><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb"><block s-if="{{order.freight_type==1}}"><text class="data-v-03105abb">取货</text></block><block s-else><text class="data-v-03105abb">收货</text></block>日期</view><view class="module_text data-v-03105abb">{{''+detail.cycle_date+" / "+detail.week+''}}</view></view><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">取货地址</view><view class="module_text data-v-03105abb">{{''+storeinfo.name+" - "+storeinfo.address+''}}</view></view><block s-if="{{order.freight_type==1}}"><view class="module_list data-v-03105abb"><view class="module_lable data-v-03105abb">核销码</view><view class="module_text data-v-03105abb"><view data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" class="wl_btn data-v-03105abb" bindtap="__e">查看核销码</view></view></view></block></view></block></block></view><block s-if="{{alertStatus}}"><view class="alert data-v-03105abb"><view data-event-opts="{{[['tap',[['alertClick']]]]}}" class="alert_none data-v-03105abb" bindtap="__e"></view><view class="alert_module data-v-03105abb"><view class="alert_title data-v-03105abb">修改顺延日期</view><block s-for="optionList trackBy index" s-for-item="item" s-for-index="index"><view data-event-opts="{{[['tap',[['itemClick',[index]]]]]}}" class="{{['alert_item','data-v-03105abb',listIndex==index?'alert_active':'']}}" bindtap="__e"><view class="alert_tag data-v-03105abb"></view><view class="alert_data data-v-03105abb"><view class="alert_name data-v-03105abb">{{''+item.title+''}}</view><view class="alert_text data-v-03105abb">{{''+item.text+''}}</view></view><block s-if="{{listIndex==index}}"><image class="alert_icon _img data-v-03105abb" src="{{pre_url+'/static/img/week/week_true.png'}}" alt></image></block></view></block><view class="alert_opt data-v-03105abb"><view data-event-opts="{{[['tap',[['alertClick']]]]}}" class="alert_btn data-v-03105abb" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['advanceDays',['$event']]]]]}}" class="alert_btn data-v-03105abb" bindtap="__e">确定</view></view></view></view></block><uni-popup vue-id="29a40114-1" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" class="data-v-03105abb vue-ref" vue-slots="{{['default']}}"><view class="hxqrbox data-v-03105abb"><image class="img data-v-03105abb" src="{{detail.hexiao_qr}}" data-url="{{detail.hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close data-v-03105abb" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}" class="data-v-03105abb"></image></view></view></uni-popup></view></block>