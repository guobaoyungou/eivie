dius:4px;flex:1;font-size:28rpx;" type="text" placeholder="请输入备注(选填)" data-event-opts="{{[['input',[['mytRemark',['$event']]]]]}}" bindinput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogExpress11Close',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmfahuo11',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view></view></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="44386bf8-7"></loading></block><dp-tabbar vue-id="44386bf8-8" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="44386bf8-9" data-ref="popmsg"></popmsg></view>