<view class="container"><block s-if="{{isload}}"><block><view class="tab-box shopping"><view class="page-tab"><view class="page-tab2"><view class="{{['item '+(curTopIndex==-1?'on':'')]}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">全部</view><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['item '+(curTopIndex==index?'on':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}</view></block></block></view></view><view class="shop-box"><block s-for="contentList trackBy index" s-for-item="item" s-for-index="__i0__"><view class="shop-item"><image class="shop-img" src="{{item.pic?item.pic:logo}}" mode="aspectFill"></image><view class="f2 flex-col flex1"><view class="shop-name multi-ellipsis-2">{{''+item.name+''}}</view><view class="desc">{{"人数："+item.seat}}</view><view class="desc">{{"预定费："+item.booking_fee+" 最低消费："+item.limit_fee}}</view></view><view class="f3 button" data-url="{{'booking?bid='+opt.bid+'&tableId='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">预定</view></view></block></view></view></block></block><block s-if="{{loading}}"><loading vue-id="fb7b0b60-1"></loading></block><dp-tabbar vue-id="fb7b0b60-2" opt="{{opt}}"></dp-tabbar></view>