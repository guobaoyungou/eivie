<view><view class="container" id="datalist"><view><view class="info-item"><block s-if="{{couponShow}}"><view class="t1">分类名称</view></block><block s-else><view class="t1">菜品分类</view></block><block s-if="{{couponShow}}"><block><view class="t2">店内</view><view class="t2">外卖</view><view class="t2">预定</view><view class="t2">排序</view></block></block></view><block s-if="{{couponShow}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="info-item"><view class="t1">{{item.name}}<block s-if="{{item.status==0}}"><text style="color:#DBAA83;">(隐藏)</text></block></view><view class="t2"><block s-if="{{item.is_shop==1}}"><text>开</text></block><block s-else><text>关</text></block></view><view class="t2"><block s-if="{{item.is_takeaway==1}}"><text>开</text></block><block s-else><text>关</text></block></view><view class="t2"><block s-if="{{item.is_booking==1}}"><text>开</text></block><block s-else><text>关</text></block></view><view class="t2">{{item.sort}}</view><image class="t3" data-url="{{'edit?id='+item.id}}" src="{{pre_url+'/static/img/arrowright.png'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image></view></block></block></block><block s-else><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="info-item flex" style="justify-content:space-between;"><view class="t1">{{item.name}}<block s-if="{{item.status==0}}"><text style="color:#DBAA83;">(隐藏)</text></block></view><view data-event-opts="{{[['tap',[['couponAddChange',['$0'],[[['datalist','',index]]]]]]]}}" class="addbut" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" bindtap="__e">添加</view></view></block></block></block></view></view><block s-if="{{nomore}}"><nomore vue-id="50def67c-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="50def67c-2"></nodata></block></view>