<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="eae5c17a-1" itemdata="{{['全部','待付款','已支付','已完成','退款']}}" itemst="{{['all','0','1','3','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view><view data-event-opts="{{[['tap',[['showTimesearch',['$event']]]]]}}" class="shaixuan" style="{{'border-color:'+($root.m0)+';'}}" bindtap="__e">按日期查询</view></view><view class="order-content"><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'shoporderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="top flex flex-bt"><view style="font-size:26rpx;">{{"时间："+item.m1}}</view><block s-if="{{item.$orig.printdaynum>0}}"><view style="color:red;font-size:30rpx;">{{"当日流水号：#"+item.$orig.printdaynum}}</view></block></view><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block s-if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.$orig.status==1&&item.$orig.paytypeid!=4}}"><text class="st1">已付款</text></block><block s-if="{{item.$orig.status==1&&item.$orig.paytypeid==4}}"><text class="st1">线下付款</text></block><block s-if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block s-if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><block s-for="item.l0 trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view data-url="{{'/restaurant/shop/product?id='+item2.$orig.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><block s-if="{{item2.$orig.ggtext&&item2.$orig.ggtext.length}}"><view class="flex-col"><block s-for="item2.$orig.ggtext" s-for-item="item3" s-for-index="index"><block><text class="t2">{{item3}}</text></block></block></view></block><block s-if="{{item2.$orig.ggname}}"><text class="t2">{{item2.$orig.ggname+(item2.$orig.jltitle?item2.$orig.jltitle:'')}}</text></block><view class="t3"><block s-if="{{item2.$orig.jlprice}}"><text class="x1 flex1">{{"￥"+item2.g0}}</text></block><block s-else><text class="x1 flex1">{{"￥"+item2.$orig.sell_price}}</text></block><text class="x2">{{"×"+item2.$orig.num}}</text></view><block s-if="{{item2.$orig.remark}}"><text class="t2">{{"备注："+item2.$orig.remark}}</text></block></view></view></block></block><view class="bottom"><text>{{"共计"+item.$orig.procount+"个菜品 实付:￥"+item.$orig.totalprice}}</text><block s-if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><block s-if="{{item.$orig.mid}}"><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.$orig.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.$orig.member.nickname}}</text>{{"(ID:"+item.$orig.mid+')'}}</view></block></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="eae5c17a-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="eae5c17a-3"></nodata></block><block s-if="{{timesearchshow}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['timesearchClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><view class="f2" style="line-height:30px;display:flex;align-items:center;font-size:26rpx;justify-content:center;"><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time1||'-选择日期-'}}</view></picker><picker mode="time" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker" style="padding-left:10rpx;">{{start_time2||'-选择时间-'}}</view></picker><view style="padding:0 10rpx;color:#222;font-weight:bold;">到</view><picker mode="date" value="{{end_time1}}" data-event-opts="{{[['change',[['bindEndTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{end_time1||'-选择日期-'}}</view></picker><picker mode="time" value="{{end_time2}}" data-event-opts="{{[['change',[['bindEndTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker" style="padding-left:10rpx;">{{end_time2||'-选择时间-'}}</view></picker></view><view class="flex"><button data-event-opts="{{[['tap',[['timeclear',['$event']]]]]}}" class="op" style="{{'background:'+($root.m2)+';'}}" bindtap="__e">清空</button><button data-event-opts="{{[['tap',[['dateSearch',['$event']]]]]}}" class="op" style="{{'background:'+($root.m3)+';'}}" bindtap="__e">确定</button></view></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="eae5c17a-4"></loading></block></view>