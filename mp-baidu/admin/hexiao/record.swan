<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="{{'输入'+$root.m0+'昵称搜索'}}" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"核销记录（共"+count+"条）"}}</text></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><image class="t1" src="{{item.$orig.headimg}}"></image><text class="t2">{{item.$orig.nickname}}</text></view><view class="f2"><text class="t1" style="color:#000;">{{item.$orig.title}}</text><text class="t2">{{item.m1}}</text><text class="t3">{{"备注："+item.$orig.remark}}</text></view></view></block></view></block><block s-if="{{nodata}}"><nodata vue-id="18474591-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="18474591-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="18474591-3"></loading></block><popmsg class="vue-ref" vue-id="18474591-4" data-ref="popmsg"></popmsg></view>