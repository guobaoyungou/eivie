<view class="view-width"><block s-if="{{isload}}"><block><view class="head-class" style="{{'background:'+('url('+set.bgimg+')')+';'+('background-size:'+('cover')+';')+('background-repeat:'+('no-repeat')+';')}}"><view style="{{'height:'+(44+statusBarHeight+'px')+';'}}"></view><view class="head-view flex-bt flex-y-center"><view class="avat-view"><view class="user-info flex-row" data-url="{{uinfo.bid==0?'/pages/index/index':'/pagesExt/business/index?id='+uinfo.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="nickname">{{set.name}}</text><block s-if="{{uinfo.bid>0}}"><text class="nickname" style="font-weight:normal;">{{"(ID:"+uinfo.bid+")"}}</text></block></view><image class="imgback" src="{{pre_url+'/static/img/location/right-black.png'}}"></image></view><view class="option-img-view"><block s-if="{{auth_data.hexiao_auth_data}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="setup-view" style="margin-right:28rpx;" bindtap="__e"><image src="{{pre_url+'/static/img/admin/saoyisao.png'}}"></image></view></block><view class="setup-view" data-url="setpage" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="setup-img" src="{{pre_url+'/static/img/admin/setup.png'}}"></image></view></view></view><block s-if="{{$root.m0}}"><block><view class="timetab flex-x-center flex-bt"><view data-event-opts="{{[['tap',[['timeTabChange',['today']]]]]}}" class="{{['tab',time_tab_index=='today'?'tab-on':'']}}" bindtap="__e">今日</view><view data-event-opts="{{[['tap',[['timeTabChange',['yesterday']]]]]}}" class="{{['tab',time_tab_index=='yesterday'?'tab-on':'']}}" bindtap="__e">昨日</view><view data-event-opts="{{[['tap',[['timeTabChange',['month']]]]]}}" class="{{['tab',time_tab_index=='month'?'tab-on':'']}}" bindtap="__e">本月</view><view data-event-opts="{{[['tap',[['timeTabChange',['total']]]]]}}" class="{{['tab',time_tab_index=='total'?'tab-on':'']}}" bindtap="__e">累计</view></view><view class="today-data flex-bt flex-y-center"><view class="option-view flex-col flex-x-center"><view class="title-text flex flex-y-center flex-x-center" data-text="商城订单和买单订单的订单总和" data-event-opts="{{[['tap',[['showExplain',['$event']]]]]}}" bindtap="__e">订单量<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="flex-y-center flex-x-center"><text class="unit-money">￥</text><text class="num-text">{{yingyedata.total_order_count||0}}</text></view></view><view class="option-view flex-col flex-x-center"><view class="title-text flex flex-y-center flex-x-center" data-text="商家商品订单+买单订单总金额" data-event-opts="{{[['tap',[['showExplain',['$event']]]]]}}" bindtap="__e">营业额<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="flex-y-center flex-x-center"><text class="unit-money">￥</text><text class="num-text">{{yingyedata.yingye_money||0}}</text></view></view><view class="option-view flex-col flex-x-center"><view class="title-text flex flex-y-center flex-x-center" data-text="营业额的基础上，除去平台抽成后所获得的金额" data-event-opts="{{[['tap',[['showExplain',['$event']]]]]}}" bindtap="__e">商家收入<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="flex-y-center flex-x-center"><text class="unit-money">￥</text><text class="num-text">{{yingyedata.business_income||0.00}}</text></view></view></view></block></block><block s-if="{{show_top_tongji}}"><view class="today-data flex-bt flex-y-center"><view class="option-view flex-col flex-x-center"><view data-event-opts="{{[['tap',[['explanation',['$event']]]]]}}" class="title-text flex flex-y-center flex-x-center" bindtap="__e">今日收款<image class="title-icon" src="{{pre_url+'/static/img/admin/jieshiicon.png'}}"></image></view><view class="flex-y-center flex-x-center"><text class="unit-money">￥</text><text class="num-text">{{today_money}}</text></view></view><view class="option-view flex-col flex-x-center"><text class="title-text">