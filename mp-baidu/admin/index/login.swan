<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="title">з®ЎзҗҶе‘ҳзҷ»еҪ•</view><view class="loginform"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-tel.png'}}"></image><input class="input" type="text" placeholder="иҜ·иҫ“е…Ҙзҷ»еҪ•иҙҰеҸ·" placeholder-style="font-size:30rpx;color:#B2B5BE" name="username" value="{{username}}" data-event-opts="{{[['input',[['__set_model',['','username','$event',[]]]]]]}}" bindinput="__e"/></view><block s-if="{{logintype==1&&(smslogin==0||smslogin==1)}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-pwd.png'}}"></image><input class="input" type="text" placeholder="иҜ·иҫ“е…ҘеҜҶз Ғ" placeholder-style="font-size:30rpx;color:#B2B5BE" name="password" value="" password="{{true}}"/></view></block><block s-if="{{logintype==2||smslogin==2}}"><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="иҜ·иҫ“е…ҘзҹӯдҝЎйӘҢиҜҒз Ғ" placeholder-style="font-size:30rpx;color:#B2B5BE" name="sms_code" value=""/><button class="mini-btn" style="{{'color:'+(smsdjs?'#999':$root.m0)+';'}}" type="default" size="mini" disabled="{{!!smsdjs}}" data-event-opts="{{[['tap',[['smscode',['$event']]]]]}}" bindtap="__e">{{''+(smsdjs||'иҺ·еҸ–йӘҢиҜҒз Ғ')+''}}</button></view></block><view class="form-item"><image class="img" src="{{pre_url+'/static/img/reg-code.png'}}"></image><input class="input" type="text" placeholder="иҜ·иҫ“е…ҘйӘҢиҜҒз Ғ" placeholder-style="font-size:30rpx;color:#B2B5BE" name="captcha" value=""/><image style="width:240rpx;height:80rpx;" src="{{pre_url+'/?s=/ApiIndex/captcha&aid='+aid+'&session_id='+session_id+'&t='+randt}}" data-event-opts="{{[['tap',[['regetcaptcha',['$event']]]]]}}" bindtap="__e"></image></view><block s-if="{{forgetpwd}}"><view style="height:50rpx;"><text style="color:#B2B5BE;float:right;padding:20rpx 0 20rpx 20rpx;" data-url="/adminExt/set/forgetPwd" data-opentype="redirect" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">еҝҳи®°еҜҶз Ғ</text></view></block><button class="form-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" form-type="submit">зҷ»еҪ•</button><block s-if="{{smslogin==1}}"><view data-event-opts="{{[['tap',[['switchLoginType',['$event']]]]]}}" class="switch-login-type" style="{{'color:'+($root.m3)+';'}}" bindtap="__e">{{''+(logintype==1?'зҹӯдҝЎзҷ»еҪ•':'еҜҶз Ғзҷ»еҪ•')+''}}</view></block></view></form></block></block><block s-if="{{loading}}"><loading vue-id="35ef5c89-1"></loading></block><dp-tabbar vue-id="35ef5c89-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="35ef5c89-3" data-ref="popmsg"></popmsg></view>