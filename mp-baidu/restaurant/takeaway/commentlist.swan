<view class="container"><view class="comment"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><image class="t1" src="{{item.headimg}}"></image><view class="t2">{{item.nickname}}</view><view class="flex1"></view><view class="t3"><block s-for="[0,1,2,3,4] trackBy index2" s-for-item="item2" s-for-index="index2"><image class="img" src="{{pre_url+'/static/img/star'+(item.score>item2?'2native':'')+'.png'}}"></image></block></view></view><view style="color:#777;font-size:22rpx;">{{item.createtime}}</view><view class="f2"><text class="t1">{{item.content}}</text><view class="t2"><block s-if="{{item.content_pic!=''}}"><block><block s-for="item.content_pic trackBy index" s-for-item="itemp" s-for-index="index"><block><view data-url="{{itemp}}" data-urls="{{item.content_pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"><image src="{{itemp}}" mode="widthFix"></image></view></block></block></block></block></view><text class="t3">{{"规格："+item.ggname}}</text></view><block s-if="{{item.reply_content}}"><view class="f3"><view class="arrow"></view><view class="t1">{{"商家回复："+item.reply_content}}</view></view></block></view></block></view><block s-if="{{nomore}}"><nomore vue-id="00543ce0-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="00543ce0-2" text="暂无评价~"></nodata></block><block s-if="{{loading}}"><loading vue-id="00543ce0-3"></loading></block><dp-tabbar vue-id="00543ce0-4" opt="{{opt}}"></dp-tabbar></view>