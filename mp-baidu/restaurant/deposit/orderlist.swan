<view class="container"><block s-if="{{isload}}"><block><view class="order-content"><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'detail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view class="f1" data-url="{{item.$orig.bid!=0?'/pages/business/index?bid='+item.$orig.bid:'/pages/index/index'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.$orig.binfo.logo}}"></image><text>{{item.$orig.binfo.name}}</text><text class="flex1"></text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></view><block s-for="item.l0 trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view class="pic"><image class="img" src="{{item2.$orig.pic}}"></image></view><view class="detail"><text class="t1">{{item2.$orig.name}}</text><text class="t2">{{"数量："+item2.$orig.num}}</text><text class="t2">{{"存入时间："+item2.m0}}</text></view><block s-if="{{item2.$orig.status==0}}"><view class="takeout st0" data-orderid="{{item2.$orig.id}}">审核中</view></block><block s-if="{{item2.$orig.status==1}}"><view class="takeout" data-bid="{{item.$orig.bid}}" data-orderid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" bindtap="__e"><image class="img" src="/static/restaurant/deposit_takeout.png"></image>取出</view></block><block s-if="{{item2.$orig.status==2}}"><view class="takeout st2" data-orderid="{{item2.$orig.id}}">已取走</view></block><block s-if="{{item2.$orig.status==3}}"><view class="takeout st3" data-orderid="{{item2.$orig.id}}">未通过</view></block><block s-if="{{item2.$orig.status==4}}"><view class="takeout st4" data-orderid="{{item2.$orig.id}}">已过期</view></block></view></block></block><view class="op"><view class="btn2" data-url="{{'orderdetail?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">寄存记录</view><view class="btn2" data-url="{{'add?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">我要寄存</view><view class="btn1" style="{{'background:'+($root.m1)+';'}}" data-bid="{{item.$orig.bid}}" data-orderid="0" data-event-opts="{{[['tap',[['takeout',['$event']]]]]}}" catchtap="__e">一键取出</view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="54e086c0-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="54e086c0-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="54e086c0-3"></loading></block><dp-tabbar vue-id="54e086c0-4" opt="{{opt}}"></dp-tabbar></view>