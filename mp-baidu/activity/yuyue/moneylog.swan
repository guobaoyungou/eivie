<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="1da7d762-1" itemdata="{{['余额明细','提现记录']}}" itemst="{{['0','2']}}" st="{{st}}" isfixed="{{true}}" color1="#06A051" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-if="{{st==0}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m0}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block s-if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block s-else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></block></block><block s-if="{{st==2}}"><block><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.$orig.money+"元"}}</text><text class="t2">{{item.m1}}</text></view><view class="f3"><block s-if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="1da7d762-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="1da7d762-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="1da7d762-4"></loading></block><dp-tabbar vue-id="1da7d762-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1da7d762-6" data-ref="popmsg"></popmsg></view>