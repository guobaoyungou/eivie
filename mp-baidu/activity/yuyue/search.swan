<view class="container"><block s-if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="/static/img/search_ico.png"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view><view data-event-opts="{{[['tap',[['searchbtn',['$event']]]]]}}" class="search-btn" bindtap="__e"><block s-if="{{!history_show&&productlisttype=='itemlist'}}"><image style="height:36rpx;width:36rpx;" src="/static/img/show-cascades.png"></image></block><block s-if="{{!history_show&&productlisttype=='item2'}}"><image style="height:36rpx;width:36rpx;" src="/static/img/show-list.png"></image></block><block s-if="{{history_show}}"><text>搜索</text></block></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" bindtap="__e"><image style="width:36rpx;height:36rpx;" src="/static/img/del.png"></image></view></view><view class="search-history-list"><block s-for="history_list trackBy index" s-for-item="item" s-for-index="index"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" bindtap="__e">{{item+''}}</view></block><block s-if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="/static/img/tanhao.png"></image>暂无记录</view></block></view></view></view><view class="product-container"><block s-if="{{datalist&&datalist.length>0}}"><block><block s-if="{{productlisttype=='item2'}}"><dp-yuyue-item vue-id="1abd24ab-1" data="{{datalist}}"></dp-yuyue-item></block><block s-if="{{productlisttype=='itemlist'}}"><dp-yuyue-itemlist vue-id="1abd24ab-2" data="{{datalist}}"></dp-yuyue-itemlist></block></block></block><block s-if="{{nomore}}"><nomore vue-id="1abd24ab-3" text="没有更多商品了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="1abd24ab-4" text="没有查找到相关商品"></nodata></block><block s-if="{{loading}}"><loading vue-id="1abd24ab-5"></loading></block></view></block></block><block s-if="{{loading}}"><loading vue-id="1abd24ab-6"></loading></block><dp-tabbar vue-id="1abd24ab-7" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1abd24ab-8" data-ref="popmsg"></popmsg></view>