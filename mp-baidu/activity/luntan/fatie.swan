<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formsubmit',['$event']]]]]}}" bindsubmit="__e"><view class="st_box"><view class="st_title flex-y-center"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" style="width:100rpx;" bindtap="__e"><image src="{{pre_url+'/static/img/goback.jpg'}}"></image></view><view style="margin-right:40%;">我要发帖</view></view><view class="st_form"><block s-if="{{cateArr}}"><view class="flex flex-y-center select-cate"><picker style="height:80rpx;line-height:80rpx;font-size:18px;" value="{{cindex}}" range="{{cateArr}}" data-event-opts="{{[['change',[['cateChange',['$event']]]]]}}" bindchange="__e"><view class="picker">{{cindex==-1?'请选择发帖类型':cateArr[cindex]}}</view></picker><view class="jiantou-icon"><image src="{{pre_url+'/static/img/lt_right_jiantou.png'}}"></image></view></view></block><block s-if="{{cate2&&cateArr2&&cateArr2.length>0}}"><view><picker style="height:80rpx;line-height:80rpx;border-bottom:1px solid #EEEEEE;font-size:18px;" value="{{cindex2}}" range="{{cateArr2}}" data-event-opts="{{[['change',[['cateChange2',['$event']]]]]}}" bindchange="__e"><view class="picker">{{cindex2==-1?'请选择二级分类':cateArr2[cindex2]}}</view></picker></view></block><block s-if="{{formcontent.length>0}}"><view><block s-for="formcontent trackBy item.id" s-for-item="item" s-for-index="idx"><view class="dp-form-item2"><view class="label"><block s-if="{{item.val3==1}}"><text style="color:red;">*</text></block>{{item.val1}}</view><block s-if="{{item.key=='input'}}"><block><block s-if="{{item.val5}}"><text style="margin-right:10rpx;">{{item.val5}}</text></block><block><input class="input" type="{{item.val4==1||item.val4==2?'digit':'text'}}" readonly="{{true}}" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" value="" data-formidx="{{'form'+idx}}" data-event-opts="{{[['input',[['setfield',['$event']]]]]}}" bindinput="__e"/></block></block></block><block s-if="{{item.key=='textarea'}}"><block><textarea class="{{['textarea','form'+idx]}}" adjust-position="{{false}}" name="{{'form'+idx}}" placeholder="{{item.val2}}" placeholder-style="font-size:28rpx" value="" data-formidx="{{'form'+idx}}" data-event-opts="{{[['focus',[['inputFocus',['$event']]]],['blur',[['inputBlur',['$event']]]],['input',[['setfield',['$event']]]]]}}" bindfocus="__e" bindblur="__e" bindinput="__e"></textarea></block></block><block s-if="{{item.key=='radio'}}"><block><radio-group class="{{[item.val10=='1'?'rowalone':'flex']}}" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" bindchange="__e"><block s-for="item.val2 trackBy item1.id" s-for-item="item1" s-for-index="idx1"><label class="{{['flex-y-center',item.val11=='1'?'checkborder':'',item.val10=='1'?'':'rowmore']}}" style="{{'padding:'+('0 10rpx')+';'+('margin-top:'+('10rpx')+';')+('border-radius:'+('10rpx')+';')}}" data-idx="{{idx}}" data-index="{{idx1}}" data-value="{{item1}}"><radio class="radio" value="{{item1}}"></radio>{{item1+''}}</label></block></radio-group></block></block><block s-if="{{item.key=='checkbox'}}"><block><checkbox-group class="{{[item.val4=='1'?'rowalone':'flex']}}" style="flex-wrap:wrap;" name="{{'form'+idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['setfield',['$event']]]]]}}" bindchange="__e"><block s-for="item.val2 trackBy item1.id" s-for-item="item1" s-for-index="idx1"><label class="{{['flex-y-center',item.val9=='1'?'checkborder':'',item.val4=='1'?'':'rowmore']}}" style="{{'padding:'+('0 10rpx')+';'+('margin-top:'+('10rpx')+';')+('border-radius:'+('10rpx')+';')}}"><checkbox class="checkbox" value="{{item1}}"></checkbox>{{item1+''}}</label></block></checkbox-group></block></block><block s-if="{{item.key=='selector'}}"><block><picker class="picker" mode="selector" name="{{'form'+idx}}" value="{{editorFormdata[idx]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]||editorFormdata[idx]===0}}"><view class="flex-y-center flex-bt"><text>{{item.val2[editorFormdata[idx]]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block s-else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block s-if="{{item.key=='time'}}"><block><picker class="picker" mode="time" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block s-else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block s-if="{{item.key=='date'}}"><block><picker class="picker" mode="date" name="{{'form'+idx}}" value="" start="{{item.val2[0]}}" end="{{item.val2[1]}}" range="{{item.val2}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block s-else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block s-if="{{item.key=='year'}}"><block><picker class="picker" name="{{'form'+idx}}" value="" data-idx="{{idx}}" range="{{yearList}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['change',[['yearChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{editorFormdata[idx]}}"><view class="flex-y-center flex-bt"><text>{{editorFormdata[idx]}}</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block><block s-else><view class="dp-form-normal flex-y-center flex-bt"><text>请选择</text><view class="arrow-area"><view class="input-arrow"></view></view></view></block></picker></block></block><block s-if="{{item.key=='region'}}"><block><uni-data-picker style="flex:1;width:100%;" vue-id="{{'43df745a-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" placeholder="请选择省市区" data-formidx="{{'form'+idx}}" data-event-opts="{{[['^change',[['onchange']]]]}}" bind:change="__e"></uni-data-picker><input style="display:none;" type="text" name="{{'form'+idx}}" value=""/></block></block><block s-if="{{item.key=='upload'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value=""/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block s-if="{{editorFormdata[idx]}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-close" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgForm',['$event']]]]]}}" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="dp-form-imgbox-img"><image class="image" src="{{editorFormdata[idx]}}" data-url="{{editorFormdata[idx]}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-else><view class="dp-form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" bindtap="__e"></view></block></view></block></block><block s-if="{{item.key=='upload_pics'}}"><block><input style="display:none;" type="text" name="{{'form'+idx}}" value="" maxlength="-1"/><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block s-for="editorFormdata[idx] trackBy index2" s-for-item="item2" s-for-index="index2"><view class="dp-form-imgbox"><view class="dp-form-imgbox-close" data-index="{{index2}}" data-type="pics" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-event-opts="{{[['tap',[['removeimgForm',['$event']]]]]}}" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="dp-form-imgbox-img" style="margin-bottom:10rpx;"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="aspectFit" data-idx="{{idx}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><view class="dp-form-uploadbtn" style="{{'background:'+('url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx')+';'+('background-size:'+('80rpx 80rpx')+';')+('background-color:'+('#F3F3F3')+';')+('margin-bottom:'+('10rpx')+';')}}" data-idx="{{idx}}" data-formidx="{{'form'+idx}}" data-type="pics" data-event-opts="{{[['tap',[['editorChooseImage',['$event']]]]]}}" bindtap="__e"></view></view></block></block></view></block></view></block><view><textarea placeholder="{{inputtips}}" name="content" maxlength="-1"></textarea></view><block s-if="{{need_call}}"><view><input type="text" placeholder="输入联系电话" name="mobile"/></view></block><block s-if="{{isphone}}"><block><view><input type="text" placeholder="请输入姓名" name="name"/></view><view><input type="text" placeholder="请输入手机号" name="mobile"/></view><block s-if="{{isphoneother}}"><block><view><input type="text" placeholder="请输入QQ" name="qq"/></view><view><input type="text" placeholder="请输入微信号" name="wechat"/></view></block></block></block></block><view class="uploadbtn_ziti1">插入图片</view><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pics.length<9}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g0}}"/><view class="uploadbtn_ziti2">插入视频</view><view class="flex-y-center" style="width:100%;padding:20rpx 0;margin-top:20rpx;"><image style="width:200rpx;height:200rpx;background:#eee;" src="{{pre_url+'/static/img/uploadvideo.png'}}" data-event-opts="{{[['tap',[['uploadvideo',['$event']]]]]}}" bindtap="__e"></image><block s-if="{{video}}"><text style="padding-left:20rpx;color:#333;">已上传短视频</text></block></view><input type="text" hidden="true" name="video" maxlength="-1" value="{{video}}"/><block s-if="{{paytop==1&&topoptions}}"><block><view class="uploadbtn_ziti2">帖子置顶展示</view><scroll-view class="top-scroll" style="padding:20rpx 0;" scroll-x="true" show-scrollbar="false" scroll-with-animation="{{true}}"><view class="top-options flex"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view data-event-opts="{{[['tap',[['selectTopTime',[index]]]]]}}" class="{{['top-option',(topselected===index)?'selected':'']}}" style="{{'background:'+(topselected==index?'linear-gradient(-90deg,'+item.m0+' 0%,rgba('+item.m1+',0.8) 100%)':'')+';'}}" bindtap="__e"><view class="time">{{"置顶"+item.$orig.hour+"小时"}}</view><view class="price">{{item.$orig.price+"元"}}</view></view></block></view></scroll-view></block></block></view></view><view class="st_title flex-y-center"><block s-if="{{paytop==1&&topselected>=0}}"><button style="{{'background:'+('linear-gradient(-90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" form-type="submit">{{"支付"+topprice+"元 发表"}}</button></block><block s-else><button style="{{'background:'+('linear-gradient(-90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')+';'}}" form-type="submit">发表</button></block></view><view style="width:100%;margin-top:20rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="fatielog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的发帖记录<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view style="width:100%;height:50rpx;"></view></form></block></block><block s-if="{{loading}}"><loading vue-id="43df745a-2"></loading></block><dp-tabbar vue-id="43df745a-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="43df745a-4" data-ref="popmsg"></popmsg></view>