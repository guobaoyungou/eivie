<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="container2"><block s-if="{{banner}}"><image style="width:100%;height:auto;" src="{{banner}}" mode="widthFix"></image></block><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="top"><image class="f1" src="{{item.headimg}}"></image><view class="f2"><view class="t1">{{item.nickname}}</view><view class="t2">{{item.showtime}}</view></view></view><view class="con"><block s-if="{{item.form}}"><block><block s-for="item.form.formcontent trackBy sindex" s-for-item="subitem" s-for-index="sindex"><block s-if="{{item.form['form'+sindex]}}"><view class="dp-form-item"><block s-if="{{subitem.key!='upload'&&subitem.key!='upload_pics'}}"><block><view>{{item.form['form'+sindex]}}</view></block></block><block s-if="{{subitem.key=='upload_pics'||subitem.key=='upload'}}"><block><view class="flex"><block s-for="item.form['form'+sindex] trackBy index2" s-for-item="item2" s-for-index="index2"><block s-if="{{item2}}"><view class="dp-form-imgbox"><view class="dp-form-imgbox-img"><image class="image" src="{{item2}}" data-url="{{item2}}" mode="heightFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" catchtap="__e"></image></view></view></block></block></view></block></block></view></block></block></block></block><view class="f1"><text style="white-space:pre-wrap;">{{item.content}}</text></view><block s-if="{{item.pics}}"><view class="f2"><block s-for="item.pics trackBy idx" s-for-item="pic" s-for-index="idx"><image style="height:auto;" src="{{pic}}" mode="widthFix"></image></block></view></block><block s-if="{{item.video}}"><video class="video" id="video" src="{{item.video}}" data-event-opts="{{[['tap',[['playvideo',['$event']]]]]}}" catchtap="__e"></video></block></view><block s-if="{{item.isshowphone}}"><view class="phone"><block s-if="{{item.name}}"><view class="f1"><label class="t1">姓名：</label>{{item.name}}</view></block><block s-if="{{item.mobile}}"><view class="f1"><label class="t1">手机号：</label>{{item.mobile}}</view></block></view></block><view class="bot"><view class="f1"><image style="margin-top:0;" src="{{pre_url+'/static/img/lt_read.png'}}"></image>{{item.readcount}}</view><view class="f1" style="margin-left:60rpx;"><image src="{{pre_url+'/static/img/lt_pinglun.png'}}"></image>{{item.plcount}}</view><view class="f2"></view><block s-if="{{sysset.cansave}}"><view class="f4" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['savecontent',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/lt_save.png'}}"></image>保存</view></block><view class="f3" data-id="{{item.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['zan',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/lt_like'+(item['iszan']==0?'':'2')+'.png'}}"></image>{{item.zan}}</view></view></view></block></block><block s-if="{{nomore}}"><nomore vue-id="38e13590-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="38e13590-2"></nodata></block></view></view><view class="{{['covermy',menuindex>-1?'tabbarbot':'notabbarbot']}}" data-url="{{'fatie?cid='+cid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/lt_fatie.png'}}"></image></view></block></block><block s-if="{{loading}}"><loading vue-id="38e13590-3"></loading></block><dp-tabbar vue-id="38e13590-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="38e13590-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="38e13590-6"></wxxieyi></view>