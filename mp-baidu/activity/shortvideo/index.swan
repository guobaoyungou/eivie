<view class="container"><block s-if="{{isload}}"><block><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的视频" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-if="{{clist.length>0}}"><dd-tab vue-id="8f8f839a-1" itemdata="{{cnamelist}}" itemst="{{cidlist}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></block></view><view class="content" style="{{(clist.length>0?'margin-top:190rpx':'margin-top:100rpx')}}"><block s-if="{{sysset.list_type==1}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item2" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="image" src="{{item.coverimg}}" mode="widthFix"></image></view><view class="f2"><view class="t1">{{item.name}}</view><view class="t2">{{item.description}}</view><view class="t3">{{"播放量 "+item.view_num+''}}<text style="padding:0 20rpx;">·</text>{{'点赞数 '+item.zan_num}}</view><view class="t4"><image class="touxiang" src="{{item.binfo.logo}}"></image>{{item.binfo.name}}</view></view></view></block></block></block><block s-else><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" style="{{(index%2==0?'margin-right:2%':'')}}"><image class="ff" mode="widthFix" src="{{item.coverimg}}" data-url="{{'detail?id='+item.id+'&cid='+st}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="f2"><view class="t1"><image class="touxiang" src="{{item.binfo.logo}}"></image></view><view class="t2"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_playnum.png'}}"></image>{{item.view_num}}</view><view class="t3"><image class="tubiao" src="{{pre_url+'/static/img/shortvideo_likenum.png'}}"></image>{{item.zan_num}}</view></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="8f8f839a-2"></nomore></block><block s-if="{{nodata}}"><view class="item" style="display:block;"><nodata vue-id="8f8f839a-3"></nodata></view></block><block s-if="{{sysset.can_upload==1}}"><view class="{{['covermy',menuindex>-1?'tabbarbot':'notabbarbot']}}" data-url="{{'uploadvideo?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/shortvideo_uploadbtn.png'}}"></image></view></block></block></block><block s-if="{{loading}}"><loading vue-id="8f8f839a-4"></loading></block><dp-tabbar vue-id="8f8f839a-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="8f8f839a-6" data-ref="popmsg"></popmsg></view>