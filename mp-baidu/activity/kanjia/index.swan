<view class="container"><block s-if="{{isload}}"><block><view class="banner"><image src="{{pic}}" mode="widthFix"></image></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="product-item2" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><block s-for="item.joinlist trackBy index2" s-for-item="join" s-for-index="index2"><view class="t1"><image src="{{join.headimg}}"></image></view></block><block s-if="{{item.saleing>7}}"><view class="t1"><image src="{{pre_url+'/static/img/moreuser.png'}}"></image></view></block><view class="t2">{{item.saleing+"人正在参加"}}</view></view><view class="p3"><view class="t1"><text class="x1"><text style="font-size:22rpx;">最低￥</text>{{item.min_price}}</text><text class="x2">{{"￥"+item.sell_price}}</text></view><button class="t2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" bindtap="__e">去砍价</button></view></view></view></block></block><block s-if="{{nomore}}"><nomore vue-id="5e804fa8-1" textcolor="#faa" linecolor="#f66"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="5e804fa8-2"></nodata></block><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的订单</button></block></block><block s-if="{{loading}}"><loading vue-id="5e804fa8-3"></loading></block><dp-tabbar vue-id="5e804fa8-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5e804fa8-5" data-ref="popmsg"></popmsg></view>