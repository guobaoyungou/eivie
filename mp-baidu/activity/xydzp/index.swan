<view class="container"><block s-if="{{isload}}"><block><view class="pageback" style="{{'background:'+(backcolor==''?'#f58d40':backcolor)+';'}}"></view><view class="wrap" style="{{('background-image:url('+info.bgpic+');background-size:100% 100%;')}}"><view class="header clearfix"><view data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" class="rule" bindtap="__e">活动规则</view><view class="my" data-url="{{'myprize?hid='+info.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的奖品</view></view><view class="title" style="{{('background-image:url('+info.banner+');background-size:100% 100%;')}}"></view><view class="canvas" hidden="{{showmaskrule||jxshow||showqrpopup}}"><block s-if="{{showdzp}}"><canvas style="width:650rpx;height:650rpx;" canvas-id="roulette"><cover-image class="start" src="{{pre_url+'/static/img/xydzp_start.png'}}" data-event-opts="{{[['tap',[['rollStart',['$event']]]]]}}" bindtap="__e"></cover-image></canvas></block></view><block s-if="{{info.use_type!=2}}"><view class="border">您今日还有<text id="change">{{remaindaytimes}}</text>次抽奖机会</view></block><block s-if="{{info.use_type==1&&info.usescore>0}}"><view class="border2"><block s-if="{{!info.is_tr}}"><text>每次</text></block><block s-else><text>本次</text></block>抽奖将消耗<text>{{info.usescore}}</text>{{''+$root.m0+'，您共有'}}<text id="myscore">{{member.score}}</text>{{''+$root.m1}}</view></block><block s-if="{{info.use_type==2&&info.usemoney>0}}"><view class="border2">每次抽奖将消耗<text>{{$root.m2}}</text>{{info.usemoney+'元 ，您共有'}}<text id="mymoney">{{member.money}}</text>元</view></block><view class="scroll"><view class="p" style="{{('background-image: url('+pre_url+'/static/img/dzp/list.png);background-size:100% 100%;')}}"></view><view class="sideBox"><swiper class="bd" autoplay="true" indicator-dots="{{false}}" current="0" vertical="{{true}}" circular="true"><block s-for="zjlist trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{index%2==0}}"><swiper-item class="sitem"><view>{{"恭喜"+item.nickname+" 获得"}}<text class="info">{{item.jxmc}}</text></view><block s-if="{{zjlist[index+1]}}"><view>{{"恭喜"+zjlist[index+1].nickname+" 获得"}}<text class="info">{{zjlist[index+1].jxmc}}</text></view></block></swiper-item></block></block></swiper></view></view><block s-if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">活动规则说明</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{info.guize}}</text></view></view></view></view></block><block s-if="{{jxshow&&jx>0}}"><view id="mask"><view class="blin"></view><view class="caidai" style="{{('background-image: url('+pre_url+'/static/img/dzp/dianzhui.png);')}}"></view><view class="winning reback" style="{{('background:url('+pre_url+'/static/img/dzp/bg2.png) no-repeat;background-size:100% 100%;')}}"><view class="p"><view>恭喜您抽中了</view><view class="b" id="text1">{{jxmc}}</view></view><view data-event-opts="{{[['tap',[['changemask',['$event']]]]]}}" class="btn" bindtap="__e">确定</view></view></view></block><block s-if="{{jxshow&&jx==0}}"><view id="mask2"><view class="blin"></view><view class="caidai" style="{{('background-image: url('+pre_url+'/static/img/dzp/dianzhui.png);')}}"></view><view class="winning reback" style="{{('background:url('+pre_url+'/static/img/dzp/bg3.png) no-repeat;background-size:100% 100%;')}}"><view class="p"><view class="b text2" id="text2">{{jxmc}}</view></view><view data-event-opts="{{[['tap',[['changemask',['$event']]]]]}}" class="btn" bindtap="__e">确定</view></view></view></block><block s-if="{{showqrpopup}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideqrmodal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__content"><view><image data-url="{{info.qrcode}}" src="{{info.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><block s-if="{{info.qrcode_tip}}"><view class="txt">{{info.qrcode_tip}}</view></block></view></view></view></block><block s-if="{{maskshow&&!formdata}}"><view id="mask-rule1"><view class="box-rule" style="height:640rpx;"><view class="h2">请填写兑奖信息</view><view style="{{('background: no-repeat center / contain;background-image: url('+pre_url+'/static/img/dzp/close.png);')}}" id="close-rule1" data-event-opts="{{[['tap',[['changemaskshow',['$event']]]]]}}" bindtap="__e"></view><view class="con"><form data-event-opts="{{[['submit',[['formsub',['$event']]]]]}}" bindsubmit="__e"><view class="pay-form" style="margin-top:0.18rem;"><block s-for="info.formcontent trackBy idx" s-for-item="item" s-for-index="idx"><view class="item flex-y-center"><view class="f1">{{item.val1+"："}}</view><view class="f2 flex flex1"><block s-if="{{item.key=='input'}}"><block><input class="input" type="text" name="{{'form'+idx}}" placeholder="{{item.val2}}"/></block></block><block s-if="{{item.key=='textarea'}}"><block><textarea class="textarea" name="{{'form'+idx}}" placeholder="{{item.val2}}"></textarea></block></block><block s-if="{{item.key=='radio'}}"><block><radio-group class="radio-group" name="{{'form'+idx}}"><block s-for="item.val2 trackBy index" s-for-item="item1" s-for-index="index"><label><radio value="{{item1}}"></radio>{{item1+''}}</label></block></radio-group></block></block><block s-if="{{item.key=='checkbox'}}"><block><checkbox-group name="{{'form'+idx}}"><block s-for="item.val2 trackBy index" s-for-item="item1" s-for-index="index"><label><checkbox class="xyy-zu" value="{{item1}}"></checkbox>{{item1+''}}</label></block></checkbox-group></block></block><block s-if="{{item.key=='switch'}}"><block><switch class="xyy-zu" value="1" name="{{'form'+idx}}"></switch></block></block><block s-if="{{item.key=='selector'}}"><block><picker class="xyy-pic" mode="selector" name="{{'form'+idx}}" range="{{item.val2}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['selector_editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{item.val2[selectIndex]}}"><view class="picker">{{''+item.val2[selectIndex]}}</view></block><block s-else><view>请选择</view></block></picker></block></block><block s-if="{{item.key=='time'}}"><block><picker class="xyy-pic" mode="time" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['time_editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{picker_tmer}}"><view class="picker">{{picker_tmer}}</view></block><block s-else><view>选择时间</view></block></picker></block></block><block s-if="{{item.key=='date'}}"><block><picker class="xyy-pic" mode="date" name="{{'form'+idx}}" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['change',[['date_editorBindPickerChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{picker_date}}"><view class="picker">{{''+picker_date}}</view></block><block s-else><view>选择日期</view></block></picker></block></block><block s-if="{{item.key=='region'}}"><block><uni-data-picker class="flex1" style="color:#333;" vue-id="{{'593a38cd-1-'+idx}}" localdata="{{items}}" popup-title="请选择省市区" data-idx="{{idx}}" data-tplindex="0" data-event-opts="{{[['^change',[['region_editorBindPickerChange']]]]}}" bind:change="__e" vue-slots="{{['default']}}"><input style="border:none;font-size:28rpx;padding:0rpx;color:#fff;" type="text" name="{{'form'+idx}}" placeholder="请选择省市区" placeholder-style="color:#fff;font-size:28rpx" value="{{picker_region}}"/></uni-data-picker></block></block></view></view></block><view><button class="subbtn" form-type="submit">确 定</button></view></view></form></view></view></view></block></view></block></block><block s-if="{{loading}}"><loading vue-id="593a38cd-2"></loading></block><dp-tabbar vue-id="593a38cd-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="593a38cd-4" data-ref="popmsg"></popmsg><wxxieyi vue-id="593a38cd-5"></wxxieyi></view>