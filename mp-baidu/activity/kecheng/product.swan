<view><block s-if="{{isload}}"><block><view class="swiper-container"><swiper class="swiper" style="{{'height:'+(swiperHeight+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{500000}}" current="{{current}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" bindchange="__e"><block s-for="product.pics trackBy index" s-for-item="item" s-for-index="index"><block><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{item}}" mode="widthFix" data-event-opts="{{[['load',[['loadImg',['$event']]]]]}}" bindload="__e"></image></view></swiper-item></block></block></swiper><view class="imageCount">{{current+1+"/"+product.pics.length}}</view></view><view class="header"><view class="price_share"><view class="title">{{product.name}}</view><view data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="share" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/share.png'}}"></image><text class="txt">分享</text></view></view><view class="pricebox flex"><view class="price"><block s-if="{{product.price>0}}"><view class="f1" style="{{'color:'+($root.m0)+';'}}">￥<text style="font-size:36rpx;">{{product.price}}</text></view></block><block s-else><view class="f1" style="{{'color:'+($root.m1)+';'}}"><text style="font-size:36rpx;">免费</text></view></block><block s-if="{{product.market_price>0}}"><view class="f2">{{"￥"+product.market_price}}</view></block></view><block s-if="{{!product.chaptertype||product.chaptertype==1}}"><view class="sales_stock"><view class="f1">{{product.count+"节课"}}<block s-if="{{sysset&&sysset.show_join_num==1}}"><block><text style="margin:0 6rpx;">|</text>{{"已有"+product.join_num+"人学习"}}</block></block></view></view></block></view><block s-if="{{kechengset.showcommission==1&&product.commission>0}}"><view class="commission" style="{{'background:'+('rgba('+$root.m2+',0.1)')+';'+('color:'+($root.m3)+';')}}">{{"分享好友购买预计可得"+$root.m4+"："}}<text style="font-weight:bold;padding:0 2px;">{{product.commission}}</text>{{product.commission_desc}}</view></block><block s-if="{{kechengset.show_lvupsavemoney==1&&product.upgrade_text&&product.price>0}}"><view class="upsavemoney" style="{{'background:'+('linear-gradient(90deg, rgb(255, 180, 153) 0%, #ffcaa8 100%)')+';'+('color:'+('#653a2b')+';')}}"><view class="flex1">{{product.upgrade_text+''}}</view><view style="margin-left:20rpx;font-weight:bold;display:flex;align-items:center;color:#ca4312;" data-url="/pagesExt/my/levelup" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright2.png'}}"></image></view></view></block></view><block s-if="{{!product.chaptertype||product.chaptertype==1}}"><view class="detail"><view class="detail_title"><view class="order-tab2"><view class="{{['item '+(curTopIndex==1?'on':'')]}}" data-index="{{1}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">课程介绍<view class="after" style="{{'background:'+($root.m5)+';'}}"></view></view><view class="{{['item '+(curTopIndex==2?'on':'')]}}" data-index="{{2}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">课程目录<view class="after" style="{{'background:'+($root.m6)+';'}}"></view></view></view></view><block s-if="{{curTopIndex==1}}"><block><dp vue-id="6409b8ca-1" pagecontent="{{pagecontent}}"></dp></block></block><block s-if="{{curTopIndex==2}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="mulubox-container"><view class="mulubox flex" data-mianfei="{{item.ismianfei}}" data-url="{{'mldetail?id='+item.id+'&kcid='+item.kcid}}" data-index="{{index}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" bindtap="__e"><block s-if="{{item.children&&item.children.length>0}}"><view class="left_box"><image style="{{'width:24rpx;height:24rpx;'+(item.expanded&&item.children&&item.children.length>0?'':'transform: rotate(-90deg);')}}" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view></block><block s-else><view class="left_box"><block s-if="{{item.kctype==1}}"><image src="{{pre_url+'/static/img/tw_icon.png'}}"></image></block><block s-if="{{item.kctype==2}}"><image src="{{pre_url+'/static/img/mp3_icon.png'}}"></image></block><block s-if="{{item.kctype==3}}"><image src="{{pre_url+'/static/img/video_icon.png'}}"></image></block></view></block><view class="right_box flex"><view class="title_box"><view class="t1">{{''+item.name}}</view><view><block s-if="{{item.kctype==1}}"><text class="t2">图文课程</text></block><block s-if="{{item.kctype==2}}"><text class="t2">音频课程</text></block><block s-if="{{item.kctype==3}}"><text class="t2">视频课程</text></block><block s-if="{{item.kctype!=1}}"><text class="t2">{{'时长: '+(item.duration?item.duration:'未知')}}</text></block></view></view><block s-if="{{item.ismianfei&&product.price>0}}"><view class="skbtn">试看</view></block><block s-if="{{product.price==0}}"><view class="skbtn">免费</view></block></view></view><block s-if="{{item.expanded&&item.children&&item.children.length>0}}"><view class="{{['children-container',item.expanded&&item.children&&item.children.length>0?'expanded':'']}}"><block s-for="item.children trackBy child.id" s-for-item="child" s-for-index="childIndex"><view class="child-item" data-mianfei="{{child.ismianfei}}" data-url="{{'mldetail?id='+child.id+'&kcid='+child.kcid}}" data-event-opts="{{[['tap',[['todetail',['$event']]]]]}}" bindtap="__e"><view class="mulubox flex"><view class="left_box"><view style="width:40rpx;height:1px;"></view><block s-if="{{child.kctype==1}}"><image style="margin-left:40rpx;" src="{{pre_url+'/static/img/tw_icon.png'}}"></image></block><block s-if="{{child.kctype==2}}"><image style="margin-left:40rpx;" src="{{pre_url+'/static/img/mp3_icon.png'}}"></image></block><block s-if="{{child.kctype==3}}"><image style="margin-left:40rpx;" src="{{pre_url+'/static/img/video_icon.png'}}"></image></block></view><view class="right_box flex"><view class="title_box"><view class="t1">{{''+child.name}}</view><view><block s-if="{{child.kctype==1}}"><text class="t2">图文课程</text></block><block s-if="{{child.kctype==2}}"><text class="t2">音频课程</text></block><block s-if="{{child.kctype==3}}"><text class="t2">视频课程</text></block><block s-if="{{child.kctype!=1}}"><text class="t2">{{'时长: '+(child.duration?child.duration:'未知')}}</text></block></view></view><block s-if="{{child.ismianfei&&product.price>0}}"><view class="skbtn">试看</view></block><block s-if="{{product.price==0}}"><view class="skbtn">免费</view></block></view></view></view></block></view></block></view></block><block s-if="{{kechengset.details_rec==1&&!nomore}}"><view data-event-opts="{{[['tap',[['showmore',['$event']]]]]}}" class="more" bindtap="__e">点击查看更多</view></block><block s-if="{{nomore}}"><nomore vue-id="6409b8ca-2" text="没有更多课程了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="6409b8ca-3" text="没有查找到相关课程"></nodata></block></block></block></view></block><block s-else><block s-if="{{product.freecontent}}"><view class="detail"><view style="padding:20rpx;font-size:28rpx;"><parse vue-id="6409b8ca-4" content="{{product.freecontent}}"></parse></view></view></block></block><view><block s-if="{{tjdatalist.length>0}}"><view class="xihuan"><view class="xihuan-line"></view><view class="xihuan-text"><image class="img" src="{{pre_url+'/static/img/xihuan.png'}}"></image><text class="txt">为您推荐</text></view><view class="xihuan-line"></view></view></block><view class="prolist"><dp-kecheng-item vue-id="6409b8ca-5" data="{{tjdatalist}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]]]}}" bind:addcart="__e"></dp-kecheng-item></view></view><view style="width:100%;height:140rpx;"></view><block s-if="{{product.status==1}}"><view class="{{['bottombar','flex-row',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view class="f1" style="width:100%;flex:1;"><view class="item" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/shou.png'}}"></image><view class="t1">首页</view></view><block s-if="{{kfurl!='contact::'}}"><view class="item" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></view></block><block s-else><button class="item" open-type="contact" show-message-card="true"><image class="img" src="{{pre_url+'/static/img/kefu.png'}}"></image><view class="t1">客服</view></button></block><view data-event-opts="{{[['tap',[['addfavorite',['$event']]]]]}}" class="item" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/shoucang.png'}}"></image><view class="t1">{{isfavorite?'已收藏':'收藏'}}</view></view></view><view class="op" style="width:100%;flex:1;"><block s-if="{{product.price==0||product.ispay==1}}"><block><view class="tobuy"><block s-if="{{!product.chaptertype||product.chaptertype==1}}"><block><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m7)+';'}}" data-url="{{'mldetail?kcid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">立即学习</view></block></block><block s-else><block><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m8)+';'}}" data-url="{{'/pagesB/kecheng/lecturermldetail?kcid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">立即查看</view></block></block></view></block></block><block s-else><block><block s-if="{{!product.chaptertype||product.chaptertype==1}}"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m9)+';'}}" bindtap="__e">立即购买</view></block><block s-else><view class="tobuy flex-x-center flex-y-center" style="{{'background:'+($root.m10)+';'}}" data-url="{{'/pagesB/kecheng/lecturermldetail?kcid='+product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">立即查看</view></block></block></block></view></view></block><scrolltop vue-id="6409b8ca-6" isshow="{{scrolltopshow}}"></scrolltop><block s-if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block s-if="{{$root.m11=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m12=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m13!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block s-if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="6409b8ca-7"></loading></block><dp-tabbar vue-id="6409b8ca-8" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="6409b8ca-9" data-ref="popmsg"></popmsg></view>