<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入课程标题搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.title}}</text><view class="t4 flex"><view><view class="t3"><text class="x1 flex1">{{item.price==0||item.price==null?'免费':'支付金额：￥'+item.price}}</text></view><view class="t2"><text>{{"共"+item.kccount+"节 已学"+item.count+"节"}}</text></view></view><block s-if="{{!item.orderlearn}}"><block><block s-if="{{item.iskaoshi!=1&&item.count>=item.kccount&&item.isdt==1}}"><view class="btn2" data-url="{{'tiku?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去答题</view></block><block s-if="{{item.iskaoshi!=1&&item.count<item.kccount}}"><view class="btn2" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">继续学习</view></block><block s-if="{{item.iskaoshi==1}}"><view class="btn2" data-url="{{'recordlog?kcid='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">答题记录</view></block></block></block><block s-else><block><view><block s-if="{{item.count<item.kccount}}"><view class="btn2" style="margin-top:10rpx;" data-url="{{'product?id='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">继续学习</view></block><block s-if="{{item.iskaoshi==1}}"><view class="btn2" style="margin-top:10rpx;" data-url="{{'recordlog?kcid='+item.kcid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">答题记录</view></block></view></block></block></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="09889c6d-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="09889c6d-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="09889c6d-3"></loading></block><dp-tabbar vue-id="09889c6d-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="09889c6d-5" data-ref="popmsg"></popmsg></view>