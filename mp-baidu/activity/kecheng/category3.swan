<view class="container"><block s-if="{{isload}}"><block><view class="view-show"><view class="search-container" data-url="/activity/kecheng/list" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的课程</view></view></view><view class="content" style="height:calc(100% - 94rpx);overflow:hidden;display:flex;"><scroll-view class="{{['nav_left',menuindex>-1?'tabbarbot':'notabbarbot']}}" scrollWithAnimation="{{animation}}" scroll-y="true"><block s-for="data trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['nav_left_items',index===currentActiveIndex?'active':'']}}" data-root-item-id="{{item.id}}" data-root-item-index="{{index}}" data-event-opts="{{[['tap',[['clickRootItem',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name}}</view></block></block></scroll-view><view class="nav_right"><view class="nav_right-content"><scroll-view class="{{['detail-list',menuindex>-1?'tabbarbot':'notabbarbot']}}" scrollWithAnimation="{{animation}}" scroll-y="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" bindscroll="__e"><block s-for="clist trackBy index" s-for-item="detail" s-for-index="index"><view class="classification-detail-item"><view class="head" data-id="{{detail.id}}" id="{{'detail-'+detail.id}}"><view class="txt">{{detail.name}}</view><view class="show-all" data-key="{{index}}" data-id="{{detail.id}}" data-event-opts="{{[['tap',[['hideshow',['$event']]]]]}}" bindtap="__e">{{detail.ishide!=1?'收起':'展开'}}</view></view><block s-if="{{detail.ishide!=1}}"><view class="detail"><block s-for="detail.child trackBy itemIndex" s-for-item="item" s-for-index="itemIndex"><view class="detail-item" style="{{((itemIndex+1)%3===0?'margin-right: 0':'')}}" data-url="{{'/activity/kecheng/list?cid='+item.id}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image class="img" src="{{item.pic}}"></image><view class="txt">{{item.name}}</view></view></block></view></block></view></block><block s-if="{{nodata}}"><nodata vue-id="6ad70ff8-1"></nodata></block></scroll-view></view></view></view></view></block></block><view style="display:none;">{{test}}</view><block s-if="{{loading}}"><loading vue-id="6ad70ff8-2" loadstyle="left:62.5%"></loading></block><dp-tabbar vue-id="6ad70ff8-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="6ad70ff8-4" data-ref="popmsg"></popmsg></view>