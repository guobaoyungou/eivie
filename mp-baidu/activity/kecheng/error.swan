<view><block s-if="{{isload}}"><block><view class="wrap"><view class="top flex"><block s-if="{{tkdata.type==1&&tkdata.rightcount==1}}"><view class="f1">单选题</view></block><block s-if="{{tkdata.type==1&&tkdata.rightcount==2}}"><view class="f1">多选题</view></block><block s-if="{{tkdata.type==2}}"><view class="f1">填空题</view></block><view class="f3">{{tkdata.sort+"/"+tkdata.nums}}</view></view><view class="question"><view class="title">{{''+tkdata.sort+"."+tkdata.title+''}}</view><block s-if="{{tkdata.type==1&&tkdata.rightcount==1}}"><block><view class="option_group"><block s-for="tkdata.option trackBy index" s-for-item="item" s-for-index="index"><view class="{{['option flex '+(index==currentindex?'on':'')]}}">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item}}</view></view></block></view></block></block><block s-if="{{tkdata.type==1&&tkdata.rightcount>1}}"><block><view class="option_group"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="{{['option flex '+(item.g0!=-1?'on':'')]}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',[index]]]]]}}" bindtap="__e">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item.$orig}}</view></view></block></view></block></block><block s-if="{{tkdata.type==1&&!tkdata.rightcount}}"><block><view class="option_group"><block s-for="tkdata.option trackBy index" s-for-item="item" s-for-index="index"><view class="{{['option flex ']}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',[index]]]]]}}" bindtap="__e">{{''+tkdata.sorts[index]+''}}<view class="after"></view><view class="t1">{{item}}</view></view></block></view></block></block><block s-if="{{tkdata.type==2}}"><block><view class="option_group"><view class="uni-textarea"><textarea placeholder-style="color:#222" placeholder="答:" data-event-opts="{{[['blur',[['bindTextAreaBlur',['$event']]]]]}}" value="{{tkdata.answer}}" bindblur="__e"></textarea></view></view></block></block></view></view><view class="right_content"><text class="t1">正确答案</text><text class="t2">{{(tkdata.type==2?tkdata.right_option:'')+(tkdata.type==1?tkdata.right_options:'')}}</text><view style="color:#93949E;font-size:26rpx;">{{"题目解析："+tkdata.jiexi}}</view></view><view class="bottom flex"><block s-if="{{tkdata.isup!=1}}"><block><button class="upbut flex-x-center flex-y-center hui">上一题</button></block></block><block s-if="{{tkdata.isup==1}}"><block><button class="upbut flex-x-center flex-y-center" style="{{'background:'+($root.m0)+';'}}" data-dttype="up" data-event-opts="{{[['tap',[['toanswer',['$event']]]]]}}" bindtap="__e">上一题</button></block></block><block s-if="{{tkdata.isdown==1}}"><button class="downbtn flex-x-center flex-y-center" style="{{'background:'+($root.m1)+';'}}" data-dttype="down" data-event-opts="{{[['tap',[['toanswer',['$event']]]]]}}" bindtap="__e">下一题</button></block><block s-if="{{tkdata.isdown!=1}}"><button class="downbtn flex-x-center flex-y-center hui">下一题</button></block></view></block></block><block s-if="{{loading}}"><loading vue-id="372d99d1-1"></loading></block><dp-tabbar vue-id="372d99d1-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="372d99d1-3" data-ref="popmsg"></popmsg></view>