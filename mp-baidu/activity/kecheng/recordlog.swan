<view class="container"><block s-if="{{isload}}"><block><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'complete?rid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="content flex"><view class="detail"><text class="t1">{{item.title}}</text><text class="t2">{{item.date}}</text></view><view class="score"><text class="t3">{{item.score}}</text><text class="t4">分</text></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="07701c66-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="07701c66-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="07701c66-3"></loading></block><dp-tabbar vue-id="07701c66-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="07701c66-5" data-ref="popmsg"></popmsg></view>