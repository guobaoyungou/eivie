<view><block s-if="{{isload}}"><block><view class="container"><view class="topbg"><image class="image" src="{{pre_url+'/static/img/collage_teambg.png'}}"></image></view><view class="topbox" data-url="{{'product?id='+product.id+'&teampid='+teamid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><image src="{{product.pic}}"></image></view><view class="right"><view class="f1">{{product.name}}</view><view class="f2"><block s-if="{{!product.collage_type}}"><view class="t1">{{product.teamnum+"人团"}}</view></block></view><view class="f3"><view class="t1">￥</view><view class="t2">{{product.sell_price}}</view><view class="t3">{{product.sales+"人已拼"}}</view></view></view></view><view class="teambox"><view class="userlist"><block s-for="userlist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><image class="f1" src="{{item.headimg?item.headimg:pre_url+'/static/img/wh.png'}}"></image><block s-if="{{item.id==team.mid}}"><text class="f2">团长</text></block></view></block></view><block s-if="{{team.status==1}}"><view class="join-text"><block s-if="{{!product.collage_type}}"><view>仅剩<text class="join-te1">{{team.teamnum-team.num}}</text>个名额</view></block><view style="font-size:28rpx;color:#f80;">{{''+rtimeformat+" 后结束"}}</view></view></block><block s-if="{{team.status==2}}"><view class="join-text">已满员,拼团成功</view></block><block s-if="{{team.status==3}}"><view class="join-text">拼团失败</view></block><block s-if="{{team.status==1&&haveme==1}}"><button data-event-opts="{{[['tap',[['shareClick',['$event']]]]]}}" class="join-btn" bindtap="__e">邀请好友参团</button></block><block s-if="{{team.status==1&&haveme==0}}"><block><button data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="join-btn" bindtap="__e">我要参团</button><button class="join-btn2" style="margin-top:30rpx;" data-url="{{'product?id='+product.id+'&teampid='+teamid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">参与更多拼团</button></block></block></view><block s-if="{{show_mingpian}}"><view class="teambox"><block s-for="userlist trackBy index" s-for-item="item" s-for-index="index"><block class="item"><block s-if="{{item.id>0}}"><view class="item1"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><block s-if="{{item.id==team.mid}}"><text class="x2">团长</text></block></view></view><block s-if="{{item.mingpian_id>0}}"><view class="f2" data-url="{{'/pagesExt/mingpian/index?id='+item.mingpian_id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="x1">查看名片</text></view></block></view></block></block></block></view></block><view hidden="{{buydialogHidden}}"><view class="buydialog-mask"><view class="{{['buydialog',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="title"><image class="img" src="{{guigelist[ks].pic?guigelist[ks].pic:product.pic}}" data-url="{{guigelist[ks].pic?guigelist[ks].pic:product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><block s-if="{{btntype==1}}"><view class="price"><text class="t1">￥</text>{{guigelist[ks].market_price}}</view></block><block s-else><view class="price"><text class="t1">￥</text>{{guigelist[ks].sell_price+''}}<block s-if="{{guigelist[ks].market_price>guigelist[ks].sell_price}}"><text class="t2">{{"￥"+guigelist[ks].market_price}}</text></block></view></block><view class="choosename">{{"已选规格: "+guigelist[ks].name}}</view><view class="stock">{{"剩余"+guigelist[ks].stock+"件"}}</view></view><block s-for="guigedata trackBy index" s-for-item="item" s-for-index="index"><view class="guigelist flex-col"><view class="name">{{item.title}}</view><view class="item flex flex-y-center"><block s-for="item.items trackBy index2" s-for-item="item2" s-for-index="index2"><block><view class="{{['item2 '+(ggselected[item.k]==item2.k?'on':'')]}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" bindtap="__e">{{item2.title}}</view></block></block></view></view></block><block s-if="{{!product.collage_type}}"><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view class="minus"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" bindtap="__e"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" bindinput="__e"/><view class="plus"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><view class="op"><button class="tobuy" style="{{'background:'+($root.m0)+';'}}" data-type="3" data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" bindtap="__e">确 定</button></view></view></view></view></view><block s-if="{{sharetypevisible}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['handleClickMask',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal" style="height:320rpx;min-height:320rpx;"><view class="popup__content"><view class="sharetypecontent"><block s-if="{{$root.m1=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m2=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="f1" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></view></block><block s-else><block s-if="{{$root.m3!='h5'}}"><button class="f1" open-type="share"><image class="img" src="{{pre_url+'/static/img/sharefriends.png'}}"></image><text class="t1">分享给好友</text></button></block></block></block><view data-event-opts="{{[['tap',[['showPoster',['$event']]]]]}}" class="f2" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/sharepic.png'}}"></image><text class="t1">生成分享图片</text></view></view></view></view></view></block><block s-if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="03f98b7c-1"></loading></block><dp-tabbar vue-id="03f98b7c-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="03f98b7c-3" data-ref="popmsg"></popmsg></view>