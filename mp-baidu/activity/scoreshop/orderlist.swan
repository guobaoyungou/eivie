<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="517890f8-1" itemdata="{{itemdata}}" itemst="{{itemst}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block s-if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.$orig.status==1&&item.$orig.freight_type!=1}}"><text class="st1">待发货</text></block><block s-if="{{item.$orig.status==1&&item.$orig.freight_type==1}}"><text class="st1">待提货</text></block><block s-if="{{item.$orig.status==2}}"><view class="st2"><block s-if="{{item.$orig.type&&item.$orig.type==1}}"><text>等待发放</text></block><block s-else><text>待收货</text></block></view></block><block s-if="{{item.$orig.status==3}}"><text class="st3">已完成</text></block><block s-if="{{item.$orig.status==4}}"><text class="st4">已关闭</text></block></view><block s-for="item.$orig.prolist trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.$orig.procount?'border-bottom:none':'')}}"><view data-url="{{'product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><block s-if="{{item2.ggname}}"><text class="t2" style="color:#666;">{{"规格："+item2.ggname}}</text></block><block s-else><text class="t2">{{"市场价￥"+item2.sell_price}}</text></block><view class="t3"><text class="x1 flex1"><block s-if="{{item2.money_price>0}}"><text>{{"￥"+item2.money_price+"+"}}</text></block>{{item2.score_price+item.m0}}</text><text class="x2">{{"×"+item2.num}}</text></view></view></view></block></block><view class="bottom"><text>{{"共计"+item.$orig.procount+"件商品 实付:￥"+item.$orig.totalprice}}</text><block s-if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block s-if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m1)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去付款</view></block></block><block s-if="{{item.$orig.status==1&&show_refund==1}}"><block><block s-if="{{item.$orig.paytypeid!='4'}}"><block><block s-if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice+'&score='+item.$orig.totalscore}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block></block></block><block s-else><block></block></block></block></block><block s-if="{{item.$orig.status==2}}"><block><block s-if="{{item.$orig.paytypeid!='4'&&show_refund==1}}"><block><block s-if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?orderid='+item.$orig.id+'&price='+item.$orig.totalprice+'&score='+item.$orig.totalscore}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block></block></block><block s-else><block></block></block><block s-if="{{item.$orig.freight_type!=3&&item.$orig.freight_type!=4}}"><view class="btn2" data-index="{{index}}" data-event-opts="{{[['tap',[['logistics',['$event']]]]]}}" catchtap="__e">查看物流</view></block><block s-if="{{item.$orig.paytypeid!='4'&&!item.$orig.type}}"><view class="btn-wrapper"><view class="btn1" style="{{'background:'+(item.m2)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['orderCollect',['$event']]]]]}}" catchtap="__e">确认收货</view><block s-if="{{collect_reward_set&&collect_reward_set.prompt&&item.$orig.is_collect_reward}}"><view class="tips-container" style="{{'background:'+('rgba('+item.m3+', 0.7)')+';'+('color:'+(collect_reward_set.fontcolor||'#fff')+';')}}"><text class="tips-text">{{collect_reward_set.prompt}}</text><view data-event-opts="{{[['tap',[['closeTips',[index]]]]]}}" class="close-btn" catchtap="__e">×</view><view class="arrow-up" style="{{'border-bottom:'+('12rpx solid rgba('+item.m4+', 0.7)')+';'}}"></view></view></block></view></block></block></block><block s-if="{{item.$orig.status==3||item.$orig.status==4}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['todel',['$event']]]]]}}" catchtap="__e">删除订单</view></block></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="517890f8-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="517890f8-3"></nodata></block><uni-popup class="vue-ref" vue-id="517890f8-4" id="dialogSelectExpress" type="dialog" data-ref="dialogSelectExpress" vue-slots="{{['default']}}"><block s-if="{{express_content}}"><view style="background:#fff;padding:20rpx 30rpx;border-radius:10rpx;width:600rpx;"><block s-for="express_content trackBy index" s-for-item="item" s-for-index="index"><view class="sendexpress" style="border-bottom:1px solid #f5f5f5;padding:20rpx 0;"><view class="sendexpress-item" style="display:flex;" data-url="{{'/pagesExt/order/logistics?express_com='+item.express_com+'&express_no='+item.express_no+'&ordertype='+item.ordertype+'&orderid='+item.orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="flex1" style="color:#121212;">{{item.express_com+" - "+item.express_no}}</view><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><block s-if="{{item.express_oglist}}"><view style="margin-top:20rpx;"><block s-for="item.express_oglist trackBy index2" s-for-item="item2" s-for-index="index2"><view class="oginfo-item" style="display:flex;align-items:center;margin-bottom:10rpx;"><image style="width:50rpx;height:50rpx;margin-right:10rpx;flex-shrink:0;" src="{{item2.pic}}"></image><view class="flex1" style="color:#555;">{{item2.name+"("+item2.ggname+")"}}</view></view></block></view></block></view></block></view></block></uni-popup><uni-popup class="vue-ref" vue-id="517890f8-5" type="center" data-ref="popupReward" vue-slots="{{['default']}}"><view class="popup-reward-content"><view class="popup-reward-price flex"><view class="price-num-text popup-color-text"><text>恭喜你获得</text><text>{{collect_reward}}</text></view><view data-event-opts="{{[['tap',[['popupRewardClose',['$event']]]]]}}" class="popup-reward-confirm" bindtap="__e">确认</view></view><image src="{{pre_url+'/static/img/ordercollect/rewardbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupRewardClose',['$event']]]]]}}" class="popupMiandan-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="517890f8-6"></loading></block><dp-tabbar vue-id="517890f8-7" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="517890f8-8" data-ref="popmsg"></popmsg></view>