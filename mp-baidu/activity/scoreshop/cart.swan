<view class="container"><block s-if="{{isload}}"><block><block s-if="{{cartlist.length>0}}"><block><view class="cartmain"><block s-for="$root.l1 trackBy item.$orig.bid" s-for-item="item" s-for-index="index"><block><view class="item"><view class="btitle"><view class="radio" style="{{(item.$orig.checked?'background:'+item.m0+';border:0':'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="btitle-name" data-url="{{item.$orig.bid==0?indexurl:'/pagesExt/business/index?id='+item.$orig.business.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{item.$orig.business.name}}</view><view class="flex1"></view><view class="btitle-del" data-bid="{{item.$orig.bid}}" data-event-opts="{{[['tap',[['cartdeleteb',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/del.png'}}"></image><text style="margin-left:10rpx;">еИ†йЩ§</text></view></view><block s-for="item.l0 trackBy index2" s-for-item="item2" s-for-index="index2"><view class="content"><view class="radio" style="{{(item2.$orig.checked?'background:'+item2.m1+';border:0':'')}}" data-index="{{index}}" data-index2="{{index2}}" data-event-opts="{{[['tap',[['changeradio2',['$event']]]]]}}" catchtap="__e"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="proinfo" style="{{(item.$orig.prolist.length==index2+1?'border:0':'')}}"><image class="img" src="{{item2.$orig.ggpic?item2.$orig.ggpic:item2.$orig.product.pic}}" data-url="{{'/activity/scoreshop/product?id='+item2.$orig.product.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="detail"><view class="title"><text>{{item2.$orig.product.name}}</text></view><view class="desc"><block s-if="{{item2.$orig.product.ggname}}"><text>{{"иІДж†ЉпЉЪпњ•"+item2.$orig.product.ggname}}</text></block><block s-else><text>{{"дїЈеАЉпЉЪпњ•"+item2.$orig.product.sell_price}}</text></block></view><view class="price" style="{{'color:'+(item.m2)+';'}}"><block s-if="{{item2.$orig.product.money_price>0}}"><text>{{"пњ•"+item2.$orig.product.money_price+"+"}}</text></block>{{item2.$orig.product.score_price+item.m3}}</view><view class="addnum"><view class="minus" data-index="{{index}}" data-index2="{{index2}}" data-cartid="{{item2.$orig.id}}" data-num="{{item2.$orig.num}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-max="{{item2.$orig.stock}}" data-index="{{index}}" data-index2="{{index2}}" data-cartid="{{item2.$orig.id}}" data-num="{{item2.$orig.num}}" data-event-opts="{{[['tap',[['',['$event']]]],['blur',[['gwcinput',['$event']]]]]}}" value="{{item2.$orig.num}}" catchtap="__e" bindblur="__e"/><view class="plus" data-index="{{index}}" data-index2="{{index2}}" data-max="{{item2.$orig.stock}}" data-num="{{item2.$orig.num}}" data-cartid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><view class="prodel" data-cartid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['cartdelete',['$event']]]]]}}" catchtap="__e"><image class="prodel-img" src="{{pre_url+'/static/img/del.png'}}"></image></view></view></view></block></view></block></block></view><view style="height:auto;position:relative;"><view style="width:100%;height:110rpx;"></view><view class="{{['footer','flex',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view class="text1">еРИиЃ°пЉЪ</view><view class="text2" style="{{'color:'+($root.m4)+';'}}"><block s-if="{{totalmoney>0}}"><text>{{"пњ•"+totalmoney+"+"}}</text></block><text>{{totalscore+$root.m5}}</text></view><view class="flex1"></view><view data-event-opts="{{[['tap',[['toOrder',['$event']]]]]}}" class="op" style="{{'background:'+('linear-gradient(-90deg,'+$root.m6+' 0%,rgba('+$root.m7+',0.8) 100%)')+';'}}" bindtap="__e">еОїзїУзЃЧ</view></view></view></block></block><block s-else><block><view class="data-empty"><image class="data-empty-img" style="width:120rpx;height:120rpx;" src="{{pre_url+'/static/img/cartnull.png'}}"></image><view class="data-empty-text" style="margin-top:20rpx;font-size:24rpx;">иі≠зЙ©иљ¶з©Їз©Їе¶ВдєЯ~</view><button style="width:400rpx;border:1px solid #ff6801;border-radius:6rpx;background:#ff6801;margin-top:20px;color:#fff;" data-url="{{scoreshopindexurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">еОїйАЙиі≠</button></view></block></block></block></block><block s-if="{{loading}}"><loading vue-id="0ae66264-1"></loading></block><dp-tabbar vue-id="0ae66264-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="0ae66264-3" data-ref="popmsg"></popmsg></view>