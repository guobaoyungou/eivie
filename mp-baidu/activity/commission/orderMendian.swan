<view class="container"><block s-if="{{isload}}"><block><view class="topfix"></view><block s-if="{{datalist&&datalist.length>0}}"><block><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text>{{item.ordernum}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.name}}</text><text class="x2">{{item.createtime}}</text><view class="x3"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></view><view class="t2"><block s-if="{{item.status==1||item.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block s-if="{{item.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><text class="dior-sp6 ywc">已完成</text><block s-if="{{item.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block s-if="{{item.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block></view></block></block></block></block><block s-if="{{nodata}}"><nodata vue-id="5e1e0eea-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="5e1e0eea-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="5e1e0eea-3"></loading></block><dp-tabbar vue-id="5e1e0eea-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5e1e0eea-5" data-ref="popmsg"></popmsg></view>