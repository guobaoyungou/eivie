<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text><text class="t2"></text></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><image src="{{item.$orig.headimg}}"></image><view class="t2"><text class="x1">{{item.$orig.nickname}}</text><text class="x2">{{item.m0}}</text><text class="x2">{{"等级："+item.$orig.levelname}}</text><block s-if="{{item.$orig.tel}}"><text class="x2">{{"手机号："+item.$orig.tel}}</text></block></view></view><view class="f2"><view class="t3"><block s-if="{{userlevel&&userlevel.team_givemoney==1}}"><view class="x1" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['givemoneyshow',['$event']]]]]}}" bindtap="__e">{{"转"+$root.m1}}</view></block><block s-if="{{userlevel&&userlevel.team_givescore==1}}"><view class="x1" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['givescoreshow',['$event']]]]]}}" bindtap="__e">{{"转"+$root.m2}}</view></block></view></view></view></block></block></view></block><uni-popup class="vue-ref" vue-id="56e0c19f-1" id="dialogmoneyInput" type="dialog" data-ref="dialogmoneyInput" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('56e0c19f-2')+','+('56e0c19f-1')}}" mode="input" title="转账金额" value="" placeholder="请输入转账金额" data-event-opts="{{[['^confirm',[['givemoney']]]]}}" bind:confirm="__e"></uni-popup-dialog></uni-popup><uni-popup class="vue-ref" vue-id="56e0c19f-3" id="dialogscoreInput" type="dialog" data-ref="dialogscoreInput" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('56e0c19f-4')+','+('56e0c19f-3')}}" mode="input" title="转账数量" value="" placeholder="请输入转账数量" data-event-opts="{{[['^confirm',[['givescore']]]]}}" bind:confirm="__e"></uni-popup-dialog></uni-popup></block></block><block s-if="{{nodata}}"><nodata vue-id="56e0c19f-5"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="56e0c19f-6"></nomore></block><block s-if="{{loading}}"><loading vue-id="56e0c19f-7"></loading></block><dp-tabbar vue-id="56e0c19f-8" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="56e0c19f-9" data-ref="popmsg"></popmsg></view>