<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1+"收益"}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.yuebao_money}}</view><view class="f3" data-url="yuebaolog?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>提现记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><view class="content2"><view class="item2"><view class="f1">提现金额(元)</view></view><view class="item3"><view class="f1">￥</view><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入提现金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><block s-if="{{sysset.yuebao_withdrawfee>0||sysset.yuebao_withdrawmin>0}}"><view class="item4"><block s-if="{{sysset.yuebao_withdrawmin>0}}"><text style="margin-right:10rpx;">{{"最低提现金额"+sysset.yuebao_withdrawmin+'元'}}</text></block><block s-if="{{sysset.yuebao_withdrawfee>0}}"><text>{{"提现手续费"+sysset.yuebao_withdrawfee+'%'}}</text></block></view></block></view><view class="withdrawtype"><view class="f1">选择提现方式：</view><view class="f2"><block s-if="{{sysset.withdraw_weixin==1}}"><view class="item" data-paytype="微信钱包" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-weixin.png'}}"></image>微信钱包</view><view class="radio" style="{{(paytype=='微信钱包'?'background:'+$root.m2+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block><block s-if="{{sysset.withdraw_aliaccount==1}}"><label class="item" data-paytype="支付宝" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-alipay.png'}}"></image>支付宝</view><view class="radio" style="{{(paytype=='支付宝'?'background:'+$root.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block><block s-if="{{sysset.withdraw_bankcard==1}}"><label class="item" data-paytype="银行卡" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1"><image class="img" src="{{pre_url+'/static/img/withdraw-cash.png'}}"></image>银行卡</view><view class="radio" style="{{(paytype=='银行卡'?'background:'+$root.m4+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></label></block></view></view><block s-if="{{sysset.yuebao_turn_yue=='1'}}"><button data-event-opts="{{[['tap',[['tomoney',['$event']]]]]}}" class="opbtn2" bindtap="__e">{{"直接转到账户"+$root.m5}}</button></block><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" bindtap="__e">立即提现</button><block s-if="{{paytype=='支付宝'}}"><view style="width:100%;margin-top:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/pagesExt/my/setaliaccount" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">设置支付宝账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block><block s-if="{{paytype=='银行卡'}}"><view style="width:100%;margin-top:40rpx;text-align:center;color:#999;display:flex;align-items:center;justify-content:center;" data-url="/pagesExt/my/setbankinfo" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">设置银行卡账户<image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></form><uni-popup class="vue-ref" vue-id="8f93c152-1" id="dialogInput" type="dialog" data-ref="dialogInput" vue-slots="{{['default']}}"><uni-popup-dialog vue-id="{{('8f93c152-2')+','+('8f93c152-1')}}" mode="input" title="{{$root.m7+'收益转'+$root.m8}}" value="" placeholder="请输入转入金额" data-event-opts="{{[['^confirm',[['tomonenyconfirm']]]]}}" bind:confirm="__e"></uni-popup-dialog></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="8f93c152-3"></loading></block><dp-tabbar vue-id="8f93c152-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="8f93c152-5" data-ref="popmsg"></popmsg></view>