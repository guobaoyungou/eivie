<view class="container"><block s-if="{{isload}}"><block><block s-if="{{psorder.status!=4}}"><map class="map" longitude="{{binfo.longitude}}" latitude="{{binfo.latitude}}" scale="14" markers="{{[{id:0,latitude:binfo.latitude,longitude:binfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_business.png',width:'44',height:'54'},{id:1,latitude:orderinfo.latitude,longitude:orderinfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_kehu.png',width:'44',height:'54'},{id:2,latitude:psuser.latitude,longitude:psuser.longitude,iconPath:pre_url+'/static/img/peisong/marker_qishou.png',width:'44',height:'54'}]}}"></map></block><block s-else><map class="map" longitude="{{binfo.longitude}}" latitude="{{binfo.latitude}}" scale="14" markers="{{[{id:0,latitude:binfo.latitude,longitude:binfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_business.png',width:'44',height:'54'},{id:1,latitude:orderinfo.latitude,longitude:orderinfo.longitude,iconPath:pre_url+'/static/img/peisong/marker_kehu.png',width:'44',height:'54'}]}}"></map></block><view class="order-box"><view class="head"><block s-if="{{psorder.status==4}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已送达</view></block><block s-else><block s-if="{{psorder.leftminute>0}}"><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image><text class="t1">{{psorder.leftminute+"分钟内"}}</text>送达</view></block><block s-else><view class="f1"><image class="img" src="{{pre_url+'/static/img/peisong/ps_time.png'}}"></image>已超时<text class="t1" style="margin-left:10rpx;">{{-psorder.leftminute+"分钟"}}</text></view></block></block><view class="flex1"></view><view class="f2"><text class="t1">{{psorder.ticheng}}</text>元<block s-if="{{psorder.tip_fee&&psorder.tip_fee>0}}"><text>{{'+'+psorder.tip_fee+'元小费'}}</text></block><block s-if="{{psorder.up_floor_fee&&psorder.up_floor_fee>0}}"><text>{{'+'+psorder.up_floor_fee+'元上楼费'}}</text></block></view></view><view class="content" style="border-bottom:0;"><block s-if="{{psorder.type=='deposit_refund_order'}}"><block><view class="f1"><view class="t1"><text class="x1">{{psorder.juli2}}</text><text class="x2">{{psorder.juli2_unit}}</text></view><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view><view class="t3"><text class="x1">{{psorder.juli}}</text><text class="x2">{{psorder.juli_unit}}</text></view></view><view class="f2"><view class="t1">{{orderinfo.address}}</view><view class="t2">{{orderinfo.area}}</view><view class="t3">{{binfo.name}}</view><view class="t2">{{binfo.address}}</view></view></block></block><block s-else><block><view class="f1"><view class="t1"><text class="x1">{{psorder.juli}}</text><text class="x2">{{psorder.juli_unit}}</text></view><view class="t2"><image class="img" src="{{pre_url+'/static/img/peisong/ps_juli.png'}}"></image></view><view class="t3"><text class="x1">{{psorder.juli2}}</text><text class="x2">{{psorder.juli2_unit}}</text></view></view><view class="f2"><view class="t1">{{binfo.name}}</view><view class="t2">{{binfo.address}}</view><view class="t3">{{orderinfo.address}}</view><view class="t2">{{orderinfo.area}}</view></view></block></block><view data-event-opts="{{[['tap',[['daohang',['$event']]]]]}}" class="f3" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/ps_daohang.png'}}"></image></view></view></view><view class="orderinfo"><view class="box-title">{{"商品清单("+orderinfo.procount+")"}}</view><block s-for="prolist trackBy idx" s-for-item="item" s-for-index="idx"><view class="item"><block s-if="{{psorder.type!='paotui_order'}}"><block><text class="t1 flex1">{{item.name+" "+item.ggname}}</text><text class="t2 flex0">{{"￥"+item.sell_price+" ×"+item.num+''}}</text></block></block><block s-else><block><text class="t1 flex1">{{item.name+''}}</text><text class="t2 flex0">{{"x"+item.num+''}}</text></block></block></view></block></view><block s-if="{{orderinfo.deposit_return_list&&orderinfo.deposit_return_list.length>0}}"><view class="orderinfo"><view class="box-title">{{$root.m0+"回收清单("+orderinfo.deposit_return_list.length+")"}}</view><block s-for="orderinfo.deposit_return_list trackBy idx" s-for-item="item" s-for-index="idx"><view class="item"><text class="t1 flex1">{{item.name+''}}</text><text class="t2 flex0">{{"x"+item.num+''}}</text></view></block></view></block><block s-if="{{psorder.status!=0}}"><view class="orderinfo"><view class="box-title">配送信息</view><view class="item"><text class="t1">接单时间</text><text class="t2">{{$root.m1}}</text></view><block s-if="{{psorder.daodiantime}}"><view class="item"><text class="t1">到店时间</text><text class="t2">{{$root.m2}}</text></view></block><block s-if="{{psorder.quhuotime}}"><view class="item"><text class="t1">取货时间</text><text class="t2">{{$root.m3}}</text></view></block><block s-if="{{psorder.endtime}}"><view class="item"><text class="t1">送达时间</text><text class="t2">{{$root.m4}}</text></view></block></view></block><view class="orderinfo"><view class="box-title">订单信息</view><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{orderinfo.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{$root.m5}}</text></view><block s-if="{{psorder.type!='deposit_refund_order'}}"><block><view class="item"><text class="t1">支付时间</text><text class="t2">{{$root.m6}}</text></view><view class="item"><text class="t1">支付方式</text><text class="t2">{{orderinfo.paytype}}</text></view></block></block><block s-if="{{orderinfo.expect_take_time}}"><view class="item"><text class="t1">取件时间</text><text class="t2">{{orderinfo.expect_take_time}}</text></view></block><block s-if="{{orderinfo.pic}}"><view class="item"><text class="t1">物品图片</text><view class="t2"><image style="width:400rpx;height:auto;" src="{{orderinfo.pic}}" mode="widthFix" data-url="{{orderinfo.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{psorder.type!='deposit_refund_order'}}"><block><block s-if="{{psorder.type!='paotui_order'}}"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+orderinfo.product_price}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+orderinfo.totalprice}}</text></view></block></block><block s-else><block><view class="item"><text class="t1">退押金额</text><text class="t2 red">{{"¥"+orderinfo.totalprice}}</text></view></block></block><block s-if="{{psorder.type!='deposit_refund_order'}}"><view class="item"><text class="t1">备注</text><text class="t2 red">{{orderinfo.message?orderinfo.message:'无'}}</text></view></block><block s-for="orderinfo.formdata trackBy index" s-for-item="item" s-for-index="__i0__"><block s-if="{{orderinfo.formdata.length>0}}"><view class="item"><text class="t1">{{item[0]}}</text><block s-if="{{item[2]=='upload'}}"><view class="t2"><image style="width:400rpx;height:auto;" src="{{item[1]}}" mode="widthFix" data-url="{{item[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block s-else><text class="t2" user-select="true" selectable="true">{{item[1]}}</text></block></view></block></block><block s-if="{{orderinfo.field1data}}"><view class="item"><text class="t1">{{orderinfo.field1data[0]}}</text><text class="t2 red">{{orderinfo.field1data[1]}}</text></view></block><block s-if="{{orderinfo.field2data}}"><view class="item"><text class="t1">{{orderinfo.field2data[0]}}</text><text class="t2 red">{{orderinfo.field2data[1]}}</text></view></block><block s-if="{{orderinfo.field3data}}"><view class="item"><text class="t1">{{orderinfo.field3data[0]}}</text><text class="t2 red">{{orderinfo.field3data[1]}}</text></view></block><block s-if="{{orderinfo.field4data}}"><view class="item"><text class="t1">{{orderinfo.field4data[0]}}</text><text class="t2 red">{{orderinfo.field4data[1]}}</text></view></block><block s-if="{{orderinfo.field5data}}"><view class="item"><text class="t1">{{orderinfo.field5data[0]}}</text><text class="t2 red">{{orderinfo.field5data[1]}}</text></view></block></view><block s-if="{{$root.m7}}"><view class="orderinfo"><view class="box-title">回收照片</view><view class="item"><view class="t2 "><view class="flex" style="flex-wrap:wrap;padding-top:20rpx;" id="content_picpreview"><block s-for="deposit_return_pic trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><block s-if="{{psorder.status!=4}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="deposit_return_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></view></view></block><view style="width:100%;height:180rpx;"></view><block s-if="{{psorder.status!=4}}"><view class="bottom notabbarbot"><block s-if="{{psorder.type!='paotui_order'}}"><block><block s-if="{{psorder.status!=0}}"><view class="f1" data-tel="{{orderinfo.tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel1.png'}}"></image>联系顾客</view></block><block s-if="{{psorder.status!=0}}"><view class="f2" data-tel="{{binfo.tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel2.png'}}"></image>联系商家</view></block></block></block><block s-else><block><block s-if="{{psorder.status!=0}}"><view class="f1" data-tel="{{orderinfo.take_tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel1.png'}}"></image>取货顾客</view></block><block s-if="{{psorder.status!=0}}"><view class="f2" data-tel="{{orderinfo.send_tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel2.png'}}"></image>收货顾客</view></block><block s-if="{{psorder.status!=0}}"><view class="f2" data-tel="{{shop_tel}}" data-event-opts="{{[['tap',[['call',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/peisong/tel2.png'}}"></image>联系商家</view></block></block></block><block s-if="{{$root.m8}}"><view class="btn1" data-field="deposit_return_pic" data-event-opts="{{[['tap',[['uploadDepositReturn',['$event']]]]]}}" bindtap="__e">回收拍照</view></block><block s-if="{{psorder.status==0}}"><view class="btn1" data-id="{{psorder.id}}" data-event-opts="{{[['tap',[['qiangdan',['$event']]]]]}}" bindtap="__e">立即抢单</view></block><block s-if="{{psorder.type!='deposit_refund_order'}}"><block><block s-if="{{psorder.status==1}}"><view class="btn1" data-id="{{psorder.id}}" data-st="2" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" bindtap="__e">我已到店</view></block></block></block><block s-if="{{psorder.status==2}}"><view class="btn1" data-id="{{psorder.id}}" data-st="3" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" bindtap="__e">我已取货</view></block><block s-if="{{psorder.status==3}}"><view class="btn1" data-id="{{psorder.id}}" data-st="4" data-event-opts="{{[['tap',[['setst',['$event']]]]]}}" bindtap="__e">我已送达</view></block></view></block><uni-popup class="vue-ref" vue-id="09732020-1" data-ref="refPopup" vue-slots="{{['default']}}"><view class="popup-content flex flex-col" style="{{'background-image:'+('linear-gradient(rgba(#06A051,0.2),#fff)')+';'}}"><view class="deposit-title-view">拍摄照片提示</view><view class="deposit-tips-view">{{"上门回收"+$root.m9+"物品需要拍摄完整照片"}}</view><view data-event-opts="{{[['tap',[['depositClose',['$event']]]]]}}" class="deposit-popup-but" style="background:#06A051;" bindtap="__e">确认</view></view></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="09732020-2"></loading></block><dp-tabbar vue-id="09732020-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="09732020-4" data-ref="popmsg"></popmsg><wxxieyi vue-id="09732020-5"></wxxieyi></view>