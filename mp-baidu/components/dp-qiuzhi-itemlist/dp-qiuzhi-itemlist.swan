<view style="width:100%;"><view class="dp-qiuzhi-itemlist"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/zhaopin/qiuzhi/detail?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="item1 flex"><view class="product-pic"><text class="{{['status','st'+item.has_job]}}">{{item.has_job==1?'在职':'离职'}}</text><image class="image" style="{{('filter: blur('+item.mohu+'px);-webkit-filter: blur('+item.mohu+'px);-moz-filter: blur('+item.mohu+'px)')}}" src="{{item.thumb}}" mode="aspectFit"></image><block s-if="{{item.qianyue_id>0}}"><text class="qianyue">签约保障中</text></block><block s-else><block><block s-if="{{item.apply_id>0}}"><text class="qianyue">认证保障中</text></block><block s-else><text data-event-opts="{{[['tap',[['gorenzheng',['$event']]]]]}}" class="norenzheng" catchtap="__e">未认证</text></block></block></block></view><view class="product-info"><block s-if="{{showname==1}}"><view class="p1">{{''+item.name+''}}<block s-if="{{item.sex==1}}"><image src="../../static/img/nan.png"></image></block><block s-if="{{item.sex==2}}"><image src="../../static/img/nv.png"></image></block></view></block><view class="p2"><text>期望薪资：</text><text class="number">{{item.salary}}</text></view><view class="p2"><text>期望岗位：</text><text>{{item.cnames}}</text></view><view class="p2"><text>期望城市：</text><text>{{item.area}}</text></view></view></view><block s-if="{{item.tags&&item.tags.length>0}}"><view class="item2 flex"><block s-for="item.tags trackBy wk" s-for-item="wf" s-for-index="wk"><view class="tagitem">{{wf}}</view></block></view></block></view></block></view><block s-if="{{buydialogShow}}"><buydialog vue-id="e73c431a-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e"></buydialog></block></view>