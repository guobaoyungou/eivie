<view style="width:100%;"><view class="dp-product-itemline"><block s-for="$root.l0 trackBy item.$orig.id" s-for-item="item" s-for-index="index"><view data-event-opts="{{[['tap',[['toDetail',[index]]]]]}}" class="item" style="{{'background-color:'+(probgcolor)+';'}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image><block s-if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{showname==1}}"><view class="p1">{{item.$orig.name}}</view></block><block s-if="{{item.$orig.showgivescore}}"><view style="{{'color:'+(item.m0)+';'}}"><text style="font-size:24rpx;">{{"赠送"+item.$orig.showgivescore+item.m1}}</text></view></block><block s-if="{{item.$orig.show_cost&&item.$orig.price_type!=1}}"><view style="{{'color:'+(item.$orig.cost_color?item.$orig.cost_color:'#999')+';'+('font-size:'+('36rpx')+';')}}"><text style="font-size:24rpx;">{{item.$orig.cost_tag}}</text>{{item.$orig.cost_price}}</view></block><view class="p2"><block s-if="{{(!item.$orig.show_sellprice||item.$orig.show_sellprice&&item.$orig.show_sellprice==true)&&(item.$orig.price_type!=1||item.$orig.sell_price>0)&&showprice=='1'}}"><view class="p2-1"><text class="t1" style="{{'color:'+(item.$orig.price_color?item.$orig.price_color:item.m2)+';'}}"><block s-if="{{item.$orig.usd_sellprice}}"><block><text style="font-size:24rpx;">$</text>{{item.$orig.usd_sellprice+''}}<text style="font-size:28rpx;"><text style="font-size:24rpx;">￥</text>{{item.$orig.sell_price}}</text><block s-if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:22rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block></block></block><block s-else><block><text style="font-size:24rpx;">{{item.$orig.price_tag?item.$orig.price_tag:'￥'}}</text>{{item.$orig.sell_price+''}}<block s-if="{{item.$orig.price_show&&item.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:22rpx;font-weight:400;">{{item.$orig.price_show_text}}</text></block><block s-if="{{item.m3}}"><text>{{"+"+item.$orig.freezemoney_price+item.m4}}</text></block></block></block></text><block s-if="{{item.$orig.show_sellprice&&item.$orig.market_price*1>item.$orig.sell_price*1&&showprice=='1'}}"><text class="t2">{{"￥"+item.$orig.market_price}}</text></block><block s-if="{{item.$orig.product_type==3}}"><text class="t3">{{"手工费: ￥"+(item.$orig.hand_fee?item.$orig.hand_fee:0)}}</text></block></view></block><block s-if="{{item.$orig.xunjia_text&&item.$orig.price_type==1&&item.$orig.sell_price<=0}}"><view class="p2-1" style="height:50rpx;line-height:44rpx;"><text class="t1" style="{{'color:'+(item.m5)+';'+('font-size:'+('30rpx')+';')}}">询价</text><block s-if="{{item.$orig.xunjia_text&&item.$orig.price_type==1}}"><block><view class="lianxi" style="{{'background:'+(item.m6)+';'}}" data-lx_name="{{item.$orig.lx_name}}" data-lx_bid="{{item.$orig.lx_bid}}" data-lx_bname="{{item.$orig.lx_bname}}" data-lx_tel="{{item.$orig.lx_tel}}" data-btntype="2" data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" catchtap="__e">{{item.$orig.xunjia_text?item.$orig.xunjia_text:'联系TA'}}</view></block></block></view></block></view><block s-if="{{item.$orig.price_show&&item.$orig.price_show==1}}"><view style="line-height:46rpx;"><text style="font-size:24rpx;">{{"￥"+item.$orig.sell_putongprice}}</text></view></block><block s-if="{{item.$orig.priceshows&&item.$orig.priceshows.length>0}}"><view><block s-for="item.$orig.priceshows" s-for-item="item2" s-for-index="index2"><view style="line-height:46rpx;"><text style="font-size:24rpx;">{{"￥"+item2.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item2.price_show_text}}</text></view></block></view></block><block s-if="{{item.$orig.merchant_name}}"><view class="p1" style="color:#666;font-size:24rpx;white-space:nowrap;text-overflow:ellipsis;margin-top:6rpx;height:30rpx;line-height:30rpx;font-weight:normal;"><text>{{item.$orig.merchant_name}}</text></view></block><block s-if="{{item.$orig.main_business}}"><view class="p1" style="color:#666;font-size:24rpx;margin-top:4rpx;font-weight:normal;"><text>{{item.$orig.main_business}}</text></view></block><block s-if="{{showsales=='1'}}"><view class="p3">{{"已售"+item.$orig.sales+"件"}}</view></block><block s-if="{{(showsales!='1'||item.$orig.sales<=0)&&item.$orig.main_business}}"><view style="height:44rpx;"></view></block><block s-if="{{showcart==1&&!item.$orig.price_type&&item.$orig.hide_cart!=true}}"><view class="p4" style="{{'background:'+('rgba('+item.m7+',0.1)')+';'+('color:'+(item.m8)+';')}}" data-proid="{{item.$orig[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchtap="__e"><text class="iconfont icon_gouwuche"></text></view></block><block s-if="{{showcart==2&&!item.$orig.price_type&&item.$orig.hide_cart!=true}}"><view class="p4" style="{{'background:'+('rgba('+item.m9+',0.1)')+';'+('color:'+(item.m10)+';')}}" data-proid="{{item.$orig[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchtap="__e"><image class="img" src="{{cartimg}}"></image></view></block></view></view></block></view><block s-if="{{productType==4}}"><block><block s-if="{{ggNum==2}}"><block><block s-if="{{buydialogShow}}"><buydialog-pifa vue-id="06baba85-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]],['^showLinkChange',[['showLinkChange']]]]}}" bind:buydialogChange="__e" bind:showLinkChange="__e"></buydialog-pifa></block></block></block><block s-else><block><block s-if="{{buydialogShow}}"><buydialog-pifa2 vue-id="06baba85-2" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]],['^showLinkChange',[['showLinkChange']]]]}}" bind:buydialogChange="__e" bind:showLinkChange="__e"></buydialog-pifa2></block></block></block></block></block><block s-else><block><block s-if="{{buydialogShow}}"><buydialog vue-id="06baba85-3" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" bind:addcart="__e" bind:buydialogChange="__e"></buydialog></block></block></block><block s-if="{{showLinkStatus}}"><view class="posterDialog linkDialog"><view class="main"><view data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><view class="title">{{lx_name}}</view><block s-if="{{lx_bid>0}}"><view class="row"><view class="f1" style="width:150rpx;">店铺名称</view><view class="f2" style="width:100%;max-width:470rpx;display:flex;" data-url="{{'/pagesExt/business/index?id='+lx_bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="width:100%;white-space:nowrap;text-overflow:ellipsis;overflow:hidden;">{{lx_bname}}</view><view style="flex:1;"></view><image class="image" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block s-if="{{lx_tel}}"><view class="row"><view class="f1" style="width:150rpx;">联系电话</view><view class="f2" style="{{'width:100%;max-width:470rpx;'+('color:'+($root.m11)+';')}}" data-url="{{'tel::'+lx_tel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{lx_tel}}<image class="copyicon" src="{{pre_url+'/static/img/copy.png'}}" data-text="{{lx_tel}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" catchtap="__e"></image></view></view></block></view></view></view></block></view>