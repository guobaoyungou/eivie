<view style="width:100%;"><view class="dp-product-zhaopin"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/zhaopin/zhaopin/detail?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="item1 flex"><view class="product-pic"><image class="image" src="{{item.thumb}}" mode="aspectFit"></image><block s-if="{{item.apply_tag}}"><text class="renzheng">担保企业</text></block></view><view class="product-info flex1"><view class="p1">{{item.title}}</view><view class="p2">{{item.salary}}</view><view class="p3"><view class="flex"><block s-if="{{item.cname}}"><view class="tagitem">{{item.cname}}</view></block><block s-if="{{item.num}}"><view class="tagitem">{{item.num+"人"}}</view></block><block s-if="{{item.experience}}"><view class="tagitem">{{item.experience}}</view></block><block s-if="{{item.education}}"><view class="tagitem">{{item.education}}</view></block></view></view><block s-if="{{showaddress&&item.area}}"><view class="p4 flex-s"><image src="../../static/img/address3.png"></image><text>{{item.area}}</text></view></block></view></view><block s-if="{{item.welfare&&item.welfare.length>0}}"><view class="item2 flex"><block s-for="item.welfare trackBy wk" s-for-item="wf" s-for-index="wk"><view class="tagitem">{{wf}}</view></block></view></block></view></block></view></view>