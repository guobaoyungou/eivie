<view><block s-if="{{isload}}"><view><view class="buydialog-mask flex-xy-center"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="buydialog-back" bindtap="__e"></view><view data-event-opts="{{[['touchmove',[['',['$event']]]]]}}" class="{{['buydialog',menuindex>-1?'tabbarbot':'notabbarbot2']}}" catchtouchmove="__e"><view data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" class="close" bindtap="__e"><image class="image" src="{{pre_url+'/static/img/close.png'}}"></image></view><scroll-view scroll-y="true"><scroll-view class="page-scroll" scroll-y="true"><view class="box"><image class="banner" src="{{nowguige.pic||product.pic}}" mode="aspectFit" data-url="{{nowguige.pic||product.pic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><block s-if="{{product.sellpoint}}"><view style="max-height:50vh;overflow:scroll;"><view class="guigelist flex-col"><view class="name">产品描述</view><view class="item flex flex-y-center"><view class="description">{{product.sellpoint}}</view></view></view></view></block><block s-if="{{jlselectdata.length>0&&(controller=='ApiRestaurantShop'||controller=='ApiRestaurantTakeaway')}}"><view style="height:auto;"><view class="guigelist flex-col"><view class="name">加料</view><view class="item flex flex-y-center"><block s-for="$root.l0 trackBy jindex" s-for-item="jitem" s-for-index="jindex"><view class="jlitem" style="{{(jitem.$orig.num>0?'color:'+jitem.m0+';border-color:'+jitem.m1:'')}}"><view data-event-opts="{{[['tap',[['jlsubnum',[jindex]]]]]}}" class="addsub" style="{{('color:'+$root.m2+';border:4rpx solid '+$root.m3)}}" bindtap="__e">－</view><view class="text">{{jitem.$orig.title}}</view><view data-event-opts="{{[['tap',[['jladdnum',[jindex]]]]]}}" class="addsub" style="{{('color:#fff;background-color:'+$root.m4)}}" bindtap="__e">＋</view><block s-if="{{jitem.$orig.num>0}}"><view class="jlnum" style="{{('background-color:'+jitem.m5)}}">{{jitem.$orig.num}}</view></block></view></block></view></view></view></block><view style="height:auto;"><block s-for="$root.l2 trackBy index" s-for-item="item" s-for-index="index"><view class="guigelist flex-col"><view class="name">{{item.$orig.title}}</view><view class="item flex flex-y-center"><block s-for="item.l1 trackBy index2" s-for-item="item2" s-for-index="index2"><block><view class="item2" style="{{(ggselected[item.$orig.k]==item2.$orig.k?'color:'+item2.m6+';'+'border-color:'+item2.m7:'')}}" data-itemk="{{item.$orig.k}}" data-idx="{{item2.$orig.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" bindtap="__e">{{item2.$orig.title}}</view></block></block></view></view></block></view><block s-if="{{jialiaodata.length>0&&(controller=='ApiRestaurantShop'||controller=='ApiRestaurantTakeaway')}}"><view style="height:auto;"><view class="guigelist flex-col"><view class="name">加料</view><view class="item flex flex-y-center"><block s-for="$root.l3 trackBy jlindex" s-for-item="jlitem" s-for-index="jlindex"><view data-event-opts="{{[['tap',[['jlchange',[jlindex]]]]]}}" class="item2" style="{{(jlitem.$orig.active?'color:'+jlitem.m8+';'+'border-color:'+jlitem.m9:'')}}" bindtap="__e">{{jlitem.$orig.jltitle}}</view></block></view></view></view></block></scroll-view><view class="page_price" style="{{'color:'+($root.m10)+';'}}">{{"￥"+totalprice}}</view><view class="page_content">{{"已选规格: "+nowguige.name+jltitle}}</view><view class="buynum flex flex-y-center"><view class="flex1">购买数量：</view><view class="addnum"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus" catchtap="__e"><image class="img" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view><block s-if="{{shopset&&shopset.showcommission==1&&nowguige.commission>0}}"><view class="tips-text" style="{{'color:'+($root.m11)+';'}}">{{"分享好友购买预计可得"+$root.m12+"："}}<text style="font-weight:bold;padding:0 2px;">{{nowguige.commission}}</text>{{nowguige.commission_desc}}</view></block><view class="op"><block s-if="{{nowguige.stock<=0||nowguige.stock_daily<=0}}"><block><button class="nostock">库存不足</button></block></block><block s-else><block><block s-if="{{btntype==0&&canaddcart}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m13)+';'}}" bindtap="__e">加入购物车</button></block><block s-if="{{btntype==0}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m14)+';'}}" bindtap="__e">立即购买</button></block><block s-if="{{btntype==1}}"><button data-event-opts="{{[['tap',[['addcart',['$event']]]]]}}" class="addcart" style="{{'background-color:'+($root.m15)+';'}}" bindtap="__e">确 定</button></block><block s-if="{{btntype==2}}"><button data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background-color:'+($root.m16)+';'}}" bindtap="__e">确 定</button></block></block></block></view></scroll-view></view></view></view></block><block s-if="{{loading}}"><loading vue-id="a7d1665a-1"></loading></block></view>