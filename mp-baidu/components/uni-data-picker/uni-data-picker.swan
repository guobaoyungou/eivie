<view class="uni-data-tree data-v-55c70928" style="{{(styleData)}}"><view data-event-opts="{{[['tap',[['handleInput',['$event']]]]]}}" class="uni-data-tree-input data-v-55c70928" bindtap="__e"><block s-if="{{$slots.default}}"><slot var-options="options" var-data="inputSelected" var-error="errorMessage"></slot></block><block s-else><view class="{{['input-value','data-v-55c70928',(border)?'input-value-border':'']}}"><block s-if="{{errorMessage}}"><text class="selected-area error-text data-v-55c70928">{{errorMessage}}</text></block><block s-else><block s-if="{{loading&&!isOpened}}"><view class="selected-area data-v-55c70928"><uni-load-more class="load-more data-v-55c70928" vue-id="07d41cae-1" contentText="{{loadMore}}" status="loading"></uni-load-more></view></block><block s-else><block s-if="{{inputSelected.length}}"><scroll-view class="selected-area data-v-55c70928" scroll-x="true"><view class="selected-list data-v-55c70928"><block s-for="inputSelected trackBy index" s-for-item="item" s-for-index="index"><view class="selected-item data-v-55c70928"><text class="data-v-55c70928">{{item.text}}</text><block s-if="{{index<inputSelected.length-1}}"><text class="input-split-line data-v-55c70928">{{split}}</text></block></view></block></view></scroll-view></block><block s-else><text class="selected-area placeholder data-v-55c70928">{{placeholder}}</text></block></block></block><block s-if="{{!readonly&&border}}"><view class="arrow-area data-v-55c70928"><view class="input-arrow data-v-55c70928"></view></view></block></view></block></view><block s-if="{{isOpened}}"><view data-event-opts="{{[['tap',[['handleClose',['$event']]]]]}}" class="uni-data-tree-cover data-v-55c70928" bindtap="__e"></view></block><block s-if="{{isOpened}}"><view class="uni-data-tree-dialog data-v-55c70928"><view class="dialog-caption data-v-55c70928"><view class="title-area data-v-55c70928"><text class="dialog-title data-v-55c70928">{{popupTitle}}</text></view><view data-event-opts="{{[['tap',[['handleClose',['$event']]]]]}}" class="dialog-close data-v-55c70928" bindtap="__e"><view class="dialog-close-plus data-v-55c70928" data-id="close"></view><view class="dialog-close-plus dialog-close-rotate data-v-55c70928" data-id="close"></view></view></view><data-picker-view class="picker-view data-v-55c70928 vue-ref" vue-id="07d41cae-2" localdata="{{localdata}}" preload="{{preload}}" collection="{{collection}}" field="{{field}}" orderby="{{orderby}}" where="{{where}}" step-searh="{{stepSearh}}" self-field="{{selfField}}" parent-field="{{parentField}}" managed-mode="{{true}}" data-ref="pickerView" value="{{value}}" data-event-opts="{{[['^change',[['onchange']]],['^datachange',[['ondatachange']]],['^input',[['__set_model',['','value','$event',[]]]]]]}}" bind:change="__e" bind:datachange="__e" bind:input="__e"></data-picker-view></view></block></view>