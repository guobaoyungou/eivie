<view class="dp-luckycollage" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block s-if="{{params.style=='2'}}"><view class="dp-collage-item"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" style="{{(params.style==2?'width:49%;margin-right:'+(index%2==0?'2%':0):params.style==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{'/activity/luckycollage/'+(item.linktype==1?'product2':'product')+'?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block><block s-if="{{item.show_teamnum==1}}"><view class="desc"><block s-if="{{item.gua_num>0}}"><text>{{''+item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text></block><block s-else><text style="line-height:80rpx;">{{''+item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text></block><block s-if="{{item.linktype==1}}"><view><block s-if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==1}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block><block s-if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==2}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_score+"积分"}}</text></block><block s-if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==3}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_commission+"元佣金"}}</text></block><block s-if="{{item.teamnum-item.gua_num>0&&item.bzjl_type==4}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"优惠券"}}</text></block></view></block><block s-else><view><block s-if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block></view></block></view></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{params.showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block s-if="{{params.showprice=='1'&&item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></block></view><view class="p3"><view class="p3-1" style="{{'background:'+('rgba('+$root.m1+',0.12)')+';'+('color:'+($root.m2)+';')}}">{{item.teamnum+"人拼"}}</view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-2"><text style="overflow:hidden;">{{"已拼成"+item.sales+"件"}}</text></view></block></view></view></view></block></view></block><block s-if="{{params.style=='list'}}"><view class="dp-collage-itemlist"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/activity/luckycollage/'+(item.linktype==1?'product2':'product')+'?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="flex"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1"><text class="team_text">{{item.teamnum+"人拼"}}</text>{{item.name}}</view></block><block s-if="{{params.showprice!='0'}}"><view class="p2 flex-bt"><view><text class="t1" style="{{'color:'+($root.m3)+';'}}"><text style="font-size:24rpx;padding-right:1px;">￥</text>{{item.sell_price}}</text><block s-if="{{params.showprice=='1'&&item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view><view class="p3"><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-2"><text style="overflow:hidden;">{{"已拼成"+item.sales+"件"}}</text></view></block></view></view></block></view></view><block s-if="{{item.linktype==1}}"><view><block s-if="{{item.bzjl_type==1}}"><view class="desc"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text><block s-if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block></view></block><block s-if="{{item.bzjl_type==2}}"><view class="desc"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text><block s-if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_score+"积分"}}</text></block></view></block><block s-if="{{item.bzjl_type==3}}"><view class="desc"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text><block s-if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.bzj_commission+"元佣金"}}</text></block></view></block><block s-if="{{item.bzjl_type==4}}"><view class="desc"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text><block s-if="{{item.teamnum-item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"优惠券"}}</text></block></view></block></view></block><block s-else><view><block s-if="{{item.show_teamnum==1}}"><view class="desc"><text>{{item.teamnum+"人拼团 "+item.gua_num+"人得商品"}}</text><block s-if="{{item.gua_num>0}}"><text>{{item.teamnum-item.gua_num+"人"+(item.teamnum-item.gua_num>1?'各':'')+"得"+item.money+"元参与奖"}}</text></block></view></block></view></block></view></block></view></block></view>