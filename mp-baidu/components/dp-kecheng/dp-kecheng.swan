<view class="dp-product" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('width:'+('calc(100% - '+params.margin_x*2.2*2+'rpx)')+';')}}"><block s-if="{{params.style=='1'||params.style=='2'||params.style=='3'}}"><dp-kecheng-item vue-id="147a3c5a-1" showstyle="{{params.style}}" data="{{data}}" saleimg="{{params.saleimg}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" idfield="proid" menuindex="{{menuindex}}"></dp-kecheng-item></block><block s-if="{{params.style=='list'}}"><dp-kecheng-itemlist vue-id="147a3c5a-2" data="{{data}}" saleimg="{{params.saleimg}}" showpic="{{params.showpic}}" showname="{{params.showname}}" showprice="{{params.showprice}}" showsales="{{params.showsales}}" idfield="proid" menuindex="{{menuindex}}"></dp-kecheng-itemlist></block></view>