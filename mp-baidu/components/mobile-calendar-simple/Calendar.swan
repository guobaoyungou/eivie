<transition vue-id="281faf2a-1" name="{{transition}}" class="data-v-10acf7aa" vue-slots="{{['default']}}"><block s-if="{{isShow}}"><view class="{{['calendar-tz','_div','data-v-10acf7aa',isFixed&&'fixed']}}"><slot name="header"></slot><view class="week-number _div data-v-10acf7aa"><block s-for="weekList trackBy index" s-for-item="item" s-for-index="index"><label style="{{'color:'+((index==0||index==weekList.length-1)&&themeColor)+';'}}" class="_span data-v-10acf7aa">{{item}}</label></block></view><block s-if="{{title}}"><view class="tips _p data-v-10acf7aa">{{title}}</view></block><view class="content _div data-v-10acf7aa" id="scrollWrap"><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><view class="con _div data-v-10acf7aa" id="{{item.$orig.year+''+item.$orig.month}}"><view class="_h3 data-v-10acf7aa">{{item.$orig.year+'年'+item.$orig.month+'月'}}</view><label class="month-bg _span data-v-10acf7aa" style="{{'color:'+(getBetweenColor)+';'}}">{{item.$orig.month}}</label><view class="each-month _ul data-v-10acf7aa"><block s-for="item.l0 trackBy idx" s-for-item="day" s-for-index="idx"><view data-event-opts="{{[['tap',[['chooseDate',['$0','$1','$2'],[[['calendar','',index],['dayList','',idx]],[['calendar','',index,'month']],[['calendar','',index,'year']]]]]]]}}" class="{{['each-day','_li','data-v-10acf7aa',day.m0]}}" style="{{'background:'+(day.m1)+';'}}" bindtap="__e"><block s-if="{{mode!=4}}"><view class="{{['_div','data-v-10acf7aa',day.m2]}}" style="{{'background:'+(day.m3)+';'}}"><view class="day _p data-v-10acf7aa">{{day.$orig?day.$orig:''}}</view><view class="recent _p data-v-10acf7aa"><view class="_i data-v-10acf7aa">{{day.m4}}</view></view></view></block><block s-else><view class="{{['_div','data-v-10acf7aa',day.m5]}}"><view class="day _p data-v-10acf7aa">{{day.$orig?day.$orig:''}}</view><view class="recent _p data-v-10acf7aa"><view class="_i data-v-10acf7aa">{{day.m6}}</view></view></view></block></view></block></view></view></block></view><slot name="footer"></slot></view></block></transition>