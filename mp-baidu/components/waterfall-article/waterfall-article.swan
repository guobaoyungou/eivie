<view class="waterfalls-box data-v-5aaf1a42" style="{{'height:'+(height+'px')+';'}}"><block s-for="list trackBy item[idKey]" s-for-item="item" s-for-index="index"><view class="waterfalls-list data-v-5aaf1a42 vue-ref-in-for" style="{{'--offset:'+(offset+'px')+';'+('--cols:'+(cols)+';')+('top:'+(allPositionArr[index]?allPositionArr[index].top:0)+';')+('left:'+(allPositionArr[index]?allPositionArr[index].left:0)+';')}}" id="{{'waterfalls-list-id-'+item[idKey]}}" data-url="{{'/pagesExt/article/detail?id='+item[idKey]}}" data-ref="{{'waterfalls-list-id-'+item[idKey]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="waterfalls-list-image data-v-5aaf1a42" style="{{(imageStyle)}}" mode="widthFix" src="{{item[imageSrcKey]||' '}}" data-event-opts="{{[['load',[['imageLoadHandle',[index]]]],['error',[['imageLoadHandle',[index]]]]]}}" bindload="__e" binderror="__e"></image><view class="article-waterfall-info data-v-5aaf1a42"><view class="p1 data-v-5aaf1a42">{{item.name}}</view><block s-if="{{item.subtitle_status&&item.subtitle}}"><view class="p3 data-v-5aaf1a42" style="{{'color:'+('#333')+';'+('font-size:'+(item.subtitle_size&&item.subtitle_size>0?item.subtitle_size*2+'rpx':'')+';')}}">{{''+item.subtitle+''}}</view></block><block s-if="{{item.po_status&&item.po_status==1}}"><block class="data-v-5aaf1a42"><block s-if="{{item.po_name}}"><view class="p3 data-v-5aaf1a42" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{''+item.po_name+" "+item.po_content+''}}</view></block></block></block><block s-if="{{item.pt_status&&item.pt_status==1}}"><block class="data-v-5aaf1a42"><block s-if="{{item.pt_name}}"><view class="p3 data-v-5aaf1a42" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{''+item.pt_name+" "+item.pt_content+''}}</view></block></block></block><block s-if="{{item.pth_status&&item.pth_status==1}}"><block class="data-v-5aaf1a42"><block s-if="{{item.pth_name}}"><view class="p3 data-v-5aaf1a42" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{''+item.pth_name+" "+item.pth_content+''}}</view></block></block></block><block s-if="{{item.pf_status&&item.pf_status==1}}"><block class="data-v-5aaf1a42"><block s-if="{{item.pf_name}}"><view class="p3 data-v-5aaf1a42" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{''+item.pf_name+" "+item.pf_content+''}}</view></block></block></block><view class="p2 data-v-5aaf1a42"><block s-if="{{showtime=='1'}}"><text class="flex1 data-v-5aaf1a42" style="overflow:hidden;">{{item.createtime}}</text></block><block s-if="{{showreadcount=='1'}}"><text style="overflow:hidden;" class="data-v-5aaf1a42">{{"阅读 "+item.readcount}}</text></block></view></view></view></block></view>