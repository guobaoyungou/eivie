<view class="dp-business" style="{{'color:'+(params.color)+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('font-size:'+(params.fontsize*2+'rpx')+';')}}"><block s-for="$root.l2 trackBy item.$orig.id" s-for-item="item" s-for-index="index"><block s-if="{{!params.showstyle||params.showstyle=='1'}}"><view class="busbox"><view class="businfo" data-bid="{{item.$orig.bid}}" data-tourl="{{item.$orig.tourl}}" data-key="{{index}}" data-event-opts="{{[['tap',[['gotourl',['$event']]]]]}}" bindtap="__e"><view class="f1"><image class="image" lazy-load="true" lazy-load-margin="0" src="{{item.$orig.logo}}"></image></view><view class="f2"><view class="title">{{item.$orig.name}}</view><block s-if="{{params.showpingfen!=='0'}}"><view class="score"><image class="image" src="{{pre_url+'/static/img/star'+item.$orig.commentscore+'.png'}}"></image>{{item.$orig.comment_score+"分"}}</view></block><block s-if="{{params.showcategroy=='1'}}"><view class="address">{{item.$orig.catname}}</view></block><block s-if="{{params.showturnover!=='0'&&item.$orig.turnover_show==1}}"><view class="sales"><text>营业额：</text>{{item.$orig.turnover}}</view></block><block s-if="{{params.showsales!=='0'}}"><view class="sales"><text>销量：</text>{{item.$orig.sales}}</view></block><block s-if="{{params.showjianjie=='1'}}"><view class="address"><text decode="{{true}}">{{item.$orig.content}}</text></view></block><view class="address flex"><view class="flex1"><block s-if="{{params.showaddress!=='0'}}"><text>{{item.$orig.address}}</text></block></view><block s-if="{{params.showdistance}}"><view style="{{'color:'+($root.m0)+';'}}">{{item.$orig.juli}}</view></block></view><block s-if="{{params.showmaidan=='1'}}"><view class="address flex"><view class="btn" style="{{'background:'+('rgba('+$root.m1+',0.1)')+';'+('color:'+($root.m2)+';')}}" data-name="{{item.$orig.name}}" data-address="{{item.$orig.address}}" data-latitude="{{item.$orig.latitude}}" data-longitude="{{item.$orig.longitude}}" data-event-opts="{{[['tap',[['showMap',['$event']]]]]}}" catchtap="__e">导航</view><view class="btn" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}" data-url="{{'/pages/maidan/pay?bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">买单</view><block s-if="{{item.$orig.tel}}"><view class="btn" style="{{'background:'+('rgba('+item.m5+',0.1)')+';'+('color:'+(item.m6)+';')}}" data-url="{{'tel::'+item.$orig.tel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">咨询电话</view></block></view></block><block s-if="{{item.$orig.activity_time&&item.$orig.activity_time_status==1}}"><view style="{{'font-size:24rpx;'+('color:'+(item.m7)+';')}}">活动时间：<text class="x1">{{item.$orig.activity_time}}</text></view></block><view class="ratio-list flex"><block s-if="{{item.$orig.rate_back&&item.$orig.rate_back>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m8)+';'+('border-color:'+(item.m9)+';')}}"><view class="label" style="{{'background-color:'+(item.m10)+';'}}">返</view><view class="t1">{{item.$orig.rate_back+"%"}}</view></view></block><block s-if="{{item.$orig.scoredkmaxpercent&&item.$orig.scoredkmaxpercent>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m11)+';'+('border-color:'+(item.m12)+';')}}"><view class="label" style="{{'background-color:'+(item.m13)+';'}}">积</view><view class="t1">{{item.$orig.scoredkmaxpercent+"%"}}</view></view></block><block s-if="{{item.m14}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m15)+';'+('border-color:'+(item.m16)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m17)+';'+('width:'+('120rpx')+';')}}">{{item.m18}}</view><view class="t1">{{item.$orig.activecoin_bili+"%"}}</view></view></block><block s-if="{{item.m19}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m20)+';'+('border-color:'+(item.m21)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m22)+';'+('width:'+('120rpx')+';')}}">{{item.m23}}</view><view class="t1">{{item.$orig.newscore_ratio+"%"}}</view></view></block><block s-if="{{item.m24}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m25)+';'+('border-color:'+(item.m26)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m27)+';'+('width:'+('120rpx')+';')}}">{{item.m28}}</view><view class="t1">{{item.$orig.newscore_pack_ratio+"%"}}</view></view></block><block s-if="{{item.m29}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m30)+';'+('border-color:'+(item.m31)+';')+('width:'+('220rpx')+';')}}"><view class="label" style="{{'background-color:'+(item.m32)+';'+('width:'+('120rpx')+';')}}">{{item.m33}}</view><view class="t1">{{item.$orig.subsidy_ratio+"%"}}</view></view></block></view><block s-if="{{params.showqueuefreeratio=='1'&&item.$orig.queue_free_set==1&&item.$orig.queue_free_rate_back>0}}"><view class="flex queue-free"><view class="queue-free-ratio flex" style="{{'color:'+(item.m34)+';'+('border-color:'+(item.m35)+';')}}"><view class="icon-div" style="{{'background-color:'+(item.m36)+';'}}"><image class="icon" src="{{pre_url+'/static/img/qianbao.png'}}"></image></view>{{''+(params.zuigaopaiduibutie||'最高排队补贴')+" "+item.$orig.queue_free_rate_back+'%'}}</view></view></block><block s-if="{{params.showdedamount=='1'}}"><block><block s-if="{{item.$orig.dedamount_maxdkpercent&&item.$orig.dedamount_maxdkpercent>0}}"><view class="flex queue-free" style="justify-content:flex-start;"><view class="queue-free-ratio flex" style="{{'color:'+(item.m37)+';'+('border-color:'+(item.m38)+';')}}"><view class="icon-div" style="{{'background-color:'+(item.m39)+';'}}"><image class="icon" src="{{pre_url+'/static/img/qianbao.png'}}"></image></view>{{'抵扣 '+item.$orig.dedamount_maxdkpercent+'%'}}</view></view></block></block></block><block s-if="{{params.showinstore=='1'}}"><view class="instore" style="{{'background:'+('rgba('+$root.m40+')')+';'}}" data-bid="{{item.$orig.bid}}" data-tourl="{{item.$orig.tourl}}" data-event-opts="{{[['tap',[['gotourl',['$event']]]]]}}" catchtap="__e"><text>进店</text></view></block></view></view><block s-if="{{params.showproduct==1}}"><view class="buspro"><block s-for="item.l0 trackBy item2.$orig.id" s-for-item="item2" s-for-index="index2"><view class="item" style="{{('width:23%;margin-right:'+(index2%4!=3?'2%':0))}}" data-url="{{item2.$orig.module=='yuyue'?'/activity/yuyue/product?id='+item2.$orig.id:'/pages/shop/product?id='+item2.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item2.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item2.$orig.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+(item.m41)+';'}}"><text style="font-size:24rpx;">￥</text>{{item2.$orig.sell_price+''}}<block s-if="{{item2.$orig.price_show&&item2.$orig.price_show_text}}"><text style="margin:0 15rpx;font-size:24rpx;font-weight:400;">{{item2.$orig.price_show_text}}</text></block><block s-if="{{item2.$orig.module=='yuyue'}}"><text style="font-size:24rpx;">{{"/"+item2.$orig.danwei}}</text></block></text></view></view><block s-if="{{item2.$orig.price_show&&item2.$orig.price_show==1}}"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item2.$orig.sell_putongprice}}</text></view></block><block s-if="{{item2.$orig.priceshows&&item2.$orig.priceshows.length>0}}"><view><block s-for="item2.$orig.priceshows" s-for-item="item3" s-for-index="index3"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item3.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item3.price_show_text}}</text></view></block></view></block><block s-if="{{item2.$orig.module=='yuyue'}}"><view class="p4" style="{{'background:'+('rgba('+item2.m42+',0.1)')+';'+('color:'+(item2.m43)+';')}}" data-url="{{'/activity/yuyue/product?id='+item2.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><text class="iconfont icon_gouwuche"></text></view></block><block s-if="{{item2.$orig.module!='yuyue'&&!item2.$orig.price_type}}"><view class="p4" style="{{'background:'+('rgba('+item2.m44+',0.1)')+';'+('color:'+(item2.m45)+';')}}" data-proid="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchtap="__e"><text class="iconfont icon_gouwuche"></text></view></block></view></view></block></view></block><block s-if="{{params.showbusinessmiandan==1&&item.$orig.miandanset_status==1&&item.$orig.miandanprolist.length>0}}"><view class="free_product"><block s-for="item.$orig.miandanprolist" s-for-item="item3" s-for-index="index3"><view class="product" data-bid="{{item.$orig.bid}}" data-tourl="{{item.$orig.tourl}}" data-event-opts="{{[['tap',[['gotourl',['$event']]]]]}}" bindtap="__e"><view class="item"><view class="hui">免</view><view class="price">{{"￥"+item3.sell_price}}</view><view class="proname">{{item3.name}}</view></view></view></block></view></block><block s-if="{{params.showscoreshop==1&&item.$orig.scoreshopprolist.length>0}}"><view class="buspro"><scroll-view style="width:100%;white-space:nowrap;" scroll-x="true"><block s-for="item.$orig.scoreshopprolist trackBy item2.id" s-for-item="item2" s-for-index="index2"><view class="item" style="{{('width:23%;margin-right:'+(index2%4!=3?'2%':0))}}" data-url="{{'/activity/scoreshop/product?id='+item2.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item2.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item2.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+(item.m46)+';'}}">{{item2.score_price+item.m47}}<block s-if="{{item2.money_price>0}}"><text>{{"+"+item2.money_price+"元"}}</text></block></text></view></view></view></view></block></scroll-view></view></block><block s-if="{{(params.showseckill==1||params.showtuangou==1||params.showkanjia==1||params.showcollage==1||params.showluckycollage==1)&&item.$orig.cuxiaoprolist.length>0}}"><view class="cuxiaopro" style="{{'background:'+('linear-gradient(180deg,rgba('+item.m48+',0.2),rgba('+item.m49+',0) 60%)')+';'}}"><block s-for="item.l1 trackBy item2.$orig.id" s-for-item="item2" s-for-index="index2"><view class="item" data-url="{{'/activity/'+item2.$orig.product_type+'/product?id='+item2.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item2.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item2.$orig.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+(item.m50)+';'}}"><block s-if="{{item2.$orig.product_type=='tuangou'}}"><text class="t1-1">低至</text></block><text>￥</text>{{item2.$orig.sell_price+''}}</text><block s-if="{{item2.$orig.product_type=='seckill'&&item2.$orig.market_price&&item2.$orig.market_price>item2.$orig.sell_price}}"><text class="t2"><text style="font-size:24rpx;">￥</text>{{item2.$orig.market_price}}</text></block></view></view><view class="p3"><view class="p3-1" style="{{'background:'+('rgba('+item.m51+',0.12)')+';'+('color:'+(item.m52)+';')}}"><block s-if="{{item2.$orig.product_type=='seckill'}}"><text>秒杀</text></block><block s-if="{{item2.$orig.product_type=='kanjia'}}"><text>砍价</text></block><block s-if="{{item2.$orig.product_type=='tuangou'}}"><text>团购</text></block><block s-if="{{item2.$orig.product_type=='collage'}}"><text>拼团</text></block><block s-if="{{item2.$orig.product_type=='luckycollage'}}"><text>{{item2.m53}}</text></block></view><block s-if="{{item2.$orig.product_type=='seckill'}}"><text class="p3-2">{{"已抢购"+item2.$orig.sales+"件"}}</text></block><block s-if="{{item2.$orig.product_type=='kanjia'}}"><text class="p3-2">{{"已砍走"+item2.$orig.sales+"件"}}</text></block><block s-if="{{item2.$orig.product_type=='collage'||item2.$orig.product_type=='luckycollage'}}"><text class="p3-2">{{item2.$orig.teamnum+"人拼"}}</text></block></view></view></view></block></view></block></view></block></block><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><block s-if="{{params.showstyle&&params.showstyle=='2'}}"><view class="busbox2" data-url="{{'/pagesA/business/businessindex?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="new_blist"><view class="f1"><image class="image" src="{{item.logo}}" mode="aspectFill"></image></view><view class="f2"><view class="t1">{{item.name}}</view><view class="t2"><image class="image" src="{{pre_url+'/static/img/telphone.png'}}" mode="widthFix"></image>{{item.tel}}</view><block s-if="{{params.showaddress==1}}"><view class="t2"><image class="image" src="{{pre_url+'/static/img/position.png'}}" mode="widthFix"></image><text class="text">{{item.address}}</text></view></block></view><view class="f3"><image class="image" src="{{pre_url+'/static/img/calltel.png'}}" data-tel="{{item.tel}}" mode="widthFix" data-event-opts="{{[['tap',[['callphone',['$event']]]]]}}" catchtap="__e"></image><block s-if="{{params.showdistance==1}}"><view style="color:#EC4149;font-size:26rpx;margin-top:10rpx;">{{item.juli}}</view></block></view></view></view></block></block><block s-if="{{buydialogShow}}"><buydialog vue-id="2a1438e2-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" bind:addcart="__e" bind:buydialogChange="__e"></buydialog></block></view>