<view class="dp-menu" style="{{'font-size:'+(params.fontsize*2+'rpx')+';'+('background-color:'+(params.bgcolor)+';')+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('border-radius:'+(params.boxradius*2.2+'rpx')+';')}}"><view style="padding-top:16rpx;"><view class="menu-title flex-bt"><view style="{{'color:'+(params.titlecolor)+';'+('font-size:'+(params.titlesize*2+'rpx')+';')}}">{{params.title}}</view><view class="positioning-class"><uni-data-picker class="dp-header-picker" vue-id="820dc41a-1" localdata="{{arealist}}" popup-title="地区" placeholder="地区" data-event-opts="{{[['^change',[['areachange']]]]}}" bind:change="__e" vue-slots="{{['default']}}"><view>{{locationCache.address?locationCache.address:'北京市'}}</view></uni-data-picker><image style="width:22rpx;height:22rpx;margin-left:6rpx;" src="https://v2d.diandashop.com/static/admin/img/down-icon.png" class="_img"></image></view></view><view class="swiper-item"><block s-for="optionsData trackBy index" s-for-item="item" s-for-index="index"><view data-event-opts="{{[['tap',[['gotoChange',['$0'],[[['optionsData','',index]]]]]]]}}" class="menu-nav6" style="{{'background-color:'+('#fafafa')+';'+('border-radius:'+(params.radius+'px')+';')}}" bindtap="__e"><image class="{{[item.is_open&&item.is_open==1?'':'grayscale']}}" style="{{'width:'+(params.iconsize*2+'rpx')+';'+('height:'+(params.iconsize*2+'rpx')+';')}}" src="{{item.imgurl}}"></image><view class="menu-text" style="{{'color:'+(item.color)+';'+('height:'+(params.fontheight*2+'rpx')+';')+('line-height:'+(params.fontheight*2+'rpx')+';')}}">{{item.text||'按钮文字'}}</view><block s-if="{{!item.is_open}}"><view class="no-opened">暂未开通</view></block></view></block></view></view><block s-if="{{loading}}"><loading vue-id="820dc41a-2"></loading></block></view>