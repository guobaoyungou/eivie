<view style="width:100%;"><view class="dp-product-itemlist"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{!item.chaptertype||item.chaptertype==1?'/activity/kecheng/product?id='+item[idfield]:'/pagesB/kecheng/lecturermldetail?kcid='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><block s-if="{{showpic==1}}"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block><view style="color:#fff;line-height:40rpx;position:absolute;right:4px;bottom:4px;background-color:rgba(0, 0, 0, 0.3);border-radius:12rpx;width:70rpx;"><view style="display:flex;align-items:center;justify-content:center;font-size:22rpx;"><block s-if="{{item.kctype===1}}"><view>图文</view></block><block s-else><block s-if="{{item.kctype===2}}"><view>音频</view></block><block s-else><block s-if="{{item.kctype===3}}"><view>视频</view></block><block s-else><view>综合</view></block></block></block></view></view></view></block><view class="product-info" style="{{(showpic==0?'width:100%':'')}}"><block s-if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><block s-if="{{showprice!='0'}}"><view class="p2"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><block s-if="{{item.price>0}}"><text style="font-size:24rpx;">￥</text></block>{{item.price==0?'免费':item.price}}</text><block s-if="{{showprice=='1'&&item.market_price*1>item.price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></block><block s-if="{{!item.chaptertype||item.chaptertype==1}}"><view class="p3"><view class="p3-1">{{"共"+item.count+'节课'}}<block s-if="{{showsales==1&&item.join_num>0}}"><block><text style="margin:0 6rpx;">|</text>{{item.join_num+"人已加入学习"}}</block></block></view></view></block></view><view class="product-details" style="{{'color:'+($root.m1)+';'}}">查看详情</view></view></block></view><block s-if="{{buydialogShow}}"><buydialog vue-id="5e8d8f51-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e"></buydialog></block></view>