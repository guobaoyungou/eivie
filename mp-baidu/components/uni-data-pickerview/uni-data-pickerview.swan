<view class="uni-data-pickerview data-v-348bb63d"><scroll-view class="selected-area data-v-348bb63d" scroll-x="true" scroll-y="false" show-scrollbar="{{false}}"><view class="selected-list data-v-348bb63d"><block s-for="selected trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{item.text}}"><view data-event-opts="{{[['tap',[['handleSelect',[index]]]]]}}" class="{{['selected-item','data-v-348bb63d',(index==selectedIndex)?'selected-item-active':'']}}" bindtap="__e"><text class="data-v-348bb63d">{{item.text}}</text></view></block></block></view></scroll-view><view class="tab-c data-v-348bb63d"><block s-for="dataList trackBy i" s-for-item="child" s-for-index="i"><block s-if="{{i==selectedIndex}}"><scroll-view class="list data-v-348bb63d" scroll-y="{{true}}"><block s-for="child trackBy j" s-for-item="item" s-for-index="j"><view data-event-opts="{{[['tap',[['handleNodeClick',['$0',i,j],[[['dataList','',i],['','',j]]]]]]]}}" class="{{['item','data-v-348bb63d',(!!item.disable)?'is-disabled':'']}}" bindtap="__e"><text class="item-text data-v-348bb63d">{{item.text}}</text><block s-if="{{selected.length>i&&item.value==selected[i].value}}"><view class="check data-v-348bb63d"></view></block></view></block></scroll-view></block></block><block s-if="{{loading}}"><view class="loading-cover data-v-348bb63d"><uni-load-more class="load-more data-v-348bb63d" vue-id="78e09a9f-1" contentText="{{loadMore}}" status="loading"></uni-load-more></view></block><block s-if="{{errorMessage}}"><view class="error-message data-v-348bb63d"><text class="error-text data-v-348bb63d">{{errorMessage}}</text></view></block></view></view>