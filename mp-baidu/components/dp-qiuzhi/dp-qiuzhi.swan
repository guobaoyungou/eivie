<view class="dp-product" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')+('width:'+('calc(100% - '+params.margin_x*2.2*2+'rpx)')+';')}}"><block s-if="{{params.style=='1'}}"><dp-qiuzhi-itemlist vue-id="fa8b6cda-1" data="{{data}}" idfield="proid" menuindex="{{menuindex}}"></dp-qiuzhi-itemlist></block><block s-if="{{params.style=='2'}}"><dp-qiuzhi-item vue-id="fa8b6cda-2" showstyle="{{params.style}}" data="{{data}}" idfield="proid" menuindex="{{menuindex}}"></dp-qiuzhi-item></block></view>