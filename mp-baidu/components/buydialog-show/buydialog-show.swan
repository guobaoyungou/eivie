<view class="data-v-6f6ba8ab"><block s-if="{{isload}}"><view class="data-v-6f6ba8ab"><view class="{{['buydialog-current','data-v-6f6ba8ab',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view style="padding-top:20rpx;padding-left:20rpx;font-weight:bold;" class="data-v-6f6ba8ab">{{shopset.guige_name?shopset.guige_name:'请选择规格和数量'}}</view><block s-if="{{nowguige.balance_price}}"><view style="{{'width:94%;margin:10rpx 3%;font-size:24rpx;'+('color:'+($root.m0)+';')}}" class="data-v-6f6ba8ab">{{"首付款金额："+nowguige.advance_price+"元，尾款金额："+nowguige.balance_price+"元"}}</view></block><view style="max-height:50vh;overflow:scroll;" class="data-v-6f6ba8ab"><block s-for="guigedata trackBy index" s-for-item="item" s-for-index="index"><view class="guigelist flex-col data-v-6f6ba8ab"><view class="name data-v-6f6ba8ab">{{item.title}}</view><view class="item flex flex-y-center data-v-6f6ba8ab"><block s-for="item.items trackBy index2" s-for-item="item2" s-for-index="index2"><block class="data-v-6f6ba8ab"><view class="{{['data-v-6f6ba8ab','item2 '+(ggselected[item.k]==item2.k?'on':'')]}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" bindtap="__e">{{item2.title}}</view></block></block></view></view></block></view><block s-if="{{product.price_type==1}}"><block class="data-v-6f6ba8ab"><button data-event-opts="{{[['tap',[['showLinkChange',['$event']]]]]}}" class="addcart data-v-6f6ba8ab" style="{{'background-color:'+($root.m1)+';'}}" bindtap="__e">{{product.xunjia_text?product.xunjia_text:'联系TA'}}</button></block></block><block s-else><block class="data-v-6f6ba8ab"><view class="buynum flex flex-y-center data-v-6f6ba8ab"><view class="flex1 data-v-6f6ba8ab">购买数量：</view><view class="addnum data-v-6f6ba8ab"><view data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" class="minus data-v-6f6ba8ab" bindtap="__e"><image class="img data-v-6f6ba8ab" src="{{pre_url+'/static/img/cart-minus.png'}}"></image></view><input class="input data-v-6f6ba8ab" type="number" data-event-opts="{{[['input',[['gwcinput',['$event']]]]]}}" value="{{gwcnum}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" class="plus data-v-6f6ba8ab" bindtap="__e"><image class="img data-v-6f6ba8ab" src="{{pre_url+'/static/img/cart-plus.png'}}"></image></view></view></view></block></block></view></view></block><block s-if="{{loading}}"><loading vue-id="46e70713-1" class="data-v-6f6ba8ab"></loading></block></view>