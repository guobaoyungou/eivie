<view class="dp-scoreshop" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block s-if="{{params.style=='1'||params.style=='2'||params.style=='3'}}"><view class="dp-scoreshop-item"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" style="{{(params.style==2?'width:49%;margin-right:'+(index%2==0?'2%':0):params.style==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{'/activity/scoreshop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{params.showprice!='0'}}"><view class="p2-1"><view class="t1" style="{{'color:'+($root.m0)+';'}}">{{item.score_price+$root.m1}}<block s-if="{{item.money_price>0&&params.showprice=='1'}}"><text>{{"+"+item.money_price+"元"}}</text></block></view><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block></view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3">{{"已兑换"+item.sales+"件"}}</view></block></view></view></block></view></block><block s-if="{{params.style=='list'}}"><view class="dp-scoreshop-itemlist"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/activity/scoreshop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><block s-if="{{params.showprice!='0'}}"><view class="p2"><view class="t1" style="{{'color:'+($root.m2)+';'}}">{{item.score_price+$root.m3}}<block s-if="{{item.money_price>0&&params.showprice=='1'}}"><text>{{"+"+item.money_price+"元"}}</text></block></view><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block><view class="p3"><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已兑换"+item.sales+"件"}}</text></view></block></view></view></view></block></view></block><block s-if="{{params.style=='line'}}"><view class="dp-scoreshop-itemline"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/activity/scoreshop/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{params.showprice!='0'}}"><view class="p2-1"><view class="t1" style="{{'color:'+($root.m4)+';'}}">{{item.score_price+$root.m5}}<block s-if="{{item.money_price>0&&params.showprice=='1'}}"><text>{{"+"+item.money_price+"元"}}</text></block></view><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block></view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3">{{"已兑换"+item.sales+"件"}}</view></block></view></view></block></view></block></view>