<view style="width:100%;"><view class="dp-product-item"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" style="{{(showstyle==2?'width:49%;margin-right:'+(index%2==0?'2%':0):showstyle==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{showtype=='0'?'/restaurant/takeaway/product?id='+item[idfield]:'/restaurant/shop/product?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{saleimg!=''}}"><image class="saleimg" src="{{saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block s-if="{{item.price_show&&item.price_show_text}}"><text style="margin:0 15rpx;font-size:22rpx;font-weight:400;">{{item.price_show_text}}</text></block><block s-if="{{showprice=='1'&&item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></block></view><block s-if="{{item.price_show&&item.price_show==1}}"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item.sell_putongprice}}</text></view></block><block s-if="{{item.priceshows&&item.priceshows.length>0}}"><view><block s-for="item.priceshows" s-for-item="item2" s-for-index="index2"><view style="line-height:44rpx;"><text style="font-size:24rpx;">{{"￥"+item2.sell_price}}</text><text style="margin-left:15rpx;font-size:22rpx;font-weight:400;">{{item2.price_show_text}}</text></view></block></view></block><block s-if="{{showsales=='1'&&item.sales>0}}"><view class="p3">{{"已售"+item.sales+"件"}}</view></block><block s-if="{{showcart==1}}"><view class="p4" style="{{'background:'+('rgba('+$root.m1+',0.1)')+';'+('color:'+($root.m2)+';')}}" data-proid="{{item[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchtap="__e"><text class="iconfont icon_gouwuche"></text></view></block><block s-if="{{showcart==2}}"><view class="p4" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}" data-proid="{{item[idfield]}}" data-event-opts="{{[['tap',[['buydialogChange',['$event']]]]]}}" catchtap="__e"><image class="img" src="{{cartimg}}"></image></view></block></view></view></block></view><block s-if="{{buydialogShow}}"><buydialog vue-id="bca4ddda-1" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^addcart',[['addcart']]],['^buydialogChange',[['buydialogChange']]]]}}" bind:addcart="__e" bind:buydialogChange="__e"></buydialog></block></view>