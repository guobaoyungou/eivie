<view style="width:100%;"><view class="dp-product-item"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" style="{{('width:49%;margin-right:'+(index%2==0?'2%':0))}}" data-url="{{'/zhaopin/zhaopin/detail?id='+item[idfield]}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.thumb}}" mode="widthFix"></image><block s-if="{{item.apply_tag}}"><text class="renzheng">担保企业</text></block></view><view class="product-info"><view class="p1">{{item.title}}</view><view class="p3"><text class="t2">{{item.num+"人/"+item.salary}}</text></view></view></view></block></view></view>