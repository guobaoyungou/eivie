<view class="dp-line" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><view class="dp-line-line" style="{{'border-top-width:'+(params.height*2.2+'rpx')+';'+('border-top-style:'+(params.style)+';')+('border-top-color:'+(params.color)+';')}}"></view></view>