<view class="uni-calendar data-v-1222a991"><block s-if="{{!insert&&show}}"><view data-event-opts="{{[['tap',[['clean',['$event']]]]]}}" class="{{['uni-calendar__mask','data-v-1222a991',(aniMaskShow)?'uni-calendar--mask-show':'']}}" bindtap="__e"></view></block><block s-if="{{insert||show}}"><view class="{{['uni-calendar__content','data-v-1222a991',(!insert)?'uni-calendar--fixed':'',(aniMaskShow)?'uni-calendar--ani-show':'']}}"><block s-if="{{!insert}}"><view class="uni-calendar__header uni-calendar--fixed-top data-v-1222a991"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="uni-calendar__header-btn-box data-v-1222a991" bindtap="__e"><text class="uni-calendar__header-text uni-calendar--fixed-width data-v-1222a991">{{cancelText}}</text></view><view data-event-opts="{{[['tap',[['confirm',['$event']]]]]}}" class="uni-calendar__header-btn-box data-v-1222a991" bindtap="__e"><text class="uni-calendar__header-text uni-calendar--fixed-width data-v-1222a991">{{okText}}</text></view></view></block><view class="uni-calendar__header data-v-1222a991"><view data-event-opts="{{[['tap',[['pre',['$event']]]]]}}" class="uni-calendar__header-btn-box data-v-1222a991" catchtap="__e"><view class="uni-calendar__header-btn uni-calendar--left data-v-1222a991"></view></view><picker mode="date" value="{{date}}" fields="month" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-1222a991"><text class="uni-calendar__header-text data-v-1222a991">{{(nowDate.year||'')+' / '+(nowDate.month||'')}}</text></picker><view data-event-opts="{{[['tap',[['next',['$event']]]]]}}" class="uni-calendar__header-btn-box data-v-1222a991" catchtap="__e"><view class="uni-calendar__header-btn uni-calendar--right data-v-1222a991"></view></view></view><view class="uni-calendar__box data-v-1222a991"><block s-if="{{showMonth}}"><view class="uni-calendar__box-bg data-v-1222a991"><text class="uni-calendar__box-bg-text data-v-1222a991">{{nowDate.month}}</text></view></block><view class="uni-calendar__weeks data-v-1222a991"><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{SUNText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{monText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{TUEText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{WEDText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{THUText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{FRIText}}</text></view><view class="uni-calendar__weeks-day data-v-1222a991"><text class="uni-calendar__weeks-day-text data-v-1222a991">{{SATText}}</text></view></view><block s-for="weeks trackBy weekIndex" s-for-item="item" s-for-index="weekIndex"><view class="uni-calendar__weeks data-v-1222a991"><block s-for="item trackBy weeksIndex" s-for-item="weeks" s-for-index="weeksIndex"><view class="uni-calendar__weeks-item data-v-1222a991"><calendar-item class="uni-calendar-item--hook data-v-1222a991" vue-id="{{'1388b973-1-'+weekIndex+'-'+weeksIndex}}" weeks="{{weeks}}" calendar="{{calendar}}" selected="{{selected}}" lunar="{{lunar}}" backColor="{{backColor}}" fontColor="{{fontColor}}" data-event-opts="{{[['^change',[['choiceDate']]]]}}" bind:change="__e"></calendar-item></view></block></view></block></view></view></block></view>