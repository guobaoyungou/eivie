<block s-if="{{!scroll}}"><view class="dd-tab" style="{{(isfixed?'position:fixed;':'')}}"><block s-for="itemdata trackBy index" s-for-item="item" s-for-index="index"><view class="{{['item',st==itemst[index]?'on':'']}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m0)+';'}}"></view></view></block></view></block><block s-else><view class="dd-tab2" style="{{(isfixed?'position:fixed;':'')}}"><scroll-view scroll-x="true"><block s-if="{{ismoney}}"><view class="dd-tab2-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{showstatus[index]}}"><view class="{{['item',st==itemst[index]?'on':'']}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item.$orig}}<view class="after" style="{{'background:'+(color1?color1:item.m1)+';'}}"></view></view></block></block></view></block><block s-else><view class="dd-tab2-content"><block s-for="itemdata trackBy index" s-for-item="item" s-for-index="index"><view class="{{['item',st==itemst[index]?'on':'']}}" data-st="{{itemst[index]}}" data-event-opts="{{[['tap',[['changetab',['$event']]]]]}}" bindtap="__e">{{item}}<view class="after" style="{{'background:'+(color1?color1:$root.m2)+';'}}"></view></view></block></view></block></scroll-view></view></block>