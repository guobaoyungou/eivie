<view class="dp-kanjia" style="{{'background-color:'+(params.bgcolor)+';'+('margin:'+(params.margin_y*2.2+'rpx '+params.margin_x*2.2+'rpx 0')+';')+('padding:'+(params.padding_y*2.2+'rpx '+params.padding_x*2.2+'rpx')+';')}}"><block s-if="{{params.style=='1'||params.style=='2'||params.style=='3'}}"><view class="dp-kanjia-item"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" style="{{(params.style==2?'width:49%;margin-right:'+(index%2==0?'2%':0):params.style==3?'width:32%;margin-right:'+(index%3!=2?'2%':0):'width:100%')}}" data-url="{{'/activity/kanjia/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{params.showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.min_price}}</text><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block></view><view class="p3"><view class="p3-1" style="{{'background:'+('rgba('+$root.m1+',0.12)')+';'+('color:'+($root.m2)+';')}}">砍价</view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-2"><text style="overflow:hidden;">{{"已砍走"+item.sales+"件"}}</text></view></block></view></view></view></block></view></block><block s-if="{{params.style=='list'}}"><view class="dp-kanjia-itemlist"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/activity/kanjia/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><block s-if="{{params.showprice!='0'}}"><view class="p2"><text class="t1" style="{{'color:'+($root.m3)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.min_price}}</text><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block><view class="p3"><view class="p3-1" style="{{'background:'+('rgba('+$root.m4+',0.12)')+';'+('color:'+($root.m5)+';')}}">砍价</view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-2"><text style="overflow:hidden;">{{"已砍走"+item.sales+"件"}}</text></view></block></view></view></view></block></view></block><block s-if="{{params.style=='line'}}"><view class="dp-kanjia-itemline"><block s-for="data trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/activity/kanjia/product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image><block s-if="{{params.saleimg!=''}}"><image class="saleimg" src="{{params.saleimg}}" mode="widthFix"></image></block></view><view class="product-info"><block s-if="{{params.showname==1}}"><view class="p1">{{item.name}}</view></block><view class="p2"><block s-if="{{params.showprice!='0'}}"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m6)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.min_price}}</text><block s-if="{{params.showprice=='1'}}"><text class="t2">{{"￥"+item.sell_price}}</text></block></view></block></view><view class="p3"><view class="p3-1" style="{{'background:'+('rgba('+$root.m7+',0.12)')+';'+('color:'+($root.m8)+';')}}">砍价</view><block s-if="{{params.showsales=='1'&&item.sales>0}}"><view class="p3-2"><text style="overflow:hidden;">{{"已砍走"+item.sales+"件"}}</text></view></block></view></view></view></block></view></block></view>