<view class="container"><block s-if="{{isload}}"><block><view class="ordertop" style="{{('background:url('+pre_url+'/static/img/ordertop.png);background-size:100%')}}"><block s-if="{{detail.status==1}}"><view class="f1"><view class="t1">活动待核销</view></view></block><block s-if="{{detail.status==2}}"><view class="f1"><view class="t1">活动已核销</view></view></block></view><view class="product"><view class="content"><view data-url="{{'index?id='+detail.hid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{detail.pic}}"></image></view><view class="detail"><text class="t1">{{detail.name}}</text><view class="t3"><text class="x1 flex1">{{"￥"+detail.price}}</text></view><view class="t2"><text>{{"已邀请"+detail.yqnum+"人"}}</text></view></view></view></view><block s-if="{{detail.yqnum>0}}"><view class="orderinfo"><view class="item flex-y-center" style="padding:10rpx 0;"><text class="t1">邀请人员</text><view class="t2" style="overflow:hidden;" user-select="true" selectable="true"><block s-for="detail.yqlist" s-for-item="item" s-for-index="index"><block><image class="yq_image" src="{{item.headimg}}"></image></block></block></view></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{detail.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{detail.createtime}}</text></view><block s-if="{{detail.status>0&&detail.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{detail.paytime}}</text></view></block><block s-if="{{detail.status==2&&detail.hxtime}}"><view class="item"><text class="t1">核销时间</text><text class="t2">{{detail.hxtime}}</text></view></block></view><view class="orderinfo"><block s-if="{{detail.price>0}}"><view class="item"><text class="t1">支付金额</text><text class="t2 red">{{"¥"+detail.price}}</text></view></block><view class="item"><text class="t1">订单状态</text><block s-if="{{detail.status==1}}"><text class="t2">待核销</text></block><block s-if="{{detail.status==2}}"><text class="t2">已核销</text></block></view></view><view style="width:100%;height:160rpx;"></view><block s-if="{{detail.status!=2}}"><view class="bottom notabbarbot"><view data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" class="btn2" bindtap="__e">核销码</view></view></block><uni-popup class="vue-ref" vue-id="36d45302-1" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{detail.hexiaoqr}}" data-url="{{detail.hexiaoqr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="36d45302-2"></loading></block><dp-tabbar vue-id="36d45302-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="36d45302-4" data-ref="popmsg"></popmsg></view>