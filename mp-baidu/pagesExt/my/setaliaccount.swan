<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="form"><view class="form-item"><input class="input" type="text" placeholder="请输入真实姓名" placeholder-style="color:#BBBBBB;font-size:28rpx" name="aliaccountname" value="{{userinfo.aliaccountname}}"/></view><view class="form-item"><input class="input" type="text" placeholder="请输入支付宝账号" placeholder-style="color:#BBBBBB;font-size:28rpx" name="aliaccount" value="{{userinfo.aliaccount}}"/></view></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block s-if="{{loading}}"><loading vue-id="f38f62d6-1"></loading></block><dp-tabbar vue-id="f38f62d6-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="f38f62d6-3" data-ref="popmsg"></popmsg></view>