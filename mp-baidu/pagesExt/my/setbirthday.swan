<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="form"><view class="form-item"><text class="label">生日</text><picker class="picker" mode="date" value="" start="1900-01-01" end="{{$root.m0}}" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{birthday}}"><view>{{birthday}}</view></block><block s-else><view>请选择生日</view></block></picker></view></view><button class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" form-type="submit">保 存</button></form></block></block><block s-if="{{loading}}"><loading vue-id="7d8fb8e7-1"></loading></block><dp-tabbar vue-id="7d8fb8e7-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7d8fb8e7-3" data-ref="popmsg"></popmsg></view>