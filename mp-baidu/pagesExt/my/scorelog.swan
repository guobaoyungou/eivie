<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}<block s-if="{{set.member_score_withdraw}}"><view class="btn" data-url="/pagesB/my/memberscorewithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></block></view><view class="f2">{{myscore}}<block s-if="{{scoreTransfer}}"><view class="btn-mini" data-url="/pagesExt/my/scoreTransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转赠</view></block></view><view class="item flex-bt flex-y-center"><block s-if="{{scoreWithdraw}}"><view><view class="label">{{"允提"+$root.m2+''}}<view class="btn" data-url="/pagesExt/my/scoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></view><view class="value">{{myscore2}}</view></view></block><block s-if="{{score_freeze>0}}"><view><view class="label flex-y-center" data-url="/pagesB/my/scorefreezelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{"冻结"+$root.m3+''}}<image class="right-image" src="{{pre_url+'/static/imgsrc/commission_dw.png'}}"></image></view><view class="value" style="margin-top:20rpx;">{{score_freeze}}</view></view></block></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block s-else><block><text class="t2">{{item.score}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="57484046-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="57484046-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="57484046-3"></loading></block><dp-tabbar vue-id="57484046-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="57484046-5" data-ref="popmsg"></popmsg></view>