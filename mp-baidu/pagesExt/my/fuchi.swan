<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-if="{{st==0}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after+"元"}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block s-else><text class="t2">{{item.money}}</text></block></view></view></block></block></block><block s-if="{{st==1}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{"提现金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block s-if="{{item.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="0176bf51-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="0176bf51-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="0176bf51-3"></loading></block><dp-tabbar vue-id="0176bf51-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0176bf51-5" data-ref="popmsg"></popmsg></view>