<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="flex1"><view class="f1">{{"商家"+$root.m1}}</view><view class="f2">{{mybscore}}</view></view><view class="flex1"><view class="f1">{{"平台"+$root.m2}}</view><view class="f2" data-url="scorelog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{myscore}}</view></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'bscorelog?bid='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image style="width:60rpx;height:60rpx;border-radius:10rpx;margin-right:10rpx;" src="{{item.logo}}"></image><text class="t1">{{item.name}}</text></view><view class="f2"><view class="t1">{{item.score}}<text>{{$root.m3}}</text></view><image style="width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="02eefd70-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="02eefd70-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="02eefd70-3"></loading></block><dp-tabbar vue-id="02eefd70-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="02eefd70-5" data-ref="popmsg"></popmsg></view>