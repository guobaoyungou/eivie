<view class="container"><block s-if="{{isload}}"><block><view class="coupon-list"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="coupon" style="{{(item.$orig.isgive==1||item.$orig.isgive==2?'padding-left:40rpx':'')}}" data-url="{{'coupondetail?rid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="pt_left"><view class="pt_left-content"><block s-if="{{item.$orig.type==1}}"><view class="f1" style="{{'color:'+(item.m0)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block s-if="{{item.$orig.type==10}}"><view class="f1" style="{{'color:'+(item.m1)+';'}}"><text class="t1">{{item.$orig.discount/10}}</text><text class="t0">折</text></view></block><block s-if="{{item.$orig.type==2}}"><view class="f1" style="{{'color:'+(item.m2)+';'}}">礼品券</view></block><block s-if="{{item.$orig.type==3}}"><view class="f1" style="{{'color:'+(item.m3)+';'}}"><text class="t1">{{item.$orig.limit_count}}</text><text class="t2">次</text></view></block><block s-if="{{item.$orig.type==4}}"><view class="f1" style="{{'color:'+(item.m4)+';'}}">抵运费</view></block><block s-if="{{item.$orig.type==5}}"><view class="f1" style="{{'color:'+(item.m5)+';'}}"><text class="t0">￥</text><text class="t1">{{item.$orig.money}}</text></view></block><block s-if="{{item.$orig.type==1||item.$orig.type==4||item.$orig.type==5}}"><view class="f2" style="{{'color:'+(item.m6)+';'}}"><block s-if="{{item.$orig.minprice>0}}"><text>{{"满"+item.$orig.minprice+"元可用"}}</text></block><block s-else><text>无门槛</text></block></view></block><block s-if="{{item.$orig.type==20}}"><view class="f1" style="{{'color:'+(item.m7)+';'}}">券包</view></block></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.$orig.couponname}}</view><block s-if="{{item.$orig.type==1}}"><text class="t2" style="{{'background:'+('rgba('+item.m8+',0.1)')+';'+('color:'+(item.m9)+';')}}">代金券</text></block><block s-if="{{item.$orig.type==2}}"><text class="t2" style="{{'background:'+('rgba('+item.m10+',0.1)')+';'+('color:'+(item.m11)+';')}}">礼品券</text></block><block s-if="{{item.$orig.type==3}}"><text class="t2" style="{{'background:'+('rgba('+item.m12+',0.1)')+';'+('color:'+(item.m13)+';')}}">计次券</text></block><block s-if="{{item.$orig.type==4}}"><text class="t2" style="{{'background:'+('rgba('+item.m14+',0.1)')+';'+('color:'+(item.m15)+';')}}">运费抵扣券</text></block><block s-if="{{item.$orig.type==5}}"><text class="t2" style="{{'background:'+('rgba('+item.m16+',0.1)')+';'+('color:'+(item.m17)+';')}}">餐饮券</text></block><block s-if="{{item.$orig.type==20}}"><text class="t2" style="{{'background:'+('rgba('+item.m18+',0.1)')+';'+('color:'+(item.m19)+';')}}">券包</text></block><block s-if="{{item.$orig.bid>0}}"><view class="t4">{{"适用商家："+item.$orig.bname}}</view></block><block s-if="{{item.$orig.type!=20}}"><view class="t3" style="{{(item.$orig.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"有效期至 "+item.$orig.endtime}}</view></block></view></view></view></block></view><view style="width:100%;height:120rpx;"></view><view class="giveopbox"><view data-event-opts="{{[['tap',[['receiveCoupon',['$event']]]]]}}" class="btn-give" style="{{'background:'+('linear-gradient(90deg,'+$root.m20+' 0%,rgba('+$root.m21+',0.8) 100%)')+';'}}" bindtap="__e">{{"立即领取("+datalist.length+"张)"}}</view></view></block></block><block s-if="{{loading}}"><loading vue-id="0c07164a-1"></loading></block><dp-tabbar vue-id="0c07164a-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="0c07164a-3" data-ref="popmsg"></popmsg></view>