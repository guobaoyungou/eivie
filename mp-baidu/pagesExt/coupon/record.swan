<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="339a3a81-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="339a3a81-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="339a3a81-3"></loading></block><dp-tabbar vue-id="339a3a81-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="339a3a81-5" data-ref="popmsg"></popmsg></view>