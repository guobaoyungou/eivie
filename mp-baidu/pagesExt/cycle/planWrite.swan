<view class="data-v-018c91fe"><block s-if="{{isload}}"><view class="page data-v-018c91fe"><view class="head data-v-018c91fe"><image class="head_img _img data-v-018c91fe" src="{{nowguige.pic||product.pic}}" data-url="{{nowguige.pic||product.pic}}" alt data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="data-v-018c91fe"><view class="head_title data-v-018c91fe">{{product.name}}</view><view class="head_text data-v-018c91fe">{{nowguige.name+" | "+product.ps_cycle_title}}</view><view class="head_price data-v-018c91fe"><text class="head_icon data-v-018c91fe">￥</text><block s-if="{{nowguige.sell_price>0}}"><text class="data-v-018c91fe">{{nowguige.sell_price}}</text></block><block s-else><text class="data-v-018c91fe">{{product.sell_price}}</text></block></view></view></view><view class="body data-v-018c91fe"><block s-for="guigedata" s-for-item="item" s-for-index="index"><view class="body_item data-v-018c91fe"><view class="body_title flex flex-bt data-v-018c91fe">{{item.title}}<text class="body_text data-v-018c91fe">请选择周期购计划</text></view><view class="body_content data-v-018c91fe"><block s-for="item.items trackBy index" s-for-item="item2" s-for-index="index2"><view class="{{['body_tag','data-v-018c91fe',ggselected[item.k]==item2.k?'body_active':'']}}" data-itemk="{{item.k}}" data-idx="{{item2.k}}" data-event-opts="{{[['tap',[['ggchange',['$event']]]]]}}" bindtap="__e">{{item2.title}}</view></block></view></view></block><view class="body_item data-v-018c91fe"><view class="body_title flex flex-bt data-v-018c91fe">配送时间<text class="body_text data-v-018c91fe">{{product.ps_cycle_title}}</text></view><block s-if="{{product.ps_cycle==1}}"><view class="body_content data-v-018c91fe"><block s-for="rateList trackBy index" s-for-item="item" s-for-index="index"><view data-event-opts="{{[['tap',[['rateClick',[index]]]]]}}" class="{{['body_tag','data-v-018c91fe',rateIndex===index?'body_active':'']}}" bindtap="__e">{{item.label}}</view></block></view></block></view><view class="body_item data-v-018c91fe"><view class="body_title flex flex-bt data-v-018c91fe"><label class="_span data-v-018c91fe">开始时间</label><view data-event-opts="{{[['tap',[['toCheckDate',['$event']]]]]}}" class="body_data data-v-018c91fe" bindtap="__e">{{week+" "+(startDate?startDate:'请选择开始时间')+''}}<image class="body_detail _img data-v-018c91fe" src="{{pre_url+'/static/img/week/week_detail.png'}}"></image></view></view></view><view class="body_item data-v-018c91fe"><view class="body_title flex flex-bt data-v-018c91fe"><text class="data-v-018c91fe">配送期数</text><view class="flex-y-center data-v-018c91fe"><block s-if="{{min_qsnum!=1}}"><text class="body_notice data-v-018c91fe">{{min_qsnum+"期起订"}}</text></block><view class="body_data data-v-018c91fe"><block s-if="{{qsnumState}}"><image class="{{['body_opt','_img','data-v-018c91fe',qsnum<=min_qsnum?'body_disabled':'']}}" src="{{pre_url+'/static/img/week/week_cut.png'}}" data-event-opts="{{[['tap',[['qsminus',['$event']]]]]}}" bindtap="__e"></image></block><block s-if="{{!qsnumState}}"><image class="body_opt body_disabled _img data-v-018c91fe" src="{{pre_url+'/static/img/week/week_cut.png'}}"></image></block><input class="body_num data-v-018c91fe" type="number" data-event-opts="{{[['blur',[['getQsTotal',['$event']]]]]}}" value="{{qsnum}}" bindblur="__e"/><image class="body_opt _img data-v-018c91fe" src="{{pre_url+'/static/img/week/week_add.png'}}" data-event-opts="{{[['tap',[['qsplus',['$event']]]]]}}" bindtap="__e"></image></view></view></view></view><view class="body_item data-v-018c91fe"><view class="body_title flex flex-bt data-v-018c91fe"><text class="data-v-018c91fe">每期数量</text><view class="flex-y-center data-v-018c91fe"><block s-if="{{min_num!=1}}"><text class="body_notice data-v-018c91fe">{{min_num+"件起订"}}</text></block><view class="body_data data-v-018c91fe"><block s-if="{{numState}}"><image class="{{['body_opt','_img','data-v-018c91fe',num<=min_num?'body_disabled':'']}}" src="{{pre_url+'/static/img/week/week_cut.png'}}" data-event-opts="{{[['tap',[['gwcminus',['$event']]]]]}}" bindtap="__e"></image></block><block s-if="{{!numState}}"><image class="body_opt body_disabled _img data-v-018c91fe" src="{{pre_url+'/static/img/week/week_cut.png'}}"></image></block><input class="body_num data-v-018c91fe" type="number" data-event-opts="{{[['blur',[['getTotal',['$event']]]]]}}" value="{{num}}" bindblur="__e"/><image class="body_opt _img data-v-018c91fe" src="{{pre_url+'/static/img/week/week_add.png'}}" data-event-opts="{{[['tap',[['gwcplus',['$event']]]]]}}" bindtap="__e"></image></view></view></view></view></view></view></block><block s-if="{{product.status==1}}"><view class="{{['bottombar','flex-row','flex-xy-center','data-v-018c91fe',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view class="operate_data data-v-018c91fe"><view class="operate_text data-v-018c91fe">配送<text class="operate_color data-v-018c91fe">{{!qsnum?'':qsnum}}</text>期，共<text class="operate_color data-v-018c91fe">{{!num||!qsnum?'':num*qsnum}}</text>件商品</view><view class="operate_price data-v-018c91fe"><text class="operate_lable data-v-018c91fe">总价：</text><text class="operate_tag data-v-018c91fe">￥</text><text class="operate_num data-v-018c91fe">{{!num||!qsnum?'':totalprice}}</text></view></view><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy flex1 data-v-018c91fe" style="{{'background:'+($root.m0)+';'}}" bindtap="__e"><text class="data-v-018c91fe">去结算</text></view></view></block><block s-if="{{loading}}"><loading vue-id="41e4ad6e-1" class="data-v-018c91fe"></loading></block></view>