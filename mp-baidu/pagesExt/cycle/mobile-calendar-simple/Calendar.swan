<transition vue-id="0256252d-1" name="{{transition}}" class="data-v-52c36708" vue-slots="{{['default']}}"><block s-if="{{isShow}}"><view class="{{['calendar-tz','_div','data-v-52c36708',isFixed&&'fixed']}}"><slot name="header"></slot><view class="week-number _div data-v-52c36708"><block s-for="weekList trackBy index" s-for-item="item" s-for-index="index"><label style="{{'color:'+((index==0||index==weekList.length-1)&&themeColor)+';'}}" class="_span data-v-52c36708">{{item}}</label></block></view><block s-if="{{title}}"><view class="tips _p data-v-52c36708">{{title}}</view></block><view class="content _div data-v-52c36708" id="scrollWrap"><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><view class="con _div data-v-52c36708" id="{{item.$orig.year+''+item.$orig.month}}"><view class="_h3 data-v-52c36708">{{item.$orig.year+'年'+item.$orig.month+'月'}}</view><label class="month-bg _span data-v-52c36708" style="{{'color:'+(getBetweenColor)+';'}}">{{item.$orig.month}}</label><view class="each-month _ul data-v-52c36708"><block s-for="item.l0 trackBy idx" s-for-item="day" s-for-index="idx"><view data-event-opts="{{[['tap',[['chooseDate',['$0','$1','$2'],[[['calendar','',index],['dayList','',idx]],[['calendar','',index,'month']],[['calendar','',index,'year']]]]]]]}}" class="{{['each-day','_li','data-v-52c36708',day.m0]}}" style="{{'background:'+(day.m1)+';'}}" bindtap="__e"><block s-if="{{mode!=4}}"><view class="{{['_div','data-v-52c36708',day.m2]}}" style="{{'background:'+(day.m3)+';'}}"><view class="day _p data-v-52c36708">{{day.$orig?day.$orig:''}}</view><block s-if="{{day.m4}}"><view class="recent _p data-v-52c36708"><view class="_i data-v-52c36708">{{day.m5}}</view></view></block><block s-else><block s-if="{{showstock==1}}"><view class="recent _p data-v-52c36708"><block s-if="{{dayroomprice[item.$orig.year+'-'+(item.$orig.month<=9?'0':'')+item.$orig.month+'-'+(day.$orig<=9?'0':'')+(day.$orig?day.$orig:'')]&&showstock==1}}"><block class="data-v-52c36708">{{dayroomprice[item.$orig.year+'-'+(item.$orig.month<=9?'0':'')+item.$orig.month+'-'+(day.$orig<=9?'0':'')+(day.$orig?day.$orig:'')]+text['间']+''}}</block></block></view></block></block></view></block><block s-else><view class="{{['_div','data-v-52c36708',day.m6]}}"><view class="day _p data-v-52c36708">{{day.$orig?day.$orig:''}}</view><view class="recent _p data-v-52c36708">1<view class="_i data-v-52c36708">{{day.m7}}</view></view></view></block></view></block></view></view></block></view><slot name="footer"></slot></view></block></transition>