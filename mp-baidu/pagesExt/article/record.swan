<view class="container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索本页" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-if="{{isload}}"><block><view class="article_list"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="article-itemlist" data-url="{{'/pagesExt/article/fujian?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="article-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="article-info"><view class="p1">{{item.name}}</view><block><view class="p3">{{''+item.subname+''}}</view></block><view class="p2"><text class="flex1" style="overflow:hidden;">{{item.createtime}}</text></view></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="52cde719-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="52cde719-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="52cde719-3"></loading></block><dp-tabbar vue-id="52cde719-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="52cde719-5" data-ref="popmsg"></popmsg></view>