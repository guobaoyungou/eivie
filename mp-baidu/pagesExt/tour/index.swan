<view><block s-if="{{isload}}"><block><view class="container"><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block s-if="{{item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view><view class="p3"><view class="t1">已拼成<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.sales}}</text>件</view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x1">{{item.teamnum+"人团"}}</text><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">去拼团</text></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="e6ae4630-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="e6ae4630-2"></nodata></block></view></block></block><block s-if="{{loading}}"><loading vue-id="e6ae4630-3"></loading></block><dp-tabbar vue-id="e6ae4630-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="e6ae4630-5" data-ref="popmsg"></popmsg></view>