<view class="container"><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><block s-if="{{item.status_text}}"><text class="t2">{{item.status_text}}</text></block><text class="t2">{{item.signdate}}</text></view><view class="f2"><text class="t1">{{"+"+item.score}}</text></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="703aa1bb-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="703aa1bb-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="703aa1bb-3"></loading></block><dp-tabbar vue-id="703aa1bb-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="703aa1bb-5" data-ref="popmsg"></popmsg></view>