<view class="container"><block s-if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+type_name}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{money}}</view></view><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block s-else><text class="t2">{{item.money}}</text></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="f6719802-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="f6719802-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="f6719802-3"></loading></block><dp-tabbar vue-id="f6719802-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="f6719802-5" data-ref="popmsg"></popmsg></view>