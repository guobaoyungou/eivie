<view class="container"><block s-if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{userinfo.money}}</view><view class="f3" data-url="/pagesExt/money/moneylog?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>充值记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view><block s-if="{{mdlist.length>0}}"><view data-event-opts="{{[['tap',[['selectmd',['$event']]]]]}}" class="mendian" bindtap="__e">{{"门店："+mdlist[mdkey].name}}</view></block></view><view class="content2"><block s-if="{{caninput==1||giveset.length>0}}"><view class="item2"><view class="f1">{{"充值金额("+$root.m2+")"}}</view></view></block><block s-if="{{caninput==1}}"><block><view class="item3"><view class="f1">￥</view><view class="f2"><input style="font-size:60rpx;" type="digit" name="money" placeholder="请输入充值金额" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{money}}" bindinput="__e"/></view></view></block></block><block s-if="{{giveset.length>0}}"><view class="giveset"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{item.$orig.money>0}}"><view class="{{['item',moneyduan==item.$orig.money?'active':'']}}" style="{{(moneyduan==item.$orig.money?'background:'+item.m3:'')}}" data-money="{{item.$orig.money}}" data-event-opts="{{[['tap',[['selectgiveset',['$event']]]]]}}" bindtap="__e"><text class="t1">{{(caninput==1?'满':'充')+item.$orig.money+item.m4}}</text><block s-if="{{item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠"+item.$orig.give+item.m5+"+"+item.$orig.give_score+item.m6}}</text></block><block s-else><block s-if="{{item.$orig.give&&!item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give+item.m7}}</text></block><block s-else><block s-if="{{!item.$orig.give&&item.$orig.give_score}}"><text class="t2">{{"赠送"+item.$orig.give_score+item.m8}}</text></block></block></block></view></block></block></view></block><block s-if="{{recharge_minimum&&recharge_minimum>0}}"><view class="item2"><view class="f1">{{"最低充值"+recharge_minimum+"元"}}</view></view></block><block s-if="{{shuoming}}"><view style="padding:20rpx 30rpx;line-height:42rpx;"><parse vue-id="5f5571e6-1" content="{{shuoming}}" data-event-opts="{{[['^navigate',[['navigate']]]]}}" bind:navigate="__e"></parse></view></block></view><view class="op"><view data-event-opts="{{[['tap',[['topay',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m9)+';'}}" bindtap="__e">去支付</view></view><block s-if="{{transfer}}"><view class="op"><view class="btn" style="{{'background:'+($root.m10)+';'}}" data-url="rechargeToMember" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账</view></view></block></block></block><block s-if="{{selectmdDialogShow}}"><view class="popup__container"><view class="popup__overlay"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择门店</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideSelectmdDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><view class="pstime-item" data-index="{{index}}" data-event-opts="{{[['tap',[['selectmdRadioChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.$orig.name}}</view><view style="color:#999;font-size:24rpx;margin-right:10rpx;">{{item.$orig.juli?' 距离:'+item.$orig.juli+'千米':''}}</view><view class="radio" style="{{(index==mdkey?'background:'+item.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></view></view></view></block><block s-if="{{loading}}"><loading vue-id="5f5571e6-2"></loading></block><dp-tabbar vue-id="5f5571e6-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5f5571e6-4" data-ref="popmsg"></popmsg></view>