<scroll-view class="pageContainer" scroll-y="{{isshowmendianmodal?false:true}}"><block s-if="{{isload}}"><view style="{{'background-color:'+(isdiy?pageinfo.bgcolor:'')+';'}}"><block s-if="{{show_mendian==1&&isdiy==1}}"><block><view class="header-mendian-box"><view class="header-mendian"><view data-event-opts="{{[['tap',[['showMendianModal',['$event']]]]]}}" class="flex-y-center" bindtap="__e"><view class="header-address">{{mendian.name?mendian.name:'全部门店'}}</view><image class="header-more" src="{{pre_url+'/static/img/location/right-dark.png'}}"></image></view></view><block s-if="{{mendian.address}}"><view class="flex-bt header-mendian-address"><view class="f1 flex-y-center">{{mendian.address}}</view><block s-if="{{mendian.distance}}"><view class="f2">{{"距离您"+mendian.distance+"km"}}</view></block></view></block></view></block></block><block s-if="{{isdiy}}"><block><view style="{{('display:flex;min-height: 100vh;flex-direction: column;background-color:'+pageinfo.bgcolor)}}"><view class="container"><dp vue-id="173a2480-1" pagecontent="{{pagecontent}}" menuindex="{{menuindex}}" latitude="{{latitude}}" longitude="{{longitude}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" bind:getdata="__e"></dp></view></view><dp-guanggao vue-id="173a2480-2" guanggaopic="{{guanggaopic}}" guanggaourl="{{guanggaourl}}" guanggaotype="{{guanggaotype}}" param="{{guanggaoparam}}"></dp-guanggao></block></block><block s-else><block><block s-if="{{isload}}"><view class="container nodiydata"><block s-if="{{pics.length>0}}"><swiper class="swiper" indicator-dots="{{pics[1]?true:false}}" autoplay="{{true}}" interval="{{5000}}" indicator-color="#dcdcdc" indicator-active-color="#fff"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><block><swiper-item class="swiper-item"><image class="image" src="{{item}}" mode="widthFix"></image></swiper-item></block></block></swiper></block><block s-if="{{showShare}}"><view style="position:absolute;top:30rpx;right:30rpx;z-index:99;" data-