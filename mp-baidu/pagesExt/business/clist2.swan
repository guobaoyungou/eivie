<view class="container"><block s-if="{{isload}}"><block><view class="ind_business"><view class="ind_buslist" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view data-id="{{item.id}}" data-event-opts="{{[['tap',[['toBack',['$event']]]]]}}" bindtap="__e"><view class="ind_busbox flex"><view class="flex1"><view class="bus_title flex">{{''+item.name+''}}</view><view class="bus_address flex"><view class="flex1">{{item.address}}</view></view><view class="bus_time flex flex-wp"><text>营业时间：</text><block s-if="{{item.start_hours}}"><text>{{item.start_hours+" - "+item.end_hours}}</text></block><block s-if="{{item.start_hours2!='00:00'&&item.start_hours2!='00:00'}}"><text style="margin-left:10rpx;">{{item.end_hours2+" - "+item.end_hours2}}</text></block><block s-if="{{item.start_hours3!='00:00'&&item.start_hours3!='00:00'}}"><text style="margin-left:10rpx;">{{item.start_hours3+" - "+item.end_hours3}}</text></block></view></view><view class="data flex-xy-center"><view><view class="data_title">去下单</view><view class="data_text">{{"距离"+item.juli}}</view><view class="data_tag flex-xy-center"><view class="flex"><block s-if="{{item.tel}}"><view class="data_item flex-xy-center" data-tel="{{item.tel}}" data-event-opts="{{[['tap',[['calltel',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/b_tel.png'}}" mode></image></view></block><view class="data_item flex-xy-center" data-name="{{item.name}}" data-address="{{item.address}}" data-longitude="{{item.longitude}}" data-latitude="{{item.latitude}}" data-event-opts="{{[['tap',[['showMap',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/b_addr.png'}}" mode></image></view></view></view></view></view></view></view></block></block><block s-if="{{nomore}}"><nomore vue-id="2d2e979b-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="2d2e979b-2"></nodata></block></view></view></block></block><block s-if="{{loading}}"><loading vue-id="2d2e979b-3"></loading></block><dp-tabbar vue-id="2d2e979b-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="2d2e979b-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="2d2e979b-6"></wxxieyi></view>