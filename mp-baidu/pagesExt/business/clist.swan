<view class="container"><block s-if="{{isload}}"><block><view class="search-container" data-url="/pagesExt/business/blist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="search-box"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><view class="search-text">搜索感兴趣的商家</view></view></view><view class="content-container"><view class="nav_left"><scroll-view style="height:100%;" scroll-y="{{true}}"><view class="{{['nav_left_items '+(curIndex==-1?'active':'')]}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>全部</view><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['nav_left_items '+(curIndex==index?'active':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.name}}</view></block></block></scroll-view></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/pagesExt/business/index?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="logo" src="{{item.$orig.logo}}"></image><view class="detail"><view class="f1">{{item.$orig.name}}</view><block s-if="{{show_business_tel==1&&item.$orig.tel}}"><view class="f2"><block s-if="{{item.$orig.tel}}"><block>电话：<text style="font-weight:bold;">{{item.$orig.tel}}</text></block></block></view></block><view class="f4">地址：<text style="font-weight:bold;">{{item.$orig.address}}</text></view><block s-if="{{item.$orig.activity_time&&item.$orig.activity_time_status==1}}"><view class="f4" style="{{'color:'+(item.m2)+';'}}">活动时间：<text class="x1">{{item.$orig.activity_time}}</text></view></block><view class="ratio-list flex"><block s-if="{{item.$orig.rate_back&&item.$orig.rate_back>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m3)+';'+('border-color:'+(item.m4)+';')}}"><view class="label" style="{{'background-color:'+(item.m5)+';'}}">返</view><view class="t1">{{item.$orig.rate_back+"%"}}</view></view></block><block s-if="{{item.$orig.scoredkmaxpercent&&item.$orig.scoredkmaxpercent>0}}"><view class="ratio-label flex-y-center" style="{{'color:'+(item.m6)+';'+('border-color:'+(item.m7)+';')}}"><view class="label" style="{{'background-color:'+(item.m8)+';'}}">积</view><view class="t1">{{item.$orig.scoredkmaxpercent+"%"}}</view></view></block></view><block s-if="{{item.$orig.juli}}"><view class="f3">{{"距离："+item.$orig.juli}}</view></block><block s-if="{{item.$orig.show_maidan==1}}"><view class="f1" style="justify-content:flex-end;display:flex;"><view class="tomaidan" style="{{'background:'+('linear-gradient(90deg,'+item.m9+' 0%, rgba('+item.m10+',0.8) 100%)')+';'}}" data-url="{{'/pagesB/maidan/pay?bid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">在线买单</view></view></block></view></view></block><block s-if="{{nomore}}"><nomore vue-id="1a225b31-1" text="没有更多商家了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="1a225b31-2" text="暂无相关商家"></nodata></block></scroll-view></view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="1a225b31-3" loadstyle="left:62.5%"></loading></block><dp-tabbar vue-id="1a225b31-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="1a225b31-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="1a225b31-6"></wxxieyi></view>