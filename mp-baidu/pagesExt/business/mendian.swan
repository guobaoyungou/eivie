<view class="container"><block s-if="{{isload}}"><block><view class="content"><map class="{{[isshowlist?'map-class-list':'map-class']}}" id="maps" latitude="{{latitude}}" longitude="{{longitude}}" markers="{{markers}}" scale="{{mapScale}}" enable-zoom="true" enable-satellite="{{maptype}}"></map></view><view class="content1"><view data-event-opts="{{[['tap',[['mendianToggle',['$event']]]]]}}" class="toggle" bindtap="__e"><image class="{{[isshowlist?'toggle-icon':'toggle-icon up']}}" src="{{pre_url+'/static/img/arrowdown.png'}}"></image></view><block s-if="{{isshowlist}}"><view class="mendian-box"><block s-for="mendianlist trackBy index" s-for-item="mendian" s-for-index="index"><block><view class="mendian-info"><view class="b1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{mendian.pic}}"></image></view><view class="b2"><view class="t1" data-url="{{'/pages/shop/mendian?id='+mendian.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{mendian.name}}</view><view class="t2 flex-y-center"><view class="mendian-distance">{{mendian.distance}}</view><block s-if="{{mendian.address||mendian.area}}"><block><view class="line"></view><view class="mendian-address">{{''+(mendian.address?mendian.address:mendian.area)}}</view></block></block></view></view><view class="b3"><image data-address="{{mendian.address}}" data-longitude="{{mendian.longitude}}" data-latitude="{{mendian.latitude}}" src="{{pre_url+'/static/img/location/daohang.png'}}" data-event-opts="{{[['tap',[['toMendian',['$event']]]]]}}" bindtap="__e"></image></view></view></block></block></view></block></view></block></block><block s-if="{{loading}}"><loading vue-id="71c0e80a-1"></loading></block><dp-tabbar vue-id="71c0e80a-2" opt="{{opt}}" index="3"></dp-tabbar><popmsg class="vue-ref" vue-id="71c0e80a-3" data-ref="popmsg"></popmsg><wxxieyi vue-id="71c0e80a-4"></wxxieyi></view>