<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="a362be4e-1" itemdata="{{['全部','已付款','已完成']}}" itemst="{{['all','1','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'workerorderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><block s-if="{{item.bid!=0}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block s-else><view>{{"订单号："+item.ordernum}}</view></block><view class="flex1"></view><block s-if="{{item.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.status==1&&item.refund_status==0}}"><text class="st1">已付款</text></block><block s-if="{{item.status==1&&item.refund_status==1}}"><text class="st1">退款审核中</text></block><block s-if="{{item.status==3}}"><text class="st4">已完成</text></block><block s-if="{{item.status==4}}"><text class="st4">已关闭</text></block></view><view class="content" style="border-bottom:none;"><view data-url="{{'product?id='+item.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><text class="t2">{{"顾客："+item.member.nickname}}</text><block s-if="{{item.yy_time.length>4}}"><text class="t2">{{"开课时间："+item.yy_time}}</text></block><block s-if="{{item.kechengnum}}"><text class="t2">{{"课程数量："+item.kechengnum}}</text></block><block s-if="{{item.kechengnum}}"><text class="t2">{{"剩余课程："+item.surpluskechengnum}}</text></block><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.totalprice}}</text></view></view></view><block s-if="{{item.refund_status!=0}}"><view class="bottom"><block s-if="{{item.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.refund_money}}</text></block><block s-if="{{item.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><view class="bottom flex-y-center"><image style="width:40rpx;height:40rpx;border-radius:50%;margin-right:10rpx;" src="{{item.member.headimg}}"></image><text style="font-weight:bold;color:#333;margin-right:8rpx;">{{item.member.nickname}}</text>{{"(ID:"+item.mid+')'}}</view><view class="op"><block s-if="{{item.yuyue_model==2}}"><view class="btn2" data-url="{{'/pagesB/yueke/workerstudyrecord?orderid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">学习记录</view></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="a362be4e-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="a362be4e-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="a362be4e-4"></loading></block><dp-tabbar vue-id="a362be4e-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="a362be4e-6" data-ref="popmsg"></popmsg></view>