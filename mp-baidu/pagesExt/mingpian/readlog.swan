<view class="container"><block s-if="{{isload}}"><block><view class="recordList"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="ListItem"><image class="firendAvatar" src="{{item.$orig.headimg}}"></image><view class="info"><text class="styleText">{{item.$orig.nickname}}</text><text>{{"于 "+item.m0+" 查看了我的"+mingpiantext}}</text><block s-if="{{item.$orig.applysee}}"><view style="display:flex;justify-content:space-between;align-items:center;margin-top:20rpx;"><view>申请查看更多内容</view><view style="display:flex;width:230rpx;justify-content:space-between;align-items:center;"><block s-if="{{item.$orig.applysee==-1}}"><view>已驳回</view></block><block s-if="{{item.$orig.applysee==2}}"><view style="color:green;">已通过</view></block><block s-if="{{item.$orig.applysee==1}}"><view class="checkaddfields" data-url="{{'/pagesB/mingpian/checkapplylog?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去审核</view></block><block s-if="{{item.$orig.applysee==2}}"><view class="checkaddfields" data-url="{{'/pagesB/mingpian/checkapplylog?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">去编辑</view></block></view></view></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="61b64bee-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="61b64bee-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="61b64bee-3"></loading></block><dp-tabbar vue-id="61b64bee-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="61b64bee-5" data-ref="popmsg"></popmsg></view>