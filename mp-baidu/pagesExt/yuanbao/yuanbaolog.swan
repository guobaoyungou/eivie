<view class="container"><block s-if="{{isload}}"><block><view class="myyuanbao" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{myyuanbao}}<block s-if="{{yuanbaoTransfer}}"><view class="btn-mini" data-url="/pagesExt/yuanbao/yuanbaoTransfer" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账</view></block></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.yuanbao>0}}"><block><text class="t1">{{"+"+item.yuanbao}}</text></block></block><block s-else><block><text class="t2">{{item.yuanbao}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="d8e50a44-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="d8e50a44-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="d8e50a44-3"></loading></block><dp-tabbar vue-id="d8e50a44-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="d8e50a44-5" data-ref="popmsg"></popmsg></view>