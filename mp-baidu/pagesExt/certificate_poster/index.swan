<view class="container"><block s-if="{{isload}}"><block><block s-if="{{set.header_text}}"><view><parse vue-id="7ee499aa-1" content="{{set.header_text}}"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><block s-if="{{set&&set.query_type=='id_card'}}"><view class="title">{{"请输入身份证号查询"+certificate_text}}</view></block><block s-if="{{set&&set.query_type=='tel'}}"><view class="title">{{"请输入手机号查询"+certificate_text}}</view></block><view class="inputdiv"><block s-if="{{set&&set.query_type=='id_card'}}"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入您的身份证号" value="{{tel}}"/></block><block s-if="{{set&&set.query_type=='tel'}}"><input type="text" name="tel2" placeholder-style="color:#666;" placeholder="请输入您的手机号" value="{{tel2}}"/></block></view><button class="btn" form-type="submit">查询</button></form><block s-if="{{set.footer_text}}"><view><parse vue-id="7ee499aa-2" content="{{set.footer_text}}"></parse></view></block></block></block><block s-if="{{loading}}"><loading vue-id="7ee499aa-3"></loading></block><dp-tabbar vue-id="7ee499aa-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7ee499aa-5" data-ref="popmsg"></popmsg></view>