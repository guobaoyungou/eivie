<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'detail?tel='+item.tel+'&posterid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"姓名："+item.realname}}</text><text class="t2">{{"身份证号："+item.tel}}</text></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="e7d06a60-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="e7d06a60-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="e7d06a60-3"></loading></block><dp-tabbar vue-id="e7d06a60-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="e7d06a60-5" data-ref="popmsg"></popmsg></view>