<view class="container"><block s-if="{{isload}}"><block><view style="padding-top:50rpx;padding-left:20rpx;padding-right:20rpx;display:flex;align-items:center;"><image class="sjew-img" src="{{poster}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><block s-if="{{info.explain}}"><view style="padding:40rpx 20rpx;"><parse vue-id="7940c260-1" content="{{info.explain}}"></parse></view></block><view class="sjew-he"></view><view class="{{['sjew-bottom',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view class="sjew-bottom-content"><view data-event-opts="{{[['tap',[['saveImage',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m0)+';'}}" bindtap="__e">保存证书</view><view class="sjew-bot-a2" style="{{'background:'+($root.m1)+';'}}" data-url="{{poster}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e">{{"查看"+certificate_text}}</view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="7940c260-2"></loading></block><dp-tabbar vue-id="7940c260-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="7940c260-4" data-ref="popmsg"></popmsg><wxxieyi vue-id="7940c260-5"></wxxieyi></view>