<view style="width:100%;height:100%;background-color:#fff;"><block s-if="{{isload}}"><block><view style="width:700rpx;margin:0 auto;"><view class="topsearch flex-y-center" data-url="list?cpid=0&displaytype=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的帖子" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><block s-if="{{clist&&clist.length>0}}"><view class="list_view"><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list_content" style="{{(index%2==0?'margin-right:40rpx':'')}}" data-url="{{'list?cpid='+item.id+'&displaytype='+item.display_type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="width:330rpx;height:330rpx;border-radius:8rpx;overflow:hidden;"><image style="width:330rpx;height:330rpx;" src="{{item.pic}}" mode="widthFix"></image></view><view style="line-height:60rpx;font-size:28rpx;">{{item.name}}</view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="32f0e55e-1"></nodata></block></view></block><block s-if="{{nomore}}"><nomore vue-id="32f0e55e-2"></nomore></block></view></block></block><block s-if="{{loading}}"><loading vue-id="32f0e55e-3"></loading></block><dp-tabbar vue-id="32f0e55e-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="32f0e55e-5" data-ref="popmsg"></popmsg></view>