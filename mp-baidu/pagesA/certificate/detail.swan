<view><block s-if="{{isload}}"><block><view class="form-box"><view class="form-item"><view class="f1">姓名</view><view class="f2"><input type="text" name="name" disabled="true" value="{{info.name}}"/></view></view><view class="form-item"><view class="f1">联系方式</view><view class="f2"><input type="text" name="tel" disabled="true" value="{{info.tel}}"/></view></view><view class="form-item"><view class="f1">毕业院校</view><view class="f2"><input type="text" name="school" disabled="true" value="{{info.school}}"/></view></view><view class="form-item"><view class="f1">学历</view><view class="f2"><input type="text" name="educationname" disabled="true" value="{{info.educationname}}"/></view></view><view class="form-item"><view class="f1">证书</view><view class="f2"><input type="text" name="cid" disabled="true" value="{{info.cname}}"/></view></view><view class="form-item"><view class="f1">职业</view><view class="f2"><input type="text" name="job_name" disabled="true" value="{{info.job_name}}"/></view></view><block s-if="{{opt.ismy==1}}"><view class="form-item"><view class="f1">审核状态</view><view class="f2"><input style="{{(info.ischecked==1?'color:green;':info.ischecked==2?'color:red;width:60%':'')}}" type="text" name="checkstatus" disabled="true" value="{{info.checkstatus}}"/><block s-if="{{info.ischecked==2}}"><button class="edit-btn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" data-url="{{'edit?id='+info.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">重新编辑</button></block></view></view></block><block s-if="{{opt.ismy==1&&info.ischecked==2}}"><view class="form-item"><view class="f1">驳回理由</view><view class="f2"><input type="text" name="check_reason" disabled="true" value="{{info.check_reason}}"/></view></view></block></view><block s-if="{{info.certificate_pic&&info.certificate_pic.length>0}}"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">证书图片</view><view class="f2" style="flex-wrap:wrap;"><block s-for="info.certificate_pic trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="certificate_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></view></block><block s-if="{{info.idcard_pic_front&&info.idcard_pic_front.length>0}}"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">身份证正面图片</view><view class="f2"><block s-for="info.idcard_pic_front trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="certificate_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></view></block><block s-if="{{info.idcard_pic_back&&info.idcard_pic_back.length>0}}"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">身份证反面图片</view><view class="f2"><block s-for="info.idcard_pic_back trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="certificate_pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view></view></view></block><block s-if="{{!opt.ismy}}"><view><block s-if="{{kfurl!='contact::'}}"><view class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')}}" data-url="{{kfurl}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="t1">立即咨询</view></view></block><block s-else><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m4+' 0%,rgba('+$root.m5+',0.8) 100%)')}}" open-type="contact" show-message-card="true">立即咨询</button></block></view></block><view style="height:50rpx;"></view></block></block></view>