<view><block s-if="{{isload}}"><block><view class="search-view flex-xy-center"><view class="input-view flex-aw"><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time1}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view><view>--</view><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time2}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view></view></view><view class="content-view flex-col"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="options-view flex-bt"><view class="info-view flex-col"><view class="title-text">门店营业额</view><view class="inventory-text flex-bt"><view class="price">{{item.yeji_total}}</view><view class="price">{{"补贴："+item.butie_yeji}}</view><view class="time">{{item.jiesuan_time}}</view></view></view></view></block><block s-if="{{nomore}}"><nomore vue-id="dfb0d148-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="dfb0d148-2"></nodata></block></view></block></block></view>