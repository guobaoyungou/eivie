<view class="container"><block s-if="{{isload}}"><view><view class="bg-view"></view><view class="content-view flex-col"><view class="info-view"><view class="image-view"><image src="{{member.headimg}}"></image></view><view class="info-view-text flex-col"><view class="title-text">{{member.nickname}}</view><view class="inventory-text">{{member.tel}}</view></view></view><view class="content-view-data flex-col"><view class="title-text">门店列表</view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="options-view flex-bt" data-url="{{'/pagesA/businessFenxiao/mendian?bid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="image-view"><image src="{{item.logo}}"></image></view><view class="info-view-data flex-col"><view class="title-text">{{item.name}}</view><view class="inventory-text">{{item.stage}}</view></view></view></block></view></view></view></block><block s-if="{{nodata}}"><nodata vue-id="f2601ad4-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="f2601ad4-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="f2601ad4-3"></loading></block></view>