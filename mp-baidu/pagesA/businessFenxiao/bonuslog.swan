<view class="container"><block s-if="{{isload}}"><block><view class="search-view flex-xy-center"><view class="input-view flex-aw"><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time1}}" data-event-opts="{{[['change',[['bindStartTime1Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time1}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view><view>--</view><view class="picker-class flex-x-center"><image src="{{pre_url+'/static/img/timeicon.png'}}"></image><picker mode="date" value="{{start_time2}}" data-event-opts="{{[['change',[['bindStartTime2Change',['$event']]]]]}}" bindchange="__e"><view class="picker">{{start_time2}}</view></picker><image src="{{pre_url+'/static/img/jiantou.png'}}"></image></view></view></view><block s-if="{{datalist&&datalist.length>0}}"><block><view class="content content-view flex-col"><block><view class="item"><view class="f2"><view class="t1"><view class="item2"><text class="x1">{{"收入合计："+total}}</text></view></view></view></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text>{{item.$orig.name}}</text></view><view class="f2"><view class="t1"><view class="item2"><text class="x1">{{item.m0}}</text></view></view><view class="t2"><text class="x1">{{"+"+item.$orig.bonus}}</text></view></view></view></block></block></view></block></block><view style="width:100%;height:20rpx;"></view></block></block><block s-if="{{nodata}}"><nodata vue-id="1777e13d-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="1777e13d-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="1777e13d-3"></loading></block><dp-tabbar vue-id="1777e13d-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1777e13d-5" data-ref="popmsg"></popmsg></view>