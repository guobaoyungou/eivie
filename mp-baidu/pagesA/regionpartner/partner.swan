<view class="container"><block s-if="{{isload}}"><block><view class="content"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/pagesA/regionpartner/fhlog?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{"申请区域："+item.province+"-"+item.city+"-"+item.district}}</text><text class="t2">{{"申请时间："+item.createtime}}</text><text class="t2">{{"已分红："+item.bonus}}</text><text class="t2">{{"剩余分红："+item.remain}}</text><block s-if="{{item.paidui>0}}"><text class="t2">{{"当前排队人数："+item.paidui}}</text></block></view><view class="f2"><block s-if="{{item.bonus_status>0}}"><text class="t1">已完成</text></block><block s-if="{{item.bonus_status==0}}"><text class="t2">未完成</text></block></view></view></block></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="083c48ee-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="083c48ee-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="083c48ee-3"></loading></block><dp-tabbar vue-id="083c48ee-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="083c48ee-5" data-ref="popmsg"></popmsg></view>