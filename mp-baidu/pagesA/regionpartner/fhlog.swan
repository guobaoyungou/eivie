<view class="container"><block s-if="{{isload}}"><block><view class="content"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t2">{{"区域："+item.region}}</text></view><view class="f2"><block s-if="{{item.commission>0}}"><text class="t1">{{"+"+item.commission}}</text></block><block s-else><text class="t2">{{item.commission}}</text></block></view></view></block></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="28396c74-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="28396c74-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="28396c74-3"></loading></block><dp-tabbar vue-id="28396c74-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="28396c74-5" data-ref="popmsg"></popmsg></view>