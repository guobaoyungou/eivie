<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="form"><view class="form-item"><text class="label">姓 名</text><input class="input" type="text" placeholder="请输入姓名" placeholder-style="font-size:28rpx;color:#BBBBBB" name="name" value="{{name}}"/></view><view class="form-item"><text class="label">店铺名称</text><input class="input" type="text" placeholder="请输入公司或单位名称" placeholder-style="font-size:28rpx;color:#BBBBBB" name="company" value="{{company}}"/></view><view class="form-item"><text class="label">手机号</text><input class="input" type="number" placeholder="请输入手机号" placeholder-style="font-size:28rpx;color:#BBBBBB" name="tel" value="{{tel}}"/></view><view class="form-item"><text class="label flex1">申请区域</text><uni-data-picker vue-id="2476ebc8-1" localdata="{{items}}" border="{{false}}" placeholder="{{regiondata||'请选择区域'}}" data-event-opts="{{[['^change',[['regionchange']]]]}}" bind:change="__e"></uni-data-picker></view><view class="form-item"><text class="label">申请费用</text><input class="input" type="text" placeholder-style="font-size:28rpx;color:#BBBBBB" disabled="true" value="{{set.apply_money||0}}"/></view><view class="form-item"><text class="label flex1">当前分红人数</text><input class="input" type="text" placeholder-style="font-size:28rpx;color:#BBBBBB" disabled="true" value="{{set.count||0}}"/></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">保 存</button></form></block></block><block s-if="{{loading}}"><loading vue-id="2476ebc8-2"></loading></block><dp-tabbar vue-id="2476ebc8-3" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="2476ebc8-4" data-ref="popmsg"></popmsg></view>