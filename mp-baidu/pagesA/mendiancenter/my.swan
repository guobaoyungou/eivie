<view><block s-if="{{isload}}"><block><view class="banner" style="{{('background:rgba('+$root.m0+',1);color:#FFF')}}"><image src="{{mendian.headimg}}" background-size="cover"></image><view class="info"><view class="nickname">{{mendian.name+''}}<block s-if="{{changemendian}}"><view class="changemendian" data-url="/pagesC/mendian/changemendian" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text style="margin-left:20rpx;font-size:26rpx;">切换</text><text class="iconfont iconjiantou" style="font-size:40rpx;"></text></view></block></view><text class="t1">{{"ID:"+mendian.id}}</text><text class="t1">{{"绑定社区："+mendian.xqname}}</text><block s-if="{{sets.showLevel_status==1}}"><text class="t1">{{$root.m1+"等级："+mendian.levelname}}</text></block></view><view class="sets"><image src="{{pre_url+'/static/img/set.png'}}" data-url="set" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="setup-view" bindtap="__e"><image src="{{pre_url+'/static/img/admin/saoyisao.png'}}"></image></view></view></view><view class="contentdata"><view class="title"><text class="t1">{{$root.m2+"概况"}}</text><view data-event-opts="{{[['tap',[['getqrcode',['$event']]]]]}}" class="t2" bindtap="__e">推广二维码<text class="iconfont iconjiantou" style="color:#0F89F0;font-weight:normal;"></text></view></view><view class="custom_field"><block s-if="{{sets.frontincome_status}}"><view class="item" data-url="jdorderlist?st=3" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">{{mendian.totalmoney}}</text><text class="t2">总收入(元)</text></view></block><view class="item"><text class="t1">{{mendian.totalnum}}</text><text class="t2">总订单</text></view><view class="item"><text class="t1">{{mendian.membernum}}</text><text class="t2">会员数</text></view></view></view><view class="contentdata" style="margin-top:0;"><view class="title"><text class="t1">今日详情</text></view><view class="custom_field"><view class="item" data-url="jdorderlist?st=3" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="t1">{{mendian.daytotalnum}}</text><text class="t2">订单总数(笔)</text></view><view class="item"><text class="t1">{{mendian.paymembernum}}</text><text class="t2">付款人数</text></view><view class="item"><text class="t1">{{mendian.daypaymoney}}</text><text class="t2">销售额</text></view><view class="item"><text class="t1">{{mendian.daymembercount}}</text><text class="t2">新增会员数</text></view><view class="item"><text class="t1">{{mendian.count4}}</text><text class="t2">售后订单(笔)</text></view><block s-if="{{sets.frontincome_status}}"><view class="item"><text class="t1">{{mendian.ygmoney}}</text><text class="t2">预估收入</text></view></block></view></view><view class="mall-orders flex-col width"><view class="order-title flex-bt"><view class="title-text flex-y-center"><image class="left-img" src="{{pre_url+'/static/img/admin/titletips.png'}}"></image>{{$root.m3+"订单"}}</view><view class="all-text flex-y-center" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">全部订单<image class="right-img" src="{{pre_url+'/static/img/admin/jiantou.png'}}"></image></view></view><view class="order-list flex-bt"><view class="option-order flex-col" data-url="orderlist?st=0" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="num-text" style="{{'color:'+($root.m4)+';'}}">{{order.count0}}</text><text class="title-text">待付款</text></view><view class="option-order flex-col" data-url="orderlist?st=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="num-text" style="{{'color:'+($root.m5)+';'}}">{{order.count1}}</text><text class="title-text">待发货</text></view><view class="option-order flex-col" data-url="orderlist?st=2" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="num-text" style="{{'color:'+($root.m6)+';'}}">{{order.count2}}</text><text class="title-text">待收货</text></view><view class="option-order flex-col" data-url="shopRefundOrder" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="num-text" style="{{'color:'+($root.m7)+';'}}">{{order.count4}}</text><text class="title-text">退款/售后</text></view><view class="option-order flex-col" data-url="orderlist?st=3" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text class="num-text" style="{{'color:'+($root.m8)+';'}}">{{order.count3}}</text><text class="title-text">已完成</text></view></view></view><view class="listcontent"><block s-if="{{sets.frontincome_status}}"><view class="list"><view class="item" data-url="withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image src="{{pre_url+'/static/img/peisong/ico-qianbao.png'}}"></image></view><view class="f2">我的钱包</view><text class="f3">{{"可用佣金："+mendian.money}}</text><image class="f4" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><block s-if="{{sets.frontincome_status}}"><view class="list"><view class="item" data-url="moneylog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image src="{{pre_url+'/static/img/peisong/ico-zhangdan.png'}}"></image></view><view class="f2">结算记录</view><text class="f3"></text><image class="f4" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><view class="list"><view class="item" data-url="/pagesB/mendianup/fahuolog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image src="{{pre_url+'/static/img/peisong/ico-zhangdan.png'}}"></image></view><view class="f2">拣货单</view><text class="f3"></text><image class="f4" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><view class="list"><view class="item" data-url="/pagesB/mendianup/hexiaolog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image src="{{pre_url+'/static/img/peisong/ico-zhangdan.png'}}"></image></view><view class="f2">核销记录</view><text class="f3"></text><image class="f4" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view><block s-if="{{sets.addhxuser_status==1}}"><view class="list"><view class="item" data-url="hexiaouser" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><image src="{{pre_url+'/static/img/peisong/ico-zhangdan.png'}}"></image></view><view class="f2">核销员管理</view><text class="f3"></text><image class="f4" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></view><view style="height:100rpx;"></view><block s-if="{{showqrcode}}"><view data-event-opts="{{[['tap',[['showqrcodes',['$event']]]]]}}" class="modal" bindtap="__e"><view class="modalcontent"><view class="title">推广二维码</view><view class="code"><image data-url="{{url}}" src="{{url}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><view data-event-opts="{{[['tap',[['saveimage',['$0'],['url']]]]]}}" class="bottom" catchtap="__e">保存图片</view></view></view></block></block></block><wxxieyi vue-id="4cdb6485-1"></wxxieyi></view>