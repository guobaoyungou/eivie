<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="apply_box"><view class="apply_item"><view>姓名<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="name" placeholder="请填写姓名"/></view></view><view class="apply_item"><view>联系电话<text style="color:red;">*</text></view><view class="flex-y-center"><input type="text" name="tel" placeholder="请填写手机号码"/></view></view></view><view style="padding:30rpx 0;"><button class="set-btn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button></view></form></block></block><block s-if="{{loading}}"><loading vue-id="7d0d23f6-1"></loading></block><dp-tabbar vue-id="7d0d23f6-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7d0d23f6-3" data-ref="popmsg"></popmsg><wxxieyi vue-id="7d0d23f6-4"></wxxieyi></view>