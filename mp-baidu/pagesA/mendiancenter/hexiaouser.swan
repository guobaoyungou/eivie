<view><block s-if="{{isload}}"><block><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"核销员列表（共"+count+"人）"}}</text></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><image src="{{item.headimg}}"></image><view class="t2">{{''+item.nickname+''}}</view></view><view class="f2">已核销订单:<text style="color:red;">{{item.hxnum}}</text></view><view class="f3 btn2" data-id="{{item.id}}" data-event-opts="{{[['tap',[['delOrder',['$event']]]]]}}" bindtap="__e">删除</view></view></block></block></view></block><block s-if="{{nomore}}"><nomore vue-id="2f96cdea-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="2f96cdea-2"></nodata></block><view class="btn-add" style="{{'background:'+($root.m0)+';'}}" data-url="{{'addhexiao?mdid='+mdid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">添加核销员</view></block></block><popmsg class="vue-ref" vue-id="2f96cdea-3" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="2f96cdea-4"></loading></block></view>