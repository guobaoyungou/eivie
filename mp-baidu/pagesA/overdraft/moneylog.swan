<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="fbd63846-1" itemdata="{{['消费明细','还款记录']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-if="{{st==0}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后余额: "+item.after}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block s-else><text class="t2">{{item.money}}</text></block></view></view></block></block></block><block s-if="{{st==1}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{"还款金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block s-if="{{item.status==0}}"><text class="t1">还款失败</text></block><block s-if="{{item.status==1}}"><text class="t2">还款成功</text></block></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="fbd63846-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="fbd63846-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="fbd63846-4"></loading></block><dp-tabbar vue-id="fbd63846-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="fbd63846-6" data-ref="popmsg"></popmsg></view>