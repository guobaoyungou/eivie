<view><block s-if="{{isload}}"><block><view class="container"><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'detail?id='+item.id+'&bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic" style="margin-bottom:20rpx;border-radius:8rpx;overflow:hidden;"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3" style="position:relative;bottom:0;overflow:hidden;display:block;"><view class="t1" style="{{'color:'+($root.m0)+';'+('font-size:'+('28rpx')+';')}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</view><view style="display:flex;"><view class="t1">已售<block s-if="{{item.sales<100000}}"><text style="font-size:28rpx;color:#f40;padding:0 2rpx;">{{item.sales}}</text></block><block s-else><text style="font-size:28rpx;color:#f40;padding:0 2rpx;">10万+</text></block>件</view><view style="flex:1;"></view><view class="t2" style="{{'background-color:'+($root.m1)+';'+('border-color:'+($root.m2)+';')+('color:'+($root.m3)+';')+('float:'+('right')+';')}}"><text class="x2" style="{{'background-color:'+($root.m4)+';'}}">去购买</text></view></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="f96b0e92-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="f96b0e92-2"></nodata></block></view></block></block><block s-if="{{loading}}"><loading vue-id="f96b0e92-3"></loading></block><dp-tabbar vue-id="f96b0e92-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="f96b0e92-5" data-ref="popmsg"></popmsg></view>