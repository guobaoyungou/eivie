<view class="container"><block s-if="{{isload}}"><block><view id="scroll_view_tab0"><view class="swiper-container"><swiper class="swiper" style="{{'height:'+(swiperHeight+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" current="{{current}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" bindchange="__e"><block s-if="{{product.pic}}"><block><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{product.pic}}" mode="widthFix" data-event-opts="{{[['load',[['loadImg',['$event']]]]]}}" bindload="__e"></image></view></swiper-item></block></block></swiper><view class="imageCount">{{current+1}}</view></view><view class="collage_title"><view class="f1"><view class="t1"><view class="x1">￥</view><view class="x2">{{product.sell_price}}</view></view></view></view><view class="header"><view class="title"><view class="lef"><text>{{product.name}}</text></view><view class="t2" style="font-size:26rpx;color:#777777;"><text>{{"已销售"+product.sales}}</text></view></view></view></view><block s-if="{{pagecontent}}"><view id="scroll_view_tab2"><view class="detail_title"><view class="t1"></view><view class="t2"></view><view class="t0">礼包描述</view><view class="t2"></view><view class="t1"></view></view><view class="detail"><parse vue-id="61f34b64-1" content="{{pagecontent}}"></parse></view></view></block><view class="notabbarbot" style="width:100%;height:110rpx;box-sizing:content-box;"></view><view class="{{['bottombar','flex-row',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m0)+';'+('margin:'+('0 auto')+';')}}" bindtap="__e"><text>立即购买</text></view></view><block s-if="{{showposter}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="61f34b64-2"></loading></block><dp-tabbar vue-id="61f34b64-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="61f34b64-4" data-ref="popmsg"></popmsg></view>