<view><block s-if="{{isload}}"><block><view class="container"><block s-if="{{pics.length>0}}"><swiper class="swiper" indicator-dots="{{pics[1]?true:false}}" autoplay="true" interval="{{5000}}"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><block><swiper-item class="swiper-item"><image src="{{item}}" mode="widthFix"></image></swiper-item></block></block></swiper></block><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'product?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2"><view class="p2-1"><text class="t1" style="{{'color:'+($root.m0)+';'}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><block s-if="{{item.market_price*1>item.sell_price*1}}"><text class="t2">{{"￥"+item.market_price}}</text></block></view></view><view class="p3"><view class="t1">礼包数量<text style="font-size:32rpx;color:#f40;padding:0 2rpx;">{{item.perlimit}}</text></view><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">立即购买</text></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="3e319252-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="3e319252-2"></nodata></block></view><button class="covermy" data-url="orderlist" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的套餐</button></block></block><block s-if="{{loading}}"><loading vue-id="3e319252-3"></loading></block><dp-tabbar vue-id="3e319252-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="3e319252-5" data-ref="popmsg"></popmsg></view>