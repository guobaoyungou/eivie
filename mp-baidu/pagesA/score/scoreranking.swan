<block s-if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank2.png'}}" mode="widthFix"></image><view class="content"><view class="top"><view class="t1">{{"我的"+$root.m1+"："+totalscore}}</view></view><view class="tab"><view class="t1">排名</view><view class="t2">姓名</view><view class="t3" style="{{'color:'+($root.m2)+';'}}">{{"累计"+$root.m3}}</view></view><view class="itembox"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><block s-if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block s-else><view class="t1">{{index+1}}</view></block><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view><text class="t3">{{''+item.sumscore}}</text></view></block></block></view></view></view><block s-if="{{nodata}}"><nodata vue-id="0d0fbc02-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="0d0fbc02-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="0d0fbc02-3"></loading></block><dp-tabbar vue-id="0d0fbc02-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0d0fbc02-5" data-ref="popmsg"></popmsg></view></block></block>