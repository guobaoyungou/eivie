<view><block s-if="{{isload}}"><block><view class="detail"><parse vue-id="00029840-1" content="{{detail.content}}"></parse></view><view class="itembox"><view class="title">工单列表</view><block s-if="{{detail.pid>0||detail.pid==0&&detail.id==id&&ispcate==1}}"><block><block s-for="datalist" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'/pagesB/workorder/index?cateid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{item.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></block><block s-else><block><block s-for="datalist" s-for-item="item" s-for-index="index2"><view class="category"><view class="cate"><view class="img" data-id="{{item.id}}" data-index="{{index2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" bindtap="__e"><image src="{{pre_url+'/static/img/workorder/'+(curIndex2==index2?'down':'up')+'.png?v1'}}" mode="widthFix"></image></view><view>{{item.name}}</view></view><block s-for="item.list" s-for-item="subitem" s-for-index="subindex"><block s-if="{{curIndex2==index2}}"><view class="item" style="padding-left:50rpx;margin-top:10rpx;" data-url="{{'/pagesB/workorder/index?cateid='+subitem.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{subitem.name}}</text><text class="iconfont iconjiantou" style="color:#999;font-weight:normal;"></text></view></block></block></view></block></block></block></view></block></block><block s-if="{{loading}}"><loading vue-id="00029840-2"></loading></block><dp-tabbar vue-id="00029840-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="00029840-4" data-ref="popmsg"></popmsg></view>