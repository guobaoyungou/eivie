<block s-if="{{isload}}"><block><view class="container" style="{{'background-color:'+($root.m0)+';'}}"><view class="contentbox"><image src="{{pre_url+'/static/imgsrc/rank.png'}}" mode="widthFix"></image><view class="content"><view class="top"><view class="t1">{{"数据统计日期： "+region_ctime}}</view></view><view class="tabsort"><block s-if="{{$root.m1}}"><view class="{{['t1 '+(1==sorttype?'on':'')]}}" style="width:30%;" data-sorttype="{{1}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" bindtap="__e">订单金额<block s-if="{{1==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m2)}}"></view></block></view></block><block s-if="{{$root.m3}}"><view class="{{['t1 '+(2==sorttype?'on':'')]}}" style="width:30%;" data-sorttype="{{2}}" data-event-opts="{{[['tap',[['sorttypeChange',['$event']]]]]}}" bindtap="__e">订单数量<block s-if="{{2==sorttype}}"><view class="before" style="{{('border-bottom:1rpx solid '+$root.m4)}}"></view></block></view></block></view><view class="tab1"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['t1 '+(index==ranktype?'on':'')]}}" style="{{'color:'+(index==ranktype?item.m5:'')+';'}}" data-ranktype="{{index}}" data-event-opts="{{[['tap',[['toranktype',['$event']]]]]}}" bindtap="__e">{{''+item.$orig+''}}<block s-if="{{index==ranktype}}"><view class="before" style="{{('border-bottom:1rpx solid '+item.m6)}}"></view></block></view></block></block></view><view class="tab"><view class="t1">排名</view><view class="t2">{{ranktype==3?'用户':'区域名'}}</view><block s-if="{{sorttype==1}}"><view class="t3" style="{{'color:'+($root.m7)+';'}}">订单金额</view></block><block s-if="{{sorttype==2}}"><view class="t3" style="{{'color:'+($root.m8)+';'}}">订单数量</view></block></view><view class="itembox"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><block s-if="{{index<3}}"><view class="t1"><image src="{{pre_url+'/static/img/comrank'+index+'.png'}}"></image></view></block><block s-else><view class="t1">{{index+1}}</view></block><block s-if="{{ranktype==3}}"><view class="t2"><image src="{{item.headimg}}"></image>{{item.nickname}}</view></block><block s-else><view class="t2"><text style="margin-left:32rpx;"></text>{{''+item.title}}</view></block><block s-if="{{sorttype==1}}"><text class="t3">{{''+item.totalprice}}</text></block><block s-if="{{sorttype==2}}"><text class="t3">{{''+item.num}}</text></block></view></block></block></view></view></view><block s-if="{{nodata}}"><nodata vue-id="7757c5d6-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="7757c5d6-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="7757c5d6-3"></loading></block><dp-tabbar vue-id="7757c5d6-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7757c5d6-5" data-ref="popmsg"></popmsg></view></block></block>