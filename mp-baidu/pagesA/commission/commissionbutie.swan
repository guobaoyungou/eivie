<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f2" data-url="{{'/pagesA/commission/commissionbutielog?pid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><block s-if="{{item.$orig.frommid>0}}"><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></block><text class="x2">{{"总期数："+item.$orig.fx_butie_circle+" 已发："+item.$orig.send_circle}}</text><text class="x2">{{item.$orig.circle_str+''}}</text></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block><text class="dior-sp6 yfk">{{"已发放："+item.$orig.have_send}}</text></block></view></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="27fed9b5-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="27fed9b5-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="27fed9b5-3"></loading></block><dp-tabbar vue-id="27fed9b5-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="27fed9b5-5" data-ref="popmsg"></popmsg></view>