<view class="container"><block s-if="{{isload}}"><block><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head" style="justify-content:space-between;"><block s-if="{{item.ordernum}}"><view class="f1">{{"订单号:"+item.ordernum}}</view></block><block s-else><view class="f1"><image class="logo-row" src="{{item.binfo.logo}}"></image>{{''+item.binfo.name}}</view></block></view><block s-for="item.prolist trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view data-url="{{'/pages/shop/product?id='+item2.proid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{item2.pic}}" mode="aspectFill"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><block><block s-if="{{item2.product_type&&item2.product_type==2}}"><view class="t3"><text class="x1 flex1">{{item2.real_sell_price+"元/斤"}}</text><text class="x2">{{"×"+item2.real_total_weight+"斤"}}</text></view></block><block s-else><view class="t3"><text class="x1 flex1">{{'￥'+item2.sell_price+''}}</text><text class="x2">{{"×"+item2.num}}</text></view></block></block></view></view></block></block><block s-if="{{item.mid||item.nickname}}"><view class="bottom" style="display:flex;"><block s-if="{{item.mid}}"><view>{{"ID:"+item.mid}}</view></block><block s-if="{{item.nickname}}"><view style="margin-left:10rpx;">{{item.nickname}}</view></block></view></block><view class="bottom"><view>{{'共计'+item.procount+"件商品 实付:￥"+item.totalprice+''}}</view></view><block s-if="{{item.tips!=''}}"><view class="bottom"><text style="color:red;">{{item.tips}}</text></view></block></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="7e16a8df-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="7e16a8df-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="7e16a8df-3"></loading></block><dp-tabbar vue-id="7e16a8df-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7e16a8df-5" data-ref="popmsg"></popmsg></view>