<view><block s-if="{{isload}}"><block><view style="width:650rpx;margin:0 auto;"><view class="form-item flex-col"><view class="f2" style="flex-wrap:wrap;"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><block s-if="{{can_del}}"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block><view class="layui-imgbox-img"><image src="{{item['img']}}" data-url="{{item['img']}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{pics?$root.g0:''}}"/></view></view><block s-if="{{!pics}}"><nodata vue-id="fddead5e-1"></nodata></block></block></block><block s-if="{{can_del||can_add}}"><view style="position:fixed;bottom:100rpx;right:20rpx;"><block s-if="{{can_add}}"><view class="deal_css" data-url="{{'upimg?orderid='+orderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">上传</view></block><block s-if="{{can_del}}"><view data-event-opts="{{[['tap',[['delall',['$event']]]]]}}" class="deal_css" style="margin-top:20rpx;" bindtap="__e">全删</view></block></view></block><dp-tabbar vue-id="fddead5e-2" opt="{{opt}}"></dp-tabbar></view>