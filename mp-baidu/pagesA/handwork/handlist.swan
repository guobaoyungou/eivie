<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="12043ac2-1" itemdata="{{['全部','待验货','返款中','已返款']}}" itemst="{{['all','1','2','3']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view style="width:94%;margin:0rpx 3%;padding:10rpx;background-color:#fff;display:flex;justify-content:space-between;line-height:70rpx;"><view>{{'待返金额:￥'+inmoney+''}}</view><view>{{'已返金额:￥'+endmoney+''}}</view></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'handDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head" style="justify-content:space-between;"><block s-if="{{item.binfo}}"><block><view class="f1">{{"回寄单号 "+item.hand_ordernum}}</view></block></block><block s-if="{{item.status==0}}"><text class="st0">待验货</text></block><block s-if="{{item.status==1&&item.issend==0}}"><text class="st4">已验货,待返款</text></block><block s-if="{{item.status==1&&item.issend==1}}"><text class="st4">已验货,已返款</text></block></view><block s-for="item.prolist trackBy idx" s-for-item="item2" s-for-index="idx"><block><view class="content" style="{{(idx+1==item.procount?'border-bottom:none':'')}}"><view><image src="{{item2.pic}}"></image></view><view class="detail"><text class="t1">{{item2.name}}</text><text class="t2">{{item2.ggname}}</text><text class="t2">{{"手工费："+item2.hand_fee}}</text><text class="t2">{{"回寄数量："+item2.hand_num}}</text></view></view></block></block><block s-if="{{item.status==1}}"><view class="bottom"><text class="t2">{{"总计返款：￥"+item.totalmoney}}</text><block s-if="{{item.issend==0}}"><text style="color:red;margin-left:10rpx;">待返款</text></block><block s-if="{{item.issend==1}}"><text style="color:grey;margin-left:10rpx;">已返款</text></block></view></block><view class="op"><view class="btn2" data-url="{{'handDetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="12043ac2-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="12043ac2-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="12043ac2-4"></loading></block><dp-tabbar vue-id="12043ac2-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="12043ac2-6" data-ref="popmsg"></popmsg></view>