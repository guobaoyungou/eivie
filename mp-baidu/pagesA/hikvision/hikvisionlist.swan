<view class="container"><block s-if="{{isload}}"><block><view class="article_list flex-wp"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="article-itemlist flex-col" data-url="{{'/pagesA/hikvision/detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="article-pic"><image class="image" src="{{item.icon}}" mode="widthFix"></image></view><view class="article-info"><view class="p1" style="{{(set.title_size&&set.title_size>0?'font-size:'+set.title_size*2+'rpx':'')}}">{{item.name}}</view><block><view class="p3">{{''+item.deviceserial+''}}</view></block></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="1eb55e88-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="1eb55e88-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="1eb55e88-3"></loading></block><dp-tabbar vue-id="1eb55e88-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1eb55e88-5" data-ref="popmsg"></popmsg></view>