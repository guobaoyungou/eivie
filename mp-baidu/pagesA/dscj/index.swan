<view class="container"><block s-if="{{isload}}"><block><view class="swiper-container"><swiper class="swiper" indicator-dots="{{false}}" autoplay="{{true}}" interval="{{5000}}" data-event-opts="{{[['change',[['swiperChange',['$event']]]]]}}" bindchange="__e"><block s-for="sliders trackBy index" s-for-item="item" s-for-index="index"><block><swiper-item class="swiper-item"><view class="swiper-item-view"><image class="img" src="{{item}}" mode="widthFix"></image></view></swiper-item></block></block></swiper><view class="counter"><view class="imageCount">{{current+1+"/"+sliders.length}}</view></view></view><view class="main-container"><view class="mainbox"><view class="title">{{''+info.name+''}}</view><view class="prize"><block s-for="jxarr trackBy index" s-for-item="item" s-for-index="index"><view>{{item.jxmc+''}}<text class="number">{{"×"+item.jxsl+"份"}}</text></view></block></view><view class="time"><block s-if="{{info.is_end==-1}}"><view>开始时间：<text class="date">{{info.starttime}}</text></view></block><block s-if="{{info.is_end==1||info.is_end==2}}"><view>开奖时间：<text class="date">{{info.opentime}}</text></view></block><block s-if="{{info.is_end==0}}"><view>结束时间：<text class="date">{{info.endtime}}</text></view></block><block s-if="{{info.need_fee&&info.fee>0}}"><view>报名费用：<text class="price">{{info.fee+" 元"}}</text></view></block></view><view class="rule"><view>{{info.opentime+" 自动开奖"}}</view><block s-if="{{info.opennum>0}}"><view>{{"或参与人数满 "+info.opennum+"人 自动开奖"}}</view></block></view><block s-if="{{info.is_end==1}}"><view class="result"><text class="restag">已开奖</text><text class="resbtn" data-url="{{'prize?hid='+info.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看中奖名单</text></view></block></view><view class="mainbox mgt10"><view class="{{['joinwrap','st'+info.is_end]}}"><view class="join"><block s-if="{{info.is_end==-1}}"><text>未开始</text></block><block s-if="{{info.is_end==2}}"><text>已结束</text></block><block s-if="{{info.is_end==1}}"><text>已开奖</text></block><block s-if="{{info.is_end==0}}"><block><block s-if="{{info.is_join==1}}"><text>等待开奖</text></block><block s-if="{{info.is_join==0&&showqrcode&&!showdoneqrcode}}"><text data-event-opts="{{[['tap',[['showqrmodal',['$event']]]]]}}" bindtap="__e">参与抽奖</text></block><block s-if="{{info.is_join==0&&(!showqrcode||showqrcode&&showdoneqrcode)}}"><text data-event-opts="{{[['tap',[['joinin',['$event']]]]]}}" bindtap="__e">参与抽奖</text></block></block></block></view></view><block s-if="{{joinnum>0}}"><block><view class="joinnum">{{"已有"+joinnum+"人参加此活动"}}</view><view class="joinlist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="img"><image src="{{item.headimg}}"></image></view></block></block></view><block s-if="{{nomore==false}}"><view data-event-opts="{{[['tap',[['getmore',['$event']]]]]}}" class="joinmore" bindtap="__e">---查看更多---</view></block><block s-if="{{nomore==true&&pagenum>1}}"><view class="joinmore">---无更多数据---</view></block></block></block></view><view class="mainbox mgt10"><view class="detail"><view class="title">活动详情</view><view class="content"><rich-text nodes="{{info.content}}"></rich-text></view></view></view></view><block s-if="{{showqrpopup}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['hideqrmodal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__content"><view><image data-url="{{info.qrcode}}" src="{{info.qrcode}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view><block s-if="{{info.qrcode_tip}}"><view class="txt">{{info.qrcode_tip}}</view></block></view></view></view></block><view class="myrecord" data-url="{{'myrecord?bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">我的<view class="_br"></view>抽奖</view></block></block><block s-if="{{loading}}"><loading vue-id="8ab11bec-1"></loading></block><dp-tabbar vue-id="8ab11bec-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="8ab11bec-3" data-ref="popmsg"></popmsg></view>