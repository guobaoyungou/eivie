<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center" style="{{'background:'+($root.m0)+';'}}"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="listbox"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="tr listitem"><view class="info flex" data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view><view class="title">{{"活动名称："+item.$orig.title}}</view><view class="td td2">{{"参加时间："+item.$orig.createtime}}</view><block s-if="{{item.$orig.totalprice>0}}"><view class="td td2">{{"报名支付：￥"+item.$orig.totalprice}}</view></block><block s-if="{{item.$orig.is_done}}"><view class="td td2">中奖奖品：<block s-if="{{item.$orig.jxid>0}}"><text style="{{'color:'+(item.m1)+';'}}">{{item.$orig.jxmc}}</text></block><block s-if="{{item.$orig.jxid==0}}"><text>未中奖</text></block></view></block><block s-else><view>待开奖</view></block></view><view class="opt"><text data-url="{{'/pagesA/dscj/index?id='+item.$orig.hid+'&bid='+item.$orig.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看</text></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="357231e5-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="357231e5-2"></nodata></block><view class="myrecord" data-url="/pages/index/index" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">首页</view></block></block><block s-if="{{loading}}"><loading vue-id="357231e5-3"></loading></block><dp-tabbar vue-id="357231e5-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="357231e5-5" data-ref="popmsg"></popmsg></view>