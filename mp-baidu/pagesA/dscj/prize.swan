<view class="container" style="min-height:100vh;"><block s-if="{{isload}}"><block><view class="activity"><view class="activity-amin"><view class="h2">中奖名单</view><view class="listbox"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="tr flex listitem"><view class="member"><view><image src="{{item.headimg}}"></image></view><view>{{item.nickname}}</view></view><view class="info"><view class="td td2">{{"中奖备注："+item.remark}}</view><view class="td td2">{{"中奖时间："+item.createtime}}</view><view class="td td2">{{"中奖奖品："+item.jxmc}}</view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="10d0226c-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="10d0226c-2"></nodata></block></view></view></block></block><block s-if="{{loading}}"><loading vue-id="10d0226c-3"></loading></block><dp-tabbar vue-id="10d0226c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="10d0226c-5" data-ref="popmsg"></popmsg></view>