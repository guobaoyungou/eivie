<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="74d35296-1" itemdata="{{['业绩明细','提现记录']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-if="{{st==0}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><block s-if="{{item.remark}}"><text class="t2">{{item.remark}}</text></block><block s-if="{{item.money>0}}"><text class="t2">{{"充值金额："+item.money}}</text></block><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.get_yj>0}}"><text class="t1">{{"+"+item.get_yj}}</text></block><block s-else><text class="t2">{{item.get_yj}}</text></block></view></view></block></block></block><block s-if="{{st==1}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{"提现业绩："+item.rechargeyj_money}}</text><text class="t1">{{"金额："+item.money+"元"}}</text><text class="t2">{{item.createtime}}</text></view><view class="f3"><block s-if="{{item.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="74d35296-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="74d35296-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="74d35296-4"></loading></block><dp-tabbar vue-id="74d35296-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="74d35296-6" data-ref="popmsg"></popmsg></view>