<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'/pagesA/my/tongzhengreleaselog?pid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{"订单ID:"+item.orderid}}</text><text class="t2">{{"总数量："+item.tongzheng}}</text><text class="t2">{{"剩余："+item.remain}}</text><text class="t2">{{"状态："+item.status_str}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block><text class="t1">{{"已释放："+item.release_num}}</text></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="5bc4a3f4-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="5bc4a3f4-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="5bc4a3f4-3"></loading></block><dp-tabbar vue-id="5bc4a3f4-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5bc4a3f4-5" data-ref="popmsg"></popmsg></view>