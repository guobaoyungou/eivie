<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的补贴</view><view class="f2">{{money}}<block s-if="{{withdraw}}"><view class="btn-mini" data-url="withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></block></view></view><dd-tab vue-id="31d57295-1" itemdata="{{['补贴记录','提现记录']}}" itemst="{{['0','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content" id="datalist"><block s-if="{{st==0}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block s-else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block></block><block s-if="{{st==2}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><view class="t1">{{"提现金额:"+item.$orig.money+'元'}}<block s-if="{{item.$orig.score>0}}"><text style="margin-left:10rpx;">{{item.m1+":"+item.$orig.score}}</text></block></view><text class="t2">{{item.$orig.createtime}}</text></view><view class="f3"><block s-if="{{item.$orig.status==0}}"><text class="t1">审核中</text></block><block s-if="{{item.$orig.status==1}}"><text class="t1">已审核</text></block><block s-if="{{item.$orig.status==2}}"><text class="t2">已驳回</text></block><block s-if="{{item.$orig.status==3}}"><text class="t1">已打款</text></block></view></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="31d57295-2"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="31d57295-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="31d57295-4"></loading></block><dp-tabbar vue-id="31d57295-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="31d57295-6" data-ref="popmsg"></popmsg></view>