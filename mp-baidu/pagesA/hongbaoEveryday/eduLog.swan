<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的额度</view><view class="f2">{{hongbao_everyday_edu}}</view></view><block s-if="{{scoreWithdraw}}"><view class="myscore" style="{{'background:'+($root.m1)+';'}}"><view class="f1">{{"允提"+$root.m2}}</view><view class="f2">{{myscore2}}<view class="btn-mini" data-url="/pagesExt/my/scoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提现</view></view></view></block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><block><text class="t1">{{"+"+item.money}}</text></block></block><block s-else><block><text class="t2">{{item.money}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="09aeee12-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="09aeee12-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="09aeee12-3"></loading></block><dp-tabbar vue-id="09aeee12-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="09aeee12-5" data-ref="popmsg"></popmsg></view>