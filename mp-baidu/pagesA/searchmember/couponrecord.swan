<view class="container"><block s-if="{{isload}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="content flex" data-id="{{item.id}}"><view data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" class="item" bindtap="__e"><view class="f1"><view class="name">{{"次卡名称："+item.couponname}}</view><view class="f2"><view class="headimg"><image src="{{item.headimg}}"></image></view><view class="text1"><text class="t1">{{item.nickname+''}}</text><text class="t2">剩余次数：<text style="font-weight:bold;">{{item.limit_count-item.used_count}}</text></text></view></view></view><view class="btn" style="{{'background:'+($root.m0)+';'}}" data-url="{{'couponused?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">使用记录</view></view></view></block><block s-if="{{nodata}}"><nodata vue-id="cfe4d092-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="cfe4d092-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="cfe4d092-3"></loading></block><dp-tabbar vue-id="cfe4d092-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="cfe4d092-5" data-ref="popmsg"></popmsg></view>