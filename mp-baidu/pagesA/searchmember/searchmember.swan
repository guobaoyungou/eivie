<view><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:28rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"共搜索到 "+count+" 条数据"}}</text></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1" data-url="{{'memberdetail?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image src="{{item.headimg}}"></image><view class="t2"><view class="x1 flex-y-center">{{''+item.nickname+''}}<block s-if="{{item.sex==1}}"><image style="margin-left:10rpx;width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/nan2.png'}}"></image></block><block s-if="{{item.sex==2}}"><image style="margin-left:10rpx;width:40rpx;height:40rpx;" src="{{pre_url+'/static/img/nv2.png'}}"></image></block></view><text class="x2" style="color:#666;">{{(item.realname?item.realname:'')+" "+(item.tel?item.tel:'')}}</text><text class="x2">{{item.createtime}}</text><block s-if="{{item.remark}}"><text class="x2" style="color:#a66;font-size:22rpx;">{{item.remark}}</text></block></view></view><view class="op"><view class="btn2" data-url="{{'jdorderlist?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">预约订单</view><view class="btn2" data-url="{{'couponrecord?mid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">计次卡</view><block s-if="{{item.tel}}"><view class="btn2" data-url="{{'formlog?tel='+item.tel}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">病例档案</view></block></view></view></block></block></view></block><block s-if="{{nomore}}"><nomore vue-id="393a4c4c-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="393a4c4c-2" text="没有搜索到相关信息"></nodata></block></block></block><popmsg class="vue-ref" vue-id="393a4c4c-3" data-ref="popmsg"></popmsg></view>