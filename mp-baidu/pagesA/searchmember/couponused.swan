<view class="container"><block s-if="{{isload}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="content flex" data-id="{{item.$orig.id}}"><view data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" class="item" bindtap="__e"><view class="f1"><view class="name">{{"次卡名称："+item.$orig.couponname}}</view><view class="f2"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{"使用时间："+item.m0}}</text></view></view></view></view></block><block s-if="{{nodata}}"><nodata vue-id="b2c51bea-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="b2c51bea-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="b2c51bea-3"></loading></block><dp-tabbar vue-id="b2c51bea-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="b2c51bea-5" data-ref="popmsg"></popmsg></view>