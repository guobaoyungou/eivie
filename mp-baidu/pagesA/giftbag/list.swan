<view><block s-if="{{isload}}"><block><view class="container"><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'detail?id='+item.id+'&gbid='+gbid+'&bid='+bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3" style="position:relative;bottom:0;"><text class="t1" style="{{'color:'+($root.m0)+';'+('font-size:'+('28rpx')+';')}}"><text style="font-size:24rpx;">￥</text>{{item.sell_price}}</text><view class="t2" style="{{'border-color:'+($root.m1)+';'+('color:'+($root.m2)+';')+('position:'+('absolute')+';')+('right:'+('0')+';')}}"><text class="x2" style="{{'background-color:'+($root.m3)+';'}}">详情</text></view></view><block s-if="{{item.shortdesc}}"><view class="p1" style="margin-top:10rpx;">{{item.shortdesc}}</view></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="ecb44c64-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="ecb44c64-2"></nodata></block></view><view class="notabbarbot" style="width:100%;height:110rpx;box-sizing:content-box;"></view><view class="{{['bottombar','flex-row',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view data-event-opts="{{[['tap',[['tobuy',['$event']]]]]}}" class="tobuy" style="{{'background:'+($root.m4)+';'+('margin:'+('0 auto')+';')}}" bindtap="__e"><text>立即领取</text></view></view></block></block><block s-if="{{loading}}"><loading vue-id="ecb44c64-3"></loading></block><dp-tabbar vue-id="ecb44c64-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="ecb44c64-5" data-ref="popmsg"></popmsg></view>