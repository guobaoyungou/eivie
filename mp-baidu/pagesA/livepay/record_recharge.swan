<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="24228919-1" itemdata="{{['全部','待付款','充值中','已完成','已关闭']}}" itemst="{{['all','0','1','3','4']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content flex-col"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="options-view"><view class="info-view"><view class="type-name">{{item.$orig.type_name}}</view><view class="recharge-number-text">{{''+item.$orig.recharge_number+" | "+item.$orig.company+''}}</view><view class="time-text">{{item.m0}}</view></view><view class="price-view"><block s-if="{{item.$orig.status==0}}"><view class="success-text">待付款</view></block><block s-if="{{item.$orig.status==2}}"><view class="success-text">充值中</view></block><block s-if="{{item.$orig.status==4}}"><view class="success-text">已关闭</view></block><block s-if="{{item.$orig.status==5}}"><view class="success-text">已退款</view></block><block s-if="{{item.$orig.status==1}}"><view class="success-text">充值中</view></block><block s-if="{{item.$orig.status==3}}"><view class="success-text" style="color:#e8b200;">充值成功</view></block><view class="price-num flex-y-center"><view>{{"￥"+item.$orig.totalprice}}</view><block s-if="{{item.g0}}"><view class="discount-text" style="margin-left:10rpx;">{{"优惠: -"+item.g1}}</view></block></view><block s-if="{{item.g2}}"><view class="discount-text">{{"优惠: -"+item.g3}}</view></block><block s-if="{{item.$orig.status==0}}"><view data-event-opts="{{[['tap',[['topay',['$0'],[[['datalist','',index]]]]]]]}}" class="btn1" style="{{'background:'+(item.m1)+';'}}" bindtap="__e">去支付</view></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="24228919-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="24228919-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="24228919-4"></loading></block><popmsg class="vue-ref" vue-id="24228919-5" data-ref="popmsg"></popmsg><dp-tabbar vue-id="24228919-6" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar></view>