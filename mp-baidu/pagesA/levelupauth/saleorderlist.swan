<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="51c60384-1" itemdata="{{['全部','待付款','已付款']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view>{{"订单号："+item.ordernum}}</view><view class="flex1"></view><block s-if="{{item.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.status==1}}"><text class="st1">{{item.ordertype==1?'已领取':'已付款'}}</text></block><block s-if="{{item.status==-1}}"><text class="st2">已取消</text></block></view><view class="content"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.title}}</text><text class="t2" style="color:#666;">{{(item.ordertype==1?'赠送':'售卖')+"等级："+item.levelname}}</text></view></view><view class="bottom"><text>{{"金额:￥"+item.totalprice}}</text></view><view class="op"><view class="btn2" data-url="{{'orderdetail?type=2&id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">订单详情</view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="51c60384-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="51c60384-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="51c60384-4"></loading></block><dp-tabbar vue-id="51c60384-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="51c60384-6" data-ref="popmsg"></popmsg></view>