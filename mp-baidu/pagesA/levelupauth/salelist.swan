<view class="container"><block s-if="{{isload}}"><block><view class="box"><view class="title flex-sb"><view class="bold">{{"剩余额度("+salelevel_money+")"}}</view></view><block s-if="{{levellist.length>0}}"><view class="itembox"><block s-for="levellist" s-for-item="item" s-for-index="index"><block><view class="item flex-sb"><view class="left" data-url="{{'leveldetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="headimg" src="{{item.icon}}"></image><view class="info"><view class="desc">{{item.name}}</view><view class="remark txthide">{{"升级费用："+item.apply_paymoney}}</view></view></view><view class="right"><block s-if="{{$root.m0}}"><button class="btn" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}" data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" catchtap="__e">转赠</button></block><block s-else><button class="btn" open-type="share" data-type="1" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}">转赠</button></block><block s-if="{{$root.m1}}"><button class="btn" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}" data-event-opts="{{[['tap',[['tosale',['$event']]]]]}}" catchtap="__e">售卖</button></block><block s-else><button class="btn" open-type="share" data-type="2" data-levelid="{{item.id}}" data-levelprice="{{item.apply_paymoney}}">售卖</button></block></view></view></block></block></view></block><block s-if="{{levellist.length==0}}"><view class="nomore">-暂无可售卖会员等级-</view></block></view><block s-if="{{dialogShow}}"><view data-event-opts="{{[['tap',[['zhaunzeng',['$event']]]]]}}" class="popup_modal" bindtap="__e"><view class="content1"><view class="title">我要转赠</view><view class="f1">点击下方按钮，复制链接发送给好友</view><block s-if="{{$root.m2=='wx'}}"><view data-event-opts="{{[['tap',[['shareScheme',['$event']]]]]}}" class="btnbox" bindtap="__e"><button class="btn2" style="{{'background:'+($root.m3)+';'}}">复制</button></view></block><block s-else><view class="btnbox"><button class="btn2" style="{{'background:'+($root.m4)+';'}}" data-text="{{pre_url+'/h5/'+aid+'.html#/pagesA/levelupauth/give?pid='+frommid+'&levelid='+levelid}}" data-event-opts="{{[['tap',[['copy',['$event']]]]]}}" bindtap="__e">复制</button></view></block></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="159775d4-1"></loading></block><popmsg class="vue-ref" vue-id="159775d4-2" data-ref="popmsg"></popmsg></view>