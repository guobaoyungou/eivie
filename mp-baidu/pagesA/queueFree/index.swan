<view class="container"><block s-if="{{isload}}"><block><view class="tongji flex-y-center " style="{{'background:'+(color1?color1:$root.m0)+';'}}"><view><view class="price">{{set.give_money}}</view><view>{{jiangli_text}}</view></view><block s-if="{{paidui_money_show}}"><view><view class="price">{{set.sy_money}}</view><view>{{paidui_text}}</view></view></block><block s-if="{{set.activity_rules}}"><view data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" style="position:absolute;right:14rpx;top:10rpx;font-size:26rpx;" bindtap="__e">活动规则</view></block></view><view class="tab tab_top"><dd-tab vue-id="97e4190a-1" itemdata="{{itemlabel}}" itemst="{{itemvalue}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></view><view class="height130"></view><view class="order-content "><block s-if="{{st==2}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item1" s-for-index="index"><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item1.$orig.ordernum}}</view><view class="flex1"></view></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item1.$orig.bname}}</text></view><view class="detail">拆单金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{item1.$orig.money}}</text></view><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m2)}}">{{item1.$orig.free_money}}</text></view><view class="detail">释放所需单数：<text class="t1" style="{{('color:'+$root.m3)}}">{{item1.$orig.order_count+"单"}}</text></view><view class="detail"><text class="t1">{{"创建时间："+item1.m4}}</text></view></view></view></block></block></block><block s-else><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.$orig.statusLabel}}</text></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item.$orig.bname}}</text></view><block s-if="{{item.$orig.title}}"><view class="detail">排队名称：<text class="t1" style="{{('color:'+item.m5)}}">{{item.$orig.title}}</text></view></block><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m6)}}">{{item.$orig.money}}</text></view><block s-if="{{set.back_money_type==1}}"><view class="detail">路上金额：<text class="t1" style="{{('color:'+$root.m7)}}">{{item.$orig.addup_money}}</text></view></block><block s-if="{{!set.back_money_type||set.back_money_type&&item.$orig.status==1}}"><view class="detail">已获金额：<text class="t1" style="{{('color:'+item.m8)}}">{{item.$orig.money_give}}</text></view></block><block s-if="{{item.$orig.queue_no}}"><view class="detail">当前排名：<text class="t1" style="{{('color:'+item.m9)}}">{{item.$orig.queue_noLabel}}</text></view></block><view class="detail"><text class="t1">{{"排队时间："+item.$orig.createtimeFormat}}</text></view></view><view class="operate flex-y-center flex-x-bottom "><block s-if="{{item.$orig.status==0&&set.quit_wxhb==1&&item.$orig.money_quit_hb>0}}"><view class="button" style="{{'background:'+(item.m10)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitWithHb',['$event']]]]]}}" catchtap="__e">{{quit_wxhb_text}}</view></block><block s-if="{{item.$orig.status==0&&set.quit_score==1}}"><view class="button" style="{{'background:'+(item.m11)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-id="{{item.$orig.id}}" data-givescore="{{item.$orig.give_score}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitScore',['$event']]]]]}}" catchtap="__e">{{"退出返"+item.m12}}</view></block><block s-if="{{item.$orig.status==0&&set.quit_random_score==1}}"><view class="button" style="{{'background:'+(item.m13)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitRandomScore',['$event']]]]]}}" catchtap="__e">{{quit_random_score_text}}</view></block><block s-if="{{item.$orig.status==0&&set.quit_back_price_st==1&&item.$orig.quit_back_price_st==1}}"><view class="button" style="{{'background:'+(item.m14)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-backprice="{{item.$orig.give_back_price}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitBackPrice',['$event']]]]]}}" catchtap="__e">退出转每日补贴</view></block><block s-if="{{item.$orig.status==0&&set.quit_freeze_money==1}}"><view class="button" style="{{'background:'+(item.m15)+';'+('color:'+('#fff')+';')+('border:'+('none')+';')}}" data-id="{{item.$orig.id}}" data-givemoney="{{item.$orig.give_freeze_money}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitFreezeMoney',['$event']]]]]}}" catchtap="__e">{{"退出返"+item.m16}}</view></block></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="97e4190a-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="97e4190a-3"></nodata></block></block></block><block s-if="{{prizeVisible}}"><view data-event-opts="{{[['touchmove',[['e0',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchtouchmove="__e" bindmousewheel="__e"><view class="hongbao-view"><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view data-event-opts="{{[['tap',[['hbclose',['$event']]]]]}}" class="hongbao-view-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup class="vue-ref" bind:change="__e" vue-id="97e4190a-4" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" vue-slots="{{['default']}}"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{hbmoney}}</text><text class="unit">元</text></view><view class="title">{{''+hbtext+''}}</view><view data-event-opts="{{[['tap',[['hbsuccess',['$event']]]]]}}" class="cl-button" bindtap="__e"><text>确定</text></view></view></view></view></uni-popup></view></block><block s-if="{{randomScoreVisible}}"><view data-event-opts="{{[['touchmove',[['e1',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchtouchmove="__e" bindmousewheel="__e"><view class="hongbao-view" style="top:15%;"><block s-for="3" s-for-item="item" s-for-index="index"><view class="wrap" style="width:33%;height:310rpx;"><view data-event-opts="{{[['tap',[['receiveRandomScore',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/queuefree/baoxiang.gif'}}" mode="aspectFill"></image></view></view></block><view data-event-opts="{{[['tap',[['randomScoreclose',['$event']]]]]}}" class="hongbao-view-close" style="bottom:-150rpx;" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup class="vue-ref" bind:change="__e" vue-id="97e4190a-5" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" vue-slots="{{['default']}}"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{randomScore}}</text><text class="unit">{{$root.m17}}</text></view><view class="title">{{'奖励将发放到个人'+$root.m18+'账户'}}</view><view data-event-opts="{{[['tap',[['randomScoreclose',['$event']]]]]}}" class="cl-button" bindtap="__e"><text>确定</text></view></view></view></view></uni-popup></view></block><block s-if="{{backPriceVisible}}"><view data-event-opts="{{[['touchmove',[['e2',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchtouchmove="__e" bindmousewheel="__e"><view class="hongbao-view"><block s-for="3" s-for-item="item" s-for-index="index"><view class="wrap"><view data-event-opts="{{[['tap',[['receiveBackPrice',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view></block><view data-event-opts="{{[['tap',[['quitBackpriceclose',['$event']]]]]}}" class="hongbao-view-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup class="vue-ref" bind:change="__e" vue-id="97e4190a-6" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" vue-slots="{{['default']}}"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{give_back_price}}</text></view><view class="title">奖励将发放到个人待返金额中</view><view data-event-opts="{{[['tap',[['quitBackpriceclose',['$event']]]]]}}" class="cl-button" bindtap="__e"><text>确定</text></view></view></view></view></uni-popup></view></block><uni-popup class="vue-ref" vue-id="97e4190a-7" type="center" data-ref="popupMiandan" vue-slots="{{['default']}}"><view class="popup-miandan-content"><view class="popup-miandan-price flex"><view class="price-num-text popup-color-text">{{set.give_money}}</view><view class="right-text popup-color-text">元</view></view><view class="popup-leiji-miandan popup-color-text">累计免单金额</view><view class="popup-guishu flex-col"><view class="top-text">{{set.popup_text1}}</view><view class="bottom-text">{{set.popup_text2}}</view></view><image src="{{pre_url+'/static/img/miandanpopupbg.png'}}" mode="widthFix"></image></view><view data-event-opts="{{[['tap',[['popupMiandanclose',['$event']]]]]}}" class="popupMiandan-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></uni-popup><block s-if="{{showmaskrule}}"><view id="mask-rule"><view class="box-rule"><view class="h2">活动规则</view><view style="{{('background-image:url('+pre_url+'/static/img/dzp/close.png);background-size:100%')}}" id="close-rule" data-event-opts="{{[['tap',[['changemaskrule',['$event']]]]]}}" bindtap="__e"></view><view class="con"><view class="text"><text decode="true" space="true">{{set.activity_rules}}</text></view></view></view></view></block><fireworks vue-id="97e4190a-8" fireworksShow="{{fireworksShow}}"></fireworks><block s-if="{{loading}}"><loading vue-id="97e4190a-9"></loading></block><dp-tabbar vue-id="97e4190a-10" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="97e4190a-11" data-ref="popmsg"></