<view style="{{'font-size:'+(fontSize)+';'}}"><block s-if="{{isload}}"><block><view class="progress">进度：<text>{{question_index+1+"/"+questionlist.length}}</text></view><view class="container"><view class="question"><view class="title"><rich-text nodes="{{question.name}}"></rich-text></view><view class="option_group"><block s-for="question.optionlist" s-for-item="item" s-for-index="index"><block><view class="option flex" style="{{(item.checked==1?'background:'+themeColor+';color:#ffffff':'')}}" data-index="{{index}}" data-event-opts="{{[['tap',[['selectOption',['$event']]]]]}}" bindtap="__e">{{''+item.option+''}}</view></block></block></view></view></view><block s-if="{{custom.PSQI}}"><view class="bottom"><block><block s-if="{{question_index>0}}"><view data-event-opts="{{[['tap',[['goprev',['$event']]]]]}}" class="btn btn1" bindtap="__e">上一题</view></block><block s-else><view class="btn btn0"></view></block></block><block s-if="{{question_index<questionlist.length-1}}"><view data-event-opts="{{[['tap',[['gonext',['$event']]]]]}}" class="btn btn2" bindtap="__e">下一题</view></block><block s-if="{{question_index==questionlist.length-1}}"><view data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" class="btn btn2" bindtap="__e">提交</view></block></view></block><block s-else><view class="bottom"><block><block s-if="{{question_index>0}}"><view data-event-opts="{{[['tap',[['goprev',['$event']]]]]}}" class="btn btn1" style="{{('background:rgba('+$root.m0+',0.16);color:'+$root.m1)}}" bindtap="__e">上一题</view></block><block s-else><view class="btn btn0"></view></block></block><block s-if="{{question_index<questionlist.length-1}}"><view data-event-opts="{{[['tap',[['gonext',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'}}" bindtap="__e">下一题</view></block><block s-if="{{question_index==questionlist.length-1}}"><view data-event-opts="{{[['tap',[['finish',['$event']]]]]}}" class="btn" style="{{'background:'+(themeColor)+';'}}" bindtap="__e">提交</view></block></view></block></block></block><block s-if="{{loading}}"><loading vue-id="19372f7c-1"></loading></block><popmsg class="vue-ref" vue-id="19372f7c-2" data-ref="popmsg"></popmsg></view>