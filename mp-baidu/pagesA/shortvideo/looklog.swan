<view><block s-if="{{isload}}"><block><view class="container"><view class="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="collage-product" data-url="{{'/activity/shortvideo/detail?id='+item.vid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p2" style="display:flex;color:#888;"><view style="width:100%;">次数：<text style="color:#000;">{{item.num}}</text></view><view style="width:100%;">进度：<text style="color:#000;">{{item.jindu+"%"}}</text></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="4d2d8ae4-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="4d2d8ae4-2"></nodata></block></view></block></block><block s-if="{{loading}}"><loading vue-id="4d2d8ae4-3"></loading></block><dp-tabbar vue-id="4d2d8ae4-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="4d2d8ae4-5" data-ref="popmsg"></popmsg></view>