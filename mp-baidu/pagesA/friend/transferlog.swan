<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="4a7566ca-1" itemdata="{{[$root.m0+'明细',$root.m1+'明细']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.title}}</text><text class="t2">{{item.$orig.createtime}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block s-if="{{item.$orig.num>0}}"><text class="t1" style="{{'color:'+(item.m2)+';'}}">{{"+"+item.$orig.num}}</text></block><block s-else><text class="t2">{{item.$orig.num}}</text></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="4a7566ca-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="4a7566ca-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="4a7566ca-4"></loading></block><dp-tabbar vue-id="4a7566ca-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="4a7566ca-6" data-ref="popmsg"></popmsg></view>