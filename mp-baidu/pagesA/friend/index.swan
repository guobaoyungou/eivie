<view class="container"><block s-if="{{isload}}"><block><view class="top"><view class="top-search"><image class="search-icon" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input class="input" type="text" placeholder="输入昵称|姓名|手机号检索" placeholder-style="font-size:26rpx;color:#999" data-event-opts="{{[['confirm',[['searchFriend',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="box"><view class="title flex-sb"><view class="bold">{{"我的好友("+friendCount+")"}}</view><block s-if="{{btnauth.addFriend}}"><view data-event-opts="{{[['tap',[['showAddModal',['$event']]]]]}}" style="{{'color:'+($root.m0)+';'}}" bindtap="__e">添加好友</view></block></view><block s-if="{{datalist.length>0}}"><view class="itembox"><block s-for="datalist" s-for-item="item" s-for-index="index"><block><view class="item flex-sb"><view class="left"><image class="headimg" src="{{item.headimg}}" data-url="{{'scan?fmid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"></image><view class="info"><view class="nickname txthide">{{item.nickname}}</view><view class="desc">{{"等级："+item.levelname}}</view><view class="remark txthide">{{"备注："+item.remark}}</view></view></view><view class="right"><block s-if="{{btnauth.moneyTransfer}}"><button class="btn" data-mid="{{item.fmid}}" data-event-opts="{{[['tap',[['transferMoney',['$event']]]]]}}" bindtap="__e">转余额</button></block><block s-if="{{btnauth.scoreTransfer}}"><button class="btn" data-mid="{{item.fmid}}" data-event-opts="{{[['tap',[['transferScore',['$event']]]]]}}" bindtap="__e">转积分</button></block><button class="btn" data-name="{{item.groupname}}" data-mid="{{item.fmid}}" data-event-opts="{{[['tap',[['showChangeGroupModal',['$event']]]]]}}" catchtap="__e">{{(item.groupname?'转换':'加入')+"分组"}}</button><block s-if="{{btnauth.moneyTransfer||btnauth.scoreTransfer}}"><button class="btn" data-url="{{'transferlog?fmid='+item.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账明细</button></block></view></view></block></block></view></block><block s-if="{{datalist.length==0}}"><view class="nomore">-暂无好友-</view></block></view><view class="box"><view class="title flex-sb"><view class="bold">我的分组</view><block s-if="{{btnauth.addFriend}}"><view data-event-opts="{{[['tap',[['showGroupModal',['$event']]]]]}}" style="{{'color:'+($root.m1)+';'}}" bindtap="__e">添加分组</view></block></view><block s-if="{{groupList.length>0}}"><view class="groupbox"><block s-for="groupList trackBy index" s-for-item="item" s-for-index="index"><block><view class="group-item"><view class="flex-s tag" data-index="{{index}}" data-event-opts="{{[['tap',[['changeGroupShow',['$event']]]]]}}" bindtap="__e"><block s-if="{{item.is_show}}"><image class="down" src="{{pre_url+'/static/img/location/down-grey.png'}}"></image></block><block s-else><image class="down" src="{{pre_url+'/static/img/location/right-grey.png'}}"></image></block><text>{{item.name+"("+item.friend_num+")"}}</text></view><block s-if="{{item.friend_num>0&&item.is_show}}"><view class="group-list"><block s-for="item.list trackBy index1" s-for-item="item1" s-for-index="index1"><block><view class="item flex-sb"><view class="left"><image class="headimg" src="{{item1.headimg}}"></image><view class="info"><view class="nickname txthide">{{item1.nickname}}</view><view class="desc">{{"等级："+item1.levelname}}</view><view class="remark txthide">{{"备注："+item1.remark}}</view></view></view><view class="right"><block s-if="{{btnauth.moneyTransfer}}"><button class="btn" data-mid="{{item1.fmid}}" data-event-opts="{{[['tap',[['transferMoney',['$event']]]]]}}" bindtap="__e">转余额</button></block><block s-if="{{btnauth.scoreTransfer}}"><button class="btn" data-mid="{{item1.fmid}}" data-event-opts="{{[['tap',[['transferScore',['$event']]]]]}}" bindtap="__e">转积分</button></block><button class="btn" data-name="{{item1.groupname}}" data-mid="{{item1.fmid}}" data-event-opts="{{[['tap',[['showChangeGroupModal',['$event']]]]]}}" catchtap="__e">转换分组</button><block s-if="{{btnauth.moneyTransfer||btnauth.scoreTransfer}}"><button class="btn" data-url="{{'transferlog?fmid='+item1.fmid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">转账明细</button></block></view></view></block></block></view></block></view></block></block></view></block><block s-if="{{groupList.length==0}}"><view class="nomore">-暂无分组-</view></block></view><block s-if="{{isshowAddModal}}"><view class="popup__container add_modal"><view data-event-opts="{{[['tap',[['hideAddModal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择添加方式</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideAddModal',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><view data-event-opts="{{[['tap',[['toaddFriend',['$event']]]]]}}" class="add_method" bindtap="__e"><image src="{{pre_url+'/static/img/dark-search.png'}}"></image>查找</view><block s-if="{{platform=='mp'||platform=='wx'}}"><view data-event-opts="{{[['tap',[['saoyisao',['$event']]]]]}}" class="add_method" bindtap="__e"><image src="{{pre_url+'/static/img/dark-scan.png'}}"></image>扫码</view></block><view data-event-opts="{{[['tap',[['showqrcode',['$event']]]]]}}" class="add_method" bindtap="__e"><image src="{{pre_url+'/static/img/dark-qrcode.png'}}"></image>我的二维码</view></view></view></view></block><block s-if="{{isshowQrcodeModal}}"><view class="popup__container add_modal qrcode_modal"><view data-event-opts="{{[['tap',[['hideQrcodeModal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">我的二维码</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideQrcodeModal',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content qrcode_box"><view><image src="{{friendQrcode}}"></image></view><view class="tips">扫一扫加好友</view></view></view></view></block><block s-if="{{isshowGroupModal}}"><view class="popup__container group_modal"><view data-event-opts="{{[['tap',[['hideGroupModal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">添加分组</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideGroupModal',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><view class="form-item"><view class="form-label">分组名称</view><view class="form-value"><input type="text" placeholder="请输入分组名称" placeholder-style="font-size:26rpx;color:#bbb" data-event-opts="{{[['input',[['__set_model',['','groupname','$event',[]]]]]]}}" value="{{groupname}}" bindinput="__e"/></view></view><view class="bottom"><view data-event-opts="{{[['tap',[['hideGroupModal',['$event']]]]]}}" class="btn cancel" catchtap="__e">取消</view><view data-event-opts="{{[['tap',[['addGroup',['$event']]]]]}}" class="btn ok" bindtap="__e">确定</view></view></view></view></view></block><block s-if="{{isshowChangeGroupModal}}"><view class="popup__container group_modal popup_store"><view data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">转换分组</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block s-if="{{oldGroupName!=''}}"><view class="form-item"><view class="form-label">现在分组</view><view class="form-value form-txt">{{''+oldGroupName+''}}</view></view></block><view class="form-item"><view class="form-label">好友分组</view><view class="form-value "><picker class="picker" name="store_id" range="{{groupList}}" range-key="name" data-event-opts="{{[['change',[['pickerChange',['$event']]]]]}}" bindchange="__e"><view class="pickerbox"><view class="{{['uni-input',newGroupId>0?'':'hui']}}">{{newGroupName?newGroupName:'请选择分组'}}</view><image class="img" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></picker></view></view><view class="bottom"><view data-event-opts="{{[['tap',[['hideChangeGroupModal',['$event']]]]]}}" class="btn cancel" catchtap="__e">取消</view><view data-event-opts="{{[['tap',[['changeGroup',['$event']]]]]}}" class="btn ok" bindtap="__e">确定</view></view></view></view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="47e51ea2-1"></loading></block><popmsg class="vue-ref" vue-id="47e51ea2-2" data-ref="popmsg"></popmsg><wxxieyi vue-id="47e51ea2-3"></wxxieyi></view>