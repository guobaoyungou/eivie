<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{userlevel&&userlevel.team_month_data==1}}"><view class="topsearch flex-y-center"><text class="t1">日期筛选：</text><view data-event-opts="{{[['tap',[['toCheckDate',['$event']]]]]}}" class="body_data" style="min-width:200rpx;height:100rpx;" bindtap="__e">{{''+(startDate?startDate:'点击选择日期')+(endDate?' 至 '+endDate:'')+''}}</view><view class="t_date"><block s-if="{{startDate}}"><view data-event-opts="{{[['tap',[['clearDate',['$event']]]]]}}" class="x1" bindtap="__e">清除</view></block></view></view></block><block s-if="{{team_auth==1&&userlevel&&userlevel.team_month_data==1}}"><view class="topsearch flex-y-center"><text class="t1">身份筛选：</text><view data-event-opts="{{[['tap',[['chooseLevel',['$event']]]]]}}" class="t2" bindtap="__e"><input type="text" placeholder="请选择级别" name="checkLevelid" placeholder-style="font-size:28rpx;color: #686868;font-family: PingFang SC;" disabled="true" value="{{checkLevelname}}"/></view></view></block><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"剩余数量："+couponnum+" 张"}}</text></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view data-event-opts="{{[['tap',[['toteam',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="f1" bindtap="__e"><image src="{{item.headimg}}"></image><view class="t2"><text class="x1">{{item.nickname}}</text><text class="x2">{{item.createtime}}</text><text class="x2">{{"等级："+item.levelname}}</text><block s-if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block s-if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block></view></view><view class="f2"><view class="t3"><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['showdialog',['$event']]]]]}}" bindtap="__e">发放</button></view></view></view></block></block></view></block><block s-if="{{dialogShow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['showdialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">优惠券发放</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['showdialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content invoiceBox"><form report-submit="true" data-event-opts="{{[['submit',[['sendCoupon',['$event']]]],['reset',[['formReset',['$event']]]]]}}" bindsubmit="__e" bindreset="__e"><view class="orderinfo"><view class="item"><text class="t1">剩余数量</text><view class="t2">{{''+couponnum+' 张'}}</view></view><view class="item"><text class="t1">发放数量</text><input class="t2" type="text" placeholder="请输入发放数量" placeholder-style="font-size:28rpx;color:#BBBBBB" name="send_num" disabled="{{inputDisabled}}" value=""/></view></view><button class="ff_btn" style="{{'background:'+($root.m2)+';'}}" form-type="submit">确定</button><view style="padding-top:30rpx;"></view></form></view></view></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="f1d65fc6-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="f1d65fc6-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="f1d65fc6-3"></loading></block><dp-tabbar vue-id="f1d65fc6-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="f1d65fc6-5" data-ref="popmsg"></popmsg></view>