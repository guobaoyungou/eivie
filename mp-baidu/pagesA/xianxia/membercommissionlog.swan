<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="d48534ce-1" itemdata="{{['待打款','待确定','完成','异议']}}" itemst="{{['0','1','2','3']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="title" style="line-height:40rpx;">打款上级</view><view class="f1"><image src="{{item.s_headimg}}"></image><view class="t2" style="flex:1;"><text class="x1">{{item.s_nickname+"(ID:"+item.mid+")"}}</text><text class="x1">{{"等   级："+item.s_levelname}}</text><block s-if="{{item.s_tel}}"><text class="x1">{{"手机号："+item.s_tel}}</text></block></view><view class="t2" style="{{('color:'+$root.m0)}}">{{"发放金额："+item.commission}}</view></view><view class="f2"><view class="t1">{{''+item.remark+''}}</view><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m1+' 0%,rgba('+$root.m2+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toSendCommission',['$event']]]]]}}" bindtap="__e">查看凭证</button></view></view></block></block></view></block><block s-if="{{nomore}}"><nomore vue-id="d48534ce-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="d48534ce-3"></nodata></block></block></block><block s-if="{{showsend}}"><view class="posterDialog"><view class="main"><view data-event-opts="{{[['tap',[['posterDialogClose',['$event']]]]]}}" class="close" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/close.png'}}"></image></view><view class="content"><image class="img" src="{{posterpic}}" mode="widthFix" data-url="{{posterpic}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></view></block><block s-if="{{loading}}"><loading vue-id="d48534ce-4"></loading></block><dp-tabbar vue-id="d48534ce-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="d48534ce-6" data-ref="popmsg"></popmsg></view>