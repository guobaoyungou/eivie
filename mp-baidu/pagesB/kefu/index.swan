<view class="container"><block s-if="{{isload}}"><block><view class="message-list"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><block s-if="{{item.formatTime}}"><view class="message-time">{{item.formatTime}}</view></block><block s-if="{{item.isreply==1}}"><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'}}"><image class="message-avatar" mode="aspectFill" src="{{item.uheadimg}}"></image><view class="message-text-left"><view class="arrow-box arrow-left"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-white.png'}}"></image></view><view class="message-text"><parse vue-id="{{'465b5fb8-1-'+index}}" content="{{item.content}}"></parse></view></view></view></block><block s-else><view class="message-item" style="{{'padding-bottom:'+(index==datalist.length-1?'100rpx':'')+';'+('justify-content:'+('flex-end')+';')}}"><view class="message-text-right"><view class="arrow-box arrow-right"><image class="arrow-icon" src="{{pre_url+'/static/img/arrow-green.png'}}"></image></view><view class="message-text"><parse vue-id="{{'465b5fb8-2-'+index}}" content="{{item.content}}"></parse></view></view><image class="message-avatar" mode="aspectFill" src="{{item.headimg}}"></image></view></block></block></block></view><view class="input-box notabbarbot" id="input-box"><view class="input-form"><image class="pic-icon" src="{{pre_url+'/static/img/msg-pic.png'}}" data-event-opts="{{[['tap',[['sendimg',['$event']]]]]}}" bindtap="__e"></image><textarea class="textarea" confirmHold="{{true}}" confirmType="send" cursor-spacing="30" type="text" maxlength="-1" data-event-opts="{{[['confirm',[['sendMessage',['$event']]]],['focus',[['onInputFocus',['$event']]]],['input',[['messageChange',['$event']]]]]}}" value="{{message}}" bindconfirm="__e" bindfocus="__e" bindinput="__e"></textarea><image class="face-icon" src="{{pre_url+'/static/img/face-icon.png'}}" data-event-opts="{{[['tap',[['toggleFaceBox',['$event']]]]]}}" bindtap="__e"></image><block s-if="{{trimMessage}}"><button data-event-opts="{{[['tap',[['sendMessage',['$event']]]]]}}" class="send-button-active" style="{{'background:'+($root.m0)+';'}}" bindtap="__e">发送</button></block></view><block s-if="{{faceshow}}"><wxface bind:selectface="__e" vue-id="465b5fb8-3" data-event-opts="{{[['^selectface',[['selectface']]]]}}"></wxface></block></view><view class="{{['anit '+(msgtipsShow==1?'show':msgtipsShow==2?'hide':'')]}}" data-url="{{'index?bid='+msgtips.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{msgtips.unickname+"："+msgtips.content}}</view></block></block><block s-if="{{loading}}"><loading vue-id="465b5fb8-4"></loading></block><popmsg class="vue-ref" vue-id="465b5fb8-5" data-ref="popmsg"></popmsg></view>