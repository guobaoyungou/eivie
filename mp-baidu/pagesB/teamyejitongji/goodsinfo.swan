<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-if="{{st==0}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.name}}</text><block s-if="{{set_tongji.slje==2||set_tongji.slje==3}}"><text class="t2">{{"商品金额："+item.real_totalprice+"元"}}</text></block><block s-if="{{set_tongji.slje==1||set_tongji.slje==3}}"><text class="t2">{{"商品数量："+item.num}}</text></block></view></view></block></block></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="0286ff94-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="0286ff94-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="0286ff94-3"></loading></block><dp-tabbar vue-id="0286ff94-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0286ff94-5" data-ref="popmsg"></popmsg></view>