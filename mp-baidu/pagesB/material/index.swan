<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="125f30fa-1" itemdata="{{['图片','视频']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="content-container"><view class="nav_left"><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['nav_left_items '+(curIndex==index?'active':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>{{item.name+''}}</view></block></block></view><view class="nav_right"><view class="nav_right-content"><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><view class="product-itemlist"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><block s-if="{{item.ctype==0}}"><image class="image" src="{{item.url}}" mode="widthFix"></image></block><block s-else><block s-if="{{item.ctype==1}}"><image class="image" src="{{item.cover}}" mode="widthFix"></image></block></block></view></block></view><block s-if="{{nomore}}"><nomore vue-id="125f30fa-2" text="没有更多商品了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="125f30fa-3" text="暂无相关商品"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="125f30fa-4"></loading></block><dp-tabbar vue-id="125f30fa-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="125f30fa-6" data-ref="popmsg"></popmsg></view>