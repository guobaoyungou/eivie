<view class="container"><block s-if="{{isload}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="content " data-id="{{item.id}}" data-name="{{item.name}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchtap="__e"><view class="flex" style="justify-content:space-between;"><view class="f1"><view class="headimg"><block s-if="{{item.logo}}"><image src="{{item.logo}}"></image></block><block s-else><image src="{{pre_url+'/static/img/touxiang.png'}}"></image></block></view><view class="text1"><text class="t1">{{item.name+''}}</text></view></view><view class="yuyue">选择</view></view><view>{{''+item.address+''}}</view></view></block><block s-if="{{nodata}}"><nodata vue-id="0e922e74-1"></nodata></block><view style="height:140rpx;"></view></block></block><block s-if="{{loading}}"><loading vue-id="0e922e74-2"></loading></block><dp-tabbar vue-id="0e922e74-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="0e922e74-4" data-ref="popmsg"></popmsg></view>