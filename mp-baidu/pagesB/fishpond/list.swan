<view class="container"><view class="search-container"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索你感兴趣的鱼塘" placeholder-style="font-size:24rpx;color:#C2C2C2" confirm-type="search" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view></view><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="product-item2" data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><text class="iconfont icondingwei" style="color:#888;"></text><block s-if="{{item.address}}"><text class="t2" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-company="{{item.name}}" data-address="{{item.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" catchtap="__e">{{item.address}}</text></block></view><view class="p2"><image class="img-tel" src="{{pre_url+'/static/img/b_tel.png'}}"></image><text class="t2" data-phone="{{item.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" catchtap="__e">{{item.tel}}</text></view></view><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="3205491a-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="3205491a-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="3205491a-3"></loading></block><dp-tabbar vue-id="3205491a-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="3205491a-5" data-ref="popmsg"></popmsg></view>