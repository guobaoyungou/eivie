<view class="container"><view class="qd_guize"><view class="gztitle">— 第<text class="t2">{{bonuscount}}</text>期 奖励排名 —</view><view class="desc">前10名奖励排行榜</view><view class="paiming"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item flex"><view class="f1"><image class="headimg" src="{{item.headimg}}"></image><text class="t1">{{item.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+item.money+''}}</text><text class="t2">元</text></view></view></block></view><block s-if="{{userinfo.money}}"><view class="item item2 flex"><view class="f1"><image class="headimg" src="{{userinfo.headimg}}"></image><text class="t1">{{userinfo.nickname}}</text></view><view class="f2"><text class="t2">获得金额</text><text class="t1" style="font-weight:bold;">{{''+userinfo.money+''}}</text><text class="t2">元</text></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="201ba66d-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="201ba66d-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="201ba66d-3"></loading></block><dp-tabbar vue-id="201ba66d-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="201ba66d-5" data-ref="popmsg"></popmsg></view>