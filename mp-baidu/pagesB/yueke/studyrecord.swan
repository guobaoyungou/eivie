<view class="container"><block s-if="{{isload}}"><block><view style="width:100%;height:10rpx;"></view><view class="order-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><view>{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><block s-if="{{item.$orig.status==0&&item.$orig.start_study_time==''}}"><text class="st3">待预约</text></block><block s-if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><text class="st1">待上课</text></block><block s-if="{{item.$orig.status==1}}"><text class="st3">上课中</text></block><block s-if="{{item.$orig.status==2}}"><text class="st4">已完成</text></block><block s-if="{{item.$orig.status==3}}"><text class="st4">已退款</text></block></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{$root.m0+"："+item.$orig.workerinfo.realname+" "+(item.$orig.workerinfo.dengji||'')}}</text><block s-if="{{item.$orig.start_study_time}}"><text class="t2">{{"开课时间："+item.$orig.start_study_time}}</text></block><block s-if="{{item.$orig.hx_time}}"><text class="t2">{{"结束时间："+item.$orig.hx_time}}</text></block></view><block s-if="{{item.$orig.comment}}"><view class="comment"><text class="t2">{{item.m1+"点评："+item.$orig.comment}}</text></view></block></view><view class="op"><block s-if="{{item.$orig.status==1}}"><view class="btn1" style="{{'background:'+(item.m2)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" bindtap="__e">上课完成</view></block><block s-if="{{item.$orig.status==0&&item.$orig.start_study_time!=''}}"><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" bindtap="__e">取消</view></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="5823804c-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="5823804c-2" text="暂无学习记录"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="5823804c-3"></loading></block><dp-tabbar vue-id="5823804c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5823804c-5" data-ref="popmsg"></popmsg></view>