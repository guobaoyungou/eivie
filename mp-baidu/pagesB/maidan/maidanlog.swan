<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'maidandetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.paytime}}</text><text class="t2">{{"订单编号："+item.ordernum}}</text><text class="t2">{{"支付方式："+item.paytype}}</text><block s-if="{{canrefund&&item.refund_money>0}}"><text class="t2">{{"退款金额：￥"+item.refund_money}}</text></block><block s-if="{{item.mendian_name&&item.mdid>0}}"><text class="t2">{{"所属门店："+item.mendian_name}}</text></block></view><view class="f2"><text class="t1">{{"-￥"+item.money}}</text></view></view></block></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="53abb50f-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="53abb50f-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="53abb50f-3"></loading></block><dp-tabbar vue-id="53abb50f-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="53abb50f-5" data-ref="popmsg"></popmsg></view>