<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="80c5aa56-1" itemdata="{{['全部','待使用','已完成']}}" itemst="{{['all','0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="head"><block s-if="{{item.bid!=0&&item.binfo}}"><view class="f1" data-url="{{'/pagesExt/business/index?id='+item.bid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.binfo.name}}</view></block><block s-else><view>{{"订单号："+item.ordernum}}</view></block><view class="flex1"></view><block s-if="{{item.status==0}}"><text class="st0">待使用</text></block><block s-if="{{item.status==1}}"><text class="st1">已完成</text></block></view><view class="content" style="border-bottom:none;"><view><image src="{{item.propic}}"></image></view><view class="detail"><text class="t1">{{item.proname}}</text><text class="t1"><block s-if="{{item.num}}"><text>{{"数量:"+item.num}}</text></block></text><view class="t3"><text class="x1 flex1">{{"实付金额：￥"+item.totalprice}}</text></view></view></view><view class="op"><block s-if="{{item.status==0}}"><block><view class="btn2" data-hexiao_qr="{{item.hexiao_qr}}" data-event-opts="{{[['tap',[['showhxqr',['$event']]]]]}}" bindtap="__e">核销码</view></block></block></view></view></block></block></view><uni-popup class="vue-ref" vue-id="80c5aa56-2" id="dialogHxqr" type="dialog" data-ref="dialogHxqr" vue-slots="{{['default']}}"><view class="hxqrbox"><image class="img" src="{{hexiao_qr}}" data-url="{{hexiao_qr}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="txt">请出示核销码给核销员进行核销</view><view data-event-opts="{{[['tap',[['closeHxqr',['$event']]]]]}}" class="close" bindtap="__e"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/close2.png'}}"></image></view></view></uni-popup><block s-if="{{nomore}}"><nomore vue-id="80c5aa56-3"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="80c5aa56-4"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="80c5aa56-5"></loading></block><dp-tabbar vue-id="80c5aa56-6" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="80c5aa56-7" data-ref="popmsg"></popmsg></view>