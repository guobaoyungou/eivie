<view class="container"><block s-if="{{isload}}"><block><view class="search-container"><view class="title-box"><view>活动报名列表</view></view></view><view class="content-container"><view class="nav_left"><view class="{{['nav_left_items '+(curIndex==-1?'active':'')]}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m0)+';'}}"></view>全部</view><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['nav_left_items '+(curIndex==index?'active':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchRightTab',['$event']]]]]}}" bindtap="__e"><view class="before" style="{{'background:'+($root.m1)+';'}}"></view>{{item.name}}</view></block></block></view><view class="nav_right"><view class="nav_right-content"><block s-if="{{curIndex>-1&&clist[curIndex].child.length>0}}"><view class="classify-ul"><view class="flex" style="width:100%;overflow-y:hidden;overflow-x:scroll;"><view class="classify-li" style="{{(curIndex2==-1?'color:'+$root.m2+';background:rgba('+$root.m3+',0.2)':'')}}" data-id="{{clist[curIndex].id}}" data-index="-1" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" bindtap="__e">全部</view><block s-for="$root.l0 trackBy idx2" s-for-item="item" s-for-index="idx2"><block><view class="classify-li" style="{{(curIndex2==idx2?'color:'+item.m4+';background:rgba('+item.m5+',0.2)':'')}}" data-id="{{item.$orig.id}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" bindtap="__e">{{item.$orig.name}}</view></block></block></view></view></block><scroll-view class="classify-box" scroll-y="true" data-event-opts="{{[['scrolltolower',[['scrolltolower',['$event']]]]]}}" bindscrolltolower="__e"><view class="product-itemlist"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="item" data-type="{{item.type?item.type:0}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1"><text>{{item.name}}</text></view><view class="p2"><view class="t1" style="{{'color:'+($root.m6)+';'}}">{{item.sell_price}}<text style="font-size:24rpx;padding-left:2px;">元</text></view></view><view class="p3"><block s-if="{{item.sales>0}}"><view class="p3-1"><text style="overflow:hidden;">{{"已售"+item.sales+"件"}}</text></view></block></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="aaecf8ae-1" text="没有更多活动了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="aaecf8ae-2" text="暂无相关活动"></nodata></block><view style="width:100%;height:100rpx;"></view></scroll-view></view></view></view><block s-if="{{buydialogShow}}"><buydialog vue-id="aaecf8ae-3" proid="{{proid}}" menuindex="{{menuindex}}" data-event-opts="{{[['^buydialogChange',[['buydialogChange']]]]}}" bind:buydialogChange="__e"></buydialog></block></block></block><block s-if="{{loading}}"><loading vue-id="aaecf8ae-4" loadstyle="left:62.5%"></loading></block><dp-tabbar vue-id="aaecf8ae-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="aaecf8ae-6" data-ref="popmsg"></popmsg></view>