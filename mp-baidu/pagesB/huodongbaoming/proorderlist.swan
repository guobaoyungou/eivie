<view class="container"><block s-if="{{isload}}"><block><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">报名列表</text></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><image src="{{item.$orig.headimg}}"></image><view class="t2"><text class="x1">{{item.$orig.nickname}}</text><text class="x2">{{item.m0}}</text><block s-for="item.$orig.formdata trackBy index" s-for-item="items" s-for-index="__i0__"><view><text class="x1" style="margin-right:5px;">{{items[0]+":"}}</text><block s-if="{{items[2]=='upload'}}"><view class="x1"><image style="width:400rpx;height:auto;" src="{{items[1]}}" mode="widthFix" data-url="{{items[1]}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block><block s-else><text class="x1" user-select="true" selectable="true">{{items[1]}}</text></block></view></block></view></view></view></block></block></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="139238ea-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="139238ea-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="139238ea-3"></loading></block><dp-tabbar vue-id="139238ea-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="139238ea-5" data-ref="popmsg"></popmsg></view>