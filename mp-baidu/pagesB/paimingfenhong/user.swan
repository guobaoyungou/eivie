<view class="container"><block s-if="{{isload}}"><block><view class="banner" style="{{'background:'+('linear-gradient(180deg,'+$root.m0+' 0%,rgba('+$root.m1+',0) 100%)')+';'}}"></view><view class="user"><image src="{{userinfo.headimg}}" background-size="cover"></image><view class="info"><text class="nickname">{{userinfo.nickname}}</text><view class="f2"><text>{{"点位："+other_data.my_point_count+"个"}}</text><text>{{"已完成点位："+other_data.finish_count+"个"}}</text></view></view></view><view class="contentdata"><view class="data"><view class="data_module flex"><view class="flex1" data-url="/pagesB/paimingfenhong/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="data_value">{{userinfo.paiming_fenhong_money}}</view><view class="data_lable">分红转出</view></view><view class="flex1"><view class="data_value">{{other_data.my_totalprice}}</view><view class="data_lable">消费总额</view></view><view class="border"></view><view class="flex1"><view class="data_value">{{other_data.yesterday_totalprice}}</view><view class="data_lable">昨日营业额</view></view><view class="flex1"><view class="data_value">{{other_data.yesterday_money}}</view><view class="data_lable">昨日分红</view></view></view></view><view class="data1"><view class="title1">我的今日排名:<block s-if="{{other_data.my_point_order}}"><text>{{other_data.my_point_order+"位"}}</text></block><block s-else><text class="t2">暂无</text></block></view><view class="title2">{{"当前排位总计"+other_data.record_count+"人"}}</view></view><view class="data"><view class="data_module "><view class="search"><picker class="picker" mode="date" value="{{date}}" start="{{startDate}}" end="{{endDate}}" data-event-opts="{{[['change',[['bindDateChange',['$event']]]]]}}" bindchange="__e"><view class="uni-input">{{date}}</view></picker><button data-event-opts="{{[['tap',[['dataSearch',['$event']]]]]}}" bindtap="__e">查询</button></view><view class="title"><view class="border"></view><view>分红记录</view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t1">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{item.money}}</text></block><block s-if="{{item.money<0}}"><text class="t1">{{"-"+item.money}}</text></block></view></view></block></view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="535ebcc2-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="535ebcc2-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="535ebcc2-3"></loading></block><dp-tabbar vue-id="535ebcc2-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="535ebcc2-5" data-ref="popmsg"></popmsg></view>