<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="content" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchtap="__e"><view class="f1"><text class="t1">{{item.$orig.name}}</text><text class="t2">{{item.$orig.tel}}</text><block s-if="{{item.$orig.company}}"><text class="t2">{{item.$orig.company}}</text></block><text class="flex1"></text><image class="t3" src="{{pre_url+'/static/img/edit.png'}}" data-url="{{'addressadd?id='+item.$orig.id+'&type='+(item.$orig.latitude>0?'1':'0')}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"></image></view><view class="f2">{{item.$orig.area+" "+item.$orig.address}}</view><view class="f3"><view class="flex-y-center"><view class="radio" style="{{(item.$orig.isdefault?'border:0;background:'+item.m0:'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view class="mrtxt">{{item.$orig.isdefault?'默认地址':'设为默认'}}</view></view><view class="flex1"></view><view class="del" style="{{'color:'+($root.m1)+';'}}" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['del',['$event']]]]]}}" catchtap="__e">删除</view></view></view></block><block s-if="{{nodata}}"><nodata vue-id="2a351e45-1"></nodata></block><view style="height:140rpx;"></view><block s-if="{{$root.m2}}"><block><view class="{{['btn-add2',menuindex>-1?'tabbarbot':'notabbarbot3']}}" style="{{('background:linear-gradient(90deg,'+$root.m3+' 0%,rgba('+$root.m4+',0.8) 100%)')}}" data-url="{{'addressadd?type='+type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:28rpx;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>添加地址</view><view data-event-opts="{{[['tap',[['getweixinaddress',['$event']]]]]}}" class="{{['btn-add3',menuindex>-1?'tabbarbot':'notabbarbot3']}}" style="{{('background:linear-gradient(90deg,'+$root.m5+' 0%,rgba('+$root.m6+',0.8) 100%)')}}" bindtap="__e"><image style="width:28rpx;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>获取微信地址</view></block></block><block s-else><block><view class="{{['btn-add',menuindex>-1?'tabbarbot':'notabbarbot3']}}" style="{{('background:linear-gradient(90deg,'+$root.m7+' 0%,rgba('+$root.m8+',0.8) 100%)')}}" data-url="{{'addressadd?type='+type}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image style="width:28rpx;height:28rpx;margin-right:6rpx;" src="{{pre_url+'/static/img/add.png'}}"></image>添加地址</view></block></block></block></block><block s-if="{{loading}}"><loading vue-id="2a351e45-2"></loading></block><dp-tabbar vue-id="2a351e45-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="2a351e45-4" data-ref="popmsg"></popmsg><wxxieyi vue-id="2a351e45-5"></wxxieyi></view>