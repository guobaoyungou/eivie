<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="e5387966-1" itemdata="{{['全部','已发放','未发放']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f2"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><block s-if="{{item.$orig.frommid>0}}"><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></block></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block s-if="{{item.$orig.status==0}}"><block><block s-if="{{item.$orig.orderstatus==1||item.$orig.orderstatus==2}}"><text class="dior-sp6 yfk">已付款</text></block><block s-if="{{item.$orig.orderstatus==0}}"><text class="dior-sp6 dfk">待付款</text></block><block s-if="{{item.$orig.orderstatus==3}}"><text class="dior-sp6 ywc">待发放</text></block><block s-if="{{item.$orig.orderstatus==4}}"><text class="dior-sp6 ygb">已关闭</text></block></block></block><block s-if="{{item.$orig.status==1}}"><block><text class="dior-sp6 yfk">已发放</text></block></block></view></view><block s-if="{{item.$orig.goods&&item.$orig.goods.name}}"><view class="goodsinfo  flex"><view class="x1 flex"><image class="img" src="{{item.$orig.goods.pic}}"></image><view style="margin-left:20rpx;"><view class="x1t name">{{item.$orig.goods.name}}</view><view class="x1t" style="color:red;">{{"￥"+item.$orig.goods.sell_price}}</view><view class="x1t" style="color:#616161;">{{item.$orig.goods.createtime}}</view></view></view><view>{{"共"+item.$orig.goods.num+"件"}}</view></view></block></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="e5387966-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="e5387966-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="e5387966-4"></loading></block><dp-tabbar vue-id="e5387966-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="e5387966-6" data-ref="popmsg"></popmsg></view>