<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="a34c1cfa-1" itemdata="{{['全部','审核中','已审核','已驳回','已打款']}}" itemst="{{['all','0','1','2','3']}}" st="{{st}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="listrow"><view class="item"><view class="f1"><text class="t1">{{"提现"+$root.m0+"："+item.score}}<text class="money" style="{{'color:'+($root.m1)+';'}}">{{"(￥"+item.money+")"}}</text></text><text class="t2">{{item.showtime}}</text></view><view class="f3"><block s-if="{{item.status==0}}"><text class="st0">审核中</text></block><block s-if="{{item.status==1}}"><text class="st1">已审核</text></block><block s-if="{{item.status==2}}"><text class="st2">已驳回</text></block><block s-if="{{item.status==3}}"><text class="st3">已打款</text></block></view></view><block s-if="{{item.status==2&&item.reason}}"><view class="tips">{{item.reason}}</view></block></view></block></view><block s-if="{{nomore}}"><nomore vue-id="a34c1cfa-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="a34c1cfa-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="a34c1cfa-4"></loading></block><dp-tabbar vue-id="a34c1cfa-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="a34c1cfa-6" data-ref="popmsg"></popmsg></view>