<view class="container"><block s-if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">设备数量</view><view class="f2"><text style="font-size:26rpx;"></text>{{possn_num}}</view><view class="f1">奖励利率<text style="font-size:26rpx;"></text>{{pos_score_ratio+"%"}}</view></view><view class="content2"><block><view class="item3"><view class="f1">姓 名:</view><view class="f2"><input style="font-size:30rpx;" type="text" name="realname" placeholder="请输入姓名" placeholder-style="color:#999;font-size:30rpx" data-event-opts="{{[['input',[['realnameinput',['$event']]]]]}}" value="{{realname}}" bindinput="__e"/></view></view></block><block><view class="item3"><view class="f1">手机号:</view><view class="f2"><input style="font-size:30rpx;" type="text" name="phone" placeholder="请输入手机号" placeholder-style="color:#999;font-size:30rpx" data-event-opts="{{[['input',[['phoneinput',['$event']]]]]}}" value="{{phone}}" bindinput="__e"/></view></view></block><block><view class="item3"><view class="f1">设备SN:</view><view class="f2"><input style="font-size:30rpx;" type="text" name="possn" placeholder="请输入设备SN" placeholder-style="color:#999;font-size:30rpx" data-event-opts="{{[['input',[['possninput',['$event']]]]]}}" bindinput="__e"/></view></view></block><block s-if="{{desc}}"><block><view class="item3"><view class="f1">操作指引:</view><view class="f2" style="width:75%;">{{''+desc+''}}</view></view></block></block></view><view class="op"><view data-event-opts="{{[['tap',[['tobind',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">绑定</view></view><view class="content"><view class="content-title-view" style="{{'color:'+($root.m2)+';'}}">设备列表</view><block s-for="possn_list trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f2"><text class="t1" style="{{'color:'+($root.m3)+';'}}">{{index+1}}</text></view><view class="f1"><text class="t1">{{item.possn}}</text><block s-if="{{item.status==0}}"><text class="t2">审核中</text></block><block s-if="{{item.status==1}}"><text class="t2">已通过</text></block><block s-if="{{item.status==2}}"><text class="t2">已驳回</text></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="b72aa810-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="b72aa810-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="b72aa810-3"></loading></block><dp-tabbar vue-id="b72aa810-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="b72aa810-5" data-ref="popmsg"></popmsg></view>