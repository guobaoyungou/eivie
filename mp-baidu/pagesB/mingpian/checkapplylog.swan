<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1" style="width:100%;">联系信息</view></view><block s-for="field_list trackBy index" s-for-item="item" s-for-index="index"><block><block s-if="{{item.isshow==1}}"><view class="form-item"><view class="f1">{{item.name}}</view><view class="f2"><radio-group><label data-event-opts="{{[['tap',[['changseeaddfields',[index,true]]]]]}}" bindtap="__e"><radio value="{{true}}" checked="{{seeaddfields[index]?true:false}}"></radio>展示</label><label data-event-opts="{{[['tap',[['changseeaddfields',[index,false]]]]]}}" style="margin-left:20rpx;" bindtap="__e"><radio value="{{false}}" checked="{{seeaddfields[index]?false:true}}"></radio>不展示</label></radio-group></view><view class="f3" style="color:#58e;font-size:24rpx;margin-left:6rpx;"></view></view></block></block></block></view><block s-if="{{log.applysee==1}}"><view style="margin-top:60rpx;display:flex;justify-content:space-between;width:680rpx;margin:0 auto;"><button class="savebtn" style="background:#fff;color:#212121;" form-type="submit2">驳回</button><button class="savebtn" form-type="submit">提交并同意</button></view></block><block s-else><block s-if="{{log.applysee==2}}"><view style="margin-top:60rpx;width:680rpx;margin:0 auto;"><button class="savebtn" style="width:100%;" form-type="submit">提交</button></view></block></block><view style="height:50rpx;"></view></form></block></block><view style="display:none;">{{test}}</view><block s-if="{{loading}}"><loading vue-id="201b1dcc-1"></loading></block><popmsg class="vue-ref" vue-id="201b1dcc-2" data-ref="popmsg"></popmsg><wxxieyi vue-id="201b1dcc-3"></wxxieyi></view>