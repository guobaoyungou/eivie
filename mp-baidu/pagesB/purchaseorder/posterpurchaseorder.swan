<view class="container"><view class="head flex-bt"><view>{{"有效期："+expiring_date}}</view><view class="totla-sum"><text>合计数量：</text><text class="total-number">{{count}}</text></view></view><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="product-item2" data-url="{{'/pages/shop/product?id='+item.proid+'&show_image=0'}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image src="{{item.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.name}}</view><view class="p3"><text class="t2">规格：</text><text class="t2">{{item.ggname}}</text></view><view class="p3"><text class="t2">数量：</text><text class="t2">{{item.num}}</text></view></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="2d593a48-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="2d593a48-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="2d593a48-3"></loading></block><dp-tabbar vue-id="2d593a48-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="2d593a48-5" data-ref="popmsg"></popmsg></view>