<view><block s-if="{{isload}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="daily-box"><view class="item" data-url="{{'/pagesB/daily/daily?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="top"><view class="left"><image class="douhao" src="{{pre_url+'/static/img/daily/yhleft.png'}}"></image></view><view class="content"><rich-text nodes="{{item.content}}"></rich-text></view><view class="right"><image class="douhao" src="{{pre_url+'/static/img/daily/yhright.png'}}"></image></view></view><view class="bottom"><view class="left"><image class="logo" src="{{item.shop_logo}}"></image><text class="ml20 txt">{{item.shop_name}}</text><text class="ml25 txt">{{item.fabutime}}</text></view><view class="btn">马上去听</view></view></view></view><view style="width:100%;height:20rpx;"></view></block></block></block></block><block s-if="{{nomore}}"><nomore vue-id="e4957914-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="e4957914-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="e4957914-3"></loading></block><dp-tabbar vue-id="e4957914-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="e4957914-5" data-ref="popmsg"></popmsg></view>