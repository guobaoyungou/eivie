<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="lists"><view class="t1">{{item.name}}</view><view><view class="t2">{{"规格: "+item.ggname}}</view><view class="t3 flex"><text>{{"件数: "+item.num}}</text><block s-if="{{item.refund_num&&item.refund_num>0}}"><text>{{"退款件数: "+item.refund_num}}</text></block></view></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="62e6f231-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="62e6f231-2"></nodata></block><view class="bottom"><block s-if="{{datainfo.status==0}}"><view data-event-opts="{{[['tap',[['shouhuo',['$event']]]]]}}" class="btn2" bindtap="__e">收货</view></block></view></block></block><block s-if="{{loading}}"><loading vue-id="62e6f231-3"></loading></block><dp-tabbar vue-id="62e6f231-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="62e6f231-5" data-ref="popmsg"></popmsg></view>