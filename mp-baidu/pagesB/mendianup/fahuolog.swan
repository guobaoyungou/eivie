<view><block s-if="{{isload}}"><block><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">{{"拣货单记录（共"+count+"条）"}}</text></view><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t2">{{"总件数："+item.$orig.number}}</text></view><view class="f2"><text class="t2">{{item.m0}}</text><block s-if="{{item.$orig.status==0}}"><text class="t3">未收货</text></block><block s-if="{{item.$orig.status==1}}"><text class="t3">已收货</text></block></view><view class="f3"><text class="t3 btn2" data-url="{{'/pagesB/mendianup/fahuoinfo?oid='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看</text><block s-if="{{item.$orig.status==0}}"><text data-event-opts="{{[['tap',[['shouhuo',['$0'],[[['datalist','',index,'id']]]]]]]}}" class="t3 btn2" bindtap="__e">收货</text></block></view></view></block></view></block><block s-if="{{nodata}}"><nodata vue-id="342c569b-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="342c569b-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="342c569b-3"></loading></block><popmsg class="vue-ref" vue-id="342c569b-4" data-ref="popmsg"></popmsg></view>