<view><block s-if="{{isload}}"><block><block s-if="{{datalist.length>0}}"><view class="initials-list-wrap"><scroll-view class="scroll-list" scroll-y="{{true}}" scroll-into-view="{{scrollViewId}}"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view><view class="letter" id="{{item.zimu}}">{{item.zimu}}</view><view class="con" data-city="{{item.city}}" data-event-opts="{{[['tap',[['search',['$event']]]]]}}" bindtap="__e"><view class="list-item">{{''+item.city}}</view></view></view></block></scroll-view><view class="{{['letter-list-bar',(touchmove)?'active':'']}}"><block s-for="letterList trackBy index" s-for-item="item" s-for-index="index"><text data-event-opts="{{[['tap',[['letterSelect',[index]]]]]}}" class="{{['text',(touchmoveIndex==index)?'active':'']}}" catchtap="__e">{{''+item+''}}</text></block></view><block s-if="{{touchmove}}"><view class="letter-alert">{{letterList[touchmoveIndex]+''}}</view></block></view></block><block s-if="{{nomore}}"><nomore vue-id="4780299c-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="4780299c-2" text></nodata></block><dp-chat-tabbar vue-id="4780299c-3" currentIndex="2"></dp-chat-tabbar></block></block><popmsg class="vue-ref" vue-id="4780299c-4" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="4780299c-5"></loading></block></view>