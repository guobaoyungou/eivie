<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="048015b4-1" itemdata="{{['排队中','已完成']}}" itemst="{{['0','1']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="order-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box"><view class="head"><view class="f1">{{"订单号："+item.$orig.ordernum}}</view><view class="flex1"></view><text class="st0">{{item.$orig.statusLabel}}</text></view><view class="content" style="border-bottom:none;"><view class="detail"><text class="t1">{{"商户名称："+item.$orig.bname}}</text></view><block s-if="{{item.$orig.title}}"><view class="detail">排队名称：<text class="t1" style="{{('color:'+item.m0)}}">{{item.$orig.title}}</text></view></block><view class="detail">排队金额：<text class="t1" style="{{('color:'+$root.m1)}}">{{item.$orig.money}}</text></view><view class="detail">已返金额：<text class="t1" style="{{('color:'+$root.m2)}}">{{item.$orig.money_give}}</text><block s-if="{{item.$orig.status==0&&set.quit_wxhb==1&&item.$orig.money_quit_hb>0}}"><text style="{{('color:'+item.m3+';margin-left: 30rpx;')}}" data-money="{{item.$orig.money_quit_hb}}" data-id="{{item.$orig.id}}" data-index="{{index}}" data-event-opts="{{[['tap',[['quitWithHb',['$event']]]]]}}" catchtap="__e">退出排队抽红包</text></block></view><block s-if="{{item.$orig.queue_no}}"><view class="detail">当前排名：<text class="t1" style="{{('color:'+item.m4)}}">{{item.$orig.queue_noLabel}}</text></view></block><view class="detail"><text class="t1">{{"排队时间："+item.$orig.createtimeFormat}}</text></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="048015b4-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="048015b4-3"></nodata></block></block></block><block s-if="{{prizeVisible}}"><view data-event-opts="{{[['touchmove',[['e0',['$event']]]],['mousewheel',[['',['$event']]]]]}}" class="page-view-hongbao" catchtouchmove="__e" bindmousewheel="__e"><view class="hongbao-view"><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view class="wrap"><view data-event-opts="{{[['tap',[['receive',['$event']]]]]}}" class="envelope" bindtap="__e"><image class="cover" src="{{pre_url+'/static/img/envelope.png'}}" mode="aspectFill"></image><image class="btn" src="{{pre_url+'/static/img/btn.png'}}" mode="aspectFill"></image></view></view><view data-event-opts="{{[['tap',[['hbclose',['$event']]]]]}}" class="hongbao-view-close" bindtap="__e"><image src="{{pre_url+'/static/img/close2.png'}}"></image></view></view><uni-popup class="vue-ref" bind:change="__e" vue-id="048015b4-4" data-ref="popup" data-event-opts="{{[['^change',[['']]]]}}" vue-slots="{{['default']}}"><view class="cl-popup"><view class="main"><image class="top" src="{{pre_url+'/static/img/popup-top.png'}}" mode="aspectFill"></image><image class="icon" src="{{pre_url+'/static/img/popup-icon.png'}}" mode="aspectFill"></image><image class="bottom" src="{{pre_url+'/static/img/popup-bottom.png'}}" mode="aspectFill"></image><view class="content"><view class="price"><text class="num">{{hbmoney}}</text><text class="unit">元</text></view><view class="title">{{''+hbtext+''}}</view><view class="cl-button"><text data-event-opts="{{[['tap',[['hbsuccess',['$event']]]]]}}" bindtap="__e">确定</text></view></view></view></view></uni-popup></view></block><block s-if="{{loading}}"><loading vue-id="048015b4-5"></loading></block><dp-tabbar vue-id="048015b4-6" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="048015b4-7" data-ref="popmsg"></popmsg></view>