<view class="container"><block s-if="{{isload}}"><block><block s-if="{{show_top==1}}"><view class="top-data-list flex flex-y-center" style="{{'background:'+($root.m0)+';'}}"><view class="data-options flex-col"><view class="title-text">最大份额</view><view class="num-text">{{set.max_green_score}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">已发放</view><view class="num-text">{{set.green_score_total}}</view></view><view class="line-class"></view><view class="data-options flex-col"><view class="title-text">剩余</view><view class="num-text">{{set.plate_remain_green_score}}</view></view></view></block><view class="myscore" style="{{'background:'+($root.m1)+';'}}"><view class="f1">{{"我的"+$root.m2}}</view><view class="f2">{{myscore}}<block s-if="{{set.open_withdraw==1}}"><view class="btn-mini" data-url="/pagesB/my/greenscoreWithdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">全部提取</view></block></view><view class="f1">{{"当前每个"+$root.m3+"价值"+set.green_score_price+"元"}}</view><block s-if="{{green_score_hb>0}}"><view class="f1">{{"已领增值红包"+green_score_hb+"元"}}</view></block></view><dd-tab vue-id="5ae06d2f-1" itemdata="{{[$root.m4+'列表','已完成记录']}}" itemst="{{['0','1']}}" st="{{is_withdraw}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-item"><view class="item-row" data-url="{{'/pagesB/my/greenscorelog?jilu_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="column"><text>{{"发放数量: "+item.value}}</text><text>{{"剩下数量: "+item.remain}}</text></view><block s-if="{{greenscore_max==1}}"><view class="column"><text>{{"封顶额度: "+(item.maximum_num||0)}}</text><text>{{"已扣额度: "+(item.dec_maximum||0)}}</text></view></block></view><view class="item-row highlight"><text>{{"可提取金额: "+item.green_score_value}}</text></view><view class="item-row"><text class="time">{{item.remark+" "+item.createtime}}</text><block s-if="{{withdraw_type==1&&set.open_withdraw==1}}"><block><block s-if="{{item.is_withdraw==0&&item.remain>0}}"><button class="btn-mini2" data-url="{{'/pagesB/my/greenscoreWithdraw?log_id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">提取</button></block><block s-else><button class="btn-mini3">已提取</button></block></block></block><block s-if="{{false}}"><block><button class="btn-mini2">查看明细</button></block></block></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="5ae06d2f-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="5ae06d2f-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="5ae06d2f-4"></loading></block><dp-tabbar vue-id="5ae06d2f-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="5ae06d2f-6" data-ref="popmsg"></popmsg></view>