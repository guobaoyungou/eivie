<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的佣金</view><view class="f2">{{my_commission}}</view><view class="f1">{{"当前每个"+$root.m1+"价值"+set.green_score_price+"元"}}</view><view class="f1">{{"我的"+$root.m2+"数量："+my_score}}</view></view><view class="content2"><view class="item2"><view class="f1">转入数量</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="integral" value="" placeholder="请输入转入数量" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><view class="item4"><text style="margin-right:10rpx;">{{set.commission_to_greenscore_desc}}</text></view></view><button class="btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">确定</button><view class="text-center" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{"返回"+$root.m4+"中心"}}</text></view></form></block></block><dp-tabbar vue-id="4729eea5-1" opt="{{opt}}"></dp-tabbar></view>