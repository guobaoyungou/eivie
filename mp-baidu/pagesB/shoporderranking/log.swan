<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view data-url="{{'detail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">{{'月份时间：'+item.month+''}}</view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="c37bf01e-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="c37bf01e-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="c37bf01e-3"></loading></block><dp-tabbar vue-id="c37bf01e-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="c37bf01e-5" data-ref="popmsg"></popmsg></view>