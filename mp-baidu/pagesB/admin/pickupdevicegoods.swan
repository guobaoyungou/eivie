<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><image class="img" src="{{item.$orig.pic}}"></image><view class="f1"><view class="title">{{"柜门编号-"+item.$orig.goods_lane}}</view><view class="t1"><text>商品信息：</text>{{item.$orig.proname+"["+item.$orig.ggname+"]"}}</view><view class="t1"><text>近期补货：</text>{{item.$orig.add_time}}</view><view class="flex" style="justify-content:flex-end;"><block s-if="{{item.$orig.lack_stock>0}}"><button data-event-opts="{{[['tap',[['addstock',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+(item.m0)+';'}}" bindtap="__e">补货</button></block><button data-event-opts="{{[['tap',[['openBox',['$0'],[[['datalist','',index,'goods_lane']]]]]]]}}" class="btn" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">开门</button></view></view><block s-if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">待补货</view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="29a6e0f6-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="29a6e0f6-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="29a6e0f6-3"></loading></block><dp-tabbar vue-id="29a6e0f6-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="29a6e0f6-5" data-ref="popmsg"></popmsg></view>