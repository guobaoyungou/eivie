<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view><uni-datetime-picker vue-id="f363b774-1" type="datetimerange" rangeSeparator="~" value="{{datetimerange}}" data-event-opts="{{[['^change',[['timeChange']]],['^input',[['__set_model',['','datetimerange','$event',[]]]]]]}}" bind:change="__e" bind:input="__e"></uni-datetime-picker></view><view class="content"><block s-for="datalist trackBy index1" s-for-item="item" s-for-index="index1"><view class="item" data-url="{{'expendEdit?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="left"><view class="f2"><text class="t2">{{"分类："+item.cname}}</text><text class="t2">{{"时间："+item.createtime}}</text><text class="t2">{{"备注："+item.remark}}</text><view class="t2">{{"管理员："+item.adminname}}</view></view></view><view class="right"><view><view class="money" style="{{'color:'+($root.m0)+';'}}">{{"￥"+item.money}}</view></view><image class="more" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block></view><block s-if="{{nodata}}"><nodata vue-id="f363b774-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="f363b774-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="f363b774-4"></loading></block><popmsg class="vue-ref" vue-id="f363b774-5" data-ref="popmsg"></popmsg></view>