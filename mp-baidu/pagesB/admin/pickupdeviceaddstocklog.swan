<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view><uni-datetime-picker vue-id="3994221d-1" type="datetimerange" rangeSeparator="~" value="{{datetimerange}}" data-event-opts="{{[['^change',[['timeChange']]],['^input',[['__set_model',['','datetimerange','$event',[]]]]]]}}" bind:change="__e" bind:input="__e"></uni-datetime-picker></view><view class="total">合计补货：<text style="color:red;margin-right:10rpx;">{{total_stock}}</text>件</view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><view class="t1">柜子名称：<text style="color:#1e88e5;">{{item.device_name}}</text></view><view class="t1">柜子编号：<text style="color:#333;">{{''+item.device_no}}</text></view><view class="t1">补货时间：<text style="color:#333;">{{''+item.createtime}}</text></view><view class="t1">小计补货：<text style="color:red;margin-right:10rpx;">{{item.total_stock}}</text>件</view><view class="t1"><text style="color:#1e88e5;">补货商品明细：</text></view><block s-for="item.goodsdata" s-for-item="item2" s-for-index="index"><block><view class="t2 flex flex-bt"><view>{{item2.proname+"["+item2.ggname+"]"}}</view><view style="color:#333;">{{"x"+item2.add_stock}}</view></view></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="3994221d-2"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="3994221d-3"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="3994221d-4"></loading></block><dp-tabbar vue-id="3994221d-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="3994221d-6" data-ref="popmsg"></popmsg></view>