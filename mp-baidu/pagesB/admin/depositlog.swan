<view><block s-if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{deposit}}</view><block s-if="{{deposit_refund}}"><view class="f3"><block s-if="{{refund_status==1}}"><text>审核中</text></block><block s-if="{{refund_status!=1&&deposit>0}}"><text data-event-opts="{{[['tap',[['depositRefund']]]]}}" bindtap="__e">退款申请</text></block></view></block></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remark}}</text><text class="t2">{{item.m2}}</text><text class="t3">{{"变更后余额: "+item.$orig.after}}</text></view><view class="f2"><block s-if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block s-else><text class="t2">{{item.$orig.money}}</text></block></view></view></block></view></block><block s-if="{{nodata}}"><nodata vue-id="c1743704-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="c1743704-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="c1743704-3"></loading></block><popmsg class="vue-ref" vue-id="c1743704-4" data-ref="popmsg"></popmsg></view>