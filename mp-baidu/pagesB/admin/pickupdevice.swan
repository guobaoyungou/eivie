<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="content" id="datalist"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" data-url="{{'pickupdevicegoods?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/imgsrc/pickup_device.png'}}" mode="widthFix"></image><view class="f1"><view class="title">{{item.$orig.name}}</view><view class="t1"><text>柜子编号：</text>{{item.$orig.device_no}}</view><view class="t1"><text>格子总数：</text>{{item.$orig.goods_lane}}</view><view class="t1"><text>柜子地址：</text>{{item.$orig.address}}</view><view class="flex" style="justify-content:flex-end;"><block s-if="{{item.$orig.lack_stock>0}}"><button class="btn" style="{{'background:'+(item.m0)+';'}}">补货</button></block></view></view><view class="status"><block s-if="{{device_status==1}}"><text>在线</text></block><block s-else><text style="color:#fff;">离线</text></block></view><block s-if="{{item.$orig.lack_stock>0}}"><view class="addstock"><image class="img2" src="{{pre_url+'/static/imgsrc/pickup_device_left.png'}}"></image><view class="text">{{"缺货: "+item.$orig.lack_stock}}</view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="2ffe525c-1"></nodata></block></view><view class="bottom-view"><view class="bottom flex "><view class="button" style="{{'background:'+($root.m1)+';'}}" data-url="pickupdeviceaddstock" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">补货统计</view><view class="button" style="{{'background:'+($root.m2)+';'}}" data-url="pickupdeviceaddstocklog" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">补货清单</view></view></view><block s-if="{{nomore}}"><nomore vue-id="2ffe525c-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="2ffe525c-3"></loading></block><dp-tabbar vue-id="2ffe525c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="2ffe525c-5" data-ref="popmsg"></popmsg></view>