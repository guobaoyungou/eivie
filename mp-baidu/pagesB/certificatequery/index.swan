<view class="container"><block s-if="{{isload}}"><block><block s-if="{{set.header_text}}"><view><parse vue-id="1d381d50-1" content="{{set.header_text}}"></parse></view></block><form style="width:100%;margin:10rpx;" report-submit="true" data-event-opts="{{[['submit',[['subconfirm',['$event']]]]]}}" bindsubmit="__e"><view class="title">{{queryText}}</view><view class="inputdiv"><input type="text" name="realname" placeholder-style="color:#666;" placeholder="请输入姓名" value="{{realname}}"/></view><block s-if="{{set&&set.query_type=='id_card'}}"><view class="inputdiv"><input type="text" name="id_card" placeholder-style="color:#666;" placeholder="请输入身份证号" value="{{id_card}}"/></view></block><block s-if="{{set&&set.query_type=='tel'}}"><view class="inputdiv"><input type="text" name="tel" placeholder-style="color:#666;" placeholder="请输入手机号" value="{{tel}}"/></view></block><button class="btn" form-type="submit">查询</button></form><block s-if="{{set.footer_text}}"><view><parse vue-id="1d381d50-2" content="{{set.footer_text}}"></parse></view></block></block></block><block s-if="{{loading}}"><loading vue-id="1d381d50-3"></loading></block><dp-tabbar vue-id="1d381d50-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="1d381d50-5" data-ref="popmsg"></popmsg></view>