<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" data-url="{{'detail?tel='+item.tel+'&posterid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="f1"><text class="t1">{{item.name}}</text><text class="t2">{{"姓名："+item.realname}}</text><text class="t2">{{"性别："+item.sex}}</text><block s-if="{{item.id_card}}"><text class="t2">{{"身份证号："+item.id_card}}</text></block><block s-if="{{item.tel}}"><text class="t2">{{"手机号："+item.tel}}</text></block><text class="t2">{{"证书编号："+item.certificate_no}}</text><text class="t2">{{"工种："+item.type}}</text><text class="t2">{{"等级："+item.certificate_level}}</text><text class="t2">{{"发证日期："+item.start_time}}</text></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="768ab56a-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="768ab56a-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="768ab56a-3"></loading></block><dp-tabbar vue-id="768ab56a-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="768ab56a-5" data-ref="popmsg"></popmsg></view>