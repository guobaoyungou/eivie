<view><block s-if="{{isload}}"><block><view class="headcontent" style="{{(bgpic?'background:url('+bgpic+') no-repeat,background-size:100% 100%':'background: linear-gradient(180deg, rgba('+$root.m0+',0.65) 0%, rgba('+$root.m1+',0) 100%);')}}"><view style="width:710rpx;margin:0 auto;padding:20rpx 0;"><view style="display:flex;align-items:center;justify-content:space-between;"><view style="display:flex;align-items:center;" data-url="{{canedit?'/pagesB/kecheng/lecturerapply?opttype=1':''}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="headimg"><image style="width:100%;height:100%;" src="{{lecturer.headimg}}"></image></view><view>{{''+lecturer.nickname+''}}</view></view><block s-if="{{canedit}}"><view class="send" style="{{('background-color:'+$root.m2)}}" data-url="/pagesB/kecheng/lecturersend" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">发布</view></block></view><view style="margin-top:20rpx;line-height:40rpx;white-space:pre-wrap;word-wrap:break-word;">{{lecturer.shortdesc}}</view></view></view><view style="background-color:#fff;"><view style="width:400rpx;"><dd-tab vue-id="cb883f2a-1" itemdata="{{itemdata}}" itemst="{{itemst}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></view></view><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" style="{{(index+1>=datalen?'border:0':'')}}" data-url="{{'/pagesB/kecheng/lecturermldetail?kcid='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="item1"><view class="title">{{''+item.name+''}}</view><view style="width:200rpx;height:140rpx;background-color:#f1f1f1;border-radius:8rpx;overflow:hidden;"><image style="width:100%;" src="{{item.pic}}" mode="widthFix"></image></view></view><view style="font-size:24rpx;color:#999;display:flex;align-items:center;"><view>{{item.showtime}}</view><block s-if="{{canedit}}"><view class="btn" data-url="{{'/pagesB/kecheng/lecturersend?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">编辑</view></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="cb883f2a-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="cb883f2a-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="cb883f2a-4"></loading></block><dp-tabbar vue-id="cb883f2a-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="cb883f2a-6" data-ref="popmsg"></popmsg></view>