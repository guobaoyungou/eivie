<view><block s-if="{{isload}}"><block><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item" style="{{(index+1>=datalen?'border:0':'')}}" data-url="{{'/pagesB/kecheng/lecturercenter?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view style="display:flex;align-items:center;justify-content:space-between;"><view style="display:flex;align-items:center;"><view class="headimg"><image style="width:100%;height:100%;" src="{{item.headimg}}"></image></view><view style="width:500rpx;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">{{''+item.nickname+''}}</view></view></view><view style="margin-top:20rpx;line-height:40rpx;white-space:pre-wrap;word-wrap:break-word;">{{item.shortdesc}}</view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="36660602-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="36660602-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="36660602-3"></loading></block><dp-tabbar vue-id="36660602-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="36660602-5" data-ref="popmsg"></popmsg></view>