<view><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['subform',['$event']]]]]}}" bindsubmit="__e"><view class="form-box"><view class="form-item"><view class="f1">课程名称<text style="color:red;">*</text></view><view class="f2"><input type="text" name="name" placeholder="请填写课程名称" placeholder-style="color:#888" value="{{info.name}}"/></view></view><view class="form-item"><view class="f1">课程分类<text style="color:red;">*</text></view><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="f2" bindtap="__e"><block s-if="{{cids&&cids.length>0}}"><text style="line-height:normal;">{{cnames}}</text></block><block s-else><text style="color:#888;">请选择</text></block><image style="width:30rpx;height:30rpx;" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></view><view class="form-box"><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">课程主图<text style="color:red;">*</text></view><view class="f2"><block s-for="pic trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pic" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pic.length==0}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pic" data-pernum="1" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pic" maxlength="-1" value="{{$root.g0}}"/></view><view class="form-item flex-col"><view class="f1">课程图片</view><view class="f2" style="flex-wrap:wrap;"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><view class="layui-imgbox"><view class="layui-imgbox-close" data-index="{{index}}" data-field="pics" data-event-opts="{{[['tap',[['removeimg',['$event']]]]]}}" bindtap="__e"><image style="display:block;" src="{{pre_url+'/static/img/ico-del.png'}}"></image></view><view class="layui-imgbox-img"><image src="{{item}}" data-url="{{item}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block><block s-if="{{pics.length<5}}"><view class="uploadbtn" style="{{('background:url('+pre_url+'/static/img/shaitu_icon.png) no-repeat 60rpx;background-size:80rpx 80rpx;background-color:#F3F3F3;')}}" data-field="pics" data-pernum="9" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"></view></block></view><input type="text" hidden="true" name="pics" maxlength="-1" value="{{$root.g1}}"/></view></view><view class="form-box"><block s-if="{{canlvprice}}"><view class="form-item"><view class="f1">会员价</view><view class="f2"><radio-group class="radio-group" name="lvprice" data-event-opts="{{[['change',[['bindLvpriceChange',['$event']]]]]}}" bindchange="__e"><label><radio value="1" checked="{{info.lvprice==1?true:false}}"></radio>开启</label><label><radio value="0" checked="{{!info||info.lvprice==0?true:false}}"></radio>关闭</label></radio-group></view></view></block><block s-if="{{!info||!info.lvprice||info.lvprice==0}}"><block><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">销售价（元）</view><view class="f2"><input type="text" name="price" placeholder="请填写销售价" placeholder-style="color:#888" value="{{info.price}}"/></view></view><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">划线价（元）</view><view class="f2"><input type="text" name="market_price" placeholder="请填写划线价" placeholder-style="color:#888" value="{{info.market_price}}"/></view></view></block></block><block s-else><block><block s-if="{{levellist}}"><block><block s-for="levellist" s-for-item="level" s-for-index="index"><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">{{level.name}}</view><view class="f2"><input type="text" name="{{'lvprice_data'+level.id}}" placeholder="请填写价格" placeholder-style="color:#888" value="{{info['lvprice_data'][level.id]['money_price']}}"/></view></view></block></block></block><view class="form-item" style="height:80rpx;line-height:80rpx;"><view class="f1">划线价（元）</view><view class="f2"><input type="text" name="market_price" placeholder="请填写划线价" placeholder-style="color:#888" value="{{info.market_price}}"/></view></view></block></block></view><view class="form-box"><view class="form-item"><view class="f1">课程类型</view><view class="f2"><radio-group class="radio-group" name="kctype" data-event-opts="{{[['change',[['bindKctypeChange',['$event']]]]]}}" bindchange="__e"><label><radio value="1" checked="{{!info||info.kctype==1?true:false}}"></radio>图文</label><label><radio value="3" checked="{{info.kctype==3?true:false}}"></radio>视频</label></radio-group></view></view><view class="form-item" style="border:0;"><view class="f1">免费内容</view><view class="f2" style="color:#999;font-size:24rpx;">免费内容在收费内容前面展示</view></view><view class="form-item" style="background-color:#f8f8f8;border-radius:8rpx;"><view style="width:100%;white-space:pre-wrap;line-height:40rpx;"><textarea name="freecontent" placeholder="请输入免费内容" value="{{info.freecontent}}"></textarea></view></view><block s-if="{{info.kctype==3}}"><block><view class="form-item flex-col" style="border-bottom:0;"><view class="f1">上传视频<text style="color:red;">*</text></view><view style="color:#999;font-size:24rpx;line-height:40rpx;">{{"视频链接必须为mp4格式的源链接，视频大小须在"+video_size+"以内"}}</view><view class="f2"><image style="width:200rpx;height:200rpx;background:#eee;" src="{{pre_url+'/static/img/uploadvideo.png'}}" data-event-opts="{{[['tap',[['uploadvideo',['$event']]]]]}}" bindtap="__e"></image><block s-if="{{video_url}}"><text style="padding-left:20rpx;color:#333;">已上传短视频</text></block><input type="text" hidden="true" name="video_url" maxlength="-1" value="{{video_url}}"/></view></view><view class="form-item"><view class="f1">视频时长</view><view class="f2"><input type="text" name="video_duration" placeholder="请填写视频时长" placeholder-style="color:#888" value="{{info.video_duration}}"/></view></view><block s-if="{{custom.video_speed}}"><view class="form-item"><view class="f1">视频倍速</view><view class="f2"><radio-group class="radio-group" name="isspeed"><label><radio value="1" checked="{{info.isspeed==1?true:false}}"></radio>开启</label><label><radio value="0" checked="{{!info||!info.isspeed||info.isspeed==0?true:false}}"></radio>关闭</label></radio-group></view></view></block><block s-if="{{info.kctype!=1}}"><view class="form-item"><view class="f1">禁止快进</view><view class="f2"><radio-group class="radio-group" name="isjinzhi"><label><radio value="1" checked="{{info.isjinzhi==1?true:false}}"></radio>开启</label><label><radio value="0" checked="{{!info||!info.isjinzhi||info.isjinzhi==0?true:false}}"></radio>关闭</label></radio-group></view></view></block></block></block></view><view class="form-box"><view class="form-item"><view>状态<text style="color:red;">*</text></view><view><radio-group class="radio-group" name="status" data-event-opts="{{[['change',[['bindStatusChange',['$event']]]]]}}" bindchange="__e"><label><radio value="1" checked="{{info.status==1?true:false}}"></radio>开启</label><label><radio value="0" checked="{{!info||info.status==0?true:false}}"></radio>关闭</label></radio-group></view></view></view><view class="form-box"><view class="form-item flex-col"><text>课程详情</text><view class="detailop"><view data-event-opts="{{[['tap',[['detailAddtxt',['$event']]]]]}}" class="btn" bindtap="__e">+文本</view><view data-event-opts="{{[['tap',[['detailAddpic',['$event']]]]]}}" class="btn" bindtap="__e">+图片</view></view><view><block s-for="pagecontent trackBy index" s-for-item="setData" s-for-index="index"><block><view class="detaildp"><view class="op"><view class="flex1"></view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMoveup',['$event']]]]]}}" bindtap="__e">上移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedown',['$event']]]]]}}" bindtap="__e">下移</view><view class="btn" data-index="{{index}}" data-event-opts="{{[['tap',[['detailMovedel',['$event']]]]]}}" bindtap="__e">删除</view></view><view class="detailbox"><block s-if="{{setData.temp=='notice'}}"><block><dp-notice vue-id="{{'fe18ad50-1-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-notice></block></block><block s-if="{{setData.temp=='banner'}}"><block><dp-banner vue-id="{{'fe18ad50-2-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-banner></block></block><block s-if="{{setData.temp=='search'}}"><block><dp-search vue-id="{{'fe18ad50-3-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-search></block></block><block s-if="{{setData.temp=='text'}}"><block><dp-text vue-id="{{'fe18ad50-4-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-text></block></block><block s-if="{{setData.temp=='title'}}"><block><dp-title vue-id="{{'fe18ad50-5-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-title></block></block><block s-if="{{setData.temp=='dhlist'}}"><block><dp-dhlist vue-id="{{'fe18ad50-6-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-dhlist></block></block><block s-if="{{setData.temp=='line'}}"><block><dp-line vue-id="{{'fe18ad50-7-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-line></block></block><block s-if="{{setData.temp=='blank'}}"><block><dp-blank vue-id="{{'fe18ad50-8-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-blank></block></block><block s-if="{{setData.temp=='menu'}}"><block><dp-menu vue-id="{{'fe18ad50-9-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-menu></block></block><block s-if="{{setData.temp=='map'}}"><block><dp-map vue-id="{{'fe18ad50-10-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-map></block></block><block s-if="{{setData.temp=='cube'}}"><block><dp-cube vue-id="{{'fe18ad50-11-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-cube></block></block><block s-if="{{setData.temp=='picture'}}"><block><dp-picture vue-id="{{'fe18ad50-12-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-picture></block></block><block s-if="{{setData.temp=='pictures'}}"><block><dp-pictures vue-id="{{'fe18ad50-13-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-pictures></block></block><block s-if="{{setData.temp=='video'}}"><block><dp-video vue-id="{{'fe18ad50-14-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-video></block></block><block s-if="{{setData.temp=='shop'}}"><block><dp-shop vue-id="{{'fe18ad50-15-'+index}}" params="{{setData.params}}" data="{{setData.data}}" shopinfo="{{setData.shopinfo}}"></dp-shop></block></block><block s-if="{{setData.temp=='product'}}"><block><dp-product vue-id="{{'fe18ad50-16-'+index}}" params="{{setData.params}}" data="{{setData.data}}" menuindex="{{menuindex}}"></dp-product></block></block><block s-if="{{setData.temp=='collage'}}"><block><dp-collage vue-id="{{'fe18ad50-17-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-collage></block></block><block s-if="{{setData.temp=='kanjia'}}"><block><dp-kanjia vue-id="{{'fe18ad50-18-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-kanjia></block></block><block s-if="{{setData.temp=='seckill'}}"><block><dp-seckill vue-id="{{'fe18ad50-19-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-seckill></block></block><block s-if="{{setData.temp=='scoreshop'}}"><block><dp-scoreshop vue-id="{{'fe18ad50-20-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-scoreshop></block></block><block s-if="{{setData.temp=='coupon'}}"><block><dp-coupon vue-id="{{'fe18ad50-21-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-coupon></block></block><block s-if="{{setData.temp=='article'}}"><block><dp-article vue-id="{{'fe18ad50-22-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-article></block></block><block s-if="{{setData.temp=='business'}}"><block><dp-business vue-id="{{'fe18ad50-23-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-business></block></block><block s-if="{{setData.temp=='liveroom'}}"><block><dp-liveroom vue-id="{{'fe18ad50-24-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-liveroom></block></block><block s-if="{{setData.temp=='button'}}"><block><dp-button vue-id="{{'fe18ad50-25-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-button></block></block><block s-if="{{setData.temp=='hotspot'}}"><block><dp-hotspot vue-id="{{'fe18ad50-26-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-hotspot></block></block><block s-if="{{setData.temp=='cover'}}"><block><dp-cover vue-id="{{'fe18ad50-27-'+index}}" params="{{setData.params}}" data="{{setData.data}}"></dp-cover></block></block><block s-if="{{setData.temp=='richtext'}}"><block><dp-richtext vue-id="{{'fe18ad50-28-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-richtext></block></block><block s-if="{{setData.temp=='form'}}"><block><dp-form vue-id="{{'fe18ad50-29-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-form></block></block><block s-if="{{setData.temp=='userinfo'}}"><block><dp-userinfo vue-id="{{'fe18ad50-30-'+index}}" params="{{setData.params}}" data="{{setData.data}}" content="{{setData.content}}"></dp-userinfo></block></block></view></view></block></block></view></view></view><button class="savebtn" style="{{('background:linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')}}" form-type="submit">提交</button><view style="height:50rpx;"></view></form><block s-if="{{clistshow}}"><view class="popup__container"><view data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" class="popup__overlay" catchtap="__e"></view><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择课程分类</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeClistDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block s-for="$root.l2 trackBy item.$orig.id" s-for-item="item" s-for-index="index"><block><view class="clist-item" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.m2?'background:'+item.m3+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block s-for="item.l1 trackBy item2.$orig.id" s-for-item="item2" s-for-index="index2"><block><view class="clist-item" style="padding-left:80rpx;" data-id="{{item2.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" bindtap="__e"><block s-if="{{item.$orig.child.length-1==index2}}"><view class="flex1">{{"└ "+item2.$orig.name}}</view></block><block s-else><view class="flex1">{{"├ "+item2.$orig.name}}</view></block><view class="radio" style="{{(item2.m4?'background:'+item2.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view><block s-for="item2.l0 trackBy item3.$orig.id" s-for-item="item3" s-for-index="index3"><block><view class="clist-item" style="padding-left:160rpx;" data-id="{{item3.$orig.id}}" data-event-opts="{{[['tap',[['cidsChange',['$event']]]]]}}" bindtap="__e"><block s-if="{{item2.$orig.child.length-1==index3}}"><view class="flex1">{{"└ "+item3.$orig.name}}</view></block><block s-else><view class="flex1">{{"├ "+item3.$orig.name}}</view></block><view class="radio" style="{{(item3.m6?'background:'+item3.m7+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></block></block></block></block></view></view></view></block><uni-popup class="vue-ref" vue-id="fe18ad50-31" id="dialogDetailtxt" type="dialog" data-ref="dialogDetailtxt" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">请输入文本内容</text></view><view class="uni-dialog-content"><textarea value="" placeholder="请输入文本内容" data-event-opts="{{[['input',[['catcheDetailtxt',['$event']]]]]}}" bindinput="__e"></textarea></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['dialogDetailtxtConfirm',['$event']]]]]}}" class="uni-dialog-button uni-border-left" bindtap="__e"><text class="uni-dialog-button-text uni-button-color">确定</text></view></view><view data-event-opts="{{[['tap',[['dialogDetailtxtClose',['$event']]]]]}}" class="uni-popup-dialog__close" bindtap="__e"><label class="uni-popup-dialog__close-icon  _span"></label></view></view></uni-popup></block></block><view style="display:none;">{{test}}</view><block s-if="{{loading}}"><loading vue-id="fe18ad50-32"></loading></block><popmsg class="vue-ref" vue-id="fe18ad50-33" data-ref="popmsg"></popmsg><wxxieyi vue-id="fe18ad50-34"></wxxieyi></view>