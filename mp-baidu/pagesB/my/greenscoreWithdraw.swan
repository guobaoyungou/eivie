<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">可提取金额(元)</view><view class="f2">{{canwithdraw_num}}</view><view class="f1">{{"当前每个"+$root.m1+"价值"+set.green_score_price+"元"}}</view><view class="f1">{{"我的"+$root.m2+"数量："+myscore}}</view><block s-if="{{green_score_hb>0}}"><view class="f1">{{"已领增值红包："+green_score_hb+"元"}}</view></block></view><view class="content2"><view class="item2"><view class="f1">提取金额</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="integral" disabled="{{isreadonly}}" placeholder="请输入提取金额" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{isreadonly==true?canwithdraw_num:0}}" bindinput="__e"/></view></view><view class="item4"><text style="margin-right:10rpx;">{{withdraw_desc}}</text></view></view><button class="btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">提交</button><view class="text-center" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{"返回"+$root.m4+"中心"}}</text></view></form></block></block><block s-if="{{datalist.length>0}}"><view class="content" id="datalist"><view class="item"><view class="f1"><text class="t2" style="font-size:32rpx;">涨幅</text></view><view class="f2"><text class="t2">价值</text></view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><block s-if="{{item.dif_price>0}}"><text class="t1" style="color:red;">{{"+ "+item.dif_price}}</text></block><block s-if="{{item.dif_price==0}}"><text class="t1">{{item.dif_price}}</text></block><block s-if="{{item.dif_price<0}}"><text class="t1" style="color:green;">{{item.dif_price}}</text></block><text class="t2">{{item.createtime}}</text></view><view class="f2"><block><text class="t2">{{item.green_score_price}}</text></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="9b3fb844-1"></nodata></block></view></block><block s-if="{{nomore}}"><nomore vue-id="9b3fb844-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="9b3fb844-3"></loading></block><dp-tabbar vue-id="9b3fb844-4" opt="{{opt}}"></dp-tabbar></view>