<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.$orig.remarks}}</text><text class="t2">{{item.$orig.create_time}}</text><block s-if="{{item.$orig.score>0}}"><text class="t3">{{"消耗"+item.m0+"："+item.$orig.score}}</text></block></view><view class="f2"><text class="t1">{{item.$orig.num}}</text></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="7b7aed06-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="7b7aed06-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="7b7aed06-3"></loading></block><dp-tabbar vue-id="7b7aed06-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7b7aed06-5" data-ref="popmsg"></popmsg></view>