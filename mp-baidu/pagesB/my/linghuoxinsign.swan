<block s-if="{{isload}}"><view><view class="content-text">请填写真实信息，完成签约</view><view class="schedule-view flex-x-center"><view class="schedule-options flex-col"><view class="num-text active-class">1</view><view class="tips-text">填写提现信息</view></view><view class="dashed-line" style="{{'border:'+(''+signstatus==true?'1px dashed #a9000e':'1px dashed #b3b3b3')+';'}}"></view><view class="schedule-options flex-col"><view class="{{[signstatus?'active-class':'','num-text']}}">2</view><view class="tips-text">灵活薪签约</view></view></view><block s-if="{{signstatus}}"><view class="success-view flex-col"><view class="icon-view"><image src="{{pre_url+'/static/img/checkd.png'}}"></image></view><view style="font-size:28rpx;color:#000;font-weight:bold;margin-top:50rpx;">提现信息已成功提交</view><view style="font-size:24rpx;color:#7a7a7a;padding:30rpx 0rpx;">请前往灵活薪进行签约</view><view style="font-size:24rpx;color:#7a7a7a;">签约成功后重新进入此页面时进行提现</view></view></block><block s-else><view class="form-view"><view class="form-title">身份信息</view><view class="form-item"><view class="label">姓名</view><input placeholder="请输入姓名" data-event-opts="{{[['input',[['__set_model',['$0','realname','$event',[]],['userinfo']]]]]}}" value="{{userinfo.realname}}" bindinput="__e"/></view><view class="form-item"><view class="label">手机号</view><input placeholder="请输入手机号" data-event-opts="{{[['input',[['__set_model',['$0','tel','$event',[]],['userinfo']]]]]}}" value="{{userinfo.tel}}" bindinput="__e"/></view><view class="form-item"><view class="label">身份证号</view><input placeholder="请输入身份证号" data-event-opts="{{[['input',[['__set_model',['$0','usercard','$event',[]],['userinfo']]]]]}}" value="{{userinfo.usercard}}" bindinput="__e"/></view></view></block><view class="but-view"><block s-if="{{signstatus}}"><button data-event-opts="{{[['tap',[['goSigning',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" bindtap="__e">去签约</button></block><block s-else><button data-event-opts="{{[['tap',[['getNext',['$event']]]]]}}" class="set-btn" style="{{'background:'+('linear-gradient(90deg,'+$root.m2+' 0%,rgba('+$root.m3+',0.8) 100%)')+';'}}" bindtap="__e">下一步</button></block></view></view></block>