<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1" style="width:100%;"><view class="t1">{{item.$orig.proname}}</view><block s-if="{{item.$orig.status>=0}}"><block><block s-if="{{item.$orig.commission}}"><view style="line-height:50rpx;"><block s-if="{{item.$orig.status==1}}"><text class="t1">分佣：</text></block><block s-if="{{item.$orig.status==0}}"><text class="t1">预估分佣：</text></block><text class="t1" style="margin-left:10rpx;">{{item.$orig.commission+item.m0}}</text></view></block><block s-else><view style="line-height:50rpx;"><block s-if="{{item.$orig.status==1}}"><text class="t1">分佣：</text></block><block s-if="{{item.$orig.status==0}}"><text class="t1">预估分佣：</text></block><text class="t1" style="margin-left:10rpx;">{{"0"+item.m1}}</text></view></block></block></block><block s-if="{{item.$orig.from_ordernum}}"><text class="t2">{{"订单编号："+item.$orig.from_ordernum}}</text></block><block s-if="{{item.$orig.create_time}}"><text class="t2">{{item.$orig.create_time}}</text></block><block s-if="{{item.$orig.tipinfor}}"><text class="t2" style="color:#ff8758;">{{item.$orig.tipinfor}}</text></block></view><view class="f2" style="width:120rpx;flex:unset;"><block s-if="{{item.$orig.status==1}}"><text class="t1">已发放</text></block><block s-if="{{item.$orig.status==0}}"><text class="t1" style="color:red;">未发放</text></block><block s-if="{{item.$orig.status==-1}}"><text class="t1" style="color:#999;">已失效</text></block></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="695314b9-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="695314b9-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="695314b9-3"></loading></block><dp-tabbar vue-id="695314b9-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="695314b9-5" data-ref="popmsg"></popmsg></view>