<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">我的积分权</view><view class="f2">{{myscoreweight}}</view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item-moudle" style="background-color:#FFFFFF;"><view>{{item.remark}}</view><view class="item"><view><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.score_weight>0}}"><block><text class="t1" style="color:#03bc01;">{{"+"+item.score_weight}}</text></block></block><block s-else><block><text class="t2">{{item.score_weight}}</text></block></block></view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="024caac6-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="024caac6-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="024caac6-3"></loading></block><dp-tabbar vue-id="024caac6-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="024caac6-5" data-ref="popmsg"></popmsg></view>