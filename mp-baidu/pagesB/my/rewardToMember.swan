<view class="container"><block s-if="{{isload}}"><block><form autocomplete="off" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="content2"><view class="item2"><view class="f1">对方ID(手机号)</view></view><view class="item3"><block s-if="{{member_info.id}}"><view class="member-info"><view class="info-view flex-y-center"><block s-if="{{head-img}}"><image class="head-img" src="member_info.headimg"></image></block><block s-else><image class="head-img" src="{{pre_url+'/static/img/wxtx.png'}}"></image></block><view class="member-text-view"><view class="member-nickname">{{member_info.nickname}}</view><view class="member-id">{{"id:"+member_info.id}}</view></view></view><view data-event-opts="{{[['tap',[['switchMember',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m0)+';'}}" bindtap="__e">切换</view></view></block><block s-else><view class="member-info"><input class="input" type="number" name="mid" placeholder="请输入对方ID/手机号" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['memberInput',['$event']]]]]}}" value="{{mid}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['changeQuery',['$0'],['mid']]]]]}}" class="query-button" style="{{'color:'+($root.m1)+';'}}" bindtap="__e">查询</view></view></block></view><view class="item4" style="height:1rpx;"></view><view class="item2"><view class="f1">打赏金额</view></view><view class="item3"><view class="f2"><input class="input" type="digit" name="money" value="" placeholder="请输入打赏金额" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view></view><button class="btn" style="{{'background:'+($root.m2)+';'}}" form-type="submit">确定</button><view class="text-center" style="margin-top:40rpx;line-height:60rpx;" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{"返回"+$root.m3+"中心"}}</text></view></form><view class="explain"><view class="f1">— 打赏说明 —</view><view class="f2"><parse vue-id="521cdb13-1" content="{{desc}}"></parse></view></view></block></block><block s-if="{{loading}}"><loading vue-id="521cdb13-2"></loading></block><dp-tabbar vue-id="521cdb13-3" opt="{{opt}}"></dp-tabbar></view>