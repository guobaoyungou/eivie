<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{myscore}}</view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.value>0}}"><block><text class="t1">{{"+"+item.value}}</text></block></block><block s-else><block><text class="t2">{{item.value}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="206ae90c-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="206ae90c-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="206ae90c-3"></loading></block><dp-tabbar vue-id="206ae90c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="206ae90c-5" data-ref="popmsg"></popmsg></view>