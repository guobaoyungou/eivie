<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{commission_max}}</view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item-moudle" style="background-color:#FFFFFF;"><view>{{item.remark}}</view><view class="item"><view><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.value>0}}"><block><text class="t1" style="color:#03bc01;">{{"+"+item.value}}</text></block></block><block s-else><block><text class="t2">{{item.value}}</text></block></block></view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="cc1112a8-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="cc1112a8-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="cc1112a8-3"></loading></block><dp-tabbar vue-id="cc1112a8-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="cc1112a8-5" data-ref="popmsg"></popmsg></view>