<view class="container"><block s-if="{{isload}}"><block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><block s-if="{{item.score>0}}"><block><text class="t1">{{"+"+item.score}}</text></block></block><block s-else><block><text class="t2">{{item.score}}</text></block></block></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="505e13bc-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="505e13bc-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="505e13bc-3"></loading></block><dp-tabbar vue-id="505e13bc-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="505e13bc-5" data-ref="popmsg"></popmsg></view>