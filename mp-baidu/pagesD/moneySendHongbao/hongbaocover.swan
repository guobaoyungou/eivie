<view><block s-if="{{isload}}"><block><view class="page-content flex flex-bt"><block s-for="sysset.pics trackBy index" s-for-item="item" s-for-index="index"><block><view class="cover-options"><image src="{{item}}" mode="scaleToFill"></image><view class="choose-view" data-url="{{item}}" data-event-opts="{{[['tap',[['change',['$event']]]]]}}" bindtap="__e">使用</view></view></block></block></view></block></block><block s-if="{{loading}}"><loading vue-id="6636d7ea-1"></loading></block></view>