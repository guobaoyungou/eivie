<view class="container"><block s-if="{{isload}}"><block><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"活动名称："+item.name}}</view></view><block s-if="{{item.jump_detail_status}}"><view class="st0 flex-y-center" data-url="{{item.jump_detail_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">查看详情<image class="arrowright" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></block></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">活动时间：<text style="font-size:24rpx;">{{item.starttime+" ~ "+item.endtime}}</text></view></view></view><view style="border-bottom:1px #f4f4f4 solid;"></view><view class="content flex-bt"><view class="option-content flex"><view>我的业绩：</view><view style="color:#ff8758;">{{"￥"+item.yeji}}</view></view><view class="option-content flex"><view><block s-if="{{item.fafang_fenhong>0}}"><text>已发奖励</text></block><block s-else><text>预估奖励：</text></block></view><view style="color:#ff8758;"><block s-if="{{item.fafang_fenhong>0}}"><text>{{"￥"+item.fafang_fenhong}}</text></block><block s-else><text>{{"￥"+item.fenhong}}</text></block></view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="0b6eeec4-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="0b6eeec4-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="0b6eeec4-3"></loading></block><dp-tabbar vue-id="0b6eeec4-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0b6eeec4-5" data-ref="popmsg"></popmsg></view>