<view class="container"><block s-if="{{isload}}"><block><form data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2"><text style="font-size:26rpx;"></text>{{userinfo.digital_score}}</view><view class="f1">{{"当前"+$root.m2+"："+set.digital_price}}</view><view class="f1">{{"当前"+$root.m3+"价值："+userinfo.alldigital_price}}</view></view><view class="content2"><view class="item2"><view class="f1">兑换数量</view></view><view class="item3"><view class="f2"><input class="input" type="digit" name="withdraw_num" placeholder="请输入兑换数量" placeholder-style="color:#999;font-size:40rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" value="{{withdraw_num}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['allwithdraw',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m4)+';'}}" bindtap="__e">全部</view></view></view><view class="tips-box"><view class="item4 tips"><block s-if="{{set.cash_fee>0}}"><text>{{"兑换手续费"+set.cash_fee+'%'}}</text></block></view></view></view><view class="withdrawtype"><view class="f1">选择兑换方式：</view><view class="f2"><block s-for="$root.l0" s-for-item="item" s-for-index="index"><block><view class="item" data-paytype="{{item.$orig.type}}" data-event-opts="{{[['tap',[['changeradio',['$event']]]]]}}" catchtap="__e"><view class="t1">{{item.$orig.name}}</view><view class="radio" style="{{(paytype==item.$orig.type?'background:'+item.m5+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></view></view><button data-event-opts="{{[['tap',[['formSubmit',['$event']]]]]}}" class="btn" style="{{'background:'+($root.m6)+';'}}" bindtap="__e">立即兑换</button></form><block s-if="{{set.withdraw_desc}}"><view class="withdraw_desc"><view class="title">说明</view><text>{{set.withdraw_desc}}</text></view></block></block></block><block s-if="{{loading}}"><loading vue-id="6cb34fee-1"></loading></block><dp-tabbar vue-id="6cb34fee-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="6cb34fee-3" data-ref="popmsg"></popmsg></view>