<view class="container"><block s-if="{{isload}}"><block><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+$root.m1}}</view><view class="f2">{{mydigitalscore}}<view class="btn-mini" data-url="/pagesD/digitalconsum/withdraw" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换</view></view><view class="f1">{{"当前"+$root.m2+"："+set.digital_price}}</view><view class="f1">{{"当前"+$root.m3+"价值："+alldigital_price}}</view></view><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-item"><view class="item-row"><view class="column"><text>{{"变动数量: "+item.value}}</text><text>{{"剩余数量: "+item.remain}}</text></view><view class="column"><text>{{$root.m4+": "+item.digital_price}}</text></view></view><view class="item-row highlight"><text>{{"可提取金额: "+item.digital_value}}</text></view><view class="item-row"><text class="time">{{item.remark+" "+item.createtime}}</text></view></view></block></block></view><block s-if="{{nodata}}"><nodata vue-id="66cd235c-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="66cd235c-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="66cd235c-3"></loading></block><dp-tabbar vue-id="66cd235c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="66cd235c-5" data-ref="popmsg"></popmsg></view>