<view class="container"><block s-if="{{isload}}"><block><view class="mian" style="{{('background: url('+set.exchange_page_bgpic+');background-size: 100% 100%;background-repeat: no-repeat;')}}"><block s-if="{{isgoback}}"><view data-event-opts="{{[['tap',[['goback',['$event']]]]]}}" class="goback" style="{{'top:'+(gobacktopHeight+'px')+';'}}" bindtap="__e"><image class="goback-img" src="{{pre_url+'/static/img/goback.png'}}"></image></view></block><view style="width:100%;position:absolute;top:60%;"><view style="width:680rpx;margin:0 auto;"><view class="codecss"><label class="_span">卡密：</label><input style="flex:1;height:80rpx;line-height:80rpx;" disabled="{{true}}" value="{{code}}"/></view><view data-event-opts="{{[['tap',[['gotourl',['$event']]]]]}}" class="gourlcss" style="{{('background:'+$root.m0)}}" bindtap="__e">点 击 使 用</view></view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="7c88f340-1"></loading></block><dp-tabbar vue-id="7c88f340-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7c88f340-3" data-ref="popmsg"></popmsg><wxxieyi vue-id="7c88f340-4"></wxxieyi></view>