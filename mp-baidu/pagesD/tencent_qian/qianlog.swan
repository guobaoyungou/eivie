<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="d0fc8812-1" itemdata="{{['全部','待签署','已完成','已失效']}}" itemst="{{['all','1','2','-1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view><view><view>{{"合同名称："+item.FlowName}}</view></view><view><view>{{"类型："+item.typename}}</view></view><block s-if="{{item.type=='member_uplevel'}}"><view><view>{{"等级："+item.levelname}}</view></view></block><block s-if="{{item.wxurl}}"><view><view style="word-wrap:break-word;line-height:40rpx;">{{"微信小程序链接："+item.wxurl}}</view><view style="width:130rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-content="{{item.wxurl}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" bindtap="__e">复制</view></view></block><block s-if="{{item.h5url}}"><view><view style="word-wrap:break-word;line-height:40rpx;">{{"手机H5链接："+item.h5url}}</view><view style="width:130rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-content="{{item.h5url}}" data-event-opts="{{[['tap',[['fuzhi',['$event']]]]]}}" bindtap="__e">复制</view></view></block><view style="display:flex;"><view>状态：</view><block s-if="{{item.status==0}}"><view style="color:#f30;">待发起</view></block><block s-if="{{item.status==1}}"><view style="display:flex;align-items:center;"><view style="color:green;">待签署</view><block s-if="{{item.cancelFlow}}"><view style="width:100rpx;color:#fff;background-color:red;text-align:center;border-radius:8rpx 8rpx;margin-left:20rpx;" data-id="{{item.id}}" data-event-opts="{{[['tap',[['popupCancelflowOpen',['$event']]]]]}}" bindtap="__e">撤销</view></block></view></block><block s-if="{{item.status==2}}"><view style="color:#999;">已完成</view></block><block s-if="{{item.status==-1||item.status==-2}}"><view style="color:#bbb;">已失效</view></block></view><block s-if="{{(item.status==-1||item.status==-2)&&item.reason}}"><view><view>{{item.reason}}</view></view></block><view><view>{{"时间："+item.createtime}}</view></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="d0fc8812-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="d0fc8812-3"></nodata></block><uni-popup class="vue-ref" vue-id="d0fc8812-4" id="popupCancelflow" type="dialog" data-ref="popupCancelflow" vue-slots="{{['default']}}"><view class="uni-popup-dialog"><view class="uni-dialog-title"><text class="uni-dialog-title-text">撤销签署合同</text></view><view class="uni-dialog-content"><view style="padding:0 20rpx;width:100%;line-height:60rpx;"><view style="margin-bottom:20rpx;display:flex;">撤销理由：<input class="input" style="width:460rpx;height:60rpx;line-height:60rpx;" data-field="reason" type="text" placeholder="请输入撤销理由" placeholder-style="color:#999;font-size:32rpx;height:60rpx;line-height: 60rpx;" data-event-opts="{{[['input',[['popupInput',['$event']]]]]}}" value="{{reason}}" bindinput="__e"/></view></view></view><view class="uni-dialog-button-group"><view data-event-opts="{{[['tap',[['popupCancelflowClose',['$event']]]]]}}" class="uni-dialog-button" bindtap="__e"><text class="uni-dialog-button-text">取消</text></view><view data-event-opts="{{[['tap',[['popupCancelflowConfirm',['$event']]]]]}}" class="uni-dialog-button" style="{{'color:'+($root.m0)+';'}}" bindtap="__e"><text class="uni-dialog-button-text">确定</text></view></view></view></uni-popup></block></block><block s-if="{{loading}}"><loading vue-id="d0fc8812-5"></loading></block><dp-tabbar vue-id="d0fc8812-6" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="d0fc8812-7" data-ref="popmsg"></popmsg></view>