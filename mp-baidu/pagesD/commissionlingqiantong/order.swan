<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="fa3c0f26-1" itemdata="{{['收益明细','本金明细']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><block s-if="{{st==2}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="item-body"><view><view class="row"><text class="label">变后余额：</text><text>{{"￥"+item.$orig.after}}</text></view><view class="row"><text class="label">变动金额：</text><block s-if="{{item.$orig.money>0}}"><text class="t1">{{"+"+item.$orig.money}}</text></block><block s-else><text class="t2">{{item.$orig.money}}</text></block></view><view class="row"><text class="label">创建时间：</text><text>{{item.m0}}</text></view><view class="row"><text class="label">备注：</text><text>{{item.$orig.remark}}</text></view></view></view></view></block></block></block><block s-if="{{st==1}}"><block><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="item-header"><text class="t1">{{item.$orig.day+"天 "+item.$orig.rate+"%"}}</text><text class="t2" style="{{('background:'+(item.$orig.status==1?'#CACACA':'#7DD0BC'))}}">{{item.$orig.status_str}}</text></view><view class="item-body"><view><view class="row"><text class="label">起始本金：</text><text>{{"￥"+item.$orig.start_money}}</text></view><view class="row"><text class="label">累计本金：</text><text>{{"￥"+item.$orig.total_money}}</text></view><block s-if="{{item.$orig.status==1}}"><block><view class="row"><text class="label">累计收益：</text><text>{{"￥"+item.$orig.yuji_income}}</text></view><view class="row"><text class="label">到期收益：</text><text>{{"￥"+item.$orig.daozhang_money}}</text></view></block></block><block s-else><block><view class="row"><text class="label">预计收益：</text><text>{{"￥"+item.$orig.yuji_income}}</text></view></block></block><view class="row"><text class="label">创建时间：</text><text>{{item.m1}}</text></view><view class="row"><text class="label">到期时间：</text><text>{{item.m2}}</text></view></view></view></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="fa3c0f26-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="fa3c0f26-3"></nomore></block><view style="height:20rpx;"></view></block></block><block s-if="{{loading}}"><loading vue-id="fa3c0f26-4"></loading></block></view>