<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="ec05a148-1" itemdata="{{['全部','待付款','待出票','已出票','退款/售后']}}" itemst="{{['all','0','1','2','10']}}" st="{{st}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view style="width:100%;height:100rpx;"></view><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入关键字搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e"/></view></view><view class="order-content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="head"><view class="f1"><image src="{{pre_url+'/static/img/ico-shop.png'}}"></image>{{''+item.$orig.product.spot_name}}</view><view class="flex1"></view><block s-if="{{item.$orig.status==0}}"><text class="st0">待付款</text></block><block s-if="{{item.$orig.status==1}}"><text class="st0">待出票</text></block><block s-if="{{item.$orig.status==2}}"><text class="st1">已出票</text></block><block s-if="{{item.$orig.status==3}}"><text class="st1">已完成</text></block><block s-if="{{item.$orig.status==4}}"><text class="st1">已取消</text></block><block s-if="{{item.$orig.status==-1}}"><text class="st4">已关闭</text></block></view><view class="content"><view><image src="{{item.$orig.product.pic}}"></image></view><view class="detail"><text class="t1">{{item.$orig.title}}</text><block s-if="{{item.$orig.book_date==2&&(item.$orig.sell_start_date||item.$orig.sell_end_date)}}"><text class="t2" style="color:#666;">{{item.$orig.sell_start_date+"~"+item.$orig.sell_end_date}}</text></block><text class="t3" style="color:#666;">{{"张数："+item.$orig.num}}</text><view class="t3">{{"价格：￥"+item.$orig.sell_price}}</view></view></view><view class="bottom" style="display:flex;justify-content:space-between;"><text>{{"实付:￥"+item.$orig.totalprice}}</text></view><block s-if="{{item.$orig.refund_status>0}}"><view class="bottom"><block s-if="{{item.$orig.refund_status==1}}"><text style="color:red;">{{'退款中￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==2}}"><text style="color:red;">{{'已退款￥'+item.$orig.refund_money}}</text></block><block s-if="{{item.$orig.refund_status==3}}"><text style="color:red;">退款申请已驳回</text></block></view></block><view class="op"><view class="btn2" data-url="{{'orderdetail?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">详情</view><block s-if="{{item.$orig.status==0}}"><block><view class="btn2" data-id="{{item.$orig.id}}" data-event-opts="{{[['tap',[['toclose',['$event']]]]]}}" catchtap="__e">关闭订单</view><view class="btn1" style="{{'background:'+(item.m0)+';'}}" data-url="{{'/pagesExt/pay/pay?id='+item.$orig.payorderid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">去付款</view></block></block><block s-if="{{item.$orig.status==1}}"><block><block s-if="{{item.$orig.refund_status==0||item.$orig.refund_status==3}}"><view class="btn2" data-url="{{'refund?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e">申请退款</view></block></block></block></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="ec05a148-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="ec05a148-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="ec05a148-4"></loading></block><dp-tabbar vue-id="ec05a148-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="ec05a148-6" data-ref="popmsg"></popmsg></view>