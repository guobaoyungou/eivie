<view class="container"><block s-if="{{isload}}"><block><view style="width:100%;margin-top:50rpx;"><view style="width:90rpx;height:90rpx;margin:0 auto;"><image style="width:100%;height:100%;" src="{{pre_url+'/static/img/success.png'}}"></image></view><view style="width:100%;margin-top:20rpx;text-align:center;font-weight:bold;">支付已完成</view></view><view class="tipmsg" style="{{('background: linear-gradient(to bottom, rgba('+$root.m0+',0.6),'+$root.m1)}}">下次消费可抵扣<text>{{"¥"+userinfo.money}}</text></view><view class="tipmsg2" style="{{('background:'+$root.m2)}}" data-url="/pagesExt/money/recharge" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">前往查看</view><block s-if="{{ischoujiang==1}}"><view class="lottery-section"><view class="lottery-text" style="{{'color:'+($root.m3)+';'}}" data-url="/pagesD/choujiang/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>您已成功参与消费免单抽奖活动，</text><text>{{"抽奖活动将于"+open_award_time+"开奖。"}}</text></view><view class="lottery-btn" style="{{'background:'+($root.m4)+';'}}" data-url="/pagesD/choujiang/index" data-opentype="reLaunch" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">前往活动查看</view></view></block></block></block><block s-if="{{loading}}"><loading vue-id="b329ff8c-1"></loading></block><dp-tabbar vue-id="b329ff8c-2" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="b329ff8c-3" data-ref="popmsg"></popmsg></view>