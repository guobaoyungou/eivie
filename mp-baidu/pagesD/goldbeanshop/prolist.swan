<view class="container"><block s-if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="商品搜索..." data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" bindtap="__e"><text class="fa fa-trash-o" style="font-size:36rpx;"></text></view></view><view class="search-history-list"><block s-for="history_list trackBy index" s-for-item="item" s-for-index="index"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" bindtap="__e">{{item+''}}</view></block><block s-if="{{!history_list||history_list.length==0}}"><view><text class="fa fa-exclamation-circle"></text>暂无记录</view></block></view></view><view hidden="{{!(!history_show)}}" class="search-navbar"><view class="{{['search-navbar-item '+(!field?'active':'')]}}" data-field data-order data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e">综合</view><view class="{{['search-navbar-item '+(field=='sales'?'active':'')]}}" data-field="sales" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e">兑换数</view><view class="search-navbar-item" data-field="score_price" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e"><text class="{{[field=='score_price'?'active':'']}}">{{"所需"+$root.m0}}</text><text class="{{['fa fa-caret-up '+(field=='score_price'&&order=='asc'?'active':'')]}}"></text><text class="{{['fa fa-caret-down '+(field=='score_price'&&order=='desc'?'active':'')]}}"></text></view><view data-event-opts="{{[['tap',[['filterClick',['$event']]]]]}}" class="search-navbar-item flex-x-center flex-y-center" catchtap="__e">筛选<text class="iconfont iconshaixuan" style="font-size:28rpx;margin-left:5rpx;"></text></view></view><block s-if="{{showfilter}}"><view class="search-filter"><view class="search-filter-content" if="{{glist&&glist.length>0}}"><block s-for="glist trackBy index" s-for-item="item" s-for-index="index"><block><view style="display:flex;align-items:center;justify-content:center;padding:15rpx 30rpx;" data-gid="{{item.id}}" data-event-opts="{{[['tap',[['groupClick',['$event']]]]]}}" catchtap="__e"><block s-if="{{gid==item.id}}"><icon type="success_no_circle" size="18"></icon></block>{{item.name+''}}</view></block></block></view><view class="search-filter-content" style="border-top:1px solid #f5f5f5;" if="{{clist&&clist.length>0}}"><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view style="display:flex;align-items:center;justify-content:center;padding:15rpx 30rpx;" data-cid="{{item.id}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchtap="__e"><block s-if="{{cid==item.id}}"><icon type="success_no_circle" size="18"></icon></block>{{item.name+''}}</view></block></block></view><view class="search-filter-content" style="border-top:1px solid #eee;text-align:right;"><view class="close _div"><text data-event-opts="{{[['tap',[['filterClick',['$event']]]]]}}" catchtap="__e">关闭</text></view></view></view></block></view><view class="product-container"><block s-if="{{datalist&&datalist.length>0}}"><block><view class="dp-product"><view class="dp-product-normal-item"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="item" style="{{('width:49%;margin-right:'+(index%2==0?'2%':0))}}" data-url="{{'product?id='+item.$orig.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="product-pic"><image class="image" src="{{item.$orig.pic}}" mode="widthFix"></image></view><view class="product-info"><view class="p1">{{item.$orig.name}}</view><view class="p2" style="color:#666;font-size:24rpx;"><block s-if="{{item.$orig.sell_price>0}}"><block>{{"价值"+item.$orig.sell_price+"元"}}</block></block></view><view class="p2"><view class="t1" style="{{'color:'+($root.m1)+';'}}"><block s-if="{{item.$orig.score_price>0}}"><block>{{item.$orig.score_price+item.m2}}</block></block><block s-if="{{item.$orig.money_price>0}}"><block><block s-if="{{item.$orig.score_price>0}}"><block>+</block></block>{{item.$orig.money_price+"元"}}</block></block></view></view><view class="p3">已兑换<text style="{{'color:'+($root.m3)+';'}}">{{''+item.$orig.sales+''}}</text>件</view><view class="p3 flex flex-x-bottom"><view class="button" style="{{'background:'+($root.m4)+';'}}">立即兑换</view></view></view></view></block></block></view></view></block></block><block s-if="{{nomore}}"><nomore vue-id="292120e4-1" text="没有更多商品了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="292120e4-2" text="没有查找到相关商品"></nodata></block><block s-if="{{loading}}"><loading vue-id="292120e4-3"></loading></block></view></block></block><block s-if="{{loading}}"><loading vue-id="292120e4-4"></loading></block><dp-tabbar vue-id="292120e4-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="292120e4-6" data-ref="popmsg"></popmsg></view>