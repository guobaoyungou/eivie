<view><view class="banner-view" style="{{'background-image:'+('url('+pre_url+'/static/img/watherbg.png)')+';'+('background-color:'+('#89c3f6')+';')}}"></view><view class="position-view"><view class="top-position-view flex flex-bt"><view class="flex flex-y-center"><view class="add-icon"><image src="{{pre_url+'/static/img/water/address_icon.png'}}"></image></view><view class="address-text">{{locationCache.street?locationCache.street:'定位中'}}</view><view class="xiala-icon flex flex-xy-center"><image src="{{pre_url+'/static/img/water/jiantou_xiala.png'}}"></image></view></view></view><view class="pos-options-view list-view"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-options-view flex flex-y-center flex-bt"><view class="flex-col left-view"><view class="title-text flex flex-y-center">{{(item.location?item.location:'净水机')+''}}<block s-if="{{index==0&&item.juli}}"><view class="juli-tisp">距离最近</view></block></view><view class="tisp-text">{{item.location?item.location:'净水机'}}</view></view><block s-if="{{item.juli}}"><view class="right-icon flex-col flex-xy-center"><image class="dizhi-icon" src="{{pre_url+'/static/img/water/dizhi.png'}}"></image><view class="dizhi-text">{{item.juli?item.juli:''}}</view></view></block></view></block></block></view></view><block s-if="{{nodata}}"><nodata vue-id="317dadbe-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="317dadbe-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="317dadbe-3"></loading></block><dp-tabbar vue-id="317dadbe-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="317dadbe-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="317dadbe-6"></wxxieyi></view>