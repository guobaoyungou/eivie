<view class="container"><block s-if="{{isload}}"><block><view class="content"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.back_type_name}}</text><block s-if="{{item.remark}}"><text class="t2">{{item.send_day+item.remark}}</text></block><text class="t2">{{item.create_time}}</text></view><view class="f2"><text class="t1">{{"+"+item.cashback_num}}</text></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="56d5a170-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="56d5a170-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="56d5a170-3"></loading></block><dp-tabbar vue-id="56d5a170-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="56d5a170-5" data-ref="popmsg"></popmsg></view>