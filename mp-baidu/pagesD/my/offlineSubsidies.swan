<view class="container"><block s-if="{{isload}}"><block><view class="mymoney" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{"我的"+title_name}}</view><view class="f2"><text style="font-size:26rpx;">￥</text>{{mymoney}}</view><view class="f3" data-url="{{data_url}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>变动记录</text><text class="iconfont iconjiantou" style="font-size:20rpx;"></text></view></view><form autocomplete="off" data-event-opts="{{[['submit',[['formSubmit',['$event']]]]]}}" bindsubmit="__e"><view class="content2"><block><view class="item2"><view class="f1">对方账号信息</view></view><view class="item3"><block s-if="{{member_info.id}}"><view class="member-info"><view class="info-view flex-y-center"><block s-if="{{member_info.headimg}}"><image class="head-img" src="{{member_info.headimg}}"></image></block><block s-else><image class="head-img" src="{{pre_url+'/static/img/wxtx.png'}}"></image></block><view class="member-text-view"><view class="member-nickname">{{member_info.nickname}}</view><view class="member-id">{{"ID："+member_info.id}}</view></view></view><view data-event-opts="{{[['tap',[['switchMember',['$event']]]]]}}" class="query-button" style="{{'color:'+($root.m1)+';'}}" bindtap="__e">切换</view></view></block><block s-else><view class="member-info"><input class="input" type="number" name="mid" placeholder="请输入对方ID/手机号" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['memberInput',['$event']]]]]}}" value="{{mid}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['changeQuery',['$0'],['mid']]]]]}}" class="query-button" style="{{'color:'+($root.m2)+';'}}" bindtap="__e">查询</view></view></block></view><view class="item4" style="height:1rpx;"></view></block><view class="item2"><view class="f1">转账金额</view></view><view class="item3"><view class="f2"><input class="input" type="number" name="money" value="" placeholder="请输入转账金额" placeholder-style="color:#999;font-size:36rpx" data-event-opts="{{[['input',[['moneyinput',['$event']]]]]}}" bindinput="__e"/></view></view><view class="item4"></view><view class="desText"></view><view class="desText">{{"注："+title_name+'转账对方收到的是余额，请仔细核对转账信息，转账后不可退回'}}</view></view><button class="btn" style="{{'background:'+($root.m3)+';'}}" form-type="submit">转账</button><view class="text-center" style="margin-top:40rpx;line-height:60rpx;" data-url="/pages/my/usercenter" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><text>{{"返回"+$root.m4+"中心"}}</text></view></form></block></block><block s-if="{{loading}}"><loading vue-id="fc305a22-1"></loading></block><dp-tabbar vue-id="fc305a22-2" opt="{{opt}}"></dp-tabbar></view>