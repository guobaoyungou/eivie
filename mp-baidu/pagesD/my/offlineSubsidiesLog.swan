<view class="container"><block s-if="{{isload}}"><block><view class="content"><block s-if="{{st==0}}"><block><block s-if="{{ly_type==6&&zhitui_num!='-1'}}"><view class="item"><view class="f1"><text class="t1">{{"当月直推新人"+zhitui_num+"个"}}</text></view></view></block><block s-if="{{ly_type==1}}"><view class="item"><block s-if="{{weisj!='-1'}}"><view class="f1"><text class="t1">{{"您还差"+weisj+"个升级奖励升级"}}<block s-if="{{level_name}}"><text>{{"到["+level_name+"]"}}</text></block>，请继续努力</text></view></block><block s-if="{{yisj!='-1'}}"><view class="f1"><text class="t1">{{"恭喜您，您已升级成为["+yisj+"]，剩下的钱自动转入爱心基金"}}</text></view></block></view></block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t2">{{item.createtime}}</text><text class="t1">{{item.remark}}</text></view><view class="f2"><block s-if="{{item.money>0}}"><text class="t1">{{"+"+item.money}}</text></block><block s-else><text class="t2">{{item.money}}</text></block></view></view></block></block></block></view><block s-if="{{nomore}}"><nomore vue-id="7b4dbfeb-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="7b4dbfeb-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="7b4dbfeb-3"></loading></block><dp-tabbar vue-id="7b4dbfeb-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="7b4dbfeb-5" data-ref="popmsg"></popmsg></view>