<view class="container"><block s-if="{{isload}}"><block><block s-if="{{pid<=0}}"><view class="mydedamount" style="{{'background:'+($root.m0)+';'}}"><view class="f1">{{'我的'+$root.m1+''}}</view><view class="item flex-bt flex-y-center"><view class="value">{{my_cashback_lock}}</view></view></view></block><view class="content" id="datalist"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f2" style="display:flex;justify-content:space-between;"><view class="t1" style="color:#000;">变动金额：<block s-if="{{item.money>0}}"><text style="color:green;">{{"+"+item.money}}</text></block><block s-else><text style="color:red;">{{item.money}}</text></block></view></view><view class="f1"><view class="t2">{{item.remark}}</view></view><view class="f1"><view class="t2">{{item.createtime}}</view></view></view></block></block><block s-if="{{nodata}}"><nodata vue-id="86315c2c-1"></nodata></block></view><block s-if="{{nomore}}"><nomore vue-id="86315c2c-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="86315c2c-3"></loading></block><dp-tabbar vue-id="86315c2c-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="86315c2c-5" data-ref="popmsg"></popmsg></view>