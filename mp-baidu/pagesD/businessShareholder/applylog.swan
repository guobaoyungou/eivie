<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="0be03128-1" itemdata="{{['发起众筹列表','申请入股列表']}}" itemst="{{['0','1']}}" st="{{st}}" showstatus="{{showstatus}}" ismoney="{{1}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view><view><view>{{"所属商户："+item.$orig.bname}}</view></view><view><view>{{"门店类型："+item.$orig.shname}}</view></view><view style="display:flex;flex-wrap:wrap;align-items:center;"><view>凭证：</view><block s-for="item.$orig.pics trackBy index2" s-for-item="item2" s-for-index="index2"><view style="margin:10rpx 0;"><view style="width:180rpx;height:180rpx;margin-right:10rpx;overflow:hidden;"><image style="width:100%;" src="{{item2}}" data-url="{{item2}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></view></block></view><view>状态：<block s-if="{{item.$orig.status==0}}"><text style="color:#f30;">待审核</text></block><block s-if="{{item.$orig.status==1}}"><text style="color:green;">已通过</text></block><block s-if="{{item.$orig.status==-1}}"><text style="color:#999;">已驳回</text></block></view><block s-if="{{item.$orig.status==-1}}"><view>{{"拒绝原因："+item.$orig.checkreason}}</view></block><view style="display:flex;justify-content:space-between;align-items:center;"><view>{{"时间："+item.$orig.createtime}}</view><block s-if="{{item.$orig.status==1&&item.$orig.endstatus==0}}"><view style="{{('border: 2rpx solid'+item.m0+';border-radius: 8rpx 8rpx ;padding: 0 18rpx;font-size:26rpx;color:'+item.m1)}}" data-url="{{'/pagesD/businessShareholder/index?type=1&id='+item.$orig.id+'&pid='+item.$orig.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">继续入股</view></block><block s-if="{{item.$orig.status==1&&item.$orig.endstatus==0}}"><view style="{{('border: 2rpx solid'+item.m2+';border-radius: 8rpx 8rpx ;padding: 0 18rpx;font-size:26rpx;color:'+item.m3)}}" data-url="{{'/pagesD/businessShareholder/index?opttype=share&type=1&id='+item.$orig.id+'&pid='+item.$orig.mid}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">邀请入股</view></block></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="0be03128-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="0be03128-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="0be03128-4"></loading></block><dp-tabbar vue-id="0be03128-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="0be03128-6" data-ref="popmsg"></popmsg></view>