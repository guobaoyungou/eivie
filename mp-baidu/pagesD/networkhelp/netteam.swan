<view class="container"><block s-if="{{isload}}"><block><block></block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入昵称/姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><block s-if="{{datalist&&datalist.length>0}}"><view class="content"><view class="label"><text class="t1">成员信息</text></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="item"><view class="f1"><image src="{{item.headimg}}" mode="widthFix"></image><view class="t2"><text class="x1">{{item.nickname+"(ID:"+item.mid+")"}}</text><text class="x2">{{"等级："+item.level_name}}</text><block s-if="{{item.tel}}"><text class="x2">{{"手机号："+item.tel}}</text></block><block s-if="{{item.pid}}"><text class="x2">{{"推荐人ID："+item.pid}}</text></block></view></view></view></block></block></view></block></block></block><block s-if="{{nodata}}"><nodata vue-id="6f5efc9e-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="6f5efc9e-2"></nomore></block><block s-if="{{loading}}"><loading vue-id="6f5efc9e-3"></loading></block><dp-tabbar vue-id="6f5efc9e-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="6f5efc9e-5" data-ref="popmsg"></popmsg></view>