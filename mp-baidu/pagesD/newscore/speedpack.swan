<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="1b6b57fa-1" itemdata="{{['未使用','已使用','已过期']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="coupon-list"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="coupon"><view class="pt_left"><view class="pt_left-content"><view class="f1" style="{{'color:'+($root.m0)+';'}}"><text class="t1">{{item.$orig.pack_ratio+"%"}}</text></view><view class="f2" style="{{'color:'+($root.m1)+';'}}">{{''+$root.m2+'加速'}}</view></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.$orig.pack_name}}</view><text class="t2" style="{{'background:'+('rgba('+$root.m3+',0.1)')+';'+('color:'+($root.m4)+';')}}">{{item.$orig.type_txt}}</text><block s-if="{{item.$orig.type!=20}}"><view class="t3" style="{{(item.$orig.bid>0?'margin-top:0':'margin-top:10rpx')}}">{{"有效期至 "+item.$orig.endtime}}</view></block><block s-if="{{item.$orig.bid>0}}"><view class="t4">{{"适用商家："+item.$orig.bname}}</view></block></view><view style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;width:140rpx;"><block s-if="{{item.$orig.status==1}}"><block><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+item.m5+' 0%,rgba('+item.m6+',0.8) 100%)')+';'}}">加速中</button></block></block><block s-if="{{st==2}}"><image class="sygq" src="{{pre_url+'/static/img/ygq.png'}}"></image></block></view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="1b6b57fa-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="1b6b57fa-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="1b6b57fa-4"></loading></block><dp-tabbar vue-id="1b6b57fa-5" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="1b6b57fa-6" data-ref="popmsg"></popmsg></view>