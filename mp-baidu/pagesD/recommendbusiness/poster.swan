<view class="container"><block s-if="{{isload}}"><block><image class="sjew-img" src="{{poster}}" data-url="{{poster}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="sjew-he"></view><view class="{{['sjew-bottom',menuindex>-1?'tabbarbot':'notabbarbot']}}"><view class="sjew-bottom-content"><block s-if="{{$root.m0=='app'}}"><view data-event-opts="{{[['tap',[['shareapp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m1)+';'}}" bindtap="__e">分享链接</view></block><block s-else><block s-if="{{$root.m2=='mp'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m3)+';'}}" bindtap="__e">分享链接</view></block><block s-else><block s-if="{{$root.m4=='h5'}}"><view data-event-opts="{{[['tap',[['sharemp',['$event']]]]]}}" class="sjew-bot-a1" style="{{'background:'+($root.m5)+';'}}" bindtap="__e">分享链接</view></block><block s-else><button class="sjew-bot-a1" style="{{'background:'+($root.m6)+';'}}" open-type="share">分享链接</button></block></block></block><view class="sjew-bot-a2" style="{{'background:'+($root.m7)+';'}}" data-url="{{poster}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e">分享图片</view></view></view></block></block><block s-if="{{loading}}"><loading vue-id="187180a6-1"></loading></block><dp-tabbar vue-id="187180a6-2" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="187180a6-3" data-ref="popmsg"></popmsg></view>