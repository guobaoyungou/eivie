<view class="container"><block s-if="{{isload}}"><block><view class="coupon-list"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="coupon" data-url="{{'coupondetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" catchtap="__e"><view class="pt_left"><view class="pt_left-content"><image src="{{item.pic}}" mode="widthFix"></image></view></view><view class="pt_right"><view class="f1"><view class="t1">{{item.name}}</view><view class="t4">{{'x '+item.limit_count}}</view><block s-if="{{item.price>0}}"><view class="t4 price"><text class="price_tag">￥</text>{{item.price}}</view></block></view><button class="btn" style="{{'background:'+('linear-gradient(270deg,'+$root.m0+' 0%,rgba('+$root.m1+',0.8) 100%)')+';'}}" data-id="{{item.id}}" data-price="{{item.price}}" data-score="{{item.score}}" data-key="{{index}}" data-event-opts="{{[['tap',[['getcoupon',['$event']]]]]}}" catchtap="__e">{{item.price>0?'购买':item.score>0?'兑换':'领取'}}</button></view></view></block></view><block s-if="{{nodata}}"><nodata vue-id="8183d91e-1" text="{{'暂无可领'+$root.m2}}"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="8183d91e-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="8183d91e-3"></loading></block><dp-tabbar vue-id="8183d91e-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="8183d91e-5" data-ref="popmsg"></popmsg></view>