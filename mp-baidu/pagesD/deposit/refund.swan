<view><block s-if="{{isload}}"><block><view class="top-view flex" style="{{'background-image:'+('linear-gradient(to right , rgba('+$root.m0+',0.7),'+$root.m1+')')+';'}}"><view class="left-view flex-col"><view class="title-view">金额总计（元）</view><view class="price-view">{{totalprice}}</view></view><view class="right-view"><image src="{{pre_url+'/static/img/deposit/buy.png'}}"></image></view></view><view class="content-view"><view class="filter-view flex flex-bt"><view class="filter-title">{{$root.m2+"名称"}}</view></view><view class="content-list"><scroll-view style="max-height:65vh;height:auto;" scroll-y="{{true}}"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="list-options flex" style="{{'border-color:'+($root.m3)+';'}}"><view class="img-view"><image src="{{item.$orig.pic}}"></image></view><view class="info-view flex-col"><view class="title-view">{{item.$orig.name}}</view><view class="bname">{{"适用商家："+item.$orig.bname}}</view><view class="price-fun-view flex flex-y-center flex-bt"><view class="flex flex-y-center flex-bt" style="line-height:46rpx;"><view class="price-text" style="{{'color:'+($root.m4)+';'}}">{{"￥"+item.$orig.money}}</view><view style="margin-left:20rpx;">{{"数量："+item.$orig.num}}</view></view><view class="fun-view flex flex-y-center"><block s-if="{{item.$orig.buynum>0}}"><view class="fun-class minus-class flex-xy-center" style="{{'color:'+(item.m5)+';'+('border-color:'+(item.m6)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['subnum',['$event']]]]]}}" bindtap="__e">-</view></block><block s-if="{{item.$orig.buynum>0}}"><view class="input-view">{{item.$orig.buynum}}</view></block><block s-if="{{numkey==-1||numkey==index}}"><view class="fun-class add-class flex-xy-center" style="{{'background-color:'+(item.m7)+';'+('border-color:'+(item.m8)+';')}}" data-key="{{index}}" data-event-opts="{{[['tap',[['addnum',['$event']]]]]}}" bindtap="__e">+</view></block></view></view></view></view></block></block></scroll-view></view><view class="input-info-view flex flex-bt flex-y-center"><view class="title-view">回收方式</view><view class="switch-view flex-y-center"><block s-if="{{recycle_type_name}}"><text class="title-desc" style="color:#666;">{{recycle_type_name}}</text></block><block s-else><text class="title-desc">请选择回收方式</text></block></view></view><block s-if="{{recycle_type==2}}"><view class="input-info-view flex flex-bt flex-y-center"><view><view class="title-view">取件地址</view></view><view class=" address-add flex-y-center" data-url="/pagesB/address/address?fromPage=depositRefund&type=1" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><block s-if="{{address&&address.name}}"><view class="f2 flex1 f1"><view style="font-weight:bold;color:#111111;font-size:30rpx;">{{address.name+" "+address.tel+''}}<block s-if="{{address.company}}"><text>{{address.company}}</text></block></view><view style="font-size:24rpx;">{{address.area+" "+address.address+''}}<block s-if="{{address.floor}}"><text>{{address.floor+"楼"}}</text></block><block s-if="{{address.room}}"><text>{{address.room}}</text></block></view></view></block><block s-else><view class="f2 flex1 ">请选择取件地址</view></block><image class="arrowright" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view></view></block><view class="input-info-view flex flex-bt flex-y-center"><view><view class="title-view">照片凭证</view><view class="title-desc">拍摄商品照片</view></view><view class="upload-img flex-xy-center"><block s-if="{{goods_pic}}"><image class="upload-img-class" src="{{goods_pic}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['goods_pic']]]]]}}" bindtap="__e"></image></block><block s-else><view class="upload-icon-view flex-xy-center" data-key="goods_pic" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block s-if="{{goods_pic}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="close-view" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></view><view class="input-info-view flex flex-bt flex-y-center"><view><view class="title-view">收款码</view><view class="title-desc">{{"上传收款二维码用来退还"+$root.m9}}</view></view><view class="upload-img flex-xy-center"><block s-if="{{payment_code}}"><image class="upload-img-class" src="{{payment_code}}" data-event-opts="{{[['tap',[['previewImage',['$0'],['payment_code']]]]]}}" bindtap="__e"></image></block><block s-else><view class="upload-icon-view flex-xy-center" data-key="payment_code" data-event-opts="{{[['tap',[['uploadimg',['$event']]]]]}}" bindtap="__e"><image class="icon-class" src="{{pre_url+'/static/img/deposit/xiangjixiao.png'}}"></image></view></block><block s-if="{{payment_code}}"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="close-view" bindtap="__e"><image src="{{pre_url+'/static/img/ico-del.png'}}"></image></view></block></view></view><view class="input-info-view flex flex-bt flex-y-center"><view class="title-view">真实姓名</view><view class="info-input-view"><input class="input-class" placeholder="请输入真实姓名" data-event-opts="{{[['input',[['__set_model',['','realname','$event',[]]]]]]}}" value="{{realname}}" bindinput="__e"/></view></view><view style="height:calc(140rpx + env(safe-area-inset-bottom));"></view></view><view class="buy-but-view"><view data-event-opts="{{[['tap',[['toSubmit',['$event']]]]]}}" class="buy-but" style="{{'background-color:'+($root.m10)+';'}}" bindtap="__e">提交审核</view></view><block s-if="{{nodata}}"><nodata vue-id="26b8d586-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="26b8d586-2"></nomore></block></block></block><uni-popup class="vue-ref" vue-id="26b8d586-3" data-ref="refPopup" vue-slots="{{['default']}}"><view class="popup__container"><view class="popup__modal"><view class="popup__title"><text class="popup__title-text">请选择回收方式</text><image class="popup__close" style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/close.png'}}" data-event-opts="{{[['tap',[['changeGlistDialog',['$event']]]]]}}" catchtap="__e"></image></view><view class="popup__content"><block s-for="$root.l1" s-for-item="item" s-for-index="index"><block><view class="clist-item" data-id="{{item.$orig.id}}" data-key="{{index}}" data-event-opts="{{[['tap',[['recycleChange',['$event']]]]]}}" bindtap="__e"><view class="flex1">{{item.$orig.name}}</view><view class="radio" style="{{(item.$orig.id==recycle_type?'background:'+item.m11+';border:0':'')}}"><image class="radio-img" src="{{pre_url+'/static/img/checkd.png'}}"></image></view></view></block></block></view></view></view></uni-popup><block s-if="{{loading}}"><loading vue-id="26b8d586-4"></loading></block></view>