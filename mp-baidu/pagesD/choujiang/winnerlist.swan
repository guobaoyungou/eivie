<view class="container"><block s-if="{{isload}}"><block><view class="order-content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><block><view class="order-box"><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center"><view class="head-title">{{"中奖用户："+item.nickname}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"获得奖品："+item.award_name}}</view></view></view><view class="head flex flex-y-center"><view class="head-top-view flex flex-y-center" style="width:100%;"><view class="head-title">{{"参与时间："+item.createtime}}</view></view></view></view></block></block></view><block s-if="{{nomore}}"><nomore vue-id="d4e26dac-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="d4e26dac-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="d4e26dac-3"></loading></block><dp-tabbar vue-id="d4e26dac-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="d4e26dac-5" data-ref="popmsg"></popmsg></view>