<view class="container"><block s-if="{{isload}}"><block><view class="top-nav"><view class="{{['nav-item',st==2?'active':'']}}" data-status="2" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>全部</text></view><view class="{{['nav-item',st==1?'active':'']}}" data-status="1" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>已种植</text></view><view class="{{['nav-item',st==0?'active':'']}}" data-status="0" data-event-opts="{{[['tap',[['changeStatus',['$event']]]]]}}" bindtap="__e"><text>未种植</text></view></view><block><view class="farm-list"><block s-for="datalist trackBy item.id" s-for-item="item" s-for-index="index"><view class="item"><text class="num">{{item.sort+"号"}}</text><view class="media"><image class="icon" style="max-width:100rpx;" src="{{item.logo}}" mode="widthFix"></image><text class="label">{{item.name}}</text><text class="label" style="font-size:16rpx;">{{"(ID:"+item.id+")"}}</text></view><block s-if="{{item.tree_status==1}}"><block><view class="progress-bar"><image class="background" src="{{pre_url+'/static/img/farm/jdt_bg.png'}}" mode="widthFix"></image><view class="inner"><view class="clip-box" style="{{'width:'+(item.tree_progress+'%')+';'+('background-image:'+('url('+pre_url+'/static/img/farm/jdt.png)')+';')}}"></view></view></view><text class="progress">{{item.tree_progress+"%"}}</text></block></block><block s-if="{{item.tree_status!=1}}"><block><view class="progress-bar"></view></block></block><block s-if="{{item.tree_status==1}}"><text class="button" data-url="{{'/pagesD/farm/landdetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">进入</text></block><block s-else><text class="button" data-id="{{item.id}}" data-event-opts="{{[['tap',[['addtree',['$event']]]]]}}" bindtap="__e">种植</text></block></view></block></view></block><block s-if="{{nodata}}"><nodata vue-id="36f5f776-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="36f5f776-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="36f5f776-3"></loading></block><dp-tabbar vue-id="36f5f776-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="36f5f776-5" data-ref="popmsg"></popmsg></view>