<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="131e3fc8-1" itemdata="{{tabdata}}" itemst="{{tabitems}}" st="{{st}}" showstatus="{{showstatus}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="myscore" style="{{'background:'+($root.m0)+';'}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">{{"我的"+fert_name}}</view><view class="value" style="margin-top:20rpx;">{{remain}}</view><block s-if="{{show_buy}}"><view class="btn" data-url="/pagesD/farm/buy" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">兑换</view></block></view></view><block s-if="{{show_ljnum==1}}"><view class="item flex-bt flex-y-center"><view><view class="label flex-y-center">累计获得</view><view class="value" style="margin-top:20rpx;">{{ljnum}}</view></view></view></block></view><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text><text class="t3">{{"变更后"+$root.m1+": "+item.after}}</text></view><view class="f2"><block s-if="{{item.num>0}}"><text class="t1">{{"+"+item.num}}</text></block><block s-else><text class="t2">{{item.num}}</text></block></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="131e3fc8-2"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="131e3fc8-3"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="131e3fc8-4"></loading></block><dp-tabbar vue-id="131e3fc8-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="131e3fc8-6" data-ref="popmsg"></popmsg></view>