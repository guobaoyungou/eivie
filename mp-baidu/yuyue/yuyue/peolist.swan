<view class="container"><block s-if="{{isload}}"><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="输入姓名/手机号搜索" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view></view><view class="order-tab"><view class="order-tab2"><view class="{{['item '+(curTopIndex==-1?'on':'')]}}" data-index="{{-1}}" data-id="{{0}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">全部<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['item '+(curTopIndex==index?'on':'')]}}" data-index="{{index}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view></block></block></view></view><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="content flex" data-id="{{item.id}}"><view class="f1" data-url="{{'peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="headimg"><image src="{{item.headimg}}"></image></view><view class="text1"><text class="t1">{{item.realname+''}}</text><block s-if="{{item.typename}}"><text class="t2">{{item.typename+''}}</text></block><view class="text2">{{item.jineng}}</view><view class="text3 flex"><view class="t4">服务<text>{{''+item.totalnum}}</text>次</view><view class="t5">评分<text>{{item.comment_score}}</text></view></view></view></view><view><view class="yuyue" style="{{'background:'+($root.m2)+';'}}" data-url="{{'/yuyue/yuyue/peodetail?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">预约</view></view></view></block><block s-if="{{nodata}}"><nodata vue-id="f7f2727e-1"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="f7f2727e-2"></nomore></block></block></block><block s-if="{{loading}}"><loading vue-id="f7f2727e-3"></loading></block><dp-tabbar vue-id="f7f2727e-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="f7f2727e-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="f7f2727e-6"></wxxieyi></view>