<view class="container"><block s-if="{{isload}}"><block><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="content flex" data-id="{{item.id}}" data-realname="{{item.realname}}" data-tel="{{item.tel}}" data-yystatus="{{item.yystatus}}" data-event-opts="{{[['tap',[['setdefault',['$event']]]]]}}" catchtap="__e"><view class="f1"><view class="headimg"><block s-if="{{item.headimg}}"><image src="{{item.headimg}}"></image></block><block s-else><image src="{{pre_url+'/static/img/touxiang.png'}}"></image></block></view><view class="text1"><text class="t1">{{item.realname+''}}</text><block s-if="{{item.typename}}"><text class="t2">{{item.typename}}</text></block><view class="text2">{{item.jineng}}</view></view></view><view class="{{['yuyue '+(item.yystatus==-1?'hui':'')]}}">预约</view></view></block><block s-if="{{nodata}}"><nodata vue-id="cc4f34cc-1"></nodata></block><view style="height:140rpx;"></view></block></block><block s-if="{{loading}}"><loading vue-id="cc4f34cc-2"></loading></block><dp-tabbar vue-id="cc4f34cc-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="cc4f34cc-4" data-ref="popmsg"></popmsg></view>