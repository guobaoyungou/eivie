<view class="container"><block s-if="{{isload}}"><block><view class="topbox"><view class="order-tab"><view class="order-tab2"><view class="{{['item '+(curIndex==-1?'on':'')]}}" data-index="-1" data-id="0" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">全部<view class="after" style="{{'background:'+($root.m0)+';'}}"></view></view><block s-for="clist trackBy index" s-for-item="item" s-for-index="index"><block><view class="{{['item '+(curIndex==index?'on':'')]}}" data-index="{{index}}" data-id="{{item.appid}}" data-event-opts="{{[['tap',[['switchTopTab',['$event']]]]]}}" bindtap="__e">{{item.name}}<view class="after" style="{{'background:'+($root.m1)+';'}}"></view></view></block></block></view></view><block s-if="{{curIndex!='-1'}}"><view class="classify-ul"><view class="libox flex" style="width:100%;"><block s-for="$root.l0 trackBy idx2" s-for-item="item" s-for-index="idx2"><block><view class="classify-li" style="{{(curIndex2==idx2?'color:'+item.m2+';background:rgba('+item.m3+',0.2)':'')}}" data-id="{{item.$orig.appid}}" data-index="{{idx2}}" data-event-opts="{{[['tap',[['changeCTab',['$event']]]]]}}" bindtap="__e">{{item.$orig.name}}</view></block></block></view></view></block></view><view class="content flex" style="{{(curIndex==-1?'top: 100rpx;':'top:'+toppx)}}"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="f1" data-url="{{'peodetail2?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e"><view class="headimg"><image src="{{item.avatar}}"></image></view><view class="text1 flex"><text class="t1">{{item.name+''}}</text><text class="t3">{{item.distanceDesc+''}}</text></view><view class="text3 flex"><block s-if="{{curIndex==-1}}"><view class="t3">{{"接单量:"+item.acceptOrderTotal+''}}<text class="statusdesc">{{item.statusDesc}}</text></view></block><block s-else><text class="t3">{{item.priceDesc+''}}</text></block><view class="yuyue" style="{{'background:'+($root.m4)+';'}}" data-url="{{'/yuyue/yuyue/peodetail2?id='+item.id}}" data-event-opts="{{[['tap',[['goto',['$event']]]]]}}" bindtap="__e">预约</view></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="0050c3ea-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="0050c3ea-2"></nodata></block></block></block><block s-if="{{loading}}"><loading vue-id="0050c3ea-3"></loading></block><dp-tabbar vue-id="0050c3ea-4" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="0050c3ea-5" data-ref="popmsg"></popmsg><wxxieyi vue-id="0050c3ea-6"></wxxieyi></view>