<view><block s-if="{{isload}}"><block><view class="address"><view class="img"><image src="{{pre_url+'/static/img/address3.png'}}"></image></view><view class="info"><text class="t1">{{order.linkman+" "+order.tel}}</text><block s-if="{{order.fwtype==2}}"><text class="t2">{{"地址："+order.area+order.address}}</text></block></view></view><view class="product"><block s-for="order.prolist trackBy idx" s-for-item="item" s-for-index="idx"><view class="content"><view><image src="{{item.pic}}"></image></view><view class="detail"><text class="t1">{{item.name}}</text><block s-if="{{item.ggname}}"><text class="t2">{{item.ggname}}</text></block><view class="t3"><text class="x1 flex1">{{"￥"+item.sell_price}}</text><text class="x2">{{"×"+item.num}}</text></view></view></view></block></view><view class="orderinfo"><view class="item"><text class="t1">下单人</text><text class="flex1"></text><image style="width:80rpx;height:80rpx;margin-right:8rpx;" src="{{order.headimg}}"></image><text style="height:80rpx;line-height:80rpx;">{{order.nickname}}</text></view><view class="item"><text class="t1">{{$root.m0+"ID"}}</text><text class="t2">{{order.mid}}</text></view></view><block s-if="{{order.remark}}"><view class="orderinfo"><view class="item"><text class="t1">备注</text><text class="t2">{{order.remark}}</text></view></view></block><view class="orderinfo"><view class="item"><text class="t1">订单编号</text><text class="t2" user-select="true" selectable="true">{{order.ordernum}}</text></view><view class="item"><text class="t1">下单时间</text><text class="t2">{{order.createtime}}</text></view><block s-if="{{order.status>0&&order.paytypeid!='4'&&order.paytime}}"><view class="item"><text class="t1">支付时间</text><text class="t2">{{order.paytime}}</text></view></block><block s-if="{{order.status>0&&order.paytime}}"><view class="item"><text class="t1">支付方式</text><text class="t2">{{order.paytype}}</text></view></block><block s-if="{{order.status>1&&order.send_time}}"><view class="item"><text class="t1">派单时间</text><text class="t2">{{order.send_time}}</text></view></block><block s-if="{{order.status==3&&order.collect_time}}"><view class="item"><text class="t1">完成时间</text><text class="t2">{{order.collect_time}}</text></view></block></view><view class="orderinfo"><view class="item"><text class="t1">商品金额</text><text class="t2 red">{{"¥"+order.product_price}}</text></view><view class="item"><text class="t1">服务方式</text><text class="t2">{{order.fwtype==1?'到店服务':'上门服务'}}</text></view><block s-if="{{order.freight_time}}"><view class="item"><text class="t1">{{(order.freight_type!=1?'配送':'提货')+"时间"}}</text><text class="t2">{{order.freight_time}}</text></view></block><block s-if="{{order.scoredk>0}}"><view class="item"><text class="t1">{{$root.m1+"抵扣"}}</text><text class="t2 red">{{"-¥"+order.scoredk_money}}</text></view></block><view class="item"><text class="t1">实付款</text><text class="t2 red">{{"¥"+order.totalprice}}</text></view><view class="item"><text class="t1">订单状态</text><block s-if="{{order.status==0}}"><text class="t2">未付款</text></block><block s-if="{{order.status==1}}"><text class="t2">已付款</text></block><block s-if="{{order.status==2}}"><text class="t2">已派单</text></block><block s-if="{{order.status==3}}"><text class="t2">已完成</text></block><block s-if="{{order.status==4}}"><text class="t2">已关闭</text></block></view><block s-if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款状态</text><block s-if="{{order.refund_status==1}}"><text class="t2 red">{{"审核中,¥"+order.refund_money}}</text></block><block s-if="{{order.refund_status==2}}"><text class="t2 red">{{"已退款,¥"+order.refund_money}}</text></block><block s-if="{{order.refund_status==3}}"><text class="t2 red">{{"已驳回,¥"+order.refund_money}}</text></block></view></block><block s-if="{{order.refund_status>0}}"><view class="item"><text class="t1">退款原因</text><text class="t2 red">{{order.refund_reason}}</text></view></block><block s-if="{{order.refund_checkremark}}"><view class="item"><text class="t1">审核备注</text><text class="t2 red">{{order.refund_checkremark}}</text></view></block><view class="item"><text class="t1">备注</text><text class="t2 red">{{order.message?order.message:'无'}}</text></view></view><view style="height:140rpx;"></view><block s-if="{{order.status==1||order.status==2}}"><view data-event-opts="{{[['tap',[['hexiao',['$event']]]]]}}" class="btn-add" style="{{'background:'+($root.m2)+';'}}" bindtap="__e">立即核销</view></block></block></block></view>