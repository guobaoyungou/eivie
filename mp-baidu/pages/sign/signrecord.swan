<view class="container"><view class="content"><block s-for="datalist trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text class="t1">{{item.remark}}</text><text class="t2">{{item.createtime}}</text></view><view class="f2"><text class="t1">{{"+"+item.score}}</text></view></view></block></view><block s-if="{{nomore}}"><nomore vue-id="6255ccc0-1"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="6255ccc0-2"></nodata></block><block s-if="{{loading}}"><loading vue-id="6255ccc0-3"></loading></block><dp-tabbar vue-id="6255ccc0-4" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="6255ccc0-5" data-ref="popmsg"></popmsg></view>