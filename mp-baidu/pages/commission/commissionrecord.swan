<view class="container"><block s-if="{{isload}}"><block><dd-tab vue-id="74d4a980-1" itemdata="{{['全部','已发放','未发放']}}" itemst="{{['0','1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab><view class="content"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f2"><view class="t1"><text class="x1">{{item.$orig.remark}}</text><text class="x2">{{"产生时间："+item.m0}}</text><view class="x3">来源：<image src="{{item.$orig.fromheadimg}}"></image>{{item.$orig.fromnickname}}</view></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block s-if="{{item.$orig.status==0}}"><block><block s-if="{{item.$orig.orderstatus==1||item.$orig.orderstatus==2}}"><text class="dior-sp6 yfk">已付款</text></block><block s-if="{{item.$orig.orderstatus==0}}"><text class="dior-sp6 dfk">待付款</text></block><block s-if="{{item.$orig.orderstatus==3}}"><text class="dior-sp6 ywc">待发放</text></block><block s-if="{{item.$orig.orderstatus==4}}"><text class="dior-sp6 ygb">已关闭</text></block></block></block><block s-if="{{item.$orig.status==1}}"><block><text class="dior-sp6 yfk">已发放</text></block></block></view></view></view></block></view></block></block><block s-if="{{nodata}}"><nodata vue-id="74d4a980-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="74d4a980-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="74d4a980-4"></loading></block><dp-tabbar vue-id="74d4a980-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="74d4a980-6" data-ref="popmsg"></popmsg></view>