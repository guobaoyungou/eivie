<view class="container"><block s-if="{{isload}}"><block><view class="topfix"><view class="toplabel"><text class="t1">{{"分红订单（"+count+"）"}}</text><text class="t2">{{"预计：+"+commissionyj+"元"}}</text></view><dd-tab vue-id="945f0ce0-1" itemdata="{{['待结算','已结算']}}" itemst="{{['1','2']}}" st="{{st}}" isfixed="{{false}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></view><view style="margin-top:190rpx;"></view><block s-if="{{datalist&&datalist.length>0}}"><block><view class="content"><block s-if="{{st==1}}"><block><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text>{{item.$orig.ordernum}}</text></view><view class="f2"><view class="t1"><text class="x1">{{item.$orig.name+" ×"+item.$orig.num}}</text><text class="x2" style="{{'font-size:28rpx;'+('color:'+($root.m0)+';')}}">{{"￥"+item.$orig.real_totalprice}}</text><text class="x2">{{item.m1}}</text><view class="x3"><image src="{{item.$orig.headimg}}"></image>{{item.$orig.nickname}}</view></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text><block s-if="{{item.$orig.status==1||item.$orig.status==2}}"><text class="dior-sp6 yfk">已付款</text></block><block s-if="{{item.$orig.status==0}}"><text class="dior-sp6 dfk">待付款</text></block><block s-if="{{item.$orig.status==3}}"><text class="dior-sp6 ywc">已完成</text></block><block s-if="{{item.$orig.status==4}}"><text class="dior-sp6 ygb">已关闭</text></block><block s-if="{{item.$orig.refund_money>0}}"><text class="dior-sp6 ygb">退款/售后</text></block></view></view></view></block></block></block><block s-if="{{st==2}}"><block><block s-for="$root.l2 trackBy index" s-for-item="item" s-for-index="index"><view class="item"><view class="f1"><text>{{item.$orig.remark+" "+item.m2}}</text></view><view class="f2"><view class="t1"><block s-for="item.l1 trackBy index" s-for-item="item2" s-for-index="index"><view class="item2"><text class="x1">{{item2.$orig.name+" ×"+item2.$orig.num}}</text><text class="x2" style="{{'font-size:28rpx;'+('color:'+(item.m3)+';')}}">{{"￥"+item2.$orig.real_totalprice}}</text><text class="x2">{{item2.m4}}</text><view class="x3"><image src="{{item2.$orig.headimg}}"></image>{{item2.$orig.nickname}}</view></view></block></view><view class="t2"><text class="x1">{{"+"+item.$orig.commission}}</text></view></view></view></block></block></block></view></block></block><view style="width:100%;height:20rpx;"></view></block></block><block s-if="{{nodata}}"><nodata vue-id="945f0ce0-2"></nodata></block><block s-if="{{nomore}}"><nomore vue-id="945f0ce0-3"></nomore></block><block s-if="{{loading}}"><loading vue-id="945f0ce0-4"></loading></block><dp-tabbar vue-id="945f0ce0-5" opt="{{opt}}"></dp-tabbar><popmsg class="vue-ref" vue-id="945f0ce0-6" data-ref="popmsg"></popmsg></view>