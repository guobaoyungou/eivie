<block s-if="{{isload}}"><view class="container" style="{{'background-color:'+(pageinfo.bgcolor)+';'}}"><block><dp vue-id="1a1465b0-1" pagecontent="{{pagecontent}}" menuindex="{{menuindex}}" latitude="{{latitude}}" longitude="{{longitude}}" htsignatureurl="{{htsignatureurl}}" data-event-opts="{{[['^getdata',[['getdata']]]]}}" bind:getdata="__e"></dp><dp-guanggao vue-id="1a1465b0-2" guanggaopic="{{guanggaopic}}" guanggaourl="{{guanggaourl}}" guanggaotype="{{guanggaotype}}" param="{{guanggaoparam}}"></dp-guanggao><dp-tabbar vue-id="1a1465b0-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><block s-if="{{isshare}}"><dp-sharegive vue-id="1a1465b0-4" sharegive="{{sharegive}}" data-event-opts="{{[['^toshare',[['toshare']]]]}}" bind:toshare="__e"></dp-sharegive></block></block><popmsg class="vue-ref" vue-id="1a1465b0-5" data-ref="popmsg"></popmsg><block s-if="{{loading}}"><loading vue-id="1a1465b0-6"></loading></block><wxxieyi vue-id="1a1465b0-7"></wxxieyi></view></block>