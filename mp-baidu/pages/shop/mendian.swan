<view><block><block s-if="{{isload}}"><view class="container nodiydata"><view class="bg-red" style="{{'background:'+($root.m0)+';'}}"></view><view class="topcontent"><view class="logo"><image class="img" src="{{info.pic}}"></image></view><view class="title">{{info.name}}</view><view class="desc"><block s-if="{{info.subname}}"><block>{{info.subname}}</block></block></view><view class="tel" style="{{'background:'+('linear-gradient(90deg,'+$root.m1+' 0%, rgba('+$root.m2+',0.8) 100%)')+';'}}"><view class="tel_online" data-phone="{{info.tel}}" data-event-opts="{{[['tap',[['phone',['$event']]]]]}}" bindtap="__e"><image class="img" src="{{pre_url+'/static/img/telwhite.png'}}"></image>联系门店</view></view><view class="address" data-latitude="{{info.latitude}}" data-longitude="{{info.longitude}}" data-company="{{info.name}}" data-address="{{info.address}}" data-event-opts="{{[['tap',[['openLocation',['$event']]]]]}}" bindtap="__e"><image class="f1" src="{{pre_url+'/static/img/shop_addr.png'}}"></image><view class="f2">{{info.address}}</view><image class="f3" src="{{pre_url+'/static/img/arrowright.png'}}"></image></view><view class="img-view"><block s-for="pics trackBy index" s-for-item="item" s-for-index="index"><block s-if="{{pics.length>0}}"><view><image class="image" src="{{item}}" mode="widthFix" data-url="{{item}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></view></block></block></view></view><block s-if="{{info.content}}"><view class="contentbox"><view class="cp_detail" style="padding:20rpx;"><parse vue-id="b4813ca2-1" content="{{info.content}}"></parse></view></view></block></view></block></block><block s-if="{{loading}}"><loading vue-id="b4813ca2-2"></loading></block><dp-tabbar vue-id="b4813ca2-3" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="b4813ca2-4" data-ref="popmsg"></popmsg></view>