<view class="container"><block s-if="{{isload}}"><block><view class="search-container" style="{{(history_show?'height:100%;':'')}}"><block s-if="{{topshowcategory==1}}"><block><dd-tab vue-id="b568e5e8-1" itemdata="{{itemdata}}" itemst="{{itemst}}" st="{{cid}}" isfixed="{{true}}" data-event-opts="{{[['^changetab',[['changetab']]]]}}" bind:changetab="__e"></dd-tab></block></block><block s-else><block><view class="topsearch flex-y-center"><view class="f1 flex-y-center"><image class="img" src="{{pre_url+'/static/img/search_ico.png'}}"></image><input placeholder="搜索感兴趣的商品" placeholder-style="font-size:24rpx;color:#C2C2C2" data-event-opts="{{[['confirm',[['searchConfirm',['$event']]]],['input',[['searchChange',['$event']]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/></view><view data-event-opts="{{[['tap',[['searchbtn',['$event']]]]]}}" class="search-btn" bindtap="__e"><block s-if="{{!history_show&&productlisttype=='itemlist'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-cascades.png'}}"></image></block><block s-if="{{!history_show&&productlisttype=='item2'}}"><image style="height:36rpx;width:36rpx;" src="{{pre_url+'/static/img/show-list.png'}}"></image></block><block s-if="{{history_show}}"><text>搜索</text></block></view></view><view hidden="{{!(history_show)}}" class="search-history"><view><text class="search-history-title">最近搜索</text><view data-event-opts="{{[['tap',[['deleteSearchHistory',['$event']]]]]}}" class="delete-search-history" bindtap="__e"><image style="width:36rpx;height:36rpx;" src="{{pre_url+'/static/img/del.png'}}"></image></view></view><view class="search-history-list"><block s-for="history_list trackBy index" s-for-item="item" s-for-index="index"><view class="search-history-item" data-value="{{item}}" data-event-opts="{{[['tap',[['historyClick',['$event']]]]]}}" bindtap="__e">{{item+''}}</view></block><block s-if="{{!history_list||history_list.length==0}}"><view class="flex-y-center"><image style="width:36rpx;height:36rpx;margin-right:10rpx;" src="{{pre_url+'/static/img/tanhao.png'}}"></image>暂无记录</view></block></view><block s-if="{{group_multi_select==1}}"><view style="margin-top:35rpx;"><view><text class="search-history-title">商品分组</text></view><view class="search-history-list"><block s-for="$root.l0 trackBy index" s-for-item="item" s-for-index="index"><block><view class="search-history-item tjgroup" style="{{(catchegid==item.$orig.id?'color:'+item.m0+';background:rgba('+item.m1+',0.1)':'')}}" data-gid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['groupClickSearch',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></view></block></view><view hidden="{{!(!history_show)}}" class="search-navbar"><view class="search-navbar-item" style="{{(!field||field=='sort'?'color:'+$root.m2:'')}}" data-field="sort" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e">综合</view><block s-if="{{$root.g0}}"><view class="search-navbar-item" style="{{(field=='sales'?'color:'+$root.m3:'')}}" data-field="sales" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e">销量</view></block><block s-if="{{$root.g1}}"><view class="search-navbar-item" style="{{(field=='stock'?'color:'+$root.m4:'')}}" data-field="stock" data-order="desc" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e">现货</view></block><view class="search-navbar-item" data-field="sell_price" data-order="{{order=='asc'?'desc':'asc'}}" data-event-opts="{{[['tap',[['sortClick',['$event']]]]]}}" catchtap="__e"><text style="{{(field=='sell_price'?'color:'+$root.m5:'')}}">价格</text><text class="iconfont iconshangla" style="{{(field=='sell_price'&&order=='asc'?'color:'+$root.m6:'')}}"></text><text class="iconfont icondaoxu" style="{{(field=='sell_price'&&order=='desc'?'color:'+$root.m7:'')}}"></text></view><view data-event-opts="{{[['tap',[['showDrawer',['showRight']]]]]}}" class="search-navbar-item flex-x-center flex-y-center" catchtap="__e">筛选<text class="{{['iconfont iconshaixuan '+(showfilter?'active':'')]}}"></text></view></view></block></block><uni-drawer class="vue-ref" vue-id="b568e5e8-2" mode="right" width="{{280}}" data-ref="showRight" data-event-opts="{{[['^change',[['change',['$event','showRight']]]]]}}" bind:change="__e" vue-slots="{{['default']}}"><scroll-view class="filter-scroll-view filter-page" scroll-y="true"><view class="filter-scroll-view-box"><view class="search-filter"><view class="filter-title">筛选</view><view class="filter-content-title">商品分组</view><block s-if="{{group_multi_select==1}}"><view class="search-filter-content"><view class="filter-item" style="{{(catchegid.length==0?'color:'+$root.m8+';background:rgba('+$root.m9+',0.1)':'')}}" data-gid data-event-opts="{{[['tap',[['groupClick',['$event']]]]]}}" catchtap="__e">全部</view><block s-for="$root.l1 trackBy index" s-for-item="item" s-for-index="index"><block><view class="filter-item" style="{{(item.g2!=-1?'color:'+item.m10+';background:rgba('+item.m11+',0.1)':'')}}" data-gid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['groupClick',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block><block s-else><view class="search-filter-content"><view class="filter-item" style="{{(catchegid==''?'color:'+$root.m12+';background:rgba('+$root.m13+',0.1)':'')}}" data-gid data-event-opts="{{[['tap',[['groupClick',['$event']]]]]}}" catchtap="__e">全部</view><block s-for="$root.l2 trackBy index" s-for-item="item" s-for-index="index"><block><view class="filter-item" style="{{(catchegid==item.$orig.id?'color:'+item.m14+';background:rgba('+item.m15+',0.1)':'')}}" data-gid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['groupClick',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block><block s-if="{{!bid||bid<=0}}"><block><view class="filter-content-title">商品分类</view><view class="search-filter-content"><view class="filter-item" style="{{(catchecid==oldcid?'color:'+$root.m16+';background:rgba('+$root.m17+',0.1)':'')}}" data-cid="{{oldcid}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchtap="__e">全部</view><block s-for="$root.l3 trackBy index" s-for-item="item" s-for-index="index"><block><view class="filter-item" style="{{(catchecid==item.$orig.id?'color:'+item.m18+';background:rgba('+item.m19+',0.1)':'')}}" data-cid="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cateClick',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block></block><block s-else><block><view class="filter-content-title">商品分类</view><view class="search-filter-content"><view class="filter-item" style="{{(catchecid2==oldcid2?'color:'+$root.m20+';background:rgba('+$root.m21+',0.1)':'')}}" data-cid2="{{oldcid2}}" data-event-opts="{{[['tap',[['cate2Click',['$event']]]]]}}" catchtap="__e">全部</view><block s-for="$root.l4 trackBy index" s-for-item="item" s-for-index="index"><block><view class="filter-item" style="{{(catchecid2==item.$orig.id?'color:'+item.m22+';background:rgba('+item.m23+',0.1)':'')}}" data-cid2="{{item.$orig.id}}" data-event-opts="{{[['tap',[['cate2Click',['$event']]]]]}}" catchtap="__e">{{item.$orig.name}}</view></block></block></view></block></block><block s-for="$root.l6" s-for-item="item" s-for-index="index"><block><view class="filter-content-title">{{item.$orig.name}}</view><view class="search-filter-content"><view class="filter-item" style="{{(catcheparams[item.$orig.name]==''?'color:'+item.m24+';background:rgba('+item.m25+',0.1)':'')}}" data-paramkey="{{item.$orig.name}}" data-paramval data-event-opts="{{[['tap',[['paramClick',['$event']]]]]}}" catchtap="__e">全部</view><block s-for="item.l5 trackBy index" s-for-item="item2" s-for-index="index"><block><view class="filter-item" style="{{(catcheparams[item.$orig.name]==item2.$orig?'color:'+item2.m26+';background:rgba('+item2.m27+',0.1)':'')}}" data-paramkey="{{item.$orig.name}}" data-paramval="{{item2.$orig}}" data-event-opts="{{[['tap',[['paramClick',['$event']]]]]}}" catchtap="__e">{{item2.$orig}}</view></block></block></view></block></block><view class="search-filter-btn"><view data-event-opts="{{[['tap',[['filterReset',['$event']]]]]}}" class="btn btn-class" catchtap="__e">重置</view><view data-event-opts="{{[['tap',[['filterConfirm',['$event']]]]]}}" class="btn2 btn-class" style="{{'background:'+($root.m28)+';'}}" catchtap="__e">确定</view></view></view></view><view class="filter-cut"></view></scroll-view></uni-drawer></view><view class="product-container" style="{{'margin-top:'+(topshowcategory==1?'110rpx':'190rpx')+';'}}"><block s-if="{{datalist&&datalist.length>0}}"><block><block s-if="{{productlisttype=='item2'}}"><dp-product-item vue-id="b568e5e8-3" data="{{datalist}}" showsales="{{hide_sales}}" showstock="{{hide_stock}}" menuindex="{{menuindex}}"></dp-product-item></block><block s-if="{{productlisttype=='itemlist'}}"><dp-product-itemlist vue-id="b568e5e8-4" data="{{datalist}}" showsales="{{hide_sales}}" showstock="{{hide_stock}}" menuindex="{{menuindex}}"></dp-product-itemlist></block></block></block><block s-if="{{nomore}}"><nomore vue-id="b568e5e8-5" text="没有更多商品了"></nomore></block><block s-if="{{nodata}}"><nodata vue-id="b568e5e8-6" text="没有查找到相关商品"></nodata></block><block s-if="{{loading}}"><loading vue-id="b568e5e8-7"></loading></block></view></block></block><view style="display:none;">{{test}}</view><block s-if="{{loading}}"><loading vue-id="b568e5e8-8"></loading></block><dp-tabbar vue-id="b568e5e8-9" opt="{{opt}}" data-event-opts="{{[['^getmenuindex',[['getmenuindex']]]]}}" bind:getmenuindex="__e"></dp-tabbar><popmsg class="vue-ref" vue-id="b568e5e8-10" data-ref="popmsg"></popmsg><wxxieyi vue-id="b568e5e8-11"></wxxieyi></view>