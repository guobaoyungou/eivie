
.tuchu {
	position: absolute;
	top: 0;
	left: 0;
	bottom: 0;
	right: 0;
	background-color: rgba(0, 0, 0, 0.75);
	z-index: 9999;
	display: none
}

.tuchug {
	border-radius: 100%;
	top: 50%;
	left: 50%;
	margin: -350px 0 0 -350px;
	width: 700px;
	height: 700px;
	position: absolute;
	z-index: 4;
}

.tuchuk {
	background-color: #FFF;
	border-radius: 10px;
	top: 50%;
	left: 50%;
	margin: -200px 0 0 -150px;
	width: 300px;
	height: 400px;
	position: absolute;
	z-index: 4;
}

.tx {
	width: 226px;
	height: 226px;
	border-radius: 100%;
	overflow: hidden;
	margin: 40px 37px 15px 37px;
}

.xm {
	font-size: 20px;
	color: #000;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
	padding: 12px 0;
	text-align: center;
	position: absolute;
	bottom: 0;
	margin: 0;
	width: 100%;
	background-color: rgba(245, 245, 245, 0.57);
	border-radius: 0 0 10px 10px;
}

.pm {
	font-size: 20px;
	text-align: center;
	background-color: rgba(255, 255, 255, 1);
	color: #000;
	margin: 15px auto;
	padding: 0;
	border-radius: 100px;
	width: 75%;
}

.pm .red {
	color: #ff7575;
}

.tuchu.view {
	display: block;
	-webkit-animation: vp 0.5s 8s ease forwards;
	-moz-animation: vp 0.5s 8s ease forwards;
	animation: vp 0.5s 8s ease forwards;
}

.view .tuchuk {
	-webkit-animation: vv 8s 0s ease forwards;
	-moz-animation: vv 8s 0s ease forwards;
	animation: vv 8s 0s ease forwards;
}

.view .tuchug {
	-webkit-animation: vg 6.5s 1s ease forwards;
	-moz-animation: vg 6.5s 1s ease forwards;
	animation: vg 6.5s 1s ease forwards;
	opacity: 0;
}

@-webkit-keyframes vv {
	0% {
		-webkit-transform: scale(0.1);
		opacity: 0;
	}

	10% {
		-webkit-transform: scale(1.5);
		opacity: 1;
	}

	20% {
		-webkit-transform: scale(1);
		opacity: 1;
	}

	90% {
		-webkit-transform: scale(1);
		opacity: 1;
	}

	100% {
		-webkit-transform: scale(0);
		opacity: 0;
	}
}

@-webkit-keyframes vp {
	0% {
		-webkit-transform: scale(1);
		opacity: 1;
	}

	100% {
		-webkit-transform: scale(1);
		opacity: 0;
	}
}

@-webkit-keyframes vg {
	0% {
		-webkit-transform: rotate(0);
		opacity: 0;
	}

	10% {
		-webkit-transform: rotate(0);
		opacity: 1;
	}

	90% {
		-webkit-transform: rotate(60deg);
		opacity: 1;
	}

	100% {
		-webkit-transform: rotate(70deg);
		opacity: 0;
	}
}

/* Standard (unprefixed) keyframes */
@keyframes vv {
	0% { transform: scale(0.1); opacity: 0; }
	10% { transform: scale(1.5); opacity: 1; }
	20% { transform: scale(1); opacity: 1; }
	90% { transform: scale(1); opacity: 1; }
	100% { transform: scale(0); opacity: 0; }
}

@keyframes vp {
	0% { transform: scale(1); opacity: 1; }
	100% { transform: scale(1); opacity: 0; }
}

@keyframes vg {
	0% { transform: rotate(0); opacity: 0; }
	10% { transform: rotate(0); opacity: 1; }
	90% { transform: rotate(60deg); opacity: 1; }
	100% { transform: rotate(70deg); opacity: 0; }
}

/* 突出卡片样式 - Sphere（球形布局） */
.sphere.view .tuchuk {
	-webkit-animation: sphere-animation var(--highlight-duration, 8s) 0s ease forwards;
	-moz-animation: sphere-animation var(--highlight-duration, 8s) 0s ease forwards;
	animation: sphere-animation var(--highlight-duration, 8s) 0s ease forwards;
}

@keyframes sphere-animation {
	0% { 
		transform: scale(0.1) rotate(0deg); 
		opacity: 0; 
		border-radius: 50%;
	}
	10% { 
		transform: scale(var(--highlight-scale, 1.5)) rotate(180deg); 
		opacity: 1; 
		border-radius: 50%;
		box-shadow: 0 0 50px rgba(255, 117, 117, 0.8);
	}
	20% { 
		transform: scale(1) rotate(360deg); 
		opacity: 1; 
		border-radius: 50%;
		box-shadow: 0 0 20px rgba(255, 117, 117, 0.5);
	}
	90% { 
		transform: scale(1) rotate(360deg); 
		opacity: 1; 
		border-radius: 50%;
		box-shadow: 0 0 20px rgba(255, 117, 117, 0.5);
	}
	100% { 
		transform: scale(0) rotate(540deg); 
		opacity: 0; 
		border-radius: 50%;
	}
}

.sphere.view .tuchug {
	-webkit-animation: sphere-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	-moz-animation: sphere-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	animation: sphere-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	opacity: 0;
	border-radius: 50%;
}

@keyframes sphere-glow {
	0% { 
		transform: rotate(0) scale(0.8);
		opacity: 0;
		box-shadow: 0 0 0 rgba(255, 117, 117, 0);
	}
	50% { 
		transform: rotate(180deg) scale(1.2);
		opacity: 0.7;
		box-shadow: 0 0 80px rgba(255, 117, 117, 0.6);
	}
	100% { 
		transform: rotate(360deg) scale(0.8);
		opacity: 0;
		box-shadow: 0 0 0 rgba(255, 117, 117, 0);
	}
}

/* 突出卡片样式 - Cube（立方体布局） */
.cube.view .tuchuk {
	-webkit-animation: cube-animation var(--highlight-duration, 8s) 0s ease forwards;
	-moz-animation: cube-animation var(--highlight-duration, 8s) 0s ease forwards;
	animation: cube-animation var(--highlight-duration, 8s) 0s ease forwards;
}

@keyframes cube-animation {
	0% { 
		transform: scale(0.1) rotateX(0deg) rotateY(0deg); 
		opacity: 0; 
	}
	10% { 
		transform: scale(var(--highlight-scale, 1.5)) rotateX(180deg) rotateY(180deg); 
		opacity: 1; 
		box-shadow: 15px 15px 30px rgba(0, 0, 0, 0.3);
	}
	20% { 
		transform: scale(1) rotateX(360deg) rotateY(360deg); 
		opacity: 1; 
		box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.2);
	}
	90% { 
		transform: scale(1) rotateX(360deg) rotateY(360deg); 
		opacity: 1; 
		box-shadow: 5px 5px 15px rgba(0, 0, 0, 0.2);
	}
	100% { 
		transform: scale(0) rotateX(540deg) rotateY(540deg); 
		opacity: 0; 
	}
}

.cube.view .tuchug {
	-webkit-animation: cube-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	-moz-animation: cube-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	animation: cube-glow var(--highlight-duration, 6.5s) 1s ease forwards;
	opacity: 0;
	transform-style: preserve-3d;
}

/* 其他样式会在需要时添加 */